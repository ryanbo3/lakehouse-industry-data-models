# --- Attribute Properties ---
ind:adInventoryId rdf:type rdf:Property ;
    rdfs:label 'Ad Inventory Id' ;
    rdfs:comment 'Unique identifier for the advertising inventory record. Primary key.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Reference to the broadcast or streaming channel where this inventory is available.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:demographicSegmentId rdf:type rdf:Property ;
    rdfs:label 'Demographic Segment Id' ;
    rdfs:comment 'Foreign key linking to audience.demographic_segment. Business justification: Inventory is forecasted, priced, and sold by Nielsen demographic segment for yield optimization and avails management. CPM/CPRP rates and GRP/TRP estimates vary by demographic. Essential for inventory' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemographicSegment .

ind:licenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'License Agreement Id' ;
    rdfs:comment 'Foreign key linking to rights.license_agreement. Business justification: Inventory forecasting depends on content rights availability. Sales planning tools must filter inventory by active license windows. Prevents overselling inventory in content with upcoming rights expir' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:partnerId rdf:type rdf:Property ;
    rdfs:label 'Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Inventory sourced from syndication partners, affiliate stations, or content distribution partners must track the supplying partner for revenue sharing calculations and inventory reconciliation. Real b' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:programTitleId rdf:type rdf:Property ;
    rdfs:label 'Program Title Id' ;
    rdfs:comment 'Reference to the specific program or content during which this ad inventory is available.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:schedulingDaypartId rdf:type rdf:Property ;
    rdfs:label 'Scheduling Daypart Id' ;
    rdfs:comment 'Foreign key linking to scheduling.daypart. Business justification: Inventory is bucketed by daypart for pricing and availability management. Rate card application, proposal generation, and avail queries require linking inventory to master daypart definitions. Removes' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Daypart .

ind:titleId rdf:type rdf:Property ;
    rdfs:label 'Title Id' ;
    rdfs:comment 'Foreign key linking to content.title. Business justification: Inventory is generated from title airings. Business process: inventory forecasting by title, avails management, sell-through reporting, title-level CPM pricing, program-based inventory allocation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:adPodPosition rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Position' ;
    rdfs:comment 'The sequential position of this inventory slot within an ad pod (group of ads in a break). Position 1 is the first ad in the break.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advertiserRestrictions rdf:type rdf:Property ;
    rdfs:label 'Advertiser Restrictions' ;
    rdfs:comment 'Comma-separated list of advertiser categories or specific advertisers that are restricted from purchasing this inventory due to content, competitive, or regulatory reasons.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutMarkets rdf:type rdf:Property ;
    rdfs:label 'Blackout Markets' ;
    rdfs:comment 'Comma-separated list of designated market areas (DMA) or geographic regions where this inventory cannot be sold due to blackout restrictions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutRestriction rdf:type rdf:Property ;
    rdfs:label 'Blackout Restriction' ;
    rdfs:comment 'Indicates whether this inventory is subject to geographic broadcast restrictions (blackout) that prevent advertising in certain markets or regions.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentRating rdf:type rdf:Property ;
    rdfs:label 'Content Rating' ;
    rdfs:comment 'The television content rating for the program associated with this inventory, which may restrict certain advertiser categories.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The timestamp when this inventory record was first created in the system.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date from which this inventory record and its pricing become effective for sales purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedGrp rdf:type rdf:Property ;
    rdfs:label 'Estimated Grp' ;
    rdfs:comment 'The estimated gross rating point (GRP) delivery for this inventory, representing the total audience reach multiplied by frequency. GRP is a standard broadcast audience measurement metric.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedImpressions rdf:type rdf:Property ;
    rdfs:label 'Estimated Impressions' ;
    rdfs:comment 'The projected number of advertising impressions (individual ad views) this inventory will deliver, based on historical audience data.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedReach rdf:type rdf:Property ;
    rdfs:label 'Estimated Reach' ;
    rdfs:comment 'The projected unique audience count (reach) that will be exposed to advertising in this inventory slot at least once.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedTrp rdf:type rdf:Property ;
    rdfs:label 'Estimated Trp' ;
    rdfs:comment 'The estimated target rating point (TRP) delivery for this inventory, representing the rating within a specific demographic target audience. TRP is used for targeted advertising campaigns.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date after which this inventory record is no longer valid or available for sale.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:heldUnits rdf:type rdf:Property ;
    rdfs:label 'Held Units' ;
    rdfs:comment 'The number of advertising units currently held or reserved pending final commitment, typically during proposal negotiation.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hutIndex rdf:type rdf:Property ;
    rdfs:label 'Hut Index' ;
    rdfs:comment 'The percentage of homes using television during this inventory time period. HUT is a standard broadcast audience availability metric.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryCode rdf:type rdf:Property ;
    rdfs:label 'Inventory Code' ;
    rdfs:comment 'Unique business identifier for this inventory slot, used in sales proposals and trafficking systems.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryDate rdf:type rdf:Property ;
    rdfs:label 'Inventory Date' ;
    rdfs:comment 'The specific broadcast date for which this inventory is available.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryEndTime rdf:type rdf:Property ;
    rdfs:label 'Inventory End Time' ;
    rdfs:comment 'The precise end time of the inventory window, including time zone information.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryStartTime rdf:type rdf:Property ;
    rdfs:label 'Inventory Start Time' ;
    rdfs:comment 'The precise start time of the inventory window, including time zone information.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current lifecycle status of the advertising inventory: available for sale, held pending commitment, sold and committed, preempted for higher-priority content, or blocked due to restrictions.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryType rdf:type rdf:Property ;
    rdfs:label 'Inventory Type' ;
    rdfs:comment 'Classification of the advertising inventory format: linear broadcast spot, video-on-demand (VOD) ad position, dynamic ad insertion (DAI) slot, free ad-supported streaming television (FAST) pod, or over-the-top (OTT) impression.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The timestamp when this inventory record was last updated or modified.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:makegoodEligible rdf:type rdf:Property ;
    rdfs:label 'Makegood Eligible' ;
    rdfs:comment 'Indicates whether this inventory is eligible to be used for makegoods (compensatory ad spots provided when original spots did not air as scheduled).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-form text field for additional notes, special instructions, or contextual information about this inventory record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preemptible rdf:type rdf:Property ;
    rdfs:label 'Preemptible' ;
    rdfs:comment 'Indicates whether this inventory can be preempted (bumped) for higher-priority programming or advertising. Preemptible inventory is typically sold at lower rates.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'The pricing tier classification for this inventory based on audience quality and demand: premium (highest value), standard, value, or remnant (lowest value, unsold inventory).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putIndex rdf:type rdf:Property ;
    rdfs:label 'Put Index' ;
    rdfs:comment 'The percentage of persons using television during this inventory time period. PUT is a standard broadcast audience availability metric.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCardCpm rdf:type rdf:Property ;
    rdfs:label 'Rate Card Cpm' ;
    rdfs:comment 'The published rate card cost per thousand impressions (CPM) for this inventory. CPM is the standard pricing metric in advertising sales.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCardCprp rdf:type rdf:Property ;
    rdfs:label 'Rate Card Cprp' ;
    rdfs:comment 'The published rate card cost per rating point (CPRP) for this inventory. CPRP is used in broadcast television pricing based on audience ratings.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingAvails rdf:type rdf:Property ;
    rdfs:label 'Remaining Avails' ;
    rdfs:comment 'The number of advertising units still available for sale, calculated as total available minus sold and held units.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesCategory rdf:type rdf:Property ;
    rdfs:label 'Sales Category' ;
    rdfs:comment 'The sales market category for this inventory: upfront (advance sales event), scatter (last-minute sales), local, national, digital, or programmatic.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soldUnits rdf:type rdf:Property ;
    rdfs:label 'Sold Units' ;
    rdfs:comment 'The number of advertising units that have been sold and committed to advertisers.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAvailableUnits rdf:type rdf:Property ;
    rdfs:label 'Total Available Units' ;
    rdfs:comment 'The total number of advertising units (spots or impressions) available for sale in this inventory record.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Unit Duration Seconds' ;
    rdfs:comment 'The standard duration in seconds for each advertising unit in this inventory (e.g., 15, 30, 60 seconds).' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adOrderId rdf:type rdf:Property ;
    rdfs:label 'Ad Order Id' ;
    rdfs:comment 'Unique identifier for the advertising sales order. Primary key. System-generated surrogate key for the ad order record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdOrder .

ind:advertiserId rdf:type rdf:Property ;
    rdfs:label 'Advertiser Id' ;
    rdfs:comment 'Reference to the advertiser (brand or company) placing the advertising order. Links to advertiser master record in Salesforce Media Cloud.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Advertiser .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to advertising.campaign. Business justification: Normalize campaign reference from STRING name to proper FK. Ad order should be linked to campaign master record for rollup reporting and campaign management. Currently denormalized as campaign_name ST' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Ad orders are sold by sales teams organized into cost centers. Commission calculation, sales performance analysis, and cost center P&L attribution require linking orders to the responsible cost center' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:primaryAdEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ad Employee Id' ;
    rdfs:comment 'Reference to the sales representative responsible for this advertising order. Links to employee/user master record.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Ad orders contribute to profit center performance. Segment EBITDA reporting and business unit P&L require linking orders to profit centers for accurate segment performance measurement and management r' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:revenueStreamId rdf:type rdf:Property ;
    rdfs:label 'Revenue Stream Id' ;
    rdfs:comment 'Foreign key linking to finance.revenue_stream. Business justification: Ad orders generate revenue that must be classified for ASC 606 revenue recognition and EBITDA reporting. Monthly close process requires linking orders to revenue stream classification for proper finan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueStream .

ind:salesAgencyId rdf:type rdf:Property ;
    rdfs:label 'Sales Agency Id' ;
    rdfs:comment 'Reference to the advertising agency representing the advertiser. Nullable if direct advertiser purchase. Links to agency master record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesAgency .

ind:salesforceOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Id' ;
    rdfs:comment 'External reference to the originating sales opportunity in Salesforce Media Cloud CRM. 15 or 18 character Salesforce record ID.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:subscriberId rdf:type rdf:Property ;
    rdfs:label 'Subscriber Id' ;
    rdfs:comment 'Foreign key linking to subscriber.subscriber. Business justification: Direct-sold addressable TV ad orders target specific subscribers for personalized advertising. Critical for programmatic guaranteed deals and advanced advertising attribution in streaming platforms. E' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:talentProfileId rdf:type rdf:Property ;
    rdfs:label 'Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: Talent endorsement deals and spokesperson campaigns require linking ad orders to specific talent for usage rights tracking, exclusivity clause enforcement, and residual payment obligations when spots ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:affidavitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Affidavit Required Flag' ;
    rdfs:comment 'Indicates whether proof of broadcast affidavits must be provided to the advertiser. True = affidavits required; False = not required. Affidavits document actual air times and are often required for political advertising.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency and timing of invoice generation for this order. Weekly = invoiced every week; Monthly = invoiced monthly; End of Flight = single invoice after campaign completion; Milestone = invoiced at defined campaign milestones.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Agency commission rate as a percentage of gross order value. Standard industry rate is 15%. Applied to calculate net revenue.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the advertising order was confirmed by the advertiser or agency. Marks transition from pending to confirmed status.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contractedCpm rdf:type rdf:Property ;
    rdfs:label 'Contracted Cpm' ;
    rdfs:comment 'Contracted Cost Per Mille (cost per thousand impressions) for this advertising order. Key pricing metric for media buying.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedCprp rdf:type rdf:Property ;
    rdfs:label 'Contracted Cprp' ;
    rdfs:comment 'Contracted Cost Per Rating Point. Pricing metric calculated as total cost divided by GRP. Used for market efficiency comparison.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all monetary amounts in this order (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartMix rdf:type rdf:Property ;
    rdfs:label 'Daypart Mix' ;
    rdfs:comment 'Distribution of advertising spots across broadcast dayparts (time segments of broadcast day). Examples: Prime (8pm-11pm), Early Morning (6am-9am), Late Night (11pm-2am). Stored as comma-separated daypart allocations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Total discount percentage applied to this order. May include volume discounts, promotional discounts, or negotiated rate reductions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flightEndDate rdf:type rdf:Property ;
    rdfs:label 'Flight End Date' ;
    rdfs:comment 'Last date the advertising campaign is scheduled to air. End of the contracted broadcast period.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flightStartDate rdf:type rdf:Property ;
    rdfs:label 'Flight Start Date' ;
    rdfs:comment 'First date the advertising campaign is scheduled to air. Beginning of the contracted broadcast period.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makegoodPolicy rdf:type rdf:Property ;
    rdfs:label 'Makegood Policy' ;
    rdfs:comment 'Policy for providing compensatory ad spots (makegoods) if contracted delivery is not met. Standard = industry-standard makegood terms; Guaranteed = full delivery guarantee; No Makegood = no compensation; Custom = special negotiated terms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'Designated Market Area (DMA) or geographic market code where the advertising will air. Used for Nielsen ratings alignment and regional pricing.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Net revenue value after agency commissions, discounts, and adjustments. Amount recognized for revenue reporting.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text notes and special instructions for this advertising order. May include trafficking instructions, creative specifications, or client preferences.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business identifier for the advertising order. Externally-known unique order number used in Wide Orbit traffic system and client communications. Also called broadcast order number or traffic order number.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the advertising order. Draft = initial entry; Pending = awaiting approval; Confirmed = accepted by advertiser; Active = currently running; Completed = flight finished; Cancelled = terminated; Invoiced = billed. [ENUM-REF-CANDIDATE: draft|pending|confirmed|active|completed|cancelled|invoiced — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the advertising order based on sales method. Upfront = advance advertising sales event; Scatter = last-minute ad inventory sales; Direct = direct advertiser purchase; Programmatic = automated bidding; Sponsorship = integrated brand partnership; Barter = trade arrangement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Contractual payment terms for this order (e.g., Net 30, Net 60, Due on Receipt). Defines when payment is due after invoice date.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:politicalAdFlag rdf:type rdf:Property ;
    rdfs:label 'Political Ad Flag' ;
    rdfs:comment 'Indicates whether this order contains political advertising content. True = political advertising; False = commercial advertising. Political ads have special FCC disclosure and equal-time requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'Industry classification of the advertised product or service (e.g., automotive, pharmaceutical, retail, financial services). Used for content clearance and regulatory compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDemographic rdf:type rdf:Property ;
    rdfs:label 'Target Demographic' ;
    rdfs:comment 'Primary audience demographic segment targeted by this advertising order (e.g., Adults 18-49, Women 25-54, Men 18-34). Used for TRP calculation and spot placement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGrp rdf:type rdf:Property ;
    rdfs:label 'Target Grp' ;
    rdfs:comment 'Target Gross Rating Points contracted for this order. GRP = Reach × Frequency, measuring total audience delivery weight. Used for campaign performance evaluation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTrp rdf:type rdf:Property ;
    rdfs:label 'Target Trp' ;
    rdfs:comment 'Target Rating Points for specific demographic audience. TRP measures delivery against a defined target audience segment rather than total audience.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalContractedValue rdf:type rdf:Property ;
    rdfs:label 'Total Contracted Value' ;
    rdfs:comment 'Total monetary value of the advertising order across all spots and placements. Gross revenue before agency commissions and discounts.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSpotCount rdf:type rdf:Property ;
    rdfs:label 'Total Spot Count' ;
    rdfs:comment 'Total number of advertising spots (commercial airings) contracted in this order across all placements and dayparts.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wideOrbitOrderReference rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Order Reference' ;
    rdfs:comment 'External reference to the corresponding order record in Wide Orbit traffic and billing system. Used for cross-system reconciliation and affidavit generation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Ad Order Line Id' ;
    rdfs:comment 'Unique identifier for the advertising order line item. Primary key.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sales .

ind:isciCreativeId rdf:type rdf:Property ;
    rdfs:label 'Isci Creative Id' ;
    rdfs:comment 'Foreign key linking to advertising.isci_creative. Business justification: Normalize creative reference from STRING business key to proper FK. Order line specifies which creative asset to use for the buy. Currently denormalized as isci_code STRING; should FK to isci_creative' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IsciCreative .

ind:makegoodForLineId rdf:type rdf:Property ;
    rdfs:label 'Makegood For Line Id' ;
    rdfs:comment 'Reference to the original ad order line that this line is compensating for (if this is a makegood spot). Null if not a makegood.' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdOrderLine .

ind:actualGrpDelivered rdf:type rdf:Property ;
    rdfs:label 'Actual Grp Delivered' ;
    rdfs:comment 'Actual Gross Rating Points (GRP) delivered based on Nielsen measurement. Used for campaign performance analysis and makegood calculation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualImpressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Actual Impressions Delivered' ;
    rdfs:comment 'Actual number of impressions delivered for this line. Sourced from DAI (Dynamic Ad Insertion) systems or CDN (Content Delivery Network) logs for digital campaigns.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSpotsAired rdf:type rdf:Property ;
    rdfs:label 'Actual Spots Aired' ;
    rdfs:comment 'Actual number of spots that successfully aired for this line. Populated from affidavit reconciliation. Used for billing and makegood determination.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitiveSeparationCategory rdf:type rdf:Property ;
    rdfs:label 'Competitive Separation Category' ;
    rdfs:comment 'Product or industry category for competitive adjacency restrictions. Prevents competing advertisers from airing in the same pod.' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedGrp rdf:type rdf:Property ;
    rdfs:label 'Contracted Grp' ;
    rdfs:comment 'Target Gross Rating Points (GRP) contracted for this line. GRP measures total audience reach multiplied by frequency.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedImpressions rdf:type rdf:Property ;
    rdfs:label 'Contracted Impressions' ;
    rdfs:comment 'Total number of impressions (individual ad views) contracted for this line item. Used for digital and OTT (Over-The-Top) campaigns.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedSpots rdf:type rdf:Property ;
    rdfs:label 'Contracted Spots' ;
    rdfs:comment 'Total number of ad spots contracted for this line item. Represents the quantity commitment.' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedTrp rdf:type rdf:Property ;
    rdfs:label 'Contracted Trp' ;
    rdfs:comment 'Target Rating Points (TRP) contracted for this line. TRP measures reach within a specific demographic target.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copySplitRule rdf:type rdf:Property ;
    rdfs:label 'Copy Split Rule' ;
    rdfs:comment 'Rules defining how multiple creative versions should be split across the contracted spots (e.g., 50/50, 70/30). Used for A/B testing or creative variation.' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpm rdf:type rdf:Property ;
    rdfs:label 'Cpm' ;
    rdfs:comment 'Cost Per Mille (CPM) - the cost per thousand impressions. Key pricing metric for advertising efficiency.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cprp rdf:type rdf:Property ;
    rdfs:label 'Cprp' ;
    rdfs:comment 'Cost Per Rating Point (CPRP) - the cost to achieve one rating point. Used to compare efficiency across dayparts and programs.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the parent ad order. Determines ordering and display sequence of line items.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle status of the ad order line. Tracks progression from booking through execution and reconciliation. [ENUM-REF-CANDIDATE: booked|confirmed|scheduled|aired|preempted|makegooded|cancelled|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Total revenue amount for this line item (unit rate × contracted spots). Base amount before discounts or adjustments.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net revenue amount after discounts and before taxes. Used for revenue recognition and financial reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionPreference rdf:type rdf:Property ;
    rdfs:label 'Position Preference' ;
    rdfs:comment 'Preferred position within the ad pod (group of ads in a break). Premium positions command higher rates.' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preemptionPriority rdf:type rdf:Property ;
    rdfs:label 'Preemption Priority' ;
    rdfs:comment 'Priority level for preemption protection (1=highest, 10=lowest). Lower-priority spots may be bumped for higher-value inventory.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue for this line is recognized for financial reporting. Typically aligned with air date or campaign completion.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rotationInstructions rdf:type rdf:Property ;
    rdfs:label 'Rotation Instructions' ;
    rdfs:comment 'Instructions for rotating multiple creatives within this line (e.g., even rotation, weighted rotation, sequential). Guides playout system behavior.' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingNotes rdf:type rdf:Property ;
    rdfs:label 'Special Handling Notes' ;
    rdfs:comment 'Free-text instructions for special handling requirements (e.g., live read, sponsorship billboard, product integration). Communicated to playout operators.' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Spot Length Seconds' ;
    rdfs:comment 'Duration of the advertising spot in seconds. Standard lengths are 15, 30, 60, or 120 seconds.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:traffickingNotes rdf:type rdf:Property ;
    rdfs:label 'Trafficking Notes' ;
    rdfs:comment 'Internal notes for trafficking team regarding execution details, creative delivery status, or special coordination requirements.' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'Price per individual ad spot or unit. Base rate before volume discounts or adjustments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adPodId rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Id' ;
    rdfs:comment 'Unique identifier for the advertising pod. Primary key.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdPod .

ind:closedCaptionRecordId rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Record Id' ;
    rdfs:comment 'Foreign key linking to compliance.closed_caption_record. Business justification: Ad pods within programming require caption compliance verification for FCC accessibility obligations. Broadcasters track caption delivery, accuracy scores, and exemption status at the pod level to ens' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClosedCaptionRecord .

ind:scheduleId rdf:type rdf:Property ;
    rdfs:label 'Schedule Id' ;
    rdfs:comment 'Reference to the program schedule entry that contains this ad pod.' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramSchedule .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual date and time when the ad pod concluded airing, used for billing reconciliation and performance verification.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Actual date and time when the ad pod began airing, captured from playout automation for affidavit generation and makegood processing.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alcoholAdAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Alcohol Ad Allowed Flag' ;
    rdfs:comment 'Indicates whether alcohol advertising is permitted within this ad pod, based on daypart restrictions and content adjacency policies.' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audienceTargetDemo rdf:type rdf:Property ;
    rdfs:label 'Audience Target Demo' ;
    rdfs:comment 'Primary demographic audience segment targeted by this ad pod, typically expressed in age-gender format (e.g., A18-49, W25-54, M18-34) per Nielsen measurement standards.' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutFlag rdf:type rdf:Property ;
    rdfs:label 'Blackout Flag' ;
    rdfs:comment 'Indicates whether this ad pod is subject to geographic broadcast restrictions or blackout rules, preventing distribution in certain markets.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakPosition rdf:type rdf:Property ;
    rdfs:label 'Break Position' ;
    rdfs:comment 'Position of the ad break within the program content flow. Pre-roll occurs before content starts, mid-roll during content, post-roll after content ends, interstitial between segments, bumper as short transition, and outro at program conclusion.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daiEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Dai Enabled Flag' ;
    rdfs:comment 'Indicates whether this ad pod supports Dynamic Ad Insertion for personalized, server-side ad stitching in streaming environments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daypart rdf:type rdf:Property ;
    rdfs:label 'Daypart' ;
    rdfs:comment 'Time segment of the broadcast day during which this ad pod airs, used for audience targeting and pricing. Early morning (6-9 AM), daytime (9 AM-4 PM), early fringe (4-6 PM), prime access (6-8 PM), prime time (8-11 PM), late fringe (11 PM-midnight), late night (midnight-2 AM), overnight (2-6 AM). [ENUM-REF-CANDIDATE: early_morning|daytime|early_fringe|prime_access|prime_time|late_fringe|late_night|overnight — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicMarketCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Market Code' ;
    rdfs:comment 'Nielsen Designated Market Area (DMA) code or equivalent geographic market identifier where this ad pod airs, used for regional targeting and blackout enforcement.' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryClass rdf:type rdf:Property ;
    rdfs:label 'Inventory Class' ;
    rdfs:comment 'Classification of the ad pod inventory by pricing tier and sales priority. Premium for high-demand slots, standard for regular inventory, remnant for unsold last-minute inventory, bonus for value-added makegoods.' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSpotCount rdf:type rdf:Property ;
    rdfs:label 'Max Spot Count' ;
    rdfs:comment 'Maximum number of individual ad spots that can be scheduled within this pod, governing inventory capacity.' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'Distribution platform type for this ad pod. Linear for traditional scheduled broadcast, VOD (Video On Demand) for on-demand viewing, SVOD (Subscription Video On Demand) for subscription services, AVOD (Advertising-Supported Video On Demand) for ad-supported streaming, TVOD (Transactional Video On Demand) for pay-per-view, OTT (Over-The-Top) for internet delivery, FAST (Free Ad-Supported Streaming Television) for linear streaming channels. [ENUM-REF-CANDIDATE: linear|vod|svod|avod|tvod|ott|fast — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podCode rdf:type rdf:Property ;
    rdfs:label 'Pod Code' ;
    rdfs:comment 'Unique business identifier or code for the ad pod used in trafficking and billing systems.' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Pod Duration Seconds' ;
    rdfs:comment 'Total duration of the ad pod in seconds, representing the maximum time allocated for all ad spots within this break.' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:podName rdf:type rdf:Property ;
    rdfs:label 'Pod Name' ;
    rdfs:comment 'Human-readable name or label for the ad pod, often used for internal identification and trafficking purposes.' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podRateCardCpm rdf:type rdf:Property ;
    rdfs:label 'Pod Rate Card Cpm' ;
    rdfs:comment 'Standard rate card Cost Per Mille (cost per thousand impressions) for this ad pod, used as the baseline pricing for inventory sales negotiations.' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podStatus rdf:type rdf:Property ;
    rdfs:label 'Pod Status' ;
    rdfs:comment 'Current lifecycle status of the ad pod. Scheduled indicates planned but not locked, confirmed indicates inventory committed, aired indicates successfully broadcast, preempted indicates replaced by higher-priority content, cancelled indicates removed from schedule, makegoods_required indicates compensatory spots needed due to delivery issues.' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podType rdf:type rdf:Property ;
    rdfs:label 'Pod Type' ;
    rdfs:comment 'Classification of the ad pod by content purpose. Commercial for paid advertising, promotional for network self-promotion, PSA (Public Service Announcement) for non-profit messaging, network for national inventory, affiliate for station-level inventory, local for regional inventory.' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:politicalAdAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Political Ad Allowed Flag' ;
    rdfs:comment 'Indicates whether political advertising is permitted within this ad pod, subject to FCC equal time and disclosure requirements.' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesMarket rdf:type rdf:Property ;
    rdfs:label 'Sales Market' ;
    rdfs:comment 'Market channel through which the ad pod inventory was sold. Upfront for advance commitment sales, scatter for last-minute inventory sales, programmatic for automated bidding platforms, direct for one-on-one advertiser deals.' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Planned date and time when the ad pod is scheduled to conclude, calculated from start time plus pod duration.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Planned date and time when the ad pod is scheduled to begin airing, in ISO 8601 format with timezone.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scte35CuePointReference rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue Point Reference' ;
    rdfs:comment 'Reference identifier for the SCTE-35 (Society of Cable Telecommunications Engineers) cue point that triggers this ad pod insertion in the broadcast stream.' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adSpotId rdf:type rdf:Property ;
    rdfs:label 'Ad Spot Id' ;
    rdfs:comment 'Unique identifier for the individual advertisement spot placement. Primary key for the ad spot entity.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdSpot .

ind:abrProfileId rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Id' ;
    rdfs:comment 'Foreign key linking to distribution.abr_profile. Business justification: ABR profile determines video quality for ad creative delivery. Broadcasters track which profile was used per spot to verify creative rendering quality, troubleshoot playback issues, and optimize ad en' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbrProfile .

ind:deviceTypeId rdf:type rdf:Property ;
    rdfs:label 'Device Type Id' ;
    rdfs:comment 'Foreign key linking to distribution.device_type. Business justification: Ad delivery systems track device type per spot to verify creative compatibility (resolution, codec, DRM), measure device-specific performance, and support device-targeted campaigns. Critical for devic' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceType .

ind:originalSpotAdSpotId rdf:type rdf:Property ;
    rdfs:label 'Original Spot Ad Spot Id' ;
    rdfs:comment 'Reference to the original ad spot that this makegood spot is compensating for. Populated only when makegood_flag is true.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdSpot .

ind:revenueRecognitionEventId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Event Id' ;
    rdfs:comment 'Foreign key linking to finance.revenue_recognition_event. Business justification: Each aired spot triggers revenue recognition under ASC 606. Daily revenue recognition close and billing reconciliation require linking spots to recognition events for accurate revenue accounting and a' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognitionEvent .

ind:scheduleSlotId rdf:type rdf:Property ;
    rdfs:label 'Schedule Slot Id' ;
    rdfs:comment 'Foreign key linking to scheduling.schedule_slot. Business justification: Spots air within specific schedule slots. Affidavit generation, as-run reconciliation, and delivery verification require linking each spot to the exact slot it occupied. No existing column fits; creat' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleSlot .

ind:streamingEndpointId rdf:type rdf:Property ;
    rdfs:label 'Streaming Endpoint Id' ;
    rdfs:comment 'Foreign key linking to distribution.streaming_endpoint. Business justification: Ad spots in OTT/FAST environments are delivered through specific streaming endpoints. Broadcasters track endpoint-per-spot for delivery verification, QoS monitoring, CDN cost allocation, and billing r' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StreamingEndpoint .

ind:actualAirTime rdf:type rdf:Property ;
    rdfs:label 'Actual Air Time' ;
    rdfs:comment 'The actual date and time when this ad spot aired, as recorded in the broadcast affidavit. Used for proof of performance and billing reconciliation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affidavitReference rdf:type rdf:Property ;
    rdfs:label 'Affidavit Reference' ;
    rdfs:comment 'Reference to the broadcast affidavit (proof of performance document) that certifies this spot aired as scheduled. Required for billing and advertiser verification.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current billing status of this spot. Tracks the spot through the billing lifecycle from unbilled through payment or dispute resolution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusSpotFlag rdf:type rdf:Property ;
    rdfs:label 'Bonus Spot Flag' ;
    rdfs:comment 'Indicates whether this spot was provided as a bonus (added value) to the advertiser at no additional charge. Used for revenue recognition and campaign value calculation.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Code identifying the broadcast channel or network where the spot aired (e.g., ABC, NBC, ESPN). Links to channel master data.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpmAmount rdf:type rdf:Property ;
    rdfs:label 'Cpm Amount' ;
    rdfs:comment 'Cost per thousand impressions for this spot. Key pricing metric in advertising sales used to compare efficiency across different placements.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daiFlag rdf:type rdf:Property ;
    rdfs:label 'Dai Flag' ;
    rdfs:comment 'Indicates whether this spot was delivered via Dynamic Ad Insertion technology, allowing personalized ad delivery to different viewers or platforms.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryPlatform rdf:type rdf:Property ;
    rdfs:label 'Delivery Platform' ;
    rdfs:comment 'Platform through which the ad spot was delivered. Distinguishes between linear broadcast, OTT (Over-The-Top), VOD (Video On Demand), SVOD (Subscription VOD), AVOD (Ad-Supported VOD), TVOD (Transactional VOD), FAST (Free Ad-Supported Streaming TV), and simulcast delivery. [ENUM-REF-CANDIDATE: linear|ott|vod|svod|avod|tvod|fast|simulcast — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpValue rdf:type rdf:Property ;
    rdfs:label 'Grp Value' ;
    rdfs:comment 'Gross Rating Point value delivered by this spot. Measures the size of the audience reached relative to the total market population. Sum of all rating points across the campaign.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Impressions Delivered' ;
    rdfs:comment 'Total number of impressions (views) delivered by this spot. Used for performance measurement and billing reconciliation.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:makegoodFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Flag' ;
    rdfs:comment 'Indicates whether this spot is a makegood (compensatory ad spot provided to an advertiser due to a previous preemption or underdelivery).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Date and time when this ad spot record was last modified. Tracks changes to scheduling, status, or other attributes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preemptedFlag rdf:type rdf:Property ;
    rdfs:label 'Preempted Flag' ;
    rdfs:comment 'Indicates whether this spot was preempted (bumped from its scheduled time slot). Preempted spots typically require makegood compensation.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preemptionReason rdf:type rdf:Property ;
    rdfs:label 'Preemption Reason' ;
    rdfs:comment 'Explanation for why the spot was preempted, if applicable. Common reasons include breaking news, technical issues, programming overrun, or higher-priority advertiser.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationPattern rdf:type rdf:Property ;
    rdfs:label 'Rotation Pattern' ;
    rdfs:comment 'Describes the rotation or sequencing pattern for this spot within the campaign (e.g., ROS - Run of Schedule, fixed position, alternating). Used for inventory management and fulfillment.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledAirDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Air Date' ;
    rdfs:comment 'The date on which this ad spot was scheduled to air. Used for planning and inventory management.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledAirTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Air Time' ;
    rdfs:comment 'The precise date and time when this ad spot was scheduled to air. Includes timezone information for accurate cross-platform scheduling.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:separationRequirement rdf:type rdf:Property ;
    rdfs:label 'Separation Requirement' ;
    rdfs:comment 'Specifies any separation rules for this spot (e.g., competitive separation, minimum time between airings). Ensures advertiser requirements are met.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotRateAmount rdf:type rdf:Property ;
    rdfs:label 'Spot Rate Amount' ;
    rdfs:comment 'The rate charged for this individual spot placement. May differ from the order line rate due to daypart, program, or inventory adjustments.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spotRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Spot Rate Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the spot rate amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotStatus rdf:type rdf:Property ;
    rdfs:label 'Spot Status' ;
    rdfs:comment 'Current lifecycle status of the ad spot. Tracks whether the spot was scheduled, successfully aired, preempted, cancelled, or requires makegood processing.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficLogReference rdf:type rdf:Property ;
    rdfs:label 'Traffic Log Reference' ;
    rdfs:comment 'Reference identifier to the Wide Orbit traffic log entry that scheduled and tracked this spot. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trpValue rdf:type rdf:Property ;
    rdfs:label 'Trp Value' ;
    rdfs:comment 'Target Rating Point value delivered by this spot. Measures audience reach within a specific demographic target segment, more precise than GRP.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advertiserCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Advertiser Created By User Employee Id' ;
    rdfs:comment 'The user identifier of the person who created this advertiser record.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advertiserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Advertiser Employee Id' ;
    rdfs:comment 'The identifier of the internal sales account manager or account executive assigned to manage this advertiser relationship.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advertiserUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Advertiser Updated By User Employee Id' ;
    rdfs:comment 'The user identifier of the person who last modified this advertiser record.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:salesAccountId rdf:type rdf:Property ;
    rdfs:label 'Sales Account Id' ;
    rdfs:comment 'The Salesforce Media Cloud account reference linking this advertiser to CRM opportunities, campaigns, and proposals.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesAccount .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the advertiser account indicating whether the advertiser is actively purchasing inventory.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualSpendTier rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Tier' ;
    rdfs:comment 'The classification tier based on annual advertising spend volume, used for pricing, service level, and upfront negotiation priority.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'The primary street address line for billing and invoice delivery.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'The secondary address line for suite, floor, or building information.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'The city or municipality for the billing address.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'The three-letter ISO country code for the billing address (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'The postal or ZIP code for the billing address.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'The state, province, or region for the billing address.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'The expiration date of the current master advertising services agreement or upfront deal, if applicable.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'The effective start date of the current master advertising services agreement or upfront deal.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'The maximum outstanding balance allowed for this advertiser before credit hold is applied, in USD.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'The credit approval status indicating whether the advertiser is authorized to purchase advertising on credit terms.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryCategory rdf:type rdf:Property ;
    rdfs:label 'Industry Category' ;
    rdfs:comment 'The Interactive Advertising Bureau (IAB) taxonomy category classifying the advertiser\'s primary business vertical (e.g., Automotive, Financial Services, Consumer Packaged Goods).' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPoliticalAdvertiser rdf:type rdf:Property ;
    rdfs:label 'Is Political Advertiser' ;
    rdfs:comment 'Boolean flag indicating whether this advertiser is a political candidate, party, or issue advocacy group subject to FCC political advertising disclosure requirements.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The full legal registered name of the advertising client or brand as it appears on contracts and invoices.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCompanyName rdf:type rdf:Property ;
    rdfs:label 'Parent Company Name' ;
    rdfs:comment 'The name of the parent or holding company if the advertiser is a subsidiary or brand within a larger corporate structure.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Code' ;
    rdfs:comment 'The three-letter ISO currency code for invoicing and financial reporting (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'The email address of the primary business contact for campaign communications and invoice delivery.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'The full name of the primary business contact at the advertiser organization for campaign coordination and billing inquiries.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'The business phone number of the primary contact for urgent campaign or billing matters.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAdClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Ad Clearance' ;
    rdfs:comment 'Boolean flag indicating whether this advertiser\'s creative content requires pre-broadcast clearance review due to industry category (e.g., pharmaceuticals, alcohol, financial services).' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'The advertiser\'s federal tax identification number (EIN in USA, VAT number in EU) used for tax reporting and invoicing.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'The doing-business-as (DBA) or brand name used in advertising campaigns and public-facing materials.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'The timestamp when this advertiser record was last modified.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'The primary website URL of the advertiser for brand reference and campaign landing page validation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitAdvertiserCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Advertiser Code' ;
    rdfs:comment 'The unique advertiser identifier in the Wide Orbit traffic and billing system, used for ad scheduling, sales orders, and invoicing.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advertisingAudienceGuaranteeId rdf:type rdf:Property ;
    rdfs:label 'Advertising Audience Guarantee Id' ;
    rdfs:comment 'Unique identifier for the audience delivery guarantee record.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upfrontDealId rdf:type rdf:Property ;
    rdfs:label 'Upfront Deal Id' ;
    rdfs:comment 'Reference to the upfront deal if this guarantee is part of an advance advertising sales commitment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UpfrontDeal .

ind:verifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Audience guarantee verification requires sign-off by revenue assurance analyst or audience measurement employee to confirm delivery metrics and trigger makegood/credit processes. Critical for revenue ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The monetary credit amount owed to the advertiser if makegoods are not provided for underdelivery.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredGrp rdf:type rdf:Property ;
    rdfs:label 'Delivered Grp' ;
    rdfs:comment 'The actual Gross Rating Point (GRP) delivered to date as measured by Nielsen or other audience measurement provider.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredImpressions rdf:type rdf:Property ;
    rdfs:label 'Delivered Impressions' ;
    rdfs:comment 'The actual number of impressions delivered to date as measured by the audience measurement system.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveredTrp rdf:type rdf:Property ;
    rdfs:label 'Delivered Trp' ;
    rdfs:comment 'The actual Target Rating Point (TRP) delivered to date for the specified demographic segment.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryPercentage rdf:type rdf:Property ;
    rdfs:label 'Delivery Percentage' ;
    rdfs:comment 'The percentage of the contracted guarantee that has been delivered, calculated as (delivered / contracted) * 100.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryVarianceGrp rdf:type rdf:Property ;
    rdfs:label 'Delivery Variance Grp' ;
    rdfs:comment 'The difference between contracted and delivered GRP, calculated as delivered minus contracted (negative indicates underdelivery).' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteeNumber rdf:type rdf:Property ;
    rdfs:label 'Guarantee Number' ;
    rdfs:comment 'Business identifier for the audience guarantee, used for tracking and reporting purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Guarantee Period End Date' ;
    rdfs:comment 'The end date of the period during which the audience guarantee applies.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Guarantee Period Start Date' ;
    rdfs:comment 'The start date of the period during which the audience guarantee applies.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteeStatus rdf:type rdf:Property ;
    rdfs:label 'Guarantee Status' ;
    rdfs:comment 'Current status of the audience guarantee: on_track (meeting targets), at_risk (trending toward underdelivery), underdelivered (below threshold), fulfilled (completed successfully), cancelled (guarantee voided).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMeasurementDate rdf:type rdf:Property ;
    rdfs:label 'Last Measurement Date' ;
    rdfs:comment 'The date of the most recent audience measurement update used to calculate delivery performance.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The date and time when this audience guarantee record was most recently updated.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:makegoodGrpOwed rdf:type rdf:Property ;
    rdfs:label 'Makegood Grp Owed' ;
    rdfs:comment 'The amount of GRP that must be delivered through makegood spots to fulfill the guarantee obligation.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Required Flag' ;
    rdfs:comment 'Indicates whether makegood spots are required due to underdelivery against the guarantee.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'The specific measurement methodology or panel used for audience tracking (e.g., Nielsen C3, C7, Live+Same Day).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'The audience measurement provider or system used to track delivery against the guarantee (e.g., Nielsen, Comscore).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkStationCode rdf:type rdf:Property ;
    rdfs:label 'Network Station Code' ;
    rdfs:comment 'The broadcast network or station identifier where the guaranteed audience delivery is measured.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextEvaluationDate rdf:type rdf:Property ;
    rdfs:label 'Next Evaluation Date' ;
    rdfs:comment 'The scheduled date for the next evaluation of guarantee delivery performance.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:underdeliveryThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Underdelivery Threshold Percentage' ;
    rdfs:comment 'The contractual threshold percentage below which underdelivery triggers makegood or credit obligations (e.g., 95% means delivery below 95% triggers makegoods).' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affidavitId rdf:type rdf:Property ;
    rdfs:label 'Affidavit Id' ;
    rdfs:comment 'Primary key for affidavit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Affidavit .

ind:adSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Ad Sales Order Id' ;
    rdfs:comment 'Reference to the sales order that authorized this ad spot placement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdSalesOrder .

ind:advertisingMakegoodId rdf:type rdf:Property ;
    rdfs:label 'Advertising Makegood Id' ;
    rdfs:comment 'Reference to the makegood order created to compensate for this discrepancy, if applicable.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Makegood .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Reference to the user who verified and approved this affidavit for billing purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Reference to the invoice on which this affidavit was included for billing purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:publicInspectionFileId rdf:type rdf:Property ;
    rdfs:label 'Public Inspection File Id' ;
    rdfs:comment 'Foreign key linking to compliance.public_inspection_file. Business justification: Political advertising affidavits must be maintained in the public inspection file per FCC rules. Broadcasters link affidavits to public file entries documenting actual air dates, times, and rates char' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PublicInspectionFile .

ind:actualAirDate rdf:type rdf:Property ;
    rdfs:label 'Actual Air Date' ;
    rdfs:comment 'The date the ad spot actually aired as confirmed by playout system logs.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSpotLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Actual Spot Length Seconds' ;
    rdfs:comment 'The actual duration in seconds that the ad spot aired as measured by playout system.' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affidavitNumber rdf:type rdf:Property ;
    rdfs:label 'Affidavit Number' ;
    rdfs:comment 'Business identifier for the affidavit document. Externally-known unique reference number used for billing finalization and compliance documentation.' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAmount rdf:type rdf:Property ;
    rdfs:label 'Billing Amount' ;
    rdfs:comment 'The amount billed for this ad spot as documented in this affidavit. Used for revenue recognition and reconciliation.' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether this affidavit meets all regulatory and contractual compliance requirements for FCC documentation and audit purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractedSpotLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Contracted Spot Length Seconds' ;
    rdfs:comment 'The duration in seconds that was contracted and paid for in the sales order.' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which the affidavit document was delivered to the advertiser or agency.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Date and time when the affidavit was delivered to the advertiser or agency.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discrepancyDescription rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Description' ;
    rdfs:comment 'Detailed explanation of the discrepancy, including root cause and impact. Used for makegood processing and client communication.' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicates whether there was any discrepancy between the contracted spot parameters and what actually aired. True if discrepancy exists, False if spot aired as contracted.' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Classification of the type of discrepancy if one occurred. None indicates spot aired exactly as contracted. [ENUM-REF-CANDIDATE: wrong_time|wrong_length|preempted|wrong_creative|wrong_channel|missed|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Generation Timestamp' ;
    rdfs:comment 'Date and time when this affidavit record was first generated by the traffic system. This is the record audit created timestamp.' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:playoutSystemLogReference rdf:type rdf:Property ;
    rdfs:label 'Playout System Log Reference' ;
    rdfs:comment 'Reference to the playout automation system log entry that provides technical proof of broadcast.' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Current status of the affidavit in the billing reconciliation workflow. Approved status enables invoice finalization.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify that the ad spot aired as documented in this affidavit.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Date and time when the affidavit was verified and approved for billing.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wideOrbitAffidavitReference rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Affidavit Reference' ;
    rdfs:comment 'External reference identifier from the Wide Orbit traffic and billing system for cross-system reconciliation.' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Date' ;
    rdfs:comment 'Date when the agency was granted accreditation status by the broadcaster or industry body.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiry Date' ;
    rdfs:comment 'Date when the current accreditation status expires and requires renewal. Nullable for indefinite accreditation.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Current accreditation status of the agency with industry bodies or the broadcaster, indicating creditworthiness and eligibility for commission-based billing.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the agency based on its primary service offering and operational model.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingModel rdf:type rdf:Property ;
    rdfs:label 'Billing Model' ;
    rdfs:comment 'Billing methodology used for this agency. Gross: agency bills advertiser full amount and remits net to broadcaster. Net: broadcaster bills agency net amount. Hybrid: mixed approach.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum credit amount (in base currency) extended to the agency for outstanding ad orders before payment is required. Used for credit risk management.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingCompanyGroup rdf:type rdf:Property ;
    rdfs:label 'Holding Company Group' ;
    rdfs:comment 'Name of the parent holding company or agency network to which this agency belongs (e.g., WPP, Omnicom, Publicis, IPG, Dentsu). Null if independent.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User identifier or system account that last modified this agency record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date when the agency was first onboarded and approved to place advertising orders with the broadcaster.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Standard number of days allowed for payment after invoice date (e.g., 30, 60, 90). Used for accounts receivable and cash flow forecasting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesAgencyName rdf:type rdf:Property ;
    rdfs:label 'Sales Agency Name' ;
    rdfs:comment 'Full legal or trade name of the advertising agency or media buying firm.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesAgencyStatus rdf:type rdf:Property ;
    rdfs:label 'Sales Agency Status' ;
    rdfs:comment 'Current operational status of the agency relationship. Active agencies can place orders; inactive/suspended/terminated agencies cannot.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusReason rdf:type rdf:Property ;
    rdfs:label 'Status Reason' ;
    rdfs:comment 'Explanation or business reason for the current status, particularly for inactive, suspended, or terminated statuses (e.g., credit issues, contract expiration, voluntary closure).' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date when the agency relationship was terminated or the agency ceased operations. Nullable for active agencies.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wideOrbitAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Agency Code' ;
    rdfs:comment 'Unique agency identifier code used in the Wide Orbit traffic and billing system for ad scheduling, sales orders, and invoicing.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User identifier or system account that created this agency record. Used for audit trail and data lineage.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Campaign Approved By User Employee Id' ;
    rdfs:comment 'Reference to the user who approved the campaign for activation.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:campaignEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Campaign Employee Id' ;
    rdfs:comment 'Reference to the sales account executive responsible for managing this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:coppaDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Coppa Declaration Id' ;
    rdfs:comment 'Foreign key linking to compliance.coppa_declaration. Business justification: Campaigns targeting children under 13 require COPPA declarations for data collection and privacy compliance. Broadcasters must link campaigns to declarations documenting parental consent mechanisms, d' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoppaDeclaration .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Timestamp when the campaign was approved and moved from draft or proposed status to active status.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'External business identifier or code for the campaign used in trafficking and billing systems.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Business name of the advertising campaign used for identification and reporting.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the advertising campaign. [ENUM-REF-CANDIDATE: draft|proposed|approved|active|paused|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign objective and strategy.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The date when the campaign is scheduled to end. Nullable for ongoing campaigns.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makegoodEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Eligible Flag' ;
    rdfs:comment 'Indicates whether this campaign is eligible for makegood compensatory ad spots if contracted delivery targets are not met.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketType rdf:type rdf:Property ;
    rdfs:label 'Market Type' ;
    rdfs:comment 'Geographic market scope classification for the campaign.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Priority classification for ad inventory allocation and scheduling conflicts.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productBrand rdf:type rdf:Property ;
    rdfs:label 'Product Brand' ;
    rdfs:comment 'The product, service, or brand being advertised in this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'The sales channel through which the campaign was sold (upfront advance sales, scatter last-minute, programmatic automated, direct negotiated, or sponsorship).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceCampaignReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Campaign Reference' ;
    rdfs:comment 'External reference identifier linking to the campaign record in Salesforce Media Cloud CRM system.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The date when the campaign is scheduled to begin airing or serving ads.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetCpm rdf:type rdf:Property ;
    rdfs:label 'Target Cpm' ;
    rdfs:comment 'Contracted target Cost Per Mille representing the cost per thousand impressions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCprp rdf:type rdf:Property ;
    rdfs:label 'Target Cprp' ;
    rdfs:comment 'Contracted target Cost Per Rating Point representing the cost to achieve one rating point.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetFrequency rdf:type rdf:Property ;
    rdfs:label 'Target Frequency' ;
    rdfs:comment 'Contracted average number of times each unique audience member should be exposed to the campaign.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetImpressions rdf:type rdf:Property ;
    rdfs:label 'Target Impressions' ;
    rdfs:comment 'Contracted total number of ad impressions to be delivered across the campaign.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetReachPercent rdf:type rdf:Property ;
    rdfs:label 'Target Reach Percent' ;
    rdfs:comment 'Contracted percentage of unique audience members to be reached by the campaign.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSovPercent rdf:type rdf:Property ;
    rdfs:label 'Target Sov Percent' ;
    rdfs:comment 'Contracted target Share of Voice representing the percentage of total advertising impressions in the category or daypart.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'The total contracted budget amount for the entire campaign across all flights and orders.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daiEventId rdf:type rdf:Property ;
    rdfs:label 'Dai Event Id' ;
    rdfs:comment 'Unique identifier for the dynamic ad insertion event record. Primary key.' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentAssetId rdf:type rdf:Property ;
    rdfs:label 'Content Asset Id' ;
    rdfs:comment 'Reference to the content asset (program, episode, or video) during which the ad was inserted.' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:mediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Dynamic ad insertion events must track which specific media asset file was served to the viewer for billing reconciliation, QC audits, and content delivery verification. Essential for programmatic ad ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:scteMarkerId rdf:type rdf:Property ;
    rdfs:label 'Scte Marker Id' ;
    rdfs:comment 'SCTE-35 cue point identifier that triggered the dynamic ad insertion opportunity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScteMarker .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Reference to the audience segment used for targeting this ad insertion. Represents the viewer demographic or behavioral profile.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:streamSessionId rdf:type rdf:Property ;
    rdfs:label 'Stream Session Id' ;
    rdfs:comment 'Unique identifier for the streaming session in which this ad insertion occurred. Links to the viewer\'s active playback session.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlaybackSession .

ind:adDecisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ad Decision Timestamp' ;
    rdfs:comment 'Precise timestamp when the DAI platform made the ad selection decision for this insertion opportunity.' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Ad Duration Seconds' ;
    rdfs:comment 'Duration of the inserted ad creative in seconds (e.g., 15, 30, 60 seconds).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adServerTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Ad Server Transaction Reference' ;
    rdfs:comment 'Transaction identifier from the upstream ad server (e.g., Wide Orbit, FreeWheel) that authorized this ad insertion.' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidPriceCpm rdf:type rdf:Property ;
    rdfs:label 'Bid Price Cpm' ;
    rdfs:comment 'Winning bid price in CPM (cost per thousand impressions) for this ad insertion in programmatic auction scenarios.' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdnNodeReference rdf:type rdf:Property ;
    rdfs:label 'Cdn Node Reference' ;
    rdfs:comment 'Identifier of the CDN edge node that delivered the ad content to the viewer. Used for delivery performance tracking.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickThroughUrl rdf:type rdf:Property ;
    rdfs:label 'Click Through Url' ;
    rdfs:comment 'Destination URL if the viewer clicked on the ad. Used for engagement tracking and attribution.' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Completion Rate Percent' ;
    rdfs:comment 'Percentage of the ad duration that was actually viewed by the user before skipping or abandoning (0.00 to 100.00).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daiPlatformName rdf:type rdf:Property ;
    rdfs:label 'Dai Platform Name' ;
    rdfs:comment 'Name of the DAI platform that executed this ad insertion (e.g., Google DAI, FreeWheel, Adobe Primetime).' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daiPlatformVersion rdf:type rdf:Property ;
    rdfs:label 'Dai Platform Version' ;
    rdfs:comment 'Version identifier of the DAI platform software used for this insertion event.' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmed Flag' ;
    rdfs:comment 'Boolean flag indicating whether the CDN confirmed successful delivery of the ad content to the viewer\'s device.' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Type of device on which the ad was inserted and viewed (e.g., smart TV, mobile phone, tablet, desktop, set-top box, gaming console).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackReason rdf:type rdf:Property ;
    rdfs:label 'Fallback Reason' ;
    rdfs:comment 'Reason code or description explaining why a fallback ad was used instead of the primary targeted ad (e.g., targeting mismatch, inventory unavailable, technical constraint).' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoLocationCode rdf:type rdf:Property ;
    rdfs:label 'Geo Location Code' ;
    rdfs:comment 'Geographic location code (DMA, postal code, or country code) of the viewer at the time of ad insertion, used for geo-targeting.' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionFiredFlag rdf:type rdf:Property ;
    rdfs:label 'Impression Fired Flag' ;
    rdfs:comment 'Boolean flag indicating whether the impression tracking URL was successfully fired and acknowledged.' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impressionFiredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Impression Fired Timestamp' ;
    rdfs:comment 'Timestamp when the impression tracking beacon was fired, marking the billable impression event.' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:impressionTrackingUrl rdf:type rdf:Property ;
    rdfs:label 'Impression Tracking Url' ;
    rdfs:comment 'URL fired to record the ad impression event. Used for third-party verification and billing reconciliation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insertionPointTimecode rdf:type rdf:Property ;
    rdfs:label 'Insertion Point Timecode' ;
    rdfs:comment 'Timecode within the content stream where the ad insertion was triggered, typically corresponding to an SCTE-35 cue marker.' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insertionStatus rdf:type rdf:Property ;
    rdfs:label 'Insertion Status' ;
    rdfs:comment 'Status outcome of the ad insertion attempt: inserted (successful), fallback (backup ad used), no-fill (no ad available), error (technical failure), or skipped (viewer action).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacySignal rdf:type rdf:Property ;
    rdfs:label 'Privacy Signal' ;
    rdfs:comment 'Privacy signal or consent string passed from the viewer\'s device (e.g., IAB TCF consent string, US Privacy string).' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quartileReached rdf:type rdf:Property ;
    rdfs:label 'Quartile Reached' ;
    rdfs:comment 'Highest quartile milestone reached during ad playback: start, first quartile (25%), midpoint (50%), third quartile (75%), complete (100%), or none.' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Amount' ;
    rdfs:comment 'Revenue amount attributed to this ad insertion event, calculated based on CPM, impressions, and contract terms.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemName rdf:type rdf:Property ;
    rdfs:label 'Source System Name' ;
    rdfs:comment 'Name of the source system that generated this DAI event record (e.g., Google DAI API, FreeWheel event stream).' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userConsentStatus rdf:type rdf:Property ;
    rdfs:label 'User Consent Status' ;
    rdfs:comment 'Privacy consent status of the viewer for personalized ad targeting: granted, denied, not required (non-EU), or unknown.' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userInteractionType rdf:type rdf:Property ;
    rdfs:label 'User Interaction Type' ;
    rdfs:comment 'Type of user interaction with the ad during playback: none, click-through, skip, pause, mute, or expand.' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Viewability Status' ;
    rdfs:comment 'Viewability measurement status indicating whether the ad met viewability criteria (e.g., 50% of pixels visible for 2+ seconds per IAB standards).' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Impression Delivery Id' ;
    rdfs:comment 'Unique identifier for the digital or streaming advertising impression delivery record.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:browserType rdf:type rdf:Property ;
    rdfs:label 'Browser Type' ;
    rdfs:comment 'Web browser used to view the impression, if applicable.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnDeliveryConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Cdn Delivery Confirmed Flag' ;
    rdfs:comment 'Boolean flag indicating whether the CDN confirmed successful delivery of the impression.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Name of the streaming channel or digital property where the impression was served.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickThroughRatePercent rdf:type rdf:Property ;
    rdfs:label 'Click Through Rate Percent' ;
    rdfs:comment 'Percentage of impressions that resulted in a click-through, calculated as click-throughs divided by total impressions served.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clickThroughs rdf:type rdf:Property ;
    rdfs:label 'Click Throughs' ;
    rdfs:comment 'Number of times viewers clicked on the ad to visit the advertiser\'s destination.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completedViews rdf:type rdf:Property ;
    rdfs:label 'Completed Views' ;
    rdfs:comment 'Number of impressions where the viewer watched the ad to completion.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentGenre rdf:type rdf:Property ;
    rdfs:label 'Content Genre' ;
    rdfs:comment 'Genre of the content during which the ad impression was served.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpmRealized rdf:type rdf:Property ;
    rdfs:label 'Cpm Realized' ;
    rdfs:comment 'Actual cost per thousand impressions realized for this delivery event.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Calendar date on which the impression was delivered, used for daily aggregation and reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geoTargetCode rdf:type rdf:Property ;
    rdfs:label 'Geo Target Code' ;
    rdfs:comment 'ISO country or region code representing the geographic targeting applied to this impression.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insertionType rdf:type rdf:Property ;
    rdfs:label 'Insertion Type' ;
    rdfs:comment 'Technical method used to insert the ad into the content stream or page. [ENUM-REF-CANDIDATE: DAI|SCTE-35|Server-Side|Client-Side|Display|Pre-Roll|Mid-Roll|Post-Roll — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'Operating system of the device that received the impression.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyVerificationSource rdf:type rdf:Property ;
    rdfs:label 'Third Party Verification Source' ;
    rdfs:comment 'Name of the third-party verification service that validated this impression delivery.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalImpressionsServed rdf:type rdf:Property ;
    rdfs:label 'Total Impressions Served' ;
    rdfs:comment 'Total number of impressions delivered in this event.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of third-party verification for this impression.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewabilityRatePercent rdf:type rdf:Property ;
    rdfs:label 'Viewability Rate Percent' ;
    rdfs:comment 'Percentage of impressions that met viewability standards, calculated as viewable impressions divided by total impressions served.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewableImpressions rdf:type rdf:Property ;
    rdfs:label 'Viewable Impressions' ;
    rdfs:comment 'Number of impressions that met the IAB viewability standard (50% of pixels in view for 2+ seconds for display, 50% for 2+ seconds for video).' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandId rdf:type rdf:Property ;
    rdfs:label 'Brand Id' ;
    rdfs:comment 'Reference to the specific brand or product line being promoted in this creative. Links to the brand master record.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:complianceContentRatingId rdf:type rdf:Property ;
    rdfs:label 'Compliance Content Rating Id' ;
    rdfs:comment 'Foreign key linking to compliance.content_rating. Business justification: Creative content requires age-appropriate ratings for daypart placement and regulatory compliance. Broadcasters must verify ratings match target demographics and time slots, ensuring children\'s progra' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentRating .

ind:genreId rdf:type rdf:Property ;
    rdfs:label 'Genre Id' ;
    rdfs:comment 'Foreign key linking to content.genre. Business justification: Creative clearance restricted by content genre (alcohol ads in sports vs. children\'s programming). Business process: standards & practices clearance workflows, content adjacency rules, advertiser cate' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Genre .

ind:previousVersionIsciCreativeId rdf:type rdf:Property ;
    rdfs:label 'Previous Version Isci Creative Id' ;
    rdfs:comment 'Reference to the immediately preceding version of this creative, if this is a revision. Null for the original version. Enables version lineage tracking.' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IsciCreative .

ind:primaryIsciEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Isci Employee Id' ;
    rdfs:comment 'Reference to the user who created this creative record in the system. Used for audit trail and accountability.' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adStandardsClearanceId rdf:type rdf:Property ;
    rdfs:label 'Ad Standards Clearance Id' ;
    rdfs:comment 'Foreign key linking to compliance.ad_standards_clearance. Business justification: Creative assets must pass ad standards clearance before airing. Broadcasters track clearance approval status, rejection reasons, and certificate numbers for each ISCI code to ensure only approved cont' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current state of the creative in the internal approval workflow. Tracks progression from draft through review to final approval or rejection. Only approved creatives can be trafficked for broadcast. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|revision_required|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aspectRatio rdf:type rdf:Property ;
    rdfs:label 'Aspect Ratio' ;
    rdfs:comment 'The proportional relationship between width and height of the video creative. Standard ratios include 16:9 (HD/widescreen), 4:3 (SD), 1:1 (square/social), 9:16 (vertical/mobile), and 21:9 (cinematic).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioStandard rdf:type rdf:Property ;
    rdfs:label 'Audio Standard' ;
    rdfs:comment 'The audio encoding and channel configuration standard used in the creative. Includes stereo, surround sound formats (Dolby Digital, Dolby Atmos, DTS), and codec specifications (AAC).' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumMd5 rdf:type rdf:Property ;
    rdfs:label 'Checksum Md5' ;
    rdfs:comment 'MD5 hash of the creative asset file used for integrity verification during transfer and playout. Ensures the file has not been corrupted or tampered with.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionAvailable rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Available' ;
    rdfs:comment 'Indicates whether closed captioning (subtitles for the deaf and hard of hearing) is embedded or available for this creative. Required for FCC compliance on broadcast television.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codec rdf:type rdf:Property ;
    rdfs:label 'Codec' ;
    rdfs:comment 'The video compression codec used to encode the creative. Common codecs include H.264 (AVC), H.265 (HEVC), ProRes, DNxHD, MPEG-2, VP9, and AV1. Impacts file size, quality, and playback compatibility. [ENUM-REF-CANDIDATE: h264|h265|prores|dnxhd|mpeg2|vp9|av1 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeDescription rdf:type rdf:Property ;
    rdfs:label 'Creative Description' ;
    rdfs:comment 'Detailed narrative description of the creative content, messaging, and visual elements. Used for trafficking, clearance review, and internal reference.' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeFormat rdf:type rdf:Property ;
    rdfs:label 'Creative Format' ;
    rdfs:comment 'The media format and delivery channel for which this creative is designed. Determines playout system routing and technical specifications. [ENUM-REF-CANDIDATE: linear_tv|digital_pre_roll|digital_mid_roll|digital_post_roll|audio_radio|audio_podcast|ott_streaming|social_media|display_banner — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeTitle rdf:type rdf:Property ;
    rdfs:label 'Creative Title' ;
    rdfs:comment 'The human-readable name or title of the advertising creative, typically describing the campaign theme or message (e.g., \'Summer Sale 2024\', \'New Product Launch\').' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletAssetReference rdf:type rdf:Property ;
    rdfs:label 'Dalet Asset Reference' ;
    rdfs:comment 'Reference identifier linking this ISCI creative record to the corresponding digital asset file stored in the Dalet Galaxy Media Asset Management system. Used for asset retrieval and playout automation.' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date after which this creative is no longer authorized to air or be distributed. Enforces campaign end dates, product discontinuations, and time-sensitive offers. Null for open-ended creatives.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date from which this creative is authorized to air or be distributed. Enforces campaign timing and seasonal restrictions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date on which the creative record and associated clearances expire and must be renewed or retired. Distinct from effective_end_date; this represents the end of the creative\'s lifecycle validity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'The digital container format of the creative asset file. Common video formats include MP4, MOV, MXF, AVI; audio formats include MP3, WAV, AAC. Determines compatibility with playout and MAM systems. [ENUM-REF-CANDIDATE: mp4|mov|mxf|avi|wmv|mpg|mp3|wav|aac — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'The size of the creative asset file in megabytes. Used for storage planning, bandwidth estimation, and delivery optimization.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frameRate rdf:type rdf:Property ;
    rdfs:label 'Frame Rate' ;
    rdfs:comment 'The number of frames per second (fps) in the video creative. Standard rates include 23.976/24 (film), 25 (PAL), 29.97/30 (NTSC), and 50/60 (high frame rate). Must match broadcast or streaming platform requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this creative record is currently active and available for trafficking and playout. Inactive creatives are retained for historical reference but cannot be scheduled.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isciCode rdf:type rdf:Property ;
    rdfs:label 'Isci Code' ;
    rdfs:comment 'The standardized 12-character alphanumeric code uniquely identifying a commercial creative in the advertising industry. Format: 4-character advertiser code + 4-character brand code + 1-character media type (H=TV, M=Radio, V=Digital) + 3-digit sequence. This is the externally-known business identifier used across trafficking, playout, and affidavit systems.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'The primary language of the creative audio and text content, expressed as ISO 639-1 two-letter code (e.g., \'en\' for English, \'es\' for Spanish) with optional ISO 3166-1 country code (e.g., \'en-US\', \'es-MX\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:politicalAdIndicator rdf:type rdf:Property ;
    rdfs:label 'Political Ad Indicator' ;
    rdfs:comment 'Indicates whether this creative is a political advertisement subject to FCC political advertising disclosure and equal time requirements. Triggers mandatory public inspection file documentation.' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedContentFlags rdf:type rdf:Property ;
    rdfs:label 'Restricted Content Flags' ;
    rdfs:comment 'Comma-separated list of content restriction flags indicating special handling requirements (e.g., \'alcohol\', \'gambling\', \'political\', \'pharmaceutical\', \'tobacco\'). Triggers daypart restrictions and disclosure requirements.' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version number for this creative. Increments when revisions are made to the creative content or metadata. Supports version history and rollback.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoResolution rdf:type rdf:Property ;
    rdfs:label 'Video Resolution' ;
    rdfs:comment 'The pixel resolution of the video creative. Standard resolutions include SD (480p), HD (720p/1080p), and UHD (4K/8K). Determines quality tier and bandwidth requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makegoodId rdf:type rdf:Property ;
    rdfs:label 'Makegood Id' ;
    rdfs:comment 'Primary key for makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Makegood resolution requires approval by operations manager or account executive to authorize replacement inventory and confirm advertiser acceptance. Replaces text \'approved_by\' field with proper FK ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_allocation. Business justification: Makegoods represent cost of service delivery failures. Cost of quality reporting and operational cost allocation require linking makegoods to cost allocation records for accurate cost center accountab' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAllocation .

ind:makegoodOriginalChannelId rdf:type rdf:Property ;
    rdfs:label 'Makegood Original Channel Id' ;
    rdfs:comment 'Reference to the channel on which the original ad spot was scheduled to air.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:makegoodProposedChannelId rdf:type rdf:Property ;
    rdfs:label 'Makegood Proposed Channel Id' ;
    rdfs:comment 'Reference to the channel on which the makegood replacement spot is proposed to air.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:originalAdSpotId rdf:type rdf:Property ;
    rdfs:label 'Original Ad Spot Id' ;
    rdfs:comment 'Reference to the original ad spot that failed to air as scheduled and triggered this makegood.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdSpot .

ind:originalIsciCreativeId rdf:type rdf:Property ;
    rdfs:label 'Original Isci Creative Id' ;
    rdfs:comment 'Foreign key linking to advertising.isci_creative. Business justification: Normalize creative reference for the original spot being made good. Makegood record needs to reference which creative was supposed to air originally. Currently denormalized as original_isci_code STRIN' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IsciCreative .

ind:affidavitDate rdf:type rdf:Property ;
    rdfs:label 'Affidavit Date' ;
    rdfs:comment 'The date on which the affidavit for the makegood spot was generated and issued.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affidavitGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Affidavit Generated Flag' ;
    rdfs:comment 'Indicates whether a proof-of-broadcast affidavit has been generated for the aired makegood spot.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which the advertiser or agency approved the makegood proposal.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makegoodNumber rdf:type rdf:Property ;
    rdfs:label 'Makegood Number' ;
    rdfs:comment 'Business identifier for the makegood record, used in external communications and affidavits.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalActualGrp rdf:type rdf:Property ;
    rdfs:label 'Original Actual Grp' ;
    rdfs:comment 'The actual GRP delivered by the original spot if it aired but underperformed, triggering a ratings shortfall makegood.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalContractedGrp rdf:type rdf:Property ;
    rdfs:label 'Original Contracted Grp' ;
    rdfs:comment 'The GRP value that was contracted for the original ad spot, used to assess audience underdelivery.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalDaypart rdf:type rdf:Property ;
    rdfs:label 'Original Daypart' ;
    rdfs:comment 'The broadcast daypart (time segment) in which the original spot was scheduled, such as Prime, Early Fringe, Late Night.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalProgramName rdf:type rdf:Property ;
    rdfs:label 'Original Program Name' ;
    rdfs:comment 'The name of the program during which the original ad spot was scheduled to air.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Original Scheduled Date' ;
    rdfs:comment 'The date on which the original ad spot was scheduled to air before the failure occurred.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalScheduledTime rdf:type rdf:Property ;
    rdfs:label 'Original Scheduled Time' ;
    rdfs:comment 'The precise timestamp at which the original ad spot was scheduled to air.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalSpotLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Original Spot Length Seconds' ;
    rdfs:comment 'The duration in seconds of the original ad spot that failed to air.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalSpotRate rdf:type rdf:Property ;
    rdfs:label 'Original Spot Rate' ;
    rdfs:comment 'The contracted rate (in USD) for the original ad spot that failed to air.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedDaypart rdf:type rdf:Property ;
    rdfs:label 'Proposed Daypart' ;
    rdfs:comment 'The broadcast daypart proposed for the makegood replacement spot.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedEstimatedGrp rdf:type rdf:Property ;
    rdfs:label 'Proposed Estimated Grp' ;
    rdfs:comment 'The estimated GRP that the proposed makegood replacement spot is expected to deliver.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedProgramName rdf:type rdf:Property ;
    rdfs:label 'Proposed Program Name' ;
    rdfs:comment 'The name of the program during which the makegood replacement spot is proposed to air.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedReplacementDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Replacement Date' ;
    rdfs:comment 'The date proposed by the broadcaster for airing the makegood replacement spot.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedReplacementTime rdf:type rdf:Property ;
    rdfs:label 'Proposed Replacement Time' ;
    rdfs:comment 'The precise timestamp proposed for airing the makegood replacement spot.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proposedSpotLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Proposed Spot Length Seconds' ;
    rdfs:comment 'The duration in seconds of the proposed makegood replacement spot.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Categorical code indicating why the original spot failed to air and a makegood was issued.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the circumstances that led to the makegood issuance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation provided by the advertiser or agency if the makegood proposal was rejected.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current lifecycle status of the makegood record, tracking whether it has been fulfilled or remains outstanding.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:politicalAdDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Political Ad Disclosure Id' ;
    rdfs:comment 'Unique identifier for the FCC-mandated political advertising disclosure record. Primary key for political ad disclosure tracking and public inspection file maintenance.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPoliticalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Political Employee Id' ;
    rdfs:comment 'Identifier of the user who created the political ad disclosure record. Supports audit trail and accountability for regulatory compliance documentation.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:airDate rdf:type rdf:Property ;
    rdfs:label 'Air Date' ;
    rdfs:comment 'The date on which the political advertisement aired. Used for public inspection file chronological organization and lowest unit rate window determination.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airTime rdf:type rdf:Property ;
    rdfs:label 'Air Time' ;
    rdfs:comment 'The precise timestamp when the political advertisement was broadcast. Required for affidavit generation and proof of performance documentation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:candidateName rdf:type rdf:Property ;
    rdfs:label 'Candidate Name' ;
    rdfs:comment 'Full name of the political candidate featured in or sponsoring the advertisement. Required for candidate ads and independent expenditure communications. Null for issue-only advocacy.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateOffice rdf:type rdf:Property ;
    rdfs:label 'Candidate Office' ;
    rdfs:comment 'The elected office being sought by the candidate (e.g., President, U.S. Senator, Governor, State Representative). Required for candidate-related political ads.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Reference number of the advertising contract or agreement under which the political ad was purchased. Links disclosure to sales order and billing documentation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureNumber rdf:type rdf:Property ;
    rdfs:label 'Disclosure Number' ;
    rdfs:comment 'Unique business identifier for the political ad disclosure record used in public inspection files and FCC reporting. Human-readable reference number for regulatory compliance tracking.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Disclosure Status' ;
    rdfs:comment 'Current lifecycle status of the political ad disclosure record. Tracks progression from initial filing through amendments to final archival in public inspection file.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureText rdf:type rdf:Property ;
    rdfs:label 'Disclosure Text' ;
    rdfs:comment 'The exact on-air or written disclosure statement required by FCC regulations identifying who paid for the advertisement. Must include \'paid for by\' language and sponsoring organization name.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionDate rdf:type rdf:Property ;
    rdfs:label 'Election Date' ;
    rdfs:comment 'Date of the election for which the political advertisement is relevant. Used to determine lowest unit rate windows (45 days for primary, 60 days for general election).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:electionType rdf:type rdf:Property ;
    rdfs:label 'Election Type' ;
    rdfs:comment 'Type of election associated with the political advertisement. Determines applicable lowest unit rate periods and disclosure requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equalTimeObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Equal Time Obligation Flag' ;
    rdfs:comment 'Indicates whether this political ad triggers FCC equal time obligations requiring the broadcaster to offer comparable advertising opportunities to opposing candidates.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date when the political ad disclosure record was filed in the public inspection file. FCC requires immediate disclosure upon request and placement in public file as soon as possible.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lowestUnitRateAmount rdf:type rdf:Property ;
    rdfs:label 'Lowest Unit Rate Amount' ;
    rdfs:comment 'The lowest unit rate available for the class of time and daypart in which the political ad aired. Used to verify compliance with FCC lowest unit rate requirements for candidate advertising.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowestUnitRateApplied rdf:type rdf:Property ;
    rdfs:label 'Lowest Unit Rate Applied' ;
    rdfs:comment 'Indicates whether the FCC-mandated lowest unit rate was applied to this political ad spot. Required to be true for candidate ads within 45 days of primary or 60 days of general election.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:politicalAdType rdf:type rdf:Property ;
    rdfs:label 'Political Ad Type' ;
    rdfs:comment 'Classification of the political advertisement according to FCC categories. Determines applicable disclosure requirements, lowest unit rate eligibility, and equal time obligations.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateClass rdf:type rdf:Property ;
    rdfs:label 'Rate Class' ;
    rdfs:comment 'The advertising rate class or tier under which the political ad was sold (e.g., preemptible, non-preemptible, fixed position). Determines lowest unit rate calculation and equal time obligations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonableAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Reasonable Access Flag' ;
    rdfs:comment 'Indicates whether this ad purchase was made under FCC reasonable access requirements mandating broadcasters provide federal candidates reasonable access to purchase advertising time.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Email' ;
    rdfs:comment 'Email address of the primary contact at the sponsoring organization for correspondence regarding the political advertising campaign.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorContactName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the sponsoring organization responsible for the political advertising campaign.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact at the sponsoring organization. Required for FCC public inspection file and reasonable access compliance.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsoringOrganization rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Organization' ;
    rdfs:comment 'Legal name of the organization sponsoring or paying for the political advertisement. May be a candidate committee, PAC, super PAC, issue advocacy group, or independent expenditure committee.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotRateCharged rdf:type rdf:Property ;
    rdfs:label 'Spot Rate Charged' ;
    rdfs:comment 'The actual rate charged for the political ad spot. Must comply with lowest unit rate requirements during pre-election windows for candidate ads.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stationCallSign rdf:type rdf:Property ;
    rdfs:label 'Station Call Sign' ;
    rdfs:comment 'FCC-assigned call letters identifying the broadcast station that aired the political advertisement. Required for public inspection file organization and regulatory reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Total monetary value of the political advertising contract. Required disclosure for public inspection file and transparency in political advertising spending.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSpotsContracted rdf:type rdf:Property ;
    rdfs:label 'Total Spots Contracted' ;
    rdfs:comment 'Total number of advertising spots contracted under the political advertising agreement. Used for campaign tracking and public disclosure of advertising volume.' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesProposalId rdf:type rdf:Property ;
    rdfs:label 'Sales Proposal Id' ;
    rdfs:comment 'Unique identifier for the sales proposal. Primary key for this entity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesProposal .

ind:billingAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Account Id' ;
    rdfs:comment 'Foreign key linking to billing.account. Business justification: Proposals are submitted to billing accounts for contract execution. Proposal approval workflows, contract management, and proposal-to-invoice conversion tracking require direct linkage to the billing ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:broadcastFacilityId rdf:type rdf:Property ;
    rdfs:label 'Broadcast Facility Id' ;
    rdfs:comment 'Foreign key linking to technology.broadcast_facility. Business justification: Proposals for facility-dependent services (studio rental, satellite uplink, transmission services) must reference the specific facility for accurate costing, availability confirmation, and SLA definit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastFacility .

ind:primarySalesRepId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Rep Id' ;
    rdfs:comment 'Reference to the sales account executive responsible for this proposal and the advertiser relationship.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:rateCardId rdf:type rdf:Property ;
    rdfs:label 'Rate Card Id' ;
    rdfs:comment 'Reference to the primary rate card used as the pricing basis for this proposal.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:rfpId rdf:type rdf:Property ;
    rdfs:label 'Rfp Id' ;
    rdfs:comment 'Foreign key linking to sales.rfp. Business justification: Proposals are often created in response to RFPs. This FK enables tracing proposals back to the RFP they respond to. N:1 relationship (one proposal per RFP in the context of a single seller responding)' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfp .

ind:acceptedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Accepted Timestamp' ;
    rdfs:comment 'Timestamp when the proposal was accepted by the advertiser or agency. Null if not yet accepted or if rejected.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:agencyCommissionPercentage rdf:type rdf:Property ;
    rdfs:label 'Agency Commission Percentage' ;
    rdfs:comment 'Agency commission percentage to be paid to the agency from the gross proposal value. Typically 15% in the industry. Null if direct advertiser buy.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audienceGuaranteeFlag rdf:type rdf:Property ;
    rdfs:label 'Audience Guarantee Flag' ;
    rdfs:comment 'Indicates whether the proposal includes an audience delivery guarantee with makegood provisions if targets are not met.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:campaignEndDate rdf:type rdf:Property ;
    rdfs:label 'Campaign End Date' ;
    rdfs:comment 'Proposed end date for the advertising campaign covered by this proposal.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignStartDate rdf:type rdf:Property ;
    rdfs:label 'Campaign Start Date' ;
    rdfs:comment 'Proposed start date for the advertising campaign covered by this proposal.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationTerms rdf:type rdf:Property ;
    rdfs:label 'Cancellation Terms' ;
    rdfs:comment 'Terms and conditions for cancellation of the proposal or resulting order, including notice periods and penalties.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelMixSummary rdf:type rdf:Property ;
    rdfs:label 'Channel Mix Summary' ;
    rdfs:comment 'High-level summary of the proposed channel distribution (e.g., 60% Linear TV, 30% OTT, 10% Digital). Detailed channel breakdown is in proposal line items.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveSituation rdf:type rdf:Property ;
    rdfs:label 'Competitive Situation' ;
    rdfs:comment 'Internal notes on competitive dynamics, other bidders, and strategic positioning for this proposal.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentAdjacencyPreferences rdf:type rdf:Property ;
    rdfs:label 'Content Adjacency Preferences' ;
    rdfs:comment 'Client-specified preferences or restrictions for content types adjacent to ad placements (e.g., sports, news, drama, avoid violent content).' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartMixSummary rdf:type rdf:Property ;
    rdfs:label 'Daypart Mix Summary' ;
    rdfs:comment 'High-level summary of the proposed daypart distribution (e.g., 40% Prime, 30% Early Fringe, 20% Late Night, 10% Weekend). Detailed daypart breakdown is in proposal line items.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demographicTarget rdf:type rdf:Property ;
    rdfs:label 'Demographic Target' ;
    rdfs:comment 'Primary audience demographic segment targeted by this proposal, expressed in standard Nielsen notation (e.g., Adults 25-54, Women 18-49).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total discount or price reduction offered in the proposal, applied to the total proposed value.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedImpressions rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Impressions' ;
    rdfs:comment 'Minimum number of impressions contractually guaranteed to be delivered, triggering makegood obligations if underdelivered.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netProposedValue rdf:type rdf:Property ;
    rdfs:label 'Net Proposed Value' ;
    rdfs:comment 'Net revenue value of the proposal after discounts and agency commissions. This is the expected revenue to the broadcaster.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformMix rdf:type rdf:Property ;
    rdfs:label 'Platform Mix' ;
    rdfs:comment 'Distribution of proposed inventory across delivery platforms: linear (traditional broadcast), OTT (over-the-top streaming), FAST (free ad-supported streaming TV), AVOD (advertising video on demand), SVOD (subscription video on demand).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalDate rdf:type rdf:Property ;
    rdfs:label 'Proposal Date' ;
    rdfs:comment 'Date when the proposal was created and issued to the advertiser or agency.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposalDescription rdf:type rdf:Property ;
    rdfs:label 'Proposal Description' ;
    rdfs:comment 'Detailed narrative description of the proposal, including campaign objectives, creative strategy, and value proposition.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalName rdf:type rdf:Property ;
    rdfs:label 'Proposal Name' ;
    rdfs:comment 'Descriptive name or title of the proposal, typically reflecting the campaign or client name.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalNumber rdf:type rdf:Property ;
    rdfs:label 'Proposal Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the proposal, used in client communications and internal tracking.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalSource rdf:type rdf:Property ;
    rdfs:label 'Proposal Source' ;
    rdfs:comment 'Origin or trigger for this proposal: response to RFP (request for proposal), proactive sales pitch, contract renewal, upsell to existing client, or cross-sell of additional services.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalStatus rdf:type rdf:Property ;
    rdfs:label 'Proposal Status' ;
    rdfs:comment 'Current lifecycle status of the advertising proposal in the sales workflow.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalType rdf:type rdf:Property ;
    rdfs:label 'Proposal Type' ;
    rdfs:comment 'Category of commercial offer: advertising (spot sales), content licensing (rights acquisition), syndication (content resale), distribution (carriage agreements), sponsorship (branded integration), or upfront (advance commitment).' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedFrequency rdf:type rdf:Property ;
    rdfs:label 'Proposed Frequency' ;
    rdfs:comment 'Proposed average frequency (number of times) that each reached individual in the target audience will be exposed to the campaign. Frequency = GRP / Reach.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedGrp rdf:type rdf:Property ;
    rdfs:label 'Proposed Grp' ;
    rdfs:comment 'Total Gross Rating Points (GRP) proposed to be delivered across all dayparts and channels. GRP measures the total exposure weight of the campaign.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedImpressions rdf:type rdf:Property ;
    rdfs:label 'Proposed Impressions' ;
    rdfs:comment 'Total number of impressions (ad views) proposed to be delivered across all channels and platforms in this campaign.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedReach rdf:type rdf:Property ;
    rdfs:label 'Proposed Reach' ;
    rdfs:comment 'Proposed reach as a percentage of the target audience that will be exposed to the campaign at least once. Reach measures unique audience coverage.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedTrp rdf:type rdf:Property ;
    rdfs:label 'Proposed Trp' ;
    rdfs:comment 'Total Target Rating Points (TRP) proposed to be delivered to the specific demographic target audience. TRP measures exposure within the target demo only.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejected Timestamp' ;
    rdfs:comment 'Timestamp when the proposal was rejected by the advertiser or agency. Null if not rejected.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Requested or required date by which the client should provide a decision or response to the proposal.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spotLengthMixSummary rdf:type rdf:Property ;
    rdfs:label 'Spot Length Mix Summary' ;
    rdfs:comment 'High-level summary of the proposed spot length distribution (e.g., 80% :30s, 15% :15s, 5% :60s). Detailed spot length breakdown is in proposal line items.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'Date when the proposal was formally submitted to the client or agency for review.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Timestamp when the proposal was formally submitted to the advertiser or agency. Null if still in draft status.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Legal and commercial terms governing the proposal, including payment terms, cancellation policies, makegood provisions, and liability clauses.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalProposedValue rdf:type rdf:Property ;
    rdfs:label 'Total Proposed Value' ;
    rdfs:comment 'Total gross revenue value of the proposal in the base currency, before any discounts or agency commissions. Sum of all proposed line items.' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:winProbabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Win Probability Percent' ;
    rdfs:comment 'Sales team estimated probability of winning this proposal, expressed as a percentage (0-100).' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpmBasis rdf:type rdf:Property ;
    rdfs:label 'Cpm Basis' ;
    rdfs:comment 'Cost per thousand impressions or viewers that the rate is based on. CPM is a standard metric in advertising pricing used to normalize rates across different audience sizes.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountEligibility rdf:type rdf:Property ;
    rdfs:label 'Discount Eligibility' ;
    rdfs:comment 'Description of volume discounts, frequency discounts, or package deals that can be applied to this rate card for qualifying advertisers.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'Geographic market or Designated Market Area (DMA) to which the rate card applies. Can be national, regional, or local market identifier.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossRate rdf:type rdf:Property ;
    rdfs:label 'Gross Rate' ;
    rdfs:comment 'Published rate for the ad spot before any discounts, commissions, or agency fees are applied. This is the list price used as the baseline for negotiations.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAudienceGuarantee rdf:type rdf:Property ;
    rdfs:label 'Minimum Audience Guarantee' ;
    rdfs:comment 'Minimum guaranteed audience size (in thousands) for the daypart and demographic. If actual audience falls below this threshold, makegoods may be required.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netRate rdf:type rdf:Property ;
    rdfs:label 'Net Rate' ;
    rdfs:comment 'Rate after standard agency commission (typically 15%) and other standard deductions are applied. This is the effective rate paid by the advertiser.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programGenre rdf:type rdf:Property ;
    rdfs:label 'Program Genre' ;
    rdfs:comment 'Genre or category of programming for which the rate applies (e.g., News, Sports, Drama, Reality, Comedy). Certain genres command premium rates due to audience engagement and demographics.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardName rdf:type rdf:Property ;
    rdfs:label 'Rate Card Name' ;
    rdfs:comment 'Descriptive name of the rate card for easy identification, typically includes year and market or channel reference (e.g., \'2024 Prime Time National Rate Card\').' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Card Number' ;
    rdfs:comment 'Business identifier for the rate card, used for external reference and communication with sales teams and advertisers. Typically follows format RC-YYYYNNNN.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Card Status' ;
    rdfs:comment 'Current lifecycle status of the rate card indicating its operational state and usability for ad order entry.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the rate amounts (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the rate card by sales market type. Upfront rates are negotiated in advance for the broadcast year, scatter rates are for last-minute inventory, package rates bundle multiple spots, digital rates apply to OTT/streaming, sponsorship rates for integrated content, and remnant rates for unsold inventory.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalityFactor rdf:type rdf:Property ;
    rdfs:label 'Seasonality Factor' ;
    rdfs:comment 'Multiplier applied to base rates to account for seasonal demand variations (e.g., 1.25 for high-demand periods like holidays, 0.85 for low-demand summer months).' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the rate card to track revisions and updates. Follows semantic versioning (e.g., 1.0, 1.1, 2.0).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesScatterOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Scatter Order Id' ;
    rdfs:comment 'Unique identifier for the scatter market advertising order. Primary key for the sales scatter order entity.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesScatterOrder .

ind:adBillingOrderId rdf:type rdf:Property ;
    rdfs:label 'Ad Billing Order Id' ;
    rdfs:comment 'Foreign key linking to billing.ad_billing_order. Business justification: Scatter orders are billed through ad billing orders in WideOrbit. Scatter market revenue tracking, order fulfillment reconciliation, and scatter vs. upfront revenue reporting require direct linkage fr' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdBillingOrder .

ind:broadcastLicenseId rdf:type rdf:Property ;
    rdfs:label 'Broadcast License Id' ;
    rdfs:comment 'Foreign key linking to compliance.broadcast_license. Business justification: Scatter market orders are station-specific and must reference the broadcast license for regulatory compliance, public file requirements, and FCC reporting. Same regulatory requirements as upfront orde' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastLicense .

ind:daypartId rdf:type rdf:Property ;
    rdfs:label 'Daypart Id' ;
    rdfs:comment 'Foreign key linking to scheduling.daypart. Business justification: Scatter orders specify daypart for purchased inventory. Business process: scatter pricing by daypart, daypart fulfillment tracking. Replaces denormalized daypart text field with proper FK.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Daypart .

ind:primarySalesEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Employee Id' ;
    rdfs:comment 'Reference to the sales account executive responsible for this scatter order. Used for commission calculation and performance tracking.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySalesforceOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Primary Salesforce Opportunity Id' ;
    rdfs:comment 'External identifier linking this scatter order to the originating sales opportunity in Salesforce Media Cloud. Enables CRM integration and sales pipeline tracking.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:salesRepId rdf:type rdf:Property ;
    rdfs:label 'Sales Rep Id' ;
    rdfs:comment 'Reference to the sales representative who negotiated and closed this scatter order.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:scatterOrderId rdf:type rdf:Property ;
    rdfs:label 'Scatter Order Id' ;
    rdfs:comment 'Foreign key linking to sales.scatter_order. Business justification: sales_scatter_order and scatter_order appear to represent the same business entity at different lifecycle stages (proposal vs. confirmed). Linking them tracks the progression from scatter order reques' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScatterOrder .

ind:agencyCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Agency Commission Rate' ;
    rdfs:comment 'Agency commission rate percentage deducted from the gross order value. Standard agency commission is typically 15% in the advertising industry.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Deadline Date' ;
    rdfs:comment 'Last date by which the advertiser may cancel this scatter order without penalty. After this date, cancellation fees may apply.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractTerms rdf:type rdf:Property ;
    rdfs:label 'Contract Terms' ;
    rdfs:comment 'Free-text field capturing special contractual terms, conditions, or notes specific to this scatter order. May include payment terms, delivery guarantees, or custom provisions.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredGrps rdf:type rdf:Property ;
    rdfs:label 'Delivered Grps' ;
    rdfs:comment 'Actual Gross Rating Points (GRPs) delivered for linear broadcast inventory. Compared against requested GRPs to assess fulfillment.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercent rdf:type rdf:Property ;
    rdfs:label 'Discount Percent' ;
    rdfs:comment 'Percentage discount applied to the scatter order total. May reflect volume discounts, promotional pricing, or negotiated rate adjustments.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current fulfillment status of the scatter order. Tracks whether requested impressions or GRPs have been delivered as scheduled.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiatedCpm rdf:type rdf:Property ;
    rdfs:label 'Negotiated Cpm' ;
    rdfs:comment 'Negotiated Cost Per Mille (CPM) rate for this scatter order. Represents the cost per thousand impressions. Scatter market CPM is typically at a premium to upfront rates.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedCprp rdf:type rdf:Property ;
    rdfs:label 'Negotiated Cprp' ;
    rdfs:comment 'Negotiated Cost Per Rating Point (CPRP) for linear broadcast inventory. Represents the cost per single rating point.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Net Order Amount' ;
    rdfs:comment 'Final order amount after discounts and adjustments. Represents the actual revenue expected from this scatter order.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Date the scatter order was placed. Represents the business event timestamp when the advertiser or agency committed to the scatter buy.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platform rdf:type rdf:Property ;
    rdfs:label 'Platform' ;
    rdfs:comment 'Distribution platform where the advertising will be delivered. Supports multi-platform scatter buying.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preemptibilityClass rdf:type rdf:Property ;
    rdfs:label 'Preemptibility Class' ;
    rdfs:comment 'Classification of whether and how scatter spots can be preempted by higher-value inventory. Non-preemptible spots are guaranteed to air; preemptible spots may be bumped for higher-paying advertisers. Critical distinction from upfront deals.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preemptionProtectionLevel rdf:type rdf:Property ;
    rdfs:label 'Preemption Protection Level' ;
    rdfs:comment 'Numeric priority level for preemption protection (1-10, where 10 is highest protection). Determines which orders are preempted first when inventory conflicts arise.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preemptionRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Preemption Risk Flag' ;
    rdfs:comment 'Boolean flag indicating whether this scatter order is subject to preemption by higher-rated inventory. True indicates the order may be bumped if higher-priority demand emerges.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedAirEndDate rdf:type rdf:Property ;
    rdfs:label 'Requested Air End Date' ;
    rdfs:comment 'Last date of the requested air window for scatter market spots. Defines the flight period for the scatter campaign.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedAirStartDate rdf:type rdf:Property ;
    rdfs:label 'Requested Air Start Date' ;
    rdfs:comment 'First date of the requested air window for scatter market spots. Typically 4-12 weeks from order date, distinguishing scatter from upfront buys.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedGrps rdf:type rdf:Property ;
    rdfs:label 'Requested Grps' ;
    rdfs:comment 'Total Gross Rating Points (GRPs) requested for linear broadcast inventory. Represents reach multiplied by frequency.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedImpressions rdf:type rdf:Property ;
    rdfs:label 'Requested Impressions' ;
    rdfs:comment 'Total number of advertising impressions requested by the advertiser for this scatter order. Used for digital and streaming inventory.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestedSpots rdf:type rdf:Property ;
    rdfs:label 'Requested Spots' ;
    rdfs:comment 'Number of individual advertising spots or units requested in this scatter order.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Clearance Flag' ;
    rdfs:comment 'Indicates whether advertising creative requires legal or standards clearance before airing. Common for political ads, pharmaceutical products, and sensitive content.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scatterCpmAmount rdf:type rdf:Property ;
    rdfs:label 'Scatter Cpm Amount' ;
    rdfs:comment 'Cost per thousand impressions for this scatter order. Typically at a premium to upfront CPM due to short lead time and market conditions. CPM is the standard pricing metric in broadcast advertising.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Total Order Amount' ;
    rdfs:comment 'Total monetary value of the scatter order before discounts or adjustments. Calculated from spot count, CPM, and estimated impressions.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total monetary value of the scatter order before any adjustments. Calculated based on negotiated rates and requested volume.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSpotsOrdered rdf:type rdf:Property ;
    rdfs:label 'Total Spots Ordered' ;
    rdfs:comment 'Total number of advertising spots purchased in this scatter order. Represents the quantity of impressions the advertiser is buying.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wideOrbitOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Order Number' ;
    rdfs:comment 'External order number assigned by Wide Orbit traffic and billing system for scatter market buys. Used for cross-system reconciliation and affidavit tracking.' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipId rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Id' ;
    rdfs:comment 'Unique identifier for the sponsorship deal. Primary key.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sponsorship .

ind:contentPartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Content Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Sponsorships require tracking the content partner (network, producer, syndicator) delivering the sponsored property, distinct from the agency. Real business process: sponsorship fulfillment verificati' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:seriesId rdf:type rdf:Property ;
    rdfs:label 'Series Id' ;
    rdfs:comment 'Foreign key linking to content.series. Business justification: Series-level sponsorships (season-long partnerships, franchise deals). Business process: upfront sponsorship packages, multi-season partnership agreements, series franchise sponsorship valuation, seas' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Series .

ind:sponsorshipApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Approved By User Employee Id' ;
    rdfs:comment 'Identifier of the user who approved the sponsorship deal.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sponsorshipCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created the sponsorship record.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sponsorshipEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Employee Id' ;
    rdfs:comment 'Reference to the sales account executive responsible for managing this sponsorship relationship.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sponsorshipModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the sponsorship record.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:billboardCount rdf:type rdf:Property ;
    rdfs:label 'Billboard Count' ;
    rdfs:comment 'Number of billboard mentions or placements included in the sponsorship package.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryExclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Category Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the sponsor has category exclusivity rights for the sponsored content.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Legal contract or insertion order number associated with the sponsorship agreement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverablesDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverables Description' ;
    rdfs:comment 'Detailed description of sponsorship deliverables including billboards, opens/closes, product integration, logo placement, mentions, and other sponsor benefits.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveCategory rdf:type rdf:Property ;
    rdfs:label 'Exclusive Category' ;
    rdfs:comment 'Product or service category for which the sponsor holds exclusivity rights (e.g., automotive, telecommunications, financial services).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityTerms rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Terms' ;
    rdfs:comment 'Description of category exclusivity provisions preventing competing sponsors within the same product or service category.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Percentage' ;
    rdfs:comment 'Percentage of sponsorship deliverables that have been completed and delivered to the sponsor.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:logoPlacementFlag rdf:type rdf:Property ;
    rdfs:label 'Logo Placement Flag' ;
    rdfs:comment 'Indicates whether sponsor logo placement is included in the deliverables.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformDistribution rdf:type rdf:Property ;
    rdfs:label 'Platform Distribution' ;
    rdfs:comment 'Platforms where the sponsored content will be distributed (linear broadcast, OTT, VOD, digital, social media).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Product Integration Flag' ;
    rdfs:comment 'Indicates whether product integration within content is part of the sponsorship agreement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsoredContentType rdf:type rdf:Property ;
    rdfs:label 'Sponsored Content Type' ;
    rdfs:comment 'Type of content being sponsored (program, series, event, segment, etc.).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsoredProgramName rdf:type rdf:Property ;
    rdfs:label 'Sponsored Program Name' ;
    rdfs:comment 'Name of the specific program, series, or event being sponsored.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipCode rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Code' ;
    rdfs:comment 'Business identifier or code for the sponsorship deal used in trafficking and billing systems.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipName rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Name' ;
    rdfs:comment 'Descriptive name of the sponsorship deal for business reference and reporting.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipStatus rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Status' ;
    rdfs:comment 'Current lifecycle status of the sponsorship deal. [ENUM-REF-CANDIDATE: draft|proposed|negotiating|approved|active|fulfilled|cancelled|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipType rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Type' ;
    rdfs:comment 'Classification of the sponsorship arrangement indicating the level and nature of sponsor integration.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueAmount rdf:type rdf:Property ;
    rdfs:label 'Value Amount' ;
    rdfs:comment 'Total monetary value of the sponsorship deal.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryUpfrontEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Upfront Employee Id' ;
    rdfs:comment 'Reference to the sales account executive responsible for negotiating and managing this upfront deal. Links to the employee/user master record.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryUpfrontAccountExecutiveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Upfront Account Executive Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryUpfrontModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Upfront Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this deal record. Links to the employee/user master record for audit and accountability.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:audienceGuaranteeGrp rdf:type rdf:Property ;
    rdfs:label 'Audience Guarantee Grp' ;
    rdfs:comment 'Total Gross Rating Points (GRP) guaranteed to the advertiser across all flights and dayparts in this deal. GRP = Reach × Frequency, representing the total audience delivery commitment.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audienceGuaranteeImpressions rdf:type rdf:Property ;
    rdfs:label 'Audience Guarantee Impressions' ;
    rdfs:comment 'Total number of ad impressions guaranteed to the advertiser. Alternative or complementary metric to GRP, especially for digital and cross-platform deals.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationOptionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Cancellation Option Window Days' ;
    rdfs:comment 'Number of days before flight start date within which the advertiser may cancel or reduce the commitment without penalty. Common in upfront deals to provide flexibility.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelMix rdf:type rdf:Property ;
    rdfs:label 'Channel Mix' ;
    rdfs:comment 'Comma-separated list or description of broadcast channels, networks, or platforms included in this deal (e.g., Network Prime, Cable Bundle, OTT Streaming). Defines the inventory scope.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Date' ;
    rdfs:comment 'Date when the advertiser or agency verbally or formally committed to the deal terms. Nullable until commitment is secured.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cpmRate rdf:type rdf:Property ;
    rdfs:label 'Cpm Rate' ;
    rdfs:comment 'Cost per thousand impressions for CPM-based deals. Nullable if pricing basis is not CPM. Represents the unit price for audience delivery.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cprpRate rdf:type rdf:Property ;
    rdfs:label 'Cprp Rate' ;
    rdfs:comment 'Cost per rating point for CPRP-based deals. Nullable if pricing basis is not CPRP. Represents the unit price per GRP delivered.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealNumber rdf:type rdf:Property ;
    rdfs:label 'Deal Number' ;
    rdfs:comment 'Externally-known unique business identifier for the upfront deal, typically formatted as prefix-year-sequence (e.g., UF-2024-000123). Used in all client-facing communications and internal references.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealStatus rdf:type rdf:Property ;
    rdfs:label 'Deal Status' ;
    rdfs:comment 'Current lifecycle state of the upfront deal. Draft = initial creation; Submitted = sent to client; Negotiating = active discussions; Committed = verbal agreement; Executed = signed contract; Cancelled = deal terminated; Expired = proposal lapsed without commitment. [ENUM-REF-CANDIDATE: draft|submitted|negotiating|committed|executed|cancelled|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealType rdf:type rdf:Property ;
    rdfs:label 'Deal Type' ;
    rdfs:comment 'Classification of the advertising deal based on sales method and timing. Upfront = annual advance commitment during upfront season; Scatter = short-term last-minute inventory; Direct = negotiated one-off; Programmatic = automated auction-based; Sponsorship = integrated content partnership; Barter = trade arrangement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealYear rdf:type rdf:Property ;
    rdfs:label 'Deal Year' ;
    rdfs:comment 'Broadcast year for which this upfront deal applies, typically representing the September-to-August broadcast season (e.g., 2024 for 2024-2025 season). Critical for upfront planning and inventory allocation.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date when the deal contract was fully executed (signed by all parties). Nullable until contract is finalized.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makegoodProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Provision Flag' ;
    rdfs:comment 'Indicates whether the deal includes makegood provisions for audience delivery shortfalls. True = makegoods required if guaranteed audience is not delivered; False = no makegood obligation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiationRoundCount rdf:type rdf:Property ;
    rdfs:label 'Negotiation Round Count' ;
    rdfs:comment 'Number of formal negotiation rounds or proposal revisions submitted during the deal lifecycle. Tracks negotiation complexity and sales effort.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optionExerciseDeadline rdf:type rdf:Property ;
    rdfs:label 'Option Exercise Deadline' ;
    rdfs:comment 'Final date by which the advertiser must exercise any options included in the deal (e.g., additional quarters, scatter conversion, renewal). Nullable if no options are included.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingBasis rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis' ;
    rdfs:comment 'Pricing model used for this deal. CPM (Cost Per Mille) = cost per thousand impressions; CPRP (Cost Per Rating Point) = cost per GRP point; Flat Rate = fixed fee regardless of delivery; Performance = outcome-based pricing.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceOpportunityReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Reference' ;
    rdfs:comment 'External reference to the corresponding Salesforce Media Cloud Opportunity record. Enables cross-system traceability between the deal negotiation (Salesforce) and trafficking/billing (Wide Orbit).' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scatterConversionRights rdf:type rdf:Property ;
    rdfs:label 'Scatter Conversion Rights' ;
    rdfs:comment 'Indicates whether the advertiser has the right to convert unused upfront commitment into scatter market inventory at preferential rates. True = conversion allowed; False = no conversion rights.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCommittedSpend rdf:type rdf:Property ;
    rdfs:label 'Total Committed Spend' ;
    rdfs:comment 'Total dollar value of advertising spend committed by the advertiser after negotiation. Nullable until commitment is secured. This is the final agreed revenue amount.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProposedSpend rdf:type rdf:Property ;
    rdfs:label 'Total Proposed Spend' ;
    rdfs:comment 'Total dollar value of advertising spend proposed in the initial deal submission. Represents the gross revenue opportunity before negotiation adjustments.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteeId rdf:type rdf:Property ;
    rdfs:label 'Guarantee Id' ;
    rdfs:comment 'Unique surrogate identifier for the audience delivery guarantee record. Primary key for the audience_guarantee data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Guarantee .

ind:accountExecutiveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Executive Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Audience guarantees are sold and managed by account executives who negotiate CPRPs, delivery thresholds, makegood terms, and reconciliation with advertisers. AE assignment critical for commission calc' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_finding. Business justification: Guarantee delivery shortfalls may trigger audit findings for revenue recognition or contract compliance. SOX audits examine guarantee fulfillment; links findings to specific guarantee contracts.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_contract. Business justification: Upfront sales negotiations frequently tie audience guarantees to specific talent participation (e.g., guaranteed GRPs for episodes featuring marquee talent). Sales teams negotiate rate premiums and de' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:measurementMethodologyId rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology Id' ;
    rdfs:comment 'Foreign key linking to audience.measurement_methodology. Business justification: Each guarantee specifies which measurement methodology (Nielsen PPM, diary, set-top box) is used for verification. The measurement_source string should be replaced with a FK to the authoritative measu' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeasurementMethodology .

ind:networkChannelId rdf:type rdf:Property ;
    rdfs:label 'Network Channel Id' ;
    rdfs:comment 'Reference to the television network or channel on which the guaranteed audience delivery is to be achieved. Links to the network/channel master record used in scheduling and playout systems.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:politicalAdRecordId rdf:type rdf:Property ;
    rdfs:label 'Political Ad Record Id' ;
    rdfs:comment 'Foreign key linking to compliance.political_ad_record. Business justification: Political advertising guarantees require special tracking for equal time and reasonable access compliance. Links guarantee delivery to political ad records for FCC public file documentation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoliticalAdRecord .

ind:productionProjectId rdf:type rdf:Property ;
    rdfs:label 'Production Project Id' ;
    rdfs:comment 'Foreign key linking to production.project. Business justification: Upfront audience guarantees specify which production projects/series will deliver promised ratings. Required for makegood reconciliation, advertiser delivery reports, and sales contract fulfillment. C' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:soxControlId rdf:type rdf:Property ;
    rdfs:label 'Sox Control Id' ;
    rdfs:comment 'Foreign key linking to compliance.sox_control. Business justification: Guarantee contracts require SOX controls for revenue recognition and makegood liability estimation. Links guarantee data to financial reporting controls for revenue assertions and accrual accuracy.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoxControl .

ind:sweepsPeriodId rdf:type rdf:Property ;
    rdfs:label 'Sweeps Period Id' ;
    rdfs:comment 'Foreign key linking to audience.sweeps_period. Business justification: Audience guarantees are often tied to specific Nielsen sweeps periods for measurement and makegood calculations. The is_sweeps_period flag indicates relevance, but the specific sweeps period should be' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SweepsPeriod .

ind:actualTrpDelivered rdf:type rdf:Property ;
    rdfs:label 'Actual Trp Delivered' ;
    rdfs:comment 'The actual total TRP delivered against this guarantee within the target demographic, as measured by the designated audience measurement source. Populated during reconciliation. Used alongside actual_grp_delivered to assess guarantee fulfillment for demographic-specific commitments.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryShortfallGrp rdf:type rdf:Property ;
    rdfs:label 'Delivery Shortfall Grp' ;
    rdfs:comment 'The calculated difference between the guaranteed GRP level and the actual GRP delivered (guaranteed_grp minus actual_grp_delivered). A positive value indicates under-delivery and potential makegood obligation. Populated during reconciliation.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedFrequency rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Frequency' ;
    rdfs:comment 'The minimum average number of times a member of the target audience is exposed to the campaign (frequency) committed to the advertiser. Frequency is the average exposures per viewer. Used alongside reach guarantees for campaigns with specific exposure objectives.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedGrp rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Grp' ;
    rdfs:comment 'The total Gross Rating Point (GRP) level committed to the advertiser for delivery over the measurement period. GRP is the sum of ratings for all ad spots in the campaign, representing total audience exposure as a percentage of the target universe. This is the contractually obligated delivery level.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedReach rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Reach' ;
    rdfs:comment 'The minimum number of unique audience members (reach) committed to the advertiser over the measurement period. Reach is the count of distinct individuals exposed to the campaign at least once. Complements GRP/TRP guarantees for campaigns focused on unique audience coverage.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedTrp rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Trp' ;
    rdfs:comment 'The total Target Rating Point (TRP) level committed to the advertiser, measured specifically against the defined target demographic segment. TRP is the GRP filtered to the target audience. Used when the guarantee is demographic-specific rather than total audience.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isSweepsPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Sweeps Period' ;
    rdfs:comment 'Indicates whether the guarantee measurement period falls within a Nielsen sweeps period (intensive ratings measurement period). Sweeps periods (February, May, July, November) carry higher audience measurement scrutiny and may affect guarantee valuation and pricing.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:makegoodDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Makegood Deadline Date' ;
    rdfs:comment 'The contractual deadline by which makegood spots must be aired to compensate for any audience delivery shortfall. Critical for revenue assurance and advertiser relationship management.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makegoodGrpIssued rdf:type rdf:Property ;
    rdfs:label 'Makegood Grp Issued' ;
    rdfs:comment 'The total GRP value of makegood (compensatory ad spots) issued to the advertiser to compensate for audience delivery shortfall. Tracked for revenue assurance and advertiser relationship management. Zero if no makegoods were required.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodTriggerCondition rdf:type rdf:Property ;
    rdfs:label 'Makegood Trigger Condition' ;
    rdfs:comment 'Textual description of the specific conditions under which makegood (compensatory ad spots) obligations are activated. Defines the contractual rules for when and how makegoods must be provided to the advertiser when guaranteed audience delivery is not met. Sourced from the advertising contract terms.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenOrderCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Order Code' ;
    rdfs:comment 'The external order or tracking identifier assigned by the Nielsen Media Research Platform for the audience measurement order associated with this guarantee. Used to cross-reference Nielsen ratings data and reconciliation reports.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingMetricType rdf:type rdf:Property ;
    rdfs:label 'Rating Metric Type' ;
    rdfs:comment 'Specifies the primary audience measurement metric on which this guarantee is based. GRP (Gross Rating Point) measures total audience exposure; TRP (Target Rating Point) measures exposure within the target demographic; HUT (Homes Using Television) and PUT (Persons Using Television) measure set usage; reach measures unique audience count; frequency measures average exposures per viewer.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold Pct' ;
    rdfs:comment 'The acceptable percentage shortfall below the guaranteed GRP/TRP level before a makegood obligation is triggered. For example, a value of 5.00 means delivery must be within 5% of the guaranteed level. Defined in the advertising contract and used in reconciliation against actual delivery records.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGuaranteeValue rdf:type rdf:Property ;
    rdfs:label 'Total Guarantee Value' ;
    rdfs:comment 'The total contracted monetary value of this audience guarantee, calculated as guaranteed GRP/TRP multiplied by CPRP. Represents the revenue at risk if the guarantee is not met and is central to revenue assurance and financial reconciliation.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wideOrbitOrderCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Order Code' ;
    rdfs:comment 'The sales order identifier in the Wide Orbit Traffic and Billing system associated with this audience guarantee. Used for cross-system reconciliation between audience delivery records and ad scheduling/invoicing.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelId rdf:type rdf:Property ;
    rdfs:label 'Panel Id' ;
    rdfs:comment 'Unique surrogate identifier for the audience measurement panel record in the lakehouse. Primary key for the audience_panel entity.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Audience panels require dedicated panel managers responsible for recruitment, retention, weighting methodology compliance, and MRC accreditation maintenance. Manager assignment critical for universe e' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:marketCoverageId rdf:type rdf:Property ;
    rdfs:label 'Market Coverage Id' ;
    rdfs:comment 'Foreign key linking to audience.market_coverage. Business justification: Audience panels are defined for specific DMAs/markets. The dma_code and dma_name are redundant with market_coverage master data. Normalizing ensures consistency with market definitions used across nie' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketCoverage .

ind:primaryBroadcastFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Broadcast Facility Id' ;
    rdfs:comment 'Foreign key linking to technology.broadcast_facility. Business justification: Audience panels are geographically recruited and must link to the primary broadcast facility serving that DMA for local market measurement, signal quality validation, and MRC accreditation audits. Rol' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastFacility .

ind:adobeSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Adobe Segment Code' ;
    rdfs:comment 'Identifier linking this audience panel definition to a corresponding audience segment or profile group in Adobe Experience Platform (AEP). Enables cross-platform audience activation by mapping Nielsen panel demographics to digital audience segments for personalization and targeted ad delivery.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cooperationRate rdf:type rdf:Property ;
    rdfs:label 'Cooperation Rate' ;
    rdfs:comment 'Percentage of recruited panel households or individuals who are actively and consistently providing usable measurement data. A declining cooperation rate is an early indicator of panel quality degradation and may trigger MRC review. Expressed as a decimal (e.g., 0.8500 = 85%).' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code indicating the primary country of coverage for this panel (e.g., USA, GBR, AUS). Required for international panels and regulatory reporting to Ofcom and the European Audiovisual Observatory.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Technical mechanism used to collect viewing data from panel members. Electronic meters (people meters) require active button-pressing; set-top-box (STB) and smart TV ACR (Automatic Content Recognition) are passive; diary is self-reported. Determines the granularity and reliability of minute-by-minute audience data.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demographicComposition rdf:type rdf:Property ;
    rdfs:label 'Demographic Composition' ;
    rdfs:comment 'Narrative or structured description of the demographic breakdowns captured by this panel (e.g., \'Age 2+, Adults 18-49, Adults 25-54, Persons 2-17, Households by income quintile\'). Defines which demographic cuts are available for TRP (Target Rating Point) calculations and demographic audience guarantees in ad sales.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Breadth of geographic coverage represented by this panel. National panels project to the total US population; DMA (Designated Market Area) panels project to a specific local television market; International panels cover non-US territories.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementCurrencyFlag rdf:type rdf:Property ;
    rdfs:label 'Measurement Currency Flag' ;
    rdfs:comment 'Indicates whether this panel is designated as the official currency measurement source for audience guarantees in advertising transactions. True = this panel\'s data is used as the contractual basis for GRP/TRP delivery and makegood calculations in upfront and scatter market deals. False = supplemental or research-only panel.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minReportableRating rdf:type rdf:Property ;
    rdfs:label 'Min Reportable Rating' ;
    rdfs:comment 'The lowest audience rating value (expressed as a decimal fraction of the universe) that this panel can reliably report without exceeding acceptable statistical error thresholds. Ratings below this threshold are suppressed or flagged as unreliable. Typically expressed as a percentage (e.g., 0.0010 = 0.1%). Governed by MRC minimum cell size requirements.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrcAccreditationDate rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Date' ;
    rdfs:comment 'Date on which the MRC most recently granted or renewed accreditation for this panel. Used to track accreditation currency and schedule renewal audits. Panels must maintain continuous accreditation to support upfront and scatter market ad sales guarantees.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrcAccreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Expiry Date' ;
    rdfs:comment 'Date on which the current MRC accreditation for this panel expires and must be renewed. Expiry triggers a mandatory re-audit process. Ad sales teams must be notified of impending expiry to manage risk on guaranteed audience delivery commitments.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrcAccreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Status' ;
    rdfs:comment 'Current accreditation status granted by the Media Rating Council (MRC) for this panel. MRC accreditation is the industry standard for currency-grade audience measurement. Accredited panels are required for guaranteed ad buys and upfront sales commitments. Non-accredited panels cannot be used as primary currency.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenPanelCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Panel Code' ;
    rdfs:comment 'Nielsen\'s proprietary internal identifier for this panel as maintained in the Nielsen Media Research Platform. Used for direct API integration, data feed reconciliation, and cross-referencing Nielsen ratings reports. Distinct from the internal audience_panel_id surrogate key.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfHomeMeasurementFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Home Measurement Flag' ;
    rdfs:comment 'Indicates whether this panel captures out-of-home (OOH) viewing, such as viewing in bars, hotels, airports, and other public venues. OOH measurement is captured via Portable People Meter (PPM) technology. OOH-inclusive panels produce higher total audience estimates than in-home-only panels.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:panelCode rdf:type rdf:Property ;
    rdfs:label 'Panel Code' ;
    rdfs:comment 'Externally-known alphanumeric code assigned by the measurement provider (e.g., Nielsen) to uniquely identify this panel within their system. Used for cross-system reconciliation with the Nielsen Media Research Platform.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelName rdf:type rdf:Property ;
    rdfs:label 'Panel Name' ;
    rdfs:comment 'Human-readable name of the audience measurement panel (e.g., \'Nielsen National People Meter 2024\', \'Nielsen Local People Meter — New York DMA\'). Used in reporting, dashboards, and ad sales presentations.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelStatus rdf:type rdf:Property ;
    rdfs:label 'Panel Status' ;
    rdfs:comment 'Current lifecycle state of the audience panel. Active panels are used for currency-grade audience projections. Suspended panels are temporarily halted due to quality or compliance issues. Retired panels are decommissioned and replaced by newer vintages.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelType rdf:type rdf:Property ;
    rdfs:label 'Panel Type' ;
    rdfs:comment 'Classification of the audience measurement methodology used by this panel. National People Meter (NPM) and Local People Meter (LPM) are electronic metered panels; Portable People Meter (PPM) captures out-of-home exposure; Diary is self-reported; Return Path Data (RPD) is set-top-box passback data; Hybrid combines multiple methods.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruitmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Recruitment Methodology' ;
    rdfs:comment 'Statistical sampling approach used to recruit panel members. Probability-based sampling (address-based or random-digit-dial) is required for MRC-accredited currency panels. Opt-in panels are used for supplemental or proprietary measurement. Affects the projectability and accreditation status of the panel.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'Cadence at which panel membership is rotated or refreshed to prevent panel conditioning effects and maintain demographic representativeness. Annual and biennial refreshes are standard for people meter panels; continuous recruitment is used for large-scale return path data panels.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingGranularity rdf:type rdf:Property ;
    rdfs:label 'Reporting Granularity' ;
    rdfs:comment 'Finest time interval at which this panel can produce reliable audience estimates. Minute-by-minute granularity is available from electronic people meter panels and supports DAI (Dynamic Ad Insertion) optimization. Quarter-hour is standard for diary panels. Determines compatibility with EPG-based program-level ratings reporting.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingErrorPct rdf:type rdf:Property ;
    rdfs:label 'Sampling Error Pct' ;
    rdfs:comment 'Estimated margin of error (as a percentage) for audience projections derived from this panel at a 95% confidence interval. Smaller panels have higher sampling error. Used by ad sales teams to communicate measurement uncertainty to advertisers and to set makegood thresholds for audience delivery shortfalls.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeHouseholds rdf:type rdf:Property ;
    rdfs:label 'Size Households' ;
    rdfs:comment 'Total number of sample households actively participating in this panel at any given time. Drives the statistical reliability and margin of error of projected audience estimates. A larger panel size yields lower sampling error for low-rated programs.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sizeIndividuals rdf:type rdf:Property ;
    rdfs:label 'Size Individuals' ;
    rdfs:comment 'Total number of individual persons (panelists) actively measured within this panel. Distinct from household count because multiple individuals per household are measured for demographic breakdowns used in Target Rating Point (TRP) calculations.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:streamingMeasurementFlag rdf:type rdf:Property ;
    rdfs:label 'Streaming Measurement Flag' ;
    rdfs:comment 'Indicates whether this panel captures streaming and OTT (Over-The-Top) viewing in addition to linear broadcast. Streaming-enabled panels support cross-platform audience measurement combining linear TV, SVOD, AVOD, and FAST channel viewing for total audience reporting.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sweepsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Sweeps Eligible Flag' ;
    rdfs:comment 'Indicates whether this panel is used during Nielsen Sweeps periods (February, May, July, November) for local market ratings measurement. Sweeps data drives local ad rates and program scheduling decisions. Only MRC-accredited panels with sufficient local market sample sizes are sweeps-eligible.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:universeEstimate rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate' ;
    rdfs:comment 'Total projected population size (in persons or households) that this panel is designed to represent. The universe estimate is the denominator used to convert raw panel viewing counts into ratings percentages (e.g., HUT, PUT, Share). Updated periodically based on census data.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:universeEstimateType rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Type' ;
    rdfs:comment 'Specifies whether the universe_estimate represents total households, total persons, or TV households (HUT-eligible). TV households are the standard denominator for HUT (Homes Using Television) calculations in broadcast ratings.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vintageYear rdf:type rdf:Property ;
    rdfs:label 'Vintage Year' ;
    rdfs:comment 'Calendar year in which this panel sample was designed and recruited. Panels are periodically refreshed to maintain demographic representativeness as the population changes. Vintage year is used to track panel age and schedule mandatory refreshes per MRC accreditation requirements.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightingFactor rdf:type rdf:Property ;
    rdfs:label 'Weighting Factor' ;
    rdfs:comment 'Numeric multiplier applied to this panel\'s raw viewing data to project sample observations to the total universe estimate. A weighting factor greater than 1.0 indicates the panel under-represents a demographic segment relative to the population. Used in GRP and TRP calculations.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightingMethodology rdf:type rdf:Property ;
    rdfs:label 'Weighting Methodology' ;
    rdfs:comment 'Description of the statistical weighting approach applied to panel data to correct for demographic imbalances and non-response bias (e.g., \'Iterative Proportional Fitting / Raking\', \'Post-stratification weighting by age/sex/race/income\'). Critical for ensuring projected audience estimates are representative of the total population.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceProfileId rdf:type rdf:Property ;
    rdfs:label 'Audience Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the audience profile record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceProfile .

ind:nielsenPanelId rdf:type rdf:Property ;
    rdfs:label 'Nielsen Panel Id' ;
    rdfs:comment 'Pseudonymized identifier assigned by Nielsen Media Research to link this audience profile to a Nielsen panel household or individual. Enables direct integration of Nielsen ratings, GRP/TRP, and demographic data. Null for non-panel profiles.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Panel .

ind:adReceptivityScore rdf:type rdf:Property ;
    rdfs:label 'Ad Receptivity Score' ;
    rdfs:comment 'Propensity score (0.00–100.00) indicating this audience member\'s likelihood to engage with advertising content, derived from behavioral signals in Adobe AEP and viewing pattern analysis. Used by ad sales teams for premium audience packaging and CPM pricing optimization.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aepProfileCode rdf:type rdf:Property ;
    rdfs:label 'Aep Profile Code' ;
    rdfs:comment 'Unique profile identifier from Adobe Experience Platform (AEP) used to link behavioral engagement data, segment memberships, and journey analytics to this audience profile. Enables personalization and digital engagement enrichment.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aepSegmentMembership rdf:type rdf:Property ;
    rdfs:label 'Aep Segment Membership' ;
    rdfs:comment 'Comma-delimited list of Adobe Experience Platform (AEP) audience segment IDs to which this profile currently belongs. Segments represent behavioral, demographic, or propensity-based audience groups used for personalization, ad targeting, and journey activation.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avgSessionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Avg Session Duration Minutes' ;
    rdfs:comment 'Average duration in minutes of a single viewing session for this audience member, derived from set-top box or streaming platform telemetry. Represents Time Spent Viewing (TSV) at the individual level. Used for engagement scoring and content performance analytics.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccpaOptOut rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out' ;
    rdfs:comment 'Indicates whether this California-resident audience member has exercised their CCPA right to opt out of the sale or sharing of their personal information. When TRUE, this profile must be excluded from data sharing with third-party ad networks and data clean rooms.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent change to any consent or privacy flag (GDPR consent status, CCPA opt-out, COPPA flag) for this audience profile. Critical for regulatory audit trails demonstrating timely consent management and data processing compliance.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contentAffinityGenre rdf:type rdf:Property ;
    rdfs:label 'Content Affinity Genre' ;
    rdfs:comment 'Top inferred content genre affinity for this audience member (e.g., \'news\', \'sports\', \'drama\', \'reality\', \'documentary\'), derived from viewing history and behavioral signals in Adobe AEP. Used for content recommendation, programming decisions, and audience-targeted ad sales. [ENUM-REF-CANDIDATE: news|sports|drama|comedy|reality|documentary|entertainment|kids|lifestyle|sci_fi — promote to reference product]' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaProtected rdf:type rdf:Property ;
    rdfs:label 'Coppa Protected' ;
    rdfs:comment 'Indicates whether this audience profile is subject to COPPA (Children\'s Online Privacy Protection Act) protections, meaning the inferred or declared age is under 13. When TRUE, ad targeting, data sharing, and behavioral tracking are strictly restricted per COPPA compliance requirements.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCleanRoomEligible rdf:type rdf:Property ;
    rdfs:label 'Data Clean Room Eligible' ;
    rdfs:comment 'Indicates whether this audience profile is eligible for inclusion in data clean room matching operations with advertising partners. Eligibility is determined by consent status, CCPA opt-out flag, COPPA protection status, and contractual data sharing agreements.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daypartPreference rdf:type rdf:Property ;
    rdfs:label 'Daypart Preference' ;
    rdfs:comment 'Preferred daypart (time segment of the broadcast day) during which this audience member most frequently views content. Dayparts are standard broadcast industry time segments used for ad scheduling, upfront sales, and audience guarantee reporting.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceGraphCode rdf:type rdf:Property ;
    rdfs:label 'Device Graph Code' ;
    rdfs:comment 'Cross-device graph linkage identifier that associates this audience profile with a cluster of known devices (smart TV, mobile, desktop, STB). Sourced from identity resolution providers or Adobe AEP device graph. Enables multi-screen reach and frequency measurement.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrichmentSourceVersion rdf:type rdf:Property ;
    rdfs:label 'Enrichment Source Version' ;
    rdfs:comment 'Version identifier of the third-party enrichment data package (e.g., Nielsen demographic file version, Adobe AEP segment refresh batch ID) used to populate inferred attributes on this profile. Enables data lineage tracing and reproducibility of audience segment definitions.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Status' ;
    rdfs:comment 'Current GDPR consent status for processing this audience member\'s personal data for audience measurement and advertising purposes. \'granted\' permits processing; \'denied\' or \'withdrawn\' restricts processing; \'not_applicable\' for non-EU audience members. Drives data processing eligibility.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdSize rdf:type rdf:Property ;
    rdfs:label 'Household Size' ;
    rdfs:comment 'Estimated number of persons in the audience household, derived from Nielsen panel data or set-top box signals. Used in HUT (Homes Using Television) and PUT (Persons Using Television) calculations for audience measurement reporting.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hutEligible rdf:type rdf:Property ;
    rdfs:label 'Hut Eligible' ;
    rdfs:comment 'Indicates whether this household-level audience profile is eligible to be counted in HUT (Homes Using Television) calculations. HUT measures the percentage of TV-equipped homes actively watching television during a given time period, a foundational metric for broadcast ratings.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identityConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Identity Confidence Score' ;
    rdfs:comment 'Confidence score (0.00–100.00) representing the reliability of the identity resolution that constructed this audience profile. Higher scores indicate stronger deterministic matching (e.g., authenticated login); lower scores indicate probabilistic device-graph inference. Used to qualify profiles for premium ad targeting.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identityHash rdf:type rdf:Property ;
    rdfs:label 'Identity Hash' ;
    rdfs:comment 'SHA-256 pseudonymized hash of the audience member\'s primary identity (e.g., email or subscriber ID) used for cross-platform identity resolution without exposing raw PII. Enables privacy-safe linkage across Nielsen, Adobe AEP, and first-party data sources.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identitySource rdf:type rdf:Property ;
    rdfs:label 'Identity Source' ;
    rdfs:comment 'Originating source of the audience identity construction: \'first_party\' (subscriber or app registration data), \'nielsen\' (Nielsen Media Research panel linkage), \'adobe_aep\' (Adobe Experience Platform profile), \'set_top_box\' (STB device-level data), \'clean_room\' (data clean room match), or \'modeled\' (probabilistic inference).' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBand rdf:type rdf:Property ;
    rdfs:label 'Income Band' ;
    rdfs:comment 'Inferred household income band derived from third-party demographic enrichment (Nielsen, data clean rooms). Used for premium audience segmentation in upfront and scatter market ad sales, enabling CPM pricing differentiation by audience affluence.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferredAgeBand rdf:type rdf:Property ;
    rdfs:label 'Inferred Age Band' ;
    rdfs:comment 'Inferred age demographic band for the audience member, derived from Nielsen panel data, set-top box signals, or modeled enrichment. Used for GRP/TRP demographic targeting and ad sales audience guarantees. Not directly collected from the individual.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferredGender rdf:type rdf:Property ;
    rdfs:label 'Inferred Gender' ;
    rdfs:comment 'Inferred gender of the audience member derived from panel data or modeled signals. Used for demographic audience targeting in ad sales (GRP/TRP calculations) and programming decisions. Not directly collected.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSeenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Seen Timestamp' ;
    rdfs:comment 'Timestamp of the most recent observed audience activity event (viewing session, app interaction, or platform login) for this profile. Used to determine audience recency, drive re-engagement campaigns, and calculate viewing recency metrics.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nielsenGrpIndex rdf:type rdf:Property ;
    rdfs:label 'Nielsen Grp Index' ;
    rdfs:comment 'Indexed GRP (Gross Rating Point) score for this audience profile relative to the total population, sourced from Nielsen Media Research. A GRP index above 100 indicates above-average exposure to rated content. Used in ad sales audience guarantees and upfront negotiations.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:panelWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Panel Weight Factor' ;
    rdfs:comment 'Statistical weighting factor assigned by Nielsen to this panel member profile to project panel observations to the total population. Applied in GRP, TRP, HUT, and PUT calculations. Null for non-panel (modeled or first-party only) profiles.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformPreference rdf:type rdf:Property ;
    rdfs:label 'Platform Preference' ;
    rdfs:comment 'Primary viewing platform preference inferred from behavioral signals: \'linear_tv\' (traditional scheduled broadcast), \'svod\' (Subscription Video On Demand), \'avod\' (Advertising-Supported VOD), \'tvod\' (Transactional VOD), \'fast\' (Free Ad-Supported Streaming TV), \'ott\' (Over-The-Top), \'mvpd\' (Multichannel Video Programming Distributor), or \'vmvpd\' (Virtual MVPD). Drives distribution strategy and ad product targeting. [ENUM-REF-CANDIDATE: linear_tv|svod|avod|tvod|fast|ott|mvpd|vmvpd — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDeviceType rdf:type rdf:Property ;
    rdfs:label 'Primary Device Type' ;
    rdfs:comment 'The primary device type through which this audience member most frequently consumes content, derived from device graph and behavioral data. Used for CDN delivery optimization, ad format targeting, and platform analytics.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle state of the audience profile. \'suppressed\' indicates a privacy opt-out or regulatory hold; \'pending_consent\' indicates consent collection is in progress; \'purged\' indicates the record has been anonymized per GDPR/CCPA erasure request.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileType rdf:type rdf:Property ;
    rdfs:label 'Profile Type' ;
    rdfs:comment 'Classification of the audience profile record: \'individual\' (single person identity), \'household\' (aggregated household unit), \'panel_member\' (Nielsen or equivalent panel participant), or \'modeled\' (synthetically constructed from behavioral signals without direct identity linkage).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepsPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Sweeps Period Flag' ;
    rdfs:comment 'Indicates whether this audience profile\'s measurement data was captured during a Nielsen Sweeps period (intensive ratings measurement period: February, May, July, November). Sweeps data carries higher statistical weight in ratings calculations and programming decisions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trpIndex rdf:type rdf:Property ;
    rdfs:label 'Trp Index' ;
    rdfs:comment 'Indexed TRP (Target Rating Point) score representing this audience member\'s contribution to a specific demographic target group\'s rating. Distinct from GRP in that it measures reach within a defined target demographic. Used for demographic-specific ad campaign planning and post-campaign analysis.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewingRecencyDays rdf:type rdf:Property ;
    rdfs:label 'Viewing Recency Days' ;
    rdfs:comment 'Number of days since this audience member last engaged with any content on any tracked platform. Used for audience recency segmentation, churn prediction, and re-engagement campaign targeting. Lower values indicate more recently active audiences.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weeklyViewingFrequency rdf:type rdf:Property ;
    rdfs:label 'Weekly Viewing Frequency' ;
    rdfs:comment 'Average number of distinct viewing sessions per week for this audience member, calculated over a rolling 4-week window. Represents the Frequency dimension of audience measurement (average exposures per viewer). Used in reach and frequency reporting for ad campaign delivery.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationStatus rdf:type rdf:Property ;
    rdfs:label 'Activation Status' ;
    rdfs:comment 'Current lifecycle state of the segment governing whether it is available for use in ad targeting, campaign activation, or content personalization. \'draft\' indicates under construction; \'pending_review\' awaits compliance or data governance approval; \'active\' is live and deployable; \'inactive\' is suspended; \'archived\' is retired.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aepSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Aep Segment Code' ;
    rdfs:comment 'The segment identifier as defined and managed within Adobe Experience Platform (AEP). Used for digital audience activation, personalization journeys, and cross-channel targeting. Enables synchronization between the internal audience_segment master record and the AEP segment definition for OTT and digital platforms.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageRangeMax rdf:type rdf:Property ;
    rdfs:label 'Age Range Max' ;
    rdfs:comment 'Maximum age (inclusive) of the primary demographic target for this segment, expressed in years. Used with age_range_min to define the Nielsen demographic cell. A null value indicates an open-ended upper bound (e.g., \'55+\' segments).' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeMin rdf:type rdf:Property ;
    rdfs:label 'Age Range Min' ;
    rdfs:comment 'Minimum age (inclusive) of the primary demographic target for this segment, expressed in years. Used in conjunction with age_range_max to define the Nielsen demographic cell (e.g., 25 for the \'Adults 25-54\' standard Nielsen demo). Null if the segment is not age-bounded.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the data governance or compliance approver who authorized this segment for activation, particularly for segments involving sensitive demographic data, COPPA-restricted audiences, or GDPR-regulated EU audiences. Supports audit trail requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentGenreAffinity rdf:type rdf:Property ;
    rdfs:label 'Content Genre Affinity' ;
    rdfs:comment 'Primary content genre(s) this segment shows strong viewership affinity toward, used for programming strategy alignment and contextual ad targeting (e.g., \'drama,sports,news\'). Sourced from Nielsen viewing behavior data or Adobe AEP content interaction signals. Informs content acquisition decisions and ad pod placement strategy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Identifies the primary data origin used to construct the segment. \'nielsen\' indicates Nielsen Media Research Platform ratings and demographic data; \'adobe_aep\' indicates Adobe Experience Platform behavioral profiles; \'first_party\' indicates proprietary subscriber or registration data; \'third_party\' indicates licensed external data; \'hybrid\' indicates a combination of multiple sources.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartApplicability rdf:type rdf:Property ;
    rdfs:label 'Daypart Applicability' ;
    rdfs:comment 'Broadcast daypart(s) for which this segment is most relevant or has been validated, expressed as a comma-delimited list of standard daypart labels (e.g., \'primetime,late_night\'). Daypart is a standard media-buying time segment of the broadcast day used in ad scheduling and upfront sales. [ENUM-REF-CANDIDATE: early_morning|daytime|early_fringe|primetime|late_news|late_night|overnight — promote to reference product]' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionLogic rdf:type rdf:Property ;
    rdfs:label 'Definition Logic' ;
    rdfs:comment 'The rule-based or SQL/JSON expression that defines segment membership criteria as implemented in Adobe AEP or Nielsen. Captures the inclusion/exclusion logic (e.g., age range, viewing frequency thresholds, content genre affinity, platform usage) used to qualify audience members into this segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'The date from which this segment definition is considered valid and available for business use. Segments may be pre-built ahead of upfront sales seasons or campaign launches. Enables temporal validity management for segment versioning and historical reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'The date after which this segment definition is no longer valid for new activations. Null indicates an open-ended segment with no planned expiry. Used to manage seasonal segments (e.g., sweeps-period segments), campaign-specific segments, and segments tied to expiring data licensing agreements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedReachUnit rdf:type rdf:Property ;
    rdfs:label 'Estimated Reach Unit' ;
    rdfs:comment 'Unit of measurement for the estimated_reach figure. \'persons\' aligns with Nielsen PUT (Persons Using Television) methodology; \'households\' aligns with HUT (Homes Using Television); \'devices\' applies to digital/OTT platform segments measured by device-level identity.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderTarget rdf:type rdf:Property ;
    rdfs:label 'Gender Target' ;
    rdfs:comment 'Gender composition target for the segment as defined in Nielsen demographic cells and ad sales targeting parameters. \'all\' indicates gender-neutral targeting. Used in GRP (Gross Rating Point) and TRP (Target Rating Point) calculations for ad campaign planning.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpIndex rdf:type rdf:Property ;
    rdfs:label 'Grp Index' ;
    rdfs:comment 'The GRP (Gross Rating Point) index value representing this segment\'s relative audience weight as a percentage of the total universe. GRP is a fundamental media planning metric equal to Reach × Frequency. Used in upfront and scatter market ad sales to price inventory and measure campaign delivery against this segment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hutPutBasis rdf:type rdf:Property ;
    rdfs:label 'Hut Put Basis' ;
    rdfs:comment 'Indicates whether the segment\'s reach and rating metrics are calculated on a HUT (Homes Using Television) or PUT (Persons Using Television) basis. HUT is household-level measurement; PUT is person-level. This distinction governs how GRP/TRP values are interpreted and how the segment is applied in Nielsen-based ad sales planning.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBracket rdf:type rdf:Property ;
    rdfs:label 'Income Bracket' ;
    rdfs:comment 'Household income tier associated with the segment\'s demographic composition, used in premium ad targeting and CPM (Cost Per Mille) pricing. Expressed as a standardized range label (e.g., \'$75K-$100K HHI\', \'$100K+ HHI\'). Sourced from Nielsen MRI-Simmons or first-party subscriber data. [ENUM-REF-CANDIDATE: under_25k|25k_50k|50k_75k|75k_100k|100k_150k|150k_plus — promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDaiEligible rdf:type rdf:Property ;
    rdfs:label 'Is Dai Eligible' ;
    rdfs:comment 'Indicates whether this segment is approved and technically configured for use in DAI (Dynamic Ad Insertion) workflows on OTT and streaming platforms. DAI-eligible segments can be activated in real-time ad decisioning systems integrated with Akamai CDN and programmatic ad servers for addressable advertising.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSweepsValidated rdf:type rdf:Property ;
    rdfs:label 'Is Sweeps Validated' ;
    rdfs:comment 'Indicates whether this segment\'s reach and demographic composition estimates have been validated using Nielsen Sweeps period data (the intensive ratings measurement periods in February, May, July, and November). Sweeps-validated segments carry higher confidence for upfront ad sales commitments and programming decisions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'The date and time when the segment membership, reach estimates, and demographic composition were last recalculated from source data. Used to assess data freshness for ad sales proposals and campaign activation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nielsenSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Segment Code' ;
    rdfs:comment 'The corresponding segment or audience cell identifier within the Nielsen Media Research Platform. Enables direct linkage to Nielsen ratings data, GRP/TRP delivery reports, and demographic reach/frequency outputs. Used for reconciliation between internal segment definitions and Nielsen-measured audience delivery.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerTeam rdf:type rdf:Property ;
    rdfs:label 'Owner Team' ;
    rdfs:comment 'The business team or department that owns and is accountable for this segment\'s definition, quality, and lifecycle management (e.g., \'Ad Sales Research\', \'Audience Analytics\', \'Programming Strategy\', \'Digital Marketing\'). Used for data governance, access control, and segment portfolio management.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformApplicability rdf:type rdf:Property ;
    rdfs:label 'Platform Applicability' ;
    rdfs:comment 'Comma-delimited list of distribution platforms for which this segment is valid and activated (e.g., \'linear,ott,avod,svod,fast\'). Governs where the segment can be applied for ad targeting or content personalization across Linear, OTT (Over-The-Top), AVOD (Advertising-Supported Video On Demand), SVOD (Subscription Video On Demand), and FAST (Free Ad-Supported Streaming Television) channels. [ENUM-REF-CANDIDATE: linear|ott|avod|svod|tvod|fast|social|digital_display — promote to reference product]' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCategory rdf:type rdf:Property ;
    rdfs:label 'Segment Category' ;
    rdfs:comment 'Business-facing category grouping segments for portfolio management and reporting (e.g., \'Ad Targeting\', \'Programming Strategy\', \'Content Personalization\', \'Subscriber Retention\', \'Regulatory Reporting\'). Enables segment library organization in Salesforce Media Cloud and Adobe AEP. [ENUM-REF-CANDIDATE: ad_targeting|programming_strategy|content_personalization|subscriber_retention|regulatory_reporting|audience_research — promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the segment used across systems such as Adobe Experience Platform (AEP), Nielsen, and Salesforce Media Cloud. Serves as the canonical cross-system reference code (e.g., \'SEG-DEMO-F25-54-OTT\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the segment\'s business purpose, defining criteria, and intended use cases. Provides context for ad sales teams, programmers, and data analysts on what the segment represents and how it should be applied.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable display name for the audience segment as it appears in ad sales proposals, programming strategy decks, and campaign targeting UIs (e.g., \'Women 25-54 OTT Heavy Viewers\'). Corresponds to the segment label in Adobe AEP and Salesforce Media Cloud.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segment by the primary methodology used to define it. Demographic segments are built on age/gender/HUT criteria; behavioral on viewing patterns; psychographic on interests/attitudes; contextual on content affinity; lookalike on modeled similarity to a seed audience.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossPlatformMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Measurement Id' ;
    rdfs:comment 'Unique surrogate identifier for each cross-platform audience measurement record in the Silver layer lakehouse. Primary key for this transactional entity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrossPlatformMeasurement .

ind:contentTitleId rdf:type rdf:Property ;
    rdfs:label 'Content Title Id' ;
    rdfs:comment 'Reference to the content title or program for which this cross-platform audience measurement is recorded. Links to the content master data product in the Content domain.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:measurementAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Measurement Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Cross-platform measurement requires specialized analysts to perform deduplication, validate MRC-accredited methodologies, reconcile linear/OTT/MVPD impressions, and certify total audience metrics. Ana' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Foreign key linking to sales.opportunity. Business justification: Cross-platform measurement is a key differentiator in modern media sales, directly referenced when pitching multi-platform opportunities. Sales teams use cross-platform reach data to justify premium p' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:productionEpisodeId rdf:type rdf:Property ;
    rdfs:label 'Production Episode Id' ;
    rdfs:comment 'Foreign key linking to production.production_episode. Business justification: Episode-level cross-platform measurement is required for total audience delivery verification, especially for time-shifted viewing and multi-platform distribution. Essential for C3/C7 ratings and adve' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionEpisode .

ind:audienceShare rdf:type rdf:Property ;
    rdfs:label 'Audience Share' ;
    rdfs:comment 'Percentage of the total viewing audience (HUT or PUT) that was watching this specific content or channel during the measurement period. Calculated as the program rating divided by HUT or PUT. Key programming performance indicator.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageFrequency rdf:type rdf:Property ;
    rdfs:label 'Average Frequency' ;
    rdfs:comment 'Average number of times a unique individual in the deduplicated reach was exposed to the content or campaign across all platforms within the measurement period. Calculated as total impressions divided by deduplicated reach.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coViewingAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Co Viewing Adjustment Factor' ;
    rdfs:comment 'Multiplicative adjustment factor applied to account for co-viewing behavior (multiple persons watching on a single device/screen), particularly relevant for connected TV and OTT platforms. Values greater than 1.0 indicate upward adjustment for co-viewing. Sourced from Nielsen co-viewing methodology.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossPlatformGrp rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Grp' ;
    rdfs:comment 'Gross Rating Point (GRP) calculated across all measured platforms, representing the sum of ratings for all platform exposures within the target universe. Equals total impressions divided by the target universe population, multiplied by 100. Primary audience currency for converged TV ad buying.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossPlatformTrp rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Trp' ;
    rdfs:comment 'Target Rating Point (TRP) calculated across all measured platforms for the specified target demographic segment. Measures GRP within the defined target audience, used for demographic-specific ad buying and campaign performance evaluation.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyVersion rdf:type rdf:Property ;
    rdfs:label 'Currency Version' ;
    rdfs:comment 'Version identifier of the audience measurement currency standard applied to this record (e.g., \'Nielsen ONE v2.1\', \'Comscore Campaign Ratings v3.0\'). Supports multi-currency and currency transition tracking as the industry evolves from legacy Nielsen C3/C7 to cross-platform currencies.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystems rdf:type rdf:Property ;
    rdfs:label 'Data Source Systems' ;
    rdfs:comment 'Pipe-delimited list of operational source systems that contributed data to this cross-platform measurement record (e.g., \'Nielsen Media Research Platform|Adobe Experience Platform\'). Supports data lineage, audit, and methodology transparency requirements.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartCode rdf:type rdf:Property ;
    rdfs:label 'Daypart Code' ;
    rdfs:comment 'Broadcast daypart classification for the measurement period, representing the time segment of the broadcast day. [ENUM-REF-CANDIDATE: EAM|AM|DAYTIME|EARLY_FRINGE|PRIME|LATE_FRINGE|OVERNIGHT — promote to reference product if additional dayparts are required]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deduplicatedReach rdf:type rdf:Property ;
    rdfs:label 'Deduplicated Reach' ;
    rdfs:comment 'Total count of unique, unduplicated individuals (persons) who were exposed to the content or campaign across all measured platforms within the measurement period. Core audience currency metric for converged TV buying. Expressed as absolute person count.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionType rdf:type rdf:Property ;
    rdfs:label 'Distribution Type' ;
    rdfs:comment 'Primary distribution model classification for the content being measured: \'linear\' for traditional scheduled broadcast; \'vod\' for generic on-demand; \'svod\' for subscription streaming; \'avod\' for ad-supported streaming; \'tvod\' for transactional on-demand; \'fast\' for free ad-supported streaming TV; \'social\' for social video platforms. [ENUM-REF-CANDIDATE: linear|vod|svod|avod|tvod|fast|social — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastChannelImpressions rdf:type rdf:Property ;
    rdfs:label 'Fast Channel Impressions' ;
    rdfs:comment 'Audience impressions attributed to Free Ad-Supported Streaming Television (FAST) channels within the measurement period. Represents the growing ad-supported streaming audience segment.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hutRating rdf:type rdf:Property ;
    rdfs:label 'Hut Rating' ;
    rdfs:comment 'Homes Using Television (HUT) rating for the measurement period, representing the percentage of all television households with at least one TV set in use during the measured time period. Used for share calculations and programming decisions.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDataSuppressed rdf:type rdf:Property ;
    rdfs:label 'Is Data Suppressed' ;
    rdfs:comment 'Indicates whether this measurement record has been suppressed from reporting due to insufficient panel sample size, MRC minimum reporting thresholds, or privacy regulations (GDPR/CCPA). Suppressed records are retained for audit but excluded from audience currency reporting.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMrcAccredited rdf:type rdf:Property ;
    rdfs:label 'Is Mrc Accredited' ;
    rdfs:comment 'Indicates whether this measurement was produced using a methodology that holds current Media Rating Council (MRC) accreditation for cross-platform measurement. MRC accreditation is required for use as official audience currency in upfront and scatter market ad transactions.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isanCode rdf:type rdf:Property ;
    rdfs:label 'Isan Code' ;
    rdfs:comment 'International Standard Audiovisual Number (ISAN) for the content title being measured, providing a globally unique, persistent identifier for the audiovisual work. Enables cross-system content identification and rights reconciliation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linearImpressions rdf:type rdf:Property ;
    rdfs:label 'Linear Impressions' ;
    rdfs:comment 'Audience impressions attributed to traditional linear broadcast television (over-the-air, cable, satellite) within the measurement period. Component of the platform-level audience breakdown.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End' ;
    rdfs:comment 'The last date of the audience measurement observation window, aligned to the content airing schedule or campaign flight end.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start' ;
    rdfs:comment 'The first date of the audience measurement observation window, aligned to the content airing schedule or campaign flight start. Used for sweeps period identification and daypart analysis.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Measurement Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this cross-platform measurement record, used in reporting, ad sales proposals, and audience currency reconciliation. Sourced from Nielsen Media Research Platform or internal measurement workflow.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Current lifecycle state of the cross-platform measurement record. \'draft\' indicates data is being assembled; \'preliminary\' indicates initial estimate released; \'certified\' indicates MRC-audited final figure; \'revised\' indicates a post-certification correction; \'archived\' indicates superseded by a newer measurement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The principal real-world timestamp representing when the audience measurement observation period was captured or the measurement run was executed. Distinct from record audit timestamps.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mvpdImpressions rdf:type rdf:Property ;
    rdfs:label 'Mvpd Impressions' ;
    rdfs:comment 'Audience impressions attributed to Multichannel Video Programming Distributor (MVPD) and virtual MVPD (vMVPD) platforms, including cable, satellite, and virtual pay-TV providers within the measurement period.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nielsenRating rdf:type rdf:Property ;
    rdfs:label 'Nielsen Rating' ;
    rdfs:comment 'The Nielsen Rating for the content or program within the measurement period, representing the percentage of all television households or persons in the universe tuned to the program. The foundational audience currency metric for linear broadcast.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ottStreamingImpressions rdf:type rdf:Property ;
    rdfs:label 'Ott Streaming Impressions' ;
    rdfs:comment 'Audience impressions attributed to Over-The-Top (OTT) and Subscription Video On Demand (SVOD) streaming platforms within the measurement period. Includes authenticated streaming on connected TV, mobile, and desktop devices.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panelSampleSize rdf:type rdf:Property ;
    rdfs:label 'Panel Sample Size' ;
    rdfs:comment 'Number of panel households or persons in the Nielsen (or equivalent vendor) measurement panel that contributed to this cross-platform measurement. Indicates statistical reliability; low sample sizes may trigger data suppression per MRC minimum reporting standards.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putRating rdf:type rdf:Property ;
    rdfs:label 'Put Rating' ;
    rdfs:comment 'Persons Using Television (PUT) rating for the measurement period, representing the percentage of all persons in the universe who are watching television during the measured time period. Used for person-level audience share calculations.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialVideoImpressions rdf:type rdf:Property ;
    rdfs:label 'Social Video Impressions' ;
    rdfs:comment 'Audience impressions attributed to social video platforms (e.g., YouTube, Facebook Video, TikTok, Instagram Reels) within the measurement period. Enables full cross-platform audience aggregation.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetUniverseSize rdf:type rdf:Property ;
    rdfs:label 'Target Universe Size' ;
    rdfs:comment 'The estimated total population size of the target demographic universe used as the denominator for GRP and TRP calculations. Sourced from Nielsen universe estimates updated annually.' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalImpressions rdf:type rdf:Property ;
    rdfs:label 'Total Impressions' ;
    rdfs:comment 'Total number of audience exposures (impressions) across all platforms within the measurement period, including duplicate exposures across platforms. Used for CPM-based advertising currency and GRP calculation inputs.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpmIndex rdf:type rdf:Property ;
    rdfs:label 'Cpm Index' ;
    rdfs:comment 'Relative CPM (Cost Per Mille) pricing index for this demographic segment compared to the baseline segment (index = 100). Premium segments such as A18-49 or W25-54 carry higher indices reflecting advertiser demand. Used in Salesforce Media Cloud ad sales proposals and upfront/scatter market pricing negotiations. Confidential commercial pricing data.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daypartRelevance rdf:type rdf:Property ;
    rdfs:label 'Daypart Relevance' ;
    rdfs:comment 'Comma-separated list of broadcast dayparts (e.g., \'Prime Time, Late Fringe, Daytime\') for which this demographic segment has primary relevance in programming and ad sales strategy. Informs Ericsson MediaFirst scheduling decisions and Wide Orbit daypart-based ad pod targeting. Null if the segment applies across all dayparts.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethnicityClassification rdf:type rdf:Property ;
    rdfs:label 'Ethnicity Classification' ;
    rdfs:comment 'Standardized ethnicity classification label for ethnicity-based demographic segments (e.g., \'Hispanic/Latino\', \'African American\', \'Asian American\', \'Non-Hispanic White\'). Populated only for ethnicity segment types. Aligned with Nielsen multicultural audience measurement standards and used in targeted content programming and ad sales. [ENUM-REF-CANDIDATE: hispanic_latino|african_american|asian_american|non_hispanic_white|native_american|multiracial|other — promote to reference product]' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprSpecialCategory rdf:type rdf:Property ;
    rdfs:label 'Gdpr Special Category' ;
    rdfs:comment 'Indicates whether this demographic segment is based on GDPR Article 9 special category data (e.g., ethnicity, health status). When true, enhanced consent and data processing controls are required for EU audience data associated with this segment. Relevant for pan-European distribution platforms and Ofcom-regulated services.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderQualifier rdf:type rdf:Property ;
    rdfs:label 'Gender Qualifier' ;
    rdfs:comment 'Gender dimension of the demographic cell. \'All\' denotes combined-gender segments (e.g., Adults 18-49, Persons 2+). Aligns with Nielsen standard gender breakdowns used in GRP/TRP calculations and ad sales targeting.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Grp Weight Factor' ;
    rdfs:comment 'Weighting factor applied to this demographic segment when calculating Gross Rating Points (GRP) and Target Rating Points (TRP) in audience measurement reports. Reflects the relative population size and measurement panel representation of the segment. Sourced from the Nielsen Media Research Platform and used in Wide Orbit ad scheduling and campaign delivery calculations.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdComposition rdf:type rdf:Property ;
    rdfs:label 'Household Composition' ;
    rdfs:comment 'Classification of household structure for household-based demographic segments. Used in HUT (Homes Using Television) and PUT (Persons Using Television) audience measurement reporting and in family-oriented programming and advertising targeting strategies.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iabAudienceCode rdf:type rdf:Property ;
    rdfs:label 'Iab Audience Code' ;
    rdfs:comment 'The IAB Audience Taxonomy 2.0 standardized code corresponding to this demographic segment. Enables cross-platform audience targeting alignment between linear broadcast, OTT/AVOD/SVOD digital campaigns, and programmatic advertising systems. Used in Salesforce Media Cloud ad proposals and Adobe Experience Platform segment mapping.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeQuintile rdf:type rdf:Property ;
    rdfs:label 'Income Quintile' ;
    rdfs:comment 'Household income quintile ranking (1=lowest 20%, 5=highest 20%) for income-based demographic segments. Populated only for income quintile segment types. Used in premium CPM pricing tiers and upfront ad sales targeting for high-value audience packages.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isChildrenSegment rdf:type rdf:Property ;
    rdfs:label 'Is Children Segment' ;
    rdfs:comment 'Indicates whether this demographic segment includes individuals under 13 years of age (e.g., K2-11, K2-5). Triggers COPPA compliance controls on data collection, ad targeting restrictions, and content rating enforcement. Critical for regulatory compliance in digital and broadcast advertising.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKeyDemo rdf:type rdf:Property ;
    rdfs:label 'Is Key Demo' ;
    rdfs:comment 'Flags whether this segment is designated as a key demographic (key demo) for the organization\'s primary ad sales and programming strategy. Key demos (typically A18-49, W25-54) command premium CPM rates and are the primary currency in upfront and scatter market negotiations.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNielsenStandardCell rdf:type rdf:Property ;
    rdfs:label 'Is Nielsen Standard Cell' ;
    rdfs:comment 'Indicates whether this demographic segment corresponds to an official Nielsen standard demographic cell (e.g., A18-49, W25-54). True for Nielsen-defined cells used in GRP/TRP/HUT/PUT ratings calculations; False for custom or proprietary segments defined internally or via Adobe Experience Platform.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nielsenCellLabel rdf:type rdf:Property ;
    rdfs:label 'Nielsen Cell Label' ;
    rdfs:comment 'The exact Nielsen Media Research standard cell label for this demographic segment (e.g., \'A18-49\', \'W25-54\', \'M18-34\', \'K2-11\', \'P2+\'). Used as the authoritative cross-reference when ingesting Nielsen ratings data and reconciling audience measurement reports from the Nielsen Media Research Platform.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psychographicProfile rdf:type rdf:Property ;
    rdfs:label 'Psychographic Profile' ;
    rdfs:comment 'Descriptive label for psychographic segment classification (e.g., \'Early Adopters\', \'Value Seekers\', \'Sports Enthusiasts\', \'News Junkies\'). Populated only for psychographic segment types. Derived from Adobe Experience Platform audience profiling and used in premium ad sales targeting and programming strategy.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachPotentialPct rdf:type rdf:Property ;
    rdfs:label 'Reach Potential Pct' ;
    rdfs:comment 'Estimated maximum reach potential expressed as a percentage of the segment universe achievable across the organization\'s full distribution footprint. Used in media planning to set realistic reach targets for ad campaigns and programming strategies. Sourced from Nielsen reach and frequency models.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Restriction Flag' ;
    rdfs:comment 'Indicates whether this demographic segment is subject to regulatory restrictions on data collection, targeting, or advertising. True for segments including minors (COPPA), sensitive demographic categories under GDPR Article 9, or segments subject to FCC advertising restrictions. Triggers compliance workflow in Adobe Experience Platform and Wide Orbit.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle state of the demographic segment definition. Active segments are available for audience targeting, ad sales proposals, and ratings reporting. Deprecated segments are retained for historical continuity but no longer used in new campaigns or programming decisions.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifies the originating operational system of record from which this demographic segment definition was sourced. Nielsen indicates the Nielsen Media Research Platform; adobe_aep indicates Adobe Experience Platform; internal indicates proprietary segment definitions; iab indicates IAB Taxonomy-derived segments. Supports data lineage and reconciliation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepsPriority rdf:type rdf:Property ;
    rdfs:label 'Sweeps Priority' ;
    rdfs:comment 'Indicates whether this demographic segment is a priority measurement target during Nielsen sweeps periods (February, May, July, November). Priority segments receive enhanced panel measurement and are the primary basis for affiliate compensation and ad rate card negotiations during sweeps.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:universeEstimateYear rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Year' ;
    rdfs:comment 'The calendar year for which the universe estimate is valid. Nielsen updates universe estimates annually; this field identifies the vintage of the estimate to ensure correct ratings calculations and year-over-year audience trend analysis.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementEventId rdf:type rdf:Property ;
    rdfs:label 'Engagement Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each discrete digital audience engagement action captured on OTT/streaming platforms. Primary key for this product in the Databricks Silver Layer.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adCampaignId rdf:type rdf:Property ;
    rdfs:label 'Ad Campaign Id' ;
    rdfs:comment 'Identifier for the advertising campaign associated with this engagement event, populated when the event is triggered within or adjacent to an ad pod. Supports DAI (Dynamic Ad Insertion) attribution and campaign performance measurement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:complianceConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Compliance Consent Record Id' ;
    rdfs:comment 'Foreign key linking to compliance.consent_record. Business justification: Engagement tracking requires consent validation for data processing legality under GDPR/CCPA. Essential for demonstrating lawful basis for behavioral analytics and targeted advertising.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceConsentRecord .

ind:originatingBroadcastFacilityId rdf:type rdf:Property ;
    rdfs:label 'Originating Broadcast Facility Id' ;
    rdfs:comment 'Foreign key linking to technology.broadcast_facility. Business justification: Engagement events must track originating broadcast facility for streaming performance analysis, CDN edge optimization, and correlating viewer experience with infrastructure health. Critical for NOC in' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastFacility .

ind:platformId rdf:type rdf:Property ;
    rdfs:label 'Platform Id' ;
    rdfs:comment 'Identifier for the distribution platform (e.g., OTT app, SVOD service, AVOD channel, FAST channel) on which the engagement event occurred. Enables multi-platform distribution and audience analytics.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OttPlatform .

ind:privacyRequestId rdf:type rdf:Property ;
    rdfs:label 'Privacy Request Id' ;
    rdfs:comment 'Foreign key linking to compliance.privacy_request. Business justification: Privacy requests must locate and process engagement event data for GDPR/CCPA compliance. Links requests to behavioral data for subject access reports and deletion fulfillment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyRequest .

ind:sessionId rdf:type rdf:Property ;
    rdfs:label 'Session Id' ;
    rdfs:comment 'Anonymized identifier for the streaming session during which this engagement event occurred. Links all events within a single continuous viewing session for session-level analytics. Sourced from Adobe Experience Platform session context.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaBroadcasting .

ind:viewerProfileId rdf:type rdf:Property ;
    rdfs:label 'Viewer Profile Id' ;
    rdfs:comment 'Anonymized identifier for the audience member or household profile that generated this engagement event. Sourced from Adobe Experience Platform unified profile. Used for audience segmentation and ad targeting without exposing personal identity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ViewerProfile .

ind:appVersion rdf:type rdf:Property ;
    rdfs:label 'App Version' ;
    rdfs:comment 'Version string of the OTT/streaming application that captured the engagement event (e.g., 4.2.1). Used to correlate engagement behaviour with app release cycles and identify version-specific anomalies in audience interaction patterns.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Bitrate Kbps' ;
    rdfs:comment 'Actual bitrate in kilobits per second of the stream being delivered at the time of the engagement event. Sourced from Akamai CDN performance telemetry. Used alongside stream_quality to assess CDN delivery performance and its impact on audience engagement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutApplied rdf:type rdf:Property ;
    rdfs:label 'Blackout Applied' ;
    rdfs:comment 'Indicates whether a geographic broadcast restriction (blackout) was enforced for this viewer at the time of the engagement event (True) or not (False). Supports FCC blackout compliance reporting and rights management audit trails.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bufferingDurationMs rdf:type rdf:Property ;
    rdfs:label 'Buffering Duration Ms' ;
    rdfs:comment 'Total duration of buffering experienced by the viewer immediately preceding or during this engagement event, in milliseconds. Sourced from Adobe Experience Platform quality-of-experience telemetry. Used to correlate buffering events with pause and abandonment engagement actions.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentDurationMs rdf:type rdf:Property ;
    rdfs:label 'Content Duration Ms' ;
    rdfs:comment 'Total duration of the content asset in milliseconds at the time of the engagement event. Used in conjunction with content_position_ms to compute completion percentage and engagement depth score. Sourced from Dalet Galaxy asset metadata.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentPositionMs rdf:type rdf:Property ;
    rdfs:label 'Content Position Ms' ;
    rdfs:comment 'Playback position within the content asset at the moment the engagement event was triggered, expressed in milliseconds from the start of the content. Core EVENT_PAYLOAD_OR_VALUE for this event log. Enables precise engagement depth analysis, completion rate calculation, and identification of drop-off points.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataPrivacyConsent rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Consent' ;
    rdfs:comment 'Viewer\'s data privacy consent status at the time of the engagement event, governing permissible use of this record for analytics, personalisation, and ad targeting. Sourced from Adobe Experience Platform consent management. Mandatory for GDPR Article 6 lawful basis determination and CCPA opt-out compliance.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceOs rdf:type rdf:Property ;
    rdfs:label 'Device Os' ;
    rdfs:comment 'Operating system of the device that generated the engagement event (e.g., iOS, Android, tvOS, Roku OS, Fire OS, Windows, macOS). Sourced from Adobe Experience Platform device context. Supports technical platform compatibility analysis and audience reach reporting.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmScheme rdf:type rdf:Property ;
    rdfs:label 'Drm Scheme' ;
    rdfs:comment 'DRM (Digital Rights Management) protection scheme active on the content stream at the time of the engagement event. Used for rights compliance verification and to ensure content is consumed within licensed windows and territories. Supports Rightsline rights enforcement reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementDepthScore rdf:type rdf:Property ;
    rdfs:label 'Engagement Depth Score' ;
    rdfs:comment 'Normalised score (0.00–100.00) representing the depth of audience engagement at the time of the event, calculated by Adobe Experience Platform based on playback position relative to content duration, interaction frequency, and event type weighting. Key metric for non-linear audience behaviour analysis and ad targeting propensity modelling.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Processing lifecycle status of the engagement event record in the Silver Layer. \'valid\' indicates the event passed all quality checks; \'invalid\' indicates a data quality failure; \'duplicate\' indicates a repeated event suppressed from analytics; \'quarantined\' indicates the event is held pending investigation.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Precise UTC timestamp recording when the engagement action occurred on the viewer\'s device. Principal EVENT_TIMESTAMP for this event log entity. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX. Used for time-series audience behaviour analysis, daypart analytics, and sweeps period reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Categorical discriminator identifying the specific audience interaction captured: play (content start/resume), pause (playback halted), seek (position jump forward), rewind (position jump backward), share (social distribution action), like (positive sentiment signal), comment (text interaction), complete (full content consumption). Core EVENT_TYPE_OR_CHANNEL field for non-linear audience behaviour analysis. [ENUM-REF-CANDIDATE: play|pause|seek|rewind|share|like|comment|complete — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geo Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the viewer\'s geographic location at the time of the engagement event, derived from IP geolocation. Used for territorial rights compliance (blackout enforcement, holdback windows), audience reach reporting by geography, and regulatory jurisdiction determination.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geo Region Code' ;
    rdfs:comment 'ISO 3166-2 subdivision code (state, province, or region) of the viewer\'s location at the time of the engagement event. Used for sub-national blackout enforcement, regional audience measurement, and daypart-adjusted analytics.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdEvent rdf:type rdf:Property ;
    rdfs:label 'Is Ad Event' ;
    rdfs:comment 'Indicates whether this engagement event occurred during an advertisement (True) or during editorial content (False). Critical for separating content engagement metrics from ad engagement metrics in AVOD and DAI (Dynamic Ad Insertion) analytics.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConcurrentStream rdf:type rdf:Property ;
    rdfs:label 'Is Concurrent Stream' ;
    rdfs:comment 'Indicates whether this engagement event occurred on a stream that was running concurrently with another active stream on the same viewer account (True) or not (False). Used for concurrent stream limit enforcement per subscription terms and HUT (Homes Using Television) measurement.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'UTC timestamp when the engagement event was received and ingested by Adobe Experience Platform. Distinct from event_timestamp (client-side occurrence time). Used to measure event latency, detect clock skew, and support data quality auditing in the Silver Layer pipeline.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Channel or mechanism through which the viewer arrived at the content that triggered this engagement event. Used for audience acquisition attribution, marketing campaign effectiveness analysis, and content discovery optimisation. [ENUM-REF-CANDIDATE: direct|search|social|email|push_notification|in_app|external_link — promote to reference product]' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seekFromPositionMs rdf:type rdf:Property ;
    rdfs:label 'Seek From Position Ms' ;
    rdfs:comment 'Playback position in milliseconds from which the viewer initiated a seek or rewind action. Populated only when event_type is \'seek\' or \'rewind\'. Combined with content_position_ms (seek-to position) to measure skip behaviour and identify content segments that audiences skip or revisit.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemEventCode rdf:type rdf:Property ;
    rdfs:label 'Source System Event Code' ;
    rdfs:comment 'Original event identifier assigned by Adobe Experience Platform at the point of capture, before Silver Layer surrogate key assignment. Used for data lineage tracing, deduplication, and reconciliation between the Silver Layer and the Adobe Experience Platform source system.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamQuality rdf:type rdf:Property ;
    rdfs:label 'Stream Quality' ;
    rdfs:comment 'Adaptive bitrate (ABR) quality tier of the stream at the time of the engagement event, reflecting the HLS or MPEG-DASH rendition being delivered by the CDN. Used to correlate stream quality with engagement behaviour and identify quality-driven churn signals.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionTier rdf:type rdf:Property ;
    rdfs:label 'Subscription Tier' ;
    rdfs:comment 'Subscription or access tier of the viewer at the time of the engagement event, reflecting the monetisation model under which content was consumed. Sourced from Zuora subscription billing. Used to segment engagement behaviour by revenue tier for ARPU analysis and churn prediction.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Market coverage areas determine applicable regulatory obligations (must-carry, retransmission consent). DMA and market type drive specific FCC obligations; links market definitions to compliance requi' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:blackoutRuleApplicable rdf:type rdf:Property ;
    rdfs:label 'Blackout Rule Applicable' ;
    rdfs:comment 'Indicates whether geographic broadcast blackout rules apply to this market for sports or syndication exclusivity purposes. True if blackout restrictions can be enforced in this DMA; False otherwise. Used by rights management (Rightsline) and CDN geo-restriction (Akamai) to enforce territorial exclusivity.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastStandard rdf:type rdf:Property ;
    rdfs:label 'Broadcast Standard' ;
    rdfs:comment 'Digital broadcast transmission standard applicable to this market. \'ATSC\' (Advanced Television Systems Committee) is the US standard; \'DVB\' (Digital Video Broadcasting) is the European standard; \'ISDB\' is the Japanese/Brazilian standard; \'DTMB\' is the Chinese standard. Determines technical playout and transmission requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cablePenetrationRate rdf:type rdf:Property ;
    rdfs:label 'Cable Penetration Rate' ;
    rdfs:comment 'Estimated percentage of television households in the DMA that subscribe to cable television (MVPD or vMVPD service). Expressed as a decimal (e.g., 0.6234 = 62.34%). Used for carriage fee negotiations, distribution planning, and ad sales reach projections.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daylightSavingObserved rdf:type rdf:Property ;
    rdfs:label 'Daylight Saving Observed' ;
    rdfs:comment 'Indicates whether the DMA observes Daylight Saving Time (DST). True if DST is observed; False if not (e.g., markets in Arizona). Affects daypart scheduling, playout timing, and EPG accuracy in broadcast automation systems.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmaCode rdf:type rdf:Property ;
    rdfs:label 'Dma Code' ;
    rdfs:comment 'Nielsen-assigned three-digit numeric code uniquely identifying the Designated Market Area (DMA). This is the externally-known business identifier used across ad sales, ratings reporting, and FCC filings. Sourced from Nielsen Media Research Platform.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmaRank rdf:type rdf:Property ;
    rdfs:label 'Dma Rank' ;
    rdfs:comment 'Nielsen-assigned national rank of the DMA by television household universe size, where rank 1 is the largest market (New York). Used for market prioritization in ad sales, upfront negotiations, and carriage fee calculations. Updated annually by Nielsen.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'The date from which this market coverage record became effective and the DMA definition was valid. Used for temporal versioning of DMA boundary and universe changes, ensuring historical ratings data is associated with the correct market definition.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'The date on which this market coverage record ceased to be effective, typically due to a DMA boundary redefinition, market merger, or discontinuation. Null for currently active market definitions. Supports slowly changing dimension (SCD) history tracking.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fccMarketCode rdf:type rdf:Property ;
    rdfs:label 'Fcc Market Code' ;
    rdfs:comment 'FCC-assigned market identifier used for must-carry and retransmission consent compliance filings. Maps the Nielsen DMA to the FCC\'s designated market definition for broadcast licensing, spectrum regulation, and MVPD carriage obligations. Required for regulatory reporting under FCC 47 CFR Part 76.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicBoundaryWkt rdf:type rdf:Property ;
    rdfs:label 'Geographic Boundary Wkt' ;
    rdfs:comment 'Well-Known Text (WKT) representation of the DMA\'s geographic boundary polygon. Used for spatial analysis, blackout rule enforcement, retransmission consent territory mapping, and OTT/streaming geo-restriction via CDN (Akamai). Conforms to OGC WKT standard.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hispanicTvHouseholdPct rdf:type rdf:Property ;
    rdfs:label 'Hispanic Tv Household Pct' ;
    rdfs:comment 'Estimated percentage of television households in the DMA that are Hispanic/Latino, as measured by Nielsen. Expressed as a decimal (e.g., 0.2341 = 23.41%). Used for Spanish-language content distribution decisions, targeted ad sales, and TRP (Target Rating Point) calculations for Hispanic demographic segments.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hutBaseEstimate rdf:type rdf:Property ;
    rdfs:label 'Hut Base Estimate' ;
    rdfs:comment 'Nielsen baseline estimate of the percentage of television households in the DMA that are using television during an average primetime daypart. Expressed as a decimal (e.g., 0.5823 = 58.23%). Used as a reference benchmark for HUT-based audience projections and ad sales planning.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketName rdf:type rdf:Property ;
    rdfs:label 'Market Name' ;
    rdfs:comment 'Official human-readable name of the Designated Market Area (DMA) or television market as defined by Nielsen (e.g., \'New York\', \'Los Angeles\', \'Chicago\'). Used in audience reports, ad sales proposals, and regulatory filings.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketStatus rdf:type rdf:Property ;
    rdfs:label 'Market Status' ;
    rdfs:comment 'Current lifecycle status of the market coverage record. \'active\' indicates the DMA is currently measured and used in audience reporting; \'inactive\' indicates it is no longer measured; \'pending\' indicates a newly defined market awaiting first measurement; \'discontinued\' indicates a market that has been merged or eliminated by Nielsen.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'Frequency at which Nielsen provides audience measurement data for this market. \'continuous\' indicates year-round metered measurement (PPM markets); \'sweeps_only\' indicates measurement only during sweeps periods (diary markets); \'quarterly\' or \'annual\' for smaller markets with less frequent measurement cycles.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medianHouseholdIncome rdf:type rdf:Property ;
    rdfs:label 'Median Household Income' ;
    rdfs:comment 'Median annual household income (in USD) for the DMA, sourced from U.S. Census Bureau data as incorporated into Nielsen demographic profiles. Used for audience demographic segmentation, CPM (Cost Per Mille) pricing tiers, and advertiser targeting qualification.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mustCarryApplicable rdf:type rdf:Property ;
    rdfs:label 'Must Carry Applicable' ;
    rdfs:comment 'Indicates whether FCC must-carry rules apply to broadcast stations in this market, requiring cable operators (MVPDs) to carry local broadcast signals. True if must-carry obligations exist; False otherwise. Critical for retransmission consent negotiations and MVPD carriage compliance.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nielsenSourceMarketCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Source Market Code' ;
    rdfs:comment 'The native market identifier as assigned and used within the Nielsen Media Research Platform source system. Used for data lineage, reconciliation between the lakehouse silver layer and the Nielsen source system, and audit of universe estimate ingestion.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenStationIndex rdf:type rdf:Property ;
    rdfs:label 'Nielsen Station Index' ;
    rdfs:comment 'Total number of television stations measured by Nielsen within this DMA. Indicates the competitive landscape of the local market and is used in share calculations and ad sales competitive analysis.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ottPenetrationRate rdf:type rdf:Property ;
    rdfs:label 'Ott Penetration Rate' ;
    rdfs:comment 'Estimated percentage of television households in the DMA that access video content via OTT (Over-The-Top) streaming services. Expressed as a decimal. Used for digital distribution planning, SVOD/AVOD audience projections, and DAI (Dynamic Ad Insertion) inventory estimation.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:populationUniverse rdf:type rdf:Property ;
    rdfs:label 'Population Universe' ;
    rdfs:comment 'Nielsen-estimated total population (persons 2+) residing within the DMA boundary. Used as the denominator for person-based ratings metrics including PUT (Persons Using Television) and TRP (Target Rating Point) calculations. Updated annually in the Nielsen universe estimates release.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'ISO 639-1 or ISO 639-2 language code representing the predominant language spoken in the DMA (e.g., \'en\' for English, \'es\' for Spanish). Used for content localization decisions, Spanish-language network distribution, and audience demographic targeting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalCity rdf:type rdf:Property ;
    rdfs:label 'Principal City' ;
    rdfs:comment 'Name of the primary city or metropolitan area that anchors and names the DMA (e.g., \'New York\', \'Los Angeles\', \'Chicago\'). Used in market identification, ad sales materials, and regulatory filings.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putBaseEstimate rdf:type rdf:Property ;
    rdfs:label 'Put Base Estimate' ;
    rdfs:comment 'Nielsen baseline estimate of the percentage of persons (2+) in the DMA who are using television during an average primetime daypart. Expressed as a decimal (e.g., 0.4612 = 46.12%). Used as a reference benchmark for PUT-based audience projections and TRP calculations.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this market coverage record was first created in the Databricks Lakehouse Silver Layer. Used for audit trail, data lineage tracking, and compliance with SOX financial reporting controls that require data provenance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this market coverage record was most recently updated in the Databricks Lakehouse Silver Layer. Used for change detection, incremental processing, and audit trail maintenance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Primary broadcast regulatory authority governing this market. \'FCC\' for US markets; \'Ofcom\' for UK markets; \'CRTC\' for Canadian markets; \'ACMA\' for Australian markets; \'other\' for all other jurisdictions. Determines applicable must-carry, retransmission consent, content standards, and licensing requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentApplicable rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Applicable' ;
    rdfs:comment 'Indicates whether retransmission consent rules apply to broadcast stations in this market, allowing broadcasters to negotiate compensation from MVPDs for carriage of their signals. True if retransmission consent is applicable; False otherwise.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'ISO 3166-2 two-letter state or province code of the primary state in which the DMA\'s principal city is located (e.g., \'NY\', \'CA\', \'IL\'). Used for geographic segmentation, blackout rule enforcement, and retransmission consent jurisdiction determination.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepsParticipation rdf:type rdf:Property ;
    rdfs:label 'Sweeps Participation' ;
    rdfs:comment 'Indicates whether this market participates in Nielsen sweeps periods (intensive ratings measurement periods in February, May, July, and November). True if the market is measured during sweeps; False if it is a non-sweeps market. Affects programming scheduling strategy and ad sales pricing.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the primary time zone of the DMA (e.g., \'America/New_York\', \'America/Los_Angeles\'). Critical for daypart scheduling, playout automation in Ericsson MediaFirst, EPG (Electronic Program Guide) alignment, and ad scheduling in Wide Orbit Traffic system.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCounties rdf:type rdf:Property ;
    rdfs:label 'Total Counties' ;
    rdfs:comment 'Total number of counties or county-equivalents included within the DMA boundary. Nielsen defines DMA boundaries at the county level. Used for geographic coverage analysis, must-carry compliance, and retransmission consent territory verification.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tvHouseholdUniverse rdf:type rdf:Property ;
    rdfs:label 'Tv Household Universe' ;
    rdfs:comment 'Nielsen-estimated total number of television households within the DMA boundary. This is the principal quantitative measurement fact for the market and serves as the denominator for all local ratings calculations, GRP/TRP computations, and CPM-based ad pricing. Updated annually in the Nielsen universe estimates release.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:universeEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Universe Effective Date' ;
    rdfs:comment 'The date from which the current Nielsen universe estimates (TV household and population) became effective for this market. Used to track the currency of universe data and ensure ratings calculations use the correct denominator for the applicable measurement period.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'The name of the independent body that has accredited or audited this measurement methodology (e.g., \'Media Rating Council (MRC)\', \'Joint Industry Committee (JIC)\', \'BARB\', \'Ofcom\'). Supports multi-market operations where different accreditation bodies govern different geographies.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableMarketTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Market Types' ;
    rdfs:comment 'Comma-separated list of market types where this methodology is valid (e.g., \'national, local_dma, regional, international\'). Nielsen PPM is typically used in national and large local DMA markets; diary methodology is used in smaller local markets. Determines which geographic market audience records can be attributed to this methodology.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicablePlatformTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Platform Types' ;
    rdfs:comment 'Comma-separated list of platform types to which this methodology applies (e.g., \'linear_tv, ott_streaming, radio, digital_display, podcast\'). Governs which viewership records and distribution channels can be measured and reported using this methodology. Critical for cross-platform audience deduplication and hybrid measurement.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceMetricTypes rdf:type rdf:Property ;
    rdfs:label 'Audience Metric Types' ;
    rdfs:comment 'Comma-separated list of audience metrics that this methodology can produce (e.g., \'GRP, TRP, HUT, PUT, reach, frequency, share, Nielsen_rating, TSR, CPRP\'). Governs which KPIs can be reported using data collected under this methodology. GRP (Gross Rating Point), TRP (Target Rating Point), HUT (Homes Using Television), PUT (Persons Using Television), TSR (Time Spent Reading/Viewing), CPRP (Cost Per Rating Point).' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMechanismRequired rdf:type rdf:Property ;
    rdfs:label 'Consent Mechanism Required' ;
    rdfs:comment 'The type of audience consent mechanism required for data collection under this methodology: opt_in (explicit consent required before data collection), opt_out (data collected unless individual opts out), panel_agreement (panelists sign participation agreement), no_consent_required (census/aggregate data with no individual tracking), or mixed. Governs GDPR, CCPA, and COPPA compliance posture.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossPlatformCapable rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Capable' ;
    rdfs:comment 'Indicates whether this methodology supports cross-platform audience deduplication and unified reach/frequency reporting across linear TV, OTT (Over-The-Top), digital, and streaming platforms. Cross-platform capability is required for total audience measurement (TAM) reporting and advanced advertising guarantees.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyStandard rdf:type rdf:Property ;
    rdfs:label 'Currency Standard' ;
    rdfs:comment 'The audience measurement currency standard supported by this methodology, defining the viewing window used for commercial ratings: C3 (average commercial ratings including 3 days of DVR playback), C7 (7-day DVR playback), C35 (35-day), live_plus_same_day, live_only, or custom. The currency standard is the contractual basis for ad sales guarantees and makegood calculations in upfront and scatter markets.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMechanism rdf:type rdf:Property ;
    rdfs:label 'Data Collection Mechanism' ;
    rdfs:comment 'The specific technical mechanism by which audience exposure data is collected: PPM device (Portable People Meter worn by panelists), diary form (paper or electronic self-report), STB return path (Set-Top Box return-path data), ACR fingerprint (Automatic Content Recognition audio/video fingerprinting), SDK telemetry (streaming app software development kit), pixel tracking (web/app pixel), or hybrid combination. Determines data fidelity and applicable use cases. [ENUM-REF-CANDIDATE: ppm_device|diary_form|stb_return_path|acr_fingerprint|sdk_telemetry|pixel_tracking|hybrid — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Days' ;
    rdfs:comment 'The maximum number of days that raw audience measurement data collected under this methodology may be retained, as governed by privacy regulations (GDPR, CCPA) and MRC audit requirements. After this period, data must be anonymized or deleted. Drives data lifecycle management in the lakehouse.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deduplicationMethod rdf:type rdf:Property ;
    rdfs:label 'Deduplication Method' ;
    rdfs:comment 'The method used to deduplicate audience reach across platforms or devices when this methodology is applied in cross-platform measurement: probabilistic (statistical modeling), deterministic (identity-matched), hybrid (combination), or none (single-platform only). Affects reported unique reach figures and frequency calculations.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demographicGranularity rdf:type rdf:Property ;
    rdfs:label 'Demographic Granularity' ;
    rdfs:comment 'Describes the level of demographic segmentation this methodology supports (e.g., \'age_sex_only\', \'age_sex_income\', \'full_psychographic\', \'household_level_only\'). Determines which audience segments can be reported for ad targeting, TRP calculations, and upfront sales guarantees.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'The date on which this measurement methodology ceases to be valid for new audience measurement records. Null indicates the methodology is currently open-ended and active. Used to enforce temporal validity in ratings lookups and prevent application of deprecated methodologies to new viewership data.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicCoverageLevel rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Level' ;
    rdfs:comment 'The geographic scope at which this methodology provides valid audience measurement: national (US-wide), dma (Designated Market Area), regional, local (sub-DMA), international, or global. Determines applicability for local vs. national ad sales, retransmission consent negotiations, and blackout enforcement.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSweepsApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Sweeps Applicable' ;
    rdfs:comment 'Indicates whether this measurement methodology is used or enhanced during Nielsen Sweeps periods (February, May, July, November) — the intensive ratings measurement periods used to set local advertising rates. Diary methodology is exclusively sweeps-based in many markets; PPM operates year-round.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodologyCode rdf:type rdf:Property ;
    rdfs:label 'Methodology Code' ;
    rdfs:comment 'Short, externally-recognized alphanumeric code uniquely identifying the measurement methodology (e.g., NIELSEN_PPM, NIELSEN_DIARY, STB_DATA, ACR, STREAMING_TELEMETRY, HYBRID_XPLATFORM). Used as a stable business key across systems including Nielsen Media Research Platform and Adobe Experience Platform integrations.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodologyDescription rdf:type rdf:Property ;
    rdfs:label 'Methodology Description' ;
    rdfs:comment 'Detailed narrative description of how the measurement methodology works, including data collection mechanism, panel recruitment approach, weighting procedures, and any known limitations. Used by ad sales teams, programming analysts, and regulatory compliance officers to understand how viewership and rating records are produced.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodologyName rdf:type rdf:Property ;
    rdfs:label 'Methodology Name' ;
    rdfs:comment 'Full human-readable name of the audience measurement methodology (e.g., \'Nielsen Portable People Meter\', \'Nielsen Diary\', \'Set-Top Box Data\', \'Automatic Content Recognition\', \'Streaming Platform Telemetry\', \'Hybrid Cross-Platform Measurement\'). Used in reports, dashboards, and regulatory filings.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodologyStatus rdf:type rdf:Property ;
    rdfs:label 'Methodology Status' ;
    rdfs:comment 'Current lifecycle status of the measurement methodology within the organization\'s audience measurement framework. Active methodologies are used in current ratings and GRP/TRP reporting; deprecated or retired methodologies are retained for historical record interpretation; pilot methodologies are under evaluation for MRC accreditation.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodologyType rdf:type rdf:Property ;
    rdfs:label 'Methodology Type' ;
    rdfs:comment 'Categorical classification of the measurement approach: passive (device-based passive capture such as PPM or STB), diary (self-reported viewer logs), census (full population streaming telemetry), hybrid (cross-platform combination), panel (statistically sampled panel), or acr (Automatic Content Recognition fingerprinting). Governs how ratings and GRP/TRP calculations are interpreted.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrcAccreditationCode rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Code' ;
    rdfs:comment 'The official accreditation reference number issued by the Media Rating Council (MRC) for this measurement methodology. Used in regulatory filings, ad sales contracts, and audit documentation to reference the specific MRC accreditation certificate.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyComplianceFramework rdf:type rdf:Property ;
    rdfs:label 'Privacy Compliance Framework' ;
    rdfs:comment 'Comma-separated list of privacy and data protection frameworks under which this methodology\'s data collection and processing is compliant (e.g., \'GDPR, CCPA, COPPA, TCPA\'). GDPR governs EU audience data; CCPA governs California viewer data; COPPA governs children\'s content measurement. Required for regulatory reporting and data governance.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'The cadence at which audience measurement data is reported using this methodology: overnight (daily ratings delivery), weekly, monthly, quarterly, or sweeps_only (data available only during Nielsen Sweeps measurement periods in February, May, July, and November). Governs scheduling of ad sales reporting and programming analysis cycles.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingLatencyHours rdf:type rdf:Property ;
    rdfs:label 'Reporting Latency Hours' ;
    rdfs:comment 'The typical number of hours between the audience exposure event and the availability of processed, reportable ratings data using this methodology. Nielsen PPM typically delivers overnight ratings within 24 hours; diary methodology may have 2–4 week latency. Critical for ad sales makegoods, scatter market decisions, and programming adjustments.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSizeMinimum rdf:type rdf:Property ;
    rdfs:label 'Sample Size Minimum' ;
    rdfs:comment 'The minimum number of panelists or measurement units required for this methodology to produce statistically valid audience estimates. Below this threshold, ratings data is considered unreliable and may be suppressed or flagged. Enforced per MRC accreditation requirements and Nielsen panel design standards.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSizeTarget rdf:type rdf:Property ;
    rdfs:label 'Sample Size Target' ;
    rdfs:comment 'The ideal or design target number of panelists or measurement units for this methodology to achieve the desired statistical confidence level and margin of error. Used in panel management and methodology performance monitoring against MRC accreditation benchmarks.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Code identifying the operational system of record from which this methodology definition originates (e.g., \'NIELSEN_MRP\' for Nielsen Media Research Platform, \'ADOBE_AEP\' for Adobe Experience Platform). Used for data lineage tracking and Silver Layer ingestion audit in the Databricks Lakehouse.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorMethodologyVersion rdf:type rdf:Property ;
    rdfs:label 'Vendor Methodology Version' ;
    rdfs:comment 'The vendor-assigned version identifier for this measurement methodology (e.g., \'PPM v3.2\', \'C3\', \'C7\', \'P2+ 2023\'). Version changes may affect historical comparability of ratings data and require restatement of audience guarantees. Critical for audit trails and makegood calculations.' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'The name of the third-party vendor or research firm that operates or provides this measurement methodology (e.g., \'Nielsen\', \'Comscore\', \'Kantar\', \'VideoAmp\', \'iSpot.tv\'). Used for vendor management, contract tracking, and source system attribution in the Nielsen Media Research Platform integration.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenRatingId rdf:type rdf:Property ;
    rdfs:label 'Nielsen Rating Id' ;
    rdfs:comment 'Unique surrogate identifier for each Nielsen audience measurement record in the Silver layer. Primary key for the nielsen_rating data product.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NielsenRating .

ind:complianceIncidentId rdf:type rdf:Property ;
    rdfs:label 'Compliance Incident Id' ;
    rdfs:comment 'Foreign key linking to compliance.incident. Business justification: Rating measurement failures or data breaches constitute compliance incidents requiring documentation. Links ratings data to incident records for root cause analysis and regulatory notification.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:easLogId rdf:type rdf:Property ;
    rdfs:label 'Eas Log Id' ;
    rdfs:comment 'Foreign key linking to compliance.eas_log. Business justification: Nielsen measurement windows affected by EAS alert transmissions require correlation for accurate rating adjustments. EAS interruptions impact audience measurement; link enables rating correction and c' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EasLog .

ind:measurementTechnicianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Measurement Technician Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Nielsen ratings require certified measurement technicians to validate panel compliance, equipment calibration, and sweeps period data accuracy for MRC accreditation audits. Technician assignment track' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: Nielsen ratings data included in FCC filings for license renewal and public interest demonstration. Ratings evidence programming service to community and support renewal applications.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:airEndTime rdf:type rdf:Property ;
    rdfs:label 'Air End Time' ;
    rdfs:comment 'The precise date and time at which the program finished airing. Combined with air_start_time to derive program duration for audience measurement calculations.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:airStartTime rdf:type rdf:Property ;
    rdfs:label 'Air Start Time' ;
    rdfs:comment 'The precise date and time (including timezone offset) at which the program began airing. Used for exact scheduling alignment and daypart classification.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:audienceCompositionPct rdf:type rdf:Property ;
    rdfs:label 'Audience Composition Pct' ;
    rdfs:comment 'The percentage of the program\'s total audience represented by the primary target demographic (typically A18-49). Indicates how well the program indexes against its target audience and is used in ad sales proposals and programming strategy.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageAudience rdf:type rdf:Property ;
    rdfs:label 'Average Audience' ;
    rdfs:comment 'The average number of persons or households tuned to the program during an average minute of the telecast. Expressed in thousands (000s). AA is the primary audience volume metric used in GRP and CPM calculations for ad sales.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumeAudience rdf:type rdf:Property ;
    rdfs:label 'Cume Audience' ;
    rdfs:comment 'The unduplicated number of different persons or households that tuned to the program for at least one minute across all airings within a defined period. Expressed in thousands (000s). Cume measures total reach and is critical for frequency management in ad campaign planning.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoA1849Rating rdf:type rdf:Property ;
    rdfs:label 'Demo A18 49 Rating' ;
    rdfs:comment 'The percentage of Adults aged 18-49 in the measured universe who were tuned to this program. A18-49 is the most commercially valuable and widely traded demographic in US television advertising, serving as the primary currency for primetime ad sales.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoA2554Rating rdf:type rdf:Property ;
    rdfs:label 'Demo A25 54 Rating' ;
    rdfs:comment 'The percentage of Adults aged 25-54 in the measured universe who were tuned to this program. A25-54 is a key secondary demographic used in news programming, cable networks, and certain advertiser categories.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoK211Rating rdf:type rdf:Property ;
    rdfs:label 'Demo K2 11 Rating' ;
    rdfs:comment 'The percentage of Children aged 2-11 in the measured universe who were tuned to this program. K2-11 is the primary demographic for children\'s programming and toy/food advertisers. Subject to COPPA compliance requirements for data handling.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoM1849Rating rdf:type rdf:Property ;
    rdfs:label 'Demo M18 49 Rating' ;
    rdfs:comment 'The percentage of Men aged 18-49 in the measured universe who were tuned to this program. M18-49 is a primary demographic for sports, automotive, and technology advertisers.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoW1849Rating rdf:type rdf:Property ;
    rdfs:label 'Demo W18 49 Rating' ;
    rdfs:comment 'The percentage of Women aged 18-49 in the measured universe who were tuned to this program. W18-49 is a primary demographic for lifestyle, beauty, and household product advertisers.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'The average number of times a unique person or household was exposed to the program within the measurement period. Frequency = GRP / Reach. Used with reach for ad campaign effectiveness analysis and makegoods calculations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grp rdf:type rdf:Property ;
    rdfs:label 'Grp' ;
    rdfs:comment 'The sum of all ratings delivered by an advertising schedule or program, representing total audience delivery without deduplication. GRP = Reach × Frequency. A fundamental currency metric in ad sales negotiations, upfront deals, and scatter market transactions.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdRating rdf:type rdf:Property ;
    rdfs:label 'Household Rating' ;
    rdfs:comment 'The percentage of all television households in the measured universe that were tuned to this program during the measurement period. Expressed as a decimal percentage (e.g., 5.2 = 5.2%). The foundational Nielsen rating metric used for ad pricing and programming evaluation.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdShare rdf:type rdf:Property ;
    rdfs:label 'Household Share' ;
    rdfs:comment 'The percentage of households using television (HUT) that were tuned to this program. Share = (Program Audience / HUT) × 100. Measures competitive performance relative to active TV viewers at the same time.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hutLevel rdf:type rdf:Property ;
    rdfs:label 'Hut Level' ;
    rdfs:comment 'The percentage of all television households in the universe that had their television sets in use during the measurement period. HUT is the denominator for household share calculations and a key indicator of overall TV viewing activity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressions rdf:type rdf:Property ;
    rdfs:label 'Impressions' ;
    rdfs:comment 'The total number of person-level exposures to the program, calculated as average audience multiplied by the number of airings. Expressed in absolute numbers (not thousands). Impressions are the transactional currency for digital and cross-platform ad sales.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingested Timestamp' ;
    rdfs:comment 'The timestamp at which this Nielsen rating record was ingested into the Databricks Lakehouse Silver layer from the Nielsen Media Research Platform. Used for data freshness monitoring, SLA tracking, and audit trail.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nielsenProgramCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Program Code' ;
    rdfs:comment 'Nielsen Media Research Platform\'s proprietary alphanumeric code uniquely identifying the program title within the Nielsen measurement system. Used as the business identifier for cross-referencing ratings data with Nielsen deliverables.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenReportDate rdf:type rdf:Property ;
    rdfs:label 'Nielsen Report Date' ;
    rdfs:comment 'The date on which Nielsen Media Research officially published or delivered this rating record to the broadcaster. Distinguishes the measurement air date from the data delivery date, which is critical for tracking preliminary vs. final rating release cycles.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nielsenReportWeek rdf:type rdf:Property ;
    rdfs:label 'Nielsen Report Week' ;
    rdfs:comment 'The ISO 8601 week identifier (e.g., 2024-W23) of the Nielsen measurement week in which this rating was reported. Nielsen measurement weeks run Monday through Sunday. Used for weekly ratings aggregation and trend analysis.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putLevel rdf:type rdf:Property ;
    rdfs:label 'Put Level' ;
    rdfs:comment 'The percentage of all persons in the measured universe who were watching television during the measurement period. PUT is the denominator for persons share calculations and complements HUT for demographic audience analysis.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingStatus rdf:type rdf:Property ;
    rdfs:label 'Rating Status' ;
    rdfs:comment 'Lifecycle status of this Nielsen rating record indicating whether the data is preliminary (fast nationals), final, or has been revised. Ad sales and programming decisions must distinguish preliminary from final ratings. Preliminary ratings are typically released within 24 hours; final ratings follow within days.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reach rdf:type rdf:Property ;
    rdfs:label 'Reach' ;
    rdfs:comment 'The unduplicated number of unique persons or households exposed to the program at least once within the measurement period. Expressed in thousands (000s). Reach is a core metric for ad campaign planning and audience delivery reporting.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The native record identifier assigned by the Nielsen Media Research Platform for this rating record. Preserved in the Silver layer for data lineage, reconciliation, and re-ingestion traceability back to the authoritative source system.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeSpentViewingMin rdf:type rdf:Property ;
    rdfs:label 'Time Spent Viewing Min' ;
    rdfs:comment 'The average number of minutes that viewers in the measured audience spent watching the program. A key engagement metric used in programming decisions and content performance analysis. Expressed in minutes.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAudience rdf:type rdf:Property ;
    rdfs:label 'Total Audience' ;
    rdfs:comment 'The total number of persons or households that tuned to the program for at least six consecutive minutes. Expressed in thousands (000s). TA provides a broader reach measure than AA and is used for program promotion and scheduling decisions.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trp rdf:type rdf:Property ;
    rdfs:label 'Trp' ;
    rdfs:comment 'Rating points delivered specifically to a defined target demographic audience (e.g., Adults 18-49). TRP = (Target Audience Impressions / Target Universe) × 100. Used by advertisers to evaluate efficiency of reaching their specific target demographic.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:universeEstimateHh rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Hh' ;
    rdfs:comment 'The total estimated number of television households in the measured market or national universe used as the denominator for household rating calculations. Expressed in thousands (000s). Nielsen updates universe estimates annually based on census data.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:universeEstimatePersons rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Persons' ;
    rdfs:comment 'The total estimated number of persons in the measured market or national universe used as the denominator for persons rating calculations. Expressed in thousands (000s). Segmented by demographic group for TRP calculations.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachFrequencyReportId rdf:type rdf:Property ;
    rdfs:label 'Reach Frequency Report Id' ;
    rdfs:comment 'Unique surrogate identifier for each reach and frequency report record in the Silver Layer lakehouse. Primary key for this transactional entity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReachFrequencyReport .

ind:reportAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Report Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Reach/frequency reports require certified analysts to validate GRP/TRP calculations, effective reach thresholds, and makegood determinations for advertiser guarantees. Analyst assignment tracked for c' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:audienceSharePct rdf:type rdf:Property ;
    rdfs:label 'Audience Share Pct' ;
    rdfs:comment 'The percentage of the total viewing audience (persons using television) that was watching the specific network or program during the measurement period. Calculated as the program\'s audience divided by the total HUT/PUT audience. Used for competitive programming analysis and ad sales positioning.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryVariancePct rdf:type rdf:Property ;
    rdfs:label 'Delivery Variance Pct' ;
    rdfs:comment 'The percentage difference between the guaranteed audience delivery (GRP or TRP) and the actual delivered audience for the campaign flight. A negative value indicates under-delivery triggering makegood obligations; a positive value indicates over-delivery. Used for upfront guarantee reconciliation and scatter market adjustments.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveReach1plus rdf:type rdf:Property ;
    rdfs:label 'Effective Reach 1plus' ;
    rdfs:comment 'The count of unique persons exposed to the content or campaign at least one time (1+) during the measurement period. Equivalent to reach_persons; included as an explicit effective reach threshold field for consistency with N+ reporting framework used in post-campaign analysis.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveReach3plus rdf:type rdf:Property ;
    rdfs:label 'Effective Reach 3plus' ;
    rdfs:comment 'The count of unique persons exposed to the content or campaign at least three times (3+) during the measurement period. The industry-standard effective reach threshold used to assess whether sufficient frequency was achieved for advertising message recall. Critical for makegoods determination and campaign effectiveness evaluation.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveReachNplus rdf:type rdf:Property ;
    rdfs:label 'Effective Reach Nplus' ;
    rdfs:comment 'The count of unique persons exposed to the content or campaign at least N times (as defined by effective_reach_threshold) during the measurement period. Provides a configurable effective reach metric for custom campaign guarantee structures and advanced frequency analysis.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveReachThreshold rdf:type rdf:Property ;
    rdfs:label 'Effective Reach Threshold' ;
    rdfs:comment 'The minimum number of exposures (N) used to define effective reach for this specific report. Configurable per campaign or client agreement (e.g., 3 for standard campaigns, 5 for high-frequency campaigns). Determines the N+ threshold applied in effective reach calculations beyond the standard 1+ and 3+ fields.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isMakegoodRequired rdf:type rdf:Property ;
    rdfs:label 'Is Makegood Required' ;
    rdfs:comment 'Indicates whether this reach and frequency report has identified an audience delivery shortfall that requires a makegood (compensatory ad spot) to be issued to the advertiser. Triggers the makegood workflow in Wide Orbit and Salesforce Media Cloud when set to True.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'The last date of the measurement window for which reach and frequency metrics are computed. Defines the end boundary of the campaign flight, programming block, or sweeps period being analyzed.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'The first date of the measurement window for which reach and frequency metrics are computed. Defines the start boundary of the campaign flight, programming block, or sweeps period being analyzed. Used in conjunction with measurement_period_end_date to bound the audience measurement interval.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'Classifies the type of measurement window for which this report was generated. \'campaign_flight\' covers a defined ad campaign run; \'programming_block\' covers a scheduled content block; \'daypart_window\' covers a standard broadcast daypart; \'sweeps_period\' covers an intensive Nielsen ratings measurement period; \'custom_window\' covers an ad hoc analysis window.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenReportCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Report Code' ;
    rdfs:comment 'The native report identifier assigned by the Nielsen Media Research Platform for this reach and frequency dataset. Used for source system traceability, data lineage, and reconciliation between the lakehouse Silver Layer and the Nielsen source system.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachPct rdf:type rdf:Property ;
    rdfs:label 'Reach Pct' ;
    rdfs:comment 'The percentage of the target demographic universe reached at least once during the measurement period, calculated as (reach_persons / universe_estimate) × 100. Expressed as a decimal percentage (e.g., 45.2500 = 45.25%). Used by ad sales for post-campaign delivery reporting and scatter market pricing justification.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachPersons rdf:type rdf:Property ;
    rdfs:label 'Reach Persons' ;
    rdfs:comment 'The unduplicated count of unique persons within the target demographic segment who were exposed to the content or campaign at least once during the measurement period. The primary reach metric sourced from Nielsen Media Research Platform. Used for post-campaign delivery validation and upfront guarantee reconciliation.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Generated Timestamp' ;
    rdfs:comment 'The principal real-world event timestamp when this reach and frequency report was generated and delivered by the Nielsen Media Research Platform. Represents the business event time, distinct from audit timestamps. Used to track Nielsen data delivery SLAs and post-campaign reporting timeliness.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known business identifier for this reach and frequency report, sourced from the Nielsen Media Research Platform. Used by ad sales teams to reference specific post-campaign delivery reports in client communications, makegoods negotiations, and upfront guarantee reconciliation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle state of the reach and frequency report. \'draft\' indicates in-progress computation; \'preliminary\' indicates initial Nielsen delivery pending validation; \'final\' indicates validated and approved for client delivery; \'revised\' indicates a corrected reissue; \'superseded\' indicates replaced by a newer version; \'archived\' indicates retired from active use.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportVersion rdf:type rdf:Property ;
    rdfs:label 'Report Version' ;
    rdfs:comment 'The version number of this reach and frequency report, incremented each time a revised or corrected report is issued by Nielsen or reprocessed in the lakehouse. Version 1 represents the initial delivery; subsequent versions represent corrections or revisions. Used to ensure ad sales teams are working with the most current data.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarId rdf:type rdf:Property ;
    rdfs:label 'Calendar Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_calendar. Business justification: Sweeps periods drive compliance calendar deadlines for ratings-based regulatory filings. FCC public file updates and license renewal exhibits tied to sweeps completion dates.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Calendar .

ind:audienceSampleSize rdf:type rdf:Property ;
    rdfs:label 'Audience Sample Size' ;
    rdfs:comment 'Total number of Nielsen panel respondents (diary participants or PPM device carriers) included in the measurement sample for this sweeps period. Larger sample sizes yield higher statistical confidence in ratings estimates.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ccpaApplicable rdf:type rdf:Property ;
    rdfs:label 'Ccpa Applicable' ;
    rdfs:comment 'Indicates whether CCPA viewer data privacy requirements apply to the measurement data collected during this sweeps period (e.g., for California DMA markets in scope). Governs opt-out rights and data sale restrictions for audience panel data.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coppaApplicable rdf:type rdf:Property ;
    rdfs:label 'Coppa Applicable' ;
    rdfs:comment 'Indicates whether COPPA restrictions apply to audience data collected during this sweeps period, specifically for children\'s programming dayparts or platforms. Governs collection and use of audience data for viewers under 13.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataReleaseStatus rdf:type rdf:Property ;
    rdfs:label 'Data Release Status' ;
    rdfs:comment 'Indicates the current release state of Nielsen audience data for this sweeps period. \'unreleased\' = data not yet available; \'preliminary\' = fast affiliate estimates published; \'final\' = confirmed ratings delivered; \'revised_final\' = post-delivery corrections applied.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartCoverage rdf:type rdf:Property ;
    rdfs:label 'Daypart Coverage' ;
    rdfs:comment 'Indicates which dayparts (time segments of the broadcast day) are included in the sweeps measurement scope. \'all_dayparts\' covers the full broadcast day; other values indicate restricted measurement windows. Daypart coverage affects which ad inventory can be rated and guaranteed.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demographicBreakdowns rdf:type rdf:Property ;
    rdfs:label 'Demographic Breakdowns' ;
    rdfs:comment 'Comma-separated list of demographic segments for which Nielsen will provide audience measurement data during this sweeps period (e.g., \'A18-49,A25-54,W18-34,M18-49,HH\'). Determines which target audience guarantees can be supported for ad sales.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diaryReturnRatePct rdf:type rdf:Property ;
    rdfs:label 'Diary Return Rate Pct' ;
    rdfs:comment 'For diary-methodology sweeps periods, the percentage of distributed Nielsen viewing diaries that were returned by respondents. A key data quality indicator; low return rates may trigger Nielsen data quality warnings or adjustments.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmaListVersion rdf:type rdf:Property ;
    rdfs:label 'Dma List Version' ;
    rdfs:comment 'Version identifier of the Nielsen DMA market list applied during this sweeps period (e.g., \'DMA-2024-v1\'). Nielsen periodically revises DMA boundaries; this field ensures correct market mapping for historical comparisons.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total number of calendar days in the sweeps measurement window (end_date minus start_date inclusive). Typically 28 days for standard Nielsen sweeps periods. Used in pacing and audience guarantee calculations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether GDPR audience data privacy requirements apply to the measurement data collected during this sweeps period (e.g., for EU markets included in scope). Governs data retention, consent, and anonymization obligations for audience panel data.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grpGuaranteeApplicable rdf:type rdf:Property ;
    rdfs:label 'Grp Guarantee Applicable' ;
    rdfs:comment 'Indicates whether Gross Rating Point (GRP) audience guarantees negotiated during the upfront or scatter market apply to advertising campaigns running within this sweeps period. True = GRP guarantees in effect; False = no guarantees applicable.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hutMeasurementIncluded rdf:type rdf:Property ;
    rdfs:label 'Hut Measurement Included' ;
    rdfs:comment 'Indicates whether Homes Using Television (HUT) level data is captured and reported as part of this sweeps period measurement. HUT data is used to calculate share and contextualize ratings within total available audience.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSpecialProgrammingFlag rdf:type rdf:Property ;
    rdfs:label 'Is Special Programming Flag' ;
    rdfs:comment 'Indicates whether special programming (e.g., season premieres, finales, major sporting events, stunting) was scheduled during this sweeps period that may inflate or distort ratings relative to non-sweeps periods. True = special programming present; False = standard schedule.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:makegoodWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Makegood Window End Date' ;
    rdfs:comment 'The last date by which makegoods (compensatory ad spots issued when audience guarantees are not met) must be aired following this sweeps period. Defined in advertiser contracts and governed by Wide Orbit traffic system scheduling.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketCount rdf:type rdf:Property ;
    rdfs:label 'Market Count' ;
    rdfs:comment 'Total number of Designated Market Areas (DMAs) included in this sweeps measurement period. Used to assess geographic coverage and local affiliate reporting obligations.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketScope rdf:type rdf:Property ;
    rdfs:label 'Market Scope' ;
    rdfs:comment 'Indicates whether this sweeps period covers national audience measurement, local market (DMA) measurement, or both. Determines which ad sales rate cards and audience guarantees apply.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenContractRef rdf:type rdf:Property ;
    rdfs:label 'Nielsen Contract Ref' ;
    rdfs:comment 'Reference number of the Nielsen Media Research contract or service agreement under which this sweeps period measurement is conducted. Used for billing reconciliation and SLA enforcement with Nielsen.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenSweepCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Sweep Code' ;
    rdfs:comment 'The externally-assigned Nielsen Media Research Platform identifier for this sweeps period (e.g., \'SWEEP-2024-NOV\'). Used to cross-reference records with Nielsen source data and reconcile audience measurement deliverables.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Current lifecycle state of the sweeps period record. \'scheduled\' = future period confirmed by Nielsen; \'active\' = measurement currently in progress; \'completed\' = measurement concluded and data delivered; \'cancelled\' = period cancelled (rare); \'revised\' = dates or scope amended post-publication.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppmComplianceRatePct rdf:type rdf:Property ;
    rdfs:label 'Ppm Compliance Rate Pct' ;
    rdfs:comment 'For PPM-methodology sweeps periods, the percentage of PPM panel members who met Nielsen\'s minimum daily wear-time compliance threshold. Low compliance rates may affect the statistical validity of ratings data.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preliminaryRatingsDate rdf:type rdf:Property ;
    rdfs:label 'Preliminary Ratings Date' ;
    rdfs:comment 'The date on which Nielsen delivers preliminary (fast affiliate) ratings estimates for this sweeps period. Preliminary data is used for early ad sales negotiations before final ratings are confirmed.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:putMeasurementIncluded rdf:type rdf:Property ;
    rdfs:label 'Put Measurement Included' ;
    rdfs:comment 'Indicates whether Persons Using Television (PUT) level data is captured and reported as part of this sweeps period measurement. PUT data enables person-level demographic audience analysis beyond household-level HUT data.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingsDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Ratings Delivery Date' ;
    rdfs:comment 'The date on which Nielsen is contractually obligated to deliver final audience ratings data for this sweeps period to the broadcaster. Drives downstream ad sales billing, makegoods calculations, and audience guarantee reconciliation.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether audience measurement data from this sweeps period must be submitted to a regulatory body (e.g., FCC, Ofcom) as part of broadcast licensing compliance or public interest reporting obligations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Source Last Updated Timestamp' ;
    rdfs:comment 'The timestamp at which the source system (Nielsen Media Research Platform) last updated the record for this sweeps period. Used for incremental data ingestion and change detection in the Databricks Silver layer pipeline.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stuntingDescription rdf:type rdf:Property ;
    rdfs:label 'Stunting Description' ;
    rdfs:comment 'Free-text description of any programming stunts or special events scheduled during this sweeps period (e.g., \'Season finale of flagship drama\', \'Super Bowl lead-out programming\'). Populated only when is_special_programming_flag is True.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepMonth rdf:type rdf:Property ;
    rdfs:label 'Sweep Month' ;
    rdfs:comment 'The calendar month in which the sweeps measurement period falls. Nielsen conducts four sweeps periods annually: February, May, July, and November. Drives programming strategy and ad rate negotiations.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepName rdf:type rdf:Property ;
    rdfs:label 'Sweep Name' ;
    rdfs:comment 'Human-readable label for the sweeps period (e.g., \'November 2024 Sweeps\', \'February 2025 Sweeps\'). Used in reports, ad sales proposals, and programming strategy documents.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepYear rdf:type rdf:Property ;
    rdfs:label 'Sweep Year' ;
    rdfs:comment 'The four-digit calendar year in which the sweeps measurement period occurs (e.g., 2024). Used to uniquely identify the period in combination with sweep_month.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trpGuaranteeApplicable rdf:type rdf:Property ;
    rdfs:label 'Trp Guarantee Applicable' ;
    rdfs:comment 'Indicates whether Target Rating Point (TRP) audience guarantees for specific demographic targets apply to advertising campaigns running within this sweeps period. True = TRP guarantees in effect; False = no TRP guarantees applicable.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upfrontRateCardApplicable rdf:type rdf:Property ;
    rdfs:label 'Upfront Rate Card Applicable' ;
    rdfs:comment 'Indicates whether advertising rates negotiated during the upfront sales event apply to inventory sold within this sweeps period. True = upfront rate cards govern pricing; False = scatter market rates apply.' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:viewershipRecordId rdf:type rdf:Property ;
    rdfs:label 'Viewership Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each granular viewership record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataQualityAuditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Data Quality Auditor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Viewership records undergo quality audits for billing reconciliation, ratings certification, and advertiser makegood disputes. Auditor assignment tracked for compliance trails, client dispute resoluti' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:householdId rdf:type rdf:Property ;
    rdfs:label 'Household Id' ;
    rdfs:comment 'Hashed/anonymized identifier representing the household unit from which the viewing event originated, derived from set-top box or ACR data. Pseudonymized per GDPR Article 25 and CCPA Section 1798.100 to prevent direct re-identification. Used for Nielsen household-level ratings aggregation and HUT (Homes Using Television) calculations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:acrSource rdf:type rdf:Property ;
    rdfs:label 'Acr Source' ;
    rdfs:comment 'The data collection methodology or source system that generated this viewership record. ACR = Automatic Content Recognition from smart TV; set_top_box = return-path data from cable/satellite STB; streaming_telemetry = OTT platform event stream via Adobe Experience Platform; panel = Nielsen People Meter panel; return_path = MVPD return-path data.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adBreakCount rdf:type rdf:Property ;
    rdfs:label 'Ad Break Count' ;
    rdfs:comment 'Number of ad breaks (ad pods) encountered by the viewer during this viewing session. Used for DAI (Dynamic Ad Insertion) reconciliation, Wide Orbit affidavit verification, and advertiser delivery reporting.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adsViewedCount rdf:type rdf:Property ;
    rdfs:label 'Ads Viewed Count' ;
    rdfs:comment 'Total number of individual advertisement spots viewed (not skipped) by the viewer during this session. Used for AVOD monetization reporting, CPM impression counting, and advertiser campaign delivery verification against Wide Orbit schedules.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcastDate rdf:type rdf:Property ;
    rdfs:label 'Broadcast Date' ;
    rdfs:comment 'The calendar date (yyyy-MM-dd) of the broadcast or streaming session, in the local broadcast timezone. Used as the primary date dimension for daily ratings aggregation, sweeps period attribution, and Nielsen overnight ratings reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdnEdgeNode rdf:type rdf:Property ;
    rdfs:label 'Cdn Edge Node' ;
    rdfs:comment 'Identifier of the Akamai CDN edge node or point-of-presence (PoP) that served the streaming content for this session. Used for CDN performance analysis, SLA compliance monitoring, and geographic delivery optimization.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionRate rdf:type rdf:Property ;
    rdfs:label 'Completion Rate' ;
    rdfs:comment 'Proportion of the content asset viewed during this session, expressed as a decimal between 0.0000 and 1.0000 (e.g., 0.7500 = 75% viewed). Sourced directly from platform telemetry; not derived within this product. Used for engagement scoring, programming decisions, and advertiser reporting.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Content Duration Seconds' ;
    rdfs:comment 'Total runtime in seconds of the full content asset or scheduled airing being viewed. Used as the denominator for completion rate calculations and to determine whether a full viewing occurred.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this viewership record was ingested into the Silver Layer. Used for data lineage tracking, quality auditing, and source-system reconciliation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of how the content was delivered to the viewer. Linear = traditional scheduled broadcast; VOD = on-demand; SVOD = subscription on-demand; AVOD = ad-supported on-demand; TVOD = transactional/pay-per-view; FAST = Free Ad-Supported Streaming Television; Simulcast = simultaneous multi-platform broadcast. Critical for rights windowing compliance and revenue attribution. [ENUM-REF-CANDIDATE: linear|vod|svod|avod|tvod|fast|simulcast — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmProtected rdf:type rdf:Property ;
    rdfs:label 'Drm Protected' ;
    rdfs:comment 'Indicates whether the content stream was delivered with DRM (Digital Rights Management) encryption active during this session. Used for rights compliance auditing, anti-piracy reporting to MPA, and content protection SLA verification.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationViewedSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Viewed Seconds' ;
    rdfs:comment 'Total number of seconds the viewer actively watched the content during this session, as reported by the source telemetry system. Accounts for pauses and buffering exclusions per platform telemetry rules. Used for TSR (Time Spent Reading/Viewing) calculations and completion rate derivation.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'The date and time when this viewership record was first loaded into the Databricks Silver Layer lakehouse. Used for data freshness monitoring, SLA compliance, and audit trail purposes. Distinct from tune_in_timestamp (business event time).' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAuthenticated rdf:type rdf:Property ;
    rdfs:label 'Is Authenticated' ;
    rdfs:comment 'Indicates whether the viewer was authenticated (logged in) at the time of viewing. Authenticated sessions enable individual-level audience measurement and subscriber-linked analytics. Unauthenticated sessions rely on household or device-level inference.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nielsenProgramRating rdf:type rdf:Property ;
    rdfs:label 'Nielsen Program Rating' ;
    rdfs:comment 'The Nielsen audience rating score associated with the program airing for this viewership record, representing the percentage of the total TV households or persons in the universe tuned to the program. Sourced from Nielsen Media Research Platform integration. Used for GRP/TRP calculations and ad rate setting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:playbackPositionSeconds rdf:type rdf:Property ;
    rdfs:label 'Playback Position Seconds' ;
    rdfs:comment 'The content offset position in seconds at which the viewer stopped watching (tune-out position within the asset). For linear broadcast, this reflects the offset from the scheduled start of the program. Used for resume-point analytics and mid-roll ad delivery attribution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tuneInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tune In Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) when the viewer began watching the content or tuned to the channel. This is the principal business event timestamp for the viewership record. Used for daypart analysis, time-spent calculations, and sweeps period attribution.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tuneOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tune Out Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) when the viewer stopped watching, changed channel, or the session ended. Used in conjunction with tune_in_timestamp to calculate duration_viewed_seconds.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:viewingStatus rdf:type rdf:Property ;
    rdfs:label 'Viewing Status' ;
    rdfs:comment 'Current lifecycle status of the viewing session record. \'completed\' = viewer watched to end or tune-out cleanly; \'in_progress\' = session still active at ingestion time; \'abandoned\' = viewer left before 10% completion; \'interrupted\' = session ended due to technical failure; \'error\' = telemetry data quality issue flagged.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycleId rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Id' ;
    rdfs:comment 'Foreign key linking to billing.cycle. Business justification: Billing account belongs to ONE billing cycle schedule (monthly, quarterly, annual). Currently stores billing_cycle_code as STRING; need FK to cycle table for full cycle configuration. Remove billing_c' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cycle .

ind:defaultCommunicationTemplateId rdf:type rdf:Property ;
    rdfs:label 'Default Communication Template Id' ;
    rdfs:comment 'Foreign key linking to billing.communication_template. Business justification: Billing account can have ONE default communication template for invoice delivery (customer preference). Need FK to track account-level communication preferences. No redundant columns to remove.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommunicationTemplate .

ind:defaultPaymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Default Payment Method Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_method. Business justification: Billing account has ONE default payment method for auto-pay and recurring charges. Currently only stores payment_method_type as STRING; need FK to the actual payment_method record. Remove default_paym' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Legal or business name associated with the billing account. For subscriber accounts, this is the account holder name; for corporate accounts, this is the registered business name.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-visible unique account number assigned to the billing account. Used on invoices, statements, and customer correspondence.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the billing account based on the nature of the billable relationship. Subscriber accounts are for SVOD/AVOD/TVOD end-users; advertiser accounts are for agencies and direct advertisers; MVPD accounts are for multichannel video programming distributors paying carriage fees; syndication licensee accounts are for content resale partners; production vendor accounts are for production service providers; talent accounts are for residuals and royalty payments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPayEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic payment processing is enabled for this account. When true, invoices are automatically charged to the default payment method on the due date.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code in which this account is billed (e.g., USD, GBP, EUR). All invoices and payments for this account are denominated in this currency.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycleDay rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Day' ;
    rdfs:comment 'Day of the month (1-31) on which recurring invoices are generated for monthly billing cycles. Null for non-monthly cycles.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date on which this billing account was permanently closed. Null for active and suspended accounts.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Current Balance Amount' ;
    rdfs:comment 'Current outstanding balance on the account, calculated as sum of unpaid invoices minus unapplied credits and payments. Positive values indicate amounts owed to the business; negative values indicate credit balances owed to the customer.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current stage in the collections escalation process for overdue accounts. 0 indicates no dunning (account current); higher values indicate progressive escalation steps (e.g., 1=reminder notice, 2=warning, 3=service suspension notice, 4=final notice before write-off).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'Preferred method for delivering invoices to this account. Email sends PDF invoices; postal mail sends printed invoices; electronic portal makes invoices available for download in customer self-service portal; EDI transmits invoices via Electronic Data Interchange (X12 810 or EDIFACT INVOIC).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date of the most recent dunning notice or collections contact sent to this account.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Invoice Date' ;
    rdfs:comment 'Date of the most recent invoice generated for this account. Used for billing cycle tracking and account activity monitoring.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Amount of the most recent payment received. Used for payment pattern analysis.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment received and applied to this account. Used for payment behavior analysis and credit risk assessment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date on which this billing account was first established and activated.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapCustomerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Account Number' ;
    rdfs:comment 'Customer master record number in SAP S/4HANA Financial Accounting (FI) module. Used for GL posting, accounts receivable management, and financial reconciliation. This is the authoritative financial system identifier.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether this account is exempt from sales tax, VAT, or other consumption taxes. True for tax-exempt organizations (e.g., non-profits, government entities, resellers with valid exemption certificates); false for standard taxable accounts.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'Government-issued certificate or registration number authorizing tax exemption. Required for audit trail when tax_exempt_flag is true.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Expiry Date' ;
    rdfs:comment 'Date on which the tax exemption certificate expires and must be renewed. Null for permanent exemptions.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wideorbitAccountReference rdf:type rdf:Property ;
    rdfs:label 'Wideorbit Account Reference' ;
    rdfs:comment 'Account identifier in WideOrbit traffic and billing system. Used for advertising sales order management, spot scheduling, and ad billing for advertiser and agency accounts.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zuoraAccountReference rdf:type rdf:Property ;
    rdfs:label 'Zuora Account Reference' ;
    rdfs:comment 'Account identifier in Zuora subscription billing platform. Used for subscription lifecycle management, recurring billing, and revenue recognition for SVOD/AVOD subscriber accounts.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyPartnerId rdf:type rdf:Property ;
    rdfs:label 'Agency Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Ad sales in broadcasting involve agency partners as intermediaries for commission splits, co-op advertising budgets, and consolidated billing. Agency relationship management requires partner domain li' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:billingContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Ad orders have designated billing contacts within the broadcaster\'s billing team who coordinate with agencies on discrepancies, makegoods, and payment issues. Tracking billing contact employee is oper' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:billingDisputeId rdf:type rdf:Property ;
    rdfs:label 'Billing Dispute Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_dispute. Business justification: Ad billing order can have ONE formal billing dispute raised against it. Currently stores dispute_reason and dispute_date as STRING/DATE; need FK to the formal billing_dispute record for full dispute l' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingDispute .

ind:transmissionEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Transmission Equipment Id' ;
    rdfs:comment 'Foreign key linking to technology.transmission_equipment. Business justification: Ad orders specify transmission equipment for spot delivery scheduling, makegoods tracking when equipment fails, affidavit generation, and proof-of-performance documentation required by advertisers in ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransmissionEquipment .

ind:affidavitStatus rdf:type rdf:Property ;
    rdfs:label 'Affidavit Status' ;
    rdfs:comment 'Status of proof-of-broadcast affidavit documentation for this order. Affidavits provide legal confirmation that contracted spots aired as scheduled.' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billedAmount rdf:type rdf:Property ;
    rdfs:label 'Billed Amount' ;
    rdfs:comment 'Total amount invoiced to the advertiser or agency for this order, including any adjustments or makegoods.' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedAmount rdf:type rdf:Property ;
    rdfs:label 'Contracted Amount' ;
    rdfs:comment 'Total contracted revenue amount for the advertising order as agreed in the sales contract, before any makegoods or adjustments.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daypartBreakdown rdf:type rdf:Property ;
    rdfs:label 'Daypart Breakdown' ;
    rdfs:comment 'Distribution of advertising spots across broadcast dayparts (time segments of the broadcast day such as Prime Time, Early Morning, Late Night). Stored as structured text or JSON showing spot count and value per daypart.' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpRate rdf:type rdf:Property ;
    rdfs:label 'Grp Rate' ;
    rdfs:comment 'Cost per gross rating point applied to this order, if GRP pricing is used.' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isciCodes rdf:type rdf:Property ;
    rdfs:label 'Isci Codes' ;
    rdfs:comment 'Comma-separated list of ISCI codes identifying the specific commercial creative assets that aired as part of this order. ISCI is the industry standard for uniquely identifying TV commercials.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makegoodsValue rdf:type rdf:Property ;
    rdfs:label 'Makegoods Value' ;
    rdfs:comment 'Total value of compensatory ad spots provided to the advertiser due to underdelivery, technical issues, or audience guarantee shortfalls.' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'Remaining unpaid balance on this billing order, calculated as billed amount minus paid amount.' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Total amount received in payment from the advertiser or agency against this billing order.' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which payment is contractually due from the advertiser or agency.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateBasis rdf:type rdf:Property ;
    rdfs:label 'Rate Basis' ;
    rdfs:comment 'Pricing model used for this advertising order. CPM (Cost Per Mille) = cost per thousand impressions, GRP (Gross Rating Point) = reach × frequency, CPRP (Cost Per Rating Point) = cost per single rating point, flat rate = fixed campaign price, cost per spot = per-unit pricing.' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSpotsAired rdf:type rdf:Property ;
    rdfs:label 'Total Spots Aired' ;
    rdfs:comment 'Total number of advertising spots that successfully aired as confirmed by affidavits and playout logs.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adBillingReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Ad Billing Reconciliation Id' ;
    rdfs:comment 'Unique identifier for the advertising billing reconciliation record. Primary key for this entity.' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'The net adjustment amount applied to the billing due to makegoods, credits, or other reconciliation adjustments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affidavitCount rdf:type rdf:Property ;
    rdfs:label 'Affidavit Count' ;
    rdfs:comment 'The total number of proof-of-broadcast affidavits associated with this reconciliation record, documenting actual spot delivery.' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affidavitVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Affidavit Verification Status' ;
    rdfs:comment 'The status of affidavit verification indicating whether proof-of-broadcast documentation has been validated and accepted.' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredAmount rdf:type rdf:Property ;
    rdfs:label 'Delivered Amount' ;
    rdfs:comment 'The monetary value of advertising spots that were successfully delivered and verified through affidavits.' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The date when the dispute was formally raised by the advertiser or agency regarding this reconciliation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Boolean indicator of whether this reconciliation record is currently under dispute by the advertiser or agency.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Detailed explanation of the reason for dispute if the reconciliation is contested by the advertiser or agency.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makegoodSpotsQuantity rdf:type rdf:Property ;
    rdfs:label 'Makegood Spots Quantity' ;
    rdfs:comment 'The number of compensatory advertising spots provided to the advertiser to remedy missed or underdelivered spots.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:makegoodValueAmount rdf:type rdf:Property ;
    rdfs:label 'Makegood Value Amount' ;
    rdfs:comment 'The monetary value of the makegood spots provided as compensation, calculated at the original contracted rate.' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netBillableAmount rdf:type rdf:Property ;
    rdfs:label 'Net Billable Amount' ;
    rdfs:comment 'The final net amount billable to the advertiser after all reconciliation adjustments, makegoods, and credits have been applied.' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'The date when the reconciliation process was completed and the advertising delivery was verified against the billing order.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationNumber rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Number' ;
    rdfs:comment 'Business-facing unique reference number for this reconciliation record, used for tracking and reporting purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Timestamp' ;
    rdfs:comment 'Precise timestamp when the reconciliation record was finalized, used for audit trail and settlement timing.' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reconciliationType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Type' ;
    rdfs:comment 'The type of reconciliation record indicating whether this is a standard delivery verification, makegood settlement, credit issuance, or billing adjustment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date when the reconciliation dispute was resolved and the final settlement was agreed upon.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapPostingReference rdf:type rdf:Property ;
    rdfs:label 'Sap Posting Reference' ;
    rdfs:comment 'The SAP S/4HANA document number or posting reference for the financial transaction associated with this reconciliation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSpotsMissed rdf:type rdf:Property ;
    rdfs:label 'Total Spots Missed' ;
    rdfs:comment 'The number of ordered advertising spots that failed to air as scheduled, requiring makegood remediation.' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The percentage variance between contracted and delivered advertising value, calculated as (delivered - contracted) / contracted * 100.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCarriageFeeInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Billing Carriage Fee Invoice Id' ;
    rdfs:comment 'Unique identifier for the carriage fee invoice issued to MVPDs and vMVPDs. Primary key for this transaction header entity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingCarriageFeeInvoice .

ind:carriageAgreementId rdf:type rdf:Property ;
    rdfs:label 'Carriage Agreement Id' ;
    rdfs:comment 'Reference to the underlying retransmission consent or must-carry agreement governing this invoice.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarriageAgreement .

ind:distributionPartnerId rdf:type rdf:Property ;
    rdfs:label 'Distribution Partner Id' ;
    rdfs:comment 'Reference to the MVPD or vMVPD operator being invoiced for channel carriage fees.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaBroadcasting .

ind:preparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Carriage fee invoices are high-value, complex documents prepared by specialized distribution billing analysts. Tracking preparer employee supports quality control, dispute resolution, and operational ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baseCarriageFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Base Carriage Fee Amount' ;
    rdfs:comment 'Base carriage fee amount calculated as subscriber count multiplied by per-subscriber rate before adjustments.' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'Email address of the billing contact at the MVPD operator for invoice delivery and correspondence.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactName rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Name' ;
    rdfs:comment 'Name of the billing contact at the MVPD operator for invoice correspondence.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the billing period covered by this carriage fee invoice.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the billing period covered by this carriage fee invoice.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blackoutCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Blackout Credit Amount' ;
    rdfs:comment 'Credit amount applied for geographic broadcast blackout periods where channel was unavailable to MVPD subscribers.' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelLineupDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Lineup Description' ;
    rdfs:comment 'Description of the channel lineup or package included in this carriage fee invoice.' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Dispute Adjustment Amount' ;
    rdfs:comment 'Adjustment amount applied due to billing disputes or makegoods for service level failures.' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Date by which payment is due from the MVPD operator per contractual payment terms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Escalation Adjustment Amount' ;
    rdfs:comment 'Adjustment amount applied due to contractual escalation clause (e.g., annual rate increase, CPI adjustment).' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perSubscriberFeeRate rdf:type rdf:Property ;
    rdfs:label 'Per Subscriber Fee Rate' ;
    rdfs:comment 'Contractual per-subscriber fee rate applied to calculate the total carriage fee amount.' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retransmissionConsentType rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Type' ;
    rdfs:comment 'Type of regulatory framework governing this carriage fee: retransmission consent (negotiated) or must-carry (mandatory).' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberCountBasis rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count Basis' ;
    rdfs:comment 'Number of MVPD subscribers used as the basis for calculating the carriage fee amount.' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCarriageFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Carriage Fee Amount' ;
    rdfs:comment 'Total carriage fee amount invoiced after all adjustments, credits, and escalations.' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoId rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Id' ;
    rdfs:comment 'Unique identifier for the credit memo. Primary key for the credit memo entity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditMemo .

ind:communicationTemplateId rdf:type rdf:Property ;
    rdfs:label 'Communication Template Id' ;
    rdfs:comment 'Foreign key linking to billing.communication_template. Business justification: Credit memo notification uses ONE communication template to notify customer of the credit. Need FK to track which template was used for audit and customer service purposes. No redundant columns to rem' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommunicationTemplate .

ind:complianceFindingId rdf:type rdf:Property ;
    rdfs:label 'Compliance Finding Id' ;
    rdfs:comment 'Foreign key linking to content.compliance_finding. Business justification: Regulatory violations (FCC fines, content rating breaches) trigger credit memos to advertisers/distributors as makegoods or contractual penalties. Compliance and finance teams track which findings gen' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceFinding .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice_line. Business justification: Credit memo can reference ONE specific invoice line item (not just the entire invoice). Credits are often issued for specific line items (e.g., one ad spot that didn\'t air, one subscription month). Ne' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:originalInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Id' ;
    rdfs:comment 'Reference to the original invoice being credited, adjusted, or written off. Null for credits not tied to a specific invoice.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:outageRecordId rdf:type rdf:Property ;
    rdfs:label 'Outage Record Id' ;
    rdfs:comment 'Foreign key linking to technology.outage_record. Business justification: Credits for service interruptions must reference outage records for SLA breach validation, revenue impact calculation, regulatory reporting, and automated credit approval workflows in broadcast servic' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutageRecord .

ind:primaryCreditEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Credit Employee Id' ;
    rdfs:comment 'Identifier of the user who approved the credit memo, for audit trail and SOX compliance.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCreditModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Credit Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the credit memo record, for audit trail purposes.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appliedDate rdf:type rdf:Property ;
    rdfs:label 'Applied Date' ;
    rdfs:comment 'Date the credit was actually applied to the customer account or invoice balance. Null if not yet applied.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:badDebtWriteOffFlag rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Write Off Flag' ;
    rdfs:comment 'Indicates whether this credit memo represents a bad debt write-off for an uncollectable balance. True for write-offs, false for other credit types.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionAgencyName rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Name' ;
    rdfs:comment 'Name of the third-party collection agency to which the debt was referred, if applicable.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAgencyReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Referral Flag' ;
    rdfs:comment 'Indicates whether the original debt was referred to a collection agency before write-off. Used for tracking recovery potential.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Externally-visible business identifier for the credit memo, used in customer communications and financial reporting. Typically follows format CM-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Status' ;
    rdfs:comment 'Current lifecycle status of the credit memo in the approval and application workflow.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General ledger account code to which the credit or write-off is posted in SAP S/4HANA for financial reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date the credit memo was formally issued and became effective for accounting purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Net Credit Amount' ;
    rdfs:comment 'Net credit amount after tax adjustments. Equals credit_amount minus tax_amount.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'Amount subsequently recovered from a written-off debt through collection efforts or customer payment. Null if no recovery occurred.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Date' ;
    rdfs:comment 'Date on which a previously written-off amount was recovered. Null if no recovery occurred.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionImpact rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Impact' ;
    rdfs:comment 'Accounting period impact classification for revenue recognition under ASC 606. Indicates whether the credit affects current, prior, or future period revenue.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'SAP S/4HANA financial document number for the credit memo posting, used for reconciliation and audit trail.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPostingDate rdf:type rdf:Property ;
    rdfs:label 'Sap Posting Date' ;
    rdfs:comment 'Date the credit memo was posted to SAP S/4HANA general ledger for financial reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Tax portion of the credit amount, if applicable. Used for tax reporting and reconciliation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleId rdf:type rdf:Property ;
    rdfs:label 'Cycle Id' ;
    rdfs:comment 'Primary key for cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenewEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Enabled' ;
    rdfs:comment 'Indicates whether subscriptions on this billing cycle automatically renew at the end of the term. True enables automatic renewal in Zuora subscription management.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingPeriodEndDay rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Day' ;
    rdfs:comment 'Day of the month (1-31) when the service period covered by the invoice ends. Used to calculate service period duration for revenue recognition. Null for non-monthly frequencies.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingPeriodStartDay rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Day' ;
    rdfs:comment 'Day of the month (1-31) when the service period covered by the invoice begins. May differ from cycle_day for advance billing scenarios. Null for non-monthly frequencies.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingRunDayOffset rdf:type rdf:Property ;
    rdfs:label 'Billing Run Day Offset' ;
    rdfs:comment 'Number of days before or after the cycle day when the billing run executes. Positive values indicate days after cycle day; negative values indicate days before. Used to schedule invoice generation in advance of service period.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingTiming rdf:type rdf:Property ;
    rdfs:label 'Billing Timing' ;
    rdfs:comment 'Indicates whether billing occurs in advance (invoice before service period) or in arrears (invoice after service period). Critical for revenue recognition under ASC 606.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User identifier or system account that created this billing cycle configuration. Used for audit trail and accountability under SOX compliance requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Business identifier code for the billing cycle (e.g., MONTHLY_01, QUARTERLY_Q1, ANNUAL_FY). Used in Zuora subscription billing engine for cycle identification.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleDescription rdf:type rdf:Property ;
    rdfs:label 'Cycle Description' ;
    rdfs:comment 'Detailed description of the billing cycle configuration, including business rules, special handling instructions, and usage notes for billing operations team.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Human-readable name of the billing cycle (e.g., Monthly Standard, Quarterly Advance, Annual Arrears).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'Current lifecycle status of the billing cycle configuration. Active cycles are available for new subscriptions; inactive cycles are closed to new assignments but continue for existing subscribers; deprecated cycles are phased out; pending cycles are configured but not yet live.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'Classification of the billing cycle by revenue stream: subscription (SVOD/AVOD subscriber billing), advertising (ad campaign billing via Wide Orbit), carriage (MVPD/vMVPD distribution fees), syndication (content licensing fees), usage (pay-per-view/TVOD), or custom (non-standard arrangements).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:day rdf:type rdf:Property ;
    rdfs:label 'Day' ;
    rdfs:comment 'Day of the month (1-31) when the billing cycle starts or billing run executes. For monthly cycles, this is the anchor date. Null for non-monthly frequencies.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days after payment due date before late fees or service suspension actions are triggered. Provides customer buffer for payment processing delays.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceGenerationDay rdf:type rdf:Property ;
    rdfs:label 'Invoice Generation Day' ;
    rdfs:comment 'Specific day of the month (1-31) when invoices are generated for this cycle. Calculated from cycle_day and billing_run_day_offset. Null for non-monthly frequencies.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastBillingDate rdf:type rdf:Property ;
    rdfs:label 'Last Billing Date' ;
    rdfs:comment 'Most recent date when a billing run was successfully completed for this cycle. Null if no billing run has occurred yet.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User identifier or system account that last modified this billing cycle configuration. Used for audit trail and accountability under SOX compliance requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextBillingDate rdf:type rdf:Property ;
    rdfs:label 'Next Billing Date' ;
    rdfs:comment 'Next date when a billing run will execute for accounts assigned to this cycle. Updated after each billing run completion. Used by Zuora billing engine for scheduling.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDueDays rdf:type rdf:Property ;
    rdfs:label 'Payment Due Days' ;
    rdfs:comment 'Number of days after invoice generation when payment is due. Used to calculate invoice due date. Standard terms are Net 30, Net 15, or immediate (0 days).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prorationEnabled rdf:type rdf:Property ;
    rdfs:label 'Proration Enabled' ;
    rdfs:comment 'Indicates whether partial-period charges are prorated when subscription starts/ends mid-cycle. True enables proration calculation in Zuora.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prorationMethod rdf:type rdf:Property ;
    rdfs:label 'Proration Method' ;
    rdfs:comment 'Method for calculating prorated charges: daily (per-day calculation), monthly (per-month calculation), or none (no proration). Used when proration_enabled is true.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days before cycle renewal when customer notification is sent. Used for auto-renew reminders and cancellation windows. Null if auto_renew_enabled is false.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueRecognitionRule rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Rule' ;
    rdfs:comment 'Code identifying the ASC 606 revenue recognition rule applied to invoices generated under this cycle. Determines how revenue is recognized over time (e.g., straight-line, milestone-based). Maps to SAP S/4HANA revenue recognition configuration.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCalculationEnabled rdf:type rdf:Property ;
    rdfs:label 'Tax Calculation Enabled' ;
    rdfs:comment 'Indicates whether automatic tax calculation is enabled for invoices generated under this cycle. True triggers tax engine integration (e.g., Avalara, Vertex) during invoice generation.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:writeOffId rdf:type rdf:Property ;
    rdfs:label 'Write Off Id' ;
    rdfs:comment 'Foreign key linking to billing.write_off. Business justification: Billing dispute can be resolved via ONE write-off decision (when dispute is valid and amount is written off). Need FK to write_off for dispute resolution tracking. No redundant columns to remove.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WriteOff .

ind:assignedResolverName rdf:type rdf:Property ;
    rdfs:label 'Assigned Resolver Name' ;
    rdfs:comment 'Name of the employee or team assigned to resolve the dispute, for operational tracking.' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address of the primary contact person for the disputing party, used for dispute correspondence.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact person for the disputing party, used for dispute resolution communication.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Issued Flag' ;
    rdfs:comment 'Indicates whether a credit memo was issued as part of the dispute resolution (True) or not (False).' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Detailed narrative explanation of the dispute as provided by the disputing party, capturing the specific issue and context.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle state of the dispute: open (newly raised), under_review (being investigated), resolved (closed with outcome), escalated (sent to higher authority), withdrawn (retracted by disputing party), rejected (dispute denied without resolution).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Classification of the dispute reason: amount_error (billing calculation error), service_not_received (content or service not delivered), makegood_claim (compensatory ad spot request), duplicate_charge (same charge billed twice), rate_discrepancy (incorrect pricing applied), contract_dispute (terms interpretation disagreement).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The monetary amount being contested by the disputing party, in the invoice currency.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputingPartyName rdf:type rdf:Property ;
    rdfs:label 'Disputing Party Name' ;
    rdfs:comment 'Name of the organization or individual who raised the dispute, for reporting and communication purposes.' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputingPartyType rdf:type rdf:Property ;
    rdfs:label 'Disputing Party Type' ;
    rdfs:comment 'Category of the entity raising the dispute: subscriber (end consumer), advertiser (ad campaign buyer), MVPD (Multichannel Video Programming Distributor), licensee (content license holder), distributor (content distribution partner).' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Numeric indicator of how many times the dispute has been escalated (0 = no escalation, 1 = first escalation to supervisor, 2 = second escalation to manager, etc.).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Explanation of why the dispute was escalated beyond the initial resolver, capturing complexity or policy exception requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCaseNumber rdf:type rdf:Property ;
    rdfs:label 'External Case Number' ;
    rdfs:comment 'Reference number from an external system (e.g., CRM case ID, legal case number) if the dispute is tracked in multiple systems.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'Username or identifier of the system user who last updated the dispute record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'The date the dispute was formally raised and entered into the dispute management system.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openTimestamp rdf:type rdf:Property ;
    rdfs:label 'Open Timestamp' ;
    rdfs:comment 'Precise timestamp when the dispute was created in the system, used for SLA tracking and audit trail.' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority level assigned to the dispute based on amount, customer tier, or contractual importance: low (routine), medium (standard), high (significant customer or amount), critical (executive escalation or legal risk).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally-visible unique reference number for the dispute, used in customer communications and tracking. Format: DSP-YYYYMMDD sequence.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Deadline Date' ;
    rdfs:comment 'Target date by which the dispute must be resolved per Service Level Agreement (SLA) or contractual terms.' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Internal notes documenting the investigation findings, resolution rationale, and actions taken by the resolver.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome of the dispute resolution: full_credit (entire disputed amount credited), partial_credit (portion credited), no_adjustment (dispute rejected, no change), makegood_issued (compensatory ad spot provided), contract_amendment (terms renegotiated), escalated_unresolved (sent to legal or executive review).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Precise timestamp when the dispute was resolved, used for SLA compliance measurement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Classification of the underlying cause of the dispute for process improvement and trend analysis: billing_system_error (system calculation bug), data_entry_error (manual input mistake), rate_card_error (incorrect pricing configuration), service_delivery_failure (content or ad not delivered), contract_misinterpretation (terms unclear or misread), customer_misunderstanding (customer expectation mismatch).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the dispute resolution exceeded the contractual SLA deadline (True) or was resolved within SLA (False).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningEventId rdf:type rdf:Property ;
    rdfs:label 'Dunning Event Id' ;
    rdfs:comment 'Unique identifier for the dunning event record. Primary key.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Reference to the payment transaction record if a payment retry was successful.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:paymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Payment Method Id' ;
    rdfs:comment 'Reference to the payment method used for retry attempts, if applicable.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:refundId rdf:type rdf:Property ;
    rdfs:label 'Refund Id' ;
    rdfs:comment 'Foreign key linking to billing.refund. Business justification: Dunning event can result in ONE refund (e.g., when dunning reveals an overpayment or billing error). Need FK to refund for dunning outcome tracking. No redundant columns to remove.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Refund .

ind:accountBalanceAtAction rdf:type rdf:Property ;
    rdfs:label 'Account Balance At Action' ;
    rdfs:comment 'Outstanding balance on the billing account at the time the dunning action was taken.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountTerminationFlag rdf:type rdf:Property ;
    rdfs:label 'Account Termination Flag' ;
    rdfs:comment 'Indicates whether the billing account was terminated as a result of this dunning action.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountTerminationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Account Termination Timestamp' ;
    rdfs:comment 'Date and time when the billing account was terminated, if applicable.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Timestamp' ;
    rdfs:comment 'Date and time when the dunning action was executed.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Type of dunning action taken against the delinquent account.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountRecovered rdf:type rdf:Property ;
    rdfs:label 'Amount Recovered' ;
    rdfs:comment 'Amount successfully recovered as a result of this dunning action, if any.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:churnRiskScore rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score' ;
    rdfs:comment 'Calculated risk score indicating the likelihood of subscriber churn as a result of this dunning action (0-100 scale).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'Channel through which the dunning communication was delivered to the subscriber.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysPastDue rdf:type rdf:Property ;
    rdfs:label 'Days Past Due' ;
    rdfs:comment 'Number of days the account has been delinquent at the time of this dunning action.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunningStepNumber rdf:type rdf:Property ;
    rdfs:label 'Dunning Step Number' ;
    rdfs:comment 'Sequential step number in the dunning workflow (e.g., 1 for first reminder, 2 for second reminder, 3 for suspension warning, 4 for service suspension).' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextDunningStepScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Dunning Step Scheduled Date' ;
    rdfs:comment 'Scheduled date for the next dunning action if this step did not resolve the delinquency.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Result or outcome of the dunning action taken. [ENUM-REF-CANDIDATE: payment_received|payment_failed|promise_to_pay|dispute_raised|no_response|account_suspended|account_terminated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientAddress rdf:type rdf:Property ;
    rdfs:label 'Recipient Address' ;
    rdfs:comment 'Email address, phone number, or postal address to which the dunning communication was sent.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Response Received Flag' ;
    rdfs:comment 'Indicates whether the subscriber responded to this dunning action (e.g., made a payment, contacted support, updated payment method).' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Date and time when the subscriber responded to the dunning action, if applicable.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retryAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Retry Attempt Count' ;
    rdfs:comment 'Number of automated payment retry attempts made for this dunning event, if action type is payment retry.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceSuspensionFlag rdf:type rdf:Property ;
    rdfs:label 'Service Suspension Flag' ;
    rdfs:comment 'Indicates whether subscriber services were suspended as a result of this dunning action.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceSuspensionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Service Suspension Timestamp' ;
    rdfs:comment 'Date and time when subscriber services were suspended, if applicable.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'Source system that generated or recorded this dunning event (e.g., Zuora, Wide Orbit, SAP S/4HANA).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Invoices are generated by billing operations staff. Tracking which employee created each invoice is required for audit trail, compliance oversight, and operational quality control in media broadcastin' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:licenseWindowId rdf:type rdf:Property ;
    rdfs:label 'License Window Id' ;
    rdfs:comment 'Reference to the content license window for syndication invoices. Defines the rights period being billed.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsContentWindow .

ind:runId rdf:type rdf:Property ;
    rdfs:label 'Run Id' ;
    rdfs:comment 'Foreign key linking to billing.run. Business justification: Invoice is generated by ONE billing run (batch process). Need to track which specific batch execution generated this invoice for operational audit trail and troubleshooting. No redundant columns to re' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Run .

ind:subscriptionPlanId rdf:type rdf:Property ;
    rdfs:label 'Subscription Plan Id' ;
    rdfs:comment 'Reference to the subscription plan for SVOD billing invoices. Null for non-subscription revenue categories.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubscriptionPlan .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'Total amount paid against this invoice to date. Used to calculate outstanding balance.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installmentNumber rdf:type rdf:Property ;
    rdfs:label 'Installment Number' ;
    rdfs:comment 'Installment sequence number for syndication license fees paid over multiple periods. Null for single-payment invoices.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date the invoice was issued to the customer, advertiser, or partner. Used as the basis for payment terms calculation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally-visible unique invoice number used for customer communication and payment reference. Generated by billing system (Zuora, Wide Orbit, or SAP S/4HANA).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice in the billing workflow. [ENUM-REF-CANDIDATE: draft|issued|sent|paid|partially_paid|overdue|disputed|void|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvpdSubscriberCount rdf:type rdf:Property ;
    rdfs:label 'Mvpd Subscriber Count' ;
    rdfs:comment 'Number of subscribers reported by the MVPD partner as the basis for carriage fee calculation. Relevant for carriage fee invoices.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid balance on this invoice. Calculated as total_amount_due minus amount_paid.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidDate rdf:type rdf:Property ;
    rdfs:label 'Paid Date' ;
    rdfs:comment 'Date the invoice was fully paid. Null if not yet paid or only partially paid.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Primary payment method used or expected for this invoice. [ENUM-REF-CANDIDATE: credit_card|bank_transfer|ach|wire|check|direct_debit|paypal|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationFlag rdf:type rdf:Property ;
    rdfs:label 'Proration Flag' ;
    rdfs:comment 'Indicates whether this subscription invoice includes prorated charges due to mid-cycle changes. Relevant for SVOD billing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition End Date' ;
    rdfs:comment 'End date of the period over which revenue from this invoice should be recognized per ASC 606 guidelines.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Start Date' ;
    rdfs:comment 'Start date of the period over which revenue from this invoice should be recognized per ASC 606 guidelines.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemInvoiceReference rdf:type rdf:Property ;
    rdfs:label 'Source System Invoice Reference' ;
    rdfs:comment 'Original invoice identifier from the source billing system. Used for reconciliation and audit trail.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Total amount before taxes, fees, and adjustments. Sum of all line item amounts.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmountDue rdf:type rdf:Property ;
    rdfs:label 'Total Amount Due' ;
    rdfs:comment 'Final total amount due after all taxes, discounts, and adjustments. This is the amount the customer must pay.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'Reason this invoice was voided or cancelled. Populated when invoice_status is void or cancelled.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itAssetId rdf:type rdf:Property ;
    rdfs:label 'It Asset Id' ;
    rdfs:comment 'Foreign key linking to technology.it_asset. Business justification: Line items for equipment leases, software licenses, and asset rentals need asset tracking for contract compliance verification, depreciation schedule reconciliation, and capital vs. operational expens' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItAsset .

ind:originalInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Line Id' ;
    rdfs:comment 'Reference to the original invoice line that this line is adjusting, crediting, or replacing. Used for tracking billing corrections, credits, and makegoods.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:performanceObligationId rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Id' ;
    rdfs:comment 'Identifier for the performance obligation under ASC 606 revenue recognition standard, linking this charge to a specific contractual promise to deliver goods or services.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceObligation .

ind:productId rdf:type rdf:Property ;
    rdfs:label 'Product Id' ;
    rdfs:comment 'Reference to the product or service catalog entry that defines what is being sold on this invoice line.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Product .

ind:subscriptionId rdf:type rdf:Property ;
    rdfs:label 'Subscription Id' ;
    rdfs:comment 'Reference to the subscriber subscription record for subscription revenue line items, linking the charge to the active subscription plan.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscription .

ind:chargeDescription rdf:type rdf:Property ;
    rdfs:label 'Charge Description' ;
    rdfs:comment 'Detailed description of the charge appearing on the invoice line, explaining the service, ad spot, carriage fee period, or license fee installment being billed.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center or business unit responsible for this revenue line, used for internal financial reporting and profitability analysis.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountCode rdf:type rdf:Property ;
    rdfs:label 'Discount Code' ;
    rdfs:comment 'Code or identifier for the discount program or promotion applied to this line, used for tracking discount effectiveness and revenue impact.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedAmount rdf:type rdf:Property ;
    rdfs:label 'Extended Amount' ;
    rdfs:comment 'Total amount for this line item including all charges, discounts, and taxes. This is the final billable amount for the line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grpDelivered rdf:type rdf:Property ;
    rdfs:label 'Grp Delivered' ;
    rdfs:comment 'Gross Rating Points delivered for this advertising line item, measuring the total audience reach and frequency achieved for the campaign.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Business-facing line item identifier displayed on customer invoices and billing statements for reference and dispute resolution.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of units being charged on this line. For ad spots this is the number of impressions or spots; for subscriptions this is typically 1; for usage-based billing this is the measured consumption.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Service Period End Date' ;
    rdfs:comment 'End date of the service period covered by this line item charge. For subscriptions this is the billing cycle end; for ad campaigns this is the flight end date.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Period Start Date' ;
    rdfs:comment 'Start date of the service period covered by this line item charge. For subscriptions this is the billing cycle start; for ad campaigns this is the flight start date.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Specific type of service or product being billed on this line, such as premium channel subscription, ad pod placement, carriage agreement tier, or syndication window.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotCount rdf:type rdf:Property ;
    rdfs:label 'Spot Count' ;
    rdfs:comment 'Number of ad spots delivered for this line item, used in advertising billing to verify delivery against the sales order commitment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax classification code that determines the tax treatment for this line item, used for tax calculation and compliance reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the quantity field, such as spot (ad placement), impression (ad view), subscriber (subscription count), stream (viewing session), or GB (data transfer).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Processed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Payment processing requires employee accountability for fraud prevention, reconciliation, and audit compliance. Tracking which billing staff member processed each payment is standard financial control' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:vendorContractId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contract Id' ;
    rdfs:comment 'Foreign key linking to technology.vendor_contract. Business justification: Payments to technology vendors must reference contracts for payment terms validation, accrual matching, milestone-based payment verification, and audit trail compliance required in technology procurem' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorContract .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The monetary amount of the payment transaction in the specified currency. Gross payment value before any adjustments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'The portion of the payment amount that has been applied against outstanding invoices or account balances. May differ from payment_amount if partial application or overpayment.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Authorization code returned by the payment processor or card issuer confirming approval of the transaction.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Bank Transaction Reference' ;
    rdfs:comment 'Reference number provided by the bank for wire transfers, ACH transactions, or check deposits. Used for bank reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The channel or interface through which the payment was submitted (web portal, mobile app, IVR, mail, in-person, API, batch import). [ENUM-REF-CANDIDATE: web_portal|mobile_app|ivr|mail|in_person|api|batch_import — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Check number for payments made by paper check. Used for reconciliation and tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Detailed reason for payment failure if status is failed. Includes processor error codes and messages.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateway rdf:type rdf:Property ;
    rdfs:label 'Gateway' ;
    rdfs:comment 'Name of the payment gateway or processor used to handle the transaction (e.g., Stripe, Authorize.Net, PayPal, Adyen).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the payment gateway or processor. Used for reconciliation and dispute resolution.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date when the payment was posted to the general ledger in the financial system. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAutopay rdf:type rdf:Property ;
    rdfs:label 'Is Autopay' ;
    rdfs:comment 'Indicates whether this payment was processed automatically through a recurring payment or autopay setup. True if autopay, false if manual.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Indicates whether this payment is currently under dispute or chargeback. True if disputed, false otherwise.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodType rdf:type rdf:Property ;
    rdfs:label 'Method Type' ;
    rdfs:comment 'The type of payment instrument used for the transaction. Indicates the financial mechanism (credit card, ACH, wire, check, etc.). [ENUM-REF-CANDIDATE: credit_card|debit_card|ach|wire_transfer|check|cash|paypal|direct_debit — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date when the payment transaction was initiated or received by the business. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Externally visible unique payment transaction number used for customer communication and reconciliation. Format: PAY-XXXXXXXX.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentSource rdf:type rdf:Property ;
    rdfs:label 'Payment Source' ;
    rdfs:comment 'Type of business relationship generating the payment (subscriber, advertiser, distributor, syndicator, licensee, other).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the payment transaction. Tracks progression from pending through cleared or failed states. [ENUM-REF-CANDIDATE: pending|processing|cleared|failed|reversed|cancelled|refunded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Timestamp' ;
    rdfs:comment 'The precise date and time when the payment transaction was processed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Amount refunded to the customer if payment status is refunded. May be partial or full refund.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundDate rdf:type rdf:Property ;
    rdfs:label 'Refund Date' ;
    rdfs:comment 'Date when the refund was processed and issued to the customer. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Reason for payment reversal if status is reversed. Includes chargeback reason codes and dispute details.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date when the payment funds were settled and cleared in the business bank account. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'The portion of the payment amount that remains unapplied and is held as credit on the account. Calculated as payment_amount minus applied_amount.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Payment Allocation Id' ;
    rdfs:comment 'Unique identifier for the payment allocation record. Primary key.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPaymentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Employee Id' ;
    rdfs:comment 'System user identifier of the person or automated process that created this allocation. Used for audit trails, accountability, and troubleshooting allocation errors. May be system account for automated allocations.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'The financial accounting period (YYYY-MM format) to which this allocation is posted. Determines which month/quarter/year the revenue and cash receipt are recognized. Used for period close, financial reporting, and revenue assurance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The monetary amount from the payment that is allocated to this specific invoice. For partial payments, this represents the portion applied to this invoice. For full settlements, this equals the invoice outstanding balance. Critical for accounts receivable aging and revenue assurance calculations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date when the payment allocation was executed and applied to the invoice. This date determines the accounting period for revenue recognition and accounts receivable aging. Critical for financial reporting and compliance with ASC 606.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'The business rule or algorithm used to determine this allocation. Manual indicates user-specified allocation; Automatic indicates system-applied based on aging rules; Prorated indicates proportional distribution across multiple invoices; FIFO (First In First Out) indicates oldest invoice paid first; LIFO (Last In First Out) indicates newest invoice paid first; Specific indicates customer-directed allocation to particular invoice.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Human-readable business identifier for the payment allocation record. Format: PA-YYYYMMDD-NNNN where YYYYMMDD is allocation date and NNNN is sequence number.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationSequence rdf:type rdf:Property ;
    rdfs:label 'Allocation Sequence' ;
    rdfs:comment 'Sequential order number for this allocation within the parent payment transaction. When a single payment is split across multiple invoices, this field indicates the application order. Used for FIFO/LIFO allocation logic and audit trails.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle status of the payment allocation. Pending indicates allocation is awaiting confirmation; Applied indicates allocation has been posted to accounts receivable; Reversed indicates allocation has been undone; Voided indicates allocation was cancelled before application; Disputed indicates allocation is under review; Reconciled indicates allocation has been verified and closed.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'Precise date and time when the payment allocation was processed in the billing system. Used for audit trails and transaction sequencing. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of the payment allocation method. Full Settlement indicates payment completely satisfies invoice balance; Partial Payment indicates payment covers portion of invoice; Advance Deposit indicates payment received before invoice generation; Unapplied Credit indicates payment not yet matched to specific invoice; Overpayment indicates payment exceeds invoice amount; Prepayment indicates payment for future services.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when this allocation was approved by authorized personnel. Null if no approval required or pending approval. Used for audit trails and compliance with financial controls. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:glDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Document Number' ;
    rdfs:comment 'The SAP S/4HANA general ledger document number generated when this allocation was posted to the financial system. Used for cross-system reconciliation and audit trails between billing and finance.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference Number' ;
    rdfs:comment 'Business identifier of the invoice receiving this allocation. Denormalized from invoice table for quick reference and reporting without joins. Typically matches invoice_number from the invoice product.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External reference number from the payment transaction, such as check number, wire transfer confirmation, credit card authorization code, or ACH trace number. Used for payment reconciliation and dispute resolution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date when this allocation was reversed or voided. Null if allocation is still active. Used for audit trails and accounts receivable reconciliation when allocations are corrected or disputed.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemAllocationReference rdf:type rdf:Property ;
    rdfs:label 'Source System Allocation Reference' ;
    rdfs:comment 'The unique identifier for this allocation in the source system (Zuora, Wide Orbit, or SAP). Used for cross-system reconciliation, data lineage tracking, and troubleshooting integration issues.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedBalance rdf:type rdf:Property ;
    rdfs:label 'Unapplied Balance' ;
    rdfs:comment 'Remaining payment amount not allocated to any invoice after this allocation. Represents credit balance available for future invoice matching. Critical for cash application and accounts receivable management.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeoffAmount rdf:type rdf:Property ;
    rdfs:label 'Writeoff Amount' ;
    rdfs:comment 'Portion of the invoice balance written off as uncollectible at the time of this allocation. Used when accepting partial payment as final settlement. Impacts bad debt reserves and revenue recognition adjustments.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountNumberLastFour rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number Last Four' ;
    rdfs:comment 'The last four digits of the bank account number. Used for customer identification without exposing full account details. Applicable for ACH, SEPA, and wire transfer methods.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'The routing number for ACH or wire transfer payment methods. Stored in masked or tokenized format per PCI DSS requirements. Used for direct debit and electronic funds transfer.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardBrand rdf:type rdf:Property ;
    rdfs:label 'Card Brand' ;
    rdfs:comment 'The brand or network of the payment card (e.g., Visa, Mastercard, American Express). Applicable only when payment method type is credit or debit card. [ENUM-REF-CANDIDATE: visa|mastercard|amex|discover|jcb|diners_club|unionpay — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'The name of the individual or entity as it appears on the payment card. Used for billing verification and fraud prevention.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivated Timestamp' ;
    rdfs:comment 'The date and time when this payment method was deactivated or closed. Null if the payment method is still active. Used for lifecycle tracking and retention analysis.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'The reason why the payment method was deactivated. Used for churn analysis and process improvement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryAlertDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Alert Date' ;
    rdfs:comment 'The date when the system should trigger an alert to the subscriber about upcoming payment method expiration. Typically set 30-60 days before card expiry to enable proactive customer outreach and reduce involuntary churn.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryMonth rdf:type rdf:Property ;
    rdfs:label 'Expiry Month' ;
    rdfs:comment 'The month (1-12) when the payment card expires. Used to validate card validity and trigger expiry alerts for subscription renewals.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryYear rdf:type rdf:Property ;
    rdfs:label 'Expiry Year' ;
    rdfs:comment 'The four-digit year when the payment card expires. Used in conjunction with expiry_month to determine card validity and schedule proactive customer outreach.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failedTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Failed Transaction Count' ;
    rdfs:comment 'The cumulative count of failed transaction attempts using this payment method. Used to identify problematic payment methods and trigger dunning workflows.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gatewayCustomerProfileReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Customer Profile Reference' ;
    rdfs:comment 'The unique customer profile identifier in the payment gateway system. Used to link this payment method to the gateway\'s customer vault for secure transaction processing.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayPaymentMethodReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Payment Method Reference' ;
    rdfs:comment 'The unique payment method identifier assigned by the payment gateway. Used for transaction processing and reconciliation with gateway records.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Boolean flag indicating whether this is the default payment method for the subscriber. Used to determine which payment method to charge for recurring subscriptions and invoices.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastFailureDate rdf:type rdf:Property ;
    rdfs:label 'Last Failure Date' ;
    rdfs:comment 'The date of the most recent failed transaction attempt. Used in conjunction with failed_transaction_count to manage retry logic and customer communication.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastFailureReason rdf:type rdf:Property ;
    rdfs:label 'Last Failure Reason' ;
    rdfs:comment 'The reason code or message returned by the payment gateway for the most recent failed transaction. Used for troubleshooting and customer support.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Last Four Digits' ;
    rdfs:comment 'The last four digits of the payment card number. Used for customer identification and verification without exposing full card details. PCI DSS permits storage of last four digits.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Amount' ;
    rdfs:comment 'The amount of the most recent successful transaction in the subscriber\'s billing currency. Used for fraud detection and transaction pattern analysis.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'The date of the most recent successful transaction using this payment method. Used for payment method activity tracking and dormancy analysis.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandateReference rdf:type rdf:Property ;
    rdfs:label 'Mandate Reference' ;
    rdfs:comment 'The unique reference identifier for the direct debit mandate authorizing recurring payments. Required for SEPA Direct Debit and other regulated direct debit schemes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandateSignedDate rdf:type rdf:Property ;
    rdfs:label 'Mandate Signed Date' ;
    rdfs:comment 'The date when the customer signed the direct debit mandate. Required for regulatory compliance and dispute resolution in direct debit transactions.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentGateway rdf:type rdf:Property ;
    rdfs:label 'Payment Gateway' ;
    rdfs:comment 'The payment gateway or processor used to tokenize and process transactions for this payment method (e.g., Stripe, Adyen, Braintree, Authorize.Net). Used for routing transactions and reconciliation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Method Status' ;
    rdfs:comment 'The current lifecycle status of the payment method. Determines whether the payment method can be used for new transactions. Inactive or expired methods require customer action to reactivate.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'The type of payment instrument registered. Indicates the payment mechanism used for billing transactions. [ENUM-REF-CANDIDATE: credit_card|debit_card|ach|sepa|wire_transfer|paypal|apple_pay — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:token rdf:type rdf:Property ;
    rdfs:label 'Token' ;
    rdfs:comment 'PCI DSS-compliant tokenized representation of the payment instrument. Never stores raw Primary Account Number (PAN). Used for secure payment processing without exposing sensitive cardholder data.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date when the payment method was last verified. Used to track verification currency and trigger re-verification workflows.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Expected Settlement Date' ;
    rdfs:comment 'Projected date when the refund is expected to be settled and funds returned to the subscriber. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fee rdf:type rdf:Property ;
    rdfs:label 'Fee' ;
    rdfs:comment 'Any processing fee deducted from the refund amount, if applicable (e.g., payment gateway fees, administrative charges).' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isChargebackRelated rdf:type rdf:Property ;
    rdfs:label 'Is Chargeback Related' ;
    rdfs:comment 'Boolean flag indicating whether this refund is related to a payment chargeback or dispute initiated by the subscriber through their financial institution.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialRefund rdf:type rdf:Property ;
    rdfs:label 'Is Partial Refund' ;
    rdfs:comment 'Boolean flag indicating whether this is a partial refund (true) or a full refund (false) of the original payment amount.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Net Refund Amount' ;
    rdfs:comment 'Net monetary amount actually returned to the subscriber or account after deducting any processing fees (refund_amount - refund_fee).' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingDate rdf:type rdf:Property ;
    rdfs:label 'Processing Date' ;
    rdfs:comment 'Date when the refund was submitted for payment processing. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'The method by which the refund is being returned to the subscriber: back to original payment instrument, check, account credit, wire transfer, or other mechanism. [ENUM-REF-CANDIDATE: original_payment_method|credit_card|bank_transfer|check|account_credit|wire_transfer|paypal|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Number' ;
    rdfs:comment 'Externally-visible business identifier for the refund, used in customer communications and financial reconciliation. Format: RFD-XXXXXXXXXX.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Current lifecycle status of the refund transaction in the processing workflow. [ENUM-REF-CANDIDATE: pending_approval|approved|processing|completed|failed|cancelled|reversed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundType rdf:type rdf:Property ;
    rdfs:label 'Refund Type' ;
    rdfs:comment 'Classification of the refund based on the revenue stream being reversed: subscription billing, advertising billing, carriage fee, syndication license fee, overpayment, or other.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date when the refund was originally requested by the subscriber or initiated by the system. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wideorbitRefundReference rdf:type rdf:Property ;
    rdfs:label 'Wideorbit Refund Reference' ;
    rdfs:comment 'External identifier from Wide Orbit traffic and billing system for refunds originating from advertising revenue, used for system integration and reconciliation.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zuoraRefundReference rdf:type rdf:Property ;
    rdfs:label 'Zuora Refund Reference' ;
    rdfs:comment 'External identifier from Zuora subscription billing system for refunds originating from subscription revenue, used for system integration and reconciliation.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Schedule Id' ;
    rdfs:comment 'Unique identifier for the revenue recognition schedule entry. Primary key for ASC 606 revenue recognition tracking.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Distribution Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.distribution_agreement. Business justification: Multi-year carriage fee agreements require revenue recognition schedules for upfront payments or minimum guarantees. Links recognition schedules to distribution agreements for carriage fee amortizatio' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionAgreement .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Business justification for any modification to the original recognition schedule (e.g., \'Contract amendment - extended term by 6 months\', \'Makegood issued for underdelivered GRPs\', \'Early termination - subscriber cancellation\', \'Price adjustment - volume discount applied\'). Required for audit trail and SOX compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'High-level business division or operating segment responsible for the revenue (e.g., Streaming Services, Linear Broadcasting, Content Licensing, Advertising Sales). Used for executive reporting and segment disclosure.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the revenue-generating contract. Determines recognition method and accounting treatment. Subscription (SVOD recurring), Syndication License (content resale), Upfront Ad Deal (advance advertising commitment), Carriage Agreement (MVPD distribution fee), Transactional VOD (TVOD pay-per-view), Sponsorship (branded content deal).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeRecognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Recognized Amount' ;
    rdfs:comment 'Total revenue recognized to date from contract inception through the current reporting period. Increases each period as revenue is earned. Used for deferred revenue balance calculation and revenue assurance reconciliation.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentPeriodRecognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Current Period Recognized Amount' ;
    rdfs:comment 'Revenue amount recognized in the current accounting period (month or quarter). Posted to the SAP revenue account. May differ from monthly recognized amount for usage-based or milestone-based contracts.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredRevenueBalance rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Balance' ;
    rdfs:comment 'Remaining unearned revenue balance on the contract. Calculated as total contract value minus cumulative recognized amount. Represents the liability on the balance sheet under ASC 606. Decreases as revenue is recognized over time.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Last Recognition Date' ;
    rdfs:comment 'Date of the most recent revenue recognition posting. Used to track recognition progress and identify schedules requiring current-period processing.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monthlyRecognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Recognized Amount' ;
    rdfs:comment 'Standard monthly revenue amount to be recognized under straight-line method. Calculated as total contract value divided by recognition period months. May vary for usage-based or milestone-based contracts.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Next Recognition Date' ;
    rdfs:comment 'Scheduled date for the next revenue recognition posting. Used by automated revenue recognition jobs to process monthly or quarterly recognition batches.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceObligationDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Description' ;
    rdfs:comment 'Narrative description of the performance obligation under ASC 606 (e.g., \'Provide streaming access to content library for 12 months\', \'Deliver 52 episodes of syndicated series\', \'Deliver 1000 GRPs in Q4 upfront commitment\'). Documents the basis for revenue recognition timing.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Recognition End Date' ;
    rdfs:comment 'Date when revenue recognition is scheduled to complete. Corresponds to the contract expiration date or end of the performance obligation period. Null for evergreen contracts until termination notice.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'ASC 606 revenue recognition method applied to this contract. Straight-Line (equal monthly recognition for subscriptions), Milestone-Based (triggered by delivery events for syndication), Usage-Based (actual consumption for AVOD/TVOD), Proportional Performance (percentage-of-completion for production contracts), Point-in-Time (immediate recognition for transactional sales).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Recognition Period Months' ;
    rdfs:comment 'Total number of months over which revenue will be recognized. Calculated from recognition start date to end date. Used for straight-line recognition calculations and forecasting.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recognitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Start Date' ;
    rdfs:comment 'Date when revenue recognition begins. Corresponds to the contract effective date or service commencement date under ASC 606. Marks the beginning of the performance obligation period.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current lifecycle state of the revenue recognition schedule. Scheduled (future start date), In Progress (actively recognizing), Completed (fully recognized), Suspended (temporarily paused), Terminated (contract cancelled early), Adjusted (modified due to contract amendment or makegood).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDeferredRevenueAccountCode rdf:type rdf:Property ;
    rdfs:label 'Sap Deferred Revenue Account Code' ;
    rdfs:comment 'General Ledger (GL) liability account code in SAP S/4HANA where deferred revenue balance is maintained. Decreases as revenue is recognized and transferred to the revenue account.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapRevenueAccountCode rdf:type rdf:Property ;
    rdfs:label 'Sap Revenue Account Code' ;
    rdfs:comment 'General Ledger (GL) account code in SAP S/4HANA where recognized revenue is posted. Maps to the appropriate revenue account based on contract type and business unit (e.g., subscription revenue, advertising revenue, licensing revenue).' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemContractReference rdf:type rdf:Property ;
    rdfs:label 'Source System Contract Reference' ;
    rdfs:comment 'Native contract identifier in the source system (e.g., Zuora subscription ID, Wide Orbit order number, Rightsline license agreement ID). Used for data lineage and reconciliation back to operational systems.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Run Approved By User Employee Id' ;
    rdfs:comment 'Identifier of the user who approved this billing run for distribution. Null if approval not required or run not yet approved.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:runEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Run Employee Id' ;
    rdfs:comment 'Identifier of the system user or automated process that triggered this billing run. Used for audit trail and accountability.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountsWithErrors rdf:type rdf:Property ;
    rdfs:label 'Accounts With Errors' ;
    rdfs:comment 'Count of customer accounts that failed to process successfully during this billing run. Used to identify accounts requiring manual intervention.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when the billing run execution began. Used to measure processing delays and operational performance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this billing run requires management approval before invoice distribution. True for high-value runs, correction runs, or runs with significant adjustments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingDate rdf:type rdf:Property ;
    rdfs:label 'Billing Date' ;
    rdfs:comment 'The effective billing date applied to all invoices generated in this run. Determines invoice date, due date calculation, and revenue recognition period.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time when the billing run finished execution, whether successfully or with errors. Null for runs still in progress or suspended.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distributionCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Distribution Completion Timestamp' ;
    rdfs:comment 'Date and time when invoice distribution to customers completed. Null for runs still distributing or not yet started.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distributionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Distribution Start Timestamp' ;
    rdfs:comment 'Date and time when invoice distribution to customers began. Used to track delivery SLA and customer communication timing.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:errorCount rdf:type rdf:Property ;
    rdfs:label 'Error Count' ;
    rdfs:comment 'Total number of errors encountered during billing run execution. Includes account processing failures, invoice generation errors, and system exceptions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceDistributionStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Distribution Status' ;
    rdfs:comment 'Status of invoice delivery to customers. Pending runs await distribution; in-progress runs are actively sending; completed runs finished delivery; failed runs encountered distribution errors; cancelled runs were stopped.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Processing Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from actual start to completion of the billing run. Used for performance monitoring and capacity planning.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of times this billing run has been retried after failure. Used to identify chronic processing issues and trigger escalation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'Primary revenue classification for this billing run. Subscription runs bill SVOD/linear subscribers; advertising runs bill CPM/GRP campaigns; carriage runs bill MVPD distribution fees; syndication runs bill content licensing; transactional runs bill TVOD purchases.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business-friendly identifier for the billing run, typically formatted as cycle-sequence (e.g., 2024-01-R001). Used for operational tracking and reporting.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle state of the billing run. Scheduled runs are queued; in-progress runs are actively generating invoices; completed runs finished successfully; failed runs encountered errors; cancelled runs were aborted; suspended runs are paused pending resolution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the billing run execution. Regular runs follow standard cycle schedules; off-cycle runs address mid-period changes; final runs close out terminated accounts; correction runs fix prior errors; makegood runs issue compensatory credits; adjustment runs apply manual corrections.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPostingBatchReference rdf:type rdf:Property ;
    rdfs:label 'Sap Posting Batch Reference' ;
    rdfs:comment 'SAP S/4HANA batch identifier for financial posting of billing run results. Links billing transactions to general ledger entries.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time when the billing run was scheduled to begin execution. Used for operational planning and SLA tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalAccountsProcessed rdf:type rdf:Property ;
    rdfs:label 'Total Accounts Processed' ;
    rdfs:comment 'Total count of customer accounts included in this billing run execution. Used for operational monitoring and reconciliation.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAmountBilled rdf:type rdf:Property ;
    rdfs:label 'Total Amount Billed' ;
    rdfs:comment 'Sum of all invoice totals generated in this billing run, representing gross revenue before payments. Used for revenue assurance and financial reconciliation.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoiceLinesGenerated rdf:type rdf:Property ;
    rdfs:label 'Total Invoice Lines Generated' ;
    rdfs:comment 'Total count of invoice line items created across all invoices in this billing run. Used for detailed processing metrics and performance analysis.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalInvoicesGenerated rdf:type rdf:Property ;
    rdfs:label 'Total Invoices Generated' ;
    rdfs:comment 'Total count of invoices successfully generated during this billing run. May differ from accounts processed if some accounts had zero charges or errors.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warningCount rdf:type rdf:Property ;
    rdfs:label 'Warning Count' ;
    rdfs:comment 'Total number of warnings generated during billing run execution. Warnings indicate potential issues that did not prevent invoice generation but require review.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wideOrbitBatchReference rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Batch Reference' ;
    rdfs:comment 'External identifier from Wide Orbit traffic and billing system for advertising billing runs. Used for ad sales invoice reconciliation.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zuoraBillingRunReference rdf:type rdf:Property ;
    rdfs:label 'Zuora Billing Run Reference' ;
    rdfs:comment 'External identifier from Zuora subscription billing system for this billing run. Used for cross-system reconciliation and audit trail.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Subscription Invoice Id' ;
    rdfs:comment 'Unique identifier for the subscription invoice record. Primary key for this entity.' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zuoraInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Zuora Invoice Id' ;
    rdfs:comment 'Native invoice identifier from Zuora subscription billing system. Used for system reconciliation and API integration.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:autoPayEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled' ;
    rdfs:comment 'Indicates whether automatic payment processing is enabled for this invoice. True means payment will be attempted automatically on due date.' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceDue rdf:type rdf:Property ;
    rdfs:label 'Balance Due' ;
    rdfs:comment 'Outstanding amount remaining to be paid on this invoice. Calculated as total_amount minus amount_paid.' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:churnRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Flag' ;
    rdfs:comment 'Indicates whether the subscriber was flagged as high churn risk at the time of invoice generation. Used for retention campaign targeting and revenue forecasting.' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Paid Timestamp' ;
    rdfs:comment 'Date and time when the invoice was fully paid by the subscriber. Null if invoice is unpaid or partially paid.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'Date and time when the invoice was posted (finalized and made available to subscriber). Marks transition from draft to official invoice.' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promotionalDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Discount Amount' ;
    rdfs:comment 'Total discount amount applied from promotional campaigns, coupon codes, or special offers. Reduces the net amount due.' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalDiscountCode rdf:type rdf:Property ;
    rdfs:label 'Promotional Discount Code' ;
    rdfs:comment 'Coupon or promotion code applied to this invoice. Used for marketing campaign tracking and discount attribution analysis.' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationAmount rdf:type rdf:Property ;
    rdfs:label 'Proration Amount' ;
    rdfs:comment 'Adjustment amount for partial billing periods due to mid-cycle subscription changes, upgrades, downgrades, or cancellations. Can be positive or negative.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Indicates whether this invoice represents an automatic renewal, manual renewal, trial-to-paid conversion, plan upgrade, or plan downgrade.' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Status' ;
    rdfs:comment 'Current status of revenue recognition for this invoice under ASC 606 accounting standards. Tracks whether revenue has been recognized in financial statements.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionPlanName rdf:type rdf:Property ;
    rdfs:label 'Subscription Plan Name' ;
    rdfs:comment 'Name of the subscription plan being billed (e.g., Premium Monthly, Basic Annual, Sports Bundle). Identifies the service tier and feature set.' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionType rdf:type rdf:Property ;
    rdfs:label 'Subscription Type' ;
    rdfs:comment 'Classification of subscription model: SVOD (Subscription Video On Demand), AVOD (Advertising-Supported Video On Demand), TVOD (Transactional Video On Demand), or bundled offering.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Final net amount due from subscriber after all charges, prorations, credits, discounts, and taxes. This is the amount the subscriber must pay.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trialPeriodCredit rdf:type rdf:Property ;
    rdfs:label 'Trial Period Credit' ;
    rdfs:comment 'Credit amount applied for free trial period. Typically offsets the full subscription charge during trial, resulting in zero net amount due.' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:syndicationLicenseFeeId rdf:type rdf:Property ;
    rdfs:label 'Syndication License Fee Id' ;
    rdfs:comment 'Unique identifier for the syndication license fee billing record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SyndicationLicenseFee .

ind:acquisitionDealId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Deal Id' ;
    rdfs:comment 'Foreign key linking to partner.acquisition_deal. Business justification: Syndication fees are structured within acquisition deals for deal-level revenue rollup, minimum guarantee recoupment tracking, and overage royalty calculation. Links individual fee installments to par' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcquisitionDeal .

ind:satelliteTransponderId rdf:type rdf:Property ;
    rdfs:label 'Satellite Transponder Id' ;
    rdfs:comment 'Foreign key linking to technology.satellite_transponder. Business justification: Syndication distribution fees tied to specific transponders enable bandwidth cost allocation, territory coverage verification, signal quality SLA tracking, and distribution cost reconciliation in cont' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SatelliteTransponder .

ind:syndicationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Syndication Agreement Id' ;
    rdfs:comment 'Reference to the Rightsline contract governing this syndication license fee.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SyndicationAgreement .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date the fee dispute was resolved (null if unresolved or not disputed).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Total syndication license fee amount due from the licensee for this billing period or contract term.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Installment Due Date' ;
    rdfs:comment 'Due date for this specific installment or lump-sum payment.' ;
    rdfs:domain ind:SyndicationLicenseFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseEndDate rdf:type rdf:Property ;
    rdfs:label 'License End Date' ;
    rdfs:comment 'Expiration date of the syndication license window.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseStartDate rdf:type rdf:Property ;
    rdfs:label 'License Start Date' ;
    rdfs:comment 'Effective start date of the syndication license window.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseTerritory rdf:type rdf:Property ;
    rdfs:label 'License Territory' ;
    rdfs:comment 'Geographic territory covered by the syndication license (country, region, or market designation).' ;
    rdfs:domain ind:SyndicationLicenseFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseWindowType rdf:type rdf:Property ;
    rdfs:label 'License Window Type' ;
    rdfs:comment 'Type of syndication license window defining the distribution rights period and exclusivity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseeName rdf:type rdf:Property ;
    rdfs:label 'Licensee Name' ;
    rdfs:comment 'Legal name of the content licensee organization.' ;
    rdfs:domain ind:SyndicationLicenseFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'Net payment amount after withholding tax deduction (fee_amount minus withholding_tax_amount).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Actual date payment was received from the licensee (null if unpaid).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentScheduleType rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule Type' ;
    rdfs:comment 'Type of payment schedule structure for the syndication license fee.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalInstallments rdf:type rdf:Property ;
    rdfs:label 'Total Installments' ;
    rdfs:comment 'Total number of installments in the payment schedule (null for lump-sum payments).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Calculated withholding tax amount deducted from the fee payment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'Withholding tax rate applied to the fee amount based on licensee jurisdiction and tax treaty provisions (expressed as decimal, e.g., 0.1500 for 15%).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRecordId rdf:type rdf:Property ;
    rdfs:label 'Tax Record Id' ;
    rdfs:comment 'Unique identifier for the tax calculation and reporting record. Primary key for the tax_record product.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerTaxClassification rdf:type rdf:Property ;
    rdfs:label 'Customer Tax Classification' ;
    rdfs:comment 'Tax classification of the customer for determining applicable tax treatment. Business (B2B), Individual (B2C), Government, Non-Profit, Exempt Organization.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Tax Number' ;
    rdfs:comment 'The customer\'s tax identification number (TIN, VAT number, GST number, EIN, etc.) used for tax reporting and validation. Format varies by jurisdiction.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nexusCountry rdf:type rdf:Property ;
    rdfs:label 'Nexus Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where tax nexus is established (e.g., USA, GBR, FRA, CAN).' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nexusStateProvince rdf:type rdf:Property ;
    rdfs:label 'Nexus State Province' ;
    rdfs:comment 'State or province where the business has established tax nexus (physical or economic presence triggering tax obligation). Critical for US sales tax and Canadian GST/PST compliance.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Date' ;
    rdfs:comment 'Date when the tax amount was remitted (paid) to the tax authority. Null if remittance_status is pending or disputed.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remittanceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Reference Number' ;
    rdfs:comment 'Payment reference or confirmation number from the tax authority acknowledging receipt of the tax remittance. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceStatus rdf:type rdf:Property ;
    rdfs:label 'Remittance Status' ;
    rdfs:comment 'Current status of tax payment to the tax authority. Pending (not yet paid), Remitted (paid in full), Partially Remitted (partial payment made), Disputed (under review or appeal), Waived (exempted or forgiven).' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reverseChargeFlag rdf:type rdf:Property ;
    rdfs:label 'Reverse Charge Flag' ;
    rdfs:comment 'Indicates whether the reverse charge mechanism applies (True = customer is responsible for self-assessing and remitting VAT/GST, False = supplier charges and remits tax). Common in EU cross-border B2B transactions.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemTaxReference rdf:type rdf:Property ;
    rdfs:label 'Source System Tax Reference' ;
    rdfs:comment 'The unique identifier for this tax record in the source operational system. Enables traceability and reconciliation back to the originating system.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthority rdf:type rdf:Property ;
    rdfs:label 'Tax Authority' ;
    rdfs:comment 'Name of the governmental tax authority responsible for collection and enforcement (e.g., IRS, HMRC, California Department of Tax and Fee Administration, Direction Générale des Finances Publiques).' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Calculation Method' ;
    rdfs:comment 'Method used to calculate the tax amount. Automated (system-calculated), Manual (finance team entry), Third-Party Service (Avalara, Vertex, TaxJar), Override (manual adjustment to automated calculation).' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Business categorization of the taxable item or service (e.g., Subscription Services, Advertising Services, Content Licensing, Equipment Rental, Digital Downloads). Used for tax rate determination and reporting segmentation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Flag' ;
    rdfs:comment 'Indicates whether a tax exemption was applied to this transaction (True = exemption applied, False = no exemption).' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptionReason rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Reason' ;
    rdfs:comment 'Business reason or regulatory basis for the tax exemption (e.g., Non-profit organization, Government entity, Educational institution, Resale certificate, Export transaction).' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxFilingDueDate rdf:type rdf:Property ;
    rdfs:label 'Tax Filing Due Date' ;
    rdfs:comment 'The statutory due date for filing the tax return that includes this transaction, based on the tax jurisdiction and filing period.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxFilingPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Filing Period' ;
    rdfs:comment 'The tax reporting period to which this transaction applies, formatted as YYYY-Q# for quarterly or YYYY-M## for monthly (e.g., 2024-Q1, 2024-M03). Aligns with jurisdiction-specific filing schedules.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code identifying the tax jurisdiction (country, state, province, county, or municipality) where the tax obligation arises. Format: ISO country code optionally followed by subdivision code (e.g., US-CA, GB, FR-75).' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Name' ;
    rdfs:comment 'Full name of the tax jurisdiction (e.g., California, United Kingdom, Paris) for human-readable reporting and compliance documentation.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLineNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Line Number' ;
    rdfs:comment 'Sequential line number for this tax record within the parent invoice, supporting multiple tax jurisdictions or tax types per invoice.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxPointDate rdf:type rdf:Property ;
    rdfs:label 'Tax Point Date' ;
    rdfs:comment 'The date when the tax liability arises according to tax regulations (also known as time of supply). May differ from transaction_date based on jurisdiction-specific rules for services, advance payments, or continuous supplies.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Tax rate applied to the taxable amount, expressed as a decimal (e.g., 0.0825 for 8.25%). Supports precision to six decimal places for complex multi-jurisdictional calculations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Code' ;
    rdfs:comment 'Internal or regulatory code defining the specific tax treatment applied (e.g., standard rate, reduced rate, zero-rated, exempt, out-of-scope). Maps to jurisdiction-specific tax rules.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Type of tax applied to the transaction. Sales Tax (US state/local), VAT (Value-Added Tax, EU/international), GST (Goods and Services Tax), Withholding Tax (international syndication/licensing), Excise Tax (specific content types), Use Tax (cross-border digital services).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Amount' ;
    rdfs:comment 'The portion of the invoice amount subject to taxation in this jurisdiction, after applying exemptions and exclusions. Denominated in the invoice currency.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thirdPartyTaxService rdf:type rdf:Property ;
    rdfs:label 'Third Party Tax Service' ;
    rdfs:comment 'Name of the external tax calculation service provider if third-party method was used (e.g., Avalara AvaTax, Vertex Cloud, TaxJar, Thomson Reuters ONESOURCE).' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The date of the underlying billing transaction that triggered the tax calculation. Used to determine applicable tax rates and rules in effect at the time of transaction.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agingBucketAtWriteOff rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket At Write Off' ;
    rdfs:comment 'Accounts receivable aging category of the invoice at the time of write-off (e.g., current, 30 days, 60 days, 90 days, 120+ days).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionReferralDate rdf:type rdf:Property ;
    rdfs:label 'Collection Referral Date' ;
    rdfs:comment 'The date on which the debt was referred to the external collection agency.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysOutstandingAtWriteOff rdf:type rdf:Property ;
    rdfs:label 'Days Outstanding At Write Off' ;
    rdfs:comment 'Number of days the invoice was outstanding (from invoice date to write-off date) at the time the write-off decision was made.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ebitdaImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Ebitda Impact Flag' ;
    rdfs:comment 'Indicates whether this write-off has a material impact on EBITDA reporting for the period (True/False).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (e.g., 2024-Q1, 2024-01) in which the write-off was recorded for financial reporting purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year in which the write-off was recorded.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Amount' ;
    rdfs:comment 'The total amount originally invoiced before any payments, adjustments, or write-offs were applied.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalanceAtWriteOff rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance At Write Off' ;
    rdfs:comment 'The remaining unpaid balance on the invoice at the time the write-off decision was made.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Recovery Gl Account Code' ;
    rdfs:comment 'SAP S/4HANA general ledger account code to which any recovered amount is posted (typically a bad debt recovery income account).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this write-off has been reversed due to subsequent payment or correction (True/False).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The date on which the bad debt write-off decision was executed and recorded in the financial system.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffNumber rdf:type rdf:Property ;
    rdfs:label 'Write Off Number' ;
    rdfs:comment 'Business-facing unique identifier for the write-off transaction, used for tracking and audit purposes.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessibilityObligationId rdf:type rdf:Property ;
    rdfs:label 'Accessibility Obligation Id' ;
    rdfs:comment 'Unique identifier for the accessibility compliance obligation record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessibilityObligation .

ind:responsibleContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FCC accessibility obligations (CVAA, closed captioning, video description) require named employee owner for compliance tracking and regulatory correspondence. Contact email should reference employee r' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableRegulation rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulation' ;
    rdfs:comment 'Primary regulatory framework governing this obligation: CVAA (Twenty-First Century Communications and Video Accessibility Act), ADA (Americans with Disabilities Act), Ofcom Access Code, EU Audiovisual Media Services Directive, WCAG 2.1 (Web Content Accessibility Guidelines), or ATSC A/53 (Advanced Television Systems Committee standard for closed captioning).' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'Date by which the organization must achieve full compliance with this accessibility obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Percentage' ;
    rdfs:comment 'Percentage of content or platform features currently meeting this accessibility obligation (0.00 to 100.00), used for tracking progress toward full compliance.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current state of the organization\'s compliance with this obligation: compliant (fully meeting requirements), non-compliant (failing to meet requirements), in progress (actively working toward compliance), not started (no action taken), exempt (obligation does not apply), or waiver granted (temporary or permanent exemption approved by regulator).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Content Type Applicability' ;
    rdfs:comment 'Types of content to which this obligation applies (e.g., all programming, news and emergency information, pre-recorded entertainment, live events, user-generated content exclusions).' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedComplianceCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Compliance Cost' ;
    rdfs:comment 'Estimated total cost in USD to achieve full compliance with this obligation, including technology implementation, content remediation, training, and ongoing operational costs.' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Explanation of why this obligation does not apply to the organization or why a waiver was granted (e.g., content category exemption, undue burden waiver, technical infeasibility).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Geographic Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the jurisdiction where this obligation is enforceable (e.g., USA for FCC/CVAA, GBR for Ofcom, DEU for German regulations).' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'Date when the organization last conducted an internal review or audit of compliance with this accessibility obligation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Review Date' ;
    rdfs:comment 'Scheduled date for the next internal review or audit of compliance with this accessibility obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Business identifier code for the accessibility obligation, used for external reference and reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'Human-readable name of the accessibility obligation (e.g., Closed Captioning for Linear Broadcast, Audio Description for VOD Content).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Category of accessibility requirement: closed captioning (CC), audio description (AD), video description, emergency alert accessibility, online video player accessibility, or keyboard navigation compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyForNonCompliance rdf:type rdf:Property ;
    rdfs:label 'Penalty For Non Compliance' ;
    rdfs:comment 'Description of regulatory penalties, fines, or sanctions that may be imposed for failure to meet this obligation (e.g., FCC forfeiture up to $100,000 per violation, Ofcom statutory sanctions, license suspension risk).' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationSection rdf:type rdf:Property ;
    rdfs:label 'Regulation Section' ;
    rdfs:comment 'Specific section, article, or clause of the regulation that mandates this obligation (e.g., 47 CFR 79.1, WCAG 2.1 Success Criterion 1.2.2).' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Team' ;
    rdfs:comment 'Name of the internal team, department, or business unit responsible for ensuring compliance with this obligation (e.g., Broadcast Operations, Digital Product, Legal Compliance, Content Production).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'Distribution platform scope to which this obligation applies: linear broadcast, VOD (Video On Demand), SVOD (Subscription Video On Demand), AVOD (Advertising-Supported Video On Demand), TVOD (Transactional Video On Demand), OTT (Over-The-Top), FAST (Free Ad-Supported Streaming Television), MVPD (Multichannel Video Programming Distributor), vMVPD (Virtual Multichannel Video Programming Distributor), or all platforms. [ENUM-REF-CANDIDATE: linear|vod|svod|avod|tvod|ott|fast|mvpd|vmvpd|all_platforms — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Target Compliance Percentage' ;
    rdfs:comment 'Required percentage of content or platform features that must meet this accessibility obligation to achieve regulatory compliance (typically 100.00, but may be lower for phased implementation schedules).' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalStandard rdf:type rdf:Property ;
    rdfs:label 'Technical Standard' ;
    rdfs:comment 'Technical standard or specification that defines how this accessibility feature must be implemented (e.g., CEA-608 for closed captioning, TTML for web captions, WCAG 2.1 AA for player accessibility).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiration Date' ;
    rdfs:comment 'Date when a granted waiver or exemption expires and the obligation becomes enforceable again (null for permanent exemptions).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adCreativeId rdf:type rdf:Property ;
    rdfs:label 'Ad Creative Id' ;
    rdfs:comment 'Identifier of the advertising creative asset submitted for clearance review.' ;
    rdfs:domain ind:AdStandardsClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IsciCreative .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Advertising standards clearance reviews require tracking which employee performed the review for accountability and audit trail. Reviewer contact data should reference employee record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alcoholTobaccoFlag rdf:type rdf:Property ;
    rdfs:label 'Alcohol Tobacco Flag' ;
    rdfs:comment 'Indicates whether the ad creative promotes alcohol or tobacco products, subject to strict regulatory restrictions and daypart limitations.' ;
    rdfs:domain ind:AdStandardsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether the advertiser filed an appeal against a rejection or required-edits decision.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Result of the appeal process if an appeal was filed against the original clearance decision.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childrenDirectedFlag rdf:type rdf:Property ;
    rdfs:label 'Children Directed Flag' ;
    rdfs:comment 'Indicates whether the ad creative is directed at children under 13, triggering stricter COPPA and CARU compliance requirements.' ;
    rdfs:domain ind:AdStandardsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Clearance Certificate Number' ;
    rdfs:comment 'Unique certificate or reference number issued upon successful clearance, used for audit trail and affidavit verification.' ;
    rdfs:domain ind:AdStandardsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Date' ;
    rdfs:comment 'Date on which the standards clearance decision was finalized and communicated to the advertiser.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Expiration Date' ;
    rdfs:comment 'Date on which the clearance approval expires, requiring re-submission if the ad is to air beyond this date.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceType rdf:type rdf:Property ;
    rdfs:label 'Clearance Type' ;
    rdfs:comment 'Type of clearance review process applied to the ad creative, indicating timing and depth of review.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialServicesFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Services Flag' ;
    rdfs:comment 'Indicates whether the ad creative promotes financial services or products, requiring compliance with truth-in-lending and consumer protection regulations.' ;
    rdfs:domain ind:AdStandardsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:politicalCandidateName rdf:type rdf:Property ;
    rdfs:label 'Political Candidate Name' ;
    rdfs:comment 'Name of the political candidate featured in or sponsoring the ad, required for FCC political advertising disclosure.' ;
    rdfs:domain ind:AdStandardsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:politicalOfficeSought rdf:type rdf:Property ;
    rdfs:label 'Political Office Sought' ;
    rdfs:comment 'Political office being sought by the candidate in the political ad, required for FCC disclosure and public inspection file.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionDrugFlag rdf:type rdf:Property ;
    rdfs:label 'Prescription Drug Flag' ;
    rdfs:comment 'Indicates whether the ad creative promotes prescription pharmaceutical products, requiring FDA compliance and specific disclosure language.' ;
    rdfs:domain ind:AdStandardsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionCategory rdf:type rdf:Property ;
    rdfs:label 'Rejection Category' ;
    rdfs:comment 'High-level category of the standards violation leading to rejection or required edits (e.g., misleading claims, inappropriate content, regulatory non-compliance, children\'s advertising violation).' ;
    rdfs:domain ind:AdStandardsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Review Outcome' ;
    rdfs:comment 'Final decision of the standards clearance review indicating whether the ad creative is approved for broadcast, requires modifications, or is rejected.' ;
    rdfs:domain ind:AdStandardsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'Date on which the standards review process officially began for the submitted ad creative.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardsBody rdf:type rdf:Property ;
    rdfs:label 'Standards Body' ;
    rdfs:comment 'Regulatory or self-regulatory organization conducting the clearance review (e.g., NAB, CARU, IAB, internal broadcast standards department).' ;
    rdfs:domain ind:AdStandardsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date on which the ad creative was submitted for standards clearance review.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:substantiationProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Substantiation Provided Flag' ;
    rdfs:comment 'Indicates whether the advertiser provided required substantiation documentation to support claims made in the ad creative.' ;
    rdfs:domain ind:AdStandardsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:substantiationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Substantiation Required Flag' ;
    rdfs:comment 'Indicates whether the ad creative makes claims requiring documented substantiation (e.g., scientific evidence, test results, endorsements).' ;
    rdfs:domain ind:AdStandardsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Intended demographic audience for the ad creative, critical for applying age-appropriate content standards and children\'s advertising rules.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Reference to the parent audit engagement or audit project during which this finding was identified.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:previousFindingAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Audit Finding Id' ;
    rdfs:comment 'Reference to the prior audit finding record if this is a recurrence, enabling tracking of repeat issues and corrective action effectiveness.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:remediationOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Remediation Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Audit findings require assigned employee for remediation tracking and accountability. Remediation owner text should reference employee record for workload management and performance evaluation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'The actual date on which the remediation action was completed and verified, resulting in closure of the finding.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedProcess rdf:type rdf:Property ;
    rdfs:label 'Affected Process' ;
    rdfs:comment 'The business process, operational area, or functional domain impacted by this finding (e.g., Content Acquisition and Licensing, Program Scheduling and Playout, Advertising Sales and Campaign Management, Rights and Royalties Management, Subscriber and Membership Management).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSystem rdf:type rdf:Property ;
    rdfs:label 'Affected System' ;
    rdfs:comment 'The operational system, application, or platform where the non-compliance or control deficiency was identified (e.g., Dalet Galaxy, Wide Orbit, SAP S/4HANA, Salesforce Media Cloud, Nielsen Media Research Platform, Ericsson MediaFirst, Adobe Experience Platform, Rightsline, Akamai CDN, Zuora).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit Period End Date' ;
    rdfs:comment 'The end date of the audit period or scope during which the condition leading to this finding occurred.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Audit Period Start Date' ;
    rdfs:comment 'The start date of the audit period or scope during which the condition leading to this finding occurred.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit engagement: internal (conducted by internal audit team), external (third-party auditor), regulatory (government agency inspection), certification (ISO/standards body), or surveillance (ongoing compliance monitoring).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Name of the lead auditor or audit firm responsible for identifying and documenting this finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorType rdf:type rdf:Property ;
    rdfs:label 'Auditor Type' ;
    rdfs:comment 'Classification of the auditor: internal (company internal audit team), external (third-party audit firm), regulatory (government agency inspector or regulator).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'High-level categorization of the finding type. [ENUM-REF-CANDIDATE: License Compliance|Content Standards Violation|Data Privacy Breach|Financial Reporting Error|Technical Standards Non-Conformance|Accessibility Non-Compliance|Rights Clearance Issue|Consent Management Deficiency|Public File Deficiency|Affidavit Discrepancy|Process Control Weakness|Documentation Gap — promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the audit finding, including the specific condition observed, the standard or requirement violated, and the evidence supporting the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Business identifier or reference number assigned to this finding for tracking and reporting purposes (e.g., FCC-2024-001, SOX-Q1-042).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the finding: open (newly identified, not yet addressed), in_remediation (corrective action underway), pending_verification (remediation complete, awaiting validation), closed (verified and resolved), deferred (accepted risk or postponed remediation).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'The date on which the audit finding was first identified or documented during the audit engagement.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementResponse rdf:type rdf:Property ;
    rdfs:label 'Management Response' ;
    rdfs:comment 'Formal response or action plan provided by management in reply to the audit finding, including agreement or disagreement with the finding, proposed corrective actions, and committed timelines.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the potential penalty amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potentialPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Potential Penalty Amount' ;
    rdfs:comment 'Estimated or assessed monetary penalty, fine, or forfeiture amount that could be imposed by the regulatory authority if the finding is not remediated or if enforcement action is taken.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedRemediation rdf:type rdf:Property ;
    rdfs:label 'Recommended Remediation' ;
    rdfs:comment 'The corrective action or remediation plan recommended by the auditor to address the finding and prevent recurrence.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceIndicator rdf:type rdf:Property ;
    rdfs:label 'Recurrence Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this finding is a repeat or recurrence of a previously identified and closed finding, suggesting ineffective corrective action or systemic control weakness.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'Specific regulatory rule, statute, standard, or policy section that was violated or not met (e.g., 47 CFR 73.3526 for FCC public file requirements, GDPR Article 32 for security measures, SOX Section 404 for internal controls).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDomain rdf:type rdf:Property ;
    rdfs:label 'Regulatory Domain' ;
    rdfs:comment 'The regulatory or compliance domain to which this finding pertains. [ENUM-REF-CANDIDATE: FCC Broadcast Licensing|Ofcom Broadcasting Standards|MPA Content Ratings|COPPA Childrens Content|GDPR Data Privacy|CCPA Consumer Privacy|SOX Financial Reporting|PCI DSS Payment Security|ATSC Technical Standards|DVB Technical Standards|Accessibility Mandates|Content Clearance|Closed Captioning|Consent Management — promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'External reference number or citation assigned by the regulatory body or governing authority (e.g., FCC Notice of Violation number, Ofcom enforcement case reference, SOX deficiency ID).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk rating assigned to this finding based on likelihood of regulatory enforcement, potential financial impact, reputational damage, and operational disruption.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Analysis of the underlying root cause or contributing factors that led to the non-compliance or control deficiency (e.g., inadequate training, process gap, system limitation, human error, policy ambiguity).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity level of the finding based on risk impact and regulatory consequence: critical (immediate regulatory action or material breach), high (significant risk or non-compliance), medium (moderate risk requiring timely remediation), low (minor issue or observation).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'The target or committed date by which the remediation action is expected to be completed and the finding closed.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the auditor, compliance officer, or quality assurance personnel who verified the effectiveness of the remediation action.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FCC broadcast licenses require a designated responsible party employee for regulatory accountability and correspondence. Licensee contact information should reference employee record rather than dupli' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'Annual regulatory fee assessed by the governing authority for maintaining this broadcast license.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:antennaHeightMeters rdf:type rdf:Property ;
    rdfs:label 'Antenna Height Meters' ;
    rdfs:comment 'Height of the transmitting antenna above average terrain, measured in meters. Critical factor in determining coverage area.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:broadcastLicenseStatus rdf:type rdf:Property ;
    rdfs:label 'Broadcast License Status' ;
    rdfs:comment 'Current lifecycle status of the broadcast license indicating its operational validity and regulatory standing. [ENUM-REF-CANDIDATE: Active|Pending|Suspended|Expired|Revoked|Cancelled|Under Renewal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callSign rdf:type rdf:Property ;
    rdfs:label 'Call Sign' ;
    rdfs:comment 'Unique station identifier assigned by the regulatory authority (e.g., WABC, KPIX-TV). Used for station identification during broadcasts.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelNumber rdf:type rdf:Property ;
    rdfs:label 'Channel Number' ;
    rdfs:comment 'Assigned broadcast channel number for television licenses (e.g., Channel 2, Channel 7). May include virtual channel numbers for digital broadcasts.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptioningRequired rdf:type rdf:Property ;
    rdfs:label 'Closed Captioning Required' ;
    rdfs:comment 'Indicates whether this license requires closed captioning for accessibility compliance.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communityOfLicense rdf:type rdf:Property ;
    rdfs:label 'Community Of License' ;
    rdfs:comment 'City or community that the broadcast station is licensed to serve. Determines local content and public interest obligations.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligations rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligations' ;
    rdfs:comment 'Summary of specific regulatory compliance requirements attached to this license (e.g., closed captioning, EAS participation, local content quotas, children\'s programming).' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageAreaContour rdf:type rdf:Property ;
    rdfs:label 'Coverage Area Contour' ;
    rdfs:comment 'Geographic boundary of the licensed coverage area, typically defined by signal strength contours (e.g., 60 dBu for FM, Grade A/B for TV). May be expressed as coordinates or geographic description.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easParticipationRequired rdf:type rdf:Property ;
    rdfs:label 'Eas Participation Required' ;
    rdfs:comment 'Indicates whether this license requires participation in the Emergency Alert System for public safety broadcasts.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyBand rdf:type rdf:Property ;
    rdfs:label 'Frequency Band' ;
    rdfs:comment 'Spectrum frequency band allocated to this license (e.g., 88.1 MHz for FM, 470-608 MHz for UHF TV). Expressed in MHz or GHz.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantDate rdf:type rdf:Property ;
    rdfs:label 'Grant Date' ;
    rdfs:comment 'Date when the broadcast license was originally granted or issued by the regulatory authority.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jurisdictionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the jurisdiction where this license is valid (e.g., USA, GBR, AUS).' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent regulatory inspection or audit of the licensed facility and operations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Modification Date' ;
    rdfs:comment 'Date of the most recent modification or amendment to the license terms, technical parameters, or ownership.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseClass rdf:type rdf:Property ;
    rdfs:label 'License Class' ;
    rdfs:comment 'Regulatory classification of the license indicating power level, coverage area, and operational constraints (e.g., Class A, Class B, Class C for FM; Full-Power, Low-Power for TV).' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Official license number or authorization code issued by the regulatory authority. This is the externally-known unique identifier for the broadcast license.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Classification of the broadcast license by service type and transmission technology. [ENUM-REF-CANDIDATE: AM Radio|FM Radio|TV Full-Power|TV Low-Power|TV Translator|Satellite|Cable Franchise|IPTV — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseeType rdf:type rdf:Property ;
    rdfs:label 'Licensee Type' ;
    rdfs:comment 'Legal structure of the licensee organization.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationType rdf:type rdf:Property ;
    rdfs:label 'Modification Type' ;
    rdfs:comment 'Nature of the most recent license modification (e.g., Technical Change, Ownership Transfer, Power Increase, Frequency Change).' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipAttribution rdf:type rdf:Property ;
    rdfs:label 'Ownership Attribution' ;
    rdfs:comment 'Details of attributable ownership interests in the licensee entity, required for regulatory ownership reporting and concentration limits.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerOutputErpWatts rdf:type rdf:Property ;
    rdfs:label 'Power Output Erp Watts' ;
    rdfs:comment 'Maximum authorized effective radiated power output for the transmitter, measured in watts. Determines the coverage area and signal strength.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicInspectionFileLocation rdf:type rdf:Property ;
    rdfs:label 'Public Inspection File Location' ;
    rdfs:comment 'Physical or online location where the stations public inspection file is maintained, as required by regulatory authorities.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Governing body that issued and oversees this broadcast license (e.g., FCC for United States, Ofcom for United Kingdom). [ENUM-REF-CANDIDATE: FCC|Ofcom|ACMA|CRTC|ANATEL|IFT|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Application Date' ;
    rdfs:comment 'Date when the license renewal application was filed with the regulatory authority.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current status of the license renewal process, tracking whether renewal application has been filed and its disposition.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmitterAddress rdf:type rdf:Property ;
    rdfs:label 'Transmitter Address' ;
    rdfs:comment 'Physical street address of the licensed transmitter facility. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmitterLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Transmitter Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the licensed transmitter site in decimal degrees.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmitterLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Transmitter Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the licensed transmitter site in decimal degrees.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetVersionId rdf:type rdf:Property ;
    rdfs:label 'Asset Version Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_version. Business justification: Closed captioning applies to specific versions/renditions of assets (broadcast master vs. streaming proxy vs. archived version). Different versions may have different caption formats (CEA-608, CEA-708' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:captionVendorPartnerId rdf:type rdf:Property ;
    rdfs:label 'Caption Vendor Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Captioning vendor performance and FCC compliance is tracked by partner. Captioning accuracy failures, latency violations, and format errors may trigger vendor SLA breaches, disputes, or vendor substit' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:contentEpisodeId rdf:type rdf:Property ;
    rdfs:label 'Content Episode Id' ;
    rdfs:comment 'Reference to the specific episode that was captioned, if applicable.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentEpisode .

ind:deliveryChannelId rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel Id' ;
    rdfs:comment 'Reference to the channel or platform where the captioned content was broadcast or streamed.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryChannel .

ind:encoderConfigId rdf:type rdf:Property ;
    rdfs:label 'Encoder Config Id' ;
    rdfs:comment 'Foreign key linking to technology.encoder_config. Business justification: Caption compliance audits require tracking which encoder processed each stream. Real NOC/compliance workflow for troubleshooting caption failures and demonstrating CVAA compliance to FCC.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EncoderConfig .

ind:narratorTalentProfileId rdf:type rdf:Property ;
    rdfs:label 'Narrator Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: Closed caption records may reference talent for audio description, voice identification, or accessibility compliance when talent narrates or appears in content. Accessibility teams identify talent voi' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:captionAccuracyScore rdf:type rdf:Property ;
    rdfs:label 'Caption Accuracy Score' ;
    rdfs:comment 'Percentage score representing the accuracy of the captions compared to the spoken audio, measured as a percentage from 0.00 to 100.00.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:captionCompletenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Caption Completeness Percentage' ;
    rdfs:comment 'Percentage of the program duration that was captioned, measured from 0.00 to 100.00.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:captionFileFormat rdf:type rdf:Property ;
    rdfs:label 'Caption File Format' ;
    rdfs:comment 'The technical format of the closed caption file used for this broadcast. [ENUM-REF-CANDIDATE: SRT|SCC|TTML|WebVTT|CEA-608|CEA-708|DFXP|STL — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captionLatencySeconds rdf:type rdf:Property ;
    rdfs:label 'Caption Latency Seconds' ;
    rdfs:comment 'The average delay in seconds between spoken audio and caption display, critical for live programming compliance.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:captionPlacementCompliance rdf:type rdf:Property ;
    rdfs:label 'Caption Placement Compliance' ;
    rdfs:comment 'Indicates whether caption placement on screen met regulatory standards for visibility and non-obstruction of critical content.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:captionQualityReviewDate rdf:type rdf:Property ;
    rdfs:label 'Caption Quality Review Date' ;
    rdfs:comment 'Date when the caption quality was formally reviewed for compliance assessment.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:captionSynchronizationCompliance rdf:type rdf:Property ;
    rdfs:label 'Caption Synchronization Compliance' ;
    rdfs:comment 'Indicates whether captions were properly synchronized with the audio and video content per regulatory requirements.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:captionType rdf:type rdf:Property ;
    rdfs:label 'Caption Type' ;
    rdfs:comment 'Indicates whether the captions were generated live during broadcast or pre-recorded offline.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captionedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Captioned Duration Minutes' ;
    rdfs:comment 'Total duration in minutes that was actually captioned within the program.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complaintReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Complaint Received Date' ;
    rdfs:comment 'Date when a viewer complaint regarding captioning was received by the broadcaster.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complaintReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Reference Number' ;
    rdfs:comment 'Reference number of any viewer complaint filed regarding caption quality or availability for this broadcast.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintType rdf:type rdf:Property ;
    rdfs:label 'Complaint Type' ;
    rdfs:comment 'Category of the captioning complaint filed by viewers or regulatory bodies.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionBasis rdf:type rdf:Property ;
    rdfs:label 'Exemption Basis' ;
    rdfs:comment 'Legal or regulatory basis for exemption from closed captioning requirements, if applicable.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionCategory rdf:type rdf:Property ;
    rdfs:label 'Exemption Category' ;
    rdfs:comment 'Category of exemption from captioning requirements as defined by regulatory frameworks. [ENUM-REF-CANDIDATE: primarily_textual|late_night|promotional|public_service_announcement|locally_produced|economic_burden|interstitial_material|secondary_audio — promote to reference product]' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Program Duration Minutes' ;
    rdfs:comment 'Total duration of the program in minutes for which captioning compliance is being tracked.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programTitle rdf:type rdf:Property ;
    rdfs:label 'Program Title' ;
    rdfs:comment 'The title of the program that was captioned as it appeared in the broadcast schedule.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicInspectionFileIncluded rdf:type rdf:Property ;
    rdfs:label 'Public Inspection File Included' ;
    rdfs:comment 'Indicates whether this caption record has been included in the broadcasters public inspection file as required by FCC regulations.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Date' ;
    rdfs:comment 'Date when the caption compliance record was filed with the regulatory authority.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required' ;
    rdfs:comment 'Indicates whether this caption record requires formal filing with regulatory authorities such as FCC or Ofcom.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completed Date' ;
    rdfs:comment 'Date when remediation actions to correct captioning issues were completed.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationDescription rdf:type rdf:Property ;
    rdfs:label 'Remediation Description' ;
    rdfs:comment 'Detailed description of the remediation actions taken to address captioning compliance issues.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of remediation efforts to address captioning deficiencies or complaints.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseRenewalId rdf:type rdf:Property ;
    rdfs:label 'License Renewal Id' ;
    rdfs:comment 'Foreign key linking to compliance.license_renewal. Business justification: License renewal deadlines are critical compliance milestones tracked in the compliance calendar. This FK links calendar entries to specific license renewal records, enabling proactive deadline managem' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseRenewal .

ind:responsibleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Compliance calendar deadlines must be assigned to specific employees for accountability and workload management. Responsible owner contact data should reference employee record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:automationStatus rdf:type rdf:Property ;
    rdfs:label 'Automation Status' ;
    rdfs:comment 'Indicates the level of automation applied to this compliance obligation (manual process, semi-automated with human review, or fully automated).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Actual date when the compliance obligation was fulfilled and submitted or completed. Null if not yet completed.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Current status of the compliance obligation in its lifecycle (not started, in progress, under review, completed, submitted to regulatory body, overdue, or deferred). [ENUM-REF-CANDIDATE: not_started|in_progress|under_review|completed|submitted|overdue|deferred — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineDate rdf:type rdf:Property ;
    rdfs:label 'Deadline Date' ;
    rdfs:comment 'The final date by which the compliance obligation must be fulfilled. This is the hard deadline for regulatory submission, renewal, or completion.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deadlineDescription rdf:type rdf:Property ;
    rdfs:label 'Deadline Description' ;
    rdfs:comment 'Detailed description of the compliance deadline, including specific requirements, deliverables, and any special conditions or instructions.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineType rdf:type rdf:Property ;
    rdfs:label 'Deadline Type' ;
    rdfs:comment 'Category of compliance deadline being tracked (filing, license renewal, audit schedule, certification expiry, reporting period, or inspection).' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationPath rdf:type rdf:Property ;
    rdfs:label 'Documentation Path' ;
    rdfs:comment 'File system path or document management system location where supporting documentation for this compliance deadline is stored.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequired rdf:type rdf:Property ;
    rdfs:label 'Documentation Required' ;
    rdfs:comment 'Indicates whether supporting documentation, evidence, or attachments must be prepared and submitted with this compliance obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date when this compliance deadline was escalated to senior management or executive leadership due to risk of non-compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationPath rdf:type rdf:Property ;
    rdfs:label 'Escalation Path' ;
    rdfs:comment 'Defined escalation hierarchy or contact chain for at-risk deadlines (e.g., Manager → Director → VP → Chief Compliance Officer).' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationStatus rdf:type rdf:Property ;
    rdfs:label 'Escalation Status' ;
    rdfs:comment 'Indicates whether this deadline is at risk of being missed and requires management escalation (none, at risk, escalated to management, or critical).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Geographic or legal jurisdiction where this compliance obligation applies (e.g., USA, GBR, EUR, state-level, or specific market designation).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Penalty Amount' ;
    rdfs:comment 'Maximum financial penalty or fine amount that could be imposed for non-compliance with this obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringSystem rdf:type rdf:Property ;
    rdfs:label 'Monitoring System' ;
    rdfs:comment 'Name of the system or tool used to monitor and track progress toward this compliance deadline (e.g., GRC platform, workflow system, calendar application).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextOccurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Next Occurrence Date' ;
    rdfs:comment 'Date of the next scheduled occurrence of this recurring compliance obligation. Null for one-time obligations.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Reference Number' ;
    rdfs:comment 'External reference number or code assigned by the regulatory body to this specific obligation or filing requirement.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the penalty amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Description of potential penalties, fines, sanctions, or consequences if this compliance deadline is missed or the obligation is not fulfilled.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Preparation Lead Time Days' ;
    rdfs:comment 'Number of days required in advance of the deadline to prepare, review, and submit the compliance deliverable. Used to calculate reminder triggers.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Required' ;
    rdfs:comment 'Indicates whether this compliance obligation requires public disclosure or inclusion in the public inspection file (e.g., FCC OPIF requirements).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrenceFrequency rdf:type rdf:Property ;
    rdfs:label 'Recurrence Frequency' ;
    rdfs:comment 'How often this compliance obligation recurs (one-time, daily, weekly, monthly, quarterly, semi-annually, annually, biennially, or triennially). [ENUM-REF-CANDIDATE: one_time|daily|weekly|monthly|quarterly|semi_annual|annual|biennial|triennial — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'The governing body or regulatory authority that mandates this compliance deadline (e.g., FCC for broadcast licensing, GDPR for data privacy, SOX for financial reporting). [ENUM-REF-CANDIDATE: FCC|Ofcom|MPA|ATSC|DVB|Nielsen|IAB|SCTE|ISO|GDPR|CCPA|SOX|PCI DSS|COPPA — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderTriggerDate rdf:type rdf:Property ;
    rdfs:label 'Reminder Trigger Date' ;
    rdfs:comment 'Date when automated reminders or alerts should be sent to the responsible owner to begin preparation. Calculated as deadline_date minus preparation_lead_time_days.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the reporting or compliance period covered by this deadline (e.g., fiscal quarter end, license term end).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the reporting or compliance period covered by this deadline (e.g., fiscal quarter start, license term start).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Business unit or department accountable for managing and completing this compliance obligation (e.g., Legal, Compliance, Engineering, Finance).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessed risk level associated with missing this compliance deadline, considering potential penalties, reputational impact, and operational consequences.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Confirmation Number' ;
    rdfs:comment 'Confirmation or tracking number provided by the regulatory body upon successful submission of the compliance deliverable.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByConsentRecordComplianceConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Consent Record Compliance Consent Record Id' ;
    rdfs:comment 'Reference to the consent record ID that supersedes this record. Used to maintain consent history and audit trail when consent is updated or renewed. Null if this is the current active record.' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceConsentRecord .

ind:auditNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Notes' ;
    rdfs:comment 'Free-text field for additional audit notes, compliance annotations, or special circumstances related to this consent record. Used for regulatory audit preparation and internal compliance reviews.' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentChannel rdf:type rdf:Property ;
    rdfs:label 'Consent Channel' ;
    rdfs:comment 'Platform or channel through which the consent was collected. Distinguishes between web, mobile app, smart TV, email, phone, in-person, or API-driven consent capture. [ENUM-REF-CANDIDATE: web|mobile_app|smart_tv|email|phone|in_person|api — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'Date on which the consent expires and must be renewed. Null for consents without expiration. Used to enforce periodic re-consent requirements under certain regulations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentLanguage rdf:type rdf:Property ;
    rdfs:label 'Consent Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code indicating the language in which the consent notice was presented to the subject (e.g., en for English, es for Spanish, fr for French).' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMechanism rdf:type rdf:Property ;
    rdfs:label 'Consent Mechanism' ;
    rdfs:comment 'Method or interface through which consent was captured. Examples include Consent Management Platform (CMP) banner, registration form, opt-in email, in-app toggle, customer service call, or written form.' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentProofUrl rdf:type rdf:Property ;
    rdfs:label 'Consent Proof Url' ;
    rdfs:comment 'URL or storage path to the archived proof of consent (e.g., screenshot, form submission, audit log entry). Used as evidence in regulatory audits.' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Detailed description of the specific data processing activities or purposes covered by this consent. May include specific data categories, processing purposes, or third-party sharing arrangements.' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Consent Source System' ;
    rdfs:comment 'Name of the source system or application that captured the consent event. Examples include Adobe Experience Platform, Salesforce, Zuora, or custom Consent Management Platform (CMP).' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current state of the consent. Indicates whether consent has been granted, withdrawn, expired, not yet provided, or is pending review.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Date and time when the consent event occurred (granted, withdrawn, or modified). Recorded in ISO 8601 format with timezone.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Consent Transaction Code' ;
    rdfs:comment 'Unique transaction or session identifier from the source system that captured the consent. Used for cross-system audit trail and reconciliation.' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Category of consent being granted or withdrawn. Includes data processing, marketing communications, profiling, cookie usage, targeted advertising, and cross-device tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cookieConsentCategories rdf:type rdf:Property ;
    rdfs:label 'Cookie Consent Categories' ;
    rdfs:comment 'Comma-separated list of cookie categories for which consent was granted (e.g., strictly_necessary, functional, analytics, advertising, social_media). Aligns with IAB Transparency and Consent Framework categories.' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address from which the consent was provided. Used for audit trail and fraud detection. May be IPv4 or IPv6 format.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingEmailConsent rdf:type rdf:Property ;
    rdfs:label 'Marketing Email Consent' ;
    rdfs:comment 'Boolean flag indicating whether the subject has consented to receive marketing communications via email.' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingPushConsent rdf:type rdf:Property ;
    rdfs:label 'Marketing Push Consent' ;
    rdfs:comment 'Boolean flag indicating whether the subject has consented to receive marketing push notifications on mobile or web applications.' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingSmsConsent rdf:type rdf:Property ;
    rdfs:label 'Marketing Sms Consent' ;
    rdfs:comment 'Boolean flag indicating whether the subject has consented to receive marketing communications via SMS or text message.' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Verified' ;
    rdfs:comment 'Boolean flag indicating whether parental or guardian consent has been verified for subjects under the age of consent (required under Children\'s Online Privacy Protection Act (COPPA) and similar regulations).' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Parental Verification Method' ;
    rdfs:comment 'Method used to verify parental consent for minors. Examples include credit card verification, government ID check, video conference, or signed consent form. Null if parental consent is not applicable.' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyPolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Version' ;
    rdfs:comment 'Version identifier of the privacy policy or terms of service that the subject accepted when providing consent. Critical for demonstrating which terms were in effect at the time of consent.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Primary privacy regulation or framework under which this consent was collected. Includes General Data Protection Regulation (GDPR), California Consumer Privacy Act (CCPA), Children\'s Online Privacy Protection Act (COPPA), California Privacy Rights Act (CPRA), Lei Geral de Proteção de Dados (LGPD), Personal Information Protection and Electronic Documents Act (PIPEDA), or other applicable laws. [ENUM-REF-CANDIDATE: GDPR|CCPA|COPPA|CPRA|LGPD|PIPEDA|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectType rdf:type rdf:Property ;
    rdfs:label 'Subject Type' ;
    rdfs:comment 'Classification of the data subject providing consent. Distinguishes between authenticated subscribers, registered users, anonymous viewers, guests, or device-level consent.' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tcfConsentString rdf:type rdf:Property ;
    rdfs:label 'Tcf Consent String' ;
    rdfs:comment 'IAB Transparency and Consent Framework encoded consent string capturing granular vendor and purpose consents. Used for programmatic advertising consent management.' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingConsent rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Consent' ;
    rdfs:comment 'Boolean flag indicating whether the subject has consented to sharing their data with third parties (e.g., advertising partners, analytics providers, content partners).' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'Browser or application user agent string captured at the time of consent. Provides context about the device and software used for consent capture.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalMechanism rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Mechanism' ;
    rdfs:comment 'Method or interface through which consent was withdrawn. Examples include preference center, unsubscribe link, customer service request, or in-app toggle. Null if consent has not been withdrawn.' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Timestamp' ;
    rdfs:comment 'Date and time when consent was withdrawn by the subject. Null if consent has not been withdrawn. Critical for demonstrating compliance with right to withdraw consent.' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contentRatingId rdf:type rdf:Property ;
    rdfs:label 'Content Rating Id' ;
    rdfs:comment 'Primary key for content_rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaBroadcasting .

ind:submittedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Submitted By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Content rating submissions to MPAA, TV Parental Guidelines, or other rating authorities require tracking which employee submitted for accountability and audit trail purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessibilityRatingNotes rdf:type rdf:Property ;
    rdfs:label 'Accessibility Rating Notes' ;
    rdfs:comment 'Notes regarding accessibility features relevant to the rating, such as closed captioning compliance, audio description availability, or photosensitive epilepsy warnings.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Status of any appeal filed by the content producer to challenge the assigned rating. Not Appealed: no appeal has been filed; Appeal Pending: appeal is under review; Appeal Approved: rating was changed following appeal; Appeal Denied: original rating upheld.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDescriptors rdf:type rdf:Property ;
    rdfs:label 'Content Descriptors' ;
    rdfs:comment 'Comma-separated list of content advisory descriptors that explain the reasons for the rating. Examples: violence, strong language, sexual content, drug use, nudity, adult themes, frightening scenes.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaCompliant rdf:type rdf:Property ;
    rdfs:label 'Coppa Compliant' ;
    rdfs:comment 'Indicates whether the content and its associated data collection practices comply with COPPA requirements for children\'s content.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drugUseDescriptor rdf:type rdf:Property ;
    rdfs:label 'Drug Use Descriptor' ;
    rdfs:comment 'Indicates whether the content contains drug use or substance abuse that contributed to the rating.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eidrCode rdf:type rdf:Property ;
    rdfs:label 'Eidr Code' ;
    rdfs:comment 'The EIDR identifier for the content asset, providing a globally unique reference for the audiovisual work.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageDescriptor rdf:type rdf:Property ;
    rdfs:label 'Language Descriptor' ;
    rdfs:comment 'Indicates whether the content contains strong or offensive language that contributed to the rating.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumAge rdf:type rdf:Property ;
    rdfs:label 'Minimum Age' ;
    rdfs:comment 'The minimum recommended or required age for viewers of this content, as specified by the rating authority. Null if no specific age restriction applies.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentalGuidanceRequired rdf:type rdf:Property ;
    rdfs:label 'Parental Guidance Required' ;
    rdfs:comment 'Indicates whether parental guidance is recommended or required for viewers under a certain age.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousRatingValue rdf:type rdf:Property ;
    rdfs:label 'Previous Rating Value' ;
    rdfs:comment 'The rating value that was assigned before the current rating, if the content was re-rated. Null for initial ratings.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingAuthority rdf:type rdf:Property ;
    rdfs:label 'Rating Authority' ;
    rdfs:comment 'The official organization or regulatory body that issued the rating. Examples: Motion Picture Association, TV Parental Guidelines Monitoring Board, British Board of Film Classification, Freiwillige Selbstkontrolle der Filmwirtschaft.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Rating Certificate Number' ;
    rdfs:comment 'The official certificate or registration number issued by the rating authority for this content rating.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingDate rdf:type rdf:Property ;
    rdfs:label 'Rating Date' ;
    rdfs:comment 'The date on which the rating was officially assigned to the content by the rating authority.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Rating Expiration Date' ;
    rdfs:comment 'The date on which the rating expires or requires renewal, if applicable. Null for ratings with no expiration.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Rating Fee Amount' ;
    rdfs:comment 'The fee charged by the rating authority for evaluating and assigning the rating to the content.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Rating Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the rating fee. Examples: USD, GBP, EUR, AUD, JPY.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingNotes rdf:type rdf:Property ;
    rdfs:label 'Rating Notes' ;
    rdfs:comment 'Additional notes or comments regarding the rating, including any special conditions, context, or clarifications provided by the rating authority or compliance team.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingReason rdf:type rdf:Property ;
    rdfs:label 'Rating Reason' ;
    rdfs:comment 'Detailed explanation provided by the rating authority describing the specific content elements that led to the assigned rating.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingReviewDate rdf:type rdf:Property ;
    rdfs:label 'Rating Review Date' ;
    rdfs:comment 'The date on which the rating was last reviewed or re-evaluated by the rating authority.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Rating Submission Date' ;
    rdfs:comment 'The date on which the content was submitted to the rating authority for evaluation.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingSystem rdf:type rdf:Property ;
    rdfs:label 'Rating System' ;
    rdfs:comment 'The rating authority or system that issued this rating. Examples: MPA (Motion Picture Association), TV Parental Guidelines, BBFC (British Board of Film Classification), FSK (Germany), ACB (Australia), EIRIN (Japan), KFCB (Kenya). [ENUM-REF-CANDIDATE: MPA|TV_PARENTAL_GUIDELINES|BBFC|FSK|ACB|EIRIN|KFCB — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingType rdf:type rdf:Property ;
    rdfs:label 'Rating Type' ;
    rdfs:comment 'The distribution context for which this rating was assigned. Different ratings may apply to theatrical release, television broadcast, home video, or streaming platforms.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingValue rdf:type rdf:Property ;
    rdfs:label 'Rating Value' ;
    rdfs:comment 'The specific rating classification assigned to the content. Examples: G, PG, PG-13, R, NC-17 (MPA); TV-Y, TV-Y7, TV-G, TV-PG, TV-14, TV-MA (TV Parental Guidelines); U, PG, 12A, 15, 18 (BBFC). [ENUM-REF-CANDIDATE: G|PG|PG-13|R|NC-17|TV-Y|TV-Y7|TV-G|TV-PG|TV-14|TV-MA|U|12A|15|18|FSK0|FSK6|FSK12|FSK16|FSK18 — promote to reference product]' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingVersion rdf:type rdf:Property ;
    rdfs:label 'Rating Version' ;
    rdfs:comment 'Version number of this rating record. Increments when the rating is re-evaluated or updated due to content changes or appeals.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sexualContentDescriptor rdf:type rdf:Property ;
    rdfs:label 'Sexual Content Descriptor' ;
    rdfs:comment 'Indicates whether the content contains sexual content or nudity that contributed to the rating.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the geographic territory where this rating is applicable. Examples: USA, GBR, DEU, AUS, JPN.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violenceDescriptor rdf:type rdf:Property ;
    rdfs:label 'Violence Descriptor' ;
    rdfs:comment 'Indicates whether the content contains violence that contributed to the rating.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:declaredByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Declared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: COPPA declarations require named responsible party employee for legal accountability to FTC. Reviewer name should reference employee record rather than store as text.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ottPlatformId rdf:type rdf:Property ;
    rdfs:label 'Ott Platform Id' ;
    rdfs:comment 'Identifier of the OTT platform or digital service on which the content is distributed. Relevant for streaming platforms carrying children\'s programming.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OttPlatform .

ind:actualKnowledgeFlag rdf:type rdf:Property ;
    rdfs:label 'Actual Knowledge Flag' ;
    rdfs:comment 'Indicates whether the operator has actual knowledge that it is collecting personal information from children under 13, triggering COPPA compliance obligations regardless of directed-to-children status.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:advertisingAssessment rdf:type rdf:Property ;
    rdfs:label 'Advertising Assessment' ;
    rdfs:comment 'Assessment of whether advertising or promotional materials are directed to children, including ad placement, messaging, and products advertised.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioContentAssessment rdf:type rdf:Property ;
    rdfs:label 'Audio Content Assessment' ;
    rdfs:comment 'Assessment of audio elements (music, voice talent, sound effects) that may appeal to children, per FTC child-directed determination factors.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference to detailed audit trail or supporting documentation for the COPPA declaration, including assessment worksheets and evidence.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childCelebrityPresenceFlag rdf:type rdf:Property ;
    rdfs:label 'Child Celebrity Presence Flag' ;
    rdfs:comment 'Indicates whether the content features child celebrities or characters that appeal to children, a factor in FTC child-directed determination.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Additional notes, observations, or context regarding the COPPA compliance assessment, including any mitigating factors or special considerations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date on which verifiable parental consent was obtained, if applicable. Must be maintained for audit purposes.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataCollectionScope rdf:type rdf:Property ;
    rdfs:label 'Data Collection Scope' ;
    rdfs:comment 'Description of personal information collected from users, including identifiers, location data, photos, videos, audio recordings, and persistent identifiers for behavioral advertising.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationDate rdf:type rdf:Property ;
    rdfs:label 'Declaration Date' ;
    rdfs:comment 'Date on which the COPPA declaration was formally made or submitted for review.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declarationNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Number' ;
    rdfs:comment 'Business identifier for the COPPA declaration, formatted as COPPA-YYYY-XXXXXXXX for external reference and audit tracking.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationStatus rdf:type rdf:Property ;
    rdfs:label 'Declaration Status' ;
    rdfs:comment 'Current lifecycle status of the COPPA declaration: draft (being prepared), active (in effect), under_review (legal/compliance review), approved (validated), rejected (non-compliant), expired (needs renewal), withdrawn (no longer applicable). [ENUM-REF-CANDIDATE: draft|active|under_review|approved|rejected|expired|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationType rdf:type rdf:Property ;
    rdfs:label 'Declaration Type' ;
    rdfs:comment 'Type of digital asset being declared: content (video/audio program), service (subscription offering), platform (streaming service), website, mobile app, or interactive feature (games, social features).' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directedToChildrenStatus rdf:type rdf:Property ;
    rdfs:label 'Directed To Children Status' ;
    rdfs:comment 'Determination of whether the content or service is directed to children under 13: directed (primary audience is children), mixed_audience (general audience including children), not_directed (not intended for children), under_review (assessment in progress).' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftcFilingReference rdf:type rdf:Property ;
    rdfs:label 'Ftc Filing Reference' ;
    rdfs:comment 'Reference number or identifier for any filings, notifications, or correspondence with the FTC regarding this COPPA declaration or compliance matter.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalOpinionReference rdf:type rdf:Property ;
    rdfs:label 'Legal Opinion Reference' ;
    rdfs:comment 'Reference to any legal opinion, memo, or external counsel advice supporting the COPPA determination.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next compliance review or reassessment of the COPPA declaration.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentalConsentMechanism rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Mechanism' ;
    rdfs:comment 'Method used to obtain verifiable parental consent: email_plus (email plus additional verification), credit_card, toll_free (phone verification), video_conference, government_id, digital_certificate, not_required (content not directed to children), under_review. [ENUM-REF-CANDIDATE: email_plus|credit_card|toll_free|video_conference|government_id|digital_certificate|not_required|under_review — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:persistentIdentifierCollectionFlag rdf:type rdf:Property ;
    rdfs:label 'Persistent Identifier Collection Flag' ;
    rdfs:comment 'Indicates whether persistent identifiers (cookies, device IDs, IP addresses) are collected for purposes other than internal operations, requiring parental consent under COPPA.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyPolicyUrl rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Url' ;
    rdfs:comment 'URL of the privacy policy that discloses data collection practices, parental rights, and COPPA compliance measures. Must be prominently displayed per COPPA requirements.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date of the most recent compliance review or reassessment of the COPPA declaration. Critical for demonstrating ongoing compliance diligence.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerTitle rdf:type rdf:Property ;
    rdfs:label 'Reviewer Title' ;
    rdfs:comment 'Job title or role of the reviewer (e.g., Chief Privacy Officer, Legal Counsel, Compliance Manager).' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeHarborCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Safe Harbor Certification Number' ;
    rdfs:comment 'Certification number or identifier issued by the safe harbor program, if applicable.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeHarborProgram rdf:type rdf:Property ;
    rdfs:label 'Safe Harbor Program' ;
    rdfs:comment 'Name of the FTC-approved safe harbor program the operator participates in, if any (e.g., CARU, TRUSTe, iKeepSafe). Provides streamlined compliance pathway.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectMatterDescription rdf:type rdf:Property ;
    rdfs:label 'Subject Matter Description' ;
    rdfs:comment 'Description of the content\'s subject matter, themes, and topics used to assess child-directed nature per FTC (Federal Trade Commission) guidelines.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAgeRangeMax rdf:type rdf:Property ;
    rdfs:label 'Target Age Range Max' ;
    rdfs:comment 'Maximum age of the intended audience for the content or service. Used to assess mixed-audience scenarios.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetAgeRangeMin rdf:type rdf:Property ;
    rdfs:label 'Target Age Range Min' ;
    rdfs:comment 'Minimum age of the intended audience for the content or service. Critical for determining COPPA applicability (under 13 threshold).' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verifiableConsentObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Verifiable Consent Obtained Flag' ;
    rdfs:comment 'Indicates whether verifiable parental consent has been obtained for data collection from children under 13, as required by COPPA.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visualContentAssessment rdf:type rdf:Property ;
    rdfs:label 'Visual Content Assessment' ;
    rdfs:comment 'Assessment of visual content elements (characters, animation style, color schemes) that may appeal to children, per FTC child-directed determination factors.' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Operator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FCC EAS logs must record which licensed operator was on duty during alert transmission for regulatory compliance verification. Operator on duty text should be FK.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alertDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Alert Duration Seconds' ;
    rdfs:comment 'Duration of the EAS alert transmission in seconds, from start to end of the alert message.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertText rdf:type rdf:Property ;
    rdfs:label 'Alert Text' ;
    rdfs:comment 'Full text content of the EAS alert message that was transmitted or received, including any instructions to the public.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Timestamp' ;
    rdfs:comment 'Date and time when the EAS alert was activated or received by the station. This is the principal business event timestamp for the alert.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the EAS alert by geographic scope: national emergency, state emergency, local emergency, or test alert.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attentionSignalTransmitted rdf:type rdf:Property ;
    rdfs:label 'Attention Signal Transmitted' ;
    rdfs:comment 'Indicates whether the two-tone attention signal was transmitted as part of the EAS alert.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioMessageTransmitted rdf:type rdf:Property ;
    rdfs:label 'Audio Message Transmitted' ;
    rdfs:comment 'Indicates whether the audio message portion of the EAS alert was transmitted.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capMessageReceived rdf:type rdf:Property ;
    rdfs:label 'Cap Message Received' ;
    rdfs:comment 'Indicates whether the alert was received in Common Alerting Protocol (CAP) format via IPAWS or other digital alert system.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endOfMessageTransmitted rdf:type rdf:Property ;
    rdfs:label 'End Of Message Transmitted' ;
    rdfs:comment 'Indicates whether the End of Message (EOM) code was transmitted to signal completion of the EAS alert.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentUsed rdf:type rdf:Property ;
    rdfs:label 'Equipment Used' ;
    rdfs:comment 'Description or model identifier of the EAS equipment (encoder/decoder) used to process and transmit the alert.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Three-letter EAS event code identifying the nature of the emergency (e.g., EAN for Emergency Action Notification, RWT for Required Weekly Test, RMT for Required Monthly Test, TOR for Tornado Warning).' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipawsMessageCode rdf:type rdf:Property ;
    rdfs:label 'Ipaws Message Code' ;
    rdfs:comment 'Unique message identifier from FEMA IPAWS system for alerts originated through the national alert infrastructure.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Six-digit FIPS code identifying the geographic area affected by the alert (county or equivalent subdivision).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatorCode rdf:type rdf:Property ;
    rdfs:label 'Originator Code' ;
    rdfs:comment 'Three-letter code identifying the entity that originated the alert (e.g., PEP for Primary Entry Point, CIV for Civil Authority, WXR for National Weather Service, EAS for EAS Participant).' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatorName rdf:type rdf:Property ;
    rdfs:label 'Originator Name' ;
    rdfs:comment 'Full name of the authority or organization that originated the EAS alert (e.g., FEMA IPAWS, National Weather Service, State Emergency Management Agency).' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicInspectionFileEntry rdf:type rdf:Property ;
    rdfs:label 'Public Inspection File Entry' ;
    rdfs:comment 'Indicates whether this EAS log entry has been included in the stations public inspection file as required by FCC regulations.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relayChainPosition rdf:type rdf:Property ;
    rdfs:label 'Relay Chain Position' ;
    rdfs:comment 'Position of this station in the EAS relay chain, indicating how many hops the alert has traveled from the originator (1 for direct receipt, 2+ for relayed).' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'Date when this EAS log record is eligible for deletion based on FCC retention requirements (minimum 2 years for EAS logs).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testComplianceType rdf:type rdf:Property ;
    rdfs:label 'Test Compliance Type' ;
    rdfs:comment 'Type of EAS test compliance this log entry satisfies: Required Weekly Test (RWT), Required Monthly Test (RMT), National Periodic Test, or none if not a test.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Test Scheduled Date' ;
    rdfs:comment 'Date when the EAS test was scheduled to occur, used for tracking compliance with required weekly and monthly test schedules.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Transmission Status' ;
    rdfs:comment 'Status of the EAS alert transmission indicating whether the station successfully transmitted, received, relayed, failed to transmit, or missed the alert.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upstreamSourceCallsign rdf:type rdf:Property ;
    rdfs:label 'Upstream Source Callsign' ;
    rdfs:comment 'Call sign of the upstream station or source from which this station received the EAS alert for relay.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validTimePeriod rdf:type rdf:Property ;
    rdfs:label 'Valid Time Period' ;
    rdfs:comment 'Four-digit code indicating the valid time period for the alert in 15-minute increments (e.g., 0030 for 30 minutes, 0100 for 1 hour).' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentId rdf:type rdf:Property ;
    rdfs:label 'Incident Id' ;
    rdfs:comment 'Primary key for incident' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryChangeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Change Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_change. Business justification: Compliance incidents may be triggered by new regulatory requirements that the organization has not yet implemented. This FK links incidents to the regulatory change that introduced the requirement, su' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryChange .

ind:responsiblePartyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Compliance incidents require assigned employee for resolution tracking and accountability. Responsible party contact data should reference employee record rather than duplicate information.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedRegulation rdf:type rdf:Property ;
    rdfs:label 'Affected Regulation' ;
    rdfs:comment 'The specific regulation, statute, or standard that was violated or at risk (e.g., FCC Part 73, GDPR Article 5, SOX Section 404, ATSC A/53).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'The date on which the compliance incident was formally closed after all remediation actions were completed and verified.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Final notes and summary documenting the resolution of the compliance incident, lessons learned, and any outstanding follow-up items.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'Actual date on which the corrective action plan was completed and verified.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target completion date for the corrective action plan.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Documented plan outlining the corrective actions to be taken to remediate the incident and prevent recurrence.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current status of the corrective action plan implementation.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'The date on which the compliance incident was discovered or identified by the organization or external party.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discoverySource rdf:type rdf:Property ;
    rdfs:label 'Discovery Source' ;
    rdfs:comment 'The source or method by which the compliance incident was discovered (e.g., internal audit, regulator inspection, viewer complaint, self-disclosure, automated monitoring). [ENUM-REF-CANDIDATE: internal_audit|external_audit|regulator_inspection|viewer_complaint|self_disclosure|automated_monitoring|third_party_report — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated or actual financial impact of the compliance incident, including fines, penalties, remediation costs, and lost revenue.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial impact amount.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedService rdf:type rdf:Property ;
    rdfs:label 'Impacted Service' ;
    rdfs:comment 'The broadcast service, streaming platform, or distribution channel affected by the compliance incident (e.g., linear broadcast, OTT platform, MVPD service).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'The date on which the compliance incident occurred or was first observed.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Detailed narrative description of the compliance incident, including what occurred, how it was identified, and the immediate circumstances.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Business-facing unique identifier or case number assigned to the compliance incident for tracking and reference purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle status of the compliance incident in the response and remediation workflow.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Classification of the compliance incident by regulatory domain (e.g., broadcast licensing, content standards, data privacy, financial reporting, accessibility, technical standards). [ENUM-REF-CANDIDATE: broadcast_licensing|content_standards|data_privacy|financial_reporting|accessibility|technical_standards|advertising_compliance|rights_clearance|closed_captioning|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Recurrence Risk Level' ;
    rdfs:comment 'Assessed risk level of the compliance incident recurring after corrective actions have been implemented.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'The date on which the regulatory body was formally notified of the compliance incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Method' ;
    rdfs:comment 'The method used to notify the regulatory body of the compliance incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether the compliance incident requires formal notification to the regulatory body under applicable reporting obligations.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Analysis of the underlying root cause(s) of the compliance incident, including process failures, system defects, human error, or policy gaps.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Assessed severity of the compliance incident based on potential regulatory impact, financial exposure, and reputational risk.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationSubmitted rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Submitted' ;
    rdfs:comment 'Indicates whether the required compliance certifications (EEO, children\'s programming, political file, etc.) were submitted as part of the renewal application.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionsImposed rdf:type rdf:Property ;
    rdfs:label 'Conditions Imposed' ;
    rdfs:comment 'Any special conditions, restrictions, or requirements imposed by the regulatory authority as part of the renewal grant (e.g., compliance reporting, technical upgrades, programming commitments).' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialDate rdf:type rdf:Property ;
    rdfs:label 'Denial Date' ;
    rdfs:comment 'The date the regulatory authority officially denied the license renewal application.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'The regulatory authority\'s stated reason for denying the license renewal (e.g., failure to meet public interest standard, character qualifications, technical violations).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Date' ;
    rdfs:comment 'The date the renewal filing fee was paid to the regulatory authority.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feePaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Status' ;
    rdfs:comment 'The current status of the renewal fee payment obligation.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDeadline rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline' ;
    rdfs:comment 'The regulatory deadline by which the renewal application must be submitted to avoid license lapse (typically 4 months prior to expiration for FCC).' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalDisposition rdf:type rdf:Property ;
    rdfs:label 'Final Disposition' ;
    rdfs:comment 'The ultimate outcome of the license renewal application process.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newLicenseTermEndDate rdf:type rdf:Property ;
    rdfs:label 'New License Term End Date' ;
    rdfs:comment 'The expiration date of the renewed license term, establishing the next renewal cycle.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:newLicenseTermStartDate rdf:type rdf:Property ;
    rdfs:label 'New License Term Start Date' ;
    rdfs:comment 'The effective start date of the renewed license term following approval.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:petitionCount rdf:type rdf:Property ;
    rdfs:label 'Petition Count' ;
    rdfs:comment 'The total number of petitions to deny filed against this renewal application.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:petitionToDenyFiled rdf:type rdf:Property ;
    rdfs:label 'Petition To Deny Filed' ;
    rdfs:comment 'Indicates whether any party filed a formal petition to deny the license renewal during the public comment period.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicCommentDeadline rdf:type rdf:Property ;
    rdfs:label 'Public Comment Deadline' ;
    rdfs:comment 'The deadline by which the public may file comments or petitions to deny the renewal application.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicInspectionFileUpdated rdf:type rdf:Property ;
    rdfs:label 'Public Inspection File Updated' ;
    rdfs:comment 'Indicates whether the station\'s public inspection file has been updated with the renewal application and related documents as required by regulation.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Public Notice Date' ;
    rdfs:comment 'The date the regulatory body published public notice of the renewal application, opening the period for public comment and petitions to deny.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalCycleEndDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Cycle End Date' ;
    rdfs:comment 'The date marking the expiration of the current license term, triggering the renewal requirement.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalCycleStartDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Cycle Start Date' ;
    rdfs:comment 'The date marking the beginning of the current license term that is subject to renewal.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Amount' ;
    rdfs:comment 'The regulatory filing fee amount required for processing the license renewal application.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the renewal fee (e.g., USD, GBP, CAD).' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'The date the regulatory authority completed its review and issued a final decision on the renewal application.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FCC political advertising records require compliance officer review for equal time and reasonable access rules. Tracking reviewer employee is essential for audit trail and accountability.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advertiserType rdf:type rdf:Property ;
    rdfs:label 'Advertiser Type' ;
    rdfs:comment 'Classification of the political advertiser entity type for regulatory reporting and rate determination purposes.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affidavitIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Affidavit Issued Flag' ;
    rdfs:comment 'Indicates whether a broadcast affidavit (proof of performance) has been issued to the advertiser confirming that this political ad aired as scheduled.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equalOpportunitiesRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Equal Opportunities Request Flag' ;
    rdfs:comment 'Indicates whether this ad placement was triggered by an equal opportunities request under Section 315 of the Communications Act, requiring equal treatment of opposing candidates.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'Governmental jurisdiction level of the race or ballot measure (federal, state, or local) for compliance categorization and public file organization.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lucPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Luc Period Flag' ;
    rdfs:comment 'Indicates whether this ad aired during the Lowest Unit Charge (LUC) period (45 days before primary or 60 days before general election) when special rate protections apply to candidate ads.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lucRate rdf:type rdf:Property ;
    rdfs:label 'Luc Rate' ;
    rdfs:comment 'The lowest unit charge rate applicable to this spot based on the rate class and daypart during the pre-election window (45 days before primary, 60 days before general election). Null if outside LUC period.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:officeSought rdf:type rdf:Property ;
    rdfs:label 'Office Sought' ;
    rdfs:comment 'The elected office or ballot measure that the political advertisement relates to (e.g., President, U.S. Senate, Governor, State Representative, Proposition 22).' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Preemption Flag' ;
    rdfs:comment 'Indicates whether this scheduled political ad spot was preempted and did not air as originally scheduled. Triggers makegood obligations.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Name of the television or radio program during which the political advertisement aired. Required for public file disclosure.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicFileDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Public File Disclosure Date' ;
    rdfs:comment 'Date when this political ad record was uploaded to the stations online public inspection file as required by FCC rules. Must occur immediately upon ad placement.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateCharged rdf:type rdf:Property ;
    rdfs:label 'Rate Charged' ;
    rdfs:comment 'Actual dollar amount charged to the political advertiser for this spot placement. Must comply with Lowest Unit Charge (LUC) requirements during pre-election windows.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonableAccessRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Reasonable Access Request Flag' ;
    rdfs:comment 'Indicates whether this ad placement was the result of a federal candidate reasonable access request under Section 312(a)(7) of the Communications Act, requiring broadcasters to provide reasonable access to federal candidates.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorAddress rdf:type rdf:Property ;
    rdfs:label 'Sponsor Address' ;
    rdfs:comment 'Mailing address of the political advertiser or sponsor. Required for public inspection file disclosure.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorEmail rdf:type rdf:Property ;
    rdfs:label 'Sponsor Email' ;
    rdfs:comment 'Email address of the political advertiser or sponsor contact for correspondence and compliance communication.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorPhone rdf:type rdf:Property ;
    rdfs:label 'Sponsor Phone' ;
    rdfs:comment 'Contact telephone number for the political advertiser or sponsor. Required for public file records.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipIdentification rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Identification' ;
    rdfs:comment 'The on-air sponsorship disclosure statement identifying who paid for the advertisement (e.g., \'Paid for by Committee to Elect Jane Smith\'). Required by FCC sponsorship identification rules.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedHandlerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Handler Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GDPR/CCPA privacy requests (access, deletion, portability) must be assigned to specific employees for fulfillment tracking and regulatory deadline compliance. Assigned handler text should be FK.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dataCategoriesInvolved rdf:type rdf:Property ;
    rdfs:label 'Data Categories Involved' ;
    rdfs:comment 'Comma-separated list of data categories involved in the request (e.g., subscriber profile, viewing history, payment data, device identifiers). Used for scope tracking and audit.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataVolumeProcessed rdf:type rdf:Property ;
    rdfs:label 'Data Volume Processed' ;
    rdfs:comment 'Total volume of data processed for this request in megabytes, used for operational metrics and resource planning.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedDeadline rdf:type rdf:Property ;
    rdfs:label 'Extended Deadline' ;
    rdfs:comment 'New deadline date if an extension was granted. GDPR allows up to 3 months total; CCPA allows up to 90 days total.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionGranted rdf:type rdf:Property ;
    rdfs:label 'Extension Granted' ;
    rdfs:comment 'Indicates whether a deadline extension was granted due to request complexity or volume. GDPR allows 2-month extension; CCPA allows 45-day extension.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionReason rdf:type rdf:Property ;
    rdfs:label 'Extension Reason' ;
    rdfs:comment 'Business justification for granting a deadline extension, such as request complexity, high volume of requests, or technical challenges.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingTimeHours rdf:type rdf:Property ;
    rdfs:label 'Processing Time Hours' ;
    rdfs:comment 'Total staff hours spent processing this request, used for cost tracking and efficiency analysis.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Deadline' ;
    rdfs:comment 'Calculated deadline for responding to the request based on regulatory requirements: 30 calendar days for GDPR, 45 calendar days for CCPA, from submission date.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Externally-visible unique identifier for the privacy request, used in communications with data subjects and regulators.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the privacy request: submitted (received), under_review (initial assessment), identity_verification (verifying requestor), in_progress (fulfilling), completed (closed successfully), rejected (denied with justification), withdrawn (cancelled by requestor). [ENUM-REF-CANDIDATE: submitted|under_review|identity_verification|in_progress|completed|rejected|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Type of data subject rights request: access (right to know), erasure (right to delete), portability (data export), rectification (correction), restriction (processing limitation), or opt_out_sale (CCPA opt-out).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorEmail rdf:type rdf:Property ;
    rdfs:label 'Requestor Email' ;
    rdfs:comment 'Primary email address of the data subject for request correspondence and response delivery.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Requestor Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the data subject\'s jurisdiction, used to determine applicable privacy law (e.g., DEU for Germany/GDPR, USA for US/CCPA).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full legal name of the data subject submitting the privacy request.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorPhone rdf:type rdf:Property ;
    rdfs:label 'Requestor Phone' ;
    rdfs:comment 'Contact phone number of the data subject for identity verification and request follow-up.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'Date when the response was delivered to the data subject, marking completion of the request.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseMethod rdf:type rdf:Property ;
    rdfs:label 'Response Method' ;
    rdfs:comment 'Method used to deliver the response to the data subject: email (encrypted), secure_portal (download link), mail (postal), phone (verbal), or in_person.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Channel through which the privacy request was submitted: web_form (online portal), email, phone (call center), mail (postal), mobile_app, or chat (live support).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when the privacy request was submitted by the data subject. Used to calculate regulatory deadline (30 days GDPR, 45 days CCPA).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:systemsAccessed rdf:type rdf:Property ;
    rdfs:label 'Systems Accessed' ;
    rdfs:comment 'Comma-separated list of internal systems queried to fulfill the request (e.g., Zuora, Adobe Experience Platform, Akamai CDN logs). Used for audit trail and completeness verification.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalDocumentPublicInspectionFileId rdf:type rdf:Property ;
    rdfs:label 'Original Document Public Inspection File Id' ;
    rdfs:comment 'If this is an amendment, reference to the original public inspection file document being amended or corrected.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PublicInspectionFile .

ind:uploadedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Uploaded By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FCC public inspection file documents require audit trail of which employee uploaded each document for compliance verification and accountability. Compliance officer name should reference employee reco' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'The FCC-mandated category of the public inspection file document. Categories include political file (advertising records), EEO reports (equal employment opportunity), ownership reports, issues/programs lists, children\'s programming reports, and contour maps.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDescription rdf:type rdf:Property ;
    rdfs:label 'Document Description' ;
    rdfs:comment 'Detailed description of the document content, purpose, and any relevant context for public inspection.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFileFormat rdf:type rdf:Property ;
    rdfs:label 'Document File Format' ;
    rdfs:comment 'The file format of the stored document (e.g., PDF, DOCX, XLSX). FCC typically requires PDF format for OPIF submissions.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFilePath rdf:type rdf:Property ;
    rdfs:label 'Document File Path' ;
    rdfs:comment 'The storage location or URI of the document file in the media asset management system or document repository.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Document File Size Bytes' ;
    rdfs:comment 'The size of the document file in bytes.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Document Period End Date' ;
    rdfs:comment 'The end date of the reporting period covered by this document.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Document Period Start Date' ;
    rdfs:comment 'The start date of the reporting period covered by this document (e.g., for quarterly EEO reports or issues/programs lists).' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'The descriptive title or name of the public inspection file document.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fccOpifSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Fcc Opif Sync Status' ;
    rdfs:comment 'Synchronization status with the FCC\'s Online Public Inspection File portal. Indicates whether the document has been successfully transmitted to and accepted by the FCC system.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fccOpifSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fcc Opif Sync Timestamp' ;
    rdfs:comment 'The date and time of the last successful synchronization with the FCC OPIF portal.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fccReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Fcc Reference Number' ;
    rdfs:comment 'The unique reference or confirmation number assigned by the FCC OPIF system upon successful document submission.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAmendment rdf:type rdf:Property ;
    rdfs:label 'Is Amendment' ;
    rdfs:comment 'Indicates whether this document is an amendment or correction to a previously filed public inspection file document.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:politicalAdvertiserName rdf:type rdf:Property ;
    rdfs:label 'Political Advertiser Name' ;
    rdfs:comment 'For political file documents, the name of the candidate, campaign, or political organization that purchased advertising time. Required for political file category documents.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicAccessStatus rdf:type rdf:Property ;
    rdfs:label 'Public Access Status' ;
    rdfs:comment 'Indicates whether the document is currently available for public inspection. Documents may be restricted during review or removed after retention period expiration.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiration Date' ;
    rdfs:comment 'The date when the regulatory retention period expires and the document may be removed from the public inspection file.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'The number of years this document must be retained in the public inspection file as mandated by FCC regulations. Varies by document category (e.g., 2 years for political files, 8 years for ownership reports).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uploadStatus rdf:type rdf:Property ;
    rdfs:label 'Upload Status' ;
    rdfs:comment 'Current status of the document upload to the FCC OPIF (Online Public Inspection File) portal. Tracks the lifecycle from pending submission through verification and archival.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upload Timestamp' ;
    rdfs:comment 'The date and time when the document was successfully uploaded to the FCC OPIF portal or internal public inspection file system.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affectedBusinessUnits rdf:type rdf:Property ;
    rdfs:label 'Affected Business Units' ;
    rdfs:comment 'Comma-separated list of business units, departments, or divisions impacted by the regulatory change (e.g., Broadcasting Operations, Digital Platforms, Legal, Finance).' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedObligationsCount rdf:type rdf:Property ;
    rdfs:label 'Affected Obligations Count' ;
    rdfs:comment 'Number of existing regulatory obligations that are modified, superseded, or created by this change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'Business identifier or reference number assigned to this regulatory change by the compliance team or regulatory body.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory change: proposed, under review, approved, effective (in force), deferred, or withdrawn.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'The nature of the regulatory change: new rule, amendment to existing rule, repeal, guidance update, interpretation clarification, or technical standard update.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated cost (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationUrl rdf:type rdf:Property ;
    rdfs:label 'Documentation Url' ;
    rdfs:comment 'URL link to the official regulatory documentation, Federal Register notice, or issuing body\'s publication page.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Amount' ;
    rdfs:comment 'Estimated financial cost to implement the regulatory change, including system modifications, training, and process updates.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Assessment of the regulatory change\'s impact on the organization\'s operations, systems, and compliance posture: critical, high, medium, low, or minimal.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactDescription rdf:type rdf:Property ;
    rdfs:label 'Impact Description' ;
    rdfs:comment 'Detailed narrative describing how the regulatory change affects the organization, including operational, technical, and financial implications.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Completion Date' ;
    rdfs:comment 'The date when implementation was completed and the organization achieved full compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationPlan rdf:type rdf:Property ;
    rdfs:label 'Implementation Plan' ;
    rdfs:comment 'Summary of the plan to implement the regulatory change, including key milestones, resource requirements, and system modifications.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationStartDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Start Date' ;
    rdfs:comment 'The date when implementation activities for this regulatory change began.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current status of the organization\'s implementation efforts: not started, planning, in progress, testing, completed, or deferred.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'The regulatory authority or governing body that issued the change (e.g., FCC, Ofcom, European Commission, MPA, ATSC).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationCommentSubmitted rdf:type rdf:Property ;
    rdfs:label 'Organization Comment Submitted' ;
    rdfs:comment 'Indicates whether the organization submitted formal comments during the public comment period (True/False).' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicCommentPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Public Comment Period End' ;
    rdfs:comment 'End date of the public comment period for proposed regulatory changes, if applicable.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicCommentPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Public Comment Period Start' ;
    rdfs:comment 'Start date of the public comment period for proposed regulatory changes, if applicable.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'The date when the regulatory change was officially published or announced by the issuing body.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulationName rdf:type rdf:Property ;
    rdfs:label 'Regulation Name' ;
    rdfs:comment 'The name or title of the regulation being changed (e.g., FCC Part 73, GDPR Article 5, ATSC 3.0 Standard).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference Number' ;
    rdfs:comment 'Official reference number or citation of the regulation (e.g., 47 CFR 73.1201, ISO 14496-10).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedChanges rdf:type rdf:Property ;
    rdfs:label 'Related Changes' ;
    rdfs:comment 'Comma-separated list of related regulatory change identifiers or reference numbers that are connected to this change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffDate rdf:type rdf:Property ;
    rdfs:label 'Sign Off Date' ;
    rdfs:comment 'The date when the compliance officer formally signed off on the implementation of this regulatory change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signOffStatus rdf:type rdf:Property ;
    rdfs:label 'Sign Off Status' ;
    rdfs:comment 'Status of formal sign-off by the compliance officer: pending, approved, rejected, or conditional approval.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesRegulationReference rdf:type rdf:Property ;
    rdfs:label 'Supersedes Regulation Reference' ;
    rdfs:comment 'Reference number or identifier of the previous regulation that this change supersedes or replaces, if applicable.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Filed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory filings (FCC Form 323, 396, etc.) require audit trail of which employee submitted the filing for compliance verification and accountability. Responsible party data should reference employee' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:originalFilingRegulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Original Filing Regulatory Filing Id' ;
    rdfs:comment 'Reference to the original regulatory filing identifier if this submission is an amendment or correction, establishing the lineage of filing revisions.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:amendmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this filing is an amendment or correction to a previously submitted filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'The primary regulatory compliance domain or category that this filing addresses, such as broadcast licensing, content standards, data privacy, financial reporting, accessibility mandates, or technical standards.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'The unique confirmation or receipt number issued by the regulatory body upon successful submission of the filing, serving as proof of receipt.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'The Uniform Resource Locator (URL) or file path to the digital copy of the filed document stored in the Media Asset Management (MAM) system or document repository.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Description' ;
    rdfs:comment 'A detailed textual description of the filing content, purpose, and scope, providing context for the regulatory submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Amount' ;
    rdfs:comment 'The monetary fee charged by the regulatory body for processing this filing, expressed in the broadcaster\'s reporting currency.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Currency' ;
    rdfs:comment 'The three-letter International Organization for Standardization (ISO) 4217 currency code for the filing fee amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Number' ;
    rdfs:comment 'The externally-known unique filing number or reference code assigned by the broadcaster or regulatory body for tracking and identification purposes.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory filing indicating its progress through the submission and approval workflow. [ENUM-REF-CANDIDATE: draft|submitted|accepted|rejected|under_review|pending_correction|completed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'The category or type of regulatory filing being submitted, such as Equal Employment Opportunity (EEO) report, ownership report, political file, children\'s programming report, annual report, license renewal application, or public inspection file entry. [ENUM-REF-CANDIDATE: eeo_report|ownership_report|political_file|childrens_programming_report|annual_report|license_renewal|public_inspection_file — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formNumber rdf:type rdf:Property ;
    rdfs:label 'Form Number' ;
    rdfs:comment 'The official form number or identifier designated by the regulatory body for this filing type (e.g., FCC Form 323, FCC Form 396, Ofcom Form 1).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketDesignation rdf:type rdf:Property ;
    rdfs:label 'Market Designation' ;
    rdfs:comment 'The designated market area or geographic market served by the broadcast facility, as defined by Nielsen or equivalent measurement authority.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFilingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Filing Due Date' ;
    rdfs:comment 'The anticipated due date for the next recurring filing of this type, supporting proactive compliance planning and calendar management.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Confirmation Number' ;
    rdfs:comment 'The confirmation or transaction number for the filing fee payment, linking the financial transaction to the regulatory submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Public Inspection Required' ;
    rdfs:comment 'Boolean indicator specifying whether this filing must be made available for public inspection as required by regulatory transparency mandates.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'The end date of the time period covered by this regulatory filing, defining the conclusion of the reporting window for compliance data.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'The start date of the time period covered by this regulatory filing, defining the beginning of the reporting window for compliance data.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxApplicable rdf:type rdf:Property ;
    rdfs:label 'Sox Applicable' ;
    rdfs:comment 'Boolean indicator specifying whether this filing is subject to Sarbanes-Oxley Act (SOX) financial reporting and internal control requirements.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'The channel or mechanism through which the filing was submitted to the regulatory body, such as online portal, email, postal mail, fax, electronic filing system, or Application Programming Interface (API).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByObligationRegulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Obligation Regulatory Obligation Id' ;
    rdfs:comment 'Reference to the regulatory obligation that supersedes this one, if applicable. Null if not superseded.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Business units, platforms, or services to which this obligation applies (e.g., linear TV, OTT platforms, radio, digital publishers, SVOD services, AVOD platforms, FAST channels).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Indicates whether an audit trail of compliance activities and decisions must be maintained for this obligation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Frequency' ;
    rdfs:comment 'How often compliance with this obligation must be demonstrated or reported: ongoing (continuous), annual, quarterly, monthly, event-driven (triggered by specific events), or biennial.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Documentation Retention Years' ;
    rdfs:comment 'Number of years that compliance documentation must be retained, as mandated by the regulation or internal policy.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalReportingRequired rdf:type rdf:Property ;
    rdfs:label 'External Reporting Required' ;
    rdfs:comment 'Indicates whether compliance with this obligation requires formal reporting or filing to an external regulatory body.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingDeadlineDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Description' ;
    rdfs:comment 'Human-readable description of the filing deadline (e.g., \'April 1 annually\', \'10 days after broadcast\', \'within 30 days of license expiration\').' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDeadlineType rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Type' ;
    rdfs:comment 'Type of deadline for compliance filing or reporting: fixed date (specific calendar date), rolling (X days from event), event-based (triggered by business event), or not applicable.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed description of the regulatory obligation, including what must be done, reported, or maintained to achieve compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedPolicyDocument rdf:type rdf:Property ;
    rdfs:label 'Related Policy Document' ;
    rdfs:comment 'Reference to internal policy, procedure, or guideline document that governs how this obligation is implemented and monitored.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensatingControlId rdf:type rdf:Property ;
    rdfs:label 'Compensating Control Id' ;
    rdfs:comment 'Reference to another SOX control that serves as a compensating control if this control fails or is temporarily inactive. Compensating controls provide alternative assurance over the same financial reporting risk.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoxControl .

ind:controlOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Control Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: SOX controls require named employee owners for accountability in financial reporting compliance. Control owner text should reference employee record for audit trail and performance tracking.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assertionCategory rdf:type rdf:Property ;
    rdfs:label 'Assertion Category' ;
    rdfs:comment 'The financial statement assertion that this control addresses. Existence ensures recorded transactions occurred; completeness ensures all transactions are recorded; accuracy ensures amounts are correct; valuation ensures proper measurement; rights and obligations ensure the entity has legal claim; presentation and disclosure ensure proper classification and disclosure; cutoff ensures transactions are recorded in the correct period. [ENUM-REF-CANDIDATE: existence|completeness|accuracy|valuation|rights and obligations|presentation and disclosure|cutoff — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorNotes rdf:type rdf:Property ;
    rdfs:label 'Auditor Notes' ;
    rdfs:comment 'Comments and observations from internal or external auditors regarding control design, operating effectiveness, or areas for improvement. Supports audit trail and continuous improvement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Flag' ;
    rdfs:comment 'Indicates whether the control is fully automated (True) or requires manual execution (False). Automated controls are typically embedded in financial systems and execute without human intervention.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlDescription rdf:type rdf:Property ;
    rdfs:label 'Control Description' ;
    rdfs:comment 'Comprehensive description of the control activity, including specific procedures, data sources, systems involved, thresholds, and documentation requirements. For media companies, may reference systems such as Wide Orbit (traffic and billing), Rightsline (rights management), or Zuora (subscription billing).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDocumentationPath rdf:type rdf:Property ;
    rdfs:label 'Control Documentation Path' ;
    rdfs:comment 'File path or document management system reference to the detailed control documentation, including procedures, flowcharts, and testing workpapers. Used for audit evidence and compliance verification.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlFrequency rdf:type rdf:Property ;
    rdfs:label 'Control Frequency' ;
    rdfs:comment 'How often the control is performed or operates. Continuous controls run automatically in real-time (e.g., system validations); periodic controls are executed at defined intervals; event-driven controls are triggered by specific business events (e.g., contract execution, content release). [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|annual|event-driven — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlName rdf:type rdf:Property ;
    rdfs:label 'Control Name' ;
    rdfs:comment 'Short descriptive name of the control that summarizes its purpose (e.g., \'Advertising Revenue Recognition Review\', \'Subscriber Billing Reconciliation\').' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlNumber rdf:type rdf:Property ;
    rdfs:label 'Control Number' ;
    rdfs:comment 'Business identifier for the control, typically formatted as a prefix code followed by a numeric sequence (e.g., FIN-001, REV-1234). Used for external reference and audit documentation.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlObjective rdf:type rdf:Property ;
    rdfs:label 'Control Objective' ;
    rdfs:comment 'Detailed statement of what the control is designed to achieve, including the specific financial reporting assertion it addresses (existence, completeness, accuracy, valuation, rights and obligations, presentation and disclosure).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlStatus rdf:type rdf:Property ;
    rdfs:label 'Control Status' ;
    rdfs:comment 'Current operational status of the control. Active controls are in effect; inactive controls are temporarily suspended; under remediation indicates deficiencies are being addressed; pending implementation means the control is designed but not yet operational; retired controls are no longer applicable.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Classification of the control based on its nature and timing. Preventive controls stop errors before they occur; detective controls identify errors after occurrence; IT general controls (ITGC) govern system access and change management; IT application controls are embedded in financial systems; entity-level controls address governance and culture; management review controls involve oversight and analysis.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyClassification rdf:type rdf:Property ;
    rdfs:label 'Deficiency Classification' ;
    rdfs:comment 'Severity classification of any identified control deficiency. No deficiency means the control is effective; control deficiency is a minor issue unlikely to result in misstatement; significant deficiency is important enough to merit attention by those charged with governance; material weakness is a deficiency or combination of deficiencies that creates a reasonable possibility of material misstatement not being prevented or detected.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyDescription rdf:type rdf:Property ;
    rdfs:label 'Deficiency Description' ;
    rdfs:comment 'Detailed explanation of any identified control deficiency, including the nature of the failure, root cause analysis, and potential impact on financial reporting. Null if no deficiency exists.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementLineItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Line Item' ;
    rdfs:comment 'The specific financial statement account or line item that this control impacts (e.g., \'Advertising Revenue\', \'Subscription Revenue\', \'Content Amortization Expense\', \'Accounts Receivable\', \'Deferred Revenue\'). Maps control to financial reporting impact.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyControlFlag rdf:type rdf:Property ;
    rdfs:label 'Key Control Flag' ;
    rdfs:comment 'Indicates whether this is a key control (True) that directly addresses a significant risk to financial reporting, or a supporting control (False). Key controls receive more rigorous testing and documentation.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Test Date' ;
    rdfs:comment 'The most recent date on which the control was formally tested for design and operating effectiveness by internal audit, external auditors, or control owners.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementAssertionMapping rdf:type rdf:Property ;
    rdfs:label 'Management Assertion Mapping' ;
    rdfs:comment 'Mapping of this control to management\'s assertions under SOX Section 302 (CEO/CFO certification) and Section 404 (internal control over financial reporting). Documents how this control supports management\'s ability to assert the effectiveness of internal controls.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processArea rdf:type rdf:Property ;
    rdfs:label 'Process Area' ;
    rdfs:comment 'The business process or financial cycle to which this control applies. Media-specific areas include advertising revenue recognition (CPM, GRP-based billing), carriage fee billing (MVPD/vMVPD distribution payments), subscriber billing (SVOD, TVOD), content licensing revenue (syndication, windowing), rights royalty accruals (talent residuals, music licensing), and barter transactions (ad inventory exchanges). [ENUM-REF-CANDIDATE: advertising revenue recognition|carriage fee billing|subscriber billing|content licensing revenue|rights royalty accruals|barter transactions|production cost capitalization|content amortization|deferred revenue|accounts receivable|accounts payable|payroll|treasury|tax compliance|financial close|general ledger|fixed assets|inventory|intercompany transactions — 19 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Action plan to address identified deficiencies, including specific corrective actions, responsible parties, and target completion dates. Null if no remediation is required.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationTargetDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Target Date' ;
    rdfs:comment 'Target date by which remediation activities are expected to be completed and validated. Null if no remediation is required.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date on which the control was retired or superseded by another control. Null for active controls. Used for historical tracking and audit trail.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:systemName rdf:type rdf:Property ;
    rdfs:label 'System Name' ;
    rdfs:comment 'Name of the primary financial or operational system in which the control is executed or from which control evidence is derived (e.g., \'SAP S/4HANA FI\', \'Wide Orbit Traffic\', \'Zuora Billing\', \'Rightsline Rights Management\').' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFrequency rdf:type rdf:Property ;
    rdfs:label 'Test Frequency' ;
    rdfs:comment 'How often the control is formally tested for effectiveness. Quarterly testing is typical for key controls; annual testing may suffice for lower-risk controls; event-driven testing occurs when significant changes are made to the control or underlying process.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResult rdf:type rdf:Property ;
    rdfs:label 'Test Result' ;
    rdfs:comment 'Outcome of the most recent control test. Effective means the control operated as designed with no exceptions; ineffective with exception indicates isolated failures that do not rise to a deficiency; ineffective means the control did not operate as designed; not tested means no evaluation has been performed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalStandardCertId rdf:type rdf:Property ;
    rdfs:label 'Technical Standard Cert Id' ;
    rdfs:comment 'Unique identifier for the technical standard certification record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechnicalStandardCert .

ind:applicablePlatform rdf:type rdf:Property ;
    rdfs:label 'Applicable Platform' ;
    rdfs:comment 'Platform or transmission system to which this certification applies (e.g., OTT streaming, linear broadcast, cable, satellite, IPTV).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateFilePath rdf:type rdf:Property ;
    rdfs:label 'Certificate File Path' ;
    rdfs:comment 'File path or storage location of the digital certificate document.' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique certificate number or identifier issued by the certification body.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the organization or authority that issued the certification (e.g., ATSC, DVB Project, SCTE, ISO, independent testing lab).' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date when the certification was officially granted by the certification body.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the certification expires and recertification is required.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current status of the certification (certified, non-compliant, pending, expired, under review, waived).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Description of corrective actions taken or planned to address non-conformance issues.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether corrective action is required to address non-conformance issues (true/false).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentIdentifier rdf:type rdf:Property ;
    rdfs:label 'Equipment Identifier' ;
    rdfs:comment 'Serial number, asset tag, or unique identifier of the equipment or system component being certified.' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonConformanceCount rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Count' ;
    rdfs:comment 'Number of non-conformance issues identified during the certification test.' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nonConformanceDetails rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Details' ;
    rdfs:comment 'Detailed description of any non-conformance issues, deviations, or exceptions identified during testing.' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Recertification Due Date' ;
    rdfs:comment 'Date by which recertification must be completed to maintain compliance.' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Recertification Required' ;
    rdfs:comment 'Indicates whether recertification is required before the expiry date (true/false).' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Specific regulatory requirement or mandate that this certification fulfills (e.g., FCC Part 73, Ofcom Code).' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCategory rdf:type rdf:Property ;
    rdfs:label 'Standard Category' ;
    rdfs:comment 'Category of the technical standard (transmission, encoding, streaming, ad insertion, loudness normalization, accessibility, metadata, security). [ENUM-REF-CANDIDATE: transmission|encoding|streaming|ad_insertion|loudness|accessibility|metadata|security — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardName rdf:type rdf:Property ;
    rdfs:label 'Standard Name' ;
    rdfs:comment 'Name of the broadcast technical standard being certified (e.g., ATSC 3.0, DVB-T2, MPEG-4, HEVC, HLS, MPEG-DASH, SCTE-35).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardVersion rdf:type rdf:Property ;
    rdfs:label 'Standard Version' ;
    rdfs:comment 'Version or release number of the technical standard (e.g., 3.0, T2, Part 10, 1.0).' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'Date when the technical standard compliance test was conducted.' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testReportReference rdf:type rdf:Property ;
    rdfs:label 'Test Report Reference' ;
    rdfs:comment 'Reference number or identifier of the official test report document.' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testScore rdf:type rdf:Property ;
    rdfs:label 'Test Score' ;
    rdfs:comment 'Numeric score or percentage achieved in the compliance test, if applicable.' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testingLabName rdf:type rdf:Property ;
    rdfs:label 'Testing Lab Name' ;
    rdfs:comment 'Name of the independent testing laboratory or facility that conducted the compliance test.' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionSystem rdf:type rdf:Property ;
    rdfs:label 'Transmission System' ;
    rdfs:comment 'Specific transmission system or infrastructure component being certified (e.g., encoder model, playout server, CDN node, IRD).' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Id' ;
    rdfs:comment 'Primary key for acquisition' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountsPayableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Payable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_payable. Business justification: Content acquisition deals create payment obligations to licensors/distributors. AP tracks amounts owed under acquisition agreements for cash flow forecasting, payment scheduling, and vendor relationsh' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsPayable .

ind:contentVersionId rdf:type rdf:Property ;
    rdfs:label 'Content Version Id' ;
    rdfs:comment 'Foreign key linking to content.version. Business justification: Acquisitions often specify which version was acquired (theatrical vs broadcast cut, localized version). This FK allows tracking version-specific acquisition terms and rights.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:payableInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Payable Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Content acquisition deals generate payable invoices to rights holders. Accounts payable teams track which invoices correspond to acquisition agreements for payment scheduling, rights verification, cos' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'The date on which the acquisition transaction was executed and the content rights were legally transferred or licensed to the enterprise. Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acquisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Acquisition Status' ;
    rdfs:comment 'Current lifecycle state of the acquisition. Negotiating = deal in discussion; Committed = contract signed but content not yet delivered; Delivered = content received and ingested; Active = content in use; Cancelled = deal terminated before delivery; Expired = license period ended.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionType rdf:type rdf:Property ;
    rdfs:label 'Acquisition Type' ;
    rdfs:comment 'Classification of the acquisition method. Purchase = outright ownership transfer; License = time-limited rights; Co-production = joint production investment; Commission = original content commissioned from producer; Barter = content exchanged for advertising inventory; Syndication = content licensed from syndicator for regional broadcast.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillaryRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Ancillary Rights Flag' ;
    rdfs:comment 'Indicates whether ancillary rights (merchandising, soundtrack, publishing, remake, sequel, spin-off, clip licensing) are included in the acquisition (True) or retained by the supplier (False).' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Status' ;
    rdfs:comment 'Rights verification status confirming that all necessary clearances (music rights, talent rights, third-party content, trademarks) have been obtained for broadcast or distribution. Pending = verification in progress; Cleared = all rights confirmed; Restricted = partial clearance with limitations; Failed = clearance issues prevent exploitation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentWindowType rdf:type rdf:Property ;
    rdfs:label 'Content Window Type' ;
    rdfs:comment 'The distribution window or rights category acquired. Windowing refers to the sequential release strategy where content is made available through different channels over time. Theatrical = cinema release; Home Video = physical/digital sell-through; SVOD = Subscription Video On Demand; AVOD = Advertising-Supported Video On Demand; TVOD = Transactional Video On Demand; Linear Broadcast = traditional scheduled TV; Syndication = resale to multiple outlets; All Rights = comprehensive rights across all windows. [ENUM-REF-CANDIDATE: theatrical|home_video|svod|avod|tvod|linear_broadcast|syndication|all_rights — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'The total monetary value paid or committed for acquiring the content rights. Represents the base acquisition cost before taxes, fees, or adjustments. For licenses, this is the total license fee; for purchases, the purchase price; for commissions, the production budget committed.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryFormat rdf:type rdf:Property ;
    rdfs:label 'Delivery Format' ;
    rdfs:comment 'The technical format and delivery method used by the supplier to provide the content. Examples: ProRes 422 HQ via FTP, IMF package via Aspera, DCP hard drive, MPEG-4 via CDN, tape (legacy).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the acquired rights are exclusive (True) or non-exclusive (False) within the specified territory and window. Exclusive rights prevent the supplier from licensing the same content to competitors in the same territory/window.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formatRights rdf:type rdf:Property ;
    rdfs:label 'Format Rights' ;
    rdfs:comment 'The technical formats or delivery specifications covered by the acquisition. May include SD, HD, 4K, HDR, theatrical DCP, broadcast master, streaming-optimized, etc. Defines the quality and format tiers the enterprise is authorized to distribute.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Holdback Period Days' ;
    rdfs:comment 'The number of days during which the content cannot be exploited in certain windows or territories as stipulated by the acquisition agreement. Holdback periods protect prior windows (e.g., theatrical holdback prevents SVOD release for 90 days post-theatrical).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageRights rdf:type rdf:Property ;
    rdfs:label 'Language Rights' ;
    rdfs:comment 'The languages or language versions for which rights were acquired. May specify original language only, dubbed versions, subtitled versions, or all language adaptations. Examples: English, Spanish, French; All Languages; Original + Subtitles.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Amount' ;
    rdfs:comment 'The minimum guaranteed payment to the supplier regardless of actual revenue performance. Common in revenue-sharing deals where the enterprise commits to a floor payment even if royalties do not reach this threshold.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualsObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Residuals Obligation Flag' ;
    rdfs:comment 'Indicates whether the enterprise has an obligation to pay residuals (talent reuse payments) to performers, writers, directors, or other rights holders each time the content is rebroadcast or redistributed (True) or if residuals are the supplier\'s responsibility (False).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percent' ;
    rdfs:comment 'The percentage of revenue or receipts that must be paid to the supplier as ongoing royalties under a revenue-sharing acquisition model. Null if the acquisition is a flat-fee structure with no revenue share.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runsAllowed rdf:type rdf:Property ;
    rdfs:label 'Runs Allowed' ;
    rdfs:comment 'The maximum number of times the content may be broadcast or streamed under the acquisition agreement. Common in linear broadcast licenses (e.g., 3 runs over 2 years). Null indicates unlimited runs within the license period.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runsConsumed rdf:type rdf:Property ;
    rdfs:label 'Runs Consumed' ;
    rdfs:comment 'The number of runs (broadcasts or streams) that have been executed to date against the runs_allowed limit. Tracked to ensure compliance with contractual run restrictions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sublicensingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Allowed Flag' ;
    rdfs:comment 'Indicates whether the enterprise is permitted to sublicense the acquired content to third parties (True) or must exploit the content directly only (False). Sublicensing enables syndication and secondary distribution deals.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryScope rdf:type rdf:Property ;
    rdfs:label 'Territory Scope' ;
    rdfs:comment 'Geographic territories or markets for which the content rights were acquired. May be specified as country codes (ISO 3166), regional groupings, or worldwide. Examples: USA, GBR, North America, EMEA, Worldwide.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artworkId rdf:type rdf:Property ;
    rdfs:label 'Artwork Id' ;
    rdfs:comment 'Unique identifier for the artwork asset record. Primary key for the artwork catalog.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedForUseFlag rdf:type rdf:Property ;
    rdfs:label 'Approved For Use Flag' ;
    rdfs:comment 'Boolean indicator of whether the artwork has passed legal, brand, and creative approval processes and is authorized for public distribution. True indicates approved and ready for use, False indicates pending approval or rejected.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:archiveLocation rdf:type rdf:Property ;
    rdfs:label 'Archive Location' ;
    rdfs:comment 'Physical or logical storage location identifier for the high-resolution master artwork file in the enterprise archive system. May reference tape library, cloud object storage bucket, or network-attached storage (NAS) path. Supports long-term preservation and disaster recovery.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artworkType rdf:type rdf:Property ;
    rdfs:label 'Artwork Type' ;
    rdfs:comment 'Classification of the artwork asset by its intended use and format. Key-art is primary promotional image, thumbnail for Electronic Program Guide (EPG) and streaming UI, banner for web headers, poster for theatrical/retail, logo for branding, still for scene captures.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorProfile rdf:type rdf:Property ;
    rdfs:label 'Color Profile' ;
    rdfs:comment 'Color space standard applied to the artwork for accurate color reproduction across devices and platforms. sRGB for web/digital, Adobe RGB for professional photography, CMYK for print, Rec. 709 for HD broadcast, Rec. 2020 for Ultra HD (UHD) broadcast.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingDisplayedFlag rdf:type rdf:Property ;
    rdfs:label 'Content Rating Displayed Flag' ;
    rdfs:comment 'Boolean indicator of whether the artwork includes a visible Motion Picture Association (MPA) or equivalent content rating badge (G, PG, PG-13, R, NC-17, TV-Y, TV-PG, TV-14, TV-MA). True indicates rating is burned into the image, False indicates clean artwork without rating overlay.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copyrightHolder rdf:type rdf:Property ;
    rdfs:label 'Copyright Holder' ;
    rdfs:comment 'Legal entity or organization that owns the copyright to the artwork asset. May be the production company, studio, distributor, or external agency. Critical for rights clearance and syndication.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copyrightYear rdf:type rdf:Property ;
    rdfs:label 'Copyright Year' ;
    rdfs:comment 'Year in which the artwork was created and copyright was established. Used for copyright notice display and rights duration calculation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eidr rdf:type rdf:Property ;
    rdfs:label 'Eidr' ;
    rdfs:comment 'Universal unique identifier from the Entertainment Identifier Registry for the associated content title. Enables global interoperability and metadata exchange across distribution partners, rights holders, and platforms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Storage size of the artwork file measured in bytes. Used for Content Delivery Network (CDN) optimization, bandwidth planning, and storage capacity management.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:heightPixels rdf:type rdf:Property ;
    rdfs:label 'Height Pixels' ;
    rdfs:comment 'Vertical dimension of the artwork image measured in pixels. Used to determine display suitability and resolution quality for various distribution channels.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageOverlayFlag rdf:type rdf:Property ;
    rdfs:label 'Language Overlay Flag' ;
    rdfs:comment 'Boolean indicator of whether the artwork contains burned-in text, titles, or language-specific graphic elements. True indicates localized artwork requiring territory-specific versions, False indicates language-neutral artwork suitable for all markets.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photographerCredit rdf:type rdf:Property ;
    rdfs:label 'Photographer Credit' ;
    rdfs:comment 'Name or attribution of the photographer, artist, or creative agency responsible for creating the artwork. Used for copyright attribution, residuals tracking, and legal compliance with talent agreements.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric ranking indicating the preferred display order or priority of this artwork when multiple artwork assets exist for the same title and type. Lower numbers indicate higher priority. Used by Electronic Program Guide (EPG) and streaming platform UI to select the primary artwork.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionDpi rdf:type rdf:Property ;
    rdfs:label 'Resolution Dpi' ;
    rdfs:comment 'Image resolution measured in dots per inch. 72 DPI for web/screen display, 300 DPI for high-quality print, 150 DPI for standard print. Critical for determining print suitability and image quality.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Human-readable descriptive title or label for the artwork asset. Used for internal cataloging and search within the Media Asset Management (MAM) system.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRights rdf:type rdf:Property ;
    rdfs:label 'Usage Rights' ;
    rdfs:comment 'Scope of authorized usage channels and media types for the artwork. All-media for unrestricted use, digital-only for Over-The-Top (OTT) and web, print-only for press kits and retail, broadcast-only for linear television, theatrical-only for cinema, promotional-only for advertising and marketing campaigns.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthPixels rdf:type rdf:Property ;
    rdfs:label 'Width Pixels' ;
    rdfs:comment 'Horizontal dimension of the artwork image measured in pixels. Used to determine display suitability and resolution quality for various distribution channels.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory compliance findings must link to the responsible compliance officer for FCC/regulatory reporting, escalation workflows, and accountability tracking. Essential for broadcast license maintena' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rightsTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Rights Territory Id' ;
    rdfs:comment 'Foreign key linking to rights.territory. Business justification: Regulatory compliance findings are territory-specific and tied to territorial rights. Fines, makegoods, and remediation are calculated based on the affected territory\'s regulatory framework.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsTerritory .

ind:violatedLicenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Violated License Agreement Id' ;
    rdfs:comment 'Foreign key linking to rights.license_agreement. Business justification: Compliance violations often stem from license agreement breaches (unauthorized territory, expired rights, platform violations). Audit trails and remediation workflows require linking findings to the v' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:affectedBroadcastDate rdf:type rdf:Property ;
    rdfs:label 'Affected Broadcast Date' ;
    rdfs:comment 'The date on which the content was broadcast or distributed when the compliance issue occurred. Nullable if the finding relates to pre-broadcast content or non-time-specific violations.' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedDaypart rdf:type rdf:Property ;
    rdfs:label 'Affected Daypart' ;
    rdfs:comment 'The broadcast daypart (time segment of broadcast day) during which the compliance issue occurred, relevant for content standards and audience protection regulations (e.g., prime time, children\'s programming hours, late night).' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedPlatform rdf:type rdf:Property ;
    rdfs:label 'Affected Platform' ;
    rdfs:comment 'The distribution platform or channel type where the compliance issue was identified: linear (traditional broadcast), OTT (Over-The-Top), VOD (Video On Demand), SVOD (Subscription Video On Demand), AVOD (Advertising-Supported Video On Demand), TVOD (Transactional Video On Demand), FAST (Free Ad-Supported Streaming Television), streaming, mobile, web. [ENUM-REF-CANDIDATE: linear|OTT|VOD|SVOD|AVOD|TVOD|FAST|streaming|mobile|web — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrail rdf:type rdf:Property ;
    rdfs:label 'Audit Trail' ;
    rdfs:comment 'Comprehensive audit trail documenting all actions, decisions, communications, and status changes related to this compliance finding throughout its lifecycle.' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceType rdf:type rdf:Property ;
    rdfs:label 'Compliance Type' ;
    rdfs:comment 'Category of compliance finding: broadcast_standard (FCC technical violations), content_standard (Ofcom content breach), rating_dispute (MPA rating challenge), accessibility (closed-caption or audio description QC), privacy (COPPA, GDPR violations), blackout_restriction (geographic restriction enforcement).' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Description of the corrective action plan or measures implemented to address the root cause and prevent recurrence of the compliance issue.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'The business department or organizational unit responsible for addressing the compliance finding (e.g., Legal, Compliance, Content Operations, Broadcast Engineering, Digital Distribution).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDate rdf:type rdf:Property ;
    rdfs:label 'Finding Date' ;
    rdfs:comment 'The date on which the compliance finding was identified, logged, or officially reported by the regulatory body or internal compliance team.' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fineAmount rdf:type rdf:Property ;
    rdfs:label 'Fine Amount' ;
    rdfs:comment 'Monetary fine or penalty amount assessed by the regulatory body for this compliance violation. Nullable if no financial penalty was imposed.' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fineCurrency rdf:type rdf:Property ;
    rdfs:label 'Fine Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the fine amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makegoodsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Makegoods Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether compensatory ad spots (makegoods) are required as part of the resolution for advertising-related compliance issues.' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Description of preventive measures, process improvements, or controls implemented to reduce the likelihood of similar compliance issues occurring in the future.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Boolean flag indicating whether this compliance finding is a recurrence of a previously identified issue for the same title or similar content.' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationCost rdf:type rdf:Property ;
    rdfs:label 'Remediation Cost' ;
    rdfs:comment 'Estimated or actual cost incurred by the organization to remediate the compliance issue, including labor, technology, content rework, and process improvements. Nullable if not tracked or not applicable.' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed narrative description of the compliance violation, including the specific standard or regulation breached, the nature of the non-compliance, and any relevant context or circumstances.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentClearanceId rdf:type rdf:Property ;
    rdfs:label 'Content Clearance Id' ;
    rdfs:comment 'Unique identifier for the content clearance record. Primary key for the content clearance entity.' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryContentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Content Employee Id' ;
    rdfs:comment 'Reference to the clearance officer or rights specialist responsible for verifying and approving this clearance. Links to the talent or employee master data.' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:validatingLicenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Validating License Agreement Id' ;
    rdfs:comment 'Foreign key linking to rights.license_agreement. Business justification: Clearance requests validate against license agreement terms before approving content for air. Automated clearance systems check holdbacks, exclusivity, and platform restrictions defined in the agreeme' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:validatingRightsGrantId rdf:type rdf:Property ;
    rdfs:label 'Validating Rights Grant Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_grant. Business justification: Clearance validates specific grant permissions (run counts, platforms, dates, territories). Automated clearance workflows check that the requested exploitation falls within an active grant\'s scope.' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grant .

ind:windowingPlanId rdf:type rdf:Property ;
    rdfs:label 'Windowing Plan Id' ;
    rdfs:comment 'Foreign key linking to content.windowing_plan. Business justification: Clearances are tied to specific distribution windows (theatrical, SVOD, linear broadcast). Links clearance verification to the intended window.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WindowingPlan .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'Detailed explanation of why the clearance was blocked or denied. Captures the specific legal, contractual, or rights-related issue preventing broadcast or distribution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastReadyFlag rdf:type rdf:Property ;
    rdfs:label 'Broadcast Ready Flag' ;
    rdfs:comment 'Boolean indicator of whether the content has passed all clearance requirements and is approved for broadcast or distribution. True indicates the content is ready; false indicates clearance is incomplete or blocked.' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionalTerms rdf:type rdf:Property ;
    rdfs:label 'Conditional Terms' ;
    rdfs:comment 'Specific conditions or restrictions attached to the clearance approval. Examples include geographic blackouts, time-of-day restrictions, or required attribution statements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference to the underlying rights contract or licensing agreement that governs this clearance. Links to the contract management system for full terms and conditions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Boolean indicator of whether the clearance request has been escalated to senior management or legal counsel due to complexity, cost, or urgency. True indicates escalation is active.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the clearance fee amount. Supports multi-currency rights transactions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedPlatform rdf:type rdf:Property ;
    rdfs:label 'Intended Platform' ;
    rdfs:comment 'Target platform or distribution channel for which the clearance is being verified. Clearance requirements vary by platform due to different rights agreements and territorial restrictions. [ENUM-REF-CANDIDATE: linear_broadcast|svod|avod|tvod|fast|ott|theatrical|home_video|syndication — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedTerritory rdf:type rdf:Property ;
    rdfs:label 'Intended Territory' ;
    rdfs:comment 'Geographic territory or market for which the clearance is being verified, represented as a three-letter ISO country code. Rights clearance is often territory-specific due to licensing agreements.' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedWindow rdf:type rdf:Property ;
    rdfs:label 'Intended Window' ;
    rdfs:comment 'Sequential release window for which the clearance is being verified. Windowing strategy determines when and where content can be distributed, and clearance requirements differ by window. [ENUM-REF-CANDIDATE: theatrical|home_video|pay_per_view|premium_cable|basic_cable|broadcast|streaming|syndication — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required Flag' ;
    rdfs:comment 'Boolean indicator of whether the clearance requires formal legal review before approval. True indicates legal counsel must review and sign off on the clearance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightsHolderContact rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Contact' ;
    rdfs:comment 'Primary contact information (email, phone, or address) for the rights holder. Used for clearance negotiation and communication.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolderName rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Name' ;
    rdfs:comment 'Name of the individual or organization that holds the intellectual property rights requiring clearance. May be a music publisher, talent agent, stock footage provider, or other rights owner.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Date' ;
    rdfs:comment 'Target date by which the clearance must be completed to meet scheduling and distribution commitments. Used to track SLA compliance and escalate overdue clearances.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contentSeasonId rdf:type rdf:Property ;
    rdfs:label 'Content Season Id' ;
    rdfs:comment 'Reference to the specific season within the series to which this episode belongs. Enables season-level grouping and rights management.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Season .

ind:contentSeriesId rdf:type rdf:Property ;
    rdfs:label 'Content Series Id' ;
    rdfs:comment 'Reference to the parent series to which this episode belongs. Links episode to its series container.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Series .

ind:masterMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Master Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Broadcast playout and VOD distribution require direct lookup of the master media asset file for each episode. Traffic systems and playout automation depend on episode-to-asset mapping for scheduling a' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:productionBudgetId rdf:type rdf:Property ;
    rdfs:label 'Production Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.production_budget. Business justification: High-cost episodes (pilots, finales, VFX-heavy episodes) often have dedicated budget line items. Production accountants track episodic costs for above-the-line talent overages, location expenses, and ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaBroadcasting .

ind:studioFacilityId rdf:type rdf:Property ;
    rdfs:label 'Studio Facility Id' ;
    rdfs:comment 'Foreign key linking to technology.studio_facility. Business justification: Episodes are recorded in specific studios. Daily production logs, studio utilization reports, post-production workflows, and per-episode cost accounting require episode-to-studio linkage. Essential fo' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudioFacility .

ind:archiveDate rdf:type rdf:Property ;
    rdfs:label 'Archive Date' ;
    rdfs:comment 'Date when the episode master was moved to long-term archive storage. Used for asset lifecycle management and storage optimization.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:audioDescriptionAvailable rdf:type rdf:Property ;
    rdfs:label 'Audio Description Available' ;
    rdfs:comment 'Indicates whether audio description track is available for visually impaired viewers. Required for accessibility compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioFormat rdf:type rdf:Property ;
    rdfs:label 'Audio Format' ;
    rdfs:comment 'Audio channel configuration and encoding format. Affects playout system configuration and premium content positioning.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastCount rdf:type rdf:Property ;
    rdfs:label 'Broadcast Count' ;
    rdfs:comment 'Total number of times this episode has been broadcast on linear television. Used for residuals calculation and syndication rights management.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentAdvisory rdf:type rdf:Property ;
    rdfs:label 'Content Advisory' ;
    rdfs:comment 'Specific content warnings or advisories for viewer guidance (e.g., violence, language, adult themes). Displayed in Electronic Program Guide (EPG) and Video On Demand (VOD) interfaces.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eidrIdentifier rdf:type rdf:Property ;
    rdfs:label 'Eidr Identifier' ;
    rdfs:comment 'Globally unique identifier for the episode registered with the Entertainment Identifier Registry. Enables universal content identification across distribution platforms and rights management systems.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeNumber rdf:type rdf:Property ;
    rdfs:label 'Episode Number' ;
    rdfs:comment 'Sequential number of the episode within its season. Used for ordering and identification in Electronic Program Guide (EPG) and Video On Demand (VOD) catalogs.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeStatus rdf:type rdf:Property ;
    rdfs:label 'Episode Status' ;
    rdfs:comment 'Current lifecycle state of the episode. Determines availability for scheduling, playout automation, and distribution to Over-The-Top (OTT) platforms.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeType rdf:type rdf:Property ;
    rdfs:label 'Episode Type' ;
    rdfs:comment 'Classification of the episode format and purpose within the series. Affects scheduling strategy, promotional treatment, and rights valuation. [ENUM-REF-CANDIDATE: standard|special|pilot|finale|recap|bonus|behind_the_scenes — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords and tags describing episode themes, topics, and notable elements. Supports content search, discovery, and metadata enrichment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicCueSheetSubmitted rdf:type rdf:Property ;
    rdfs:label 'Music Cue Sheet Submitted' ;
    rdfs:comment 'Indicates whether the music cue sheet has been submitted for royalty collection. Required for music rights compliance and royalty distribution.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalAirDate rdf:type rdf:Property ;
    rdfs:label 'Original Air Date' ;
    rdfs:comment 'The date when the episode was first broadcast on linear television. Critical for rights windowing, residuals calculation, and syndication eligibility.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:premiereFlag rdf:type rdf:Property ;
    rdfs:label 'Premiere Flag' ;
    rdfs:comment 'Indicates whether this is a premiere episode (first broadcast). Used for promotional planning, upfront advertising sales, and Nielsen sweeps period strategy.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionCode rdf:type rdf:Property ;
    rdfs:label 'Production Code' ;
    rdfs:comment 'Internal production identifier assigned during content creation. Used for tracking production workflow, post-production tasks, and archival reference.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rerunFlag rdf:type rdf:Property ;
    rdfs:label 'Rerun Flag' ;
    rdfs:comment 'Indicates whether this broadcast is a rerun. Affects advertising rates, Cost Per Rating Point (CPRP) calculations, and residuals payments to talent.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Clearance Status' ;
    rdfs:comment 'Current status of rights clearance for broadcast and distribution. Determines whether episode can be scheduled for playout or made available on Over-The-Top (OTT) platforms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runtimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Runtime Seconds' ;
    rdfs:comment 'Total duration of the episode content in seconds, excluding commercial breaks. Used for playout scheduling, ad pod allocation, and Electronic Program Guide (EPG) display.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runtimeWithAdsSeconds rdf:type rdf:Property ;
    rdfs:label 'Runtime With Ads Seconds' ;
    rdfs:comment 'Total broadcast duration including commercial ad breaks. Used for linear scheduling and daypart planning.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subtitlesAvailable rdf:type rdf:Property ;
    rdfs:label 'Subtitles Available' ;
    rdfs:comment 'Indicates whether subtitle tracks are available for this episode. Supports international distribution and localization strategies.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:synopsisLong rdf:type rdf:Property ;
    rdfs:label 'Synopsis Long' ;
    rdfs:comment 'Detailed description of the episode plot, themes, and key moments. Used for Video On Demand (VOD) platforms, promotional materials, and content discovery.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synopsisShort rdf:type rdf:Property ;
    rdfs:label 'Synopsis Short' ;
    rdfs:comment 'Brief summary of the episode content, typically 50-100 characters. Used for Electronic Program Guide (EPG) listings and mobile applications with limited display space.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vodAvailableFromDate rdf:type rdf:Property ;
    rdfs:label 'Vod Available From Date' ;
    rdfs:comment 'Date when the episode becomes available on Video On Demand (VOD) platforms. Part of windowing strategy and rights holdback management.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vodAvailableUntilDate rdf:type rdf:Property ;
    rdfs:label 'Vod Available Until Date' ;
    rdfs:comment 'Date when the episode is removed from Video On Demand (VOD) platforms. Enforces rights windows and exclusivity periods.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentGenreId rdf:type rdf:Property ;
    rdfs:label 'Parent Genre Id' ;
    rdfs:comment 'Reference to the parent genre in the hierarchical taxonomy, enabling multi-level classification such as Drama > Legal Drama or Sports > Football. Null for top-level genres.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Genre .

ind:adPodCompatibility rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Compatibility' ;
    rdfs:comment 'Indicates whether content in this genre is compatible with Dynamic Ad Insertion (DAI) and ad pod placement. False for genres requiring uninterrupted viewing (e.g., live sports critical moments, news breaking coverage).' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableContentTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Content Types' ;
    rdfs:comment 'Comma-separated list of content types to which this genre applies (e.g., series, film, clip, live_event, news_segment, music_video). Enables content-type-specific genre filtering.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveRetentionPolicy rdf:type rdf:Property ;
    rdfs:label 'Archive Retention Policy' ;
    rdfs:comment 'Digital asset archival retention policy for content in this genre. Permanent retention for high-value evergreen genres; short-term for time-sensitive news and event content.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avodMonetizationPotential rdf:type rdf:Property ;
    rdfs:label 'Avod Monetization Potential' ;
    rdfs:comment 'Revenue generation potential for this genre on Advertising-Supported Video On Demand (AVOD) platforms, based on Cost Per Mille (CPM) rates and advertiser demand. High-potential genres command premium ad rates.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartAffinity rdf:type rdf:Property ;
    rdfs:label 'Daypart Affinity' ;
    rdfs:comment 'Comma-separated list of broadcast dayparts where this genre typically performs best (e.g., prime_time, late_night, early_morning, daytime, weekend). Informs program scheduling and playout automation strategies.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eidrGenreMapping rdf:type rdf:Property ;
    rdfs:label 'Eidr Genre Mapping' ;
    rdfs:comment 'Mapping to Entertainment Identifier Registry (EIDR) genre taxonomy for cross-industry content identification and rights management interoperability.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastChannelApplicability rdf:type rdf:Property ;
    rdfs:label 'Fast Channel Applicability' ;
    rdfs:comment 'Indicates whether this genre is suitable for Free Ad-Supported Streaming Television (FAST) linear channel programming. FAST channels require genres with deep catalog availability and consistent audience appeal.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genreCode rdf:type rdf:Property ;
    rdfs:label 'Genre Code' ;
    rdfs:comment 'Short alphanumeric code representing the genre for system integration and Electronic Program Guide (EPG) feeds. Used as a business key across scheduling, distribution, and metadata systems.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreDescription rdf:type rdf:Property ;
    rdfs:label 'Genre Description' ;
    rdfs:comment 'Detailed textual description of the genre, including defining characteristics, typical content examples, and audience expectations. Used for editorial guidance and content acquisition briefings.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreName rdf:type rdf:Property ;
    rdfs:label 'Genre Name' ;
    rdfs:comment 'Full display name of the genre as presented to audiences in Electronic Program Guides (EPG), streaming platform interfaces, and content discovery systems.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreTier rdf:type rdf:Property ;
    rdfs:label 'Genre Tier' ;
    rdfs:comment 'Hierarchical level of the genre within the taxonomy. Primary represents top-level genres, secondary represents sub-genres, and tertiary represents granular classifications.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestrictionApplicability rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction Applicability' ;
    rdfs:comment 'Indicates whether content in this genre is subject to geographic blackout restrictions or regional licensing constraints. Common for sports genres with territorial rights and retransmission consent agreements.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iabContentCategory rdf:type rdf:Property ;
    rdfs:label 'Iab Content Category' ;
    rdfs:comment 'Mapping to Interactive Advertising Bureau (IAB) content taxonomy for programmatic advertising and contextual ad targeting. Enables Share of Voice (SOV) optimization and Cost Per Mille (CPM) rate alignment.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linearBroadcastSuitability rdf:type rdf:Property ;
    rdfs:label 'Linear Broadcast Suitability' ;
    rdfs:comment 'Indicates whether this genre is suitable for traditional linear scheduled broadcasting. Some genres (e.g., interactive, choose-your-own-adventure) are non-linear only.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localizationPriority rdf:type rdf:Property ;
    rdfs:label 'Localization Priority' ;
    rdfs:comment 'Priority level for content localization (dubbing, subtitling, cultural adaptation) for this genre. High-priority genres justify investment in multi-language versions for international distribution.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataEnrichmentPriority rdf:type rdf:Property ;
    rdfs:label 'Metadata Enrichment Priority' ;
    rdfs:comment 'Priority level for metadata enrichment and tagging in Media Asset Management (MAM) systems. Critical genres require comprehensive metadata for content discovery and personalization.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpaRatingApplicability rdf:type rdf:Property ;
    rdfs:label 'Mpa Rating Applicability' ;
    rdfs:comment 'Comma-separated list of Motion Picture Association (MPA) ratings typically associated with this genre (e.g., G, PG, PG-13, R, NC-17). Used for content clearance and daypart scheduling compliance.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenGenreCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Genre Code' ;
    rdfs:comment 'Nielsen Media Research genre classification code used for audience measurement, ratings analysis, and Gross Rating Point (GRP) reporting alignment.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ottPlatformPriority rdf:type rdf:Property ;
    rdfs:label 'Ott Platform Priority' ;
    rdfs:comment 'Priority level for featuring this genre on Over-The-Top (OTT) streaming platforms and Video On Demand (VOD) services. High priority genres receive prominent placement in content discovery and recommendation engines.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalGuidanceFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Guidance Flag' ;
    rdfs:comment 'Indicates whether content in this genre typically requires parental guidance warnings or viewer discretion advisories. Used for compliance with Federal Communications Commission (FCC) broadcast standards and Children\'s Online Privacy Protection Act (COPPA) requirements.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:svodPerformanceTier rdf:type rdf:Property ;
    rdfs:label 'Svod Performance Tier' ;
    rdfs:comment 'Performance classification for this genre on Subscription Video On Demand (SVOD) platforms. Premium genres drive subscriber acquisition and reduce churn rate; catalog genres provide library depth.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationEligibility rdf:type rdf:Property ;
    rdfs:label 'Syndication Eligibility' ;
    rdfs:comment 'Indicates whether content in this genre is typically eligible for syndication to multiple outlets and resale. Used in rights and royalties management and windowing strategy planning.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Notes' ;
    rdfs:comment 'Internal notes and guidelines for content producers, schedulers, and metadata specialists on proper application of this genre classification. Includes edge cases and disambiguation rules.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierId rdf:type rdf:Property ;
    rdfs:label 'Identifier Id' ;
    rdfs:comment 'Primary key for identifier' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'External Reference Url' ;
    rdfs:comment 'A URL or web link to the external registry or system where this identifier can be looked up or verified (e.g., EIDR registry lookup page, ISAN database).' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierType rdf:type rdf:Property ;
    rdfs:label 'Identifier Type' ;
    rdfs:comment 'The type or classification of the identifier. Indicates the issuing authority or system that generated the identifier. [ENUM-REF-CANDIDATE: EIDR|ISAN|ISRC|ISCI|MAM_ID|DISTRIBUTOR_ID|PLATFORM_ID|INTERNAL_ID|VENDOR_ID|RIGHTS_ID|ARCHIVE_ID — promote to reference product]' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierValue rdf:type rdf:Property ;
    rdfs:label 'Identifier Value' ;
    rdfs:comment 'The actual identifier string or code assigned to the content asset. This is the unique value issued by the external or internal system (e.g., EIDR ID, ISAN number, ISRC code, MAM asset ID).' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Boolean flag indicating whether this identifier is the primary or preferred identifier for the content asset within its type category. Used to prioritize identifiers when multiple exist.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'The organization, system, or registry that issued or assigned this identifier (e.g., Entertainment Identifier Registry, Dalet Galaxy MAM, distributor name, platform name).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'The date on which this identifier was officially registered or assigned to the content asset by the issuing authority.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageContext rdf:type rdf:Property ;
    rdfs:label 'Usage Context' ;
    rdfs:comment 'The primary business context or use case for which this identifier is utilized (e.g., rights clearance, royalty calculation, metadata syndication to downstream platforms, distribution tracking, archival reference).' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestEventId rdf:type rdf:Property ;
    rdfs:label 'Ingest Event Id' ;
    rdfs:comment 'Unique identifier for the content ingest event. Primary key for the ingest_event product.' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ingestBroadcastFacilityId rdf:type rdf:Property ;
    rdfs:label 'Ingest Broadcast Facility Id' ;
    rdfs:comment 'Foreign key linking to technology.broadcast_facility. Business justification: Ingest operations occur at specific facilities with dedicated ingest infrastructure. Operational dashboards, capacity planning, SLA tracking, and facility performance metrics require facility attribut' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastFacility .

ind:thirdPartyVendorPartnerId rdf:type rdf:Property ;
    rdfs:label 'Third Party Vendor Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Third-party vendors deliver content for ingest. Delivery acceptance tracking, technical QC dispute resolution, redelivery cost allocation, and vendor performance scorecarding require partner attributi' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:audioDescriptionDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Audio Description Detected Flag' ;
    rdfs:comment 'Indicates whether an audio description track for visually impaired audiences was detected in the ingested content. True if audio description present, False otherwise.' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automatedQcResult rdf:type rdf:Property ;
    rdfs:label 'Automated Qc Result' ;
    rdfs:comment 'The outcome of automated quality control checks performed during or immediately after ingest (e.g., technical compliance, audio/video sync, black frames, silence detection).' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumSha256 rdf:type rdf:Property ;
    rdfs:label 'Checksum Sha256' ;
    rdfs:comment 'SHA-256 hash of the ingested file for enhanced integrity verification and forensic audit. Calculated at ingest time.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Detected Flag' ;
    rdfs:comment 'Indicates whether closed caption or subtitle tracks were detected in the ingested content. True if captions present, False otherwise.' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingestCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingest Completion Timestamp' ;
    rdfs:comment 'The date and time when the ingest operation reached a terminal state (completed, failed, or cancelled). Null for in-progress operations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ingestErrorCode rdf:type rdf:Property ;
    rdfs:label 'Ingest Error Code' ;
    rdfs:comment 'Machine-readable error code generated when the ingest operation fails. Null for successful ingests.' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestErrorDescription rdf:type rdf:Property ;
    rdfs:label 'Ingest Error Description' ;
    rdfs:comment 'Human-readable description of the failure reason when ingest status is failed or quarantined. Null for successful ingests.' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestJobNumber rdf:type rdf:Property ;
    rdfs:label 'Ingest Job Number' ;
    rdfs:comment 'Externally-known unique job identifier assigned by the MAM (Media Asset Management) system for tracking and audit purposes.' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestSourceLocation rdf:type rdf:Property ;
    rdfs:label 'Ingest Source Location' ;
    rdfs:comment 'The physical or logical location from which the content was ingested (e.g., file path, tape library slot, satellite feed identifier, cloud bucket URI).' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestSourceType rdf:type rdf:Property ;
    rdfs:label 'Ingest Source Type' ;
    rdfs:comment 'The delivery mechanism or medium through which the content was received into the MAM (Media Asset Management) system. [ENUM-REF-CANDIDATE: tape|file|satellite|ip_stream|cloud|ftp|aspera|physical_media — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestStatus rdf:type rdf:Property ;
    rdfs:label 'Ingest Status' ;
    rdfs:comment 'Current lifecycle status of the ingest operation. Tracks progression from queued through completion or failure states.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingest Timestamp' ;
    rdfs:comment 'The date and time when the content ingest operation was initiated. Represents the principal business event time for this transaction.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ingestWorkflowCode rdf:type rdf:Property ;
    rdfs:label 'Ingest Workflow Code' ;
    rdfs:comment 'Reference to the specific workflow template or automation rule that governed this ingest operation in the MAM (Media Asset Management) system.' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataPackageReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Metadata Package Received Flag' ;
    rdfs:comment 'Indicates whether accompanying metadata (EIDR, ISAN, descriptive metadata, rights information) was received with the media file. True if metadata was included, False otherwise.' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcErrorCode rdf:type rdf:Property ;
    rdfs:label 'Qc Error Code' ;
    rdfs:comment 'Machine-readable error code generated by the automated QC system when issues are detected. Null if QC passed or was not performed.' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcErrorDescription rdf:type rdf:Property ;
    rdfs:label 'Qc Error Description' ;
    rdfs:comment 'Human-readable description of quality control issues detected during ingest. Null if QC passed or was not performed.' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceAspectRatio rdf:type rdf:Property ;
    rdfs:label 'Source Aspect Ratio' ;
    rdfs:comment 'The aspect ratio of the ingested video content (e.g., 16:9, 4:3, 21:9). Null for audio-only content.' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceAudioChannels rdf:type rdf:Property ;
    rdfs:label 'Source Audio Channels' ;
    rdfs:comment 'The number of audio channels in the ingested content (e.g., 2 for stereo, 6 for 5.1 surround). Null for video-only content.' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceAudioCodec rdf:type rdf:Property ;
    rdfs:label 'Source Audio Codec' ;
    rdfs:comment 'The audio codec used in the ingested content (e.g., AAC, AC-3, PCM, Dolby Digital). Null for video-only content.' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Source Duration Seconds' ;
    rdfs:comment 'The runtime duration of the ingested media content in seconds. Null for still images or non-time-based assets.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Source File Size Bytes' ;
    rdfs:comment 'The size of the ingested media file in bytes. Used for storage planning, bandwidth analysis, and integrity verification.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceFormat rdf:type rdf:Property ;
    rdfs:label 'Source Format' ;
    rdfs:comment 'The technical format and codec of the ingested media file (e.g., MPEG-4, ProRes, MXF, H.264, HEVC). Captured as received before any transcoding.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFrameRate rdf:type rdf:Property ;
    rdfs:label 'Source Frame Rate' ;
    rdfs:comment 'The frame rate of the ingested video content in frames per second (e.g., 23.976, 25.000, 29.970, 59.940). Null for audio-only content.' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceResolution rdf:type rdf:Property ;
    rdfs:label 'Source Resolution' ;
    rdfs:comment 'The video resolution of the ingested content (e.g., 1920x1080, 3840x2160, 1280x720). Null for audio-only content.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Event Id' ;
    rdfs:comment 'Primary key for lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLifecycleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lifecycle Employee Id' ;
    rdfs:comment 'The system identifier of the user who initiated or approved this lifecycle transition. Used for accountability and audit purposes.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:blockingCondition rdf:type rdf:Property ;
    rdfs:label 'Blocking Condition' ;
    rdfs:comment 'Any condition, issue, or dependency that is blocking or delaying the content from progressing to the next lifecycle stage (e.g., pending rights clearance, QC failure, missing metadata, technical issue). Null if no blocking condition exists.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingResolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Blocking Resolved Flag' ;
    rdfs:comment 'Indicates whether any previously identified blocking condition has been resolved. True if resolved, False if still blocking, Null if no blocking condition was present.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCheckpointPassed rdf:type rdf:Property ;
    rdfs:label 'Compliance Checkpoint Passed' ;
    rdfs:comment 'Indicates whether all regulatory and compliance checkpoints required for this lifecycle stage were successfully passed (e.g., content rating verification, rights clearance, broadcast standards review). True if passed, False if failed, Null if not applicable.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'The sequential order of this lifecycle event within the complete lifecycle history of the content asset. Used to reconstruct the chronological audit trail.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'The operational lifecycle stage of the content asset at the time of this event. Represents the major phase in the content workflow from acquisition through archival. [ENUM-REF-CANDIDATE: acquisition|commission|development|pre_production|production|post_production|clearance|mastering|distribution|archival|retired — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The status of the content asset immediately after this lifecycle transition. Represents the current state following the event.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The status of the content asset immediately before this lifecycle transition. Captures the prior state for audit trail and provenance.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Status' ;
    rdfs:comment 'The quality control review status associated with this lifecycle transition. Indicates whether technical and editorial quality standards were met.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackFlag rdf:type rdf:Property ;
    rdfs:label 'Rollback Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event represents a rollback to a previous stage due to failure, rejection, or rework requirement. True if rollback, False for forward progression.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollbackReason rdf:type rdf:Property ;
    rdfs:label 'Rollback Reason' ;
    rdfs:comment 'The reason or justification for rolling back the content to a previous lifecycle stage. Null if rollback_flag is False.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaActualDate rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Date' ;
    rdfs:comment 'The actual date when this lifecycle stage was completed. Used to measure SLA compliance by comparing against sla_target_date.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transitionDurationHours rdf:type rdf:Property ;
    rdfs:label 'Transition Duration Hours' ;
    rdfs:comment 'The elapsed time in hours between the previous lifecycle event and this event. Measures the duration spent in the previous stage. Used for operational efficiency analysis.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'The precise date and time when the lifecycle stage transition occurred. This is the business event timestamp, distinct from audit timestamps.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:triggeredByEvent rdf:type rdf:Property ;
    rdfs:label 'Triggered By Event' ;
    rdfs:comment 'The specific event or action that triggered this lifecycle transition (e.g., QC approval, rights clearance, ingest completion, delivery confirmation, manual override).' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowInstanceCode rdf:type rdf:Property ;
    rdfs:label 'Workflow Instance Code' ;
    rdfs:comment 'The unique identifier of the workflow instance in the Media Asset Management (MAM) system that orchestrated this lifecycle transition. Links to Dalet Galaxy workflow execution.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationId rdf:type rdf:Property ;
    rdfs:label 'Localization Id' ;
    rdfs:comment 'Unique identifier for the localization work product record.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localizedMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Localized Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Localized audio tracks and subtitle files are delivered as media assets. Distribution workflows require linking localization records to their delivered asset files for QC, versioning, and platform del' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:titleVersionId rdf:type rdf:Property ;
    rdfs:label 'Title Version Id' ;
    rdfs:comment 'Reference to the specific title version being localized.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:voiceTalentProfileId rdf:type rdf:Property ;
    rdfs:label 'Voice Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: Dubbing and voice localization require tracking which talent performed the localized version for residual payments, credit attribution, and guild reporting. Essential for international content distrib' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:accessibilityStandardMet rdf:type rdf:Property ;
    rdfs:label 'Accessibility Standard Met' ;
    rdfs:comment 'Specific accessibility standard that the localization work product complies with (e.g., WCAG 2.1 AA, FCC CVAA).' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Actual date when the localization work product was delivered by the vendor or internal team.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the individual or role who provided final approval for the localization work product.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetFilePath rdf:type rdf:Property ;
    rdfs:label 'Asset File Path' ;
    rdfs:comment 'Storage location or URI path to the delivered localization asset file in the Media Asset Management (MAM) system or Content Delivery Network (CDN).' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characterCount rdf:type rdf:Property ;
    rdfs:label 'Character Count' ;
    rdfs:comment 'Total number of characters in the subtitle or metadata translation work product, used for billing and capacity planning.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Flag' ;
    rdfs:comment 'Indicates whether the localization meets regulatory compliance requirements for the target territory (e.g., local content quotas, language laws, accessibility standards).' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total runtime duration in minutes of the content being localized, relevant for dubbing and subtitling scope.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationStatus rdf:type rdf:Property ;
    rdfs:label 'Localization Status' ;
    rdfs:comment 'Current workflow status of the localization work product. [ENUM-REF-CANDIDATE: ordered|in_progress|delivered|qc_review|approved|rejected|revision_required — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationType rdf:type rdf:Property ;
    rdfs:label 'Localization Type' ;
    rdfs:comment 'The type of localization work being performed on the content asset.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Purchase order number issued to the localization vendor for this work product.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcNotes rdf:type rdf:Property ;
    rdfs:label 'Qc Notes' ;
    rdfs:comment 'Detailed notes and findings from the quality control review process, including any defects or issues identified.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcPassFlag rdf:type rdf:Property ;
    rdfs:label 'Qc Pass Flag' ;
    rdfs:comment 'Boolean indicator of whether the localization work product passed quality control review.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcReviewDate rdf:type rdf:Property ;
    rdfs:label 'Qc Review Date' ;
    rdfs:comment 'Date when quality control review of the localization work product was completed.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcReviewerName rdf:type rdf:Property ;
    rdfs:label 'Qc Reviewer Name' ;
    rdfs:comment 'Name of the individual or team who performed the quality control review.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Business reason or description for why a revision of the localization work product was required.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Contractually agreed or planned delivery date for the completed localization work product.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subtitleFormat rdf:type rdf:Property ;
    rdfs:label 'Subtitle Format' ;
    rdfs:comment 'Technical format specification for subtitle files (SRT, TTML, WebVTT, etc.). [ENUM-REF-CANDIDATE: SRT|TTML|WebVTT|EBU-STL|SMPTE-TT|SCC|DFXP — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Target Language Code' ;
    rdfs:comment 'ISO 639 language code for the target localization language (e.g., es-MX for Mexican Spanish, fr-CA for Canadian French).' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Target Territory Code' ;
    rdfs:comment 'ISO 3166 three-letter country code representing the target distribution territory for this localization.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataProfileId rdf:type rdf:Property ;
    rdfs:label 'Metadata Profile Id' ;
    rdfs:comment 'Unique identifier for the metadata profile record. Primary key.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previewMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Preview Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Metadata packages for platform delivery often include preview clips or thumbnail assets. Distribution systems require linking metadata profiles to their associated preview/promo assets for bundled del' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:castSummary rdf:type rdf:Property ;
    rdfs:label 'Cast Summary' ;
    rdfs:comment 'Summarized list of principal cast members and their roles. Used for promotional materials and EPG (Electronic Program Guide) displays where full cast lists are impractical.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directorCredit rdf:type rdf:Property ;
    rdfs:label 'Director Credit' ;
    rdfs:comment 'Name(s) of the director(s) of the content. Used for attribution, promotional materials, and search/discovery.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributor rdf:type rdf:Property ;
    rdfs:label 'Distributor' ;
    rdfs:comment 'Name of the distributor responsible for delivering the content to platforms and audiences. Used for rights management and business intelligence.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreClassification rdf:type rdf:Property ;
    rdfs:label 'Genre Classification' ;
    rdfs:comment 'Genre or category classification specific to the target platform. May differ from the master title genre to align with platform-specific taxonomies (e.g., Netflix genres vs. broadcast EPG genres).' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keywordTags rdf:type rdf:Property ;
    rdfs:label 'Keyword Tags' ;
    rdfs:comment 'Comma-separated list of keyword tags for content discovery, search indexing, and recommendation engines. Includes themes, topics, moods, and contextual descriptors.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longSynopsis rdf:type rdf:Property ;
    rdfs:label 'Long Synopsis' ;
    rdfs:comment 'Extended narrative description of the content title. Typically 200-500 words, used for detailed program guides, press releases, and promotional materials.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataLanguage rdf:type rdf:Property ;
    rdfs:label 'Metadata Language' ;
    rdfs:comment 'ISO 639 language code (2 or 3 letters) with optional ISO 3166 country code for the language in which this metadata profile is written. Examples: en, en-US, fr, es-MX.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataStandard rdf:type rdf:Property ;
    rdfs:label 'Metadata Standard' ;
    rdfs:comment 'The metadata standard or schema used for this profile. Defines the structure and vocabulary of the metadata package.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalGuidanceNotes rdf:type rdf:Property ;
    rdfs:label 'Parental Guidance Notes' ;
    rdfs:comment 'Detailed notes explaining the content rating, including specific content descriptors (violence, language, sexual content, etc.). Used for parental controls and compliance.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformSpecificCode rdf:type rdf:Property ;
    rdfs:label 'Platform Specific Code' ;
    rdfs:comment 'Unique identifier assigned by the target platform for this metadata profile. Used for cross-referencing and reconciliation with external systems.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posterUrl rdf:type rdf:Property ;
    rdfs:label 'Poster Url' ;
    rdfs:comment 'URL (Uniform Resource Locator) to the poster or cover art image associated with this metadata profile. Used for streaming platform UI, marketing, and promotional materials.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCompany rdf:type rdf:Property ;
    rdfs:label 'Production Company' ;
    rdfs:comment 'Name of the production company or studio that produced the content. Used for rights attribution and promotional materials.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalTagline rdf:type rdf:Property ;
    rdfs:label 'Promotional Tagline' ;
    rdfs:comment 'Short, catchy promotional phrase or slogan used in marketing campaigns, social media, and advertising. Typically 10-30 words.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runtimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Runtime Minutes' ;
    rdfs:comment 'Total runtime of the content in minutes. Used for scheduling, EPG (Electronic Program Guide) display, and audience planning.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonNumber rdf:type rdf:Property ;
    rdfs:label 'Season Number' ;
    rdfs:comment 'Season number within a series, if applicable. Used for episodic content organization in EPG (Electronic Program Guide) and streaming platforms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shortSynopsis rdf:type rdf:Property ;
    rdfs:label 'Short Synopsis' ;
    rdfs:comment 'Brief narrative description of the content title. Typically 50-150 words, used for EPG (Electronic Program Guide) listings, mobile apps, and quick reference.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'URL (Uniform Resource Locator) to the thumbnail image associated with this metadata profile. Used for EPG (Electronic Program Guide) display, streaming platform UI, and promotional materials.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerUrl rdf:type rdf:Property ;
    rdfs:label 'Trailer Url' ;
    rdfs:comment 'URL (Uniform Resource Locator) to the trailer or preview video associated with this content. Used for promotional campaigns and streaming platform previews.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrors rdf:type rdf:Property ;
    rdfs:label 'Validation Errors' ;
    rdfs:comment 'Detailed list of validation errors or warnings encountered during metadata quality checks. Used for troubleshooting and metadata remediation.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Result of automated or manual validation checks against the target metadata standard. Indicates whether the profile meets all required schema and business rules.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageId rdf:type rdf:Property ;
    rdfs:label 'Package Id' ;
    rdfs:comment 'Primary key for package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Billing Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Content packages sold to distributors/platforms generate invoices. Sales operations and revenue accounting track which invoices bill for which packages for revenue allocation, package performance anal' ;
    rdfs:domain ind:Package ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:audioDescriptionAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Audio Description Available Flag' ;
    rdfs:comment 'Indicates whether audio description tracks are available for the majority of content in the package (True/False). Required for accessibility compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedCaptionAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Available Flag' ;
    rdfs:comment 'Indicates whether closed captioning is available for the majority of content in the package (True/False). Required for FCC compliance and accessibility standards.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commercialContext rdf:type rdf:Property ;
    rdfs:label 'Commercial Context' ;
    rdfs:comment 'Free-text description of the business purpose or deal context for which the package was assembled, such as upfront sales event, scatter market offering, MVPD (Multichannel Video Programming Distributor) carriage negotiation, or international syndication deal.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Drm Required Flag' ;
    rdfs:comment 'Indicates whether Digital Rights Management (DRM) protection is required for distribution of this package (True/False). Critical for rights enforcement and anti-piracy compliance.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Hd Available Flag' ;
    rdfs:comment 'Indicates whether the package content is available in high-definition (HD) format (True/False). Used for distribution planning and quality assurance.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePrimary rdf:type rdf:Property ;
    rdfs:label 'Language Primary' ;
    rdfs:comment 'The primary language of the content in the package, expressed as ISO 639-2 three-letter language code (e.g., eng, spa, fra). Critical for localization and international distribution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'The externally-known unique business identifier or code for the package used in contracts, invoicing, and distribution systems.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageDescription rdf:type rdf:Property ;
    rdfs:label 'Package Description' ;
    rdfs:comment 'A detailed narrative description of the package content, target audience, and commercial positioning. Used for marketing, sales proposals, and catalog listings.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageName rdf:type rdf:Property ;
    rdfs:label 'Package Name' ;
    rdfs:comment 'The business name or title of the content package as recognized in commercial agreements and distribution deals.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the package: draft (under construction), active (available for distribution), suspended (temporarily unavailable), expired (past effective period), terminated (cancelled before expiry), or archived (historical record).' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'The classification of the package based on its commercial or distribution purpose: syndication (content resale to multiple outlets), SVOD (Subscription Video On Demand) library (subscription-based catalog), AVOD (Advertising-Supported Video On Demand) catalog (ad-supported offering), FAST (Free Ad-Supported Streaming Television) channel (linear streaming channel), educational (academic or training content bundle), or international (cross-border distribution bundle).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolder rdf:type rdf:Property ;
    rdfs:label 'Rights Holder' ;
    rdfs:comment 'The name of the organization or entity that holds the distribution rights for the package. May be a studio, distributor, or licensor.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRuntimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Runtime Hours' ;
    rdfs:comment 'The aggregate runtime of all content in the package, expressed in hours. Used for programming and scheduling calculations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTitleCount rdf:type rdf:Property ;
    rdfs:label 'Total Title Count' ;
    rdfs:comment 'The total number of distinct titles (episodes, films, clips, or other content assets) included in the package. Used for inventory reporting and deal valuation.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uhd4kAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Uhd 4k Available Flag' ;
    rdfs:comment 'Indicates whether the package content is available in ultra-high-definition 4K format (True/False). Used for premium distribution and OTT platform requirements.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valueUsd rdf:type rdf:Property ;
    rdfs:label 'Value Usd' ;
    rdfs:comment 'The estimated or contracted commercial value of the package in United States Dollars (USD). Used for revenue forecasting, deal valuation, and financial reporting.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingId rdf:type rdf:Property ;
    rdfs:label 'Rating Id' ;
    rdfs:comment 'Primary key for rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:body rdf:type rdf:Property ;
    rdfs:label 'Body' ;
    rdfs:comment 'The official name of the regulatory or industry body that issued the rating (e.g., Motion Picture Association, TV Parental Guidelines Monitoring Board, British Board of Film Classification, Freiwillige Selbstkontrolle der Filmwirtschaft).' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDescriptorDrugUse rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Drug Use' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for drug use or substance abuse.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorFear rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Fear' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for frightening or intense scenes that may be unsuitable for younger audiences.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorLanguage rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Language' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for strong or offensive language.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorNudity rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Nudity' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for nudity or sexual content.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorViolence rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Violence' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for violence or intense action.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalControlEnabled rdf:type rdf:Property ;
    rdfs:label 'Parental Control Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this rating is used to enforce parental control features on linear broadcast, OTT (Over-The-Top), or MVPD (Multichannel Video Programming Distributor) platforms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingCode rdf:type rdf:Property ;
    rdfs:label 'Rating Code' ;
    rdfs:comment 'The official rating classification code assigned to the content (e.g., G, PG, PG-13, R, NC-17 for MPA film ratings; TV-Y, TV-Y7, TV-G, TV-PG, TV-14, TV-MA for TV Parental Guidelines; or international equivalents such as BBFC, FSK, OFLC codes). [ENUM-REF-CANDIDATE: G|PG|PG-13|R|NC-17|TV-Y|TV-Y7|TV-G|TV-PG|TV-14|TV-MA — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingDescription rdf:type rdf:Property ;
    rdfs:label 'Rating Description' ;
    rdfs:comment 'Detailed textual description of the rating, including the rationale for the classification and any additional context provided by the rating body (e.g., \'Rated PG-13 for intense sequences of violence and action, some suggestive content, and brief strong language\').' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Boolean flag indicating whether the rating is legally mandated by a regulatory body (e.g., FCC, Ofcom) or is a voluntary industry classification.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:system rdf:type rdf:Property ;
    rdfs:label 'System' ;
    rdfs:comment 'The rating system or classification framework under which the rating was assigned (e.g., MPA for Motion Picture Association, TVPG for TV Parental Guidelines, BBFC for British Board of Film Classification, FSK for Freiwillige Selbstkontrolle der Filmwirtschaft, OFLC for Australian Classification Board, CBFC for Central Board of Film Certification India).' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonId rdf:type rdf:Property ;
    rdfs:label 'Season Id' ;
    rdfs:comment 'Unique identifier for the season record. Primary key.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Season .

ind:awardsNominated rdf:type rdf:Property ;
    rdfs:label 'Awards Nominated' ;
    rdfs:comment 'Comma-separated list of major award nominations received by the season. Supports promotional messaging and content valuation.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardsWon rdf:type rdf:Property ;
    rdfs:label 'Awards Won' ;
    rdfs:comment 'Comma-separated list of major awards won by the season (e.g., Emmy, Golden Globe). Used for marketing and promotional value enhancement.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bannerArtworkUrl rdf:type rdf:Property ;
    rdfs:label 'Banner Artwork Url' ;
    rdfs:comment 'URL reference to the season\'s banner or hero image for wide-format displays on streaming platforms and websites.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeCountAired rdf:type rdf:Property ;
    rdfs:label 'Episode Count Aired' ;
    rdfs:comment 'Number of episodes that have been broadcast or released to audiences. Used for tracking release progress.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeCountOrdered rdf:type rdf:Property ;
    rdfs:label 'Episode Count Ordered' ;
    rdfs:comment 'Number of episodes originally ordered or commissioned for this season by the network or platform.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeCountProduced rdf:type rdf:Property ;
    rdfs:label 'Episode Count Produced' ;
    rdfs:comment 'Actual number of episodes produced and delivered for this season. May differ from ordered count due to production changes.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finaleDate rdf:type rdf:Property ;
    rdfs:label 'Finale Date' ;
    rdfs:comment 'Date when the final episode of the season was broadcast or released. Marks the end of the season\'s linear run.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isan rdf:type rdf:Property ;
    rdfs:label 'Isan' ;
    rdfs:comment 'International standard identifier for audiovisual works, used for season-level identification in global distribution and rights management.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageOriginal rdf:type rdf:Property ;
    rdfs:label 'Language Original' ;
    rdfs:comment 'ISO 639-3 three-letter code for the original production language of the season. Critical for localization and distribution planning.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkOriginal rdf:type rdf:Property ;
    rdfs:label 'Network Original' ;
    rdfs:comment 'Name of the network or platform that originally commissioned or first aired the season. Used for windowing and exclusivity tracking.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posterArtworkUrl rdf:type rdf:Property ;
    rdfs:label 'Poster Artwork Url' ;
    rdfs:comment 'URL reference to the season\'s primary poster artwork stored in the Media Asset Management (MAM) system. Used for EPG, VOD, and promotional displays.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionYear rdf:type rdf:Property ;
    rdfs:label 'Production Year' ;
    rdfs:comment 'Calendar year in which the season was produced. Used for cataloging, rights management, and archival purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rightsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Rights Expiry Date' ;
    rdfs:comment 'Date when current distribution rights for the season expire. Triggers rights renewal workflows and availability restrictions.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsTerritory rdf:type rdf:Property ;
    rdfs:label 'Rights Territory' ;
    rdfs:comment 'Geographic territories where distribution rights are held, using ISO 3166-1 alpha-3 country codes or regional groupings. Critical for windowing and blackout enforcement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonStatus rdf:type rdf:Property ;
    rdfs:label 'Season Status' ;
    rdfs:comment 'Current lifecycle status of the season. Tracks progression from development through archival or cancellation. [ENUM-REF-CANDIDATE: in-development|in-production|post-production|completed|airing|aired|archived|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRuntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Runtime Minutes' ;
    rdfs:comment 'Cumulative runtime of all episodes in the season, measured in minutes. Used for scheduling blocks and VOD packaging.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRightsHolderId rdf:type rdf:Property ;
    rdfs:label 'Primary Rights Holder Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_holder. Business justification: Series-level rights ownership (studio/production company) drives all downstream licensing and royalty flows. Franchise management and multi-season deal negotiations require knowing the primary rights ' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:productionBroadcastFacilityId rdf:type rdf:Property ;
    rdfs:label 'Production Broadcast Facility Id' ;
    rdfs:comment 'Foreign key linking to technology.broadcast_facility. Business justification: Series production is facility-based; long-running shows are tied to specific studio facilities for multi-year scheduling, crew allocation, facility cost allocation, and production continuity. Essentia' ;
    rdfs:domain ind:Series ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastFacility .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the series was originally produced. Used for content quotas, regulatory compliance, and international rights management.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeRuntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Episode Runtime Minutes' ;
    rdfs:comment 'Standard runtime duration in minutes for a typical episode of the series, excluding commercials. Used for scheduling, ad pod planning, and playout automation.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:franchiseName rdf:type rdf:Property ;
    rdfs:label 'Franchise Name' ;
    rdfs:comment 'Brand name of the content franchise or show brand. Used for grouping related series, spin-offs, and reboots under a common brand umbrella.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdrFormat rdf:type rdf:Property ;
    rdfs:label 'Hdr Format' ;
    rdfs:comment 'High Dynamic Range format specification for the series. Impacts content delivery network configuration and device compatibility.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalNetwork rdf:type rdf:Property ;
    rdfs:label 'Original Network' ;
    rdfs:comment 'Name of the original broadcast network or streaming platform that first aired or released the series. Critical for rights management and syndication deals.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiereDate rdf:type rdf:Property ;
    rdfs:label 'Premiere Date' ;
    rdfs:comment 'Date when the first episode of the series originally aired or was released. Marks the beginning of the series lifecycle and is used for rights windowing calculations.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionStandard rdf:type rdf:Property ;
    rdfs:label 'Resolution Standard' ;
    rdfs:comment 'Standard video resolution for the series master content. Determines transcoding requirements and Adaptive Bitrate (ABR) streaming profile generation.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesStatus rdf:type rdf:Property ;
    rdfs:label 'Series Status' ;
    rdfs:comment 'Current lifecycle status of the series. Indicates whether the series is actively producing new content, has concluded, or is temporarily paused.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesType rdf:type rdf:Property ;
    rdfs:label 'Series Type' ;
    rdfs:comment 'Classification of the series format and production style. Determines scheduling strategy, audience targeting, and production workflow. [ENUM-REF-CANDIDATE: scripted|unscripted|documentary|news|sports|reality|talk_show|game_show|variety|animated|miniseries|anthology — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationEligible rdf:type rdf:Property ;
    rdfs:label 'Syndication Eligible' ;
    rdfs:comment 'Indicates whether the series meets the minimum episode threshold and rights clearance requirements for syndication to secondary markets and broadcast stations.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:titleOriginal rdf:type rdf:Property ;
    rdfs:label 'Title Original' ;
    rdfs:comment 'Original title of the series in its native language and market before localization or translation.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEpisodeCount rdf:type rdf:Property ;
    rdfs:label 'Total Episode Count' ;
    rdfs:comment 'Cumulative count of all episodes produced across all seasons. Includes specials and pilot episodes.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSeasonCount rdf:type rdf:Property ;
    rdfs:label 'Total Season Count' ;
    rdfs:comment 'Total number of seasons produced for the series to date. Updated as new seasons are commissioned and produced.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tagId rdf:type rdf:Property ;
    rdfs:label 'Tag Id' ;
    rdfs:comment 'Primary key for tag' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentTagId rdf:type rdf:Property ;
    rdfs:label 'Parent Tag Id' ;
    rdfs:comment 'Reference to a parent tag in a hierarchical taxonomy structure. Enables multi-level tag classification (e.g., \'Action\' as parent, \'Car Chase\' as child). Null for top-level tags.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tag .

ind:tagEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tag Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that applied this tag. Supports audit trails and editorial accountability. May reference internal staff, partner systems, or automated processes.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tagReviewedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tag Reviewed By User Employee Id' ;
    rdfs:comment 'Identifier of the editorial staff member who reviewed and approved or rejected this tag assignment. Null if no review has occurred or review is not required.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:taxonomyId rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Id' ;
    rdfs:comment 'External identifier linking this tag to a standardized industry taxonomy or controlled vocabulary system (e.g., IAB Content Taxonomy, Gracenote Video Descriptors, EIDR Content Identifiers). Enables interoperability and consistent metadata across platforms.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Taxonomy .

ind:advertiserSafe rdf:type rdf:Property ;
    rdfs:label 'Advertiser Safe' ;
    rdfs:comment 'Indicates whether content with this tag is suitable for advertising placement according to brand safety guidelines. False may indicate sensitive or controversial content that requires restricted ad inventory.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Confidence level for algorithmically-generated tags, expressed as a decimal between 0.0000 and 1.0000. A score of 1.0000 indicates highest confidence. Null for manually-applied editorial tags.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Depth level of this tag within a hierarchical taxonomy structure. Level 1 represents top-level categories, with increasing numbers indicating deeper nesting. Supports faceted navigation and drill-down discovery.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDisplayable rdf:type rdf:Property ;
    rdfs:label 'Is Displayable' ;
    rdfs:comment 'Indicates whether this tag should be displayed to end users in content detail pages, Electronic Program Guides (EPG), or Over-The-Top (OTT) platform interfaces. Some tags are for backend analytics only.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSearchable rdf:type rdf:Property ;
    rdfs:label 'Is Searchable' ;
    rdfs:comment 'Indicates whether this tag should be indexed and surfaced in user-facing search interfaces. Some tags may be used for internal classification or algorithmic purposes only.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'ISO 639-2/T three-letter language code indicating the language in which the tag value is expressed. Supports multilingual tagging for international content catalogs.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Free-text notes or comments from the editorial reviewer regarding the tag assignment. May include rationale for approval or rejection, suggested alternatives, or quality feedback.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Editorial review and approval status for the tag assignment. Supports quality control workflows where algorithmically-generated or partner-supplied tags require human validation before publication.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagSource rdf:type rdf:Property ;
    rdfs:label 'Tag Source' ;
    rdfs:comment 'Origin of the tag assignment. Indicates whether the tag was applied by internal editorial staff, generated by machine learning algorithms, provided by a content partner or rights holder, contributed by users, or supplied by the production team.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagType rdf:type rdf:Property ;
    rdfs:label 'Tag Type' ;
    rdfs:comment 'Category of the tag applied to the content. Defines the semantic purpose of the tag (e.g., mood for emotional tone, theme for subject matter, setting for location context, era for time period, franchise for brand universe, content_warning for viewer advisories, editorial_collection for curated groupings, campaign for promotional initiatives). [ENUM-REF-CANDIDATE: mood|theme|setting|era|franchise|universe|content_warning|editorial_collection|campaign|keyword — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagValue rdf:type rdf:Property ;
    rdfs:label 'Tag Value' ;
    rdfs:comment 'The specific controlled vocabulary term or label applied to the content. Examples: \'suspenseful\', \'family-friendly\', \'urban\', \'1980s\', \'Marvel Cinematic Universe\', \'violence\', \'holiday-special\', \'summer-blockbuster\'.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxonomyVersion rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Version' ;
    rdfs:comment 'Version number of the external taxonomy or controlled vocabulary system referenced by taxonomy_id. Tracks schema evolution and ensures backward compatibility.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weight rdf:type rdf:Property ;
    rdfs:label 'Weight' ;
    rdfs:comment 'Relative importance or prominence of this tag for the content asset, expressed as a decimal between 0.0000 and 1.0000. Higher weights indicate more central or defining characteristics. Used to prioritize tags in recommendation and discovery algorithms.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:talentCreditId rdf:type rdf:Property ;
    rdfs:label 'Talent Credit Id' ;
    rdfs:comment 'Unique identifier for the talent credit record. Primary key for the talent credit association entity.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roleId rdf:type rdf:Property ;
    rdfs:label 'Role Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_role. Business justification: Credits reference specific roles for character attribution, billing position validation, and role-specific residual eligibility. Eliminates denormalized role/character data and ensures single source o' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Role .

ind:billingPosition rdf:type rdf:Property ;
    rdfs:label 'Billing Position' ;
    rdfs:comment 'The ordinal position of the talent in the credit sequence, determining the order in which credits are displayed. Lower numbers indicate higher prominence (e.g., 1 = top billing). Used for EPG display and contractual compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Credit Approval Date' ;
    rdfs:comment 'The date on which the credit was officially approved for publication. Used for audit trails and compliance with guild credit determination timelines.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Approval Status' ;
    rdfs:comment 'Current approval state of the credit. Pending indicates awaiting review; Approved indicates credit is finalized and ready for publication; Disputed indicates a challenge has been raised; Rejected indicates credit was not approved; Arbitration indicates the credit is under formal guild arbitration process.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCategory rdf:type rdf:Property ;
    rdfs:label 'Credit Category' ;
    rdfs:comment 'High-level categorization of the credit by functional area or department. Used for grouping credits in EPG displays, streaming platform interfaces, and analytics. [ENUM-REF-CANDIDATE: cast|director|producer|writer|cinematography|editing|music|sound|production_design|costume|makeup|visual_effects|executive|other — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditDisplayName rdf:type rdf:Property ;
    rdfs:label 'Credit Display Name' ;
    rdfs:comment 'The exact name as it should appear in credits, EPG metadata, and streaming platform displays. May differ from the talents legal name if a pseudonym or stage name is used. This is the authoritative display value for all public-facing credit presentations.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditDisplayOrder rdf:type rdf:Property ;
    rdfs:label 'Credit Display Order' ;
    rdfs:comment 'The sequence number for displaying this credit within its credit type or section (e.g., within the cast section or crew section). Used for rendering credits in EPG, streaming platforms, and promotional materials.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Credit End Timestamp' ;
    rdfs:comment 'The timestamp marking when this credit ceases to be effective or visible. Nullable for credits that remain active indefinitely. Used for managing credit corrections, disputes, or contractual credit windows.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditNotes rdf:type rdf:Property ;
    rdfs:label 'Credit Notes' ;
    rdfs:comment 'Free-text field for additional context, special credit requirements, contractual stipulations, or notes related to credit disputes, arbitration outcomes, or special billing arrangements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Credit Start Timestamp' ;
    rdfs:comment 'The timestamp marking when this credit becomes effective or visible in EPG and streaming platform metadata. Used for managing credit changes over time and versioning.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditType rdf:type rdf:Property ;
    rdfs:label 'Credit Type' ;
    rdfs:comment 'Classification of the credit based on how the talent contribution is presented. On-screen credits appear in the visual content; off-screen credits appear in end titles or metadata only; voice credits are for voice-over or dubbing; stunt credits are for stunt performers; archive credits are for archival footage appearances.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pseudonymFlag rdf:type rdf:Property ;
    rdfs:label 'Pseudonym Flag' ;
    rdfs:comment 'Indicates whether the talent is credited under a pseudonym or stage name rather than their legal name. True if pseudonym is used; False if legal name is used. Relevant for guild compliance and contractual credit requirements.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualsEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Residuals Eligibility Flag' ;
    rdfs:comment 'Indicates whether this credit qualifies the talent for residual payments based on content reuse, syndication, or secondary distribution. True if eligible; False otherwise. Triggers residuals calculation workflows in the rights and royalties domain.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionAffiliationFlag rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation Flag' ;
    rdfs:comment 'Indicates whether the talent is affiliated with a recognized industry union (SAG-AFTRA, DGA, WGA, IATSE) for this credit. True if union-affiliated; False otherwise. Used for residuals eligibility determination and compliance reporting.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:colorFormat rdf:type rdf:Property ;
    rdfs:label 'Color Format' ;
    rdfs:comment 'Indicates whether the content is in color, black and white, or has been colorized. Used for archival classification and presentation metadata.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentStatus rdf:type rdf:Property ;
    rdfs:label 'Content Status' ;
    rdfs:comment 'Current lifecycle status of the content asset. Determines availability for scheduling, distribution, and monetization. Active content is available for use; archived content is retained but not actively distributed; restricted content has legal or rights limitations.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentType rdf:type rdf:Property ;
    rdfs:label 'Content Type' ;
    rdfs:comment 'Discriminator classifying the fundamental type of content asset. Determines applicable business rules for scheduling, rights windowing, and distribution strategies. [ENUM-REF-CANDIDATE: film|series|episode|clip|music|news|live_event|documentary — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaChildDirectedFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Child Directed Flag' ;
    rdfs:comment 'Indicates whether the content is directed to children under 13 years of age. Triggers COPPA compliance requirements for data collection, advertising restrictions, and privacy protections.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributorName rdf:type rdf:Property ;
    rdfs:label 'Distributor Name' ;
    rdfs:comment 'Name of the primary distributor or licensor of the content. Used for rights management, financial reconciliation, and contract tracking.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isrc rdf:type rdf:Property ;
    rdfs:label 'Isrc' ;
    rdfs:comment 'International standard code for uniquely identifying sound recordings and music video recordings. Used for music tracks and audio content royalty tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalLanguage rdf:type rdf:Property ;
    rdfs:label 'Original Language' ;
    rdfs:comment 'ISO 639-2 three-letter code representing the original language of the content production. Used for localization planning, dubbing, and subtitle workflows.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTitle rdf:type rdf:Property ;
    rdfs:label 'Original Title' ;
    rdfs:comment 'Original title name in the native language of production. Preserved for rights management, archival, and international distribution purposes.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalAdvisoryFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Advisory Flag' ;
    rdfs:comment 'Indicates whether the content carries a parental advisory warning for explicit content, violence, or mature themes. Used for compliance with broadcast standards and platform content policies.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the content was first released to the public or premiered. Used for rights availability calculations, windowing strategies, and anniversary programming.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Status' ;
    rdfs:comment 'Current rights availability status indicating whether the content can be legally broadcast or distributed. Drives scheduling decisions and geographic blackout enforcement.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studioName rdf:type rdf:Property ;
    rdfs:label 'Studio Name' ;
    rdfs:comment 'Name of the studio or production company that produced the content. Used for rights attribution, royalty calculations, and catalog organization.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subGenre rdf:type rdf:Property ;
    rdfs:label 'Sub Genre' ;
    rdfs:comment 'Secondary or more granular genre classification providing additional content categorization for advanced audience segmentation and personalization.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theatricalReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Theatrical Release Flag' ;
    rdfs:comment 'Indicates whether the content had a theatrical release. Used for windowing strategy, rights holdback periods, and marketing classification.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:titleName rdf:type rdf:Property ;
    rdfs:label 'Title Name' ;
    rdfs:comment 'Primary display name of the content title. The human-readable identifier used across all systems and customer-facing platforms.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Title Relationship Id' ;
    rdfs:comment 'Unique identifier for the title relationship record. Primary key.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceTitleId rdf:type rdf:Property ;
    rdfs:label 'Source Title Id' ;
    rdfs:comment 'The originating content title in the relationship. References the title that serves as the starting point of the relationship (e.g., the original film in a sequel relationship, the parent series in a spin-off).' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:targetTitleId rdf:type rdf:Property ;
    rdfs:label 'Target Title Id' ;
    rdfs:comment 'The destination content title in the relationship. References the title that is the result or endpoint of the relationship (e.g., the sequel film, the spin-off series, the remake).' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:bidirectionalFlag rdf:type rdf:Property ;
    rdfs:label 'Bidirectional Flag' ;
    rdfs:comment 'Indicates whether the relationship should be surfaced in both directions (e.g., show sequel on original AND show original on sequel). True for symmetric relationships like franchise siblings or crossovers, false for asymmetric relationships like clip-of or compilation.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:canonicalOrder rdf:type rdf:Property ;
    rdfs:label 'Canonical Order' ;
    rdfs:comment 'The sequence position of the target title within a series or franchise when viewed in canonical order (e.g., Episode IV is canonical_order 4 in Star Wars franchise). Null for non-sequential relationships like remakes or crossovers.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chronologicalOrder rdf:type rdf:Property ;
    rdfs:label 'Chronological Order' ;
    rdfs:comment 'The sequence position of the target title when viewed in story chronological order (e.g., Episode I is chronological_order 1 in Star Wars despite being released later). Null for non-sequential relationships.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayPriority rdf:type rdf:Property ;
    rdfs:label 'Display Priority' ;
    rdfs:comment 'Numeric ranking (lower numbers = higher priority) controlling the order in which related titles are displayed in user interfaces, Electronic Program Guides (EPG), and recommendation carousels. Enables editorial control over content discovery presentation.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:editorialNotes rdf:type rdf:Property ;
    rdfs:label 'Editorial Notes' ;
    rdfs:comment 'Free-text notes from content editors or curators explaining the nature, context, or nuances of the relationship. May include information about shared characters, plot connections, or reasons for the relationship classification.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'Identifier for this relationship in an external system or metadata provider (e.g., EIDR relationship ID, ISAN linkage ID, third-party content graph ID). Enables cross-system reconciliation and metadata enrichment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformVisibility rdf:type rdf:Property ;
    rdfs:label 'Platform Visibility' ;
    rdfs:comment 'Comma-separated list of platforms or distribution channels where this relationship should be surfaced (e.g., OTT, Linear, SVOD, AVOD, FAST). Enables platform-specific content discovery strategies. Empty or null indicates visibility across all platforms.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationWeight rdf:type rdf:Property ;
    rdfs:label 'Recommendation Weight' ;
    rdfs:comment 'Numeric weight (0.00 to 100.00) indicating the priority or relevance of this relationship for recommendation engine algorithms. Higher weights indicate stronger recommendation signals. Used to tune content discovery and auto-play sequences.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipDirection rdf:type rdf:Property ;
    rdfs:label 'Relationship Direction' ;
    rdfs:comment 'Indicates the directionality of the relationship. Forward means source points to target, reverse means target points back to source, bidirectional means the relationship is mutual and non-hierarchical (e.g., franchise siblings).' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle status of the relationship. Active relationships are live and used by recommendation engines. Pending relationships are scheduled but not yet effective. Inactive relationships are temporarily disabled. Deprecated relationships are historical and no longer relevant.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStrength rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength' ;
    rdfs:comment 'Indicates the strength or importance of the relationship for content discovery and recommendation purposes. Primary relationships are direct and essential (e.g., direct sequel), secondary are significant but less direct (e.g., shared universe), tertiary are weak connections (e.g., cameo appearance), tangential are loosely related (e.g., similar theme).' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'The nature of the relationship between the source and target titles. Defines how the two content assets are connected (e.g., sequel indicates target follows source chronologically, spin-off indicates target derives characters/universe from source, remake indicates target is a new version of source). [ENUM-REF-CANDIDATE: sequel|prequel|remake|reboot|spin-off|compilation|clip-of|franchise-sibling|crossover|adaptation|parody|documentary-of|behind-the-scenes — promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseOrder rdf:type rdf:Property ;
    rdfs:label 'Release Order' ;
    rdfs:comment 'The sequence position of the target title in the order of original release or premiere dates within the franchise or relationship set. Supports viewing content in historical release sequence.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionId rdf:type rdf:Property ;
    rdfs:label 'Version Id' ;
    rdfs:comment 'Primary key for version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionDrmPolicyId rdf:type rdf:Property ;
    rdfs:label 'Distribution Drm Policy Id' ;
    rdfs:comment 'Foreign key linking to distribution.drm_policy. Business justification: Each content version is protected by specific DRM policy (Widevine L1, HDCP 2.2 requirements). Required for rights enforcement, device compatibility validation, and studio compliance in premium conten' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrmPolicy .

ind:grantId rdf:type rdf:Property ;
    rdfs:label 'Grant Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_grant. Business justification: Version-specific grants (4K rights vs HD rights, dubbed vs subtitled) are tracked separately in modern distribution. Clearance systems must validate that the specific version has an active grant.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grant .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'Timestamp when this version was moved to long-term archive storage.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:audioCodec rdf:type rdf:Property ;
    rdfs:label 'Audio Codec' ;
    rdfs:comment 'Audio compression codec used for this version (e.g., \'AAC\', \'AC-3\', \'E-AC-3\', \'Dolby Atmos\', \'DTS\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioTrackConfiguration rdf:type rdf:Property ;
    rdfs:label 'Audio Track Configuration' ;
    rdfs:comment 'Comma-separated list of audio track languages and types available in this version (e.g., \'en:stereo,es:5.1,fr:stereo,en:descriptive\').' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastSafe rdf:type rdf:Property ;
    rdfs:label 'Broadcast Safe' ;
    rdfs:comment 'Indicates whether this version has been certified as broadcast-safe, meeting technical standards for linear transmission (audio levels, video levels, closed captioning).' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:colorSpace rdf:type rdf:Property ;
    rdfs:label 'Color Space' ;
    rdfs:comment 'Color space standard used for this version (Rec. 709, Rec. 2020, DCI-P3, sRGB).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isrcCode rdf:type rdf:Property ;
    rdfs:label 'Isrc Code' ;
    rdfs:comment 'International Standard Recording Code for music or audio content versions, enabling tracking and royalty distribution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Human-readable label identifying this version (e.g., \'Theatrical Cut\', \'Director\'s Cut\', \'Broadcast Safe\', \'Spanish Dub\', \'UK Censored\').' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Primary Language Code' ;
    rdfs:comment 'ISO 639 two or three-letter code for the primary audio language of this version (e.g., \'en\', \'es\', \'fr\').' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Qc Completed Date' ;
    rdfs:comment 'Date when quality control review was completed for this version.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolution rdf:type rdf:Property ;
    rdfs:label 'Resolution' ;
    rdfs:comment 'Video resolution classification for this version (SD, HD 720p, HD 1080p, UHD 4K, UHD 8K).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runtimeDeltaSeconds rdf:type rdf:Property ;
    rdfs:label 'Runtime Delta Seconds' ;
    rdfs:comment 'Difference in runtime (in seconds) between this version and the master version. Positive values indicate longer runtime, negative indicate shorter.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical or logical storage location identifier where this version is archived (e.g., tape library ID, cloud bucket path, MAM archive reference).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleLanguages rdf:type rdf:Property ;
    rdfs:label 'Subtitle Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639 language codes for subtitle tracks included in this version (e.g., \'en,es,fr,de\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPlatform rdf:type rdf:Property ;
    rdfs:label 'Target Platform' ;
    rdfs:comment 'Distribution platform or window this version is optimized for (e.g., linear broadcast, SVOD, AVOD, theatrical). [ENUM-REF-CANDIDATE: linear_broadcast|svod|avod|tvod|theatrical|home_video|syndication|fast|mvpd|vmvpd — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTerritory rdf:type rdf:Property ;
    rdfs:label 'Target Territory' ;
    rdfs:comment 'Three-letter ISO country code indicating the primary geographic territory this version is intended for (e.g., USA, GBR, FRA).' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of the version indicating its readiness for distribution and playout. [ENUM-REF-CANDIDATE: draft|in_production|qc_pending|approved|active|archived|deprecated|rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionType rdf:type rdf:Property ;
    rdfs:label 'Version Type' ;
    rdfs:comment 'Classification of the version type indicating the nature of the edit or adaptation. [ENUM-REF-CANDIDATE: theatrical|broadcast|director|extended|unrated|censored|dubbed|subtitled|localized|preview|trailer — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCodec rdf:type rdf:Property ;
    rdfs:label 'Video Codec' ;
    rdfs:comment 'Video compression codec used for this version (e.g., \'H.264\', \'H.265/HEVC\', \'VP9\', \'AV1\', \'MPEG-2\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLicenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Governing License Agreement Id' ;
    rdfs:comment 'Foreign key linking to rights.license_agreement. Business justification: Windowing strategies must comply with license agreement terms (holdbacks, exclusivity windows, platform restrictions). Windowing plan validation and conflict detection require checking against the gov' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:marketingCampaignId rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Id' ;
    rdfs:comment 'Reference identifier for the marketing campaign associated with this window release. Links to promotional activities, advertising spend, and audience acquisition efforts.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:primaryWindowingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Windowing Employee Id' ;
    rdfs:comment 'Identifier of the content planning or distribution strategy team member who created this windowing plan. Used for accountability and workflow tracking.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:abrEnabled rdf:type rdf:Property ;
    rdfs:label 'Abr Enabled' ;
    rdfs:comment 'Indicates whether adaptive bitrate streaming is enabled for this window, allowing dynamic quality adjustment based on viewer bandwidth. True=ABR enabled, False=fixed bitrate.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioConfiguration rdf:type rdf:Property ;
    rdfs:label 'Audio Configuration' ;
    rdfs:comment 'The audio format specification for this window. Stereo=2-channel, Surround 5.1=5.1 channel surround, Surround 7.1=7.1 channel surround, Dolby Atmos=object-based audio, DTS:X=immersive audio format.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutRestrictions rdf:type rdf:Property ;
    rdfs:label 'Blackout Restrictions' ;
    rdfs:comment 'Geographic or temporal blackout rules that restrict content availability in specific regions or time periods within the territory (e.g., sports blackouts, regional exclusions).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleEligibility rdf:type rdf:Property ;
    rdfs:label 'Bundle Eligibility' ;
    rdfs:comment 'Indicates whether this content is eligible for inclusion in subscription bundles or multi-title packages during this window. True=bundle eligible, False=standalone only.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concurrentStreamsLimit rdf:type rdf:Property ;
    rdfs:label 'Concurrent Streams Limit' ;
    rdfs:comment 'Maximum number of simultaneous streams allowed per subscriber account for this content in this window. Used for subscription service tier management.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentFormat rdf:type rdf:Property ;
    rdfs:label 'Content Format' ;
    rdfs:comment 'The technical format specification for content delivery in this window. SD=standard definition, HD=high definition 1080p, 4K=ultra high definition, 8K=8K resolution, HDR=high dynamic range, Dolby Vision=premium HDR format.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartRestriction rdf:type rdf:Property ;
    rdfs:label 'Daypart Restriction' ;
    rdfs:comment 'Time-of-day broadcast restrictions for linear windows, defining when content may air (e.g., prime time only, late night only, daytime safe). Applies primarily to linear broadcast and cable windows.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadToGoEnabled rdf:type rdf:Property ;
    rdfs:label 'Download To Go Enabled' ;
    rdfs:comment 'Indicates whether offline download capability is enabled for this window, allowing viewers to download content for offline viewing. True=downloads allowed, False=streaming only.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dubbingAvailability rdf:type rdf:Property ;
    rdfs:label 'Dubbing Availability' ;
    rdfs:comment 'Indicates whether dubbed audio tracks in alternate languages are available for this window release. True=dubbing provided, False=original language only.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityTier rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Tier' ;
    rdfs:comment 'The level of exclusivity granted to the platform during this window. Exclusive=sole distribution rights, Non-Exclusive=concurrent availability on multiple platforms, Shared Exclusive=limited to a defined group of platforms, First Run=premiere window, Second Run=subsequent availability.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackDurationDays rdf:type rdf:Property ;
    rdfs:label 'Holdback Duration Days' ;
    rdfs:comment 'The number of days between the close of the previous window and the open of this window, representing the exclusivity period or gap between release phases.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageVersion rdf:type rdf:Property ;
    rdfs:label 'Language Version' ;
    rdfs:comment 'ISO 639-2 or ISO 639-3 language code for the primary audio/subtitle language version to be released in this window (e.g., eng, spa, fra, deu).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Planned Close Date' ;
    rdfs:comment 'The intended end date when the content will no longer be available on the specified platform/channel in the specified territory. Nullable for open-ended windows.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedOpenDate rdf:type rdf:Property ;
    rdfs:label 'Planned Open Date' ;
    rdfs:comment 'The intended start date when the content becomes available on the specified platform/channel in the specified territory. Represents the editorial/commercial release plan.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricePoint rdf:type rdf:Property ;
    rdfs:label 'Price Point' ;
    rdfs:comment 'The consumer-facing price for transactional windows (TVOD, EST, PPV) in the specified currency. Represents the retail price charged to end viewers.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Pricing Flag' ;
    rdfs:comment 'Indicates whether promotional or discounted pricing is applied for this window. True=promotional pricing active, False=standard pricing.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Model' ;
    rdfs:comment 'The monetization approach for this window. Subscription=SVOD model, Advertising=AVOD model, Transactional=TVOD/PPV/EST, Hybrid=combination of models, Free=no direct revenue.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamingProtocol rdf:type rdf:Property ;
    rdfs:label 'Streaming Protocol' ;
    rdfs:comment 'The streaming delivery protocol used for OTT windows. HLS=HTTP Live Streaming (Apple), DASH=Dynamic Adaptive Streaming over HTTP (MPEG-DASH), Smooth Streaming=Microsoft, RTMP=Real-Time Messaging Protocol, WebRTC=real-time communication.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleAvailability rdf:type rdf:Property ;
    rdfs:label 'Subtitle Availability' ;
    rdfs:comment 'Indicates whether subtitles or closed captions are available for this window release. True=subtitles provided, False=no subtitles.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:viewingWindowHours rdf:type rdf:Property ;
    rdfs:label 'Viewing Window Hours' ;
    rdfs:comment 'For TVOD/rental windows, the number of hours a viewer has to complete watching the content after initiating playback (e.g., 48-hour rental window).' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Window Sequence Number' ;
    rdfs:comment 'Sequential ordering of this window within the overall release strategy for the content. Lower numbers indicate earlier windows (e.g., 1=theatrical, 2=SVOD, 3=AVOD).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowStatus rdf:type rdf:Property ;
    rdfs:label 'Window Status' ;
    rdfs:comment 'Current lifecycle status of the windowing plan. Planned=initial strategy, Confirmed=approved by stakeholders, Active=currently in release window, Completed=window has closed, Cancelled=window will not execute, Postponed=delayed to future date.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowType rdf:type rdf:Property ;
    rdfs:label 'Window Type' ;
    rdfs:comment 'The distribution window category defining the release channel type. Theatrical=cinema release, SVOD=subscription video on demand, AVOD=advertising-supported video on demand, TVOD=transactional video on demand, Linear Broadcast=traditional scheduled TV, Home Video=physical media, Syndication=content resale to multiple outlets, FAST=free ad-supported streaming television, PPV=pay-per-view, EST=electronic sell-through. [ENUM-REF-CANDIDATE: theatrical|svod|avod|tvod|linear_broadcast|home_video|syndication|fast|vod|ppv|est — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastStandardId rdf:type rdf:Property ;
    rdfs:label 'Broadcast Standard Id' ;
    rdfs:comment 'Foreign key linking to technology.broadcast_standard. Business justification: ABR profiles implement broadcast standards (HLS, DASH). Required for broadcast standard compliance verification and device interoperability testing.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastStandard .

ind:formatSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Format Specification Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.format_specification. Business justification: ABR profiles implement technical delivery standards (codec, bitrate ladder, resolution tiers) defined in format specifications. Broadcasters validate ABR configs against house specs for compliance. Qo' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormatSpecification .

ind:audioBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Audio Bitrate Kbps' ;
    rdfs:comment 'Audio bitrate in kilobits per second (e.g., 128, 192, 256). Defines audio quality.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioChannelConfig rdf:type rdf:Property ;
    rdfs:label 'Audio Channel Config' ;
    rdfs:comment 'Audio channel layout (mono, stereo, 5.1 surround, 7.1 surround, Dolby Atmos). Defines spatial audio configuration.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnOptimizationFlag rdf:type rdf:Property ;
    rdfs:label 'Cdn Optimization Flag' ;
    rdfs:comment 'Indicates whether the profile is optimized for CDN delivery with caching-friendly segment naming and structure. True if CDN-optimized; false otherwise.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerFormat rdf:type rdf:Property ;
    rdfs:label 'Container Format' ;
    rdfs:comment 'Media container format for the encoded segments (fMP4 for DASH, TS for HLS, MP4, WebM). Defines how video and audio streams are packaged.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Drm Support Flag' ;
    rdfs:comment 'Indicates whether the profile supports DRM encryption. True if DRM is enabled; false otherwise.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmSystem rdf:type rdf:Property ;
    rdfs:label 'Drm System' ;
    rdfs:comment 'DRM system(s) supported by this profile (Widevine, PlayReady, FairPlay Streaming, Multi-DRM). Null if DRM is not enabled.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encodingPreset rdf:type rdf:Property ;
    rdfs:label 'Encoding Preset' ;
    rdfs:comment 'Encoder speed/quality preset (fast, medium, slow, veryslow). Slower presets yield better compression but require more processing time.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdrSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Hdr Support Flag' ;
    rdfs:comment 'Indicates whether the profile supports HDR (High Dynamic Range) video. True if HDR is enabled; false for SDR (Standard Dynamic Range) only.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyframeIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Keyframe Interval Seconds' ;
    rdfs:comment 'Interval between keyframes (I-frames) in seconds. Aligns with segment duration for seamless ABR switching.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manifestTemplateReference rdf:type rdf:Property ;
    rdfs:label 'Manifest Template Reference' ;
    rdfs:comment 'Reference to the MPEG-DASH MPD or HLS M3U8 manifest template used for this profile. Defines playlist structure and metadata.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Max Bitrate Kbps' ;
    rdfs:comment 'Highest video bitrate in kilobits per second across all renditions in the ladder. Used for high-quality streaming on fast connections.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxResolution rdf:type rdf:Property ;
    rdfs:label 'Max Resolution' ;
    rdfs:comment 'Highest video resolution in the ladder (e.g., \'1920x1080\', \'3840x2160\'). Defines the top quality tier.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Min Bitrate Kbps' ;
    rdfs:comment 'Lowest video bitrate in kilobits per second across all renditions in the ladder. Used for low-bandwidth scenarios.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minResolution rdf:type rdf:Property ;
    rdfs:label 'Min Resolution' ;
    rdfs:comment 'Lowest video resolution in the ladder (e.g., \'320x180\', \'640x360\'). Typically used for mobile or constrained bandwidth.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Unique business identifier code for the ABR profile used in transcode job requests and CDN configuration.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileDescription rdf:type rdf:Property ;
    rdfs:label 'Profile Description' ;
    rdfs:comment 'Detailed description of the ABR profile, including use cases, target audience, and technical notes.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable name of the ABR profile (e.g., \'Premium 4K HDR\', \'Standard HD\', \'Mobile Optimized\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosTier rdf:type rdf:Property ;
    rdfs:label 'Qos Tier' ;
    rdfs:comment 'Quality of Service tier associated with this profile (premium, standard, basic). Influences CDN priority and SLA commitments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renditionCount rdf:type rdf:Property ;
    rdfs:label 'Rendition Count' ;
    rdfs:comment 'Total number of video renditions (bitrate/resolution variants) in the ABR ladder. Typical range is 3-10 renditions.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Segment Duration Seconds' ;
    rdfs:comment 'Duration of each media segment in seconds (e.g., 2, 4, 6, 10). Shorter segments enable faster ABR switching but increase overhead.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetDeviceClass rdf:type rdf:Property ;
    rdfs:label 'Target Device Class' ;
    rdfs:comment 'Primary device class this profile is optimized for (mobile, tablet, desktop, smart TV, set-top box, gaming console). Influences resolution and bitrate choices.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiEndpointId rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Id' ;
    rdfs:comment 'Unique identifier for the API endpoint. Primary key.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nocMonitorId rdf:type rdf:Property ;
    rdfs:label 'Noc Monitor Id' ;
    rdfs:comment 'Foreign key linking to technology.noc_monitor. Business justification: API endpoints require NOC monitoring for availability. Required for API monitoring setup and SLA compliance measurement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NocMonitor .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: API endpoints require engineering ownership for deprecation decisions, rate limit adjustments, SLA monitoring, and breaking change management. Essential for on-call rotations, API versioning accountab' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:techProjectId rdf:type rdf:Property ;
    rdfs:label 'Tech Project Id' ;
    rdfs:comment 'Foreign key linking to technology.tech_project. Business justification: API endpoints are developed via technology projects. Required for API development project tracking and feature release management.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechProject .

ind:techSlaId rdf:type rdf:Property ;
    rdfs:label 'Tech Sla Id' ;
    rdfs:comment 'Foreign key linking to technology.tech_sla. Business justification: API endpoints have technology SLAs for availability and response time. Required for API SLA compliance tracking and performance optimization.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechSla .

ind:activatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activated Timestamp' ;
    rdfs:comment 'The date and time when this endpoint was activated and made available for use. Null if the endpoint has never been activated or is still in development.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allowedOrigins rdf:type rdf:Property ;
    rdfs:label 'Allowed Origins' ;
    rdfs:comment 'Comma-separated list of allowed origin domains for CORS requests (e.g., https://www.example.com, https://app.example.com). Asterisk (*) indicates all origins are allowed. Null if CORS is disabled.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiVersion rdf:type rdf:Property ;
    rdfs:label 'Api Version' ;
    rdfs:comment 'The version of the API that this endpoint belongs to (e.g., v1, v2, v3). Used for versioning and backward compatibility management.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationScheme rdf:type rdf:Property ;
    rdfs:label 'Authentication Scheme' ;
    rdfs:comment 'The authentication mechanism required to access this endpoint (OAuth2 for token-based, API key for simple key-based, JWT for JSON Web Token, basic auth for username/password, none for public endpoints).' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationScope rdf:type rdf:Property ;
    rdfs:label 'Authorization Scope' ;
    rdfs:comment 'The OAuth2 scope or permission level required to access this endpoint (e.g., read:content, write:profile, admin:all). Defines what actions the authenticated user is authorized to perform.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cacheStrategy rdf:type rdf:Property ;
    rdfs:label 'Cache Strategy' ;
    rdfs:comment 'The caching strategy applied to responses from this endpoint (no_cache for dynamic data, private for user-specific data, public for shared data, cdn for CDN-cacheable content).' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cacheTtlSeconds rdf:type rdf:Property ;
    rdfs:label 'Cache Ttl Seconds' ;
    rdfs:comment 'The time-to-live in seconds for cached responses from this endpoint. Defines how long the response can be cached before it must be revalidated. Null indicates no caching.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:corsEnabled rdf:type rdf:Property ;
    rdfs:label 'Cors Enabled' ;
    rdfs:comment 'Indicates whether Cross-Origin Resource Sharing is enabled for this endpoint (true), allowing web browsers to make requests from different domains, or disabled (false) for same-origin only.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deprecationDate rdf:type rdf:Property ;
    rdfs:label 'Deprecation Date' ;
    rdfs:comment 'The date when this endpoint was officially marked as deprecated. Used to track the deprecation timeline and communicate sunset schedules to API consumers.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endpointDescription rdf:type rdf:Property ;
    rdfs:label 'Endpoint Description' ;
    rdfs:comment 'Detailed description of the endpoint\'s purpose, functionality, and business use case. Explains what the endpoint does and when it should be used.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointName rdf:type rdf:Property ;
    rdfs:label 'Endpoint Name' ;
    rdfs:comment 'Human-readable name or label for the API endpoint (e.g., Content Search, Playback Authorization, Subscriber Entitlement Check).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointPath rdf:type rdf:Property ;
    rdfs:label 'Endpoint Path' ;
    rdfs:comment 'The URI path of the API endpoint (e.g., /api/v2/content/search, /api/v1/playback/authorize). This is the resource path exposed to API consumers.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointStatus rdf:type rdf:Property ;
    rdfs:label 'Endpoint Status' ;
    rdfs:comment 'The current operational status of the endpoint (active for production use, beta for testing with select partners, alpha for internal testing, inactive for disabled, maintenance for temporary unavailability).' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCategory rdf:type rdf:Property ;
    rdfs:label 'Functional Category' ;
    rdfs:comment 'The business function or domain that this endpoint serves (e.g., content discovery for browsing, playback authorization for DRM, DAI for Dynamic Ad Insertion, EPG for Electronic Program Guide). [ENUM-REF-CANDIDATE: content_discovery|playback_authorization|subscriber_entitlement|epg|search|recommendation|dai|user_profile|analytics|billing — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:httpMethod rdf:type rdf:Property ;
    rdfs:label 'Http Method' ;
    rdfs:comment 'The HTTP method supported by this endpoint (GET for retrieval, POST for creation, PUT for full update, PATCH for partial update, DELETE for removal). [ENUM-REF-CANDIDATE: GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeprecated rdf:type rdf:Property ;
    rdfs:label 'Is Deprecated' ;
    rdfs:comment 'Indicates whether this endpoint has been marked as deprecated (true) and should no longer be used by new integrations. Deprecated endpoints are maintained for backward compatibility but will eventually be removed.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublic rdf:type rdf:Property ;
    rdfs:label 'Is Public' ;
    rdfs:comment 'Indicates whether this endpoint is publicly accessible without authentication (true) or requires authentication (false). Public endpoints are typically used for content discovery and marketing.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:owningService rdf:type rdf:Property ;
    rdfs:label 'Owning Service' ;
    rdfs:comment 'The name of the microservice or backend service that implements and owns this endpoint (e.g., content-service, playback-service, subscriber-service). Used for operational ownership and incident routing.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Team' ;
    rdfs:comment 'The engineering team responsible for maintaining and supporting this endpoint (e.g., Content Platform Team, Playback Engineering, Subscriber Services). Used for escalation and change management.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLimitRequestsPerDay rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Requests Per Day' ;
    rdfs:comment 'The maximum number of requests allowed per day for this endpoint under the assigned rate limit tier. Used for daily quota enforcement.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateLimitRequestsPerMinute rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Requests Per Minute' ;
    rdfs:comment 'The maximum number of requests allowed per minute for this endpoint under the assigned rate limit tier. Null indicates no specific limit or unlimited access.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateLimitTier rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Tier' ;
    rdfs:comment 'The rate limiting tier applied to this endpoint, determining how many requests per time window are allowed (e.g., public tier allows 100 req/min, enterprise allows 10000 req/min).' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementEndpointPath rdf:type rdf:Property ;
    rdfs:label 'Replacement Endpoint Path' ;
    rdfs:comment 'The URI path of the replacement endpoint that should be used instead of this deprecated endpoint. Null if no direct replacement exists. Used to guide API consumers during migration.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestContentType rdf:type rdf:Property ;
    rdfs:label 'Request Content Type' ;
    rdfs:comment 'The expected content type for the request body (e.g., application/json for JSON payloads, application/xml for XML). Null for endpoints that do not accept a request body (e.g., GET requests).' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseContentType rdf:type rdf:Property ;
    rdfs:label 'Response Content Type' ;
    rdfs:comment 'The content type returned by this endpoint in the response body (e.g., application/json for JSON responses, application/xml for XML). Defines the format of the data returned to the client.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Ms' ;
    rdfs:comment 'The target response time in milliseconds for this endpoint under normal load conditions (e.g., 200ms for p95, 500ms for p99). Used for performance monitoring and alerting.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'The service level agreement tier for this endpoint, defining uptime guarantees, response time targets, and support priority (e.g., mission_critical requires 99.99% uptime, gold requires 99.9%).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percentage' ;
    rdfs:comment 'The guaranteed uptime percentage for this endpoint as defined in the SLA (e.g., 99.99 for four nines, 99.9 for three nines). Measured monthly.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sunsetDate rdf:type rdf:Property ;
    rdfs:label 'Sunset Date' ;
    rdfs:comment 'The planned date when this endpoint will be permanently removed and no longer available. Null if no sunset is planned. Used to give API consumers advance notice for migration.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportsFiltering rdf:type rdf:Property ;
    rdfs:label 'Supports Filtering' ;
    rdfs:comment 'Indicates whether this endpoint supports query parameter filtering to narrow down results (true) or returns a fixed result set (false). Filtering allows clients to request specific subsets of data.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsPagination rdf:type rdf:Property ;
    rdfs:label 'Supports Pagination' ;
    rdfs:comment 'Indicates whether this endpoint supports pagination for large result sets (true) or returns all results in a single response (false). Paginated endpoints typically accept page and page_size query parameters.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsSorting rdf:type rdf:Property ;
    rdfs:label 'Supports Sorting' ;
    rdfs:comment 'Indicates whether this endpoint supports query parameter sorting to order results (true) or returns results in a default order (false). Sorting allows clients to control result ordering.' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appVersionId rdf:type rdf:Property ;
    rdfs:label 'App Version Id' ;
    rdfs:comment 'Unique identifier for each application version release. Primary key for the app_version product.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AppVersion .

ind:abTestCohort rdf:type rdf:Property ;
    rdfs:label 'Ab Test Cohort' ;
    rdfs:comment 'Identifier for the A/B test cohort or experiment group assigned to this application version. Used for controlled feature testing and user experience optimization.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeInstallCount rdf:type rdf:Property ;
    rdfs:label 'Active Install Count' ;
    rdfs:comment 'The current number of active installations of this application version across all users. Used for version adoption tracking and deprecation planning.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analyticsSdkVersion rdf:type rdf:Property ;
    rdfs:label 'Analytics Sdk Version' ;
    rdfs:comment 'Version of the analytics SDK integrated for tracking user engagement, viewership metrics, and QoS (Quality of Service) data.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appSizeMb rdf:type rdf:Property ;
    rdfs:label 'App Size Mb' ;
    rdfs:comment 'The total download size of the application package in megabytes. Important for user download experience and app store requirements.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildNumber rdf:type rdf:Property ;
    rdfs:label 'Build Number' ;
    rdfs:comment 'Internal build identifier assigned by the continuous integration system. Used for precise version tracking and debugging. May be numeric or alphanumeric.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaCompliant rdf:type rdf:Property ;
    rdfs:label 'Ccpa Compliant' ;
    rdfs:comment 'Indicates whether this application version meets CCPA (California Consumer Privacy Act) requirements for viewer data privacy in California.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdnEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Cdn Endpoint Url' ;
    rdfs:comment 'The primary CDN (Content Delivery Network) endpoint URL configured for this application version. Determines content delivery infrastructure and streaming performance.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionSupport rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Support' ;
    rdfs:comment 'Indicates whether this application version supports closed captioning and subtitles for accessibility compliance.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crashReportingEnabled rdf:type rdf:Property ;
    rdfs:label 'Crash Reporting Enabled' ;
    rdfs:comment 'Indicates whether automated crash reporting and error tracking is enabled for this application version. Critical for QoS root-cause analysis.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daiEnabled rdf:type rdf:Property ;
    rdfs:label 'Dai Enabled' ;
    rdfs:comment 'Indicates whether this application version supports DAI (Dynamic Ad Insertion) for server-side ad stitching in streaming content.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dashSupportEnabled rdf:type rdf:Property ;
    rdfs:label 'Dash Support Enabled' ;
    rdfs:comment 'Indicates whether this application version supports MPEG-DASH (Dynamic Adaptive Streaming over HTTP) protocol for video streaming.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dolbyAtmosEnabled rdf:type rdf:Property ;
    rdfs:label 'Dolby Atmos Enabled' ;
    rdfs:comment 'Indicates whether this application version supports Dolby Atmos immersive audio technology.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmLibraryVersion rdf:type rdf:Property ;
    rdfs:label 'Drm Library Version' ;
    rdfs:comment 'Version of the DRM (Digital Rights Management) library integrated into this application build. Critical for content protection and license enforcement compliance.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureFlags rdf:type rdf:Property ;
    rdfs:label 'Feature Flags' ;
    rdfs:comment 'Comma-separated list or JSON string of feature flags enabled in this application version. Controls experimental features, A/B test variants, and gradual rollout capabilities.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceUpgradeThreshold rdf:type rdf:Property ;
    rdfs:label 'Force Upgrade Threshold' ;
    rdfs:comment 'The minimum application version number below which users will be forced to upgrade. Used to enforce critical security patches or deprecate incompatible versions.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprCompliant rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant' ;
    rdfs:comment 'Indicates whether this application version meets GDPR (General Data Protection Regulation) requirements for user data privacy and consent management in EU markets.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdrSupportEnabled rdf:type rdf:Property ;
    rdfs:label 'Hdr Support Enabled' ;
    rdfs:comment 'Indicates whether this application version supports HDR (High Dynamic Range) video playback for enhanced picture quality.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hlsSupportEnabled rdf:type rdf:Property ;
    rdfs:label 'Hls Support Enabled' ;
    rdfs:comment 'Indicates whether this application version supports HLS (HTTP Live Streaming) protocol for adaptive bitrate video delivery.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal technical notes and documentation for this application version. Includes deployment instructions, known issues, and rollback procedures.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBitrateMbps rdf:type rdf:Property ;
    rdfs:label 'Max Bitrate Mbps' ;
    rdfs:comment 'The maximum streaming bitrate supported by this application version in Mbps. Determines highest video quality available through ABR (Adaptive Bitrate Streaming).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOsVersion rdf:type rdf:Property ;
    rdfs:label 'Minimum Os Version' ;
    rdfs:comment 'The minimum operating system version required to run this application version. Format varies by platform (e.g., iOS 14.0, Android 10, Roku OS 9.4).' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offlinePlaybackEnabled rdf:type rdf:Property ;
    rdfs:label 'Offline Playback Enabled' ;
    rdfs:comment 'Indicates whether this application version supports offline content download and playback for SVOD (Subscription Video On Demand) users.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerSdkVersion rdf:type rdf:Property ;
    rdfs:label 'Player Sdk Version' ;
    rdfs:comment 'Version of the video player SDK embedded in this application. Determines streaming capabilities, ABR (Adaptive Bitrate Streaming) support, and playback features.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNotes rdf:type rdf:Property ;
    rdfs:label 'Release Notes' ;
    rdfs:comment 'User-facing description of new features, bug fixes, and improvements included in this application version. Published in app stores and update notifications.' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Current lifecycle status of the application version. Tracks progression from development through production release to eventual deprecation. [ENUM-REF-CANDIDATE: development|alpha|beta|release_candidate|released|deprecated|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloutPercentage rdf:type rdf:Property ;
    rdfs:label 'Rollout Percentage' ;
    rdfs:comment 'The percentage of users to whom this application version is currently deployed. Used for gradual rollout and canary deployment strategies (0.00 to 100.00).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportedResolutions rdf:type rdf:Property ;
    rdfs:label 'Supported Resolutions' ;
    rdfs:comment 'Comma-separated list of video resolutions supported by this application version (e.g., 480p, 720p, 1080p, 4K). Determines playback quality options.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: Carriage agreements are managed by assigned sales reps who negotiate terms and maintain partner relationships. Critical for rep commission calculation on carriage fees, account ownership tracking, and' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:contractOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Carriage agreements are high-value contracts requiring business/legal owner for amendments, renewal negotiations, retransmission consent disputes, and must-carry elections. Essential for approval work' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:masterInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Master Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Carriage agreements generate master invoices for services beyond specialized carriage fee invoices (setup fees, equipment, technical services). Real business process: comprehensive agreement billing, ' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:networkCircuitId rdf:type rdf:Property ;
    rdfs:label 'Network Circuit Id' ;
    rdfs:comment 'Foreign key linking to technology.network_circuit. Business justification: Carriage agreements specify dedicated network circuits for content delivery. Required for technical compliance verification and circuit cost allocation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkCircuit .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique identifier or contract number for this carriage agreement, used in business communications and legal references.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the carriage agreement: draft (being prepared), active (in force), suspended (temporarily paused), expired (term ended), terminated (cancelled before expiry), or under negotiation (renewal or amendment in progress).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the carriage agreement: retransmission consent (FCC-regulated authorization for MVPDs to rebroadcast OTA signals), must-carry (mandatory carriage under FCC rules), voluntary carriage (negotiated carriage without must-carry obligation), or platform carriage (OTT/vMVPD distribution agreement).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the agreement automatically renews at the end of the term unless either party provides termination notice.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutProvisions rdf:type rdf:Property ;
    rdfs:label 'Blackout Provisions' ;
    rdfs:comment 'Geographic or temporal restrictions on content availability, such as sports blackout rules, local market exclusions, or event-specific restrictions required by rights holders or league rules.' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Amount' ;
    rdfs:comment 'Monetary compensation paid by the distribution partner to the content provider for the right to carry the channel or content package. May be per-subscriber, flat fee, or tiered based on subscriber count.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carriageFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the carriage fee amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeStructure rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Structure' ;
    rdfs:comment 'Pricing model for the carriage fee: per-subscriber (fee per active subscriber), flat monthly (fixed monthly payment), tiered (rate varies by subscriber volume), revenue share (percentage of ad or subscription revenue), or barter (non-cash compensation such as promotional commitments or channel positioning).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelNumberAssignment rdf:type rdf:Property ;
    rdfs:label 'Channel Number Assignment' ;
    rdfs:comment 'The channel number or dial position assigned to the channel on the distribution platform. May vary by market or headend.' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPositioningTier rdf:type rdf:Property ;
    rdfs:label 'Channel Positioning Tier' ;
    rdfs:comment 'The service tier or package in which the channel is positioned (e.g., basic, expanded basic, premium, sports tier). Affects channel visibility and subscriber reach.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationTerms rdf:type rdf:Property ;
    rdfs:label 'Compensation Terms' ;
    rdfs:comment 'Detailed description of all compensation provided under the agreement, including cash payments, barter arrangements (e.g., promotional commitments, ad inventory exchange), channel carriage reciprocity, or other non-monetary considerations.' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Agreed method for resolving disputes arising under the agreement: arbitration (binding third-party decision), mediation (facilitated negotiation), litigation (court proceedings), or negotiation (direct party-to-party resolution).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmRequirements rdf:type rdf:Property ;
    rdfs:label 'Drm Requirements' ;
    rdfs:comment 'DRM and content protection requirements mandated under the agreement, such as encryption standards, conditional access systems, watermarking, and anti-piracy measures.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityWindow rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Window' ;
    rdfs:comment 'Period during which the distribution partner has exclusive carriage rights within a defined geographic territory or platform category (e.g., exclusive MVPD rights in a DMA, exclusive vMVPD rights nationally).' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Geographic scope of the carriage agreement, typically expressed as authorized DMAs (Designated Market Areas), states, regions, or national coverage. Defines where the distribution partner is authorized to carry the content.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction and governing law applicable to the agreement (e.g., State of New York, England and Wales). Determines which courts and laws apply in case of dispute.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackRestrictions rdf:type rdf:Property ;
    rdfs:label 'Holdback Restrictions' ;
    rdfs:comment 'Restrictions on when or where content may be made available on other platforms or windows. Protects the distribution partners investment by limiting competing distribution during the agreement term.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or modification to the carriage agreement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumSubscriberGuarantee rdf:type rdf:Property ;
    rdfs:label 'Minimum Subscriber Guarantee' ;
    rdfs:comment 'Minimum number of subscribers the distribution partner guarantees to deliver for the channel. Used in per-subscriber fee calculations and performance commitments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mustCarryElection rdf:type rdf:Property ;
    rdfs:label 'Must Carry Election' ;
    rdfs:comment 'Indicates whether the broadcaster has elected must-carry status under FCC rules, requiring the MVPD to carry the signal without negotiation. Applicable to qualified broadcast stations.' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiationHistory rdf:type rdf:Property ;
    rdfs:label 'Negotiation History' ;
    rdfs:comment 'Summary of key negotiation milestones, amendments, and material changes to the agreement over its lifecycle. Provides context for current terms and future renegotiations.' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalCommitment rdf:type rdf:Property ;
    rdfs:label 'Promotional Commitment' ;
    rdfs:comment 'Marketing and promotional obligations agreed by either party, such as on-air promotion, co-marketing campaigns, EPG placement guarantees, or cross-platform promotion.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Conditions and terms governing agreement renewal, including renewal period length, rate adjustments, renegotiation triggers, and notice requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentGranted rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Granted' ;
    rdfs:comment 'Indicates whether retransmission consent has been granted under FCC regulations, authorizing the MVPD to rebroadcast over-the-air signals. Applicable only to retransmission consent agreement types.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'Performance commitments and service quality standards, including uptime guarantees, signal quality metrics, fault resolution times, and penalties for non-compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalDeliveryRequirements rdf:type rdf:Property ;
    rdfs:label 'Technical Delivery Requirements' ;
    rdfs:comment 'Technical specifications for content delivery, including signal format (HD, 4K, HDR), encoding standards (MPEG-2, MPEG-4, HEVC), delivery method (satellite, fiber, IP), and quality parameters (bitrate, resolution, audio channels).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the agreement. Protects both parties from abrupt service disruption.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdnConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Cdn Configuration Id' ;
    rdfs:comment 'Unique identifier for the CDN configuration record. Primary key for the cdn_configuration product.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CdnConfiguration .

ind:bandwidthLimitGbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Limit Gbps' ;
    rdfs:comment 'The maximum bandwidth capacity provisioned for this CDN configuration in gigabits per second. Exceeding this limit may trigger throttling or overage charges.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cacheControlHeader rdf:type rdf:Property ;
    rdfs:label 'Cache Control Header' ;
    rdfs:comment 'HTTP Cache-Control header directives applied to CDN responses, controlling caching behavior at edge and client levels.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnProvider rdf:type rdf:Property ;
    rdfs:label 'Cdn Provider' ;
    rdfs:comment 'The CDN vendor providing content delivery services for this configuration. Akamai is the primary provider per operational systems of record.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionEnabled rdf:type rdf:Property ;
    rdfs:label 'Compression Enabled' ;
    rdfs:comment 'Indicates whether content compression (gzip, brotli) is enabled at the CDN edge to reduce bandwidth consumption and improve delivery performance.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configurationName rdf:type rdf:Property ;
    rdfs:label 'Configuration Name' ;
    rdfs:comment 'Human-readable name for this CDN configuration, used for operational identification and management.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerGb rdf:type rdf:Property ;
    rdfs:label 'Cost Per Gb' ;
    rdfs:comment 'The contracted cost per gigabyte of data transferred through this CDN configuration. Used for cost allocation and financial reconciliation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failoverOriginUrl rdf:type rdf:Property ;
    rdfs:label 'Failover Origin Url' ;
    rdfs:comment 'Secondary origin server URL used for redundancy and failover when the primary origin is unavailable.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoBlockingCountries rdf:type rdf:Property ;
    rdfs:label 'Geo Blocking Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes subject to geo-blocking rules (allowed or denied based on mode).' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoBlockingEnabled rdf:type rdf:Property ;
    rdfs:label 'Geo Blocking Enabled' ;
    rdfs:comment 'Indicates whether geographic content restrictions are enforced at the CDN edge based on viewer location.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geoBlockingMode rdf:type rdf:Property ;
    rdfs:label 'Geo Blocking Mode' ;
    rdfs:comment 'Specifies whether the geo-blocking rules operate as an allow-list (whitelist) or deny-list (blacklist) of countries.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthCheckIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Health Check Interval Seconds' ;
    rdfs:comment 'Frequency in seconds at which health checks are performed against this CDN configuration to detect outages or degradation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:healthCheckUrl rdf:type rdf:Property ;
    rdfs:label 'Health Check Url' ;
    rdfs:comment 'The URL endpoint used by monitoring systems to verify CDN configuration availability and responsiveness.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:http2Enabled rdf:type rdf:Property ;
    rdfs:label 'Http2 Enabled' ;
    rdfs:comment 'Indicates whether HTTP/2 protocol is enabled for this CDN configuration to improve streaming performance through multiplexing and header compression.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipv6Enabled rdf:type rdf:Property ;
    rdfs:label 'Ipv6 Enabled' ;
    rdfs:comment 'Indicates whether IPv6 addressing is enabled for this CDN configuration to support next-generation internet protocol delivery.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastHealthCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Health Check Timestamp' ;
    rdfs:comment 'The timestamp of the most recent successful health check performed against this CDN configuration.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of this CDN configuration. Active configurations are serving live traffic; inactive configurations are not in use.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPullUrl rdf:type rdf:Property ;
    rdfs:label 'Origin Pull Url' ;
    rdfs:comment 'The origin server URL from which the CDN pulls content when not cached. Typically points to the media asset management system or playout server.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prefetchEnabled rdf:type rdf:Property ;
    rdfs:label 'Prefetch Enabled' ;
    rdfs:comment 'Indicates whether content prefetching is enabled to proactively cache content at edge locations before viewer requests.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:propertyHostname rdf:type rdf:Property ;
    rdfs:label 'Property Hostname' ;
    rdfs:comment 'The fully qualified domain name (FQDN) of the CDN property or edge hostname used for content delivery.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionedDate rdf:type rdf:Property ;
    rdfs:label 'Provisioned Date' ;
    rdfs:comment 'The date when this CDN configuration was initially provisioned and deployed to the CDN provider infrastructure.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:queryStringCachingMode rdf:type rdf:Property ;
    rdfs:label 'Query String Caching Mode' ;
    rdfs:comment 'Defines how URL query string parameters are handled in cache key generation. Controls cache efficiency and personalization support.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaUptimeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Target Percent' ;
    rdfs:comment 'The contracted uptime percentage guarantee for this CDN configuration (e.g., 99.99%). Used for SLA compliance monitoring and reporting.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sslCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Ssl Certificate Expiry Date' ;
    rdfs:comment 'The expiration date of the SSL/TLS certificate. Operations teams must renew certificates before this date to prevent service disruption.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sslCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Ssl Certificate Reference' ;
    rdfs:comment 'Reference identifier or serial number of the SSL/TLS certificate deployed on the CDN property for secure HTTPS delivery.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenAuthenticationEnabled rdf:type rdf:Property ;
    rdfs:label 'Token Authentication Enabled' ;
    rdfs:comment 'Indicates whether token-based authentication is enabled for this CDN configuration to prevent unauthorized access to content.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tokenAuthenticationScheme rdf:type rdf:Property ;
    rdfs:label 'Token Authentication Scheme' ;
    rdfs:comment 'The method by which authentication tokens are passed to the CDN edge for validation (query parameter, cookie, or HTTP header).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenSecretKey rdf:type rdf:Property ;
    rdfs:label 'Token Secret Key' ;
    rdfs:comment 'The cryptographic secret key used to generate and validate authentication tokens. Must be kept confidential and rotated regularly.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelLineupId rdf:type rdf:Property ;
    rdfs:label 'Channel Lineup Id' ;
    rdfs:comment 'Primary key for channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutRegionCodes rdf:type rdf:Property ;
    rdfs:label 'Blackout Region Codes' ;
    rdfs:comment 'Comma-separated list of geographic region codes where blackout restrictions apply for this channel (e.g., DMA codes, postal codes, state codes).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutRulesApplicable rdf:type rdf:Property ;
    rdfs:label 'Blackout Rules Applicable' ;
    rdfs:comment 'Indicates whether geographic broadcast restriction (blackout) rules apply to this channel within the lineup.' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the carriage fee (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeePerSubscriber rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Per Subscriber' ;
    rdfs:comment 'Monthly fee paid by the MVPD/vMVPD to the content provider per subscriber who has access to this channel within the lineup. Used for carriage fee calculation and revenue assurance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carriageType rdf:type rdf:Property ;
    rdfs:label 'Carriage Type' ;
    rdfs:comment 'Legal basis for the channel\'s inclusion in the lineup: must-carry (mandatory FCC requirement), retransmission consent (negotiated rebroadcast authorization), or negotiated carriage agreement.' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDisplayName rdf:type rdf:Property ;
    rdfs:label 'Channel Display Name' ;
    rdfs:comment 'The branded name of the channel as displayed to subscribers in the EPG (Electronic Program Guide) for this specific lineup.' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPositionNumber rdf:type rdf:Property ;
    rdfs:label 'Channel Position Number' ;
    rdfs:comment 'Logical channel number or position assigned to the channel within this lineup (e.g., channel 101, channel 502). Used for Electronic Program Guide (EPG) display and subscriber navigation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedCaptionRequired rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Required' ;
    rdfs:comment 'Indicates whether closed captioning is mandated for this channel per FCC accessibility requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dvrEnabled rdf:type rdf:Property ;
    rdfs:label 'Dvr Enabled' ;
    rdfs:comment 'Indicates whether subscribers can record content from this channel using DVR functionality.' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRestrictionRules rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction Rules' ;
    rdfs:comment 'Detailed description of geographic restrictions, including allowed and blocked regions, for subscriber entitlement validation.' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdAvailable rdf:type rdf:Property ;
    rdfs:label 'Hd Available' ;
    rdfs:comment 'Indicates whether the channel is available in high definition (HD) format within this lineup.' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineupCode rdf:type rdf:Property ;
    rdfs:label 'Lineup Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the lineup within the partner\'s system (e.g., \'BASIC-01\', \'PREM-SPORTS\').' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineupName rdf:type rdf:Property ;
    rdfs:label 'Lineup Name' ;
    rdfs:comment 'Business name of the channel lineup or package (e.g., \'Basic Cable\', \'Premium Sports Tier\', \'Expanded Basic\').' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineupStatus rdf:type rdf:Property ;
    rdfs:label 'Lineup Status' ;
    rdfs:comment 'Current operational status of the channel lineup configuration.' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketApplicability rdf:type rdf:Property ;
    rdfs:label 'Market Applicability' ;
    rdfs:comment 'Geographic scope of the lineup: national (available across all markets), regional (multi-state region), local (single market), or DMA-specific (Designated Market Area).' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalControlRating rdf:type rdf:Property ;
    rdfs:label 'Parental Control Rating' ;
    rdfs:comment 'Content rating classification for parental control enforcement at the channel level within the lineup. [ENUM-REF-CANDIDATE: TV-Y|TV-Y7|TV-G|TV-PG|TV-14|TV-MA|not_rated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotional End Date' ;
    rdfs:comment 'Date when the promotional offering for this channel expires, after which standard pricing or availability rules apply.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this channel is being offered as part of a promotional campaign or limited-time offer within the lineup.' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceTier rdf:type rdf:Property ;
    rdfs:label 'Service Tier' ;
    rdfs:comment 'Service level classification indicating the quality or feature set of the lineup (e.g., standard definition, high definition, 4K).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberCountEstimate rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count Estimate' ;
    rdfs:comment 'Estimated number of subscribers who have access to this channel through this lineup. Used for carriage fee calculation and audience reach estimation.' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierType rdf:type rdf:Property ;
    rdfs:label 'Tier Type' ;
    rdfs:comment 'Classification of the channel tier or package type offered to subscribers. [ENUM-REF-CANDIDATE: basic|expanded_basic|premium|sports|news|entertainment|international|a_la_carte — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uhd4kAvailable rdf:type rdf:Property ;
    rdfs:label 'Uhd 4k Available' ;
    rdfs:comment 'Indicates whether the channel is available in 4K ultra high definition format within this lineup.' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vodEnabled rdf:type rdf:Property ;
    rdfs:label 'Vod Enabled' ;
    rdfs:comment 'Indicates whether Video On Demand (VOD) content is available for this channel within the lineup.' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDeliveryOrderId rdf:type rdf:Property ;
    rdfs:label 'Content Delivery Order Id' ;
    rdfs:comment 'Unique identifier for the content delivery order. Primary key for this transactional record representing a formal order to deliver content assets to distribution partners or platforms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentDeliveryOrder .

ind:drmPolicyId rdf:type rdf:Property ;
    rdfs:label 'Drm Policy Id' ;
    rdfs:comment 'Reference to the DRM policy governing content protection, encryption, and playback restrictions for this delivery.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrmPolicy .

ind:fulfillmentCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Content delivery orders require operations ownership for prioritization, troubleshooting delivery failures, SLA compliance, and partner communication. Essential for on-call rotations, delivery metrics' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rightsAvailabilityWindowId rdf:type rdf:Property ;
    rdfs:label 'Rights Availability Window Id' ;
    rdfs:comment 'Reference to the rights and licensing window that permits this content delivery. Ensures delivery complies with windowing and holdback restrictions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsAvailabilityWindow .

ind:serviceInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Service Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Content delivery orders for encoding, transcoding, QC, and distribution services are billable to content owners or internal cost centers. Real business process: content services billing, delivery fee ' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:sourceOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Source Opportunity Id' ;
    rdfs:comment 'Foreign key linking to sales.opportunity. Business justification: Content delivery orders fulfill closed content licensing opportunities. Tracks opportunity-to-fulfillment lifecycle for syndication deals, content licensing agreements, and distribution contracts. Ess' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Timestamp when the content was actually delivered and confirmed received by the distribution partner. Used for SLA performance measurement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'Username or identifier of the user who approved this delivery order for fulfillment. Tracks authorization and approval workflow.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioLanguages rdf:type rdf:Property ;
    rdfs:label 'Audio Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639-2 language codes for audio tracks included in the delivery. Supports multi-language distribution requirements.' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionsIncluded rdf:type rdf:Property ;
    rdfs:label 'Closed Captions Included' ;
    rdfs:comment 'Indicates whether closed captions are included in the delivered content. Required for FCC compliance and accessibility standards.' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Deadline Timestamp' ;
    rdfs:comment 'Precise deadline timestamp for content delivery. Used for Service Level Agreement (SLA) compliance tracking and penalty calculations.' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes and special instructions for the delivery order. Captures partner-specific requirements, technical considerations, or operational alerts.' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Duration Minutes' ;
    rdfs:comment 'Estimated time required to complete the content delivery, measured in minutes. Based on file size, bandwidth, and delivery method.' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileSizeGb rdf:type rdf:Property ;
    rdfs:label 'File Size Gb' ;
    rdfs:comment 'Total file size of the content package being delivered, measured in gigabytes. Used for bandwidth planning and cost estimation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Confirmation Number' ;
    rdfs:comment 'Unique confirmation identifier provided upon successful delivery completion. Used for proof of delivery and reconciliation with distribution partners.' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestrictions rdf:type rdf:Property ;
    rdfs:label 'Geographic Restrictions' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where content delivery is restricted or permitted. Enforces territorial rights and blackout rules.' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Target date by which the content must be delivered to the distribution partner. Drives scheduling and prioritization of delivery tasks.' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transcodeProfileCode rdf:type rdf:Property ;
    rdfs:label 'Transcode Profile Code' ;
    rdfs:comment 'Reference to the transcode profile specifying encoding parameters, bitrates, resolutions, and quality settings for content preparation.' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daiConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Dai Configuration Id' ;
    rdfs:comment 'Unique identifier for the DAI configuration record. Primary key.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DaiConfiguration .

ind:configurationOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Configuration Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: DAI configurations control ad insertion logic and revenue streams, requiring ownership for approval workflows, fill rate troubleshooting, blackout override decisions, and ad server contract compliance' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:abrProfileCompatibility rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Compatibility' ;
    rdfs:comment 'Comma-separated list of ABR streaming profiles this DAI configuration is compatible with (e.g., HLS, MPEG-DASH, Smooth Streaming).' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adDecisionServerUrl rdf:type rdf:Property ;
    rdfs:label 'Ad Decision Server Url' ;
    rdfs:comment 'Endpoint URL for the Ad Decision Server that determines which ads to serve based on targeting criteria and inventory availability.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adFormatSupport rdf:type rdf:Property ;
    rdfs:label 'Ad Format Support' ;
    rdfs:comment 'Comma-separated list of supported ad formats for this configuration (e.g., VAST, VMAP, VPAID, SIMID).' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adPodPlacementRules rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Placement Rules' ;
    rdfs:comment 'Business rules defining where ad pods (groups of ads in a break) can be inserted within the content, including pre-roll, mid-roll, and post-roll positions.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adServerTimeoutMilliseconds rdf:type rdf:Property ;
    rdfs:label 'Ad Server Timeout Milliseconds' ;
    rdfs:comment 'Maximum time in milliseconds to wait for a response from the ad decision server before triggering fallback logic.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backupAdServerUrl rdf:type rdf:Property ;
    rdfs:label 'Backup Ad Server Url' ;
    rdfs:comment 'Failover endpoint URL for ad decision requests when the primary ad server is unavailable or times out.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutOverrideEnabled rdf:type rdf:Property ;
    rdfs:label 'Blackout Override Enabled' ;
    rdfs:comment 'Indicates whether this DAI configuration can override geographic blackout restrictions for ad insertion purposes.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdnIntegrationMode rdf:type rdf:Property ;
    rdfs:label 'Cdn Integration Mode' ;
    rdfs:comment 'How the DAI system integrates with the CDN: direct (CDN serves pre-stitched streams), proxied (DAI proxies through CDN), or edge decisioning (ad decisions at CDN edge).' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companionAdsEnabled rdf:type rdf:Property ;
    rdfs:label 'Companion Ads Enabled' ;
    rdfs:comment 'Indicates whether companion banner ads are displayed alongside video ads to enhance engagement and click-through rates.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configurationCode rdf:type rdf:Property ;
    rdfs:label 'Configuration Code' ;
    rdfs:comment 'Unique alphanumeric code identifying this DAI configuration across systems and platforms.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Current lifecycle status of this DAI configuration: active (in production use), inactive (not in use), testing (under validation), or deprecated (scheduled for removal).' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationVersion rdf:type rdf:Property ;
    rdfs:label 'Configuration Version' ;
    rdfs:comment 'Version number of this configuration, incremented with each modification to support change tracking and rollback capabilities.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceTargetingEnabled rdf:type rdf:Property ;
    rdfs:label 'Device Targeting Enabled' ;
    rdfs:comment 'Indicates whether device-specific targeting is enabled to serve ads optimized for the viewers device type (mobile, tablet, TV, desktop).' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmEnforcementMode rdf:type rdf:Property ;
    rdfs:label 'Drm Enforcement Mode' ;
    rdfs:comment 'Level of DRM enforcement applied to ad content: strict (full encryption), lenient (selective protection), or disabled (no DRM on ads).' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackCreativeStrategy rdf:type rdf:Property ;
    rdfs:label 'Fallback Creative Strategy' ;
    rdfs:comment 'Strategy for handling unfilled ad inventory: display house ads, show slate/filler, continue content, or repeat the last served ad.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRateTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Target Percentage' ;
    rdfs:comment 'Target percentage of available ad inventory that should be filled with paid advertisements, used to measure monetization effectiveness.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyCapEnabled rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Enabled' ;
    rdfs:comment 'Indicates whether frequency capping is enforced to limit the number of times a viewer sees the same ad within a session or time period.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geoTargetingEnabled rdf:type rdf:Property ;
    rdfs:label 'Geo Targeting Enabled' ;
    rdfs:comment 'Indicates whether geographic targeting is enabled to serve location-specific ads based on viewer IP address or device location.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxAdPodDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Max Ad Pod Duration Seconds' ;
    rdfs:comment 'Maximum allowed duration in seconds for a single ad pod insertion, ensuring viewer experience and regulatory compliance.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxImpressionsPerHour rdf:type rdf:Property ;
    rdfs:label 'Max Impressions Per Hour' ;
    rdfs:comment 'Maximum number of times the same ad creative can be shown to a viewer within a one-hour period when frequency capping is enabled.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxImpressionsPerSession rdf:type rdf:Property ;
    rdfs:label 'Max Impressions Per Session' ;
    rdfs:comment 'Maximum number of times the same ad creative can be shown to a viewer within a single viewing session when frequency capping is enabled.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minAdPodDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Min Ad Pod Duration Seconds' ;
    rdfs:comment 'Minimum required duration in seconds for an ad pod to be considered valid for insertion.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scte35SignalHandling rdf:type rdf:Property ;
    rdfs:label 'Scte35 Signal Handling' ;
    rdfs:comment 'How SCTE-35 cue markers embedded in the content stream are processed: enabled (parse and act), disabled (ignore), or passthrough (forward without processing).' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stitchingMode rdf:type rdf:Property ;
    rdfs:label 'Stitching Mode' ;
    rdfs:comment 'Method used to insert ads into the content stream: server-side stitching (SSAI), client-side stitching (CSAI), or hybrid approach combining both.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingEventsEnabled rdf:type rdf:Property ;
    rdfs:label 'Tracking Events Enabled' ;
    rdfs:comment 'Indicates whether ad tracking events (impressions, quartiles, completions, clicks) are captured and reported to measurement systems.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daiSessionId rdf:type rdf:Property ;
    rdfs:label 'Dai Session Id' ;
    rdfs:comment 'Unique identifier for the DAI session. Primary key for the dai_session product.' ;
    rdfs:domain ind:DaiSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playbackSessionId rdf:type rdf:Property ;
    rdfs:label 'Playback Session Id' ;
    rdfs:comment 'Reference to the parent streaming playback session during which this DAI session occurred. Links DAI monetization events to viewer streaming activity.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlaybackSession .

ind:adDecisionServerResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Ad Decision Server Response Time Ms' ;
    rdfs:comment 'Time in milliseconds taken by the ad decision server to respond with ad selection. Critical for measuring DAI latency and QoS.' ;
    rdfs:domain ind:DaiSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adPodDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Duration Seconds' ;
    rdfs:comment 'Total duration of the ad pod in seconds. Represents the available inventory window for ad insertion.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adPodSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Sequence Number' ;
    rdfs:comment 'Sequential number of this ad pod within the content playback session. Enables tracking of multiple ad breaks within a single viewing session.' ;
    rdfs:domain ind:DaiSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adTargetingSegmentIds rdf:type rdf:Property ;
    rdfs:label 'Ad Targeting Segment Ids' ;
    rdfs:comment 'Comma-separated list of audience segment IDs applied for ad targeting during this DAI session. Links to audience segmentation and personalization strategies.' ;
    rdfs:domain ind:DaiSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adsFallbackCount rdf:type rdf:Property ;
    rdfs:label 'Ads Fallback Count' ;
    rdfs:comment 'Number of fallback or house ads served when primary ad inventory was unavailable. Indicates unfilled demand.' ;
    rdfs:domain ind:DaiSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adsInsertedCount rdf:type rdf:Property ;
    rdfs:label 'Ads Inserted Count' ;
    rdfs:comment 'Number of ads successfully inserted and delivered during this DAI session. Used to calculate fill rate and monetization efficiency.' ;
    rdfs:domain ind:DaiSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adsRequestedCount rdf:type rdf:Property ;
    rdfs:label 'Ads Requested Count' ;
    rdfs:comment 'Number of ad slots requested from the ad decision server for this DAI session. Represents the maximum fill capacity of the ad pod.' ;
    rdfs:domain ind:DaiSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Blackout Override Flag' ;
    rdfs:comment 'Indicates whether geographic blackout restrictions were overridden for this DAI session. True if blackout rules were bypassed (e.g., for authenticated subscribers).' ;
    rdfs:domain ind:DaiSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Drm Enforcement Flag' ;
    rdfs:comment 'Indicates whether DRM protection was enforced on the ad-stitched stream. True if ads were delivered with DRM encryption.' ;
    rdfs:domain ind:DaiSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Error code returned if the DAI session encountered a failure. Used for troubleshooting ad delivery issues and optimizing fill rates.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Human-readable error message describing the failure reason if the DAI session did not complete successfully.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Percentage' ;
    rdfs:comment 'Percentage of requested ad slots that were successfully filled with paid ads. Calculated as (ads_inserted_count / ads_requested_count) * 100. Key monetization metric.' ;
    rdfs:domain ind:DaiSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyCapAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Applied Flag' ;
    rdfs:comment 'Indicates whether frequency capping rules were applied to limit ad repetition for this viewer. True if frequency cap was enforced.' ;
    rdfs:domain ind:DaiSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the viewers geographic location. Derived from IP address or device GPS. Used for geo-targeted ad campaigns.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicDmaCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Dma Code' ;
    rdfs:comment 'Nielsen Designated Market Area code representing the viewers media market. Critical for local advertising sales and audience measurement alignment.' ;
    rdfs:domain ind:DaiSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'State, province, or region where the viewer was located during the DAI session. Enables regional ad targeting and compliance with local advertising regulations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scte35CueType rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue Type' ;
    rdfs:comment 'Type of SCTE-35 cue message that triggered the DAI session. Indicates the nature of the ad opportunity (splice insert, time signal, segmentation descriptor). [ENUM-REF-CANDIDATE: splice_insert|time_signal|segmentation_descriptor|provider_advertisement|distributor_advertisement|program_start|program_end|chapter_start|break_start|break_end — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DaiSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scte35SignalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scte35 Signal Timestamp' ;
    rdfs:comment 'Timestamp of the SCTE-35 cue message that triggered the DAI opportunity. Critical for synchronizing ad insertion with content breaks.' ;
    rdfs:domain ind:DaiSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session End Timestamp' ;
    rdfs:comment 'Timestamp when the DAI session completed. Marks the end of ad pod delivery and return to content.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Start Timestamp' ;
    rdfs:comment 'Timestamp when the DAI session was initiated. Represents the moment the ad decision server was queried for this ad opportunity.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Final status of the DAI session. Indicates whether the session completed successfully, partially filled, failed, timed out, or was abandoned by the viewer.' ;
    rdfs:domain ind:DaiSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAdDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Ad Duration Seconds' ;
    rdfs:comment 'Total duration of all ads actually delivered during this DAI session. May differ from ad_pod_duration_seconds if pod was not fully filled.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewerIpAddress rdf:type rdf:Property ;
    rdfs:label 'Viewer Ip Address' ;
    rdfs:comment 'IP address of the viewer device at the time of the DAI session. Used for geo-targeting and fraud detection. May be considered PII under GDPR.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealId rdf:type rdf:Property ;
    rdfs:label 'Deal Id' ;
    rdfs:comment 'Primary key for deal' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentScope rdf:type rdf:Property ;
    rdfs:label 'Content Scope' ;
    rdfs:comment 'Description of the content assets included in this deal. May reference specific titles, series, libraries, or content categories covered by the agreement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealName rdf:type rdf:Property ;
    rdfs:label 'Deal Name' ;
    rdfs:comment 'Human-readable name or title of the distribution deal for identification and reporting purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityWindowDays rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Window Days' ;
    rdfs:comment 'Duration in days of the exclusivity period or holdback window during which content cannot be distributed through competing channels.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flatFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Fee Amount' ;
    rdfs:comment 'Fixed payment amount for flat fee deal structures. Represents total or periodic payment value.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiationStartDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Start Date' ;
    rdfs:comment 'Date when commercial negotiations for this deal commenced.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percentage' ;
    rdfs:comment 'Percentage of revenue allocated to the content owner under revenue share agreements. Expressed as a percentage (e.g., 65.00 represents 65%).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when the distribution deal contract was executed by all parties.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termMonths rdf:type rdf:Property ;
    rdfs:label 'Term Months' ;
    rdfs:comment 'Duration of the deal term expressed in months. Calculated from effective date to expiration date.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territory rdf:type rdf:Property ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Geographic territory or territories covered by this distribution deal. May be a single country code, multiple countries, or regional designation (e.g., USA, CAN|MEX, EMEA).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adInsertionMethod rdf:type rdf:Property ;
    rdfs:label 'Ad Insertion Method' ;
    rdfs:comment 'Technical method used for inserting advertisements into the content stream: server-side stitching, client-side insertion, DAI (Dynamic Ad Insertion), SCTE-35 marker-based, or none for ad-free channels.' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutRulesEnabled rdf:type rdf:Property ;
    rdfs:label 'Blackout Rules Enabled' ;
    rdfs:comment 'Indicates whether geographic or rights-based blackout restrictions are enforced for this channel (true) or not (false).' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Usd' ;
    rdfs:comment 'Monthly or per-subscriber carriage fee paid by MVPDs or vMVPDs to carry this channel, expressed in USD. Confidential commercial data.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Classification of the delivery channel by distribution model: linear (traditional broadcast), OTT (over-the-top streaming), FAST (free ad-supported streaming TV), simulcast (simultaneous multi-platform), VOD (video on demand), or hybrid.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRefreshCadence rdf:type rdf:Property ;
    rdfs:label 'Content Refresh Cadence' ;
    rdfs:comment 'Frequency at which the channel programming lineup or content library is updated with new material.' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTechnology rdf:type rdf:Property ;
    rdfs:label 'Delivery Technology' ;
    rdfs:comment 'The technical transmission standard used for content delivery. DVB (Digital Video Broadcasting) variants for European broadcast, ATSC (Advanced Television Systems Committee) for North American broadcast, QAM (Quadrature Amplitude Modulation) for cable, HLS (HTTP Live Streaming) and MPEG-DASH for adaptive bitrate streaming. [ENUM-REF-CANDIDATE: dvb-t|dvb-s|dvb-c|atsc|qam|hls|mpeg-dash|smooth-streaming|rtmp|webrtc — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgSourceCode rdf:type rdf:Property ;
    rdfs:label 'Epg Source Code' ;
    rdfs:comment 'External identifier linking this channel to its Electronic Program Guide (EPG) metadata feed provider (e.g., Gracenote, Tribune Media Services).' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastAggregatorPlatform rdf:type rdf:Property ;
    rdfs:label 'Fast Aggregator Platform' ;
    rdfs:comment 'Name of the FAST platform aggregator hosting the channel (e.g., \'Pluto TV\', \'Tubi\', \'Samsung TV Plus\', \'Roku Channel\', \'Xumo\'). Applicable only to FAST channel types.' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastPlaylistType rdf:type rdf:Property ;
    rdfs:label 'Fast Playlist Type' ;
    rdfs:comment 'Content scheduling model for FAST channels: linear-loop (repeating content block), scheduled (traditional time-based EPG), dynamic (algorithm-driven), or hybrid. Applicable only to FAST channel types.' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreCategory rdf:type rdf:Property ;
    rdfs:label 'Genre Category' ;
    rdfs:comment 'Primary content genre or programming category of the channel. [ENUM-REF-CANDIDATE: news|sports|entertainment|kids|lifestyle|documentary|music|movies|drama|comedy — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'Date when the channel first went live and began broadcasting or streaming to audiences.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monetizationModel rdf:type rdf:Property ;
    rdfs:label 'Monetization Model' ;
    rdfs:comment 'Revenue model for the channel: AVOD (Advertising-Supported Video On Demand), SVOD (Subscription Video On Demand), TVOD (Transactional Video On Demand), hybrid (multiple models), or free (no monetization).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionFormat rdf:type rdf:Property ;
    rdfs:label 'Resolution Format' ;
    rdfs:comment 'Video resolution tier supported by the channel: SD (standard definition 480p), HD (720p), Full HD (1080p), 4K UHD (2160p), 8K UHD (4320p).' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Required' ;
    rdfs:comment 'Indicates whether retransmission consent agreements are required for MVPDs to rebroadcast this channel (true) or if must-carry rules apply (false).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Secondary Language' ;
    rdfs:comment 'ISO 639-3 three-letter code for the secondary audio track or subtitle language, if available (e.g., SAP - Secondary Audio Program).' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaUptimePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percent' ;
    rdfs:comment 'Contractual uptime guarantee for the channel expressed as a percentage (e.g., 99.95 for \'four nines\' availability).' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:streamingEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Streaming Endpoint Url' ;
    rdfs:comment 'Primary streaming endpoint URL or manifest URL for OTT and FAST channels. Confidential operational data.' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the primary geographic market for the channel (e.g., \'USA\', \'GBR\', \'CAN\').' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryEventId rdf:type rdf:Property ;
    rdfs:label 'Delivery Event Id' ;
    rdfs:comment 'Unique identifier for the delivery event record. Primary key.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adFillRatePercent rdf:type rdf:Property ;
    rdfs:label 'Ad Fill Rate Percent' ;
    rdfs:comment 'Percentage of available ad inventory that was successfully filled during this DAI event (0.00 to 100.00).' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bytesDelivered rdf:type rdf:Property ;
    rdfs:label 'Bytes Delivered' ;
    rdfs:comment 'Total number of bytes delivered to the viewer during this event.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdnCacheStatus rdf:type rdf:Property ;
    rdfs:label 'Cdn Cache Status' ;
    rdfs:comment 'CDN cache status for this delivery (hit, miss, stale, bypass).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnNodeCode rdf:type rdf:Property ;
    rdfs:label 'Cdn Node Code' ;
    rdfs:comment 'Identifier of the CDN edge node that served the content for this delivery event.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnPopLocation rdf:type rdf:Property ;
    rdfs:label 'Cdn Pop Location' ;
    rdfs:comment 'Geographic location identifier of the CDN point of presence that served this delivery.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryChannelType rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel Type' ;
    rdfs:comment 'Classification of the delivery channel type (linear broadcast, OTT streaming, VOD, FAST channel, MVPD, vMVPD).' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Outcome status of the delivery event (success, failure, degraded quality, partial delivery).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Network Latency Ms' ;
    rdfs:comment 'Network latency measured in milliseconds between CDN edge and viewer device.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originServerResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Origin Server Response Time Ms' ;
    rdfs:comment 'Response time from origin server in milliseconds for cache-miss scenarios.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scte35SignalType rdf:type rdf:Property ;
    rdfs:label 'Scte35 Signal Type' ;
    rdfs:comment 'Type of SCTE-35 signal that triggered the DAI event (e.g., splice_insert, time_signal).' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Session Duration Seconds' ;
    rdfs:comment 'Total duration of the delivery session in seconds for streaming events.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliverySlaId rdf:type rdf:Property ;
    rdfs:label 'Delivery Sla Id' ;
    rdfs:comment 'Unique identifier for the delivery SLA record. Primary key.' ;
    rdfs:domain ind:DeliverySla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sla Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Delivery SLAs require ownership for target setting, measurement validation, penalty negotiation, and partner contract alignment. Essential for accountability in service quality, escalation paths, perf' ;
    rdfs:domain ind:DeliverySla ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date when this SLA was formally approved.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdnAvailabilityTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Cdn Availability Target Percent' ;
    rdfs:comment 'Target availability percentage for CDN infrastructure supporting content delivery.' ;
    rdfs:domain ind:DeliverySla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverySlaDescription rdf:type rdf:Property ;
    rdfs:label 'Delivery Sla Description' ;
    rdfs:comment 'Detailed description of the SLA scope, objectives, and key commitments.' ;
    rdfs:domain ind:DeliverySla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySlaStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Sla Status' ;
    rdfs:comment 'Current lifecycle status of the SLA record (e.g., active, inactive, suspended, expired, draft, pending approval).' ;
    rdfs:domain ind:DeliverySla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'The distribution channel or platform type this SLA applies to (e.g., linear broadcast, OTT streaming, MVPD carriage, vMVPD, FAST channel, CDN).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorRateThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Error Rate Threshold Percent' ;
    rdfs:comment 'Maximum allowable error rate percentage for delivery failures, buffering events, or playback errors.' ;
    rdfs:domain ind:DeliverySla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationContactEmail rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact Email' ;
    rdfs:comment 'Email address of the escalation contact for SLA breach notifications and coordination.' ;
    rdfs:domain ind:DeliverySla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationContactName rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact Name' ;
    rdfs:comment 'Name of the primary contact person for SLA breach escalation and resolution.' ;
    rdfs:domain ind:DeliverySla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationContactPhone rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact Phone' ;
    rdfs:comment 'Phone number of the escalation contact for urgent SLA breach communications.' ;
    rdfs:domain ind:DeliverySla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Conditions or events excluded from SLA measurement (e.g., planned maintenance, force majeure, third-party failures).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Max Latency Ms' ;
    rdfs:comment 'Maximum allowable latency in milliseconds for content delivery from origin to edge or end-user device.' ;
    rdfs:domain ind:DeliverySla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementWindow rdf:type rdf:Property ;
    rdfs:label 'Measurement Window' ;
    rdfs:comment 'Time window over which SLA metrics are measured and evaluated (e.g., monthly, quarterly).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'Business department or team responsible for managing and enforcing this SLA (e.g., Distribution Operations, Partner Management).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'Name of the distribution partner, MVPD, vMVPD, or OTT platform to which this SLA applies.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary penalty amount applied per SLA breach incident or measurement period.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClause rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause' ;
    rdfs:comment 'Description of financial or service penalties applied when SLA commitments are breached.' ;
    rdfs:domain ind:DeliverySla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the SLA tier for operational reference and system integration.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Business-friendly name of the SLA tier or agreement (e.g., Premium Delivery SLA, Standard OTT SLA).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamStartTimeTargetMs rdf:type rdf:Property ;
    rdfs:label 'Stream Start Time Target Ms' ;
    rdfs:comment 'Target time in milliseconds for stream initialization and first frame delivery to the viewer.' ;
    rdfs:domain ind:DeliverySla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uptimeCommitmentPercent rdf:type rdf:Property ;
    rdfs:label 'Uptime Commitment Percent' ;
    rdfs:comment 'Guaranteed uptime percentage for content delivery availability (e.g., 99.95% uptime commitment).' ;
    rdfs:domain ind:DeliverySla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Order Id' ;
    rdfs:comment 'Foreign key linking to technology.maintenance_work_order. Business justification: Device types require maintenance tracking for firmware updates and recalls. Required for device firmware update campaigns and recall management.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceWorkOrder .

ind:abrProfileDash rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Dash' ;
    rdfs:comment 'Indicates whether the device supports MPEG-DASH (Dynamic Adaptive Streaming over HTTP) adaptive bitrate streaming protocol.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:abrProfileHls rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Hls' ;
    rdfs:comment 'Indicates whether the device supports HLS (HTTP Live Streaming) adaptive bitrate streaming protocol.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:abrProfileSmooth rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Smooth' ;
    rdfs:comment 'Indicates whether the device supports Microsoft Smooth Streaming adaptive bitrate protocol.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activeInstallBase rdf:type rdf:Property ;
    rdfs:label 'Active Install Base' ;
    rdfs:comment 'Estimated number of active devices of this type currently accessing the OTT platform, used for capacity planning and analytics.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codecAudioSupport rdf:type rdf:Property ;
    rdfs:label 'Codec Audio Support' ;
    rdfs:comment 'List of audio codecs supported by the device (e.g., AAC, Dolby Digital, Dolby Atmos, DTS). Pipe-separated list.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codecVideoSupport rdf:type rdf:Property ;
    rdfs:label 'Codec Video Support' ;
    rdfs:comment 'List of video codecs supported by the device (e.g., H.264, H.265/HEVC, VP9, AV1). Pipe-separated list.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daiSupported rdf:type rdf:Property ;
    rdfs:label 'Dai Supported' ;
    rdfs:comment 'Indicates whether the device supports DAI (Dynamic Ad Insertion) for server-side ad stitching in streaming content.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceCategory rdf:type rdf:Property ;
    rdfs:label 'Device Category' ;
    rdfs:comment 'High-level classification of the device type (e.g., smart TV, mobile phone, tablet, desktop browser, streaming stick, gaming console, set-top box). [ENUM-REF-CANDIDATE: smart_tv|mobile_phone|tablet|desktop_browser|streaming_stick|gaming_console|set_top_box — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmFairplaySupported rdf:type rdf:Property ;
    rdfs:label 'Drm Fairplay Supported' ;
    rdfs:comment 'Indicates whether the device supports Apple FairPlay DRM for content protection.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmPlayreadySupported rdf:type rdf:Property ;
    rdfs:label 'Drm Playready Supported' ;
    rdfs:comment 'Indicates whether the device supports Microsoft PlayReady DRM for content protection.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmWidevineLevel rdf:type rdf:Property ;
    rdfs:label 'Drm Widevine Level' ;
    rdfs:comment 'Google Widevine DRM security level supported (L1 = hardware-backed, L2 = software-backed, L3 = software only, not_supported).' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formFactor rdf:type rdf:Property ;
    rdfs:label 'Form Factor' ;
    rdfs:comment 'Physical form factor of the device (handheld, television, desktop, wearable, embedded).' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdrCapable rdf:type rdf:Property ;
    rdfs:label 'Hdr Capable' ;
    rdfs:comment 'Indicates whether the device supports HDR (High Dynamic Range) video playback for enhanced color and contrast.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inputMethod rdf:type rdf:Property ;
    rdfs:label 'Input Method' ;
    rdfs:comment 'Primary input method(s) supported by the device (e.g., touchscreen, remote_control, keyboard_mouse, voice, gamepad). Pipe-separated list if multiple.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the device manufacturer or brand (e.g., Samsung, Apple, Roku, Amazon, LG, Sony).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Specific model name or identifier assigned by the manufacturer (e.g., Galaxy S21, iPhone 13 Pro, Fire TV Stick 4K).' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Technical model number or SKU (Stock Keeping Unit) used for precise device identification and inventory tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCapability rdf:type rdf:Property ;
    rdfs:label 'Network Capability' ;
    rdfs:comment 'Network connectivity capabilities of the device (e.g., wifi, ethernet, cellular_4g, cellular_5g). Pipe-separated list if multiple.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osFamily rdf:type rdf:Property ;
    rdfs:label 'Os Family' ;
    rdfs:comment 'Operating system family running on the device (e.g., Android, iOS, tvOS, webOS, Tizen, Roku OS, Fire OS, Windows, macOS, Linux, PlayStation, Xbox). [ENUM-REF-CANDIDATE: android|ios|tvos|webos|tizen|roku_os|fire_os|windows|macos|linux|playstation|xbox — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osVersionMax rdf:type rdf:Property ;
    rdfs:label 'Os Version Max' ;
    rdfs:comment 'Maximum OS version tested and certified for compatibility. Null indicates no upper bound.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osVersionMin rdf:type rdf:Property ;
    rdfs:label 'Os Version Min' ;
    rdfs:comment 'Minimum OS version required for OTT (Over-The-Top) platform compatibility and playback support.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenResolutionClass rdf:type rdf:Property ;
    rdfs:label 'Screen Resolution Class' ;
    rdfs:comment 'Display resolution category supported by the device (SD, HD, Full HD, 4K UHD (Ultra High Definition), 8K UHD).' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportEndDate rdf:type rdf:Property ;
    rdfs:label 'Support End Date' ;
    rdfs:comment 'Date when platform support for this device type will be discontinued, after which playback may no longer be guaranteed.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:userAgentString rdf:type rdf:Property ;
    rdfs:label 'User Agent String' ;
    rdfs:comment 'Standard HTTP user agent string reported by the device, used for device detection and analytics.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionCarriageFeeInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Distribution Carriage Fee Invoice Id' ;
    rdfs:comment 'Unique identifier for the carriage fee invoice record. Primary key for this transactional billing entity.' ;
    rdfs:domain ind:DistributionCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountsReceivableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Receivable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_receivable. Business justification: Carriage fee invoices create A/R entries when billed to distribution partners. Monthly A/R aging reports include outstanding carriage fee invoices for cash flow management and collections tracking in ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsReceivable .

ind:responsibleSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Responsible Sales Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: Carriage fee invoices are tracked by responsible sales rep for commission calculation and dispute resolution. Essential for rep compensation on recurring carriage revenue, account health monitoring, a' ;
    rdfs:domain ind:DistributionCarriageFeeInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:subscriberCountReportId rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count Report Id' ;
    rdfs:comment 'Foreign key linking to distribution.subscriber_count_report. Business justification: Carriage fee invoices are based on subscriber count reports. Billing uses reported subscriber counts for fee calculation. Removes subscriber_count BIGINT (derivable from subscriber_count_report.report' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubscriberCountReport .

ind:baseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Base Fee Amount' ;
    rdfs:comment 'The base carriage fee amount before any adjustments, discounts, or taxes. Represents the core contractual fee for the billing period.' ;
    rdfs:domain ind:DistributionCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The cost center or profit center to which this invoice is allocated for internal financial reporting and management accounting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeBasis rdf:type rdf:Property ;
    rdfs:label 'Fee Basis' ;
    rdfs:comment 'The pricing model or calculation method used to determine the carriage fee amount. Defines whether the fee is per-subscriber, flat-rate, tiered by volume, revenue-share, or a hybrid structure.' ;
    rdfs:domain ind:DistributionCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalLedgerAccountCode rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account Code' ;
    rdfs:comment 'The GL account code to which this carriage fee invoice is posted in the financial system. Used for financial reporting and revenue recognition.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'The username or identifier of the user or system process that last modified this invoice record. Used for audit and accountability.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedSalesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_territory. Business justification: Distribution partners (MVPDs, cable operators, streaming aggregators) are assigned to sales territories for account management. Supports territory-based partner relationship management, quota allocati' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTerritory .

ind:relationshipManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Distribution partnerships require dedicated relationship managers for contract negotiations, SLA dispute resolution, carriage fee negotiations, and technical integration oversight. Essential for escal' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:abrProfileSupport rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Support' ;
    rdfs:comment 'Description of Adaptive Bitrate streaming profiles and quality tiers supported by the distribution partner for OTT and streaming delivery. Includes resolution ranges, bitrate ladders, and codec support.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Blackout Capability Flag' ;
    rdfs:comment 'Indicates whether the distribution partner has technical capability to enforce geographic broadcast restrictions and content blackouts based on licensing and rights windows.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageCapacityChannels rdf:type rdf:Property ;
    rdfs:label 'Carriage Capacity Channels' ;
    rdfs:comment 'Number of linear channels or content streams that the distribution partner has capacity to carry simultaneously. Relevant for MVPD, vMVPD, and cable operators.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carriageFeeModel rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Model' ;
    rdfs:comment 'Commercial model for carriage fees paid by or to the distribution partner. Per Subscriber indicates fees based on subscriber count, Flat Rate indicates fixed periodic payment, Revenue Share indicates percentage of advertising or subscription revenue, Hybrid indicates combination of models.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRenewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Notice Days' ;
    rdfs:comment 'Number of days advance notice required for contract renewal or termination as specified in the distribution agreement.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daiSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Dai Support Flag' ;
    rdfs:comment 'Indicates whether the distribution partner supports Dynamic Ad Insertion technology for server-side ad stitching in streaming content.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmCapability rdf:type rdf:Property ;
    rdfs:label 'Drm Capability' ;
    rdfs:comment 'Digital Rights Management systems and encryption standards supported by the distribution partner. May include Widevine, FairPlay, PlayReady, and other DRM technologies.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicFootprint rdf:type rdf:Property ;
    rdfs:label 'Geographic Footprint' ;
    rdfs:comment 'Description of the geographic markets, regions, or territories served by this distribution partner. May include country codes, DMA (Designated Market Area) codes, or regional descriptors.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Physical address of the distribution partner\'s corporate headquarters or primary business location.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the distribution partner\'s headquarters is located.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the country where the distribution partner\'s headquarters is located.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the distribution partner\'s headquarters location.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State, province, or administrative region where the distribution partner\'s headquarters is located.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Must Carry Obligation Flag' ;
    rdfs:comment 'Indicates whether the distribution partner has a must-carry obligation requiring mandatory inclusion of certain broadcast channels under FCC regulations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerCode rdf:type rdf:Property ;
    rdfs:label 'Partner Code' ;
    rdfs:comment 'Unique business identifier or short code assigned to the distribution partner for operational reference and system integration.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerTier rdf:type rdf:Property ;
    rdfs:label 'Partner Tier' ;
    rdfs:comment 'Strategic classification of the partner based on reach, revenue contribution, and business importance. Tier 1 represents largest national/international partners, Tier 2 represents regional significant partners, Tier 3 represents local or niche partners.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the distribution partner based on delivery model. MVPD (Multichannel Video Programming Distributor) includes traditional cable, satellite, and telco providers. vMVPD (Virtual MVPD) includes internet-based multichannel services. OTT Platform includes direct-to-consumer streaming services. FAST Aggregator includes Free Ad-Supported Streaming Television channel aggregators. Syndication Outlet includes broadcast stations and regional networks.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalUrl rdf:type rdf:Property ;
    rdfs:label 'Portal Url' ;
    rdfs:comment 'Web URL for the distribution partner\'s business portal, technical documentation, or partner management system.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosMonitoringEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Qos Monitoring Enabled Flag' ;
    rdfs:comment 'Indicates whether active Quality of Service monitoring and reporting is enabled for content delivery through this distribution partner.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retransmissionConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Status' ;
    rdfs:comment 'Status of retransmission consent authorization allowing the distribution partner to rebroadcast content. Relevant for MVPD and cable operators under FCC regulations.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaLatencyTargetMs rdf:type rdf:Property ;
    rdfs:label 'Sla Latency Target Ms' ;
    rdfs:comment 'Maximum acceptable latency in milliseconds for content delivery as defined in the distribution Service Level Agreement. Critical for live streaming and low-latency applications.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriberReachEstimate rdf:type rdf:Property ;
    rdfs:label 'Subscriber Reach Estimate' ;
    rdfs:comment 'Estimated number of subscribers, households, or unique users that can access content through this distribution partner. Used for reach analysis and revenue forecasting.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalDeliveryStandards rdf:type rdf:Property ;
    rdfs:label 'Technical Delivery Standards' ;
    rdfs:comment 'Comma-separated list of technical broadcast and streaming standards supported by the partner. May include DVB (Digital Video Broadcasting), ATSC (Advanced Television Systems Committee), QAM (Quadrature Amplitude Modulation), HLS (HTTP Live Streaming), MPEG-DASH (Dynamic Adaptive Streaming over HTTP), and other delivery protocols.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airplayEnabled rdf:type rdf:Property ;
    rdfs:label 'Airplay Enabled' ;
    rdfs:comment 'Flag indicating whether Apple AirPlay streaming to external devices is permitted.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowedCountries rdf:type rdf:Property ;
    rdfs:label 'Allowed Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where content playback is permitted.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analogOutputControl rdf:type rdf:Property ;
    rdfs:label 'Analog Output Control' ;
    rdfs:comment 'Policy governing analog video output (allowed, restricted with downscaling, or completely blocked).' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analogSunsetEnabled rdf:type rdf:Property ;
    rdfs:label 'Analog Sunset Enabled' ;
    rdfs:comment 'Flag indicating whether analog output is progressively restricted or disabled (analog sunset policy).' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedCountries rdf:type rdf:Property ;
    rdfs:label 'Blocked Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where content playback is explicitly blocked.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chromecastEnabled rdf:type rdf:Property ;
    rdfs:label 'Chromecast Enabled' ;
    rdfs:comment 'Flag indicating whether Google Chromecast streaming to external devices is permitted.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concurrentStreamLimit rdf:type rdf:Property ;
    rdfs:label 'Concurrent Stream Limit' ;
    rdfs:comment 'The maximum number of simultaneous streams allowed per user account or license.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentKeyReference rdf:type rdf:Property ;
    rdfs:label 'Content Key Reference' ;
    rdfs:comment 'The unique identifier for the encryption key used to protect the content.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceBindingEnabled rdf:type rdf:Property ;
    rdfs:label 'Device Binding Enabled' ;
    rdfs:comment 'Flag indicating whether licenses are bound to specific devices to prevent unauthorized sharing.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmVendor rdf:type rdf:Property ;
    rdfs:label 'Drm Vendor' ;
    rdfs:comment 'The vendor or provider of the DRM solution (e.g., Google, Microsoft, Apple, Adobe).' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionScheme rdf:type rdf:Property ;
    rdfs:label 'Encryption Scheme' ;
    rdfs:comment 'The encryption scheme used for content protection (CENC, CBC1, CENS, CBCS) as defined by Common Encryption standards.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRestrictionEnabled rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Enabled' ;
    rdfs:comment 'Flag indicating whether geographic restrictions are enforced for content delivery based on viewer location.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdcpLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Hdcp Level Required' ;
    rdfs:comment 'The minimum HDCP version required for output protection to prevent unauthorized digital copying. [ENUM-REF-CANDIDATE: none|hdcp_1_0|hdcp_1_1|hdcp_1_2|hdcp_1_3|hdcp_1_4|hdcp_2_0|hdcp_2_1|hdcp_2_2|hdcp_2_3 — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyRotationIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Key Rotation Interval Hours' ;
    rdfs:comment 'The frequency in hours at which encryption keys are rotated for enhanced security.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'License Duration Seconds' ;
    rdfs:comment 'The validity period in seconds for a DRM license before it must be renewed.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseServerEndpoint rdf:type rdf:Property ;
    rdfs:label 'License Server Endpoint' ;
    rdfs:comment 'The URL endpoint of the DRM license server that issues decryption keys to authorized clients.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDeviceRegistrations rdf:type rdf:Property ;
    rdfs:label 'Max Device Registrations' ;
    rdfs:comment 'The maximum number of devices that can be registered for content playback per user account.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offlineLicenseDurationHours rdf:type rdf:Property ;
    rdfs:label 'Offline License Duration Hours' ;
    rdfs:comment 'The maximum duration in hours that offline downloaded content remains playable before license expiration.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offlinePlaybackWindowHours rdf:type rdf:Property ;
    rdfs:label 'Offline Playback Window Hours' ;
    rdfs:comment 'The time window in hours during which offline content must be played once playback begins.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:persistentLicenseEnabled rdf:type rdf:Property ;
    rdfs:label 'Persistent License Enabled' ;
    rdfs:comment 'Flag indicating whether licenses can be stored persistently on the device for offline or repeated playback.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playbackDurationHours rdf:type rdf:Property ;
    rdfs:label 'Playback Duration Hours' ;
    rdfs:comment 'The time window in hours during which content must be consumed once playback begins for rental content.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Unique business code or identifier for the DRM policy used across systems and platforms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name of the DRM policy for identification and reference purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyPriority rdf:type rdf:Property ;
    rdfs:label 'Policy Priority' ;
    rdfs:comment 'The priority ranking of this policy when multiple policies could apply. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'The current lifecycle status of the DRM policy (draft, active, suspended, deprecated, retired).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rentalDurationHours rdf:type rdf:Property ;
    rdfs:label 'Rental Duration Hours' ;
    rdfs:comment 'The total rental period in hours during which content is accessible for Transactional Video On Demand (TVOD) rentals.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:screenCaptureBlocked rdf:type rdf:Property ;
    rdfs:label 'Screen Capture Blocked' ;
    rdfs:comment 'Flag indicating whether screen capture and recording are blocked during content playback.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'The security level required for DRM implementation (software or hardware-based cryptography and decoding).' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenExpirySeconds rdf:type rdf:Property ;
    rdfs:label 'Token Expiry Seconds' ;
    rdfs:comment 'The expiration time in seconds for authentication tokens used in DRM license acquisition.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:widevineSecurityLevel rdf:type rdf:Property ;
    rdfs:label 'Widevine Security Level' ;
    rdfs:comment 'The Widevine-specific security level (L1 hardware-backed, L2 software-backed, L3 software only).' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureFlagId rdf:type rdf:Property ;
    rdfs:label 'Feature Flag Id' ;
    rdfs:comment 'Unique identifier for the feature flag configuration record.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appVersionMax rdf:type rdf:Property ;
    rdfs:label 'App Version Max' ;
    rdfs:comment 'Maximum Over-The-Top (OTT) application version for which this feature flag is active (semantic versioning format: major.minor.patch). Null if no upper bound.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appVersionMin rdf:type rdf:Property ;
    rdfs:label 'App Version Min' ;
    rdfs:comment 'Minimum Over-The-Top (OTT) application version required for this feature flag to be active (semantic versioning format: major.minor.patch).' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyFlags rdf:type rdf:Property ;
    rdfs:label 'Dependency Flags' ;
    rdfs:comment 'Comma-separated list of other feature flag keys that must be enabled for this flag to function correctly. Captures flag interdependencies.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enabledFlag rdf:type rdf:Property ;
    rdfs:label 'Enabled Flag' ;
    rdfs:comment 'Boolean indicator of whether the feature flag is currently enabled (True) or disabled (False) for the target audience.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evaluationCount rdf:type rdf:Property ;
    rdfs:label 'Evaluation Count' ;
    rdfs:comment 'Total number of times this feature flag has been evaluated by application code since activation. Used for usage analytics and cleanup decisions.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:experimentHypothesis rdf:type rdf:Property ;
    rdfs:label 'Experiment Hypothesis' ;
    rdfs:comment 'Business hypothesis being tested when flag_type is \'experiment\' (e.g., \'Personalized content rail will increase engagement by 15%\'). Null for non-experiment flags.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureFlagDescription rdf:type rdf:Property ;
    rdfs:label 'Feature Flag Description' ;
    rdfs:comment 'Detailed business description of the feature controlled by this flag, including purpose, expected behavior, and rollout strategy.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagKey rdf:type rdf:Property ;
    rdfs:label 'Flag Key' ;
    rdfs:comment 'Unique programmatic identifier for the feature flag used in application code (e.g., \'new_player_ui\', \'personalized_rail_v2\'). Must be unique across the platform.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagName rdf:type rdf:Property ;
    rdfs:label 'Flag Name' ;
    rdfs:comment 'Human-readable display name for the feature flag shown in management dashboards and reporting interfaces.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagStatus rdf:type rdf:Property ;
    rdfs:label 'Flag Status' ;
    rdfs:comment 'Current lifecycle status of the feature flag: active (in use), inactive (temporarily disabled), archived (no longer needed but retained for audit), deprecated (scheduled for removal).' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagType rdf:type rdf:Property ;
    rdfs:label 'Flag Type' ;
    rdfs:comment 'Classification of the feature flag purpose: release_toggle (gradual feature rollout), experiment (A/B test variant), ops_toggle (operational control), permission_toggle (access control), ux_variant (user experience configuration), kill_switch (emergency disable capability).' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:killSwitchEnabled rdf:type rdf:Property ;
    rdfs:label 'Kill Switch Enabled' ;
    rdfs:comment 'Boolean indicator of whether this flag can be used as an emergency kill switch to rapidly disable a feature without application redeployment.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastEvaluationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Evaluation Timestamp' ;
    rdfs:comment 'Timestamp of the most recent evaluation of this feature flag by any application instance. Used to identify stale or unused flags.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:owningProductTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Product Team' ;
    rdfs:comment 'Name of the product team responsible for managing this feature flag and making rollout decisions (e.g., \'Player Experience Team\', \'Personalization Team\').' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated list of tags for categorization and filtering (e.g., \'personalization\', \'monetization\', \'compliance\', \'performance\'). Enables flag discovery and governance.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceSegment rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segment' ;
    rdfs:comment 'Audience segment or cohort identifier to which this feature flag applies (e.g., \'premium_subscribers\', \'beta_testers\', \'geo_usa_west\'). References audience segmentation taxonomy.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Traffic Split Percentage' ;
    rdfs:comment 'Percentage of traffic allocated to variant B in A/B experiments (0.00 to 100.00). Remaining traffic goes to variant A. Null for non-experiment flags.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uxConfigurationJson rdf:type rdf:Property ;
    rdfs:label 'Ux Configuration Json' ;
    rdfs:comment 'JSON-encoded configuration parameters for user experience variants including rail ordering, theme selection, layout variant, navigation structure, and other UX-specific settings controlled by this flag.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantAConfig rdf:type rdf:Property ;
    rdfs:label 'Variant A Config' ;
    rdfs:comment 'Configuration parameters for variant A in A/B test experiments (typically the control group). JSON-encoded or plain text depending on complexity.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantBConfig rdf:type rdf:Property ;
    rdfs:label 'Variant B Config' ;
    rdfs:comment 'Configuration parameters for variant B in A/B test experiments (typically the treatment group). JSON-encoded or plain text depending on complexity.' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseeSalesAccountId rdf:type rdf:Property ;
    rdfs:label 'Licensee Sales Account Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_account. Business justification: OTT platforms are licensed to enterprise customers and distribution partners tracked as sales accounts. Supports B2B platform licensing deals, white-label OTT agreements, and enterprise streaming serv' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesAccount .

ind:platformManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Platform Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: OTT platforms require operational ownership for launch management, SLA compliance monitoring, sunset decisions, and incident escalation. Platform managers are accountable for subscriber growth, ARPU t' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adobePropertyCode rdf:type rdf:Property ;
    rdfs:label 'Adobe Property Code' ;
    rdfs:comment 'The unique property identifier assigned to this OTT platform within Adobe Experience Platform (AEP) for audience data collection, segmentation, and personalization. Used to link platform-level engagement events to subscriber profiles and Nielsen cross-platform measurement.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arpu rdf:type rdf:Property ;
    rdfs:label 'Arpu' ;
    rdfs:comment 'Average monthly revenue generated per active subscriber on this platform, expressed in the platform\'s billing currency. Calculated at the platform level for strategic pricing and investor reporting. Confidential as a key financial performance indicator. Sourced from Zuora revenue recognition data.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseSubscriptionPrice rdf:type rdf:Property ;
    rdfs:label 'Base Subscription Price' ;
    rdfs:comment 'The standard monthly subscription price for this platform in the billing currency. Applicable for SVOD and HYBRID tiers. Null for AVOD and FAST platforms with no subscription fee. Used in Zuora plan configuration and financial forecasting in SAP S/4HANA.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrency rdf:type rdf:Property ;
    rdfs:label 'Billing Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the primary billing currency used on this platform (e.g., \'USD\', \'GBP\', \'EUR\'). Governs Zuora subscription plan pricing, SAP S/4HANA financial reconciliation, and multi-currency revenue reporting.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnOriginUrl rdf:type rdf:Property ;
    rdfs:label 'Cdn Origin Url' ;
    rdfs:comment 'The base origin URL configured in the CDN for this platform\'s content delivery. Used by Akamai CDN to route requests to the correct media origin server. Critical for CDN configuration audits and incident troubleshooting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingSystem rdf:type rdf:Property ;
    rdfs:label 'Content Rating System' ;
    rdfs:comment 'The content classification and rating system applied to content on this platform (e.g., MPAA for USA, BBFC for UK, FSK for Germany). Governs parental control enforcement, COPPA compliance for children\'s content, and MPA anti-piracy obligations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daiProvider rdf:type rdf:Property ;
    rdfs:label 'Dai Provider' ;
    rdfs:comment 'The technology vendor or platform providing DAI services for this OTT platform (e.g., \'Google DAI\', \'FreeWheel\', \'Yospace\', \'Brightcove SSAI\'). Null if DAI is not enabled. Used for vendor management, SLA tracking, and ad revenue reconciliation.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgFeedUrl rdf:type rdf:Property ;
    rdfs:label 'Epg Feed Url' ;
    rdfs:comment 'The URL of the Electronic Program Guide data feed for this platform, used by third-party EPG aggregators, smart TV manufacturers, and vMVPD partners to display scheduling information. Null for pure VOD platforms without a linear schedule. Sourced from Ericsson MediaFirst playout system.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastChannelEnabled rdf:type rdf:Property ;
    rdfs:label 'Fast Channel Enabled' ;
    rdfs:comment 'Indicates whether this platform operates or hosts FAST channels — linear-style, ad-supported free streaming channels. True = FAST channel delivery active; False = no FAST channel. Relevant for FAST syndication partnerships and Wide Orbit ad scheduling.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeTrialDays rdf:type rdf:Property ;
    rdfs:label 'Free Trial Days' ;
    rdfs:comment 'Number of days in the free trial period offered to new subscribers on this platform. Zero or null if no free trial is offered. Configured in Zuora subscription plans and used in churn rate and LTV analysis.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hdrSupported rdf:type rdf:Property ;
    rdfs:label 'Hdr Supported' ;
    rdfs:comment 'Indicates whether the platform supports High Dynamic Range video delivery (HDR10, Dolby Vision, or HLG). True = HDR delivery supported; False = SDR only. Relevant for premium content licensing negotiations and CTV device compatibility.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxConcurrentStreams rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Streams' ;
    rdfs:comment 'The maximum number of simultaneous streams permitted per subscriber account on this platform. Enforced at the entitlement layer to prevent credential sharing and manage CDN bandwidth capacity. A key parameter in Zuora subscription plan configuration.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxDownloadDevices rdf:type rdf:Property ;
    rdfs:label 'Max Download Devices' ;
    rdfs:comment 'The maximum number of devices on which a subscriber may store downloaded content for offline viewing on this platform. Null if offline downloads are not supported. Governed by DRM policy and Rightsline windowing rules.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxVideoResolution rdf:type rdf:Property ;
    rdfs:label 'Max Video Resolution' ;
    rdfs:comment 'The highest video resolution tier supported for streaming on this platform. SD = Standard Definition (480p); HD = High Definition (720p); FHD = Full HD (1080p); 4K = Ultra HD (2160p); 8K = Super Hi-Vision (4320p). Drives ABR profile configuration, CDN bandwidth planning, and content ingest specifications in Dalet Galaxy.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvpdCarriageEligible rdf:type rdf:Property ;
    rdfs:label 'Mvpd Carriage Eligible' ;
    rdfs:comment 'Indicates whether this OTT platform\'s content or channels are eligible for carriage by MVPD or vMVPD partners (cable, satellite, virtual pay-TV operators). True = eligible for carriage agreements; False = direct-to-consumer only. Governs retransmission consent and must-carry negotiations.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentBrand rdf:type rdf:Property ;
    rdfs:label 'Parent Brand' ;
    rdfs:comment 'The overarching corporate or media brand under which this OTT platform operates (e.g., \'Media Broadcasting Group\', \'MB Sports Network\'). Supports brand hierarchy reporting, consolidated audience measurement, and multi-brand advertising sales in Salesforce Media Cloud.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformCode rdf:type rdf:Property ;
    rdfs:label 'Platform Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to the OTT platform (e.g., \'MB_SVOD_WEB\', \'MB_AVOD_CTV\'). Used in operational systems, contracts, and partner integrations as the canonical platform identifier. Maps to the platform identifier used in Zuora subscription plans and Akamai CDN configuration.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformDescription rdf:type rdf:Property ;
    rdfs:label 'Platform Description' ;
    rdfs:comment 'Detailed narrative description of the platform\'s content offering, target audience, and service proposition. Used in partner onboarding documentation, regulatory filings, and internal product catalogues.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Official commercial brand name of the OTT platform as presented to subscribers and partners (e.g., \'MediaBroadcast+\', \'MB Sports Live\'). Used in marketing materials, EPG listings, and subscriber-facing interfaces.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformStatus rdf:type rdf:Property ;
    rdfs:label 'Platform Status' ;
    rdfs:comment 'Current lifecycle state of the OTT platform. \'active\' = live and serving audiences; \'beta\' = limited release for testing; \'sunset\' = scheduled for decommission; \'suspended\' = temporarily offline; \'inactive\' = decommissioned. Governs whether the platform is eligible for new subscriber acquisition, ad campaign targeting, and CDN resource allocation.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryStreamingProtocol rdf:type rdf:Property ;
    rdfs:label 'Primary Streaming Protocol' ;
    rdfs:comment 'The primary adaptive bitrate streaming protocol used for content delivery on this platform. HLS = HTTP Live Streaming (Apple standard, widely supported); MPEG-DASH = Dynamic Adaptive Streaming over HTTP (ISO 23009 standard); RTMP = Real-Time Messaging Protocol (legacy live); SRT = Secure Reliable Transport (low-latency live). Drives CDN configuration in Akamai and player SDK selection.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryStreamingProtocol rdf:type rdf:Property ;
    rdfs:label 'Secondary Streaming Protocol' ;
    rdfs:comment 'Fallback or secondary adaptive bitrate streaming protocol supported by the platform for device compatibility or redundancy. Null or \'NONE\' if only one protocol is used. Supports multi-protocol CDN origin configuration in Akamai.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaUptimeTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Target Pct' ;
    rdfs:comment 'The contractually committed platform availability target expressed as a percentage (e.g., 99.95). Governs CDN SLA enforcement with Akamai, incident escalation thresholds, and operational reporting. Distinct from actual measured uptime.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriberCount rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count' ;
    rdfs:comment 'Current count of active paying or registered subscribers on this platform as of the last reconciliation cycle. A key operational metric for ARPU calculation, churn rate monitoring, and Zuora revenue reporting. Confidential as it represents commercially sensitive business performance data.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportedDeviceClasses rdf:type rdf:Property ;
    rdfs:label 'Supported Device Classes' ;
    rdfs:comment 'Comma-separated list of device categories supported by this platform (e.g., \'web,mobile,ctv,stb,gaming_console\'). Drives device compatibility testing, app store distribution, and audience reach reporting. [ENUM-REF-CANDIDATE: web|mobile|ctv|stb|gaming_console|smart_tv|tablet — promote to reference product]' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Target Start Bitrate Kbps' ;
    rdfs:comment 'The minimum target bitrate in kilobits per second at which the ABR player should initiate playback on this platform. Drives ABR profile ladder configuration in Akamai CDN and QoS monitoring thresholds. Key parameter for streaming quality benchmarking.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zuoraProductCode rdf:type rdf:Property ;
    rdfs:label 'Zuora Product Code' ;
    rdfs:comment 'The product identifier in Zuora\'s subscription billing platform corresponding to this OTT platform\'s subscription offering. Used for revenue recognition, invoice generation, and subscription lifecycle management. Links the platform master record to Zuora\'s billing product catalogue.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationEngineId rdf:type rdf:Property ;
    rdfs:label 'Personalization Engine Id' ;
    rdfs:comment 'Unique identifier for the personalization engine instance. Primary key for the personalization engine configuration record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PersonalizationEngine .

ind:fallbackEnginePersonalizationEngineId rdf:type rdf:Property ;
    rdfs:label 'Fallback Engine Personalization Engine Id' ;
    rdfs:comment 'Reference to an alternative personalization engine to use if this engine fails or returns insufficient recommendations. Ensures continuous user experience during engine failures or maintenance.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PersonalizationEngine .

ind:softwareLicenseId rdf:type rdf:Property ;
    rdfs:label 'Software License Id' ;
    rdfs:comment 'Foreign key linking to technology.software_license. Business justification: Personalization engines use licensed ML frameworks. Required for ML software license compliance and engine cost allocation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoftwareLicense .

ind:abTestVariant rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant' ;
    rdfs:comment 'A/B test variant identifier if this engine is part of an experimentation framework (e.g., \'control\', \'variant_a\', \'variant_b\'). Null if not part of active testing.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:algorithmType rdf:type rdf:Property ;
    rdfs:label 'Algorithm Type' ;
    rdfs:comment 'The machine learning algorithm type used by the personalization engine. Collaborative filtering uses user behavior patterns, content-based uses content attributes, hybrid combines both approaches, matrix factorization decomposes user-item interactions, deep learning uses neural networks, and contextual bandit balances exploration and exploitation.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'Uniform Resource Locator (URL) of the Application Programming Interface (API) endpoint that serves recommendations from this engine. Used by client applications to request personalized content.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Business rationale and expected outcomes for deploying this personalization engine (e.g., \'Increase Average Revenue Per User (ARPU) by 15%\', \'Reduce churn rate by improving content discovery\', \'Support new FAST channel launch\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Compliant Flag' ;
    rdfs:comment 'Boolean indicator of whether this personalization engine complies with California Consumer Privacy Act (CCPA) requirements, including opt-out mechanisms and data sale restrictions.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coldStartStrategy rdf:type rdf:Property ;
    rdfs:label 'Cold Start Strategy' ;
    rdfs:comment 'Strategy used to generate recommendations for new users or content with insufficient interaction history. Popularity-based shows trending content, content similarity uses metadata matching, demographic default uses segment averages, hybrid fallback combines multiple approaches, and random exploration introduces serendipity.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceThreshold rdf:type rdf:Property ;
    rdfs:label 'Confidence Threshold' ;
    rdfs:comment 'Minimum confidence score (0.00 to 1.00) required for a recommendation to be surfaced to users. Lower thresholds increase recommendation volume but may reduce relevance.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentFilterRules rdf:type rdf:Property ;
    rdfs:label 'Content Filter Rules' ;
    rdfs:comment 'Business rules defining content eligibility for recommendations (e.g., exclude expired rights, enforce parental controls, respect geographic blackouts, honor windowing restrictions). Stored as structured text or JSON.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Date' ;
    rdfs:comment 'Date when this personalization engine instance was first deployed to production. Used for tracking engine age and performance trends over time.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:diversityThreshold rdf:type rdf:Property ;
    rdfs:label 'Diversity Threshold' ;
    rdfs:comment 'Minimum diversity score (0.00 to 1.00) enforced in recommendation sets to prevent filter bubbles. Higher values ensure greater variety in content genres, formats, and themes.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineCode rdf:type rdf:Property ;
    rdfs:label 'Engine Code' ;
    rdfs:comment 'Unique business identifier code for the personalization engine (e.g., \'HOME_REC_01\', \'CONT_DISC_02\'). Used for system integration and API references.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineName rdf:type rdf:Property ;
    rdfs:label 'Engine Name' ;
    rdfs:comment 'Human-readable name of the personalization engine instance (e.g., \'Homepage Recommender\', \'Content Discovery Engine\', \'Next Episode Predictor\'). Used for operational identification and reporting.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureSetConfiguration rdf:type rdf:Property ;
    rdfs:label 'Feature Set Configuration' ;
    rdfs:comment 'JSON or structured text describing the feature set used by the model (e.g., viewing history, genre preferences, time-of-day patterns, device type, engagement metrics). Defines the input variables for the recommendation algorithm.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Boolean indicator of whether this personalization engine complies with General Data Protection Regulation (GDPR) requirements for audience data processing, including consent management, data minimization, and right to erasure.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTrainingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Training Timestamp' ;
    rdfs:comment 'Timestamp of the most recent model training execution. Critical for monitoring model freshness and ensuring recommendations reflect current user behavior patterns.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Semantic version number of the deployed machine learning model (e.g., \'v1.2.3\'). Follows semantic versioning convention for model lifecycle management and rollback capability.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMetricTarget rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Target' ;
    rdfs:comment 'Primary business metric this personalization engine is optimized to maximize. Click-through rate measures initial engagement, watch time measures sustained viewing, completion rate measures content finish rate, engagement score is a composite metric, and revenue per user measures monetization impact.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationScope rdf:type rdf:Property ;
    rdfs:label 'Personalization Scope' ;
    rdfs:comment 'Granularity level at which personalization is applied. User-level provides individual recommendations, segment-level groups similar users, household-level considers shared viewing, and device-level adapts to device context.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationCountLimit rdf:type rdf:Property ;
    rdfs:label 'Recommendation Count Limit' ;
    rdfs:comment 'Maximum number of recommendations this engine will return per request. Typical values range from 10 to 100 depending on user interface requirements and performance constraints.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refreshCadence rdf:type rdf:Property ;
    rdfs:label 'Refresh Cadence' ;
    rdfs:comment 'Frequency at which the personalization model is retrained or recommendations are regenerated. Real-time engines update continuously, while batch engines refresh on schedule.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeSlaMs rdf:type rdf:Property ;
    rdfs:label 'Response Time Sla Ms' ;
    rdfs:comment 'Maximum acceptable response time in milliseconds for recommendation requests as defined in the Service Level Agreement (SLA). Typical values range from 100ms to 500ms for real-time engines.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingDataWindowDays rdf:type rdf:Property ;
    rdfs:label 'Training Data Window Days' ;
    rdfs:comment 'Number of days of historical data used to train the personalization model. Typical values range from 30 to 365 days depending on content velocity and user behavior patterns.' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceTypeId rdf:type rdf:Property ;
    rdfs:label 'Device Device Type Id' ;
    rdfs:comment 'Reference to the device used for this playback session. Enables device-level analytics and QoS (Quality of Service) monitoring.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceType .

ind:techIncidentId rdf:type rdf:Property ;
    rdfs:label 'Tech Incident Id' ;
    rdfs:comment 'Foreign key linking to technology.tech_incident. Business justification: Playback sessions are impacted by technology incidents. Required for incident viewer impact assessment and session failure correlation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechIncident .

ind:transactionInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Transaction Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Playback sessions for TVOD, rental, and pay-per-view models generate per-transaction invoices. Real business process: transactional VOD billing, rental revenue recognition, PPV event billing. Role pre' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:adBreaksServedCount rdf:type rdf:Property ;
    rdfs:label 'Ad Breaks Served Count' ;
    rdfs:comment 'Number of ad breaks (ad pods) served during this playback session. Used for advertising inventory management and revenue reconciliation.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioLanguage rdf:type rdf:Property ;
    rdfs:label 'Audio Language' ;
    rdfs:comment 'ISO 639 language code for the audio track selected by the viewer. Supports multi-language content analytics and localization strategy.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Average Bitrate Kbps' ;
    rdfs:comment 'Average streaming bitrate in kilobits per second during the session. Indicates video quality delivered and network performance.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedCaptionsEnabled rdf:type rdf:Property ;
    rdfs:label 'Closed Captions Enabled' ;
    rdfs:comment 'Indicates whether closed captions were enabled during the session. Critical for accessibility compliance reporting and user preference analysis.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of content watched relative to total content duration. Key engagement metric for content performance and recommendation algorithms.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exitReason rdf:type rdf:Property ;
    rdfs:label 'Exit Reason' ;
    rdfs:comment 'The reason the playback session ended. Critical for distinguishing intentional exits from technical failures and optimizing viewer experience.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCity rdf:type rdf:Property ;
    rdfs:label 'Geographic City' ;
    rdfs:comment 'City where the viewer is located during playback. Enables hyper-local audience analytics and targeted advertising campaigns.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicPostalCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Postal Code' ;
    rdfs:comment 'Postal code derived from viewer location. Used for demographic overlay and targeted advertising. Subject to privacy regulations.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialBufferingDurationMs rdf:type rdf:Property ;
    rdfs:label 'Initial Buffering Duration Ms' ;
    rdfs:comment 'Time in milliseconds from session start until playback began. Key QoS metric for measuring time-to-first-frame and viewer experience.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playbackMode rdf:type rdf:Property ;
    rdfs:label 'Playback Mode' ;
    rdfs:comment 'The mode of content consumption: live linear broadcast, VOD (Video On Demand), DVR (time-shifted), or restart. Critical for audience measurement methodology and rights management.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebufferingEventsCount rdf:type rdf:Property ;
    rdfs:label 'Rebuffering Events Count' ;
    rdfs:comment 'Number of rebuffering (stalling) events that occurred during the session. Critical QoS metric for viewer experience and churn prediction.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Created Timestamp' ;
    rdfs:comment 'Timestamp when this playback session record was created in the system. Used for data lineage and operational monitoring.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Updated Timestamp' ;
    rdfs:comment 'Timestamp when this playback session record was last updated. Supports audit trail and data quality monitoring.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subtitleLanguage rdf:type rdf:Property ;
    rdfs:label 'Subtitle Language' ;
    rdfs:comment 'ISO 639 language code for subtitles displayed during the session. Null if no subtitles were enabled. Supports accessibility and localization analytics.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRebufferingDurationMs rdf:type rdf:Property ;
    rdfs:label 'Total Rebuffering Duration Ms' ;
    rdfs:comment 'Cumulative time in milliseconds spent in rebuffering state during the session. Complements rebuffering count for comprehensive QoS analysis.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalWatchDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Watch Duration Seconds' ;
    rdfs:comment 'Total time in seconds the viewer actively watched content during this session. Primary metric for audience measurement and content engagement analysis.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playoutFeedId rdf:type rdf:Property ;
    rdfs:label 'Playout Feed Id' ;
    rdfs:comment 'Unique identifier for the playout feed. Primary key for the playout feed entity representing a discrete output stream from the playout automation system.' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failoverFeedId rdf:type rdf:Property ;
    rdfs:label 'Failover Feed Id' ;
    rdfs:comment 'Reference to the backup playout feed that will take over in case of failure of this primary feed, enabling high availability and business continuity.' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayoutFeed .

ind:playoutEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Playout Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Playout feeds are broadcast operations infrastructure requiring engineering ownership for failover testing, graphics overlay management, SCTE-35 configuration, and automation system integration. Essen' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:signalRouteId rdf:type rdf:Property ;
    rdfs:label 'Signal Route Id' ;
    rdfs:comment 'Foreign key linking to distribution.signal_route. Business justification: Playout feeds are routed via signal routes. Each feed uses a signal route for distribution. Essential for feed routing and failover management.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SignalRoute .

ind:automationMode rdf:type rdf:Property ;
    rdfs:label 'Automation Mode' ;
    rdfs:comment 'Level of automation for playout operations: fully automated with no operator intervention, semi-automated requiring operator approval for certain events, or manual requiring operator control for all playout actions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandingProfile rdf:type rdf:Property ;
    rdfs:label 'Branding Profile' ;
    rdfs:comment 'Name or identifier of the branding profile applied to this playout feed, controlling channel logos, watermarks, and visual identity elements.' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Enabled' ;
    rdfs:comment 'Indicates whether closed captioning (CEA-608, CEA-708) is enabled and embedded in the playout feed output for accessibility compliance.' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failoverTriggerMode rdf:type rdf:Property ;
    rdfs:label 'Failover Trigger Mode' ;
    rdfs:comment 'Method by which failover to the backup feed is initiated: automatic based on health monitoring, manual operator intervention, or scheduled for planned maintenance.' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedCode rdf:type rdf:Property ;
    rdfs:label 'Feed Code' ;
    rdfs:comment 'Unique business identifier code for the playout feed used in scheduling systems, traffic systems, and operational workflows.' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedName rdf:type rdf:Property ;
    rdfs:label 'Feed Name' ;
    rdfs:comment 'Human-readable name of the playout feed used for identification and operational reference within the playout automation system.' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedType rdf:type rdf:Property ;
    rdfs:label 'Feed Type' ;
    rdfs:comment 'Classification of the playout feed indicating its operational role: primary broadcast feed, backup feed for failover, redundant feed for high availability, test feed for validation, or preview feed for quality control.' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:graphicsOverlayEnabled rdf:type rdf:Property ;
    rdfs:label 'Graphics Overlay Enabled' ;
    rdfs:comment 'Indicates whether real-time graphics overlay (bugs, tickers, lower thirds, branding elements) is enabled for this playout feed.' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:graphicsTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Graphics Template Code' ;
    rdfs:comment 'Reference to the graphics template configuration used for branding, bugs, and overlay elements on this playout feed.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multicastAddress rdf:type rdf:Property ;
    rdfs:label 'Multicast Address' ;
    rdfs:comment 'Multicast IP address used for distributing the playout feed to multiple receivers simultaneously in IP-based broadcast networks.' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputFormat rdf:type rdf:Property ;
    rdfs:label 'Output Format' ;
    rdfs:comment 'Physical or network output format of the playout feed: Serial Digital Interface (SDI) for baseband video, Internet Protocol (IP) for network streaming, Asynchronous Serial Interface (ASI) for MPEG transport streams, Secure Reliable Transport (SRT), Reliable Internet Stream Transport (RIST), or Network Device Interface (NDI).' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutServerCode rdf:type rdf:Property ;
    rdfs:label 'Playout Server Code' ;
    rdfs:comment 'Identifier of the physical or virtual playout server assigned to generate this feed. Links the feed to the automation infrastructure.' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portNumber rdf:type rdf:Property ;
    rdfs:label 'Port Number' ;
    rdfs:comment 'Network port number used for the playout feed output connection in IP-based delivery configurations.' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redundancyMode rdf:type rdf:Property ;
    rdfs:label 'Redundancy Mode' ;
    rdfs:comment 'Redundancy configuration for the playout feed: none (single feed), hot standby (backup ready to take over), active-active (both feeds broadcasting simultaneously), or N+1 (shared backup for multiple feeds).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scte35Enabled rdf:type rdf:Property ;
    rdfs:label 'Scte35 Enabled' ;
    rdfs:comment 'Indicates whether SCTE-35 digital program insertion cue messages are enabled in the playout feed for Dynamic Ad Insertion (DAI) and program segmentation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Service Identifier' ;
    rdfs:comment 'DVB Service ID or ATSC program number identifying the service within the transport stream for Electronic Program Guide (EPG) and receiver tuning.' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportStreamIdentifier rdf:type rdf:Property ;
    rdfs:label 'Transport Stream Identifier' ;
    rdfs:comment 'MPEG Transport Stream ID (TSID) assigned to this playout feed for multiplexing and demultiplexing in broadcast distribution networks.' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uptimeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Uptime Target Percent' ;
    rdfs:comment 'Target uptime percentage for the playout feed as defined in the Service Level Agreement (SLA), typically 99.9% or higher for mission-critical broadcast feeds.' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoBitrateMbps rdf:type rdf:Property ;
    rdfs:label 'Video Bitrate Mbps' ;
    rdfs:comment 'Target video bitrate in megabits per second (Mbps) for the playout feed output, determining video quality and bandwidth consumption.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qosEventId rdf:type rdf:Property ;
    rdfs:label 'Qos Event Id' ;
    rdfs:comment 'Unique identifier for the QoS event record. Primary key.' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nocAlertId rdf:type rdf:Property ;
    rdfs:label 'Noc Alert Id' ;
    rdfs:comment 'Foreign key linking to technology.noc_alert. Business justification: QoS events are generated in response to NOC alerts. Required for event correlation analysis and root cause determination.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NocAlert .

ind:bufferLevelSeconds rdf:type rdf:Property ;
    rdfs:label 'Buffer Level Seconds' ;
    rdfs:comment 'Amount of video content buffered in the player at the time of the event, measured in seconds. Indicates playback health and risk of stalling.' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downloadThroughputKbps rdf:type rdf:Property ;
    rdfs:label 'Download Throughput Kbps' ;
    rdfs:comment 'Measured download throughput in kilobits per second at the time of the event. Used by ABR algorithms to determine optimal bitrate.' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:droppedFramesCount rdf:type rdf:Property ;
    rdfs:label 'Dropped Frames Count' ;
    rdfs:comment 'Number of video frames dropped by the player at the time of the event. Indicates rendering performance issues.' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventSeverity rdf:type rdf:Property ;
    rdfs:label 'Event Severity' ;
    rdfs:comment 'Severity level of the QoS event indicating impact on user experience: critical (playback failure), high (significant degradation), medium (noticeable impact), low (minor impact), info (informational only).' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispName rdf:type rdf:Property ;
    rdfs:label 'Isp Name' ;
    rdfs:comment 'Name of the Internet Service Provider through which the viewer is connected. Used for ISP-level QoS analysis and peering optimization.' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'New Bitrate Kbps' ;
    rdfs:comment 'Bitrate in kilobits per second after a bitrate switch event. Populated when event_type is bitrate_switch_up or bitrate_switch_down. Null for other event types.' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerState rdf:type rdf:Property ;
    rdfs:label 'Player State' ;
    rdfs:comment 'State of the video player at the time of the event: playing, paused, buffering, seeking, idle, or error.' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerVersion rdf:type rdf:Property ;
    rdfs:label 'Player Version' ;
    rdfs:comment 'Version identifier of the video player software that generated this QoS event. Used for player-specific issue analysis.' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Previous Bitrate Kbps' ;
    rdfs:comment 'Bitrate in kilobits per second before a bitrate switch event. Populated when event_type is bitrate_switch_up or bitrate_switch_down. Null for other event types.' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seekPositionSeconds rdf:type rdf:Property ;
    rdfs:label 'Seek Position Seconds' ;
    rdfs:comment 'Playback position in seconds to which the user seeked. Populated when event_type is seek. Null for other event types.' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stallDurationMs rdf:type rdf:Property ;
    rdfs:label 'Stall Duration Ms' ;
    rdfs:comment 'Duration of the playback stall or buffering event in milliseconds. Populated when event_type is buffering_start, buffering_end, or stall. Null for other event types.' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releaseWindowId rdf:type rdf:Property ;
    rdfs:label 'Release Window Id' ;
    rdfs:comment 'Primary key for release_window' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReleaseWindow .

ind:licensingInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Licensing Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Release windows (theatrical, home video, SVOD, AVOD) have associated platform licensing fees that generate invoices. Real business process: windowing revenue recognition, platform licensing billing, m' ;
    rdfs:domain ind:ReleaseWindow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:windowingManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Windowing Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Release windows are strategic revenue decisions requiring business owner for holdback negotiations, pricing decisions, exclusivity terms, and PVOD/TVOD strategy. Essential for P&L accountability, righ' ;
    rdfs:domain ind:ReleaseWindow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adInsertionEnabled rdf:type rdf:Property ;
    rdfs:label 'Ad Insertion Enabled' ;
    rdfs:comment 'Indicates whether Dynamic Ad Insertion (DAI) is enabled for this distribution window, allowing targeted advertising within the content stream.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adLoadMinutes rdf:type rdf:Property ;
    rdfs:label 'Ad Load Minutes' ;
    rdfs:comment 'Total minutes of advertising permitted per hour of content in this distribution window. Applicable for AVOD, linear, and FAST windows.' ;
    rdfs:domain ind:ReleaseWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audioDescriptionRequired rdf:type rdf:Property ;
    rdfs:label 'Audio Description Required' ;
    rdfs:comment 'Indicates whether audio description track is required for visually impaired accessibility in this distribution window.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutRules rdf:type rdf:Property ;
    rdfs:label 'Blackout Rules' ;
    rdfs:comment 'Geographic or temporal blackout restrictions applied to this distribution window, preventing broadcast in specific regions or time periods (e.g., sports blackout rules).' ;
    rdfs:domain ind:ReleaseWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dubbingLanguages rdf:type rdf:Property ;
    rdfs:label 'Dubbing Languages' ;
    rdfs:comment 'Comma-separated list of dubbing/audio track languages available for this distribution window (ISO 639-1 codes).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'Precise timestamp when this distribution window record became effective and operational for scheduling and delivery systems.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'Precise timestamp when this distribution window record expires and is no longer valid for operational use. Nullable for indefinite windows.' ;
    rdfs:domain ind:ReleaseWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hdrEnabled rdf:type rdf:Property ;
    rdfs:label 'Hdr Enabled' ;
    rdfs:comment 'Indicates whether High Dynamic Range video format is enabled for this distribution window, providing enhanced color and contrast.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Revenue model for this distribution window. Subscription = SVOD flat fee; Transactional = TVOD pay-per-view or rental; Advertising = AVOD ad-supported; Free = no charge to viewer; Hybrid = combination of models.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasePrice rdf:type rdf:Property ;
    rdfs:label 'Purchase Price' ;
    rdfs:comment 'Price charged to viewers for permanent purchase/download during this window (EST model). Nullable if not applicable.' ;
    rdfs:domain ind:ReleaseWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentalPrice rdf:type rdf:Property ;
    rdfs:label 'Rental Price' ;
    rdfs:comment 'Price charged to viewers for transactional rental access during this window (TVOD model). Nullable if not applicable.' ;
    rdfs:domain ind:ReleaseWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueSharePercent rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percent' ;
    rdfs:comment 'Percentage of revenue shared with the platform or distributor for this window, per the commercial distribution agreement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windowCloseDate rdf:type rdf:Property ;
    rdfs:label 'Window Close Date' ;
    rdfs:comment 'Date when the distribution window closes and content is no longer available on the specified platform or channel. Nullable for open-ended windows.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windowCode rdf:type rdf:Property ;
    rdfs:label 'Window Code' ;
    rdfs:comment 'Business identifier code for the distribution window, used for operational scheduling and reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowOpenDate rdf:type rdf:Property ;
    rdfs:label 'Window Open Date' ;
    rdfs:comment 'Date when the distribution window opens and content becomes available on the specified platform or channel.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windowPriority rdf:type rdf:Property ;
    rdfs:label 'Window Priority' ;
    rdfs:comment 'Numeric priority ranking of this window in the overall release strategy, where 1 = highest priority (typically theatrical), incrementing for subsequent windows.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retransmissionConsentId rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Id' ;
    rdfs:comment 'Primary key for retransmission_consent' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetransmissionConsent .

ind:negotiatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Negotiator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Retransmission consent agreements are regulatory/legal contracts requiring negotiator ownership for FCC compliance, blackout coordination, must-carry elections, and good-faith negotiation requirements' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorizedDmaList rdf:type rdf:Property ;
    rdfs:label 'Authorized Dma List' ;
    rdfs:comment 'Comma-separated list of Nielsen DMA codes where the MVPD is authorized to retransmit the broadcast signal (e.g., 501,602,803).' ;
    rdfs:domain ind:RetransmissionConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Blackout Provision Flag' ;
    rdfs:comment 'Indicates whether the agreement includes geographic blackout provisions restricting retransmission in certain markets or during specific events.' ;
    rdfs:domain ind:RetransmissionConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutTerms rdf:type rdf:Property ;
    rdfs:label 'Blackout Terms' ;
    rdfs:comment 'Detailed description of blackout restrictions, including affected content types, geographic areas, and triggering conditions.' ;
    rdfs:domain ind:RetransmissionConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Compensation Amount' ;
    rdfs:comment 'Monetary compensation amount paid by the MVPD to the broadcaster per billing period. Null if compensation is non-cash.' ;
    rdfs:domain ind:RetransmissionConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelCarriageCommitment rdf:type rdf:Property ;
    rdfs:label 'Channel Carriage Commitment' ;
    rdfs:comment 'Description of channel carriage commitments provided by the MVPD as part of the retransmission consent agreement (e.g., carriage of affiliated digital subchannels).' ;
    rdfs:domain ind:RetransmissionConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for cash compensation (e.g., USD, CAD, GBP).' ;
    rdfs:domain ind:RetransmissionConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationFrequency rdf:type rdf:Property ;
    rdfs:label 'Compensation Frequency' ;
    rdfs:comment 'Billing frequency for cash compensation payments from MVPD to broadcaster.' ;
    rdfs:domain ind:RetransmissionConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationType rdf:type rdf:Property ;
    rdfs:label 'Compensation Type' ;
    rdfs:comment 'Primary form of compensation provided by the MVPD to the broadcaster in exchange for retransmission consent.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Consent Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the retransmission consent agreement, typically formatted as RTC-YYYYNNNN.' ;
    rdfs:domain ind:RetransmissionConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the executed retransmission consent contract document in the document management system.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Agreed-upon method for resolving disputes arising from the retransmission consent agreement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fccFilingReference rdf:type rdf:Property ;
    rdfs:label 'Fcc Filing Reference' ;
    rdfs:comment 'Reference number or identifier for any FCC filings, notifications, or complaints associated with this retransmission consent agreement.' ;
    rdfs:domain ind:RetransmissionConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodFaithNegotiationFlag rdf:type rdf:Property ;
    rdfs:label 'Good Faith Negotiation Flag' ;
    rdfs:comment 'Indicates whether both parties certified compliance with FCC good faith negotiation requirements during retransmission consent discussions.' ;
    rdfs:domain ind:RetransmissionConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mustCarryElectionDate rdf:type rdf:Property ;
    rdfs:label 'Must Carry Election Date' ;
    rdfs:comment 'Date when the broadcaster formally elected must-carry status with the MVPD. Null if retransmission consent was negotiated.' ;
    rdfs:domain ind:RetransmissionConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mustCarryElectionFlag rdf:type rdf:Property ;
    rdfs:label 'Must Carry Election Flag' ;
    rdfs:comment 'Indicates whether the broadcaster elected must-carry status instead of negotiating retransmission consent. True if must-carry was elected.' ;
    rdfs:domain ind:RetransmissionConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mvpdType rdf:type rdf:Property ;
    rdfs:label 'Mvpd Type' ;
    rdfs:comment 'Classification of the MVPD platform type receiving retransmission consent.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Completion Date' ;
    rdfs:comment 'Date when retransmission consent negotiations were successfully concluded and agreement was reached.' ;
    rdfs:domain ind:RetransmissionConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the agreement includes an automatic renewal option or requires renegotiation at expiry.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Description of conditions under which either party may terminate the retransmission consent agreement prior to expiry date.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutChannelId rdf:type rdf:Property ;
    rdfs:label 'Playout Channel Id' ;
    rdfs:comment 'Identifier of the specific playout channel within the playout system that originates the signal for this route.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:slaDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Id' ;
    rdfs:comment 'Identifier of the Service Level Agreement (SLA) definition governing uptime, performance, and quality commitments for this signal route.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaDefinition .

ind:technicalOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Technical Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Signal routes are broadcast infrastructure requiring technical ownership for failover testing, maintenance windows, satellite coordination, and IRD management. Essential for FCC compliance ownership, ' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:backupPathDescription rdf:type rdf:Property ;
    rdfs:label 'Backup Path Description' ;
    rdfs:comment 'Detailed description of the backup or redundant signal routing path used for failover in case of primary path failure.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Mbps' ;
    rdfs:comment 'Allocated bandwidth capacity for this signal route in megabits per second (Mbps), defining the maximum throughput for signal transmission.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Destination Endpoint Url' ;
    rdfs:comment 'Uniform Resource Locator (URL) of the destination endpoint where the signal is delivered (CDN origin, distribution partner, or broadcast facility).' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downlinkFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Downlink Frequency Mhz' ;
    rdfs:comment 'Downlink reception frequency in megahertz (MHz) for satellite signal routes.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drmLicenseServerUrl rdf:type rdf:Property ;
    rdfs:label 'Drm License Server Url' ;
    rdfs:comment 'Uniform Resource Locator (URL) of the DRM license server that issues decryption keys for protected content delivered via this route.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Encryption Algorithm' ;
    rdfs:comment 'Cryptographic algorithm used for signal encryption (e.g., AES-128, AES-256).' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled' ;
    rdfs:comment 'Boolean flag indicating whether signal encryption is enabled for this route to protect content during transmission.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failoverMode rdf:type rdf:Property ;
    rdfs:label 'Failover Mode' ;
    rdfs:comment 'Method by which the signal route switches from primary to backup path during a failure event (automatic, manual, or hybrid).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failoverPriority rdf:type rdf:Property ;
    rdfs:label 'Failover Priority' ;
    rdfs:comment 'Numeric priority ranking determining the order in which this route is selected during failover scenarios (lower number indicates higher priority).' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failoverThresholdSeconds rdf:type rdf:Property ;
    rdfs:label 'Failover Threshold Seconds' ;
    rdfs:comment 'Maximum allowable signal interruption duration in seconds before automatic failover to backup path is triggered.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:irdModel rdf:type rdf:Property ;
    rdfs:label 'Ird Model' ;
    rdfs:comment 'Model name and identifier of the Integrated Receiver Decoder (IRD) equipment used to receive and decode the satellite or terrestrial signal.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irdSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Ird Serial Number' ;
    rdfs:comment 'Serial number of the IRD equipment deployed for this signal route, used for asset tracking and maintenance.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latencyTargetMs rdf:type rdf:Property ;
    rdfs:label 'Latency Target Ms' ;
    rdfs:comment 'Target end-to-end latency in milliseconds for signal delivery from origin to destination, critical for live broadcast and low-latency streaming.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playoutSystemCode rdf:type rdf:Property ;
    rdfs:label 'Playout System Code' ;
    rdfs:comment 'Identifier of the playout automation system serving as the origin source for this signal route (e.g., Ericsson MediaFirst instance).' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:polarization rdf:type rdf:Property ;
    rdfs:label 'Polarization' ;
    rdfs:comment 'Polarization mode of the satellite signal transmission (horizontal, vertical, left circular, right circular).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPathDescription rdf:type rdf:Property ;
    rdfs:label 'Primary Path Description' ;
    rdfs:comment 'Detailed description of the primary signal routing path, including intermediate hops, network segments, and infrastructure components.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the signal route in operational systems and documentation.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Human-readable name identifying the signal routing path, typically describing the source-to-destination flow (e.g., \'Studio-A-to-East-Coast-Uplink\').' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the signal routing path based on delivery technology and infrastructure (linear broadcast, OTT streaming, hybrid, satellite uplink, terrestrial transmission, IP interconnect).' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportProtocol rdf:type rdf:Property ;
    rdfs:label 'Transport Protocol' ;
    rdfs:comment 'Technical protocol used for signal transport and delivery across the routing path. Includes HTTP Live Streaming (HLS), MPEG Dynamic Adaptive Streaming over HTTP (MPEG-DASH), User Datagram Protocol/Transport Stream (UDP/TS), Digital Video Broadcasting Satellite Second Generation (DVB-S2), and others. [ENUM-REF-CANDIDATE: HLS|MPEG-DASH|UDP/TS|DVB-S2|DVB-T2|ATSC|RTP|RTMP|SRT — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uplinkFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Uplink Frequency Mhz' ;
    rdfs:comment 'Uplink transmission frequency in megahertz (MHz) for satellite signal routes.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaBreachId rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Id' ;
    rdfs:comment 'Unique identifier for the SLA breach record. Primary key for the sla_breach product.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incident Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: SLA breaches require incident ownership for root cause analysis, remediation coordination, partner communication, and penalty mitigation. Essential for on-call rotations, incident postmortems, perform' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedRegion rdf:type rdf:Property ;
    rdfs:label 'Affected Region' ;
    rdfs:comment 'The geographic region or CDN Point of Presence (POP) where the breach occurred, identifying the scope of impact.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Breach Duration Minutes' ;
    rdfs:comment 'The total duration of the SLA breach in minutes, from detection to restoration of service within SLA parameters.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'The severity classification of the breach based on business impact, used for prioritization and escalation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachStatus rdf:type rdf:Property ;
    rdfs:label 'Breach Status' ;
    rdfs:comment 'Current state of the breach in its resolution lifecycle, tracking progress from detection through closure.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach Timestamp' ;
    rdfs:comment 'The exact date and time when the SLA breach was detected and recorded. This is the principal business event timestamp for the breach.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'The method by which the SLA breach was detected, indicating whether it was proactive monitoring or reactive reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makegoodTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Triggered Flag' ;
    rdfs:comment 'Indicates whether a makegood (compensatory delivery or ad spot) was triggered as a result of this breach.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The actual measured value of the metric at the time of breach, representing the performance level that violated the SLA threshold.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'The specific SLA metric that was breached, such as uptime percentage, latency, error rate, or availability.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricType rdf:type rdf:Property ;
    rdfs:label 'Metric Type' ;
    rdfs:comment 'Category of the SLA metric that was breached, classifying the nature of the performance issue.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether breach notification was sent to affected partners, stakeholders, or customers as required by SLA terms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'The date and time when breach notification was sent to affected parties.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:penaltyApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Applicable Flag' ;
    rdfs:comment 'Indicates whether a contractual penalty or credit is applicable for this breach based on SLA terms.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationAction rdf:type rdf:Property ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Description of the corrective action taken to resolve the breach and restore service to acceptable levels.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative explanation of the root cause identified through investigation, providing context for the breach.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'The SLA threshold value that was violated, representing the minimum acceptable performance level defined in the SLA commitment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'The user or system that validated the breach measurement and determination, ensuring accuracy for reporting.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validated Timestamp' ;
    rdfs:comment 'The date and time when the breach record was validated and approved for reporting or penalty processing.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:varianceValue rdf:type rdf:Property ;
    rdfs:label 'Variance Value' ;
    rdfs:comment 'The calculated difference between the measured value and the threshold value, quantifying the magnitude of the breach.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Amount' ;
    rdfs:comment 'The monetary amount or percentage of the penalty applied per SLA breach incident.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachPenaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Currency' ;
    rdfs:comment 'The currency in which the breach penalty is denominated, using ISO 4217 three-letter currency code.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachPenaltyType rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Type' ;
    rdfs:comment 'The type of penalty or remedy applied when the SLA is breached (credit, refund, none, custom).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Description of the formula or methodology used to calculate the SLA metric from raw measurements.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalThreshold rdf:type rdf:Property ;
    rdfs:label 'Critical Threshold' ;
    rdfs:comment 'The threshold value at which a critical alert is triggered, indicating an SLA breach has occurred or is imminent.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Escalation Procedure' ;
    rdfs:comment 'Description of the escalation process and contacts when an SLA breach occurs or is imminent.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDefinitionDescription rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Description' ;
    rdfs:comment 'Detailed description of the SLA, including business context, objectives, and any special conditions.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Status' ;
    rdfs:comment 'Current lifecycle status of the SLA definition (active, inactive, draft, superseded, retired).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Category of SLA defining the nature of the service commitment (availability, performance, quality, capacity, support, security).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The target threshold value that defines the SLA commitment (e.g., 99.9 for 99.9% uptime, 2.0 for 2 seconds latency).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warningThreshold rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold' ;
    rdfs:comment 'The threshold value at which a warning alert is triggered, indicating performance is approaching but has not yet breached the SLA target.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Sla Performance Id' ;
    rdfs:comment 'Unique identifier for the SLA performance measurement record.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyCreditMemoId rdf:type rdf:Property ;
    rdfs:label 'Penalty Credit Memo Id' ;
    rdfs:comment 'Foreign key linking to billing.credit_memo. Business justification: SLA breaches trigger contractual penalties and service credits to distribution partners or advertisers. Real business process: SLA penalty assessment, makegood credit issuance, partner compensation fo' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditMemo .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The actual measured value of the SLA metric during the measurement period. Unit of measure is defined in the associated SLA definition.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Flag' ;
    rdfs:comment 'Boolean indicator of whether the SLA was breached during this measurement period. True indicates a breach occurred; False indicates SLA was met.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementGranularity rdf:type rdf:Property ;
    rdfs:label 'Measurement Granularity' ;
    rdfs:comment 'The time granularity at which this SLA performance measurement was captured (hourly, daily, weekly, monthly, quarterly, annual).' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Remediation Timestamp' ;
    rdfs:comment 'The timestamp when remediation action was completed and normal service levels were restored. Null if remediation is pending or not applicable.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'The number of individual observations or data points used to calculate the aggregated SLA metric value. Provides statistical context for measurement confidence.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failoverEndpointId rdf:type rdf:Property ;
    rdfs:label 'Failover Endpoint Id' ;
    rdfs:comment 'Reference to the backup streaming endpoint that should be used if this endpoint becomes unavailable. Supports high availability and disaster recovery.' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StreamingEndpoint .

ind:endpointType rdf:type rdf:Property ;
    rdfs:label 'Endpoint Type' ;
    rdfs:comment 'Classification of the endpoint role within the CDN architecture. Origin endpoints serve as the source, edge endpoints serve end users, and backup endpoints provide failover capability.' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointUrl rdf:type rdf:Property ;
    rdfs:label 'Endpoint Url' ;
    rdfs:comment 'The full URL address of the streaming endpoint, including protocol, domain, and path. This is the technical delivery address for the stream.' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRestrictionMode rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Mode' ;
    rdfs:comment 'Defines whether geo_restriction_rules represent an allow list (whitelist) or deny list (blacklist) for content delivery.' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRestrictionRules rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Rules' ;
    rdfs:comment 'Comma-separated list of ISO country codes or regions where content delivery is allowed or blocked. Enforces territorial licensing and rights management requirements.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestFormat rdf:type rdf:Property ;
    rdfs:label 'Manifest Format' ;
    rdfs:comment 'The streaming manifest file format used by this endpoint. m3u8 for HLS, mpd for MPEG-DASH, ism for Smooth Streaming, f4m for Adobe HDS.' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedDevices rdf:type rdf:Property ;
    rdfs:label 'Supported Devices' ;
    rdfs:comment 'Comma-separated list of device types or platforms that this endpoint is optimized to serve (e.g., iOS, Android, Smart TV, Web Browser, Set-Top Box).' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Auditor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Subscriber count reports drive carriage fee invoicing and require auditor ownership for variance investigation, dispute resolution, audit rights exercise, and third-party auditor coordination. Essenti' ;
    rdfs:domain ind:SubscriberCountReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditReportReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Reference' ;
    rdfs:comment 'Reference identifier to the formal audit report document associated with this subscriber count verification, if a third-party audit was conducted.' ;
    rdfs:domain ind:SubscriberCountReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRightsExercised rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Exercised' ;
    rdfs:comment 'Indicator of whether contractual audit rights were formally exercised for this reporting period, triggering enhanced verification procedures.' ;
    rdfs:domain ind:SubscriberCountReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Status' ;
    rdfs:comment 'Current status of any dispute resolution process related to this subscriber count report.' ;
    rdfs:domain ind:SubscriberCountReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Invoice Generated Flag' ;
    rdfs:comment 'Indicator of whether a carriage fee invoice has been generated based on this subscriber count report.' ;
    rdfs:domain ind:SubscriberCountReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceReference rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference' ;
    rdfs:comment 'Reference identifier to the carriage fee invoice generated from this subscriber count report.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedSubscriberCount rdf:type rdf:Property ;
    rdfs:label 'Reported Subscriber Count' ;
    rdfs:comment 'Total number of subscribers reported by the distribution partner for the specified channel and period, as submitted by the MVPD or vMVPD.' ;
    rdfs:domain ind:SubscriberCountReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Type' ;
    rdfs:comment 'Frequency of the subscriber count reporting period as defined in the carriage agreement (monthly, quarterly, annual, or custom).' ;
    rdfs:domain ind:SubscriberCountReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyAuditor rdf:type rdf:Property ;
    rdfs:label 'Third Party Auditor' ;
    rdfs:comment 'Name of the external audit firm or third-party verification service engaged to validate subscriber counts, if applicable.' ;
    rdfs:domain ind:SubscriberCountReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceCount rdf:type rdf:Property ;
    rdfs:label 'Variance Count' ;
    rdfs:comment 'Numerical difference between reported subscriber count and verified subscriber count (verified minus reported).' ;
    rdfs:domain ind:SubscriberCountReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceExplanation rdf:type rdf:Property ;
    rdfs:label 'Variance Explanation' ;
    rdfs:comment 'Detailed explanation provided by the distribution partner or internal audit team describing the reason for any variance between reported and verified counts.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFlag rdf:type rdf:Property ;
    rdfs:label 'Variance Flag' ;
    rdfs:comment 'Indicator of whether a material variance exists between reported and verified subscriber counts, triggering additional review or dispute resolution.' ;
    rdfs:domain ind:SubscriberCountReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verifiedSubscriberCount rdf:type rdf:Property ;
    rdfs:label 'Verified Subscriber Count' ;
    rdfs:comment 'Subscriber count after internal verification and audit processes, used as the basis for carriage fee calculation.' ;
    rdfs:domain ind:SubscriberCountReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Foreign key linking to finance.chart_of_accounts. Business justification: AP postings reference GL accounts from the chart of accounts. The gl_account STRING is a business key that should be supplemented with FK to chart_of_accounts.chart_of_accounts_id for referential inte' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:companyLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Company Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Accounts payable records must be associated with a legal entity for consolidation and reporting. The company_code is a business key reference to legal_entity. FK will enable proper legal entity consol' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:equipmentProcurementId rdf:type rdf:Property ;
    rdfs:label 'Equipment Procurement Id' ;
    rdfs:comment 'Foreign key linking to technology.equipment_procurement. Business justification: AP invoices are matched to equipment purchase orders for three-way match (PO, goods receipt, invoice). Finance validates invoice against PO terms for payment approval, purchase price variance analysis' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentProcurement .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Identifier of the vendor to whom payment is owed. Links to talent agencies, production vendors, content licensors, technology providers, and distribution partners.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:assignmentReference rdf:type rdf:Property ;
    rdfs:label 'Assignment Reference' ;
    rdfs:comment 'Free-text reference field for additional assignment information (e.g., production code, content title, project ID). Used for detailed cost tracking.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Date from which payment terms are calculated. Typically the document date or goods receipt date, used to determine the due date.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'Date when the payable was fully cleared (paid). Null if still open or partially cleared.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'SAP FI document number of the payment document that cleared this payable. Null if not yet cleared.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Current clearing status of the payable. Open=unpaid, Partially Cleared=partial payment applied, Fully Cleared=completely paid.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Four-character SAP company code representing the legal entity responsible for this payable. Used for financial consolidation and reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'Date by which payment must be made to qualify for early payment discount. Null if no discount terms apply.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentCurrency rdf:type rdf:Property ;
    rdfs:label 'Document Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the invoice (e.g., USD, EUR, GBP). Currency in which the vendor billed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'Date on the vendor invoice or credit memo. Typically the invoice date provided by the vendor.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Ten-digit SAP FI document number uniquely identifying this payable within the company code and fiscal year. The externally-known business identifier for this payable.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'SAP document type code classifying the nature of the payable. KR=Vendor Invoice, KG=Vendor Credit Memo, KN=Net Vendor Invoice, RE=Invoice Receipt, DR=Debit Memo.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Exchange rate used to convert document currency to local currency at posting date. Null if document currency equals local currency.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'Ten-digit general ledger account number to which this payable is posted. Determines the expense or asset classification in the chart of accounts.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total invoice amount before any deductions, in document currency. Represents the full amount billed by the vendor.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'Net payable amount converted to the company code local currency for general ledger posting and financial reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openAmount rdf:type rdf:Property ;
    rdfs:label 'Open Amount' ;
    rdfs:comment 'Outstanding unpaid amount remaining on this payable, in document currency. Reduced as partial payments are applied. Zero when fully cleared.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlock rdf:type rdf:Property ;
    rdfs:label 'Payment Block' ;
    rdfs:comment 'Single-character code indicating if payment is blocked (e.g., A=Blocked for Payment, R=Blocked for Review, blank=Not Blocked). Prevents automatic payment until resolved.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Free-text explanation for why payment is blocked (e.g., pending approval, invoice dispute, missing documentation). Null if not blocked.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Date when the accounts payable document was posted to the general ledger. Determines the fiscal period for financial reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Boolean flag indicating whether this payable is subject to SOX financial controls and requires additional approval workflows. True for material transactions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:textDescription rdf:type rdf:Property ;
    rdfs:label 'Text Description' ;
    rdfs:comment 'Free-text description of the payable, typically describing the goods or services invoiced (e.g., \'Q4 2023 content licensing fees\', \'Studio equipment rental\').' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxIndicator rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Indicator' ;
    rdfs:comment 'Boolean flag indicating whether withholding tax applies to this payable. True if withholding tax is calculated and deducted.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'The aging category of the receivable based on days past due (current, 1-30 days, 31-60 days, 61-90 days, over 90 days).' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'Free-text assignment field used for additional sorting, grouping, or reconciliation purposes in SAP FI-AR.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'The date when the most recent dunning notice was sent to the customer for this receivable.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localCurrency rdf:type rdf:Property ;
    rdfs:label 'Local Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code of the company\'s local reporting currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalAmount rdf:type rdf:Property ;
    rdfs:label 'Original Amount' ;
    rdfs:comment 'The original gross amount of the receivable in document currency when first posted.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDocument rdf:type rdf:Property ;
    rdfs:label 'Reference Document' ;
    rdfs:comment 'External reference document number such as customer purchase order number, contract number, or other business reference.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersionId rdf:type rdf:Property ;
    rdfs:label 'Budget Version Id' ;
    rdfs:comment 'Unique identifier for the budget version record. Primary key.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'The employee identifier of the approver in the HR system. Links to the employee master data for audit and authorization verification.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Reference to the parent budget entity that this version belongs to. Links to the master budget record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'The full name of the individual who approved this budget version. Typically a finance director, CFO, or department head with budget authority.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineAmount rdf:type rdf:Property ;
    rdfs:label 'Baseline Amount' ;
    rdfs:comment 'The original baseline budget amount before any revisions or adjustments. Used as a reference point for variance analysis and tracking budget changes over time.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level classification of the budget type. Operating expense (OPEX) covers day-to-day costs; capital expenditure (CAPEX) covers long-term investments; production cost tracks content creation spend; revenue target sets income goals; headcount manages personnel costs; marketing covers promotional spend; content acquisition tracks licensing and rights purchases. [ENUM-REF-CANDIDATE: operating_expense|capital_expenditure|production_cost|revenue_target|headcount|marketing|content_acquisition — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersionStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Version Status' ;
    rdfs:comment 'Current lifecycle status of the budget version. Draft indicates work in progress; pending approval is awaiting authorization; approved is authorized but not yet active; active is currently in effect; superseded has been replaced by a newer version; closed is finalized and archived.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRationale rdf:type rdf:Property ;
    rdfs:label 'Change Rationale' ;
    rdfs:comment 'Detailed explanation of why this budget version was created. Captures the business justification for revisions, reforecasts, or supplemental allocations. Critical for variance analysis and audit compliance.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationLevel rdf:type rdf:Property ;
    rdfs:label 'Consolidation Level' ;
    rdfs:comment 'Indicates the organizational level at which this budget version is consolidated. Entity is the highest corporate level; division represents major business units; department is operational units; project is specific initiatives; consolidated represents fully aggregated enterprise-wide budgets.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether this budget version is locked from further edits. True means the version is frozen and cannot be modified; false means it is still editable. Used to enforce budget control and prevent unauthorized changes after approval.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningPeriod rdf:type rdf:Property ;
    rdfs:label 'Planning Period' ;
    rdfs:comment 'The planning period granularity for this budget version. Supports quarterly (Q1-Q4), monthly (M01-M12), half-yearly (H1-H2), or full fiscal year (FY) planning cycles.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalApprovedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Approved Amount' ;
    rdfs:comment 'The total monetary amount approved for this budget version. Represents the authorized spending limit or revenue target for the specified cost center, profit center, or production project.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percentage' ;
    rdfs:comment 'The acceptable variance percentage threshold for this budget version. Triggers alerts or approval workflows when actual spend deviates from budget by more than this percentage. Typically set between 5% and 15%.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexProjectId rdf:type rdf:Property ;
    rdfs:label 'Capex Project Id' ;
    rdfs:comment 'Unique identifier for the capital expenditure project record. Primary key.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapexProject .

ind:actualCapitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Capitalization Date' ;
    rdfs:comment 'Actual date when the project was settled to fixed assets and depreciation commenced. Used for SOX compliance and financial statement preparation.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when project was completed and ready for asset settlement. Triggers capitalization workflow and depreciation start date calculation.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when project execution commenced. Used for variance analysis against planned timeline.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'Total capital budget approved for the project by the investment committee. Represents the authorized spending limit for the capital investment.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'Fixed asset class code that the project will be capitalized into upon completion. Determines depreciation method, useful life, and GL account assignment. Examples include broadcast equipment, buildings, IT infrastructure.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aucAccountCode rdf:type rdf:Property ;
    rdfs:label 'Auc Account Code' ;
    rdfs:comment 'General ledger account code for the asset under construction balance sheet account. All project costs are accumulated in this account until capitalization. Typically a fixed asset sub-account per chart of accounts.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'Business area or segment for internal management reporting. Examples include Linear Broadcasting, OTT Streaming, News Division, Sports Network. Used for EBITDA segment reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Spend Amount' ;
    rdfs:comment 'Total actual expenditure incurred to date on the capital project. Aggregates all posted costs from journal entries and purchase orders. Used for budget variance analysis and capitalization.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Planned depreciation method to be applied once the asset is capitalized. Straight line is most common for buildings and infrastructure; declining balance may be used for technology assets; units of production for usage-based assets.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Governance Review Status' ;
    rdfs:comment 'Status of the capital project governance review by the investment committee or capital allocation board. Tracks approval workflow and conditional requirements.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentJustification rdf:type rdf:Property ;
    rdfs:label 'Investment Justification' ;
    rdfs:comment 'Primary business rationale for the capital investment. Capacity expansion includes new studios or transmission capacity; technology upgrade covers platform modernization; regulatory compliance addresses FCC or technical standards; cost reduction targets operational efficiency; revenue generation supports new monetization channels.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User ID of the person who last modified the capital project record. Used for audit trail and change accountability.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCapitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Capitalization Date' ;
    rdfs:comment 'Target date for transferring the asset under construction (AUC) to fixed assets and beginning depreciation. Aligns with asset placed-in-service date for financial reporting.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Target date for project completion and readiness for capitalization. Used for depreciation planning and asset lifecycle management.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled date for project execution to begin. Used for resource planning and timeline tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectClassification rdf:type rdf:Property ;
    rdfs:label 'Project Classification' ;
    rdfs:comment 'Categorical classification of the capital project type. Infrastructure includes broadcast towers and transmission equipment; technology covers OTT platforms and enterprise systems; facilities encompasses studio construction and office build-outs; equipment includes production gear and IRDs.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Business identifier for the capital project, used across financial systems and reporting. Typically follows organizational coding standards for capital investment tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed description of the capital project scope, objectives, and deliverables. Provides context for investment justification and asset capitalization.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Descriptive name of the capital project, such as \'OTT Platform Infrastructure Upgrade\' or \'Studio B Renovation\'.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the capital project. Planning indicates pre-approval stage; approved means budget authorized; in_progress reflects active execution; completed indicates project finished but not yet capitalized; capitalized means transferred to fixed assets; cancelled indicates project terminated. [ENUM-REF-CANDIDATE: planning|approved|in_progress|on_hold|completed|capitalized|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Budget Amount' ;
    rdfs:comment 'Unspent budget balance available for the project. Calculated as approved budget minus cumulative spend. Used for commitment control and budget monitoring.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sponsorName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Name' ;
    rdfs:comment 'Name of the executive sponsor or business owner who approved and champions the capital investment. Typically a VP or C-level executive.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful life of the asset in years for depreciation calculation. Determined by asset class and regulatory/tax guidelines. Broadcast towers may be 20-30 years; technology platforms 3-7 years; studio facilities 15-40 years.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCurrency rdf:type rdf:Property ;
    rdfs:label 'Account Currency' ;
    rdfs:comment 'The primary currency in which this account is maintained, using ISO 4217 three-letter currency codes (e.g., \'USD\', \'EUR\', \'GBP\'). Determines the currency for postings and balance reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'SAP account group classification that controls field status, number range assignment, and screen layout for the account. Groups accounts with similar characteristics and processing rules (e.g., \'REVENUE\', \'COGS\', \'OPEX\', \'CAPEX\').' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNotes rdf:type rdf:Property ;
    rdfs:label 'Account Notes' ;
    rdfs:comment 'Free-text field for additional notes, usage guidelines, or special instructions related to this account. Used to document account-specific policies, restrictions, or business context.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountShortText rdf:type rdf:Property ;
    rdfs:label 'Account Short Text' ;
    rdfs:comment 'Abbreviated name or short description of the account used in reports and transaction displays where space is limited.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'An alternative or legacy account number used for mapping to previous chart of accounts structures, external reporting systems, or consolidation systems. Supports migration and integration scenarios.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'For balance sheet accounts, specifies whether the account is classified as current asset, non-current asset, current liability, non-current liability, or equity. Not applicable for P&L accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'The chart of accounts identifier to which this account belongs. Media Broadcasting may maintain multiple charts of accounts for different regions or business units (e.g., \'USGA\' for US GAAP, \'IFRS\' for international operations).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccount rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account' ;
    rdfs:comment 'The consolidation account code used for corporate consolidation and intercompany eliminations. Maps local entity accounts to group-level chart of accounts for consolidated financial reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterRequired rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required' ;
    rdfs:comment 'Indicates whether a cost center must be specified when posting to this account. True for expense accounts requiring cost center assignment; false for balance sheet and revenue accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Classification of the account as a cost element for controlling purposes: primary (direct posting from FI), secondary (internal allocations/assessments), revenue (revenue postings), or none (not a cost element). Links financial accounting to management accounting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Item' ;
    rdfs:comment 'The line item code on the financial statement (balance sheet or income statement) where this account\'s balance is reported. Used for financial statement generation and external reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'SAP functional area classification used for segment reporting and cost-of-sales accounting. Represents business functions such as \'Content Production\', \'Distribution\', \'Sales & Marketing\', \'Technology\', \'Corporate\'. Enables P&L reporting by business function per IFRS requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Account Number' ;
    rdfs:comment 'The unique account code used to identify this general ledger account across all financial postings. This is the authoritative account identifier used in SAP S/4HANA FI module for all financial transactions.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplayAllowed rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Allowed' ;
    rdfs:comment 'Indicates whether individual line items (transaction details) can be displayed for this account. True enables drill-down to transaction level; false shows only account balance. Typically true for balance sheet accounts, false for P&L accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialityThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Materiality Threshold Amount' ;
    rdfs:comment 'The monetary threshold above which transactions or balances in this account are considered material for audit and control purposes. Used to determine testing scope and control frequency for SOX compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Indicates whether this account uses open item management, tracking individual postings until they are cleared (e.g., for receivables, payables, clearing accounts). True enables clearing transactions; false for standard balance accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plStatementClassification rdf:type rdf:Property ;
    rdfs:label 'Pl Statement Classification' ;
    rdfs:comment 'For P&L accounts, specifies the detailed classification within the income statement (e.g., \'Operating Revenue\', \'Cost of Sales\', \'Operating Expenses\', \'Depreciation\', \'Interest Expense\', \'Tax Expense\'). Not applicable for balance sheet accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'The planning level or budget category assigned to this account for financial planning and budgeting purposes. Links the account to budget planning hierarchies and enables budget vs. actual reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingBlocked rdf:type rdf:Property ;
    rdfs:label 'Posting Blocked' ;
    rdfs:comment 'Indicates whether direct postings to this account are currently blocked. True prevents new transactions; false allows normal posting. Used to freeze accounts during period-end close or for inactive accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterRequired rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required' ;
    rdfs:comment 'Indicates whether a profit center must be specified when posting to this account. True for accounts requiring segment profitability tracking; false otherwise.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Type' ;
    rdfs:comment 'Identifies if this is a reconciliation account (subledger control account) and its type: customer (accounts receivable), vendor (accounts payable), asset (fixed assets), or none (standard GL account). Reconciliation accounts are automatically posted from subledgers.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlClassification rdf:type rdf:Property ;
    rdfs:label 'Sox Control Classification' ;
    rdfs:comment 'Classification of the account for SOX compliance purposes: key_control (critical accounts requiring enhanced controls and testing), supporting_control (accounts with standard controls), or not_in_scope (accounts outside SOX scope). Drives audit testing requirements.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerRequired rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Required' ;
    rdfs:comment 'Indicates whether a trading partner (intercompany entity) must be specified when posting to this account. True for intercompany accounts requiring elimination tracking; false for standard accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this account becomes active and available for posting. Supports time-dependent chart of accounts changes and new account activation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date until which this account remains active. After this date, the account is no longer available for posting. Null indicates the account is currently active with no planned end date.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costElementChartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Cost Element Chart Of Accounts Id' ;
    rdfs:comment 'Foreign key linking to finance.chart_of_accounts. Business justification: Cost elements in SAP CO are GL accounts from the chart of accounts. The cost_element STRING is a business key that should be supplemented with FK to chart_of_accounts.chart_of_accounts_id.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:originalAllocationCostAllocationId rdf:type rdf:Property ;
    rdfs:label 'Original Allocation Cost Allocation Id' ;
    rdfs:comment 'Foreign key reference to the original cost allocation record that this record reverses. Null if this is not a reversal transaction.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAllocation .

ind:primarySenderCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Sender Cost Center Id' ;
    rdfs:comment 'Foreign key reference to the cost center from which costs are being allocated (the source of the shared costs being distributed).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:receiverProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Receiver Profit Center Id' ;
    rdfs:comment 'Foreign key reference to the profit center receiving the allocated costs. Null if the receiver is a cost center instead of a profit center.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:allocationKey rdf:type rdf:Property ;
    rdfs:label 'Allocation Key' ;
    rdfs:comment 'The allocation key or driver used to determine the proportion of costs allocated to the receiver (e.g., headcount, square footage, revenue, FTE, transaction volume). Defines the basis for cost distribution.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationKeyValue rdf:type rdf:Property ;
    rdfs:label 'Allocation Key Value' ;
    rdfs:comment 'The numeric value of the allocation key used for this specific allocation (e.g., 15 FTEs, 2500 square feet, 1000000 transactions). Used to calculate the allocated amount.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'The percentage of total sender costs allocated to this receiver, expressed as a decimal (e.g., 15.75 for 15.75%). Derived from the allocation key value relative to total allocation base.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationRunDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Run Date' ;
    rdfs:comment 'The date on which the allocation cycle was executed and this allocation record was created. May differ from posting date if allocations are run in advance and posted later.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'The SAP controlling area within which this cost allocation is executed. Represents the organizational unit for cost accounting and internal reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElement rdf:type rdf:Property ;
    rdfs:label 'Cost Element' ;
    rdfs:comment 'The SAP CO cost element (account assignment) under which the allocated cost is recorded. Maps to the general ledger account in SAP FI.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaReportingSegment rdf:type rdf:Property ;
    rdfs:label 'Ebitda Reporting Segment' ;
    rdfs:comment 'The EBITDA reporting segment to which this allocation contributes. Used for segment-level EBITDA calculation and executive reporting in Media Broadcasting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Boolean flag indicating whether this allocation crosses company code boundaries and represents an intercompany charge (True) or is intra-company (False). Used for consolidation and elimination processing.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this allocation record is a reversal of a previous allocation (True) or an original allocation (False). Used for correction and adjustment tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the allocated amount (e.g., USD, EUR, GBP). Represents the currency in which the allocation was originally recorded.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Reference to the parent cost center in the organizational hierarchy, enabling hierarchical cost roll-ups and departmental P&L aggregation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'The primary activity type or service provided by this cost center for internal cost allocation purposes (e.g., Studio Hours, Editing Hours, Transmission Hours).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'The total annual budget allocated to this cost center for the current fiscal year, in the cost center\'s currency.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAllocationReference rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Reference' ;
    rdfs:comment 'Reference identifier to the annual or periodic budget allocation document for this cost center, used for budget vs. actual variance analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'The method used to allocate costs from this cost center to other cost objects (e.g., direct assignment, activity-based costing, percentage allocation, driver-based).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Classification of the cost center by cost behavior: direct costs attributable to specific content/programs, indirect costs supporting operations, overhead, or capital expenditure.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Detailed description of the cost center\'s purpose, scope, and responsibilities within the organization.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The full descriptive name of the cost center (e.g., \'Digital Platform Operations\', \'News Production Studio A\', \'Ad Sales Northeast Region\').' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center indicating whether it is operational and available for cost posting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by functional area within the media broadcasting business. [ENUM-REF-CANDIDATE: production|operations|sales|distribution|corporate|technology|content_acquisition — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group' ;
    rdfs:comment 'The primary cost element group or category that this cost center typically incurs (e.g., Personnel Costs, Production Costs, Technology Costs, Rights & Licensing).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'The department code within the organizational structure to which this cost center is assigned.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyNode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node' ;
    rdfs:comment 'The position of this cost center within the organizational cost center hierarchy, used for roll-up reporting and consolidation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRevenueGenerating rdf:type rdf:Property ;
    rdfs:label 'Is Revenue Generating' ;
    rdfs:comment 'Flag indicating whether this cost center directly generates revenue (e.g., Ad Sales regions) or is purely a cost-incurring unit.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depreciationRunId rdf:type rdf:Property ;
    rdfs:label 'Depreciation Run Id' ;
    rdfs:comment 'Unique identifier for the depreciation calculation and posting run. Primary key for the depreciation run record.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'Classification code grouping fixed assets by type (e.g., broadcast equipment, studio facilities, transmission towers, vehicles, IT infrastructure). Determines default depreciation methods, useful life, and general ledger account assignments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCount rdf:type rdf:Property ;
    rdfs:label 'Asset Count' ;
    rdfs:comment 'The total number of fixed asset records processed in this depreciation run for the specified company code, asset class, and depreciation area. Used for run completeness validation and audit trail.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'Two-digit code representing the depreciation area (e.g., 01 for book depreciation, 15 for tax depreciation, 20 for group consolidation). Allows parallel valuation of assets according to different accounting principles and legal requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorLogReference rdf:type rdf:Property ;
    rdfs:label 'Error Log Reference' ;
    rdfs:comment 'Reference identifier or file path to the detailed error log generated during the depreciation run. Used for troubleshooting and resolving posting errors before period-end close.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Depreciation Amount' ;
    rdfs:comment 'The total depreciation expense amount calculated by the system for the specified period, company code, and depreciation area based on asset master data and depreciation rules. Represents the expected value reduction before any adjustments or errors.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postedDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Posted Depreciation Amount' ;
    rdfs:comment 'The actual depreciation expense amount successfully posted to the general ledger for the period. May differ from planned amount due to posting errors, manual adjustments, or period-end corrections.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingPeriod rdf:type rdf:Property ;
    rdfs:label 'Posting Period' ;
    rdfs:comment 'The posting period within the fiscal year (typically 1-12 for monthly periods, or 1-16 including special periods) to which the depreciation amounts are posted. Aligns with the period-end close calendar.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repeatRunIndicator rdf:type rdf:Property ;
    rdfs:label 'Repeat Run Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this run is a repeat execution for a period that was previously processed. True indicates repeat run to correct prior errors; false indicates initial run for the period.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'The SAP financial document number of the reversal posting if this depreciation run was reversed. Null if no reversal has occurred. Links to the reversing document for audit trail.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Completed Timestamp' ;
    rdfs:comment 'The precise date and time when the depreciation run completed processing (successfully or with errors). Used to calculate run duration and monitor period-end close performance.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runDate rdf:type rdf:Property ;
    rdfs:label 'Run Date' ;
    rdfs:comment 'The calendar date on which the depreciation calculation and posting run was executed. Used for audit trail and reconciliation purposes.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runInitiatedByUser rdf:type rdf:Property ;
    rdfs:label 'Run Initiated By User' ;
    rdfs:comment 'The SAP user ID of the person or system account that initiated the depreciation run. Provides accountability and audit trail for period-end close activities and SOX compliance.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Timestamp' ;
    rdfs:comment 'The precise date and time when the depreciation run was initiated in the SAP FI-AA system. Provides granular audit trail for period-end close activities.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testRunIndicator rdf:type rdf:Property ;
    rdfs:label 'Test Run Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this was a test run executed to validate depreciation calculations without posting to the general ledger. True indicates test mode; false indicates production posting run.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The difference between planned depreciation amount and posted depreciation amount (posted minus planned). Positive variance indicates over-posting; negative variance indicates under-posting. Used for reconciliation and exception investigation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaSnapshotId rdf:type rdf:Property ;
    rdfs:label 'Ebitda Snapshot Id' ;
    rdfs:comment 'Unique identifier for the EBITDA snapshot record. Primary key for this period-locked financial management reporting record.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advertisingRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Advertising Revenue Amount' ;
    rdfs:comment 'Total revenue generated from advertising sales during the reporting period, including linear TV ads, digital ads, and DAI (Dynamic Ad Insertion).' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetEbitdaAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Ebitda Amount' ;
    rdfs:comment 'Budgeted EBITDA amount for this reporting period as approved in the annual planning cycle.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Amount' ;
    rdfs:comment 'Variance between actual EBITDA and budgeted EBITDA, calculated as actual minus budget.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Percentage' ;
    rdfs:comment 'Budget variance expressed as a percentage of budgeted EBITDA.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessSegment rdf:type rdf:Property ;
    rdfs:label 'Business Segment' ;
    rdfs:comment 'The business segment classification for this EBITDA snapshot, such as Linear Broadcasting, Streaming/OTT, Content Production, or Syndication.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Revenue Amount' ;
    rdfs:comment 'Revenue from carriage fees and retransmission consent agreements with MVPDs (Multichannel Video Programming Distributors) and vMVPDs during the reporting period.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentAcquisitionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Content Acquisition Cost Amount' ;
    rdfs:comment 'Direct costs for acquiring or licensing content during the reporting period, including rights payments and royalties.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:covenantComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Covenant Compliance Flag' ;
    rdfs:comment 'Indicates whether this EBITDA snapshot is used for debt covenant compliance reporting and monitoring.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Distribution Cost Amount' ;
    rdfs:comment 'Direct costs for content distribution and delivery, including CDN (Content Delivery Network) fees, playout, and transmission costs.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaAmount rdf:type rdf:Property ;
    rdfs:label 'Ebitda Amount' ;
    rdfs:comment 'EBITDA calculated as gross margin minus total operating expenses. This is the authoritative management reporting metric for operational profitability.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Ebitda Margin Percentage' ;
    rdfs:comment 'EBITDA expressed as a percentage of total revenue. Key profitability metric for board reporting and covenant compliance.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilitiesExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Facilities Expense Amount' ;
    rdfs:comment 'Operating expenses for facilities, rent, utilities, and physical infrastructure during the reporting period.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastEbitdaAmount rdf:type rdf:Property ;
    rdfs:label 'Forecast Ebitda Amount' ;
    rdfs:comment 'Latest forecast EBITDA amount for this reporting period, updated through rolling forecast processes.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Forecast Variance Amount' ;
    rdfs:comment 'Variance between actual EBITDA and forecast EBITDA, calculated as actual minus forecast.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Forecast Variance Percentage' ;
    rdfs:comment 'Forecast variance expressed as a percentage of forecast EBITDA.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Amount' ;
    rdfs:comment 'Gross margin calculated as total revenue minus total direct costs for the reporting period.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Percentage' ;
    rdfs:comment 'Gross margin expressed as a percentage of total revenue.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Marketing Expense Amount' ;
    rdfs:comment 'Operating expenses for marketing, advertising, and promotional activities during the reporting period.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDirectCostAmount rdf:type rdf:Property ;
    rdfs:label 'Other Direct Cost Amount' ;
    rdfs:comment 'Other direct costs not classified in the primary cost categories but directly attributable to revenue generation.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherOperatingExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Other Operating Expense Amount' ;
    rdfs:comment 'Other operating expenses not classified in the primary expense categories.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Other Revenue Amount' ;
    rdfs:comment 'Revenue from other sources not classified in the primary revenue streams, such as merchandise, events, or ancillary services.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodLockDate rdf:type rdf:Property ;
    rdfs:label 'Period Lock Date' ;
    rdfs:comment 'The date on which this EBITDA snapshot was locked and became the authoritative management reporting record.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:personnelExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Personnel Expense Amount' ;
    rdfs:comment 'Operating expenses for personnel costs including salaries, benefits, and talent residuals during the reporting period.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preparedByUser rdf:type rdf:Property ;
    rdfs:label 'Prepared By User' ;
    rdfs:comment 'User ID or name of the financial analyst who prepared this EBITDA snapshot.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodEbitdaAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Period Ebitda Amount' ;
    rdfs:comment 'EBITDA amount from the comparable prior period (prior year same period) for variance analysis.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Period Variance Amount' ;
    rdfs:comment 'Variance between current period EBITDA and prior period EBITDA, calculated as current minus prior.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Prior Period Variance Percentage' ;
    rdfs:comment 'Prior period variance expressed as a percentage of prior period EBITDA.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Production Cost Amount' ;
    rdfs:comment 'Direct costs for content production and post-production activities during the reporting period.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotNumber rdf:type rdf:Property ;
    rdfs:label 'Snapshot Number' ;
    rdfs:comment 'Business identifier for this EBITDA snapshot, typically following a sequential or period-based numbering scheme for management reporting.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapshotStatus rdf:type rdf:Property ;
    rdfs:label 'Snapshot Status' ;
    rdfs:comment 'Current status of this EBITDA snapshot in the period-close workflow. Once locked, the snapshot becomes the authoritative record for board reporting and covenant compliance.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Subscription Revenue Amount' ;
    rdfs:comment 'Total revenue from subscription services during the reporting period, including SVOD (Subscription Video On Demand) and membership fees.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:syndicationRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Syndication Revenue Amount' ;
    rdfs:comment 'Revenue from content syndication and licensing to third-party broadcasters and platforms during the reporting period.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Technology Expense Amount' ;
    rdfs:comment 'Operating expenses for technology infrastructure, software licenses, and IT services during the reporting period.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDirectCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Direct Cost Amount' ;
    rdfs:comment 'Total direct costs for the reporting period. Sum of content acquisition, production, distribution, and other direct costs.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOperatingExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Total Operating Expense Amount' ;
    rdfs:comment 'Total operating expenses for the reporting period. Sum of personnel, marketing, technology, facilities, and other operating expenses.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Amount' ;
    rdfs:comment 'Total revenue across all streams for the reporting period. Sum of advertising, subscription, carriage fees, syndication, and other revenue.' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Financial Reconciliation Id' ;
    rdfs:comment 'Unique identifier for the financial reconciliation record. Primary key for the financial reconciliation entity.' ;
    rdfs:domain ind:FinancialReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFinancialReconcilerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Financial Reconciler Employee Id' ;
    rdfs:comment 'Employee identifier of the person who performed the reconciliation, used for audit trail and accountability purposes.' ;
    rdfs:domain ind:FinancialReconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Document Number' ;
    rdfs:comment 'The SAP FI document number of the journal entry posted to resolve the reconciliation variance, providing traceability to corrective actions.' ;
    rdfs:domain ind:FinancialReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Required Flag' ;
    rdfs:comment 'Boolean indicator specifying whether a journal entry adjustment is required to resolve the identified variance.' ;
    rdfs:domain ind:FinancialReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Gl Balance Amount' ;
    rdfs:comment 'The balance amount recorded in the general ledger for the specified GL account as of the reconciliation date.' ;
    rdfs:domain ind:FinancialReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconcilerName rdf:type rdf:Property ;
    rdfs:label 'Reconciler Name' ;
    rdfs:comment 'Full name of the finance team member who performed the reconciliation activity.' ;
    rdfs:domain ind:FinancialReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationNotes rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Notes' ;
    rdfs:comment 'Additional free-text notes and comments related to the reconciliation activity, including special circumstances, follow-up actions, or audit observations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Full name of the finance manager or supervisor who reviewed and validated the reconciliation results.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sign Off Timestamp' ;
    rdfs:comment 'The precise date and time when the reconciliation was formally signed off, providing audit trail for SOX compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subledgerBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Subledger Balance Amount' ;
    rdfs:comment 'The balance amount recorded in the subledger system (AR, AP, fixed assets, or revenue system) as of the reconciliation date, to be compared against the GL balance.' ;
    rdfs:domain ind:FinancialReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Unique identifier for the fixed asset record. Primary key.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'The total depreciation expense recognized to date since acquisition. Used to calculate net book value.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'The original purchase price or capitalized cost of the asset at the time of acquisition, excluding accumulated depreciation. Represents the gross book value.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed textual description of the fixed asset including make, model, specifications, and location details. Provides human-readable context for the asset.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLocation rdf:type rdf:Property ;
    rdfs:label 'Asset Location' ;
    rdfs:comment 'Physical location or site where the asset is installed or deployed (e.g., transmission tower site, studio facility, data center). Used for asset tracking and maintenance planning.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNotes rdf:type rdf:Property ;
    rdfs:label 'Asset Notes' ;
    rdfs:comment 'Free-text field for additional notes, comments, or special instructions related to the asset. Used for operational context and exception documentation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'The externally-known unique asset number assigned by SAP FI-AA for tracking and identification purposes. This is the business identifier used across financial reporting and asset management processes.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset indicating whether it is in active use, under construction, disposed, retired, or impaired.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Sub Number' ;
    rdfs:comment 'Sub-asset number used when a main asset is divided into multiple components for separate depreciation tracking (e.g., building structure vs. HVAC system).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSuperNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Super Number' ;
    rdfs:comment 'Parent asset number when this asset is part of a larger asset hierarchy (e.g., individual broadcast equipment within a transmission tower complex).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'The date on which the asset was placed in service and capitalization began. May differ from acquisition date for assets under construction.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'The date on which the asset was disposed, sold, or retired from service. Null for active assets.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'The method by which the asset was disposed (e.g., sale, scrap, donation, trade-in, transfer to another entity, write-off). Null for active assets.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'The amount received from the sale or disposal of the asset. Used to calculate gain or loss on disposal. Null for active assets.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gainLossOnDisposal rdf:type rdf:Property ;
    rdfs:label 'Gain Loss On Disposal' ;
    rdfs:comment 'The financial gain or loss recognized upon disposal, calculated as disposal proceeds minus net book value at disposal. Null for active assets.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'The insurance policy number covering this asset. Used for risk management and claims processing.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'The current carrying value of the asset on the balance sheet, calculated as acquisition cost minus accumulated depreciation. Represents the asset\'s current financial value.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Remaining Useful Life Years' ;
    rdfs:comment 'The number of years remaining in the asset\'s useful life as of the current reporting period. Used for forward-looking depreciation planning.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer\'s serial number or unique equipment identifier for the physical asset. Used for warranty tracking and maintenance records.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'The date on which the manufacturer\'s warranty for this asset expires. Used for maintenance planning and cost forecasting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generalLedgerId rdf:type rdf:Property ;
    rdfs:label 'General Ledger Id' ;
    rdfs:comment 'Unique identifier for the general ledger record. Primary key for the general ledger data product.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAmountFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Amount Functional Currency' ;
    rdfs:comment 'Budgeted amount allocated to the general ledger account for the fiscal period, expressed in functional currency. Used for budget vs. actual variance analysis and financial planning. Particularly relevant for production budgets, content acquisition costs, and operational expense management.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingBalanceFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Closing Balance Functional Currency' ;
    rdfs:comment 'Closing balance of the general ledger account at the end of the fiscal period, expressed in functional currency. Calculated as opening balance plus net period activity. Represents the ending position for trial balance and financial statement generation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consolidationUnit rdf:type rdf:Property ;
    rdfs:label 'Consolidation Unit' ;
    rdfs:comment 'Consolidation unit code representing the entity for group consolidation and statutory reporting. Used for multi-entity financial consolidation, intercompany eliminations, and corporate-level financial statement preparation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmountFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Amount Functional Currency' ;
    rdfs:comment 'Total credit amount posted to the general ledger account for the period, expressed in the functional currency of the company code. Represents increases to liability, equity, and revenue accounts or decreases to asset and expense accounts.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditAmountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Amount Transaction Currency' ;
    rdfs:comment 'Total credit amount posted to the general ledger account for the period, expressed in the original transaction currency. Maintained for audit trail and foreign exchange reconciliation purposes.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmountFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Debit Amount Functional Currency' ;
    rdfs:comment 'Total debit amount posted to the general ledger account for the period, expressed in the functional currency of the company code. Represents increases to asset and expense accounts or decreases to liability, equity, and revenue accounts.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Debit Amount Transaction Currency' ;
    rdfs:comment 'Total debit amount posted to the general ledger account for the period, expressed in the original transaction currency. Maintained for audit trail and foreign exchange reconciliation purposes.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaIndicator rdf:type rdf:Property ;
    rdfs:label 'Ebitda Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the general ledger account is included in EBITDA calculation for management reporting and investor disclosures. True if the account contributes to EBITDA (operating revenues and expenses), false if excluded (interest, taxes, depreciation, amortization).' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the functional currency of the company code (e.g., USD, GBP, EUR). The functional currency is the primary currency in which the legal entity conducts business and prepares financial statements.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPostingDate rdf:type rdf:Property ;
    rdfs:label 'Last Posting Date' ;
    rdfs:comment 'Date of the most recent transaction posted to this general ledger account within the fiscal period. Used for audit trail and period-end reconciliation validation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'Ledger group code representing the accounting principle or reporting standard (e.g., 0L for leading ledger, 2L for IFRS, 3L for US GAAP). Enables parallel accounting for multiple reporting frameworks within a single system.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBalanceFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Net Balance Functional Currency' ;
    rdfs:comment 'Net balance of the general ledger account for the period, calculated as debit amount minus credit amount (or vice versa depending on account type), expressed in the functional currency. Represents the aggregated account state for trial balance and financial statement generation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingBalanceFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Opening Balance Functional Currency' ;
    rdfs:comment 'Opening balance of the general ledger account at the beginning of the fiscal period, expressed in functional currency. Represents the carried-forward balance from the previous period for balance sheet accounts.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodLockStatus rdf:type rdf:Property ;
    rdfs:label 'Period Lock Status' ;
    rdfs:comment 'Status of the posting period indicating whether the period is open for new postings, closed for regular postings but open for adjustments, or locked for all postings. Used for period-end close control and financial statement finalization.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit numeric code that controls the posting behavior and determines whether the entry is a debit or credit (e.g., 40 for debit, 50 for credit). Used for transaction validation and account determination logic.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the general ledger account is a reconciliation account (subledger control account) that must reconcile with subsidiary ledgers such as accounts receivable, accounts payable, or fixed assets. True if reconciliation account, false otherwise.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueStreamCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Stream Category' ;
    rdfs:comment 'Classification of revenue accounts by primary revenue stream type for Media Broadcasting business. Categories include advertising (linear and digital ad sales), subscription (SVOD/AVOD), carriage fees (MVPD/vMVPD distribution), syndication (content resale), licensing (rights monetization), transactional (TVOD), and other. Used for revenue assurance and segment reporting. [ENUM-REF-CANDIDATE: advertising|subscription|carriage_fees|syndication|licensing|transactional|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Segment code for external segment reporting as required by IFRS 8 and US GAAP. Represents reportable business segments for statutory financial reporting and investor disclosures (e.g., content production, advertising, subscription services).' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Sox Control Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the general ledger account is subject to Sarbanes-Oxley Act internal control requirements and audit procedures. True if SOX-controlled account requiring enhanced documentation and approval workflows, false otherwise.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradingPartner rdf:type rdf:Property ;
    rdfs:label 'Trading Partner' ;
    rdfs:comment 'Trading partner code identifying the intercompany counterparty for intercompany transactions. Used for intercompany eliminations and consolidated financial statement preparation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmountFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Variance Amount Functional Currency' ;
    rdfs:comment 'Variance between actual net balance and budgeted amount for the fiscal period, expressed in functional currency. Calculated as actual minus budget. Positive variance indicates over-budget for expense accounts or under-budget for revenue accounts.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique identifier for the intercompany transaction record within the Media Broadcasting corporate group.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sendingCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Sending Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Intercompany transactions can be allocated to sending cost center. The sending_cost_center STRING column will be replaced by FK to cost_center.cost_center_id.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:sendingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Sending Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Intercompany transactions have a sending legal entity. The sending_company_code is a business key reference to legal_entity. FK enables proper intercompany elimination and netting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this intercompany transaction requires elimination entries during consolidated financial statement preparation at group level.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Elimination Status' ;
    rdfs:comment 'Current status of the consolidation elimination process for this intercompany transaction in the group financial consolidation system.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'The type of exchange rate used for currency conversion (e.g., spot rate, monthly average rate, budget rate, or fixed contractual rate).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrency rdf:type rdf:Property ;
    rdfs:label 'Group Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code representing the corporate group reporting currency (typically USD for Media Broadcasting).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'The transaction amount converted to the corporate group reporting currency for consolidated financial statement preparation.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyTransactionDescription rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Description' ;
    rdfs:comment 'Free-text description providing additional business context for the intercompany transaction, such as the specific content title licensed, service provided, or purpose of the charge.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingStatus rdf:type rdf:Property ;
    rdfs:label 'Netting Status' ;
    rdfs:comment 'Indicates whether the intercompany transaction is subject to bilateral netting arrangements to reduce cash settlement volumes between legal entities.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'The SAP company code of the legal entity receiving or being charged for the intercompany transaction (the entity consuming the service, content, or financing).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCostCenter rdf:type rdf:Property ;
    rdfs:label 'Receiving Cost Center' ;
    rdfs:comment 'The cost center within the receiving company code that is being charged for the intercompany transaction, enabling detailed cost allocation and budget tracking.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationPeriod rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period' ;
    rdfs:comment 'The fiscal period (YYYY-MM format) in which this intercompany transaction is subject to monthly intercompany reconciliation procedures.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number linking this intercompany transaction to source documents such as content licensing agreements, service invoices, or loan agreements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code' ;
    rdfs:comment 'The SAP company code of the legal entity originating or charging the intercompany transaction (the entity providing the service, content, or financing).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current status of cash settlement for the intercompany transaction, tracking whether payment has been made between the legal entities.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The monetary value of the intercompany transaction in the transaction currency, representing the gross charge before any adjustments or netting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the intercompany transaction was originally denominated (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Business-facing unique identifier for the intercompany transaction, typically following the format IC-XXXXXXXXXX for tracking and reconciliation purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the intercompany transaction indicating its position in the approval, posting, and reconciliation workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|posted|reconciled|disputed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the intercompany transaction indicating the nature of the charge or transfer between legal entities (e.g., content licensing charges between production subsidiaries and broadcast networks, shared service allocations, management fees, technology recharges, intercompany loans, royalty payments).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date for interest calculation and cash flow purposes, particularly relevant for intercompany loans and financing arrangements.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique identifier for the journal entry record. Primary key for the journal entry entity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:approverUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver User Employee Id' ;
    rdfs:comment 'The SAP user ID of the individual who approved this journal entry for posting, as required by SOX internal control procedures. Null if no approval was required or entry is still pending approval.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryJournalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Employee Id' ;
    rdfs:comment 'The SAP user ID of the individual who posted this journal entry into the system. Used for audit trail and accountability purposes.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:recurringEntryTemplateId rdf:type rdf:Property ;
    rdfs:label 'Recurring Entry Template Id' ;
    rdfs:comment 'The identifier of the recurring entry template from which this journal entry was generated. Populated only when recurring_entry_indicator is True.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecurringEntryTemplate .

ind:sourceDocumentId rdf:type rdf:Property ;
    rdfs:label 'Source Document Id' ;
    rdfs:comment 'The unique identifier of the source document in the originating system that generated this journal entry. Used for traceability and reconciliation back to operational systems.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourceDocument .

ind:accrualReversalDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Reversal Date' ;
    rdfs:comment 'The future posting date on which this accrual entry will automatically reverse. Populated only when accrual_reversal_indicator is True.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualReversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Accrual Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is an automatic accrual reversal. True if this entry will automatically reverse in the subsequent period.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the journal entry by its accounting purpose: standard operational posting, period-end accrual, prepayment amortization, account reclassification, intercompany elimination, or error correction.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchInputSession rdf:type rdf:Property ;
    rdfs:label 'Batch Input Session' ;
    rdfs:comment 'The name of the batch input session if this journal entry was posted via batch processing rather than manual entry. Empty for manually posted entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentHeaderText rdf:type rdf:Property ;
    rdfs:label 'Document Header Text' ;
    rdfs:comment 'Descriptive text at the document header level providing context or explanation for the journal entry, such as the business purpose, transaction description, or special instructions.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The calendar date when the journal entry was physically entered into the SAP system by the user, which may differ from both document date and posting date.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryTime rdf:type rdf:Property ;
    rdfs:label 'Entry Time' ;
    rdfs:comment 'The precise date and time when the journal entry was created in the SAP system. Provides audit trail for record creation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry represents an intercompany transaction between different legal entities within Media Broadcasting. True for intercompany entries requiring elimination in consolidated reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the local currency of the company code. Used for parallel accounting and statutory reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkedIndicator rdf:type rdf:Property ;
    rdfs:label 'Parked Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is in parked status (saved but not yet posted). True if parked, False if fully posted.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurringEntryIndicator rdf:type rdf:Property ;
    rdfs:label 'Recurring Entry Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is part of a recurring entry template (e.g., monthly depreciation, rent accruals). True if generated from a recurring template.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Two-digit code indicating the business reason for reversing the original document (e.g., 01=Error Correction, 02=Accrual Reversal, 03=Period-End Adjustment). Populated only when reversal_indicator is True.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the original journal entry that this entry reverses. Populated only when reversal_indicator is True.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'The company code of the intercompany trading partner for intercompany transactions. Populated only when intercompany_indicator is True. Used for intercompany reconciliation and consolidation eliminations.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Code' ;
    rdfs:comment 'The SAP transaction code (T-Code) used to post this journal entry (e.g., FB01, FB50, F-02). Indicates the posting interface and provides context for the entry method.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Status' ;
    rdfs:comment 'Current status of the journal entry within the SOX-compliant approval workflow. Tracks the document through draft, approval, posting, and potential reversal stages.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Primary key for legal_entity' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:parentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Legal Entity Id' ;
    rdfs:comment 'Reference to the parent legal entity in the corporate hierarchy. Used to establish organizational structure and consolidation relationships. Null for the ultimate parent entity.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'Primary accounting standard or framework used for financial reporting by this legal entity. Determines recognition, measurement, and disclosure requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'The date on which the legal entity became active and began conducting business operations. Used for financial reporting period determination.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:broadcastLicenseHolderFlag rdf:type rdf:Property ;
    rdfs:label 'Broadcast License Holder Flag' ;
    rdfs:comment 'Indicates whether this legal entity holds one or more broadcast licenses issued by the FCC or equivalent regulatory authority. True if the entity is a licensed broadcaster.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Four-character code identifying the chart of accounts assigned to this legal entity in SAP S/4HANA. Defines the structure of general ledger accounts used for financial postings.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'Identifier for the consolidation group or reporting unit to which this legal entity belongs. Used for corporate consolidation, intercompany eliminations, and segment reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Country Of Incorporation' ;
    rdfs:comment 'Three-letter ISO country code representing the country where the legal entity is incorporated and registered. Determines primary legal jurisdiction and regulatory framework.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'Four-character code identifying the credit control area assigned to this legal entity in SAP S/4HANA. Used for credit management and accounts receivable monitoring.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'The date on which the legal entity ceased active operations or was dissolved. Null for active entities. Used to determine the end of financial reporting obligations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ebitdaReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Ebitda Reporting Flag' ;
    rdfs:comment 'Indicates whether this legal entity is included in corporate EBITDA calculations and segment performance reporting. True if the entity contributes to consolidated EBITDA metrics.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'Current operational status of the legal entity. Active indicates the entity is conducting business; inactive indicates temporary suspension; dormant indicates no current operations but entity remains registered; liquidation indicates entity is being wound down; dissolved indicates entity has been formally closed.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the legal entity based on its primary business function within the Media Broadcasting corporate structure. Determines the operational model and reporting requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Two-character code defining the fiscal year structure for this legal entity, including the number of periods, period start and end dates, and year-end closing rules. Used for period-based financial reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Functional Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the primary currency in which the entity conducts its business and maintains its books of account. Used for financial statement preparation and consolidation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the legal entity was officially incorporated or registered with the governing authority.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyEliminationGroup rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Group' ;
    rdfs:comment 'Code identifying the group of entities for which intercompany transactions must be eliminated during consolidation. Used to ensure accurate consolidated financial statements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Full legal name of the entity as registered with the governing authority. This is the official name used in all legal documents, contracts, regulatory filings, and financial statements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalForm rdf:type rdf:Property ;
    rdfs:label 'Legal Form' ;
    rdfs:comment 'The legal structure or incorporation type of the entity (e.g., Corporation, Limited Liability Company, Partnership, Public Limited Company). Determines liability, taxation, and regulatory obligations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of equity ownership held by the parent entity. Used for consolidation calculations and minority interest determination. Range: 0.00 to 100.00.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the official registered address of the legal entity as filed with the incorporation authority. Used for legal correspondence and regulatory filings.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Second line of the official registered address (suite, floor, building name). Optional field for additional address details.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'City or municipality of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountry rdf:type rdf:Property ;
    rdfs:label 'Registered Country' ;
    rdfs:comment 'Three-letter ISO country code for the registered address. Typically matches the country of incorporation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredStateProvince rdf:type rdf:Property ;
    rdfs:label 'Registered State Province' ;
    rdfs:comment 'State, province, or region of the registered address. Uses standard postal abbreviations where applicable.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official registration or incorporation number assigned by the government authority in the country of incorporation. Used for legal identification and regulatory compliance.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingObligations rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Obligations' ;
    rdfs:comment 'Comma-separated list of regulatory reporting frameworks and obligations applicable to this legal entity (e.g., SEC 10-K, FCC Form 323, Ofcom Annual Return). Determines mandatory filings and disclosure requirements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the currency used for external financial reporting and consolidation at the corporate level.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or trade name of the legal entity used for internal reporting and operational purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Scope Flag' ;
    rdfs:comment 'Indicates whether this legal entity is within the scope of SOX compliance and internal control testing. True if the entity is material to consolidated financial statements and subject to SOX Section 404 requirements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Primary tax identification number assigned by the tax authority in the country of incorporation. Used for all tax filings, withholding, and revenue reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'VAT or GST registration number for entities operating in jurisdictions requiring VAT registration. Used for VAT reporting and cross-border transactions.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodCloseId rdf:type rdf:Property ;
    rdfs:label 'Period Close Id' ;
    rdfs:comment 'Unique identifier for the financial period close record. Primary key for the period close entity.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'The actual date when the period close was completed and the period was locked for further postings. Null if close is not yet completed.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeChecklistCompletionPct rdf:type rdf:Property ;
    rdfs:label 'Close Checklist Completion Pct' ;
    rdfs:comment 'Percentage of period-end close checklist tasks that have been completed. Ranges from 0.00 to 100.00. Provides visibility into close progress.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closeCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Completed Timestamp' ;
    rdfs:comment 'Date and time when the period close process was completed and the period was locked. Null if close is not yet completed.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closeInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Initiated Timestamp' ;
    rdfs:comment 'Date and time when the period close process was formally initiated in the system.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closeNotes rdf:type rdf:Property ;
    rdfs:label 'Close Notes' ;
    rdfs:comment 'Free-text field for documenting significant events, issues, or observations during the period close process. Provides context for future reference and audit trail.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closePhase rdf:type rdf:Property ;
    rdfs:label 'Close Phase' ;
    rdfs:comment 'Current phase of the period-end close process. Pre-close for preliminary activities, soft close for initial close with limited posting allowed, hard close for final close with restricted access, final close for locked period after SOX sign-off.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeStatus rdf:type rdf:Property ;
    rdfs:label 'Close Status' ;
    rdfs:comment 'Current status of the period close execution. Tracks the lifecycle state from initiation through completion or failure.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationStatus rdf:type rdf:Property ;
    rdfs:label 'Consolidation Status' ;
    rdfs:comment 'Status of financial consolidation processing for this company code and period. Tracks whether the legal entity data has been successfully consolidated into group reporting.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllerEmail rdf:type rdf:Property ;
    rdfs:label 'Controller Email' ;
    rdfs:comment 'Email address of the responsible controller for communication and notification purposes during the close process.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditRequired rdf:type rdf:Property ;
    rdfs:label 'External Audit Required' ;
    rdfs:comment 'Indicates whether this period close requires external auditor review and sign-off. Typically true for quarterly and annual closes for publicly traded entities.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalAuditStatus rdf:type rdf:Property ;
    rdfs:label 'External Audit Status' ;
    rdfs:comment 'Status of external auditor review for this period close. Tracks the progress of third-party audit activities.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyEliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Status' ;
    rdfs:comment 'Status of intercompany transaction elimination processing for consolidated financial reporting. Indicates whether intercompany balances have been identified and eliminated.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReopenDate rdf:type rdf:Property ;
    rdfs:label 'Last Reopen Date' ;
    rdfs:comment 'Date when the period was most recently reopened for adjustments. Null if the period has never been reopened.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openItemsCount rdf:type rdf:Property ;
    rdfs:label 'Open Items Count' ;
    rdfs:comment 'Number of open line items (uncleared documents) remaining in the general ledger at the time of close execution. Indicates outstanding reconciliation work.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodLockTimestamp rdf:type rdf:Property ;
    rdfs:label 'Period Lock Timestamp' ;
    rdfs:comment 'Date and time when the posting period was locked in the system. Null if the period is not yet locked.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the accounting period being closed. Monthly for standard month-end close, quarterly for quarter-end, annual for year-end, special for adjustment periods.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriodLocked rdf:type rdf:Property ;
    rdfs:label 'Posting Period Locked' ;
    rdfs:comment 'Indicates whether the posting period has been locked to prevent further transactions. True when the period is closed and locked, false when still open for postings.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reopenCount rdf:type rdf:Property ;
    rdfs:label 'Reopen Count' ;
    rdfs:comment 'Number of times this period has been reopened after initial close. Tracks the frequency of post-close adjustments and indicates close process quality.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reopenReason rdf:type rdf:Property ;
    rdfs:label 'Reopen Reason' ;
    rdfs:comment 'Business justification for the most recent period reopen. Documents the reason for post-close adjustments for audit trail purposes.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleController rdf:type rdf:Property ;
    rdfs:label 'Responsible Controller' ;
    rdfs:comment 'Name or identifier of the financial controller responsible for executing and certifying the period close for this company code and period.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAssuranceStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Assurance Status' ;
    rdfs:comment 'Status of revenue assurance validation for this period. Indicates whether all revenue streams (advertising, subscription, carriage fees, syndication) have been reconciled and verified.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCloseDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Close Date' ;
    rdfs:comment 'The planned target date for completing the period close process. Established based on the financial calendar and reporting deadlines.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxControlStatus rdf:type rdf:Property ;
    rdfs:label 'Sox Control Status' ;
    rdfs:comment 'Status of SOX internal control testing and certification for this period close. Required for publicly traded companies to ensure financial reporting compliance.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxSignoffBy rdf:type rdf:Property ;
    rdfs:label 'Sox Signoff By' ;
    rdfs:comment 'Name or identifier of the individual who provided the SOX control sign-off for this period close.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxSignoffDate rdf:type rdf:Property ;
    rdfs:label 'Sox Signoff Date' ;
    rdfs:comment 'Date when the SOX control certification was completed and signed off by the responsible controller or compliance officer. Null if not yet signed off.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unreconciledAmount rdf:type rdf:Property ;
    rdfs:label 'Unreconciled Amount' ;
    rdfs:comment 'Total monetary value of unreconciled items in the company code currency. Represents the financial exposure from incomplete reconciliations.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unreconciledItemsCount rdf:type rdf:Property ;
    rdfs:label 'Unreconciled Items Count' ;
    rdfs:comment 'Number of accounts or subledger items that have not been reconciled to the general ledger at the time of close. Critical metric for close quality.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceToForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Variance To Forecast Amount' ;
    rdfs:comment 'Monetary variance between actual period results and forecasted amounts in company code currency. Positive indicates favorable variance, negative indicates unfavorable.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aboveTheLineAmount rdf:type rdf:Property ;
    rdfs:label 'Above The Line Amount' ;
    rdfs:comment 'Budget allocated to above-the-line costs including key creative talent (writers, directors, producers, lead actors). These are typically negotiated individually and represent significant budget items.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSpendToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Spend To Date' ;
    rdfs:comment 'Cumulative actual expenditure against this budget as of the last financial update. Used for variance tracking and budget performance monitoring.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:belowTheLineAmount rdf:type rdf:Property ;
    rdfs:label 'Below The Line Amount' ;
    rdfs:comment 'Budget allocated to below-the-line costs including crew, equipment, facilities, and production support. These are standard production costs not tied to key creative talent.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Budget Effective Date' ;
    rdfs:comment 'The date from which this budget version becomes effective and spending authorization begins.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Budget Expiry Date' ;
    rdfs:comment 'The date on which this budget version expires or is superseded by a new version. Null for open-ended budgets.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetNotes rdf:type rdf:Property ;
    rdfs:label 'Budget Notes' ;
    rdfs:comment 'Free-text notes and comments regarding this budget version, including justification for revisions, special conditions, or approval stipulations.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Externally-known unique identifier for the production budget, used for tracking and reference in financial systems and production workflows.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the production budget. Tracks progression from draft through approval to active spending and final closure. [ENUM-REF-CANDIDATE: draft|submitted|approved|active|revised|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the production budget by content type. Different content types have different cost structures and budget approval workflows. [ENUM-REF-CANDIDATE: scripted_series|film|live_event|news_programming|digital_original|documentary|sports|reality|animation — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Version number of the budget. Budgets are revised throughout the production lifecycle; this field tracks the iteration (e.g., 1 for initial, 2 for first revision).' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Amount committed through purchase orders and contracts but not yet invoiced or paid. Used for funds reservation and budget availability calculation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Amount' ;
    rdfs:comment 'Contingency reserve allocated for unforeseen production costs and budget overruns. Typically 5-10% of total budget.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilitiesAmount rdf:type rdf:Property ;
    rdfs:label 'Facilities Amount' ;
    rdfs:comment 'Budget allocated to production facilities including studio rental, location fees, set construction, and production office space.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'SAP CO internal order number used for production cost control and tracking actual expenditures against this budget.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicLicensingAmount rdf:type rdf:Property ;
    rdfs:label 'Music Licensing Amount' ;
    rdfs:comment 'Budget allocated to music licensing, original score composition, and music rights clearance for the production.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postProductionAmount rdf:type rdf:Property ;
    rdfs:label 'Post Production Amount' ;
    rdfs:comment 'Budget allocated to post-production activities including editing, color correction, sound design, mixing, and final mastering.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionEndDate rdf:type rdf:Property ;
    rdfs:label 'Production End Date' ;
    rdfs:comment 'Planned or actual end date of production for this project. Used for budget closure and final cost reconciliation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionStartDate rdf:type rdf:Property ;
    rdfs:label 'Production Start Date' ;
    rdfs:comment 'Planned or actual start date of production for this project. Used for budget phasing and cash flow planning.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vfxAmount rdf:type rdf:Property ;
    rdfs:label 'Vfx Amount' ;
    rdfs:comment 'Budget allocated to visual effects production. VFX is often a significant cost category for scripted series, films, and high-production-value content.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager Employee Id' ;
    rdfs:comment 'The unique employee identifier of the manager responsible for this profit center. Links to HR master data for organizational reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Method' ;
    rdfs:comment 'The methodology used for allocating budgets to this profit center. Top-down allocates from corporate targets; bottom-up aggregates from operational plans; zero-based requires justification of all expenses; incremental adjusts prior year budgets.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'The controlling area to which this profit center is assigned. Controlling area is the organizational unit in SAP CO that represents a closed system for cost accounting purposes.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterAssignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Center Assignment Flag' ;
    rdfs:comment 'Indicates whether cost centers can be directly assigned to this profit center for cost allocation and internal charging purposes.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyEliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Flag' ;
    rdfs:comment 'Indicates whether transactions involving this profit center require intercompany elimination adjustments during financial consolidation. Used in multi-entity corporate structures.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Code' ;
    rdfs:comment 'The code of the parent profit center in the organizational hierarchy, if this profit center rolls up to another. Enables hierarchical consolidation for segment EBITDA and management reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'The externally-known unique alphanumeric code identifying the profit center within the controlling area. Used in SAP CO for segment reporting and management accounting. Examples: SVOD-US, LINEAR-UK, ADSALES-NA.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Detailed textual description of the profit centers business purpose, scope of operations, and strategic role within the enterprise. Used for documentation and onboarding.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'The full business name of the profit center. Human-readable label used in financial reports and management dashboards.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center. Active profit centers are operational and accept postings; inactive are temporarily suspended; planned are future entities; closed are historical and no longer accept transactions.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center based on its accountability model. Revenue centers are responsible for revenue generation; cost centers for cost control; investment centers for return on invested capital; service centers provide internal services.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenuePostingFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Posting Flag' ;
    rdfs:comment 'Indicates whether revenue transactions can be posted directly to this profit center. Used to control which profit centers participate in revenue recognition workflows.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxControlScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Scope Flag' ;
    rdfs:comment 'Indicates whether this profit center is within the scope of SOX financial controls and requires enhanced audit trails and segregation of duties for financial postings.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'The method used for pricing internal transactions between this profit center and other organizational units. Examples: cost-plus, market-based, negotiated. Critical for accurate profit center performance measurement.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalRecognitionEventRevenueRecognitionEventId rdf:type rdf:Property ;
    rdfs:label 'Original Recognition Event Revenue Recognition Event Id' ;
    rdfs:comment 'Reference to the original revenue recognition event ID if this record represents a reversal or adjustment. Enables full audit trail of revenue corrections.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognitionEvent .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Reference to the originating sales order (from Wide Orbit for ad sales, or Salesforce Media Cloud for direct sales) that triggered this revenue recognition event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdSalesOrder .

ind:accountingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Accounting Document Number' ;
    rdfs:comment 'The SAP S/4HANA accounting document number (FI document) that records this revenue recognition event. Provides full audit trail and drill-back capability to source transactions.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asc606CompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Asc 606 Compliant Flag' ;
    rdfs:comment 'Boolean indicator (True/False) confirming that this revenue recognition event was processed in accordance with ASC 606 (US GAAP) revenue recognition standards.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractModificationFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Modification Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this revenue recognition event resulted from a contract modification. ASC 606 requires specific accounting treatment for modified contracts.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deferredAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Amount' ;
    rdfs:comment 'The monetary amount of revenue deferred (not yet recognized) as of this event. Represents unearned revenue that will be recognized in future periods as performance obligations are satisfied.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ifrs15CompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs 15 Compliant Flag' ;
    rdfs:comment 'Boolean indicator (True/False) confirming that this revenue recognition event was processed in accordance with IFRS 15 (International Financial Reporting Standards) revenue recognition standards.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The accounting date on which this revenue was recognized in the general ledger. This is the principal business event timestamp for financial reporting and period-end close.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Amount' ;
    rdfs:comment 'The monetary amount of revenue recognized in this event and posted to the general ledger. Represents the earned portion of the transaction price allocated to the performance obligation.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audienceMeasurementSource rdf:type rdf:Property ;
    rdfs:label 'Audience Measurement Source' ;
    rdfs:comment 'Primary audience measurement provider used for revenue validation and guarantees (e.g., Nielsen, Comscore, Adobe Analytics). Critical for advertising revenue streams with audience guarantees.' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percent' ;
    rdfs:comment 'Standard commission rate percentage paid to sales representatives or agencies for revenue generated through this stream.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDeferred rdf:type rdf:Property ;
    rdfs:label 'Is Deferred' ;
    rdfs:comment 'Indicates whether revenue from this stream is initially recorded as deferred revenue and recognized over time (True for advance payments, subscriptions; False for immediate recognition).' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this revenue stream generates recurring revenue (True for subscriptions, carriage fees; False for one-time transactions, spot advertising).' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:makegoodsPolicy rdf:type rdf:Property ;
    rdfs:label 'Makegoods Policy' ;
    rdfs:comment 'Policy for providing makegoods (compensatory ad spots) when delivery guarantees are not met: automatic, negotiated, none, audience-based, or technical failure only.' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceObligation rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation' ;
    rdfs:comment 'Description of the performance obligation that must be satisfied for revenue recognition per ASC 606 / IFRS 15 (e.g., delivery of ad impressions, provision of streaming access, content licensing rights transfer).' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSegment rdf:type rdf:Property ;
    rdfs:label 'Reporting Segment' ;
    rdfs:comment 'Corporate reporting segment for external financial reporting (e.g., Linear Broadcasting, Streaming Services, Content Licensing). Used for segment disclosure per ASC 280 / IFRS 8.' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueStreamStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Stream Status' ;
    rdfs:comment 'Current lifecycle status of the revenue stream: active (currently generating revenue), inactive (not in use), suspended (temporarily halted), pending approval (awaiting finance approval), or deprecated (phased out).' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSubcategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Subcategory' ;
    rdfs:comment 'Detailed sub-classification within the revenue category (e.g., Upfront, Scatter, Programmatic for advertising; SVOD, AVOD, TVOD for subscription; Linear Carriage, OTT Carriage for carriage fees).' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamCode rdf:type rdf:Property ;
    rdfs:label 'Stream Code' ;
    rdfs:comment 'Business identifier code for the revenue stream (e.g., ADV-UPFRONT, SVOD-PREM, CARRIAGE-FEE). Used across financial systems and reporting.' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamName rdf:type rdf:Property ;
    rdfs:label 'Stream Name' ;
    rdfs:comment 'Full descriptive name of the revenue stream (e.g., Upfront Advertising Sales, Premium SVOD Subscription, Syndication License Fees).' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'Primary tax jurisdiction for this revenue stream using ISO 3166-1 alpha-2 or alpha-3 country codes (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatment rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment' ;
    rdfs:comment 'Tax treatment classification for this revenue stream: taxable (subject to VAT/GST/sales tax), exempt, zero-rated, or out of scope.' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPostingId rdf:type rdf:Property ;
    rdfs:label 'Tax Posting Id' ;
    rdfs:comment 'Unique identifier for the tax posting record in SAP FI. Primary key for the tax posting entity.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Free-text field for documenting special circumstances, adjustments, or explanations related to the tax posting. Used for audit defense and tax authority inquiries.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Reference number of the payment transaction that cleared this tax liability. Links the tax posting to the actual remittance to the tax authority.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle status of the tax posting. Posted indicates active posting; Parked indicates pending approval; Cleared indicates settled with tax authority; Reversed indicates cancelled by reversal entry; Cancelled indicates voided before posting.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Document Number' ;
    rdfs:comment 'Ten-digit SAP document number uniquely identifying the tax posting document within the company code and fiscal year. Used for audit trail and tax return reconciliation.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingCountry rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Country' ;
    rdfs:comment 'Three-letter ISO 3166 country code identifying the country where the tax return will be filed. May differ from company code country for cross-border transactions.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReturnPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Return Period' ;
    rdfs:comment 'The reporting period (quarterly or monthly) to which this tax posting applies for tax return filing. Format: YYYY-Q# for quarterly or YYYY-M## for monthly (e.g., 2024-Q1, 2024-M03).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Base Amount' ;
    rdfs:comment 'The gross amount subject to taxation before tax calculation. Represents the revenue, payment, or transaction value on which the tax is computed.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:archiveRecordId rdf:type rdf:Property ;
    rdfs:label 'Archive Record Id' ;
    rdfs:comment 'Primary key for archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:custodianPartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Custodian Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Archives may be held at partner facilities (Iron Mountain, AWS Glacier, offsite vaults). Tracks custodian partner for retrieval requests, audit compliance, disaster recovery planning, and vendor perfo' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:archiveCostPerGb rdf:type rdf:Property ;
    rdfs:label 'Archive Cost Per Gb' ;
    rdfs:comment 'The cost per gigabyte for storing the asset in the archive destination, used for financial planning and cost allocation.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:archiveDestinationIdentifier rdf:type rdf:Property ;
    rdfs:label 'Archive Destination Identifier' ;
    rdfs:comment 'Specific identifier for the archive destination such as LTO (Linear Tape-Open) tape barcode, cloud vault identifier, or off-site facility location code.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveDestinationType rdf:type rdf:Property ;
    rdfs:label 'Archive Destination Type' ;
    rdfs:comment 'The type of long-term storage destination where the asset was archived.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Archive File Size Bytes' ;
    rdfs:comment 'The size of the archived media file in bytes, used for storage capacity planning and billing.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:archiveFormat rdf:type rdf:Property ;
    rdfs:label 'Archive Format' ;
    rdfs:comment 'The file format or container format of the archived asset (e.g., MXF, MOV, MP4, ProRes, DNxHD) as stored in the archive.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveJobReference rdf:type rdf:Property ;
    rdfs:label 'Archive Job Reference' ;
    rdfs:comment 'Unique reference number assigned to the archival job or batch process that created this archive record.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveNotes rdf:type rdf:Property ;
    rdfs:label 'Archive Notes' ;
    rdfs:comment 'Free-text notes or comments about the archival process, special handling instructions, or any issues encountered during archival.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveStatus rdf:type rdf:Property ;
    rdfs:label 'Archive Status' ;
    rdfs:comment 'Current lifecycle status of the archived asset indicating its availability and operational state. [ENUM-REF-CANDIDATE: archived|restore_requested|restore_in_progress|restored|purge_pending|purged|failed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveSystemName rdf:type rdf:Property ;
    rdfs:label 'Archive System Name' ;
    rdfs:comment 'Name of the archival system or MAM module that performed the archival operation (e.g., Dalet Galaxy Archive, Spectra Logic).' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archive Timestamp' ;
    rdfs:comment 'Precise timestamp when the archival process completed and the asset was committed to long-term storage.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checksumAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Checksum Algorithm' ;
    rdfs:comment 'The cryptographic hash algorithm used to generate the checksum for verifying asset integrity during archival and restore operations.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumValue rdf:type rdf:Property ;
    rdfs:label 'Checksum Value' ;
    rdfs:comment 'The computed checksum hash value of the archived media asset, used to verify data integrity and detect corruption.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cloudVaultIdentifier rdf:type rdf:Property ;
    rdfs:label 'Cloud Vault Identifier' ;
    rdfs:comment 'Unique identifier for the cloud deep-archive vault or bucket where the asset is stored (e.g., AWS Glacier vault ARN, Azure Archive Storage container).' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionCodec rdf:type rdf:Property ;
    rdfs:label 'Compression Codec' ;
    rdfs:comment 'The compression codec applied to the media asset for archival storage (e.g., H.264, H.265, JPEG2000, uncompressed).' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicates whether the archived asset is under legal hold, preventing deletion or modification regardless of retention policy.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ltoTapeGeneration rdf:type rdf:Property ;
    rdfs:label 'Lto Tape Generation' ;
    rdfs:comment 'The LTO tape generation standard used for archival (e.g., LTO-8, LTO-9) if the destination is tape-based storage.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oaisComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Oais Compliance Flag' ;
    rdfs:comment 'Indicates whether this archive record complies with ISO 14721 OAIS reference model standards for long-term digital preservation.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offsiteFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Offsite Facility Code' ;
    rdfs:comment 'Code identifying the physical off-site archival facility or vault location where the media is stored.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purgeApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Purge Approval Status' ;
    rdfs:comment 'Approval status for purging the archived asset, ensuring compliance with retention and legal hold requirements before deletion.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purgeScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Purge Scheduled Date' ;
    rdfs:comment 'The scheduled date for purging or permanently deleting the archived asset, based on retention policy expiration.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Restore Completion Date' ;
    rdfs:comment 'The date when the restore operation was completed and the asset was made available for use.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreRequestDate rdf:type rdf:Property ;
    rdfs:label 'Restore Request Date' ;
    rdfs:comment 'The date when a restore request was submitted for this archived asset, if applicable.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreSlaTier rdf:type rdf:Property ;
    rdfs:label 'Restore Sla Tier' ;
    rdfs:comment 'The service level tier defining the expected restore time for retrieving this archived asset (e.g., expedited within hours, standard within days, bulk within weeks).' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restoreTestDate rdf:type rdf:Property ;
    rdfs:label 'Restore Test Date' ;
    rdfs:comment 'The date when the last restore test was performed to verify the integrity and retrievability of the archived asset.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreTestResult rdf:type rdf:Property ;
    rdfs:label 'Restore Test Result' ;
    rdfs:comment 'Outcome of the most recent restore test indicating whether the asset was successfully retrieved and validated.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Code' ;
    rdfs:comment 'Code identifying the retention policy applied to this archived asset, governing how long it must be preserved and under what conditions it may be purged.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTier rdf:type rdf:Property ;
    rdfs:label 'Storage Tier' ;
    rdfs:comment 'The storage tier classification indicating access frequency and cost structure (hot for frequent access, deep archive for infrequent access).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeBarcode rdf:type rdf:Property ;
    rdfs:label 'Tape Barcode' ;
    rdfs:comment 'Physical barcode identifier on the LTO tape cartridge used for archival, enabling physical inventory tracking.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetAccessRequestId rdf:type rdf:Property ;
    rdfs:label 'Asset Access Request Id' ;
    rdfs:comment 'Unique identifier for the asset access request. Primary key.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAssetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Asset Employee Id' ;
    rdfs:comment 'Identifier of the individual or system user who submitted the access request. Supports chain-of-custody tracking and accountability.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessDurationHours rdf:type rdf:Property ;
    rdfs:label 'Access Duration Hours' ;
    rdfs:comment 'Number of hours for which access is granted, calculated from access_granted_timestamp to access_expiry_timestamp. Used for policy enforcement and reporting.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Access Expiry Timestamp' ;
    rdfs:comment 'Date and time when the granted access expires and the URI or checkout lock is automatically revoked. Enforces time-bound access for security and rights compliance.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accessGrantedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Access Granted Timestamp' ;
    rdfs:comment 'Date and time when access was actually granted and the URI or download became available to the requestor. May differ from approval_timestamp if provisioning delay exists.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accessGrantedUri rdf:type rdf:Property ;
    rdfs:label 'Access Granted Uri' ;
    rdfs:comment 'Secure URL or file path provided to the requestor for accessing the approved asset. Generated upon approval and may include time-limited token or DRM protection.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessPurpose rdf:type rdf:Property ;
    rdfs:label 'Access Purpose' ;
    rdfs:comment 'Business reason for requesting access to the asset. Determines approval workflow and usage restrictions applied. [ENUM-REF-CANDIDATE: editing|review|distribution|legal|compliance|research|archival|rights_clearance|promotional|internal_use — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessType rdf:type rdf:Property ;
    rdfs:label 'Access Type' ;
    rdfs:comment 'Type of access being requested: stream (view-only online), download (local copy), checkout (exclusive edit lock), preview (low-res proxy), or metadata-only (descriptive information without media file).' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Free-text comments or justification provided by the approver explaining the approval or rejection decision. Supports audit trail and dispute resolution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether the request requires explicit approval (true) or is auto-approved based on policy rules (false). Determined by asset sensitivity, rights restrictions, and requestor role.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkoutLockActive rdf:type rdf:Property ;
    rdfs:label 'Checkout Lock Active' ;
    rdfs:comment 'Indicates whether an exclusive checkout lock is currently active on the asset (true) or not (false). Prevents concurrent editing and ensures version control integrity.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceClassification rdf:type rdf:Property ;
    rdfs:label 'Compliance Classification' ;
    rdfs:comment 'Data classification level of the asset being accessed, determining approval workflow rigor and access logging requirements.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadCount rdf:type rdf:Property ;
    rdfs:label 'Download Count' ;
    rdfs:comment 'Number of times the asset was downloaded by the requestor under this access grant. Supports usage tracking and compliance auditing.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drmApplied rdf:type rdf:Property ;
    rdfs:label 'Drm Applied' ;
    rdfs:comment 'Indicates whether DRM protection was applied to the accessed asset (true) or not (false). Supports rights protection and anti-piracy compliance.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAccessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Accessed Timestamp' ;
    rdfs:comment 'Date and time when the requestor last accessed (streamed or downloaded) the asset under this grant. Supports usage monitoring and inactive access cleanup.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestSource rdf:type rdf:Property ;
    rdfs:label 'Request Source' ;
    rdfs:comment 'System or interface through which the access request was submitted. Supports usage analytics and integration monitoring.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Date and time when the access request was submitted. Recorded in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX) for audit trail and SLA tracking.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestorDepartment rdf:type rdf:Property ;
    rdfs:label 'Requestor Department' ;
    rdfs:comment 'Business unit or department of the requestor (e.g., News, Sports, Production, Legal, Compliance, Marketing). Used for access policy enforcement and usage analytics.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Rights Clearance Required' ;
    rdfs:comment 'Indicates whether the requested access purpose requires explicit rights clearance verification (true) or not (false). Applies to distribution, promotional, and external use cases.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:streamCount rdf:type rdf:Property ;
    rdfs:label 'Stream Count' ;
    rdfs:comment 'Number of times the asset was streamed by the requestor under this access grant. Supports usage tracking and analytics.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageRestrictions rdf:type rdf:Property ;
    rdfs:label 'Usage Restrictions' ;
    rdfs:comment 'Free-text description of any usage restrictions or conditions applied to the granted access (e.g., internal use only, no redistribution, watermarked, editorial use only). Enforces rights and compliance requirements.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watermarkApplied rdf:type rdf:Property ;
    rdfs:label 'Watermark Applied' ;
    rdfs:comment 'Indicates whether a forensic or visible watermark was applied to the accessed asset (true) or not (false). Supports leak tracing and chain-of-custody enforcement.' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetCollectionId rdf:type rdf:Property ;
    rdfs:label 'Asset Collection Id' ;
    rdfs:comment 'Unique identifier for the asset collection. Primary key.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetCollection .

ind:retentionPolicyId rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.retention_policy. Business justification: Normalization: asset_collection has retention_policy_code STRING which should be FK to retention_policy catalog. This connects asset_collection to the relational graph and allows retrieving full polic' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionPolicy .

ind:archiveTier rdf:type rdf:Property ;
    rdfs:label 'Archive Tier' ;
    rdfs:comment 'Storage tier classification for the collection: hot (frequent access), warm (occasional access), cold (rare access), glacier (long-term preservation), or deep-archive (regulatory retention).' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCollectionDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Collection Description' ;
    rdfs:comment 'Detailed narrative description of the collection\'s content, purpose, and editorial context. Used for cataloging and discovery.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCollectionStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Collection Status' ;
    rdfs:comment 'Current lifecycle status of the collection: draft (being assembled), active (available for use), archived (preserved but not active), deprecated (superseded), under-review (pending approval), or locked (no modifications allowed).' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkOperationEnabled rdf:type rdf:Property ;
    rdfs:label 'Bulk Operation Enabled' ;
    rdfs:comment 'Indicates whether bulk operations (bulk QC, bulk rights check, bulk archive, bulk transcode) are enabled for this collection (true) or must be performed individually (false).' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionCode rdf:type rdf:Property ;
    rdfs:label 'Collection Code' ;
    rdfs:comment 'Business identifier or code for the collection, used for external reference and cataloging (e.g., \'GOT-S08-PKG\', \'NEWS-ELEC24-001\').' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionName rdf:type rdf:Property ;
    rdfs:label 'Collection Name' ;
    rdfs:comment 'Human-readable name of the asset collection (e.g., \'Breaking News Package - Election 2024\', \'Game of Thrones Season 8 Bundle\', \'Super Bowl LVIII Highlights\').' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionType rdf:type rdf:Property ;
    rdfs:label 'Collection Type' ;
    rdfs:comment 'Classification of the collection by content grouping purpose: series (episodic television), film-franchise (related films), news-package (story bundle), sports-event (game/match clips), music-album (music tracks), campaign-creative (advertising assets), documentary-series, special-event, archive-bundle, or promo-package. [ENUM-REF-CANDIDATE: series|film-franchise|news-package|sports-event|music-album|campaign-creative|documentary-series|special-event|archive-bundle|promo-package — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curatorName rdf:type rdf:Property ;
    rdfs:label 'Curator Name' ;
    rdfs:comment 'Name of the individual or team responsible for curating and maintaining the collection.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Distribution Window End' ;
    rdfs:comment 'End date of the distribution window after which the collection may no longer be distributed or broadcast. Part of windowing strategy.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionWindowStart rdf:type rdf:Property ;
    rdfs:label 'Distribution Window Start' ;
    rdfs:comment 'Start date of the distribution window during which the collection may be distributed or broadcast. Part of windowing strategy.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:metadataCompletenessScore rdf:type rdf:Property ;
    rdfs:label 'Metadata Completeness Score' ;
    rdfs:comment 'Percentage score (0.00 to 100.00) indicating the completeness of metadata across all assets in the collection. Used for quality assurance and discoverability.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingFormat rdf:type rdf:Property ;
    rdfs:label 'Packaging Format' ;
    rdfs:comment 'Technical packaging format used for distribution (e.g., \'IMF\', \'DPP\', \'AS-11\', \'ProRes Package\', \'MPEG-DASH Manifest\'). Relevant for distribution deals.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryGenre rdf:type rdf:Property ;
    rdfs:label 'Primary Genre' ;
    rdfs:comment 'Primary content genre or category for the collection (e.g., \'Drama\', \'News\', \'Sports\', \'Documentary\', \'Comedy\', \'Music\', \'Reality\').' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Syndication Eligible Flag' ;
    rdfs:comment 'Indicates whether the collection is eligible for syndication (resale to multiple outlets) based on rights and content suitability (true) or not (false).' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalAssetCount rdf:type rdf:Property ;
    rdfs:label 'Total Asset Count' ;
    rdfs:comment 'Total number of media assets currently included in the collection.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Duration Seconds' ;
    rdfs:comment 'Cumulative playback duration of all time-based assets in the collection, measured in seconds.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStorageSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Total Storage Size Bytes' ;
    rdfs:comment 'Total storage footprint of all assets in the collection, measured in bytes. Used for capacity planning and archival costing.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when the collection was first created in the MAM (Media Asset Management) system.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Asset Lifecycle Event Id' ;
    rdfs:comment 'Unique identifier for the asset lifecycle event record. Primary key. Inferred role: EVENT_LOG. This entity represents an immutable audit log of state transitions for media assets, capturing the complete chain-of-custody trail required for regulatory, legal, and rights compliance in media asset management systems.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalHoldId rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Id' ;
    rdfs:comment 'Reference identifier for the legal case or matter that triggered a legal hold event. Applicable for legal_hold_applied and legal_hold_released events. Used to track preservation obligations for litigation, regulatory investigation, or compliance requirements.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalHold .

ind:techChangeRequestId rdf:type rdf:Property ;
    rdfs:label 'Tech Change Request Id' ;
    rdfs:comment 'Identifier for the Dalet Galaxy workflow instance that triggered or processed this lifecycle event. Used to trace events back to specific automated workflow executions for troubleshooting and audit purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechChangeRequest .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'The name or identifier of the person or role that provided approval for this lifecycle event, applicable for approval, publish, and legal_hold_released events. Used for accountability and compliance documentation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumAfter rdf:type rdf:Property ;
    rdfs:label 'Checksum After' ;
    rdfs:comment 'The cryptographic checksum (MD5, SHA-256, or other hash) of the media file after this event. Used to verify file integrity and detect unauthorized modifications. Critical for chain-of-custody audit trail.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumBefore rdf:type rdf:Property ;
    rdfs:label 'Checksum Before' ;
    rdfs:comment 'The cryptographic checksum (MD5, SHA-256, or other hash) of the media file before this event. Used to verify file integrity and detect unauthorized modifications. Critical for chain-of-custody audit trail.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'The playback duration of the media asset in seconds at the time of this lifecycle event. Used to verify content integrity after format migrations and to track asset characteristics over time.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDurationMilliseconds rdf:type rdf:Property ;
    rdfs:label 'Event Duration Milliseconds' ;
    rdfs:comment 'The elapsed time in milliseconds that this lifecycle event took to complete. Used for performance monitoring, SLA (Service Level Agreement) tracking, and workflow optimization. Applicable for transcode, migration, and ingest events.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventReason rdf:type rdf:Property ;
    rdfs:label 'Event Reason' ;
    rdfs:comment 'Free-text explanation or justification for why this lifecycle event occurred. May include business context, regulatory requirement, editorial decision rationale, or technical reason. Critical for audit trail and compliance documentation.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataVersion rdf:type rdf:Property ;
    rdfs:label 'Metadata Version' ;
    rdfs:comment 'Version number of the assets descriptive metadata at the time of this lifecycle event. Incremented with each metadata_update event. Used to track metadata evolution and support rollback scenarios.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newState rdf:type rdf:Property ;
    rdfs:label 'New State' ;
    rdfs:comment 'The lifecycle state of the media asset immediately after this event occurred. Captures the to state in the state transition. Uses the same value set as previous_state. This is the EVENT_PAYLOAD_OR_VALUE required for EVENT_LOG role. [ENUM-REF-CANDIDATE: raw|ingested|qc_pending|qc_approved|qc_rejected|approved|published|archived|on_legal_hold|migrated|purged|active|inactive — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorIdentity rdf:type rdf:Property ;
    rdfs:label 'Operator Identity' ;
    rdfs:comment 'The identity of the human operator or automated system that triggered or executed this lifecycle event. May be a user ID, system account name, or automated workflow identifier. Used for accountability and audit trail purposes.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorType rdf:type rdf:Property ;
    rdfs:label 'Operator Type' ;
    rdfs:comment 'Classification of the entity that initiated the lifecycle event. Values: human (manual user action), automated_workflow (Dalet Galaxy workflow automation), scheduled_job (time-based system task), api_integration (external system integration), system_process (internal MAM process).' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousState rdf:type rdf:Property ;
    rdfs:label 'Previous State' ;
    rdfs:comment 'The lifecycle state of the media asset immediately before this event occurred. Captures the from state in the state transition. Values include: raw (unprocessed footage), ingested (imported into MAM), qc_pending (awaiting quality control), qc_approved (passed quality control), qc_rejected (failed quality control), approved (editorially approved), published (available for distribution), archived (moved to long-term storage), on_legal_hold (preservation hold active), migrated (format converted), purged (deleted), active (in use), inactive (not in use). [ENUM-REF-CANDIDATE: raw|ingested|qc_pending|qc_approved|qc_rejected|approved|published|archived|on_legal_hold|migrated|purged|active|inactive — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcDefectCount rdf:type rdf:Property ;
    rdfs:label 'Qc Defect Count' ;
    rdfs:comment 'Number of quality defects identified during quality control inspection, applicable for qc_fail events. Defects may include video artifacts, audio issues, metadata errors, or format compliance violations.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcScore rdf:type rdf:Property ;
    rdfs:label 'Qc Score' ;
    rdfs:comment 'Numeric quality control score assigned during qc_pass or qc_fail events. Scale typically 0-100, representing technical quality assessment of video, audio, and metadata completeness. Used to track asset quality metrics over time.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceStorageTier rdf:type rdf:Property ;
    rdfs:label 'Source Storage Tier' ;
    rdfs:comment 'The storage tier where the asset resided before this event, applicable for storage_tier_migration events. Values: hot (high-performance online storage), warm (standard online storage), cold (infrequent access storage), archive (long-term preservation), glacier (deep archive), nearline (tape-based near-online), offline (physical media storage). [ENUM-REF-CANDIDATE: hot|warm|cold|archive|glacier|nearline|offline — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFormat rdf:type rdf:Property ;
    rdfs:label 'Target Format' ;
    rdfs:comment 'The media file format or codec of the asset after this event, applicable for format_migration and transcode events. Examples: MPEG-4, ProRes, H.264, H.265, MXF, MOV, AVI. Follows ISO 14496 MPEG-4 and related video format standards.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStorageTier rdf:type rdf:Property ;
    rdfs:label 'Target Storage Tier' ;
    rdfs:comment 'The storage tier where the asset was moved to during this event, applicable for storage_tier_migration events. Uses the same value set as source_storage_tier. [ENUM-REF-CANDIDATE: hot|warm|cold|archive|glacier|nearline|offline — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStorageAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Asset Storage Assignment Id' ;
    rdfs:comment 'Unique identifier for the asset storage assignment record. Primary key for tracking storage placement history.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Reference to the physical or logical storage location where the asset file resides. Links to storage infrastructure registry.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:accessFrequency rdf:type rdf:Property ;
    rdfs:label 'Access Frequency' ;
    rdfs:comment 'Number of times this file has been accessed since assignment to this storage location. Used to inform tiering and migration decisions.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'Date when the asset file was migrated, purged, or removed from this storage location. Null if still active at this location.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment End Timestamp' ;
    rdfs:comment 'Precise timestamp when the asset file was migrated, purged, or removed from this storage location. Null if still active.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'Date when the asset file was placed at this storage location. Marks the beginning of the storage assignment period.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the asset file was placed at this storage location. Provides exact time for chain-of-custody audit trails.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of this storage assignment. Indicates whether the file is actively stored, has been moved, or has been deleted.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Complete file system path or URI where the asset file is physically stored. Enables restore path resolution and file retrieval.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Access Timestamp' ;
    rdfs:comment 'Timestamp of the most recent access to this file at this storage location. Used for tiering policy enforcement and usage analytics.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:migrationTrigger rdf:type rdf:Property ;
    rdfs:label 'Migration Trigger' ;
    rdfs:comment 'Reason why the asset was moved to or from this storage location. Captures business or technical driver for storage placement decisions.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replicationCount rdf:type rdf:Property ;
    rdfs:label 'Replication Count' ;
    rdfs:comment 'Number of redundant copies of this file maintained at this storage location. Used for disaster recovery and high availability planning.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageCostPerGb rdf:type rdf:Property ;
    rdfs:label 'Storage Cost Per Gb' ;
    rdfs:comment 'Cost per gigabyte for this storage tier at the time of assignment. Used for storage cost allocation and financial reporting.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryPartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Delivery Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Specific versions may be delivered by different partners (e.g., international dub from foreign partner, localized version from regional distributor). Tracks provenance for quality issues, delivery acc' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:transcodeJobId rdf:type rdf:Property ;
    rdfs:label 'Transcode Job Id' ;
    rdfs:comment 'Reference to the transcode or encoding job that created this version. Links to workflow orchestration system (Dalet Galaxy) for lineage tracking and troubleshooting.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TranscodeJob .

ind:abrLadderRung rdf:type rdf:Property ;
    rdfs:label 'Abr Ladder Rung' ;
    rdfs:comment 'Position in the ABR ladder for HLS or DASH streaming (e.g., 1 for lowest quality, 5 for highest). Enables adaptive streaming based on viewer bandwidth. Null if not part of an ABR ladder.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioChannels rdf:type rdf:Property ;
    rdfs:label 'Audio Channels' ;
    rdfs:comment 'Number of audio channels in this version (e.g., 2 for stereo, 6 for 5.1 surround, 8 for 7.1 surround). Determines audio format and playback capability requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmProtection rdf:type rdf:Property ;
    rdfs:label 'Drm Protection' ;
    rdfs:comment 'Indicates whether this version is protected by DRM encryption (True/False). DRM systems include Widevine, PlayReady, FairPlay. Supports content security and anti-piracy.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proxyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Proxy Expiry Date' ;
    rdfs:comment 'Date when this proxy or preview version expires and should be purged from storage. Applicable only when rendition_purpose is proxy or preview. Supports storage cost optimization and compliance with retention policies.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renditionPurpose rdf:type rdf:Property ;
    rdfs:label 'Rendition Purpose' ;
    rdfs:comment 'Business purpose or use case for this version: playout (broadcast transmission), distribution (delivery to platforms), archive (long-term preservation), preview (review/approval), proxy (low-res editing), watermark (forensic tracking), mezzanine (high-quality master), localized_dub (language variant), thumbnail (visual reference). [ENUM-REF-CANDIDATE: playout|distribution|archive|preview|proxy|watermark|mezzanine|localized_dub|thumbnail — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionHeight rdf:type rdf:Property ;
    rdfs:label 'Resolution Height' ;
    rdfs:comment 'Vertical resolution of the video frame in pixels (e.g., 1080 for 1080p, 2160 for 4K). Used for format classification and quality assessment.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionWidth rdf:type rdf:Property ;
    rdfs:label 'Resolution Width' ;
    rdfs:comment 'Horizontal resolution of the video frame in pixels (e.g., 1920 for 1080p, 3840 for 4K). Used for format classification and quality assessment.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageUri rdf:type rdf:Property ;
    rdfs:label 'Storage Uri' ;
    rdfs:comment 'Full storage path or URI where this version is physically stored (e.g., s3://bucket/path, file://nas/volume/path, https://cdn.example.com/asset). Supports multi-tier storage (hot/warm/cold/archive) and CDN distribution via Akamai.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleTracks rdf:type rdf:Property ;
    rdfs:label 'Subtitle Tracks' ;
    rdfs:comment 'Comma-separated list of ISO 639-2 language codes for embedded subtitle or closed caption tracks (e.g., eng,spa,fra). Supports accessibility compliance (COPPA, FCC) and multi-language distribution.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watermarkPayload rdf:type rdf:Property ;
    rdfs:label 'Watermark Payload' ;
    rdfs:comment 'Forensic watermark identifier or payload embedded in this version for anti-piracy tracking and content protection. Applicable only when rendition_purpose is watermark. Supports DRM (Digital Rights Management) and content security.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatMigrationId rdf:type rdf:Property ;
    rdfs:label 'Format Migration Id' ;
    rdfs:comment 'Unique identifier for the format migration operation. Primary key.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Source Asset Version Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_version. Business justification: Format migration converts a specific source version to a target version. This FK identifies the source version being migrated. Distinct from the existing media_asset_id FK which identifies the asset c' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:sourceFormatSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Source Format Specification Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.format_specification. Business justification: Normalization: source format details should be retrieved from format_specification catalog via JOIN. Removes redundant format attributes. The source_format STRING becomes a FK to the authoritative for' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormatSpecification .

ind:migrationDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Migration Duration Seconds' ;
    rdfs:comment 'Total elapsed time for the migration operation in seconds. Used for performance monitoring and capacity planning.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:migrationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Migration End Timestamp' ;
    rdfs:comment 'Date and time when the format migration job completed or terminated. Used to calculate migration duration and throughput.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:migrationEngine rdf:type rdf:Property ;
    rdfs:label 'Migration Engine' ;
    rdfs:comment 'Name and version of the transcoding or migration software used to perform the format conversion (e.g., FFmpeg 5.1, Telestream Vantage 8.2, AWS MediaConvert).' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationJobNumber rdf:type rdf:Property ;
    rdfs:label 'Migration Job Number' ;
    rdfs:comment 'Business identifier for the migration job. Externally-known unique code used for tracking and reporting.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationNotes rdf:type rdf:Property ;
    rdfs:label 'Migration Notes' ;
    rdfs:comment 'Free-text notes and comments about the migration operation. Captures operator observations, special handling instructions, or business context.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationPriority rdf:type rdf:Property ;
    rdfs:label 'Migration Priority' ;
    rdfs:comment 'Business priority assigned to the migration job. Determines queue position and resource allocation.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationReason rdf:type rdf:Property ;
    rdfs:label 'Migration Reason' ;
    rdfs:comment 'Business justification for the format migration operation. Indicates why the asset required conversion.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Migration Start Timestamp' ;
    rdfs:comment 'Date and time when the format migration job began processing. Principal business event timestamp for the migration operation.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:migrationStatus rdf:type rdf:Property ;
    rdfs:label 'Migration Status' ;
    rdfs:comment 'Current state of the migration job in its workflow lifecycle.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationType rdf:type rdf:Property ;
    rdfs:label 'Migration Type' ;
    rdfs:comment 'Technical classification of the migration operation performed on the asset.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'Full name of the operator who initiated the migration job. Denormalized for reporting and audit purposes.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityValidationNotes rdf:type rdf:Property ;
    rdfs:label 'Quality Validation Notes' ;
    rdfs:comment 'Detailed findings from quality validation process. Includes warnings, errors, or observations about the migrated asset quality.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityValidationResult rdf:type rdf:Property ;
    rdfs:label 'Quality Validation Result' ;
    rdfs:comment 'Outcome of automated quality assurance checks performed on the migrated asset. Indicates whether the migration met technical quality standards.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityValidationScore rdf:type rdf:Property ;
    rdfs:label 'Quality Validation Score' ;
    rdfs:comment 'Numeric quality score (0-100) assigned by automated validation tools. Measures technical fidelity of the migrated asset against the source.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceChecksum rdf:type rdf:Property ;
    rdfs:label 'Source Checksum' ;
    rdfs:comment 'Cryptographic hash (MD5, SHA-256, or SHA-512) of the source file before migration. Ensures file integrity and supports chain-of-custody verification.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTierSource rdf:type rdf:Property ;
    rdfs:label 'Storage Tier Source' ;
    rdfs:comment 'Storage tier classification of the source asset before migration. Indicates retrieval latency and cost profile.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTierTarget rdf:type rdf:Property ;
    rdfs:label 'Storage Tier Target' ;
    rdfs:comment 'Storage tier classification of the migrated asset after conversion. Indicates where the new asset will be stored.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Target Bitrate Kbps' ;
    rdfs:comment 'Average bitrate of the migrated media file in kilobits per second. Indicates encoding quality and bandwidth requirements after migration.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetChecksum rdf:type rdf:Property ;
    rdfs:label 'Target Checksum' ;
    rdfs:comment 'Cryptographic hash (MD5, SHA-256, or SHA-512) of the migrated file after conversion. Validates successful migration and file integrity.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCodec rdf:type rdf:Property ;
    rdfs:label 'Target Codec' ;
    rdfs:comment 'Video and audio codec specifications of the migrated asset (e.g., H.264 + AAC, H.265/HEVC + Dolby AC-3).' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Target File Size Bytes' ;
    rdfs:comment 'Size of the migrated media file in bytes after conversion. Used to measure storage optimisation achieved.' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetResolution rdf:type rdf:Property ;
    rdfs:label 'Target Resolution' ;
    rdfs:comment 'Pixel dimensions of the migrated video (e.g., 1920x1080, 3840x2160, 7680x4320).' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioBitDepth rdf:type rdf:Property ;
    rdfs:label 'Audio Bit Depth' ;
    rdfs:comment 'Audio bit depth in bits per sample (e.g., 16-bit for standard, 24-bit for professional, 32-bit float for mastering).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioChannelConfiguration rdf:type rdf:Property ;
    rdfs:label 'Audio Channel Configuration' ;
    rdfs:comment 'Audio channel layout and count (e.g., stereo 2.0, surround 5.1, immersive 7.1.4 Dolby Atmos, mono 1.0).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioSampleRateKhz rdf:type rdf:Property ;
    rdfs:label 'Audio Sample Rate Khz' ;
    rdfs:comment 'Audio sampling frequency in kilohertz (e.g., 48.000 kHz for broadcast, 44.100 kHz for CD quality, 96.000 kHz for high-resolution).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bitRateMbps rdf:type rdf:Property ;
    rdfs:label 'Bit Rate Mbps' ;
    rdfs:comment 'Target video bit rate in megabits per second (Mbps) for encoding, determining quality and file size.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bitRateMode rdf:type rdf:Property ;
    rdfs:label 'Bit Rate Mode' ;
    rdfs:comment 'Encoding bit rate control mode: CBR (Constant Bit Rate), VBR (Variable Bit Rate), or ABR (Average Bit Rate / Adaptive Bitrate Streaming).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmCompatibility rdf:type rdf:Property ;
    rdfs:label 'Drm Compatibility' ;
    rdfs:comment 'Digital Rights Management systems compatible with this format (e.g., Widevine, FairPlay, PlayReady, none for unencrypted).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileExtension rdf:type rdf:Property ;
    rdfs:label 'File Extension' ;
    rdfs:comment 'Standard file extension for files encoded in this format (e.g., .mxf, .mp4, .mov, .ts, .m3u8).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatCategory rdf:type rdf:Property ;
    rdfs:label 'Format Category' ;
    rdfs:comment 'Classification of the format by its intended use case in the media workflow: ingest (acquisition), mezzanine (high-quality intermediate), proxy (low-res editing), playout (broadcast transmission), OTT delivery (streaming), or archive (long-term preservation).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatCode rdf:type rdf:Property ;
    rdfs:label 'Format Code' ;
    rdfs:comment 'Unique business identifier code for the format specification used across systems and workflows.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatName rdf:type rdf:Property ;
    rdfs:label 'Format Name' ;
    rdfs:comment 'Human-readable name of the media format specification (e.g., HD 1080p H.264 AAC, 4K UHD HEVC Dolby Atmos).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingStandard rdf:type rdf:Property ;
    rdfs:label 'Governing Standard' ;
    rdfs:comment 'Primary industry or regulatory standard governing this format specification (e.g., ATSC 3.0, DVB-T2, SMPTE ST 2110, ISO/IEC 14496, ITU-R BT.2020).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdrStandard rdf:type rdf:Property ;
    rdfs:label 'Hdr Standard' ;
    rdfs:comment 'High Dynamic Range standard applied to the format (e.g., HDR10, HDR10+, HLG (Hybrid Log-Gamma), Dolby Vision, none for SDR).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:horizontalResolution rdf:type rdf:Property ;
    rdfs:label 'Horizontal Resolution' ;
    rdfs:comment 'Horizontal pixel count of the video frame (e.g., 1920 for Full HD, 3840 for UHD).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle state of the format specification: active (in production use), deprecated (phasing out), retired (no longer used), draft (under development), under_review (pending approval), or approved (ready for deployment).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loudnessStandard rdf:type rdf:Property ;
    rdfs:label 'Loudness Standard' ;
    rdfs:comment 'Audio loudness normalization standard applied (e.g., ITU-R BS.1770-4 LKFS, EBU R128 LUFS, ATSC A/85 for broadcast).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mimeType rdf:type rdf:Property ;
    rdfs:label 'Mime Type' ;
    rdfs:comment 'MIME (Multipurpose Internet Mail Extensions) type for HTTP delivery and content negotiation (e.g., video/mp4, application/mxf, video/MP2T).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcProfile rdf:type rdf:Property ;
    rdfs:label 'Qc Profile' ;
    rdfs:comment 'Quality control validation profile applied to assets in this format, defining automated checks for technical compliance (e.g., video levels, audio loudness, format conformance).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionClass rdf:type rdf:Property ;
    rdfs:label 'Resolution Class' ;
    rdfs:comment 'Video resolution classification: SD (Standard Definition 480/576), HD (720p), FHD (Full HD 1080p), UHD (Ultra HD 2160p), 4K (4096x2160), 8K (7680x4320).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanType rdf:type rdf:Property ;
    rdfs:label 'Scan Type' ;
    rdfs:comment 'Video scanning method: progressive (all lines scanned sequentially, denoted \'p\') or interlaced (alternating fields, denoted \'i\').' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLoudnessLufs rdf:type rdf:Property ;
    rdfs:label 'Target Loudness Lufs' ;
    rdfs:comment 'Target integrated loudness level in LUFS (Loudness Units relative to Full Scale) or LKFS, typically -23 LUFS for broadcast, -14 LUFS for streaming.' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transcodePriority rdf:type rdf:Property ;
    rdfs:label 'Transcode Priority' ;
    rdfs:comment 'Default processing priority for transcode jobs targeting this format: critical (immediate), high (expedited), normal (standard queue), low (off-peak), batch (scheduled bulk processing).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verticalResolution rdf:type rdf:Property ;
    rdfs:label 'Vertical Resolution' ;
    rdfs:comment 'Vertical pixel count of the video frame (e.g., 1080 for Full HD, 2160 for UHD).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ingestJobId rdf:type rdf:Property ;
    rdfs:label 'Ingest Job Id' ;
    rdfs:comment 'Unique identifier for the media ingest job. Primary key for the ingest_job data product.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Created Asset Version Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_version. Business justification: Ingest job creates a specific version (typically the mezzanine or raw master). This FK links the ingest job to the version it produced. Populated upon successful ingest completion.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:sourcePartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Source Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Content ingested from partner feeds (satellite, FTP, aspera) requires tracking source partner for SLA compliance monitoring, billing reconciliation, delivery acceptance workflows, and automated partne' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:bytesTransferred rdf:type rdf:Property ;
    rdfs:label 'Bytes Transferred' ;
    rdfs:comment 'Total number of bytes successfully transferred during the ingest operation. Used for capacity planning and performance monitoring.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedCaptionPresent rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Present' ;
    rdfs:comment 'Indicates whether closed captions or subtitles are embedded in the ingested media. Required for FCC accessibility compliance validation.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingestEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingest End Timestamp' ;
    rdfs:comment 'Timestamp when the ingest job completed or terminated. Null for jobs still in progress.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ingestStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingest Start Timestamp' ;
    rdfs:comment 'Timestamp when the ingest job began processing. Represents the actual start of media transfer, not the queued time.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:jobNumber rdf:type rdf:Property ;
    rdfs:label 'Job Number' ;
    rdfs:comment 'Human-readable business identifier for the ingest job, typically formatted as prefix-date-sequence (e.g., ING-20240115-0042). Used for operational tracking and reference.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobStatus rdf:type rdf:Property ;
    rdfs:label 'Job Status' ;
    rdfs:comment 'Current lifecycle status of the ingest job. Tracks progression from queued through execution to final disposition.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLocation rdf:type rdf:Property ;
    rdfs:label 'Source Location' ;
    rdfs:comment 'Physical or logical location of the source media. May be a tape ID, file path, URL, satellite transponder identifier, or cloud storage bucket path.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Target Storage Location' ;
    rdfs:comment 'Destination storage path or tier where the ingested media asset will be stored. May reference nearline, online, or archive storage systems.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timecodeStart rdf:type rdf:Property ;
    rdfs:label 'Timecode Start' ;
    rdfs:comment 'Starting timecode of the ingested media in SMPTE format (HH:MM:SS:FF). Used for frame-accurate editing and synchronization.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferRateMbps rdf:type rdf:Property ;
    rdfs:label 'Transfer Rate Mbps' ;
    rdfs:comment 'Average data transfer rate achieved during ingest, measured in megabits per second. Key performance indicator for ingest infrastructure.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subjectTalentProfileId rdf:type rdf:Property ;
    rdfs:label 'Subject Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: Legal holds triggered by talent-related litigation (contract disputes, likeness rights claims, guild grievances) require tracking which talent is the subject. Essential for legal compliance and discov' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:acknowledgmentDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Deadline Date' ;
    rdfs:comment 'Deadline by which custodians must acknowledge the legal hold order. Nullable if acknowledgment is not required. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentRequired rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Required' ;
    rdfs:comment 'Indicates whether custodians and stakeholders are required to formally acknowledge receipt and understanding of the legal hold order.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Official case, docket, or investigation number associated with the legal matter requiring the hold. Used for cross-referencing with legal case management systems.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianEmail rdf:type rdf:Property ;
    rdfs:label 'Custodian Email' ;
    rdfs:comment 'Primary email address of the legal hold custodian for communication regarding hold status, scope changes, and release authorization.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianName rdf:type rdf:Property ;
    rdfs:label 'Custodian Name' ;
    rdfs:comment 'Full name of the individual responsible for managing and enforcing this legal hold order, typically a legal counsel or compliance officer.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianPhone rdf:type rdf:Property ;
    rdfs:label 'Custodian Phone' ;
    rdfs:comment 'Primary contact phone number for the legal hold custodian.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCounselContact rdf:type rdf:Property ;
    rdfs:label 'External Counsel Contact' ;
    rdfs:comment 'Full name of the primary contact person at the external counsel firm managing this legal hold matter.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCounselFirm rdf:type rdf:Property ;
    rdfs:label 'External Counsel Firm' ;
    rdfs:comment 'Name of the external law firm or legal counsel representing the organization in the matter associated with this legal hold.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdEndDate rdf:type rdf:Property ;
    rdfs:label 'Hold End Date' ;
    rdfs:comment 'Date when the legal hold order was formally released or expired, allowing normal retention policies to resume. Nullable for active holds. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdPriority rdf:type rdf:Property ;
    rdfs:label 'Hold Priority' ;
    rdfs:comment 'Priority level assigned to this legal hold, indicating urgency and importance for compliance and enforcement purposes.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Detailed explanation of the legal matter, dispute, investigation, or regulatory inquiry that necessitates preservation of media assets under this hold.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this legal hold order for tracking and citation purposes. Format: LH-YYYY-NNNNNN.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStartDate rdf:type rdf:Property ;
    rdfs:label 'Hold Start Date' ;
    rdfs:comment 'Date when the legal hold order became effective and preservation obligations commenced. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle status of the legal hold order. Active holds prevent automated retention policy actions (purge, tier migration) on in-scope assets.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Classification of the legal hold based on the nature of the legal matter requiring preservation of media assets.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Name' ;
    rdfs:comment 'Full name of the specific authority, court, or regulatory body that issued the legal hold order.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mamSystemLockEnabled rdf:type rdf:Property ;
    rdfs:label 'Mam System Lock Enabled' ;
    rdfs:comment 'Indicates whether a system-level lock has been applied in the Media Asset Management (MAM) system (Dalet Galaxy) to prevent modification or deletion of held assets.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'Date when formal notification of the legal hold was sent to relevant custodians, stakeholders, and Media Asset Management (MAM) system administrators. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Release Authorization Date' ;
    rdfs:comment 'Date when formal authorization was granted to release the legal hold, allowing normal retention policies to resume on previously held assets. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseAuthorizedBy rdf:type rdf:Property ;
    rdfs:label 'Release Authorized By' ;
    rdfs:comment 'Full name of the individual or authority who formally authorized the release of this legal hold order.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Retention Override Flag' ;
    rdfs:comment 'Indicates whether this legal hold overrides standard retention policies and prevents automated purge, archival tier migration, or deletion actions on in-scope assets.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed description of the media assets, content types, date ranges, and metadata criteria that define which assets are subject to this legal hold.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTitle rdf:type rdf:Property ;
    rdfs:label 'Asset Title' ;
    rdfs:comment 'Primary human-readable title or name of the media asset. Used for search, cataloging, and display in MAM interfaces.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Primary media type classification of the digital object. Determines handling, playback, and workflow routing in the MAM system. [ENUM-REF-CANDIDATE: video|audio|image|graphics|document|subtitle|caption — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentClassification rdf:type rdf:Property ;
    rdfs:label 'Content Classification' ;
    rdfs:comment 'Business classification tags for content categorization (e.g., news, sports, drama, documentary, commercial, promo). Supports search, rights management, and workflow routing. Pipe-separated list for multiple classifications.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingSystem rdf:type rdf:Property ;
    rdfs:label 'Originating System' ;
    rdfs:comment 'Source system or device that created or ingested the asset (e.g., camera model, editing suite, ingest station, external vendor). Provides provenance for chain-of-custody tracking.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Completed Timestamp' ;
    rdfs:comment 'Date and time when quality control review was completed. Null if QC is pending or not required.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qcOperator rdf:type rdf:Property ;
    rdfs:label 'Qc Operator' ;
    rdfs:comment 'User ID or name of the operator who performed quality control review. Used for accountability and audit trails.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsRestriction rdf:type rdf:Property ;
    rdfs:label 'Rights Restriction' ;
    rdfs:comment 'Rights and usage restrictions governing distribution and use of the asset. Enforces compliance with licensing agreements, territorial restrictions, and legal holds.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationUri rdf:type rdf:Property ;
    rdfs:label 'Storage Location Uri' ;
    rdfs:comment 'Full URI path to the physical storage location of the media file (e.g., s3://bucket/path, file://server/share/path). Used by MAM for retrieval and playout automation.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:umid rdf:type rdf:Property ;
    rdfs:label 'Umid' ;
    rdfs:comment 'SMPTE 330M globally unique identifier for the media essence. 64-character hexadecimal string providing universal identification across systems and organizations.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcInspectionId rdf:type rdf:Property ;
    rdfs:label 'Qc Inspection Id' ;
    rdfs:comment 'Unique identifier for the quality control inspection record. Primary key.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mediaAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Media Asset Version Id' ;
    rdfs:comment 'Reference to the specific version of the media asset that underwent this quality control inspection.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:primaryQcEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Qc Employee Id' ;
    rdfs:comment 'Reference to the human operator who performed or supervised the manual or hybrid quality control inspection. Null for fully automated inspections.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aspectRatioComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Aspect Ratio Compliance Result' ;
    rdfs:comment 'Result of aspect ratio compliance check. Verifies that video aspect ratio (e.g., 16:9, 4:3, 21:9) matches expected format and Active Format Description (AFD) metadata is correct.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioCodecComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Audio Codec Compliance Result' ;
    rdfs:comment 'Result of audio codec format compliance check. Verifies that audio encoding conforms to expected codec standard (e.g., AAC, Dolby Digital, Dolby Atmos, MPEG-1 Layer II).' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioSyncOffsetMs rdf:type rdf:Property ;
    rdfs:label 'Audio Sync Offset Ms' ;
    rdfs:comment 'Measured audio-to-video synchronization offset in milliseconds. Positive values indicate audio leads video; negative values indicate audio lags video. Null if sync check not performed.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioSyncResult rdf:type rdf:Property ;
    rdfs:label 'Audio Sync Result' ;
    rdfs:comment 'Result of audio-to-video synchronization check. Detects lip-sync errors or audio drift.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackFrameCount rdf:type rdf:Property ;
    rdfs:label 'Black Frame Count' ;
    rdfs:comment 'Total number of black frames detected in the media asset. Zero if none detected.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackFrameDetected rdf:type rdf:Property ;
    rdfs:label 'Black Frame Detected' ;
    rdfs:comment 'Indicates whether unintended black frames (video signal dropout or encoding error) were detected during inspection.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:captionValidationResult rdf:type rdf:Property ;
    rdfs:label 'Caption Validation Result' ;
    rdfs:comment 'Result of closed caption (CEA-608, CEA-708) or subtitle validation check. Verifies presence, format compliance, and synchronization of captions.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDefectCount rdf:type rdf:Property ;
    rdfs:label 'Critical Defect Count' ;
    rdfs:comment 'Number of critical-severity defects that block asset approval for playout or distribution. Critical defects require remediation.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of quality defects detected during inspection. Zero indicates no defects found.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectSummary rdf:type rdf:Property ;
    rdfs:label 'Defect Summary' ;
    rdfs:comment 'Structured JSON or delimited text summary of all detected defects with timecode references, severity levels, and defect type codes. Detailed defect records may be stored in a separate qc_defect child table.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedAspectRatio rdf:type rdf:Property ;
    rdfs:label 'Detected Aspect Ratio' ;
    rdfs:comment 'Actual aspect ratio detected in the video stream (e.g., 16:9, 4:3, 1.85:1, 2.39:1). Null if aspect ratio check not performed.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeFrameCount rdf:type rdf:Property ;
    rdfs:label 'Freeze Frame Count' ;
    rdfs:comment 'Total number of freeze frame incidents detected in the media asset. Zero if none detected.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freezeFrameDetected rdf:type rdf:Property ;
    rdfs:label 'Freeze Frame Detected' ;
    rdfs:comment 'Indicates whether freeze frames (static video for extended duration) were detected during inspection.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdrMetadataValidationResult rdf:type rdf:Property ;
    rdfs:label 'Hdr Metadata Validation Result' ;
    rdfs:comment 'Result of High Dynamic Range (HDR) metadata validation check. Verifies presence and correctness of HDR10, HDR10+, Dolby Vision, or HLG metadata. Not applicable for Standard Dynamic Range (SDR) content.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Inspection Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds required to complete the quality control inspection process.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Human-readable business identifier for the inspection record, formatted as QC-YYYYMMDD-NNNNNN.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle state of the quality control inspection process.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when the quality control inspection was performed or completed. Primary business event timestamp.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loudnessComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Loudness Compliance Result' ;
    rdfs:comment 'Result of audio loudness compliance check against regulatory standards (EBU R128 for Europe, ATSC A/85 for North America, ITU-R BS.1770 globally).' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loudnessLufs rdf:type rdf:Property ;
    rdfs:label 'Loudness Lufs' ;
    rdfs:comment 'Measured integrated loudness level in LUFS (Loudness Units relative to Full Scale) or LKFS. Typical broadcast target is -23 LUFS (EBU R128) or -24 LKFS (ATSC A/85).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Final pass/fail determination for the quality control inspection. Conditional pass indicates minor issues that do not block playout. Review required indicates human escalation needed.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcToolName rdf:type rdf:Property ;
    rdfs:label 'Qc Tool Name' ;
    rdfs:comment 'Name and version of the automated quality control software or tool used for inspection (e.g., Baton, Interra, Venera, Dalet QC Module).' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcType rdf:type rdf:Property ;
    rdfs:label 'Qc Type' ;
    rdfs:comment 'Classification of the quality control inspection method: automated (software-based), manual (human operator), or hybrid (combination of both).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCodecComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Video Codec Compliance Result' ;
    rdfs:comment 'Result of video codec format compliance check. Verifies that video encoding conforms to expected codec standard (e.g., H.264/AVC, H.265/HEVC, MPEG-2, AV1).' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesPolicyRetentionPolicyId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Policy Retention Policy Id' ;
    rdfs:comment 'Reference to the previous retention policy that this policy replaces. Null if this is the first version. Supports policy lineage and historical analysis.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionPolicy .

ind:appliesToLegalHold rdf:type rdf:Property ;
    rdfs:label 'Applies To Legal Hold' ;
    rdfs:comment 'Indicates whether this retention policy applies to assets under legal hold. If false, legal hold assets are exempt from automated lifecycle actions governed by this policy.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToSyndicationContent rdf:type rdf:Property ;
    rdfs:label 'Applies To Syndication Content' ;
    rdfs:comment 'Indicates whether this retention policy applies to syndicated content (content resold to multiple outlets). Syndication agreements may impose distinct retention obligations.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetClassScope rdf:type rdf:Property ;
    rdfs:label 'Asset Class Scope' ;
    rdfs:comment 'The category of media assets to which this retention policy applies. Aligns with MAM (Media Asset Management) asset classification in Dalet Galaxy. [ENUM-REF-CANDIDATE: raw|mezzanine|proxy|archive|master|graphics|audio|metadata — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'Checksum Verification Required' ;
    rdfs:comment 'Indicates whether checksum integrity verification is mandatory before executing post-retention actions. Ensures asset integrity throughout the retention lifecycle.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formatMigrationAllowed rdf:type rdf:Property ;
    rdfs:label 'Format Migration Allowed' ;
    rdfs:comment 'Indicates whether format migration (transcoding to newer codecs or containers) is permitted during the retention period. Supports long-term preservation and format obsolescence mitigation.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Retention Period Days' ;
    rdfs:comment 'The maximum number of days an asset may be retained before mandatory action (purge or archive migration). Null indicates indefinite retention.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Retention Period Days' ;
    rdfs:comment 'The minimum number of days an asset must be retained before any deletion or migration action can occur. Enforces regulatory and contractual obligations.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationRecipients rdf:type rdf:Property ;
    rdfs:label 'Notification Recipients' ;
    rdfs:comment 'Comma-separated list of email addresses or role identifiers to be notified when retention actions are triggered (e.g., \'legal@mediabroadcasting.com, content-ops-team\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed business description of the retention policy, including rationale, scope, and any special handling instructions.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyOwner rdf:type rdf:Property ;
    rdfs:label 'Policy Owner' ;
    rdfs:comment 'The business role, department, or individual responsible for defining and maintaining this retention policy (e.g., \'Legal & Compliance\', \'Media Operations Director\', \'Chief Content Officer\').' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postRetentionAction rdf:type rdf:Property ;
    rdfs:label 'Post Retention Action' ;
    rdfs:comment 'The action to be taken when the retention period expires. Drives automated lifecycle workflows in MAM (Media Asset Management) systems.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'The regulatory framework, statute, or compliance requirement that mandates or informs this retention policy (e.g., \'FCC 47 CFR 73.1840\', \'Ofcom Section 11\', \'GDPR Article 5\', \'SOX Section 802\', \'Legal Hold Case #12345\').' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionTrigger rdf:type rdf:Property ;
    rdfs:label 'Retention Trigger' ;
    rdfs:comment 'The business event that starts the retention clock for this policy (e.g., when the asset was ingested, when it was first broadcast, when the licensing contract expires, or when a legal hold is placed).' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessProtocol rdf:type rdf:Property ;
    rdfs:label 'Access Protocol' ;
    rdfs:comment 'Network protocol or interface used to access the storage location (NFS = Network File System, SMB = Server Message Block, S3 = Amazon S3 API, SFTP = Secure File Transfer Protocol, iSCSI = Internet Small Computer Systems Interface, Fibre_Channel = FC SAN protocol). [ENUM-REF-CANDIDATE: NFS|SMB|S3|SFTP|iSCSI|Fibre_Channel|HTTP|HTTPS — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCapacityTb rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Tb' ;
    rdfs:comment 'Remaining available storage capacity (total minus used), measured in terabytes (TB). Drives automated alerts and provisioning workflows.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checksumValidationEnabled rdf:type rdf:Property ;
    rdfs:label 'Checksum Validation Enabled' ;
    rdfs:comment 'Indicates whether automated checksum integrity validation is performed on assets stored at this location (True = enabled, False = disabled). Critical for ensuring asset integrity and detecting corruption.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costPerTbPerMonth rdf:type rdf:Property ;
    rdfs:label 'Cost Per Tb Per Month' ;
    rdfs:comment 'Monthly cost per terabyte of storage at this location, used for cost allocation and financial reporting. Includes infrastructure, licensing, and operational costs.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCenterName rdf:type rdf:Property ;
    rdfs:label 'Data Center Name' ;
    rdfs:comment 'Name or identifier of the physical data center or facility housing the storage infrastructure (e.g., \'NYC-DC1\', \'AWS-US-East-1\', \'Azure-WestEurope\').' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date when the storage location was or is planned to be decommissioned and removed from service. Null if still active. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:encryptionMethod rdf:type rdf:Property ;
    rdfs:label 'Encryption Method' ;
    rdfs:comment 'Encryption algorithm or method applied to data at rest (e.g., \'AES-256\', \'AES-128\', \'RSA-2048\'). Null if encryption is not enabled.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCapacityCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Capacity Check Timestamp' ;
    rdfs:comment 'Timestamp of the most recent capacity measurement or audit for this storage location. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalHoldCapable rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Capable' ;
    rdfs:comment 'Indicates whether this storage location supports legal hold functionality to prevent deletion or modification of assets under litigation or regulatory investigation (True = capable, False = not capable).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name or label for the storage location (e.g., \'Production SAN Array 01\', \'Archive LTO Tape Library\', \'AWS S3 US-East Bucket\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mountPoint rdf:type rdf:Property ;
    rdfs:label 'Mount Point' ;
    rdfs:comment 'File system mount point, UNC path, or object storage URI used by MAM systems to access the location (e.g., \'/mnt/production_san\', \'\\\\nas01\\media\', \'s3://bucket-name/prefix\').' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replicationEnabled rdf:type rdf:Property ;
    rdfs:label 'Replication Enabled' ;
    rdfs:comment 'Indicates whether this storage location is replicated to another location for redundancy and disaster recovery (True = replicated, False = not replicated).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restoreTimeObjectiveHours rdf:type rdf:Property ;
    rdfs:label 'Restore Time Objective Hours' ;
    rdfs:comment 'Maximum acceptable time to restore or retrieve assets from this storage location, measured in hours. Critical for disaster recovery and operational planning.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionPolicyDays rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Days' ;
    rdfs:comment 'Default retention period in days for assets stored at this location, after which assets may be migrated or purged per policy. Null if no default retention applies.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageType rdf:type rdf:Property ;
    rdfs:label 'Storage Type' ;
    rdfs:comment 'Classification of the physical or logical storage technology (SAN = Storage Area Network, NAS = Network Attached Storage, LTO_Tape = Linear Tape-Open, Cloud_Object_Storage = S3/Azure Blob/GCS, CDN_Origin = Content Delivery Network origin store, Deep_Archive = long-term cold storage vault).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageVendor rdf:type rdf:Property ;
    rdfs:label 'Storage Vendor' ;
    rdfs:comment 'Name of the storage hardware or cloud service provider (e.g., \'Dell EMC\', \'NetApp\', \'AWS\', \'Azure\', \'Google Cloud\', \'IBM Spectrum Archive\').' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapacityTb rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Tb' ;
    rdfs:comment 'Total storage capacity of the location measured in terabytes (TB). Used for capacity planning and allocation reporting.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usedCapacityTb rdf:type rdf:Property ;
    rdfs:label 'Used Capacity Tb' ;
    rdfs:comment 'Current amount of storage capacity consumed or allocated, measured in terabytes (TB). Updated periodically to reflect actual usage.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetFormatSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Target Format Specification Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.format_specification. Business justification: Normalization: transcode job targets an approved format specification from the catalog. The target_format_specification STRING attribute becomes a FK. Format details retrieved via JOIN.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormatSpecification .

ind:abrLadderConfiguration rdf:type rdf:Property ;
    rdfs:label 'Abr Ladder Configuration' ;
    rdfs:comment 'Configuration specification for ABR ladder generation, defining the set of bitrate/resolution variants to be created for adaptive streaming (e.g., 240p@400kbps, 360p@800kbps, 480p@1.2Mbps, 720p@2.5Mbps, 1080p@5Mbps). Applicable when job_type is abr_ladder_generation.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codecParameters rdf:type rdf:Property ;
    rdfs:label 'Codec Parameters' ;
    rdfs:comment 'Detailed codec encoding parameters including profile, level, GOP structure, B-frames, reference frames, and other encoder-specific settings (e.g., x264 preset=medium, crf=23, profile=high, level=4.1).' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Usd' ;
    rdfs:comment 'Estimated processing cost in US dollars for this transcode job, based on compute time, storage, and resource utilization. Used for chargeback and budget tracking.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobPriority rdf:type rdf:Property ;
    rdfs:label 'Job Priority' ;
    rdfs:comment 'Processing priority level for the transcode job, determining queue position and resource allocation. Critical jobs are processed immediately, batch jobs during off-peak hours.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobType rdf:type rdf:Property ;
    rdfs:label 'Job Type' ;
    rdfs:comment 'Classification of the transcode operation: standard transcode for routine format conversion, ABR (Adaptive Bitrate) ladder generation for streaming, proxy creation for editing workflows, delivery package preparation for distribution, or format migration for obsolescence-driven conversions. [ENUM-REF-CANDIDATE: standard_transcode|abr_ladder_generation|proxy_creation|delivery_package|format_migration|tape_digitization|analogue_to_digital — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputChecksum rdf:type rdf:Property ;
    rdfs:label 'Output Checksum' ;
    rdfs:comment 'Cryptographic checksum (MD5, SHA-256, or SHA-512) of the output file for integrity verification and chain-of-custody audit trails.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputFileSizeGb rdf:type rdf:Property ;
    rdfs:label 'Output File Size Gb' ;
    rdfs:comment 'Total file size of the transcoded output in gigabytes. Populated upon job completion.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputStorageUri rdf:type rdf:Property ;
    rdfs:label 'Output Storage Uri' ;
    rdfs:comment 'Storage location URI for the transcoded output file(s), including protocol, bucket/path, and filename pattern (e.g., s3://media-archive/transcoded/2024/01/asset_12345_1080p.mp4).' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing End Timestamp' ;
    rdfs:comment 'Date and time when the transcoding engine completed or terminated processing of this job.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Start Timestamp' ;
    rdfs:comment 'Date and time when the transcoding engine began processing this job.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:queueEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Queue Entry Timestamp' ;
    rdfs:comment 'Date and time when the transcode job was submitted to the processing queue.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceBitrateMbps rdf:type rdf:Property ;
    rdfs:label 'Source Bitrate Mbps' ;
    rdfs:comment 'Average bitrate of the source asset in megabits per second.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceCodec rdf:type rdf:Property ;
    rdfs:label 'Source Codec' ;
    rdfs:comment 'Video codec of the source asset (e.g., H.264, H.265/HEVC, MPEG-2, ProRes, DNxHD).' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFileSizeGb rdf:type rdf:Property ;
    rdfs:label 'Source File Size Gb' ;
    rdfs:comment 'File size of the source asset in gigabytes.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transcodingEngine rdf:type rdf:Property ;
    rdfs:label 'Transcoding Engine' ;
    rdfs:comment 'Name and version of the transcoding engine or software used to perform the conversion (e.g., FFmpeg 5.1.2, AWS Elemental MediaConvert, Dalet Brio).' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDeliveryFormat rdf:type rdf:Property ;
    rdfs:label 'Content Delivery Format' ;
    rdfs:comment 'Technical specifications for content delivery including file formats, resolution standards, and delivery methods (e.g., HD 1080p ProRes, 4K HEVC, physical media, digital file transfer).' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentPackageScope rdf:type rdf:Property ;
    rdfs:label 'Content Package Scope' ;
    rdfs:comment 'Detailed description of the content included in this acquisition deal, including series titles, episode counts, seasons, or film packages.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Contract Execution Date' ;
    rdfs:comment 'Date when the acquisition deal contract was formally signed and executed by all parties, marking the transition from negotiation to binding agreement.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Deal Effective Date' ;
    rdfs:comment 'Date when the acquisition deal terms become effective and rights begin to accrue, which may differ from execution date.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Deal Expiration Date' ;
    rdfs:comment 'Date when the acquisition deal expires and rights revert to the content provider, marking the end of the license period.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealTitle rdf:type rdf:Property ;
    rdfs:label 'Deal Title' ;
    rdfs:comment 'Human-readable name or title of the acquisition deal, typically reflecting the content package or series being acquired.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealValueAmount rdf:type rdf:Property ;
    rdfs:label 'Deal Value Amount' ;
    rdfs:comment 'Total monetary value of the acquisition deal in the specified currency, representing the gross commitment before adjustments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionRights rdf:type rdf:Property ;
    rdfs:label 'Distribution Rights' ;
    rdfs:comment 'Comma-separated list of distribution platforms and methods covered by this deal (e.g., linear, SVOD, AVOD, TVOD, FAST, syndication, VOD).' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeCount rdf:type rdf:Property ;
    rdfs:label 'Episode Count' ;
    rdfs:comment 'Total number of episodes included in the acquisition deal for episodic content such as television series.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Detailed description of exclusivity terms, including platform restrictions, genre exclusivity, or time-based exclusivity windows.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseTermMonths rdf:type rdf:Property ;
    rdfs:label 'License Term Months' ;
    rdfs:comment 'Duration of the content license in months, representing the period during which the broadcaster has rights to exploit the acquired content.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketingMaterialsIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Materials Included Flag' ;
    rdfs:comment 'Indicates whether the deal includes delivery of marketing and promotional materials such as trailers, key art, press kits, and promotional clips.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metadataRequirements rdf:type rdf:Property ;
    rdfs:label 'Metadata Requirements' ;
    rdfs:comment 'Specifications for content metadata to be delivered with the content package, including descriptive, technical, and rights metadata standards.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentSchedule rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule' ;
    rdfs:comment 'Detailed schedule of payment milestones and amounts, including upfront payments, delivery payments, and ongoing royalty schedules.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceGuarantees rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantees' ;
    rdfs:comment 'Contractual performance commitments such as minimum broadcast hours, promotional support, or audience delivery guarantees required by the content provider.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensingTerms rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Terms' ;
    rdfs:comment 'Detailed terms and restrictions governing sublicensing rights, including revenue sharing with original content provider and territorial limitations.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCoverage rdf:type rdf:Property ;
    rdfs:label 'Territory Coverage' ;
    rdfs:comment 'Geographic territories or markets covered by this acquisition deal, specified as comma-separated ISO 3166-1 alpha-3 country codes or regional designations (e.g., USA, CAN, GBR, or NORTH_AMERICA).' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowingStrategy rdf:type rdf:Property ;
    rdfs:label 'Windowing Strategy' ;
    rdfs:comment 'Sequential release strategy defining the order and timing of content availability across different platforms and distribution channels.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDealLineId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Deal Line Id' ;
    rdfs:comment 'Unique identifier for the acquisition deal line item. Primary key for this entity.' ;
    rdfs:domain ind:AcquisitionDealLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryDueDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Due Date' ;
    rdfs:comment 'The date by which the content provider must deliver the content asset for this line item. Critical for production scheduling and playout planning.' ;
    rdfs:domain ind:AcquisitionDealLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:genrePrimary rdf:type rdf:Property ;
    rdfs:label 'Genre Primary' ;
    rdfs:comment 'Primary genre classification for the content in this line item. Used for programming strategy and audience analytics.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseDurationMonths rdf:type rdf:Property ;
    rdfs:label 'License Duration Months' ;
    rdfs:comment 'Total duration of the license term expressed in months. Calculated from start and end dates for reporting and windowing analysis.' ;
    rdfs:domain ind:AcquisitionDealLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'License Fee Amount' ;
    rdfs:comment 'The base license fee amount for this specific content line item. Represents the core acquisition cost before adjustments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseTermEndDate rdf:type rdf:Property ;
    rdfs:label 'License Term End Date' ;
    rdfs:comment 'The date when the license rights for this content line item expire. Marks the end of the rights window.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseTermStartDate rdf:type rdf:Property ;
    rdfs:label 'License Term Start Date' ;
    rdfs:comment 'The date when the license rights for this content line item become effective. Marks the beginning of the rights window.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affiliateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Affiliate Agreement Id' ;
    rdfs:comment 'Unique identifier for the affiliate agreement record. Primary key.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AffiliateAgreement .

ind:affiliateStationChannelId rdf:type rdf:Property ;
    rdfs:label 'Affiliate Station Channel Id' ;
    rdfs:comment 'Reference to the local broadcast station or regional affiliate partner that is party to this agreement.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:affiliateStationPartnerId rdf:type rdf:Property ;
    rdfs:label 'Affiliate Station Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: affiliate_agreement.affiliate_station_id represents the affiliate station partner. Renaming to affiliate_station_partner_id for clarity (ends with partner_partner_partner_id pattern). Links to partner' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:networkLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Network Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Affiliate agreements generate intercompany transactions requiring legal entity tracking for network compensation accounting, retransmission revenue split allocation, and consolidation elimination. Cri' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:affiliationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Affiliation Fee Amount' ;
    rdfs:comment 'Monthly or annual fee paid by the network to the affiliate station for carrying network programming, or reverse compensation paid by affiliate to network. Negative values indicate reverse compensation.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affiliationFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Affiliation Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the affiliation fee amount (e.g., USD, CAD, GBP).' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliationFeeFrequency rdf:type rdf:Property ;
    rdfs:label 'Affiliation Fee Frequency' ;
    rdfs:comment 'Frequency at which affiliation fees are calculated and paid between network and affiliate.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalRightsIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Rights Included Flag' ;
    rdfs:comment 'Indicates whether the affiliate agreement includes rights to distribute network content via digital platforms, streaming services, and Over-The-Top (OTT) channels.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityTerritory rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Territory' ;
    rdfs:comment 'Geographic territory within which the affiliate has exclusive rights to broadcast network programming, typically defined by DMA boundaries, county lists, or signal contours.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localAdAvailsMinutesPerHour rdf:type rdf:Property ;
    rdfs:label 'Local Ad Avails Minutes Per Hour' ;
    rdfs:comment 'Number of minutes per hour of network programming that the affiliate may use for local advertising insertion, typically 2-4 minutes per hour.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localInsertionRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Local Insertion Rights Flag' ;
    rdfs:comment 'Indicates whether the affiliate has the right to insert local advertising spots during designated network programming breaks (ad pods).' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumClearancePercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Clearance Percentage' ;
    rdfs:comment 'Minimum percentage of network programming hours that the affiliate is contractually obligated to broadcast, typically 85-95% for primary affiliates. Expressed as percentage (e.g., 90.00 for 90%).' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mustAirProgrammingHours rdf:type rdf:Property ;
    rdfs:label 'Must Air Programming Hours' ;
    rdfs:comment 'Minimum number of weekly hours of network programming that the affiliate must broadcast without preemption, including prime-time, news, and sports.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkCompensationModel rdf:type rdf:Property ;
    rdfs:label 'Network Compensation Model' ;
    rdfs:comment 'Economic model governing compensation flow between network and affiliate: fixed fee paid to affiliate, revenue share from advertising, audience-based payments, hybrid model, or reverse compensation where affiliate pays network.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMeasurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Performance Measurement Methodology' ;
    rdfs:comment 'Audience measurement methodology used to assess affiliate performance against contractual standards (Nielsen ratings, Comscore, proprietary measurement, or multi-source approach).' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceStandardGrpMinimum rdf:type rdf:Property ;
    rdfs:label 'Performance Standard Grp Minimum' ;
    rdfs:comment 'Minimum Gross Rating Points (GRP) that the affiliate must deliver for network programming to meet performance standards and avoid penalties or compensation adjustments.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preemptionNoticeHours rdf:type rdf:Property ;
    rdfs:label 'Preemption Notice Hours' ;
    rdfs:comment 'Minimum number of hours advance notice the affiliate must provide to the network before preempting scheduled programming, typically 24-72 hours except for breaking news.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preemptionRights rdf:type rdf:Property ;
    rdfs:label 'Preemption Rights' ;
    rdfs:comment 'Extent to which the affiliate may preempt scheduled network programming for local content, special events, or breaking news. Preemption typically requires advance notice and makegoods.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Included Flag' ;
    rdfs:comment 'Indicates whether the affiliate agreement includes provisions for retransmission consent negotiations with Multichannel Video Programming Distributors (MVPDs) and virtual MVPDs (vMVPDs).' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retransmissionRevenueSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Retransmission Revenue Split Percentage' ;
    rdfs:comment 'Percentage of retransmission consent fees collected from MVPDs that the affiliate must share with the network. Expressed as percentage (e.g., 30.00 for 30% to network).' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:simulcastRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Simulcast Requirement Flag' ;
    rdfs:comment 'Indicates whether the affiliate is required to simulcast network programming simultaneously across multiple platforms (linear broadcast, digital streaming, mobile apps).' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termLengthMonths rdf:type rdf:Property ;
    rdfs:label 'Term Length Months' ;
    rdfs:comment 'Duration of the affiliate agreement term expressed in months, typically ranging from 12 to 60 months for broadcast affiliations.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationForCauseProvisions rdf:type rdf:Property ;
    rdfs:label 'Termination For Cause Provisions' ;
    rdfs:comment 'Description of conditions under which either party may terminate the agreement for cause, including breach of clearance obligations, payment defaults, license revocation, or material violations of broadcast standards.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Schedule Id' ;
    rdfs:comment 'Unique identifier for the carriage fee schedule. Primary key for this entity.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Flag' ;
    rdfs:comment 'Boolean indicator of whether Media Broadcasting retains the right to audit the distributors subscriber counts and fee calculations to ensure compliance with the schedule terms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseFeePerSubscriber rdf:type rdf:Property ;
    rdfs:label 'Base Fee Per Subscriber' ;
    rdfs:comment 'The baseline carriage fee amount charged per subscriber per month. This is the foundational rate before any escalations, discounts, or adjustments are applied.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationFrequency rdf:type rdf:Property ;
    rdfs:label 'Escalation Frequency' ;
    rdfs:comment 'Frequency at which fee escalations are applied. Defines how often the base fee is adjusted according to the escalation type and rate.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Escalation Rate Percentage' ;
    rdfs:comment 'Annual percentage rate by which the base fee per subscriber increases, if escalation type is fixed percentage. Expressed as a percentage (e.g., 3.00 for 3% annual increase).' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationType rdf:type rdf:Property ;
    rdfs:label 'Escalation Type' ;
    rdfs:comment 'Method by which carriage fees increase over time. Options include no escalation, fixed annual percentage increase, Consumer Price Index (CPI) indexing, negotiated increases at specified intervals, or tiered increases based on subscriber growth.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeType rdf:type rdf:Property ;
    rdfs:label 'Fee Type' ;
    rdfs:comment 'Classification of the fee structure. Indicates whether fees are charged per subscriber, as a flat monthly rate, in tiers based on subscriber count, volume-based with discounts, a hybrid model, or as a percentage of revenue share.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latePaymentPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Rate' ;
    rdfs:comment 'Percentage rate applied as a penalty for late payment of carriage fees beyond the payment terms. Expressed as an annual percentage rate or per-period rate.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumFeeCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Fee Cap' ;
    rdfs:comment 'The maximum total carriage fee amount per billing period, regardless of subscriber count. Protects the distributor from excessive fees in high-subscriber scenarios.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mfnProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Mfn Provision Flag' ;
    rdfs:comment 'Boolean indicator of whether this schedule includes a Most-Favored-Nation clause. If true, the distributor is entitled to the most favorable carriage fee terms that Media Broadcasting offers to any comparable distributor.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mfnScope rdf:type rdf:Property ;
    rdfs:label 'Mfn Scope' ;
    rdfs:comment 'Defines the scope and conditions under which the MFN provision applies, including comparable distributor criteria, geographic limitations, and exclusions.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteedFee rdf:type rdf:Property ;
    rdfs:label 'Minimum Guaranteed Fee' ;
    rdfs:comment 'The minimum total carriage fee amount guaranteed per billing period, regardless of subscriber count. Protects Media Broadcasting revenue in low-subscriber scenarios.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Frequency at which carriage fees are invoiced and paid by the distributor. Defines the billing cycle for this fee schedule.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Business-friendly name or identifier for this fee schedule, used for internal reference and reporting purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the fee schedule. Indicates whether the schedule is in draft, actively in force, temporarily suspended, expired, terminated early, or superseded by a newer version.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version identifier for this fee schedule, used to track amendments, renegotiations, and historical changes to fee structures over the life of the agreement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberCountSource rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count Source' ;
    rdfs:comment 'Source of subscriber count data used to calculate carriage fees. Options include distributor self-reporting, third-party audit, Nielsen measurement, or Media Broadcasting internal estimates.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeDiscountTier1Rate rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 1 Rate' ;
    rdfs:comment 'Discounted per-subscriber fee rate applicable when subscriber count exceeds the Tier 1 threshold.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountTier1Threshold rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 1 Threshold' ;
    rdfs:comment 'Subscriber count threshold at which the first volume discount tier is triggered. Distributors exceeding this subscriber count qualify for a reduced per-subscriber fee.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeDiscountTier2Rate rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 2 Rate' ;
    rdfs:comment 'Discounted per-subscriber fee rate applicable when subscriber count exceeds the Tier 2 threshold.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountTier2Threshold rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 2 Threshold' ;
    rdfs:comment 'Subscriber count threshold at which the second volume discount tier is triggered, offering further per-subscriber fee reduction.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeDiscountTier3Rate rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 3 Rate' ;
    rdfs:comment 'Discounted per-subscriber fee rate applicable when subscriber count exceeds the Tier 3 threshold.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountTier3Threshold rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 3 Threshold' ;
    rdfs:comment 'Subscriber count threshold at which the third volume discount tier is triggered, offering the deepest per-subscriber fee reduction.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerContentWindowId rdf:type rdf:Property ;
    rdfs:label 'Partner Content Window Id' ;
    rdfs:comment 'Unique identifier for the content window record. Primary key.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerContentWindow .

ind:businessOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Business Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Windowing strategies require business owner tracking for activation decisions, performance monitoring, and renewal negotiations. Critical for accountability in SVOD/AVOD/TVOD window management and rev' ;
    rdfs:domain ind:PartnerContentWindow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:drmRequirement rdf:type rdf:Property ;
    rdfs:label 'Drm Requirement' ;
    rdfs:comment 'The DRM technology required to protect the content during this window (e.g., Widevine, FairPlay, PlayReady, Multi-DRM, or none for unprotected distribution).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageAvailability rdf:type rdf:Property ;
    rdfs:label 'Language Availability' ;
    rdfs:comment 'Languages in which the content must be made available during this window (e.g., English, Spanish, French). Comma-separated list of ISO 639-1 language codes.' ;
    rdfs:domain ind:PartnerContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingRightsIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Rights Included Flag' ;
    rdfs:comment 'Indicates whether the platform has rights to use promotional materials, trailers, and marketing assets for this window (True) or must obtain separate clearance (False).' ;
    rdfs:domain ind:PartnerContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceGuaranteeDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Description' ;
    rdfs:comment 'Free-text description of any performance commitments tied to this window (e.g., minimum viewership targets, promotional spend requirements, platform placement guarantees).' ;
    rdfs:domain ind:PartnerContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleRequirement rdf:type rdf:Property ;
    rdfs:label 'Subtitle Requirement' ;
    rdfs:comment 'Specifies subtitle languages required for this window to meet accessibility and localization obligations. Comma-separated list of ISO 639-1 language codes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowDurationDays rdf:type rdf:Property ;
    rdfs:label 'Window Duration Days' ;
    rdfs:comment 'The total length of the distribution window in days, calculated from start to end date. Used for planning and compliance tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowEndDate rdf:type rdf:Property ;
    rdfs:label 'Window End Date' ;
    rdfs:comment 'The date on which this distribution window expires and the content must be removed from the platform or the rights revert. Nullable for perpetual windows.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windowStartDate rdf:type rdf:Property ;
    rdfs:label 'Window Start Date' ;
    rdfs:comment 'The date on which this distribution window becomes active and the content may be released on the specified platform.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coproductionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Coproduction Agreement Id' ;
    rdfs:comment 'Unique identifier for the co-production agreement record. Primary key.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoproductionAgreement .

ind:contractingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Contracting Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Co-production investments are capitalized and tracked at legal entity level for consolidation, IP ownership accounting, and residuals liability. Essential for balance sheet classification and intercom' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:executiveSponsorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Executive Sponsor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Coproduction agreements require executive sponsor tracking for approval authority, strategic oversight, and escalation. High-value IP investments need clear internal ownership beyond approval_authorit' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:leadPartnerId rdf:type rdf:Property ;
    rdfs:label 'Lead Partner Id' ;
    rdfs:comment 'Reference to the primary partner organization responsible for managing the co-production.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:leadTalentProfileId rdf:type rdf:Property ;
    rdfs:label 'Lead Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: Co-production agreements frequently specify lead talent (star, showrunner, director) as part of the deal structure—attached talent drives financing approval and production greenlight decisions. Critic' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:productionTitleId rdf:type rdf:Property ;
    rdfs:label 'Production Title Id' ;
    rdfs:comment 'Foreign key linking to content.title. Business justification: Coproduction agreements are title-specific investments requiring direct linkage for production finance tracking, IP ownership percentage calculation, delivery milestone management, and revenue waterfa' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of formal amendments made to the original co-production agreement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditRights rdf:type rdf:Property ;
    rdfs:label 'Audit Rights' ;
    rdfs:comment 'Provisions allowing partners to audit financial records and production accounts related to the co-production.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the total budget amount.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityTerms rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Terms' ;
    rdfs:comment 'Non-disclosure obligations and confidentiality requirements binding all co-production partners.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeControlLevel rdf:type rdf:Property ;
    rdfs:label 'Creative Control Level' ;
    rdfs:comment 'Degree of creative decision-making authority held by our organization in the production process.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditObligation rdf:type rdf:Property ;
    rdfs:label 'Credit Obligation' ;
    rdfs:comment 'Contractual requirements for on-screen and promotional credits for each co-production partner.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionRightsAllocation rdf:type rdf:Property ;
    rdfs:label 'Distribution Rights Allocation' ;
    rdfs:comment 'Description of how distribution rights are divided among co-production partners by territory and platform.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureProvision rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Provision' ;
    rdfs:comment 'Contractual terms addressing obligations and liabilities in the event of unforeseeable circumstances preventing performance.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Mandatory insurance coverage types and amounts required for the co-production.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ourInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Our Investment Amount' ;
    rdfs:comment 'Financial contribution amount committed by our organization to the co-production.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ourInvestmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Our Investment Percentage' ;
    rdfs:comment 'Percentage of total production budget contributed by our organization.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ourIpOwnershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Our Ip Ownership Percentage' ;
    rdfs:comment 'Percentage of intellectual property rights owned by our organization in the co-produced content.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ourPrimaryTerritory rdf:type rdf:Property ;
    rdfs:label 'Our Primary Territory' ;
    rdfs:comment 'Geographic territory or territories where our organization holds primary distribution rights.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionType rdf:type rdf:Property ;
    rdfs:label 'Production Type' ;
    rdfs:comment 'Category of content being co-produced (film, television series, documentary, etc.).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualsSharingFormula rdf:type rdf:Property ;
    rdfs:label 'Residuals Sharing Formula' ;
    rdfs:comment 'Formula or methodology for distributing residual payments to talent among co-production partners.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharingModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Sharing Model' ;
    rdfs:comment 'Methodology for distributing revenues generated from the co-produced content among partners.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Deal Amendment Id' ;
    rdfs:comment 'Unique identifier for the deal amendment record. Primary key.' ;
    rdfs:domain ind:DealAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Initiated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Contract amendments require structured tracking of internal initiator for audit trail, approval workflow routing, and accountability. Replaces text field initiator_contact_name with proper FK for work' ;
    rdfs:domain ind:DealAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByAmendmentDealAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Amendment Deal Amendment Id' ;
    rdfs:comment 'Reference to a subsequent amendment that replaces or supersedes this amendment. Null if this amendment is still current.' ;
    rdfs:domain ind:DealAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DealAmendment .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Business identifier for the amendment, typically following a sequential or hierarchical numbering scheme (e.g., AMD-001, AMD-002). Used for external reference and tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle state of the amendment: draft (in preparation), pending_approval (submitted for review), approved (authorized but not yet signed), executed (fully signed and in effect), rejected (declined by one or both parties), superseded (replaced by a newer amendment).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the amendment by its primary purpose: financial (pricing, payment terms, royalty rates), territorial (geographic rights expansion or restriction), term_extension (contract duration changes), content_scope (addition or removal of titles/episodes), rights_modification (windowing, exclusivity, sublicensing changes), or technical (delivery specifications, format requirements).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalChain rdf:type rdf:Property ;
    rdfs:label 'Approval Chain' ;
    rdfs:comment 'Structured or comma-separated list of internal approvers and their approval status (e.g., \'Legal:Approved, Finance:Approved, VP Content:Pending\'). Tracks the internal authorization workflow.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clausesModified rdf:type rdf:Property ;
    rdfs:label 'Clauses Modified' ;
    rdfs:comment 'Comma-separated list or structured reference to the specific contract clauses, sections, or articles being amended (e.g., \'Section 3.2 Payment Terms, Section 5.1 Territory, Exhibit A Content Schedule\').' ;
    rdfs:domain ind:DealAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentScopeChange rdf:type rdf:Property ;
    rdfs:label 'Content Scope Change' ;
    rdfs:comment 'Description of changes to the content covered by the agreement, including titles, episodes, seasons, or genres added or removed. Null for amendments that do not modify content scope.' ;
    rdfs:domain ind:DealAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'File path, document management system identifier, or URI pointing to the executed amendment document (PDF, DOCX, or scanned image).' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'Indicates which party requested the amendment: internal (broadcaster initiated), partner (studio/syndicator/distributor initiated), or mutual (jointly proposed).' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Internal Signatory Name' ;
    rdfs:comment 'Name of the authorized representative from the broadcasting organization who signed the amendment.' ;
    rdfs:domain ind:DealAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Internal Signatory Title' ;
    rdfs:comment 'Job title or role of the internal signatory (e.g., \'SVP Content Acquisition\', \'Chief Business Officer\').' ;
    rdfs:domain ind:DealAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'Date on which legal review was completed and the amendment was cleared for execution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewerName rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer Name' ;
    rdfs:comment 'Name of the legal counsel or attorney who reviewed and approved the amendment language for compliance and risk.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Partner Signatory Name' ;
    rdfs:comment 'Name of the authorized representative from the partner organization who signed the amendment.' ;
    rdfs:domain ind:DealAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Partner Signatory Title' ;
    rdfs:comment 'Job title or role of the partner signatory (e.g., \'VP Business Affairs\', \'Director of Distribution\').' ;
    rdfs:domain ind:DealAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsModificationDescription rdf:type rdf:Property ;
    rdfs:label 'Rights Modification Description' ;
    rdfs:comment 'Narrative description of changes to rights granted, including windowing adjustments, exclusivity modifications, sublicensing permissions, or platform restrictions. Null for amendments that do not modify rights.' ;
    rdfs:domain ind:DealAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termExtensionMonths rdf:type rdf:Property ;
    rdfs:label 'Term Extension Months' ;
    rdfs:comment 'Number of months by which the agreement term is extended (positive) or shortened (negative). Null for amendments that do not modify the agreement duration.' ;
    rdfs:domain ind:DealAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Change Description' ;
    rdfs:comment 'Narrative description of territorial rights changes, including countries or regions added or removed from the agreement scope. Null for non-territorial amendments.' ;
    rdfs:domain ind:DealAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerDealApprovalId rdf:type rdf:Property ;
    rdfs:label 'Partner Deal Approval Id' ;
    rdfs:comment 'Unique identifier for the deal approval record. Primary key for the deal approval workflow entity.' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalConditions rdf:type rdf:Property ;
    rdfs:label 'Approval Conditions' ;
    rdfs:comment 'Stipulations or requirements that must be satisfied before deal execution. Examples include legal review completion, budget reallocation, or third-party consent.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDecision rdf:type rdf:Property ;
    rdfs:label 'Approval Decision' ;
    rdfs:comment 'Final determination rendered by the approver. Conditional approvals require fulfillment of specified conditions before execution.' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiration Date' ;
    rdfs:comment 'Date after which the approval is no longer valid and must be resubmitted. Ensures approvals reflect current business conditions and deal terms.' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Organizational tier required for sign-off. Escalation level determined by deal value, risk profile, and strategic impact.' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Request Number' ;
    rdfs:comment 'Business identifier for the approval request. Human-readable reference number used in communications and audit trails.' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalThresholdExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Exceeded Flag' ;
    rdfs:comment 'Indicates whether the deal value exceeds the monetary threshold requiring elevated approval. True triggers escalation to CFO or board per SOX authorization controls.' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approverEmail rdf:type rdf:Property ;
    rdfs:label 'Approver Email' ;
    rdfs:comment 'Email address of the approver for notification and audit purposes. Used for workflow routing and decision confirmation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverRole rdf:type rdf:Property ;
    rdfs:label 'Approver Role' ;
    rdfs:comment 'Functional role of the individual or committee authorized to approve. Examples include VP Content Acquisition, General Counsel, Chief Financial Officer (CFO), Board of Directors.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Commitment Amount' ;
    rdfs:comment 'Distribution payment obligation to Multichannel Video Programming Distributors (MVPD) or virtual Multichannel Video Programming Distributors (vMVPD). Material carriage fee agreements require CFO sign-off.' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Deal Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the deal value. Required for multi-currency deal portfolio management.' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Date and time when the approval decision was rendered. Critical for SOX audit trails and time-sensitive deal execution.' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationCount rdf:type rdf:Property ;
    rdfs:label 'Escalation Count' ;
    rdfs:comment 'Number of times the approval request has been escalated to a higher authority. Tracks workflow complexity and decision-making bottlenecks.' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financeReviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Finance Review Completed Date' ;
    rdfs:comment 'Date when finance department completed their review and cleared the deal for approval. Nullable if finance review is not required or still pending.' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financeReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Finance Review Required Flag' ;
    rdfs:comment 'Indicates whether finance department review is mandatory before approval. True for deals with material budget impact or complex payment structures.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipOwnershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Percentage' ;
    rdfs:comment 'Percentage of intellectual property rights retained or acquired in co-production arrangements. IP ownership implications require legal and executive approval.' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalReviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed Date' ;
    rdfs:comment 'Date when legal counsel completed their review and cleared the deal for approval. Nullable if legal review is not required or still pending.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Risk classification of the deal based on financial exposure, partner creditworthiness, and strategic impact. High and critical tiers require elevated approval levels.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicImportance rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance' ;
    rdfs:comment 'Business significance of the deal to corporate objectives. Transformational deals require board-level approval regardless of financial threshold.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier or URI to supporting documentation attached to the approval request. Includes deal summaries, financial models, and legal memos.' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Execution Date' ;
    rdfs:comment 'Desired date for deal execution and contract signing. Used to prioritize approval workflow and ensure timely decision-making.' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealNegotiationId rdf:type rdf:Property ;
    rdfs:label 'Deal Negotiation Id' ;
    rdfs:comment 'Unique identifier for the deal negotiation record. Primary key for the deal negotiation entity.' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDealEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Deal Employee Id' ;
    rdfs:comment 'Reference to the employee or business development executive assigned as the primary negotiator for this deal.' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:resultingAcquisitionDealId rdf:type rdf:Property ;
    rdfs:label 'Resulting Acquisition Deal Id' ;
    rdfs:comment 'Foreign key linking to partner.acquisition_deal. Business justification: deal_negotiation tracks the negotiation lifecycle. When negotiation completes successfully, it results in an executed deal. New FK: resulting_acquisition_deal_id → acquisition_deal.acquisition_deal_id' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcquisitionDeal .

ind:resultingAffiliateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Resulting Affiliate Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.affiliate_agreement. Business justification: deal_negotiation can result in affiliate_agreement. New FK: resulting_affiliate_agreement_id → affiliate_agreement.affiliate_agreement_id. Nullable (populated only when negotiation results in affiliat' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AffiliateAgreement .

ind:resultingCoproductionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Resulting Coproduction Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.coproduction_agreement. Business justification: deal_negotiation can result in coproduction_agreement. New FK: resulting_coproduction_agreement_id → coproduction_agreement.coproduction_agreement_id. Nullable (populated only when negotiation results' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoproductionAgreement .

ind:resultingDistributionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Resulting Distribution Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.distribution_agreement. Business justification: deal_negotiation can result in distribution_agreement. New FK: resulting_distribution_agreement_id → distribution_agreement.distribution_agreement_id. Nullable (populated only when negotiation results' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionAgreement .

ind:resultingSyndicationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Resulting Syndication Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.syndication_agreement. Business justification: deal_negotiation can result in syndication_agreement. New FK: resulting_syndication_agreement_id → syndication_agreement.syndication_agreement_id. Nullable (populated only when negotiation results in ' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SyndicationAgreement .

ind:targetGenreId rdf:type rdf:Property ;
    rdfs:label 'Target Genre Id' ;
    rdfs:comment 'Foreign key linking to content.genre. Business justification: Deal negotiations target specific content genres for portfolio strategy. Pipeline forecasting by genre, content gap analysis, competitive positioning assessment, and strategic acquisition planning req' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Genre .

ind:tertiaryDealLegalReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Deal Legal Reviewer Employee Id' ;
    rdfs:comment 'Reference to the legal counsel or attorney assigned to review this deal negotiation.' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agreedDealValue rdf:type rdf:Property ;
    rdfs:label 'Agreed Deal Value' ;
    rdfs:comment 'Final agreed total monetary value of the deal after negotiation, in the deal currency. Null until deal is finalized.' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date on which the finalized contract becomes legally effective and binding on the parties.' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'Date on which the contract term ends and rights revert or require renewal.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealCurrency rdf:type rdf:Property ;
    rdfs:label 'Deal Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all monetary values in this deal negotiation.' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyOpenIssues rdf:type rdf:Property ;
    rdfs:label 'Key Open Issues' ;
    rdfs:comment 'Summary of the primary unresolved issues or sticking points in the negotiation that require resolution before deal closure.' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Review Status' ;
    rdfs:comment 'Current status of the legal departments review of the deal terms and contract language.' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationStage rdf:type rdf:Property ;
    rdfs:label 'Negotiation Stage' ;
    rdfs:comment 'Current stage in the deal negotiation workflow lifecycle, from initial term sheet through final execution or closure. [ENUM-REF-CANDIDATE: term_sheet|initial_proposal|counter_offer|redline_review|legal_review|business_approval|executive_approval|board_approval|final_execution|closed_won|closed_lost — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationStatus rdf:type rdf:Property ;
    rdfs:label 'Negotiation Status' ;
    rdfs:comment 'Current operational status of the negotiation indicating whether it is actively progressing, on hold, escalated, or completed. [ENUM-REF-CANDIDATE: active|on_hold|escalated|pending_approval|approved|rejected|cancelled|completed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStructure rdf:type rdf:Property ;
    rdfs:label 'Payment Structure' ;
    rdfs:comment 'Description of the proposed or agreed payment terms and structure (e.g., upfront, milestone-based, revenue share, minimum guarantee plus percentage).' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedDealValue rdf:type rdf:Property ;
    rdfs:label 'Proposed Deal Value' ;
    rdfs:comment 'Total monetary value proposed by the initiating party for this deal, in the deal currency.' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redlineVersionCount rdf:type rdf:Property ;
    rdfs:label 'Redline Version Count' ;
    rdfs:comment 'Number of redlined contract versions exchanged during the negotiation process, indicating negotiation complexity.' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rightsDurationYears rdf:type rdf:Property ;
    rdfs:label 'Rights Duration Years' ;
    rdfs:comment 'Duration in years for which content rights are being negotiated or agreed.' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetCloseDate rdf:type rdf:Property ;
    rdfs:label 'Target Close Date' ;
    rdfs:comment 'Target date by which the parties aim to finalize and execute the deal agreement.' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termSheetDate rdf:type rdf:Property ;
    rdfs:label 'Term Sheet Date' ;
    rdfs:comment 'Date on which the initial term sheet was presented or agreed upon by the parties.' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryObligationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Obligation Id' ;
    rdfs:comment 'Primary key for delivery_obligation' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveredAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Delivered Asset Version Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_version. Business justification: Delivery obligations specify exact version/format requirements (HD vs 4K, dubbed vs subtitled). Tracks which specific version satisfies contractual delivery for acceptance sign-off, QC validation, and' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:programScheduleId rdf:type rdf:Property ;
    rdfs:label 'Program Schedule Id' ;
    rdfs:comment 'Foreign key linking to scheduling.program_schedule. Business justification: Content delivery obligations tie to specific broadcast schedules for fulfillment tracking (e.g., deliver episode 3 days before scheduled air date). Critical for partner SLA compliance, on-time deliver' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramSchedule .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the partner formally accepted the delivered content as meeting technical and contractual specifications.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:audioTrackLanguages rdf:type rdf:Property ;
    rdfs:label 'Audio Track Languages' ;
    rdfs:comment 'Comma-separated list of audio track languages that must be included in the delivery, using ISO 639 codes.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDeadline rdf:type rdf:Property ;
    rdfs:label 'Delivery Deadline' ;
    rdfs:comment 'Contractually agreed date by which the content must be delivered to the partner.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Physical or network location where the content must be delivered, such as FTP server address, CDN endpoint, or facility address.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isanIdentifier rdf:type rdf:Property ;
    rdfs:label 'Isan Identifier' ;
    rdfs:comment 'International Standard Audiovisual Number uniquely identifying the audiovisual work being delivered.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Number' ;
    rdfs:comment 'Business identifier for the delivery obligation, typically referenced in contracts and communications.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Qc Completion Date' ;
    rdfs:comment 'Date on which quality control review was completed and content was approved for delivery.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Control Status' ;
    rdfs:comment 'Status of quality control review process for the content before delivery to ensure technical compliance.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redeliveryRequired rdf:type rdf:Property ;
    rdfs:label 'Redelivery Required' ;
    rdfs:comment 'Indicates whether the content must be redelivered due to rejection or technical issues with the initial delivery.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredBitrateMbps rdf:type rdf:Property ;
    rdfs:label 'Required Bitrate Mbps' ;
    rdfs:comment 'Minimum or target bitrate in megabits per second required for the delivered content to meet quality standards.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredCodec rdf:type rdf:Property ;
    rdfs:label 'Required Codec' ;
    rdfs:comment 'Video and audio codec specifications required for the delivery, such as H.264, H.265, AAC, or Dolby Digital.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredFormat rdf:type rdf:Property ;
    rdfs:label 'Required Format' ;
    rdfs:comment 'Technical delivery format required by the partner, such as HLS (HTTP Live Streaming), MPEG-DASH (Dynamic Adaptive Streaming over HTTP), or mezzanine file format.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredResolution rdf:type rdf:Property ;
    rdfs:label 'Required Resolution' ;
    rdfs:comment 'Video resolution specification required for delivery, ranging from standard definition to ultra-high definition.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCompliance rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance' ;
    rdfs:comment 'Indicates whether the delivery was completed within the service level agreement timeframe specified in the partner contract.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Included' ;
    rdfs:comment 'Indicates whether Media Broadcasting retains the right to audit the distributors subscriber counts, revenue reports, and compliance with agreement terms.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelsIncluded rdf:type rdf:Property ;
    rdfs:label 'Channels Included' ;
    rdfs:comment 'List or description of Media Broadcasting channels covered by this distribution agreement (e.g., primary network, secondary channels, HD feeds, regional variants).' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'URL or file path to the signed distribution agreement contract document stored in the document management system.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryObligation rdf:type rdf:Property ;
    rdfs:label 'Must Carry Obligation' ;
    rdfs:comment 'Indicates whether this agreement includes must-carry obligations under FCC regulations requiring the distributor to carry the broadcast signal.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiatedBy rdf:type rdf:Property ;
    rdfs:label 'Negotiated By' ;
    rdfs:comment 'Name or identifier of the Media Broadcasting executive or team responsible for negotiating this distribution agreement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Hours' ;
    rdfs:comment 'Maximum response time in hours for addressing service disruptions or technical issues under the SLA.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:streamingRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Streaming Rights Included' ;
    rdfs:comment 'Indicates whether the agreement includes rights for the distributor to offer live streaming or simulcast of Media Broadcasting channels via OTT platforms.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:svodRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Svod Rights Included' ;
    rdfs:comment 'Indicates whether the agreement includes rights for the distributor to offer Subscription Video On Demand (SVOD) access as part of a subscription package.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason for early termination of the agreement, if applicable (e.g., breach of contract, mutual agreement, business closure).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tvodRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Tvod Rights Included' ;
    rdfs:comment 'Indicates whether the agreement includes rights for the distributor to offer Transactional Video On Demand (TVOD) access where viewers pay per transaction.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vodRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Vod Rights Included' ;
    rdfs:comment 'Indicates whether the agreement includes rights for the distributor to offer Video On Demand (VOD) access to Media Broadcasting content.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vodWindowDays rdf:type rdf:Property ;
    rdfs:label 'Vod Window Days' ;
    rdfs:comment 'Number of days that content remains available in the distributors VOD library after initial broadcast, if VOD rights are included.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumGuaranteeId rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Id' ;
    rdfs:comment 'Unique identifier for the minimum guarantee commitment within a content acquisition deal.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoupmentInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Recoupment Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: MG recoupment tracking requires linking actual invoiced revenue (syndication fees, royalty statements) back to the guarantee for overage calculation, royalty true-ups, and partner financial reporting.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:accountingTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Accounting Treatment Code' ;
    rdfs:comment 'The financial accounting classification for the minimum guarantee: asset (capitalized content cost), expense (immediate P&L impact), deferred expense (amortized over time), prepaid (advance payment), or liability (obligation to provider).' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amortizationMethod rdf:type rdf:Property ;
    rdfs:label 'Amortization Method' ;
    rdfs:comment 'The method used to amortize the minimum guarantee cost over its useful life: straight-line (equal periods), usage-based (viewership-driven), revenue-based (proportional to earnings), accelerated (front-loaded), or none (expensed immediately).' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Final Payment Date' ;
    rdfs:comment 'The date when the last scheduled minimum guarantee payment was made or is due. Relevant for installment or milestone-based payment structures.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstPaymentDate rdf:type rdf:Property ;
    rdfs:label 'First Payment Date' ;
    rdfs:comment 'The date when the initial minimum guarantee payment was made or is scheduled to be made to the content provider.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fullyRecoupedDate rdf:type rdf:Property ;
    rdfs:label 'Fully Recouped Date' ;
    rdfs:comment 'The date when the minimum guarantee was fully recouped and the outstanding balance reached zero. After this date, overage royalty terms apply to additional revenue.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCrossCollateralized rdf:type rdf:Property ;
    rdfs:label 'Is Cross Collateralized' ;
    rdfs:comment 'Indicates whether this minimum guarantee can be recouped from revenue generated by other content titles or deals with the same provider (true) or is isolated to this specific deal (false).' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecoupable rdf:type rdf:Property ;
    rdfs:label 'Is Recoupable' ;
    rdfs:comment 'Indicates whether the minimum guarantee can be recouped from revenue (true) or is a non-recoupable floor payment (false). Non-recoupable MGs are paid regardless of performance with no offset.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRecoupmentCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Last Recoupment Calculation Date' ;
    rdfs:comment 'The date when the most recent recoupment calculation was performed, updating the recouped to date and outstanding balance amounts.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mgAmount rdf:type rdf:Property ;
    rdfs:label 'Mg Amount' ;
    rdfs:comment 'The floor payment amount owed to the content provider regardless of actual viewership or revenue performance. This is the baseline financial commitment.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mgNumber rdf:type rdf:Property ;
    rdfs:label 'Mg Number' ;
    rdfs:comment 'Business identifier for the minimum guarantee commitment, used in contracts and financial reconciliation.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mgStatus rdf:type rdf:Property ;
    rdfs:label 'Mg Status' ;
    rdfs:comment 'Current lifecycle state of the minimum guarantee: draft (under negotiation), active (in effect), partially recouped (some revenue applied), fully recouped (MG threshold met), overage (revenue exceeds MG), expired (term ended), or terminated (contract cancelled). [ENUM-REF-CANDIDATE: draft|active|partially_recouped|fully_recouped|overage|expired|terminated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mgType rdf:type rdf:Property ;
    rdfs:label 'Mg Type' ;
    rdfs:comment 'Classification of the minimum guarantee structure: flat (single fixed payment), tiered (stepped payments based on milestones), performance-based (adjusted by viewership), hybrid (combination), recoupable (can be offset by revenue share), or non-recoupable (floor payment regardless of performance).' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRecoupmentCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Next Recoupment Calculation Date' ;
    rdfs:comment 'The scheduled date for the next recoupment calculation cycle. Typically aligned with monthly, quarterly, or annual reporting periods.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outstandingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance Amount' ;
    rdfs:comment 'Remaining minimum guarantee amount not yet recouped. Calculated as MG amount minus recouped to date amount. When zero, the MG is fully recouped.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageAmount rdf:type rdf:Property ;
    rdfs:label 'Overage Amount' ;
    rdfs:comment 'Revenue earned beyond the minimum guarantee threshold. Once the MG is fully recouped, additional revenue share payments are calculated on this overage amount per the contract terms.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageRoyaltyRate rdf:type rdf:Property ;
    rdfs:label 'Overage Royalty Rate' ;
    rdfs:comment 'The percentage rate applied to overage revenue to calculate additional royalty payments owed to the content provider after the minimum guarantee is fully recouped. Typically ranges from 0.00 to 100.00 percent.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Description' ;
    rdfs:comment 'Detailed narrative of the payment schedule, milestones, and conditions governing the minimum guarantee disbursement. Includes specific dates, amounts, and triggering events.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoupedToDateAmount rdf:type rdf:Property ;
    rdfs:label 'Recouped To Date Amount' ;
    rdfs:comment 'Cumulative revenue amount that has been applied against the minimum guarantee as of the current reporting period. Tracks progress toward full recoupment.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoupmentBasis rdf:type rdf:Property ;
    rdfs:label 'Recoupment Basis' ;
    rdfs:comment 'The revenue or performance metric against which the minimum guarantee is recouped: gross revenue (total), net revenue (after costs), advertising revenue (CPM/GRP-based), subscription revenue (SVOD/ARPU), combined revenue (multi-stream), or viewership metric (Nielsen ratings, reach).' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoupmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Recoupment Percentage' ;
    rdfs:comment 'The percentage of revenue (based on recoupment basis) that is applied toward recouping the minimum guarantee. Typically ranges from 0.00 to 100.00 percent.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoupmentPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Recoupment Period Months' ;
    rdfs:comment 'The duration in months over which the minimum guarantee can be recouped from revenue. Common periods are 12, 24, 36, or 60 months depending on content type and windowing strategy.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoupmentWaterfallDescription rdf:type rdf:Property ;
    rdfs:label 'Recoupment Waterfall Description' ;
    rdfs:comment 'Detailed explanation of the revenue allocation sequence and priority order for recouping the minimum guarantee. Defines which revenue streams are applied first and how costs are deducted before recoupment.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerAuditEventId rdf:type rdf:Property ;
    rdfs:label 'Partner Audit Event Id' ;
    rdfs:comment 'Unique identifier for the partner audit event record. Primary key.' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditedInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Audited Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Partner audits (royalty audits, subscriber count verification audits, revenue share audits) examine specific invoices for accuracy. Linking audit events to invoices enables audit trail documentation, ' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:disputedContentTitleId rdf:type rdf:Property ;
    rdfs:label 'Disputed Content Title Id' ;
    rdfs:comment 'Foreign key linking to content.title. Business justification: Audits often dispute specific title performance data, revenue allocation, or delivery compliance. Audit finding resolution, adjustment calculation, evidence documentation, and settlement negotiation r' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:internalCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Internal Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Partner audits require internal coordinator tracking for liaison with external auditors, document gathering, response management, and follow-up. Essential for audit workload planning, response time tr' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:partnerAgreementId rdf:type rdf:Property ;
    rdfs:label 'Partner Agreement Id' ;
    rdfs:comment 'Identifier of the specific partner agreement under which the audit right is being exercised. Links to the contract containing audit provisions.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerAgreement .

ind:adjustmentAmountCurrency rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the adjustment amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCost rdf:type rdf:Property ;
    rdfs:label 'Audit Cost' ;
    rdfs:comment 'The total cost incurred for conducting the audit, including audit firm fees, internal resource costs, travel expenses, and other related costs. Used for cost recovery and budget tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Audit Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the audit cost (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingSummary rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Summary' ;
    rdfs:comment 'High-level summary of the audit findings, including key discrepancies, compliance issues, or areas of concern identified during the audit.' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFirmName rdf:type rdf:Property ;
    rdfs:label 'Audit Firm Name' ;
    rdfs:comment 'Name of the external audit firm or internal audit team conducting the audit. May be a third-party accounting firm, specialized media audit firm, or internal audit department.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Audit Initiated Date' ;
    rdfs:comment 'The date on which the audit was formally initiated, typically when the audit notice was sent to the partner or when the audit firm was engaged.' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Reference Number' ;
    rdfs:comment 'External reference number or code assigned to this audit event by the auditing party or audit firm for tracking and correspondence purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the scope of the audit, including the specific content, time periods, territories, revenue streams, or cost categories being examined.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit event. Planned audits are scheduled but not started; in-progress audits are actively being conducted; fieldwork complete indicates data collection is done; draft report indicates preliminary findings are documented; final report indicates audit is complete; disputed indicates findings are contested; resolved indicates disputes are settled; closed indicates all actions are complete. [ENUM-REF-CANDIDATE: planned|in_progress|fieldwork_complete|draft_report|final_report|disputed|resolved|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrigger rdf:type rdf:Property ;
    rdfs:label 'Audit Trigger' ;
    rdfs:comment 'The event or condition that initiated the audit. Scheduled audits are routine contractual audits; threshold breach audits are triggered by variance thresholds; dispute audits arise from disagreements; regulatory audits are mandated by authorities; random audits are part of compliance sampling; partner request audits are initiated by the partner.' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costRecoveryStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Recovery Status' ;
    rdfs:comment 'Status of recovering audit costs from the partner when contractually permitted. Not applicable if costs are not recoverable; pending if recovery not yet initiated; invoiced if bill sent; partially recovered if some payment received; fully recovered if all costs reimbursed; waived if costs forgiven.' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmountCurrency rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the disputed amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftReportDate rdf:type rdf:Property ;
    rdfs:label 'Draft Report Date' ;
    rdfs:comment 'The date on which the draft audit report was issued to the partner for review and response before finalization.' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkEndDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork End Date' ;
    rdfs:comment 'The date on which the audit fieldwork was completed, when auditors finished their on-site or remote examination activities.' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkStartDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Start Date' ;
    rdfs:comment 'The date on which the audit fieldwork began, when auditors started examining records, conducting interviews, and gathering evidence.' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalReportDate rdf:type rdf:Property ;
    rdfs:label 'Final Report Date' ;
    rdfs:comment 'The date on which the final audit report was issued, incorporating partner responses and auditor conclusions.' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Date' ;
    rdfs:comment 'The scheduled or actual date of the follow-up audit to verify corrective action implementation and compliance.' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required' ;
    rdfs:comment 'Indicates whether a follow-up audit is required to verify implementation of corrective actions or to re-examine areas of concern. True if subsequent audit is mandated.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor responsible for conducting and overseeing the audit engagement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerResponseDate rdf:type rdf:Property ;
    rdfs:label 'Partner Response Date' ;
    rdfs:comment 'The date on which the partner formally responded to the draft or final audit report, providing their position on the findings.' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerResponseSummary rdf:type rdf:Property ;
    rdfs:label 'Partner Response Summary' ;
    rdfs:comment 'Summary of the partners formal response to the audit findings, including their agreement, disagreement, explanations, or proposed corrective actions.' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerContactId rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Id' ;
    rdfs:comment 'Unique identifier for the partner contact record. Primary key.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assistantEmail rdf:type rdf:Property ;
    rdfs:label 'Assistant Email' ;
    rdfs:comment 'The email address of the contacts executive assistant, used for meeting coordination and scheduling.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantName rdf:type rdf:Property ;
    rdfs:label 'Assistant Name' ;
    rdfs:comment 'The name of the contacts executive assistant or administrative support person, if applicable. Used for scheduling and coordination.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantPhone rdf:type rdf:Property ;
    rdfs:label 'Assistant Phone' ;
    rdfs:comment 'The phone number of the contacts executive assistant, used for urgent scheduling needs and coordination.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationLanguage rdf:type rdf:Property ;
    rdfs:label 'Communication Language' ;
    rdfs:comment 'The preferred language for business communications with this contact, specified using ISO 639-1 two-letter language codes (e.g., EN, ES, FR).' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the partner contact. Indicates whether the contact is actively engaged, temporarily unavailable, or no longer with the partner organization.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractSignatory rdf:type rdf:Property ;
    rdfs:label 'Contract Signatory' ;
    rdfs:comment 'Boolean flag indicating whether this contact has legal authority to sign contracts and binding agreements on behalf of the partner organization.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionMakingAuthority rdf:type rdf:Property ;
    rdfs:label 'Decision Making Authority' ;
    rdfs:comment 'The level of decision-making authority the contact has within their organization for partnership matters, contract negotiations, and business agreements.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for the partner contact. Used for official communications, contract negotiations, and business correspondence.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'The first name or given name of the partner contact individual.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'The complete formatted name of the partner contact, typically combining first, middle, and last names.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Boolean flag indicating whether this contact is the primary or main point of contact for the partner organization.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'The official job title or position of the contact within the partner organization (e.g., Vice President of Content Acquisition, Director of Business Development, Legal Counsel).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'The date of the most recent business interaction or communication with this partner contact. Used for relationship health tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'The last name or family name of the partner contact individual.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'The URL to the contacts professional LinkedIn profile, used for professional networking and background verification.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile or cell phone number for the partner contact, used for urgent communications and on-the-go accessibility.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaSignedDate rdf:type rdf:Property ;
    rdfs:label 'Nda Signed Date' ;
    rdfs:comment 'The date when the contact signed a non-disclosure agreement with Media Broadcasting, if applicable. Used to track confidentiality obligations.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledContactDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Contact Date' ;
    rdfs:comment 'The planned date for the next scheduled interaction or follow-up with this partner contact. Supports proactive relationship management.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'The physical office location or city where the contact is based within the partner organization.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary business phone number for the partner contact, including country code and extension if applicable.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Method' ;
    rdfs:comment 'The contacts preferred method of communication for business interactions and negotiations.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'The functional role category of the contact within the partnership context. Defines the primary area of responsibility and engagement. [ENUM-REF-CANDIDATE: executive|legal|business_development|technical|finance|operations|marketing — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'The user identifier or name of the person who last modified this partner contact record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerDisputeId rdf:type rdf:Property ;
    rdfs:label 'Partner Dispute Id' ;
    rdfs:comment 'Unique identifier for the partner dispute record. Primary key.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputedTitleId rdf:type rdf:Property ;
    rdfs:label 'Disputed Title Id' ;
    rdfs:comment 'Foreign key linking to content.title. Business justification: Disputes frequently concern specific title rights interpretation, royalty calculations, or delivery specifications. Legal case management, settlement negotiation, evidence gathering, and contract inte' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date on which the receiving party formally acknowledged receipt of the dispute.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:arbitrationBody rdf:type rdf:Property ;
    rdfs:label 'Arbitration Body' ;
    rdfs:comment 'Name of the arbitration organization or body handling the dispute (e.g., American Arbitration Association, JAMS).' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Arbitration Case Number' ;
    rdfs:comment 'External case or docket number assigned by the arbitration body.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationRequired rdf:type rdf:Property ;
    rdfs:label 'Arbitration Required' ;
    rdfs:comment 'Indicates whether the dispute requires or has entered binding arbitration per contractual dispute resolution clauses.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignedToDepartment rdf:type rdf:Property ;
    rdfs:label 'Assigned To Department' ;
    rdfs:comment 'Name of the internal department or functional area currently handling the dispute (e.g., Finance, Legal, Operations).' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeCategory rdf:type rdf:Property ;
    rdfs:label 'Dispute Category' ;
    rdfs:comment 'High-level category grouping disputes by functional area for reporting and routing purposes.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Externally-visible unique reference number assigned to the dispute for tracking and communication purposes.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount Usd' ;
    rdfs:comment 'The monetary value in dispute, expressed in USD. Represents the financial exposure or claim amount.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputedPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Disputed Period End Date' ;
    rdfs:comment 'End date of the time period to which the dispute relates.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputedPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Disputed Period Start Date' ;
    rdfs:comment 'Start date of the time period to which the dispute relates (e.g., billing cycle, content delivery window).' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evidenceSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Evidence Submitted Date' ;
    rdfs:comment 'Date on which supporting evidence was submitted by the disputing party.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filedDate rdf:type rdf:Property ;
    rdfs:label 'Filed Date' ;
    rdfs:comment 'Date on which the dispute was formally filed or raised by either party.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalHoldDate rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Date' ;
    rdfs:comment 'Date on which the legal hold was initiated for this dispute.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalHoldStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Status' ;
    rdfs:comment 'Indicates whether a legal hold has been placed on records and communications related to this dispute for litigation preservation.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediationRequired rdf:type rdf:Property ;
    rdfs:label 'Mediation Required' ;
    rdfs:comment 'Indicates whether the dispute requires or has entered formal mediation per contractual dispute resolution clauses.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Taken' ;
    rdfs:comment 'Description of corrective or preventive actions implemented to avoid recurrence of similar disputes.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionSummary rdf:type rdf:Property ;
    rdfs:label 'Resolution Summary' ;
    rdfs:comment 'Narrative summary of the resolution terms, settlement agreement, or arbitration decision.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount Usd' ;
    rdfs:comment 'Final settlement amount agreed upon or awarded, expressed in USD. May differ from the originally disputed amount.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportingEvidenceLocation rdf:type rdf:Property ;
    rdfs:label 'Supporting Evidence Location' ;
    rdfs:comment 'File path, document repository reference, or Media Asset Management (MAM) location where supporting evidence and documentation are stored.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPartnerId rdf:type rdf:Property ;
    rdfs:label 'Parent Partner Id' ;
    rdfs:comment 'Reference to the parent partner entity in cases where this partner is a subsidiary or division of a larger corporate entity. Enables tracking of corporate hierarchies and consolidated relationships. Null for top-level parent entities.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:annualContentVolumeHours rdf:type rdf:Property ;
    rdfs:label 'Annual Content Volume Hours' ;
    rdfs:comment 'Estimated or actual annual volume of content hours acquired from or distributed through this partner. Used for capacity planning, content pipeline forecasting, and partner performance evaluation.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenueContributionUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Contribution Usd' ;
    rdfs:comment 'Estimated or actual annual revenue contribution from this partner relationship in USD. Includes content licensing fees, distribution revenue share, advertising revenue, or other monetization streams. Used for partner valuation and ROI analysis.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentSpecialization rdf:type rdf:Property ;
    rdfs:label 'Content Specialization' ;
    rdfs:comment 'Primary content genres, formats, or categories that the partner specializes in producing or distributing. Examples include scripted drama, unscripted reality, sports, news, children\'s programming, documentary, or multi-genre. Supports content acquisition strategy and partner matching.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Date' ;
    rdfs:comment 'Next scheduled date for master agreement renewal or renegotiation with this partner. Used for relationship management planning, contract pipeline tracking, and ensuring continuity of content supply or distribution.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:corporateHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Corporate Hierarchy Level' ;
    rdfs:comment 'Numeric level in the corporate hierarchy tree where 1 represents the ultimate parent entity and higher numbers represent deeper subsidiary levels. Used for roll-up reporting and consolidated analytics.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'External credit rating assigned by rating agencies such as Moody\'s, S&P, or Fitch. Used for financial risk assessment, contract negotiation, and determining payment terms or guarantees required.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionTerritories rdf:type rdf:Property ;
    rdfs:label 'Distribution Territories' ;
    rdfs:comment 'Geographic territories or markets where the partner operates or holds distribution rights. Stored as comma-separated list of country codes or region identifiers. Critical for rights management and windowing strategy.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domicileCountryCode rdf:type rdf:Property ;
    rdfs:label 'Domicile Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the legal domicile jurisdiction where the partner entity is incorporated or registered. Determines applicable regulatory frameworks and tax treaties.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit unique identifier assigned by Dun & Bradstreet to identify business entities globally. Used for credit assessment, vendor management, and corporate hierarchy tracking.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'First line of the physical headquarters address including street number and street name. Used for legal correspondence, contract execution, and regulatory filings.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line2' ;
    rdfs:comment 'Second line of the physical headquarters address for suite, floor, building name, or other secondary address details.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Indicates whether the partnership includes exclusivity provisions that restrict either party from engaging with competing partners in specified territories, content categories, or distribution channels. Critical for rights management and competitive strategy.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingStage rdf:type rdf:Property ;
    rdfs:label 'Onboarding Stage' ;
    rdfs:comment 'Current stage in the partner onboarding workflow. Tracks progression from initial prospect through due diligence, contract negotiation, legal review, approval, and final onboarding completion.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPaymentTerms rdf:type rdf:Property ;
    rdfs:label 'Preferred Payment Terms' ;
    rdfs:comment 'Standard payment terms negotiated with the partner for content licensing, royalties, or service fees. Examples include Net 30, Net 60, advance against royalties, or milestone-based payments. Feeds into accounts payable and cash flow planning.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date when the business relationship with this partner was formally terminated or is scheduled to end. Null for active ongoing relationships. Used for historical analysis and transition planning.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date when the business relationship with this partner was formally established, typically corresponding to the first executed agreement or onboarding completion. Used for relationship tenure analysis and anniversary tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strategicTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Tier' ;
    rdfs:comment 'Classification of the partner\'s strategic importance to the business. Tier 1 represents critical strategic partners with significant content volume or distribution reach, Tier 2 represents important but not critical partners, Tier 3 represents transactional relationships, and emerging represents new partners under evaluation.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Secondary classification providing additional granularity within the partner type. Examples include major studio vs independent studio, first-run syndicator vs off-network syndicator, FAST channel operator, co-production house, or affiliate network.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermId rdf:type rdf:Property ;
    rdfs:label 'Payment Term Id' ;
    rdfs:comment 'Unique identifier for the partner payment term record. Primary key.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestoneInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Milestone Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Partner payment terms define milestone-based invoicing (delivery milestones, window activation, subscriber thresholds). Linking actual invoices to terms enables payment compliance tracking, late payme' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:paymentScheduleId rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule Id' ;
    rdfs:comment 'Reference to a detailed payment schedule record that breaks down this term into multiple installments or recurring payments.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentSchedule .

ind:invoiceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Invoice Required Flag' ;
    rdfs:comment 'Indicates whether the partner must submit an invoice before payment can be processed. True if invoice is required, False if payment is automatic or self-billed.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latePaymentGracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Late Payment Grace Period Days' ;
    rdfs:comment 'Number of days after the payment due date during which no late payment penalty is assessed, allowing the payer time to remit without financial consequence.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The gross monetary value of the payment obligation before any adjustments, taxes, or withholdings. Expressed in the currency specified in the currency_code field.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Approval Required Flag' ;
    rdfs:comment 'Indicates whether internal approval is required before payment can be released. True if approval workflow must be completed, False if payment is automatic upon due date.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentBankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Bank Account Number' ;
    rdfs:comment 'Reference to the partner\'s bank account record where payment should be remitted. Used for wire transfer and ACH payments.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentMilestone rdf:type rdf:Property ;
    rdfs:label 'Payment Milestone' ;
    rdfs:comment 'Business event or condition that triggers this payment obligation (e.g., \'Upon Delivery\', \'First Broadcast\', \'Quarterly Arrears\', \'Upon Execution\', \'Net 30 Days from Invoice\').' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNotes rdf:type rdf:Property ;
    rdfs:label 'Payment Notes' ;
    rdfs:comment 'Internal notes or comments regarding this payment term, including any special handling instructions, dispute history, or reconciliation issues.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRemittanceEmail rdf:type rdf:Property ;
    rdfs:label 'Payment Remittance Email' ;
    rdfs:comment 'Email address to which payment remittance advice and confirmation should be sent. May differ from the partner\'s primary contact email.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termNumber rdf:type rdf:Property ;
    rdfs:label 'Term Number' ;
    rdfs:comment 'Business identifier for this payment term, often used in invoicing and reconciliation. May follow partner-specific or internal numbering conventions.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termType rdf:type rdf:Property ;
    rdfs:label 'Term Type' ;
    rdfs:comment 'Classification of the payment term based on the nature of the financial obligation: acquisition fee (content licensing), carriage fee (distribution payment), syndication fee (content resale), co-production contribution (shared production cost), royalty (usage-based payment), or residual (talent reuse payment).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Jurisdiction' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the jurisdiction whose tax laws govern the withholding obligation (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachCount rdf:type rdf:Property ;
    rdfs:label 'Breach Count' ;
    rdfs:comment 'The cumulative number of times this performance obligation has been breached since the effective start date or last reset.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cureDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Cure Deadline Date' ;
    rdfs:comment 'The calculated deadline by which the partner must cure the most recent breach to avoid penalties. Null if no active breach exists.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:curePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Cure Period Days' ;
    rdfs:comment 'The number of days allowed for the partner to remedy a breach before penalties or escalation actions are triggered, as defined in the agreement.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastBreachDate rdf:type rdf:Property ;
    rdfs:label 'Last Breach Date' ;
    rdfs:comment 'The date of the most recent breach event for this performance obligation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMeasuredDate rdf:type rdf:Property ;
    rdfs:label 'Last Measured Date' ;
    rdfs:comment 'The date when the performance obligation was last evaluated for compliance.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMeasuredValue rdf:type rdf:Property ;
    rdfs:label 'Last Measured Value' ;
    rdfs:comment 'The actual measured value from the most recent compliance evaluation period.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Notification Date' ;
    rdfs:comment 'The date when the partner was last notified regarding the compliance status or breach of this performance obligation.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makegoodSpotsRequired rdf:type rdf:Property ;
    rdfs:label 'Makegood Spots Required' ;
    rdfs:comment 'The number of compensatory advertising spots or content deliveries required to remedy a breach, if makegood provision applies.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Measurement Period' ;
    rdfs:comment 'The time period over which the performance obligation is measured and evaluated for compliance. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annually|per_broadcast|per_delivery — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Required Flag' ;
    rdfs:comment 'Indicates whether the partner must be formally notified of compliance status or breach events for this obligation.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyType rdf:type rdf:Property ;
    rdfs:label 'Penalty Type' ;
    rdfs:comment 'The type of penalty or remedy applied when this performance obligation is breached, as specified in the partner agreement.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMetric rdf:type rdf:Property ;
    rdfs:label 'Sla Metric' ;
    rdfs:comment 'The specific metric being measured for this obligation (e.g., \'System Uptime Percentage\', \'Content Delivery Time\', \'Average Rating Points\', \'Subscriber Count\').' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdOperator rdf:type rdf:Property ;
    rdfs:label 'Threshold Operator' ;
    rdfs:comment 'The comparison operator used to evaluate compliance against the threshold value (e.g., greater than or equal to 99.9% uptime).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalId rdf:type rdf:Property ;
    rdfs:label 'Renewal Id' ;
    rdfs:comment 'Unique identifier for the partner renewal record. Primary key for tracking renewal lifecycle events across acquisition deals, distribution agreements, affiliate agreements, and syndication contracts.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Reference to the specific partner agreement being renewed. May link to acquisition deals, distribution agreements, affiliate agreements, syndication contracts, or co-production arrangements depending on agreement type.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerAgreement .

ind:renewalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Renewal Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for managing this partner relationship and driving the renewal process. Typically a content acquisition manager, distribution director, or partnership manager.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:renewalExecutiveApproverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Renewal Executive Approver Employee Id' ;
    rdfs:comment 'Reference to the senior executive with final approval authority. Typically Chief Content Officer, Chief Revenue Officer, or Chief Executive Officer depending on strategic importance and financial magnitude.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:renewalFinanceApproverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Renewal Finance Approver Employee Id' ;
    rdfs:comment 'Reference to the finance executive responsible for budget approval and financial impact assessment. Required approval level varies based on deal value thresholds.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:renewalLegalReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Renewal Legal Reviewer Employee Id' ;
    rdfs:comment 'Reference to the legal counsel assigned to review renewal terms, assess risk, and ensure compliance with regulatory requirements and corporate policies.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalWorkflowStage rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Stage' ;
    rdfs:comment 'Current stage in the multi-level approval process. Workflow stages and required approvers vary based on deal value thresholds, strategic importance, and organizational governance policies. [ENUM-REF-CANDIDATE: business_owner_review|legal_review|finance_review|executive_review|board_approval|final_approval|completed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Clause Flag' ;
    rdfs:comment 'Indicates whether the original agreement contains an automatic renewal provision. When true, agreement renews automatically unless explicit non-renewal notice is provided by the decision due date.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalTerms rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Terms' ;
    rdfs:comment 'Detailed description of automatic renewal provisions including renewal term length, rate escalation clauses, and conditions under which auto-renewal applies. Critical for preventing unintended contract extensions.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDueDate rdf:type rdf:Property ;
    rdfs:label 'Decision Due Date' ;
    rdfs:comment 'Deadline by which the organization must communicate renewal decision to the partner. Failure to meet this date may trigger auto-renewal clauses or result in unintended agreement lapse.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:keyTermsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Terms Summary' ;
    rdfs:comment 'Executive summary of material changes and key provisions in the proposed renewal including pricing adjustments, rights modifications, performance guarantees, and strategic commitments.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonRenewalReason rdf:type rdf:Property ;
    rdfs:label 'Non Renewal Reason' ;
    rdfs:comment 'Detailed explanation when renewal outcome is not_renewed or terminated. Captures business rationale such as poor content performance, unfavorable terms, strategic realignment, or partner performance issues.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalAgreementEndDate rdf:type rdf:Property ;
    rdfs:label 'Original Agreement End Date' ;
    rdfs:comment 'Expiration date of the current agreement term. Triggers renewal workflow initiation based on advance notice requirements specified in the contract.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalAgreementStartDate rdf:type rdf:Property ;
    rdfs:label 'Original Agreement Start Date' ;
    rdfs:comment 'Effective start date of the current agreement term being renewed. Provides historical context for relationship duration and performance evaluation.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalDealValueAmount rdf:type rdf:Property ;
    rdfs:label 'Original Deal Value Amount' ;
    rdfs:comment 'Total financial value of the current agreement term being renewed. Provides baseline for evaluating proposed renewal terms and calculating value change percentage.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outcomeDate rdf:type rdf:Property ;
    rdfs:label 'Outcome Date' ;
    rdfs:comment 'Date when final renewal decision was communicated to the partner. Critical for audit trail, compliance verification, and preventing disputes over notice timing.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Partner Performance Rating' ;
    rdfs:comment 'Overall assessment of partner performance during the current agreement term. Evaluates content quality, delivery timeliness, audience performance, rights compliance, and relationship collaboration. Key input to renewal decision.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedDealValueAmount rdf:type rdf:Property ;
    rdfs:label 'Proposed Deal Value Amount' ;
    rdfs:comment 'Total financial value of the proposed renewed agreement over its full term. Used for budget planning, financial forecasting, and executive approval thresholds.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedDealValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Proposed Deal Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the proposed deal value. Essential for multi-currency contract management and financial consolidation.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedEndDate rdf:type rdf:Property ;
    rdfs:label 'Proposed End Date' ;
    rdfs:comment 'Intended expiration date for the renewed agreement. Calculated from proposed start date plus proposed term length.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedPaymentTerms rdf:type rdf:Property ;
    rdfs:label 'Proposed Payment Terms' ;
    rdfs:comment 'Detailed payment schedule and terms for the renewed agreement including payment frequency, milestone-based payments, minimum guarantees, revenue share percentages, and payment methods.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedRenewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Proposed Renewal Term Months' ;
    rdfs:comment 'Duration in months for the proposed renewed agreement. May differ from original term based on negotiation outcomes, market conditions, or strategic relationship objectives.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedRightsScope rdf:type rdf:Property ;
    rdfs:label 'Proposed Rights Scope' ;
    rdfs:comment 'Description of content rights, distribution territories, platform exclusivity, windowing strategies, and sublicensing provisions proposed for the renewed agreement. Critical for rights management and content strategy alignment.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedStartDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Start Date' ;
    rdfs:comment 'Intended effective date for the renewed agreement. Typically aligns with original agreement end date to ensure continuity, but may include gap or overlap periods based on negotiation.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renegotiationPriority rdf:type rdf:Property ;
    rdfs:label 'Renegotiation Priority' ;
    rdfs:comment 'Business priority level for renegotiation efforts. Critical priority indicates strategic partnerships requiring executive involvement; low priority may allow standard renewal terms.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renegotiationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renegotiation Required Flag' ;
    rdfs:comment 'Indicates whether material terms must be renegotiated rather than simply renewed under existing terms. Set to true when market conditions, partner performance, or strategic priorities require substantive changes.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNumber rdf:type rdf:Property ;
    rdfs:label 'Renewal Number' ;
    rdfs:comment 'Business identifier for this renewal instance. Typically follows a pattern incorporating the original agreement number plus renewal sequence (e.g., ACQ-2023-001-R02 for second renewal).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Evaluation of risks associated with renewal including financial exposure, rights clearance issues, regulatory compliance concerns, partner stability, and competitive threats. Informs approval requirements and contract protections.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerDate rdf:type rdf:Property ;
    rdfs:label 'Trigger Date' ;
    rdfs:comment 'Date when the renewal evaluation process was initiated. Typically calculated based on original agreement end date minus advance notice period (e.g., 90 days, 180 days) specified in contract terms.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valueChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Value Change Percentage' ;
    rdfs:comment 'Percentage change between original deal value and proposed renewal value. Positive values indicate cost increases; negative values indicate cost reductions. Critical metric for financial impact assessment.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Negotiated By Employee Id' ;
    rdfs:comment 'Reference to the Media Broadcasting employee who negotiated and finalized this syndication agreement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:syndicationPartnerId rdf:type rdf:Property ;
    rdfs:label 'Syndication Partner Id' ;
    rdfs:comment 'Reference to the third-party broadcaster, regional station, or international network acquiring syndication rights.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:barterSpotCount rdf:type rdf:Property ;
    rdfs:label 'Barter Spot Count' ;
    rdfs:comment 'Number of advertising spots retained by Media Broadcasting per episode in barter syndication arrangements.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearanceObligation rdf:type rdf:Property ;
    rdfs:label 'Clearance Obligation' ;
    rdfs:comment 'Party responsible for obtaining broadcast clearances and rights verification in the syndication territory.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Window End Date' ;
    rdfs:comment 'End date of the exclusivity period. Nullable if exclusivity_flag is false.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Window Start Date' ;
    rdfs:comment 'Start date of the exclusivity period during which no other syndication partner may broadcast the content in the granted territory. Nullable if exclusivity_flag is false.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:perEpisodeFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Per Episode Fee Amount' ;
    rdfs:comment 'Fee amount charged per episode. Applicable when syndication_fee_structure is per_episode or hybrid.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceGuarantee rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee' ;
    rdfs:comment 'Minimum performance commitments required from the syndication partner, such as minimum broadcast frequency or audience reach targets.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runLimit rdf:type rdf:Property ;
    rdfs:label 'Run Limit' ;
    rdfs:comment 'Maximum number of times each episode may be broadcast by the syndication partner during the agreement term.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:syndicationFeeStructure rdf:type rdf:Property ;
    rdfs:label 'Syndication Fee Structure' ;
    rdfs:comment 'Compensation model governing how the syndication partner pays for content rights.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryGrant rdf:type rdf:Property ;
    rdfs:label 'Territory Grant' ;
    rdfs:comment 'Geographic territories where the syndication partner is granted broadcast rights. Pipe-separated list of ISO 3166-1 alpha-3 country codes or regional designations. [ENUM-REF-CANDIDATE: USA|CAN|GBR|AUS|DEU|FRA|JPN|BRA|MEX|IND|CHN — promote to reference product]' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryGrantId rdf:type rdf:Property ;
    rdfs:label 'Territory Grant Id' ;
    rdfs:comment 'Unique identifier for the territory grant record. Primary key.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Rights grants require legal reviewer tracking for clearance verification, compliance sign-off, and dispute resolution. Clearance_status exists but no FK to attorney who verified - critical for legal w' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:schedulingAvailabilityWindowId rdf:type rdf:Property ;
    rdfs:label 'Scheduling Availability Window Id' ;
    rdfs:comment 'Foreign key linking to scheduling.scheduling_availability_window. Business justification: Territory grants in partner agreements define where/when content can be scheduled (e.g., exclusive US broadcast rights 2024-2026). Essential for rights-compliant scheduling, avoiding territorial viola' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchedulingAvailabilityWindow .

ind:avodRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Avod Rights Flag' ;
    rdfs:comment 'Indicates whether Advertising-Supported Video On Demand distribution rights are included in this grant.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutZoneIndicator rdf:type rdf:Property ;
    rdfs:label 'Blackout Zone Indicator' ;
    rdfs:comment 'Flag indicating whether this grant defines a blackout zone where distribution is explicitly prohibited rather than authorized.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageFeeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Applicable Flag' ;
    rdfs:comment 'Indicates whether a carriage fee (distribution payment) is required for this territorial grant.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Verification Date' ;
    rdfs:comment 'Date when rights clearance was last verified for this territorial grant.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Grant Reference Code' ;
    rdfs:comment 'Business identifier for the territory grant, used in contracts and rights clearance documentation.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantType rdf:type rdf:Property ;
    rdfs:label 'Grant Type' ;
    rdfs:comment 'Type of territorial grant indicating exclusivity level. Exclusive grants prohibit other licensees in the territory; non-exclusive allows multiple licensees; co-exclusive allows a limited number of licensees; holdback restricts distribution during a specific window; reserved indicates rights retained by licensor.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackRestriction rdf:type rdf:Property ;
    rdfs:label 'Holdback Restriction' ;
    rdfs:comment 'Description of any holdback period or exclusivity restrictions that limit distribution during specific windows or in relation to other platforms. For example, a 90-day theatrical holdback before SVOD release.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageRestriction rdf:type rdf:Property ;
    rdfs:label 'Language Restriction' ;
    rdfs:comment 'Comma-separated list of ISO 639-2 language codes specifying which language versions are covered by this grant. Null if all language versions are included.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linearRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Linear Rights Flag' ;
    rdfs:comment 'Indicates whether traditional scheduled broadcast (linear) distribution rights are included in this grant.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaFormatRestriction rdf:type rdf:Property ;
    rdfs:label 'Media Format Restriction' ;
    rdfs:comment 'Restrictions on media formats or technical specifications (e.g., HD only, 4K excluded, standard definition only). Null if no format restrictions apply.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformScope rdf:type rdf:Property ;
    rdfs:label 'Platform Scope' ;
    rdfs:comment 'Comma-separated list of distribution platforms covered by this grant. May include: linear (traditional broadcast), SVOD (Subscription Video On Demand), AVOD (Advertising-Supported Video On Demand), TVOD (Transactional Video On Demand), OTT (Over-The-Top), theatrical, home video, FAST (Free Ad-Supported Streaming Television), MVPD (Multichannel Video Programming Distributor), vMVPD (Virtual Multichannel Video Programming Distributor).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Named region for multi-country grants (e.g., North America, European Union, Asia-Pacific, Latin America). Used when grant covers multiple countries as a group.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Required Flag' ;
    rdfs:comment 'Indicates whether retransmission consent (rebroadcast authorization) is required for this territorial grant under FCC regulations.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sublicensePermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Sublicense Permitted Flag' ;
    rdfs:comment 'Indicates whether the licensee is authorized to sublicense the territorial rights to third parties.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:svodRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Svod Rights Flag' ;
    rdfs:comment 'Indicates whether Subscription Video On Demand distribution rights are included in this grant.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tvodRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Tvod Rights Flag' ;
    rdfs:comment 'Indicates whether Transactional Video On Demand (pay-per-view, rental, electronic sell-through) distribution rights are included in this grant.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Cumulative actual costs incurred to date for this cost category, sourced from SAP S/4HANA FI/CO actual postings. Represents real expenditure against the approved budget.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'The formally approved budget amount for this cost category and version, representing the financial control baseline authorized by the production greenlight committee.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this budget record within the production finance system. Used for cross-system reference and reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Free-text narrative explaining the business justification for a budget revision (e.g., \'Schedule extension due to weather delays\', \'Additional VFX shots approved by director\'). Mandatory for revised versions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRequestReference rdf:type rdf:Property ;
    rdfs:label 'Change Request Reference' ;
    rdfs:comment 'Reference number of the formal budget change request (BCR) document that authorized a revision to this budget line, traceable in the production finance approval workflow.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Contingency Percentage' ;
    rdfs:comment 'The percentage of the approved budget allocated as contingency reserve for this cost category, representing the risk buffer approved by the production finance committee.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Cost Category Code' ;
    rdfs:comment 'SAP cost element or cost category code classifying the type of production expenditure (e.g., ATL-TALENT, BTL-CREW, BTL-EQUIPMENT, POST-VFX, POST-AUDIO). [ENUM-REF-CANDIDATE: ATL-TALENT|ATL-RIGHTS|BTL-CREW|BTL-EQUIPMENT|BTL-FACILITIES|BTL-TRAVEL|POST-VFX|POST-AUDIO|POST-COLOR|CONTINGENCY — promote to reference product]' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCategoryName rdf:type rdf:Property ;
    rdfs:label 'Cost Category Name' ;
    rdfs:comment 'Human-readable name of the production cost category (e.g., \'Above-the-Line Talent\', \'Below-the-Line Crew\', \'Visual Effects\', \'Audio Post-Production\').' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costLineType rdf:type rdf:Property ;
    rdfs:label 'Cost Line Type' ;
    rdfs:comment 'High-level classification of the cost line distinguishing above-the-line (ATL) creative costs (writers, directors, producers, talent) from below-the-line (BTL) technical and crew costs, post-production, contingency, and overhead.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastAmount rdf:type rdf:Property ;
    rdfs:label 'Forecast Amount' ;
    rdfs:comment 'Latest estimate of the total cost expected to be incurred for this cost category by production completion, incorporating actuals to date and projected remaining spend.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGreenlightBudget rdf:type rdf:Property ;
    rdfs:label 'Is Greenlight Budget' ;
    rdfs:comment 'Indicates whether this budget record represents the original greenlight-approved budget for the production, as distinct from subsequent revisions. The greenlight budget is the primary financial authorization baseline.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The end date of the fiscal or production period covered by this budget record. Defines the temporal boundary for cost accumulation and variance measurement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The start date of the fiscal or production period covered by this budget record, aligning to the SAP fiscal year/period structure.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionPhase rdf:type rdf:Property ;
    rdfs:label 'Production Phase' ;
    rdfs:comment 'The production lifecycle phase to which this budget line is attributed (e.g., Development, Pre-Production, Principal Photography, Post-Production, Delivery). Enables phase-level budget tracking.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the group reporting currency to which all amounts are translated for consolidated financial reporting (e.g., USD for a US-headquartered broadcaster).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Amount' ;
    rdfs:comment 'The most recently revised budget amount for this cost category following a formal budget change request. Null if no revision has been approved since the original budget.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapCostObjectCode rdf:type rdf:Property ;
    rdfs:label 'Sap Cost Object Code' ;
    rdfs:comment 'The SAP S/4HANA CO cost object identifier (Internal Order number or WBS Element ID) that anchors this budget record to the controlling module for financial reconciliation.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'SAP Project System Work Breakdown Structure element code that maps this budget line to a specific phase or deliverable within the production project hierarchy (e.g., PRE-PROD, PRINCIPAL, POST-PROD).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual budget line item within a production budget. Primary key for this entity.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetLine .

ind:accountCode rdf:type rdf:Property ;
    rdfs:label 'Account Code' ;
    rdfs:comment 'Industry-standard production account code identifying the cost category within the budget (e.g., 1100 for Above-the-Line Talent, 2200 for Camera Equipment). Follows standard production accounting chart of accounts (e.g., AICP, Producers Guild).' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accruedAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Amount' ;
    rdfs:comment 'Costs accrued for work performed or services received but not yet invoiced or formally committed. Supports period-end financial close and accurate cost-to-complete reporting.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'Total actual costs incurred and posted against this budget line to date, sourced from SAP FI invoice postings and payroll actuals. Used for variance analysis against budgeted and committed amounts.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedAmount rdf:type rdf:Property ;
    rdfs:label 'Budgeted Amount' ;
    rdfs:comment 'Original approved budget amount for this line item as established at greenlight or budget approval. Represents the planned cost baseline against which actuals and commitments are measured.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyPct rdf:type rdf:Property ;
    rdfs:label 'Contingency Pct' ;
    rdfs:comment 'Contingency percentage applied to this budget line to cover unforeseen cost overruns. Typically 5–15% for production lines. Contributes to the overall production contingency reserve.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'High-level cost category classifying the budget line within the production budget structure. Above-the-line covers creative talent (writers, directors, producers, cast); below-the-line covers crew, equipment, locations, and production services. [ENUM-REF-CANDIDATE: above_the_line|below_the_line|post_production|music_licensing|vfx|marketing|overhead|contingency|insurance|legal — promote to reference product]' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSubCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Sub Category' ;
    rdfs:comment 'Granular sub-classification within the cost category (e.g., \'Cast Fees\', \'Location Fees\', \'Equipment Rental\', \'VFX Compositing\', \'Music Synchronization License\', \'Post-Production Labor\'). Enables detailed variance analysis at the sub-category level.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fringeRatePct rdf:type rdf:Property ;
    rdfs:label 'Fringe Rate Pct' ;
    rdfs:comment 'Percentage applied to labor costs on this line to account for employer fringe benefits (payroll taxes, pension contributions, health insurance, residuals). Standard production accounting practice for above-the-line and below-the-line labor lines.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAboveTheLine rdf:type rdf:Property ;
    rdfs:label 'Is Above The Line' ;
    rdfs:comment 'Flag indicating whether this budget line is classified as above-the-line (ATL) cost, covering creative talent such as writers, directors, producers, and principal cast. False indicates below-the-line (BTL) cost.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnionLabor rdf:type rdf:Property ;
    rdfs:label 'Is Union Labor' ;
    rdfs:comment 'Flag indicating whether this budget line involves union or guild labor subject to collective bargaining agreements (DGA, SAG-AFTRA, WGA, IATSE). Drives fringe rate calculations and residuals obligations.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Free-text description of the specific cost item represented by this budget line (e.g., \'Lead Actor Day Rate — Week 3\', \'Steadicam Rental — Principal Photography\', \'Dolby Atmos Mix — Episode 4\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedBudgetedAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Budgeted Amount' ;
    rdfs:comment 'Most recent approved revision to the budgeted amount, reflecting approved change orders, scope changes, or budget transfers. Null if no revision has been approved since original budget.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shootDateEnd rdf:type rdf:Property ;
    rdfs:label 'Shoot Date End' ;
    rdfs:comment 'Planned or actual end date for the activity or service associated with this budget line. Used for scheduling, resource allocation, and cost accrual period determination.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shootDateStart rdf:type rdf:Property ;
    rdfs:label 'Shoot Date Start' ;
    rdfs:comment 'Planned or actual start date for the activity or service associated with this budget line (e.g., first day of location shoot, start of VFX work, commencement of post-production labor).' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxCreditEligible rdf:type rdf:Property ;
    rdfs:label 'Tax Credit Eligible' ;
    rdfs:comment 'Flag indicating whether this budget line qualifies for production tax credits or incentives (e.g., UK High-End TV Tax Relief, US state film tax credits). Enables automated calculation of eligible spend for tax credit claims.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'SAP Work Breakdown Structure element code that hierarchically positions this budget line within the production project plan (e.g., PRD-2024-001.3.2.1 for a specific post-production task).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callSheetId rdf:type rdf:Property ;
    rdfs:label 'Call Sheet Id' ;
    rdfs:comment 'Unique identifier for the call sheet record. Primary key.' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Foreign key linking to production.location. Business justification: Normalization opportunity. Call sheet currently has denormalized location_name, location_address, location_type. Adding FK to location table allows retrieving authoritative location data via JOIN and ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:shootScheduleId rdf:type rdf:Property ;
    rdfs:label 'Shoot Schedule Id' ;
    rdfs:comment 'Foreign key linking to production.shoot_schedule. Business justification: Call sheet is issued FOR a specific shoot schedule entry. Strong operational relationship — the call sheet operationalizes the shoot schedule for that day. FK allows linking call sheet details to the ' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShootSchedule .

ind:advanceScheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Advance Schedule Notes' ;
    rdfs:comment 'Advance schedule information for the following shoot day, providing crew with next-day preparation details.' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCampLocation rdf:type rdf:Property ;
    rdfs:label 'Base Camp Location' ;
    rdfs:comment 'Location of the base camp where trailers, catering, and crew facilities are set up.' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callSheetNumber rdf:type rdf:Property ;
    rdfs:label 'Call Sheet Number' ;
    rdfs:comment 'The externally-known call sheet number or identifier issued by the assistant director department for this shoot day.' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callSheetStatus rdf:type rdf:Property ;
    rdfs:label 'Call Sheet Status' ;
    rdfs:comment 'Current lifecycle status of the call sheet document.' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:castCallTimes rdf:type rdf:Property ;
    rdfs:label 'Cast Call Times' ;
    rdfs:comment 'Structured list of individual cast member call times and pickup details (e.g., Actor Name: 05:30 - Pickup from hotel). Stored as formatted text.' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverSetDescription rdf:type rdf:Property ;
    rdfs:label 'Cover Set Description' ;
    rdfs:comment 'Description of the cover set or alternative scenes to be shot if weather or other conditions prevent the primary schedule.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletWorkflowReference rdf:type rdf:Property ;
    rdfs:label 'Dalet Workflow Reference' ;
    rdfs:comment 'Reference identifier linking this call sheet to the corresponding workflow task or document in Dalet Galaxy Media Asset Management system.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCallTimes rdf:type rdf:Property ;
    rdfs:label 'Department Call Times' ;
    rdfs:comment 'Structured list of individual department call times (e.g., Hair/Makeup: 06:00, Camera: 07:00, Grip/Electric: 06:30). Stored as formatted text.' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directorName rdf:type rdf:Property ;
    rdfs:label 'Director Name' ;
    rdfs:comment 'Name of the director assigned to this shoot day.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedWrapTime rdf:type rdf:Property ;
    rdfs:label 'Estimated Wrap Time' ;
    rdfs:comment 'Anticipated time for the shoot day to conclude and crew to wrap.' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firstAdName rdf:type rdf:Property ;
    rdfs:label 'First Ad Name' ;
    rdfs:comment 'Name of the first assistant director responsible for issuing this call sheet and managing the shoot day.' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstShotTime rdf:type rdf:Property ;
    rdfs:label 'First Shot Time' ;
    rdfs:comment 'Scheduled time for the first camera shot or principal photography to begin.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:generalCrewCallTime rdf:type rdf:Property ;
    rdfs:label 'General Crew Call Time' ;
    rdfs:comment 'The default call time for general crew members to arrive on set or location.' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mealTimes rdf:type rdf:Property ;
    rdfs:label 'Meal Times' ;
    rdfs:comment 'Scheduled meal break times for the shoot day (e.g., Breakfast: 07:00, Lunch: 13:00).' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nearestHospital rdf:type rdf:Property ;
    rdfs:label 'Nearest Hospital' ;
    rdfs:comment 'Name and address of the nearest hospital or emergency medical facility to the shoot location.' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Total script page count scheduled to be shot on this call sheet date, measured in eighths of a page.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingInstructions rdf:type rdf:Property ;
    rdfs:label 'Parking Instructions' ;
    rdfs:comment 'Parking location and instructions for crew and cast arriving at the shoot location.' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionUnit rdf:type rdf:Property ;
    rdfs:label 'Production Unit' ;
    rdfs:comment 'The production unit or crew team assigned to this shoot day.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Date when the current revision of the call sheet was issued.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision number of the call sheet. Incremented each time the call sheet is revised and reissued.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyNotices rdf:type rdf:Property ;
    rdfs:label 'Safety Notices' ;
    rdfs:comment 'Safety notices, hazard warnings, and safety protocols for the shoot day (e.g., stunts, pyrotechnics, special effects).' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sceneDescriptions rdf:type rdf:Property ;
    rdfs:label 'Scene Descriptions' ;
    rdfs:comment 'Brief descriptions of the scenes to be shot, providing context for cast and crew.' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sceneNumbers rdf:type rdf:Property ;
    rdfs:label 'Scene Numbers' ;
    rdfs:comment 'Comma-separated list of scene numbers scheduled to be shot on this call sheet date.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shootDate rdf:type rdf:Property ;
    rdfs:label 'Shoot Date' ;
    rdfs:comment 'The principal shoot date for which this call sheet is issued. This is the business event date for the production day.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shootDayNumber rdf:type rdf:Property ;
    rdfs:label 'Shoot Day Number' ;
    rdfs:comment 'Sequential shoot day number within the production schedule (e.g., Day 1, Day 2, etc.).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialEquipmentRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Equipment Requirements' ;
    rdfs:comment 'List of special equipment, vehicles, props, or technical gear required for this shoot day.' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherContingencyFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Contingency Flag' ;
    rdfs:comment 'Indicates whether a weather contingency plan or cover set is in place for this shoot day.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weatherForecast rdf:type rdf:Property ;
    rdfs:label 'Weather Forecast' ;
    rdfs:comment 'Weather forecast for the shoot date and location, critical for outdoor shoots and contingency planning.' ;
    rdfs:domain ind:CallSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costTransactionId rdf:type rdf:Property ;
    rdfs:label 'Cost Transaction Id' ;
    rdfs:comment 'Primary key for cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costTransactionDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Transaction Description' ;
    rdfs:comment 'Detailed description or narrative of the cost transaction, including purpose and context.' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeeName rdf:type rdf:Property ;
    rdfs:label 'Payee Name' ;
    rdfs:comment 'Name of the individual or entity receiving payment for this transaction (e.g., crew member, contractor, petty cash recipient).' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Amount' ;
    rdfs:comment 'Transaction amount converted to the standard reporting currency (typically USD) for consolidated financial reporting.' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Line Item Number' ;
    rdfs:comment 'Line item number within the SAP document for granular traceability.' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Crew Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for a crew assignment record in the production domain. Primary key for the crew_assignment data product.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loanOutPartnerId rdf:type rdf:Property ;
    rdfs:label 'Loan Out Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Crew members often work through loan-out companies or talent agencies (partners). Linking enables tracking all crew supplied by that partner, payment processing to the loan-out entity, union/guild com' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Externally-known business identifier for this crew assignment, used in deal memos, call sheets, and payroll processing. Format: CA-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Status of the crew member\'s background check for this production assignment. Required for productions involving minors (COPPA compliance) or access to secure facilities. Values: not_required, pending, cleared, failed, expired.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boxRentalRate rdf:type rdf:Property ;
    rdfs:label 'Box Rental Rate' ;
    rdfs:comment 'Daily or weekly rate paid to the crew member for the rental of their personal tool box or specialized equipment package (e.g., makeup artist\'s kit, wardrobe supervisor\'s supplies). Distinct from kit_rental_rate which covers technical equipment.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedRate rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate' ;
    rdfs:comment 'The agreed compensation rate for this crew assignment, expressed in the applicable deal_type unit (per day, per week, or flat total). Stored in the production\'s base currency. Used for budget tracking and payroll processing in SAP S/4HANA.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditName rdf:type rdf:Property ;
    rdfs:label 'Credit Name' ;
    rdfs:comment 'The name as it should appear in the production\'s end credits, which may differ from the crew member\'s legal name (e.g., stage name, preferred professional name). Sourced from the deal memo credit clause.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditPosition rdf:type rdf:Property ;
    rdfs:label 'Credit Position' ;
    rdfs:comment 'Specifies where the crew member\'s credit appears in the production: main_title (opening credits), end_title (closing credits), both, or none (no contractual credit obligation). Drives post-production credit sequence assembly.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filmingLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Filming Location Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the primary filming location where this crew member will work. Determines applicable labor laws, tax treaties, work permit requirements, and per diem rates.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedDays rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Days' ;
    rdfs:comment 'The minimum number of work days guaranteed to the crew member under this assignment deal, regardless of actual production schedule. Relevant for weekly and episodic deal types. Used for take-or-pay liability calculation.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kitRentalRate rdf:type rdf:Property ;
    rdfs:label 'Kit Rental Rate' ;
    rdfs:comment 'Daily or weekly rate paid to the crew member for the rental of their personal professional equipment (kit) used on the production (e.g., camera operator\'s lens kit, sound mixer\'s equipment package). Common in below-the-line crew deals.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mealPenaltyEligible rdf:type rdf:Property ;
    rdfs:label 'Meal Penalty Eligible' ;
    rdfs:comment 'Indicates whether this crew member is entitled to meal penalty payments if the production fails to provide a meal break within the contractually required interval (typically 6 hours under IATSE/DGA agreements). Drives production scheduling compliance.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeEligible rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible' ;
    rdfs:comment 'Indicates whether this crew member is eligible for overtime pay under their union/guild agreement or applicable labor law. True = eligible for overtime; False = flat deal or exempt classification. Drives payroll calculation logic.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Rate Multiplier' ;
    rdfs:comment 'The multiplier applied to the base contracted_rate for overtime hours (e.g., 1.5 for time-and-a-half, 2.0 for double-time). Applicable only when overtime_eligible is True. Sourced from the applicable union/guild agreement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perDiemRate rdf:type rdf:Property ;
    rdfs:label 'Per Diem Rate' ;
    rdfs:comment 'Daily allowance paid to the crew member for meals and incidental expenses when working away from their home base location. Rate varies by filming location and union agreement. Used for production cost budgeting.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualsEligible rdf:type rdf:Property ;
    rdfs:label 'Residuals Eligible' ;
    rdfs:comment 'Indicates whether this crew member is entitled to residual payments when the production is reused, syndicated, or distributed on additional platforms (e.g., streaming, international broadcast). Residuals are governed by DGA, IATSE, and SAG-AFTRA agreements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleTitle rdf:type rdf:Property ;
    rdfs:label 'Role Title' ;
    rdfs:comment 'The specific production role or job title assigned to the crew member (e.g., Director, Director of Photography, Gaffer, Script Supervisor, Editor, Colorist, VFX Supervisor, Sound Mixer, Key Grip, Best Boy). [ENUM-REF-CANDIDATE: director|director_of_photography|gaffer|script_supervisor|editor|colorist|vfx_supervisor|sound_mixer|key_grip|best_boy|production_designer|costume_designer — promote to reference product]' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyTrainingCertified rdf:type rdf:Property ;
    rdfs:label 'Safety Training Certified' ;
    rdfs:comment 'Indicates whether the crew member has completed the required on-set safety training certification for this production (e.g., OSHA safety, COVID-19 protocols, stunt safety). Required for insurance compliance and production liability management.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapPersonnelActionCode rdf:type rdf:Property ;
    rdfs:label 'Sap Personnel Action Code' ;
    rdfs:comment 'The personnel action number in SAP S/4HANA HR that corresponds to this crew assignment. Used for payroll processing, benefits enrollment, and HR compliance reporting. Enables reconciliation between the production data product and the ERP system of record.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDays rdf:type rdf:Property ;
    rdfs:label 'Scheduled Days' ;
    rdfs:comment 'The total number of work days currently scheduled for this crew member on the production, as reflected in the current production schedule. May differ from guaranteed_days if the schedule changes.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:travelAllowance rdf:type rdf:Property ;
    rdfs:label 'Travel Allowance' ;
    rdfs:comment 'Fixed or estimated travel reimbursement amount for this crew assignment, covering transportation costs to and from the filming location. Distinct from per_diem_rate which covers daily living expenses.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Hours' ;
    rdfs:comment 'The minimum number of hours required between the end of one work day and the start of the next for this crew member, as stipulated by their union/guild agreement (e.g., 10 hours for IATSE, 12 hours for DGA). Violation triggers turnaround penalty payments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionGuildAffiliation rdf:type rdf:Property ;
    rdfs:label 'Union Guild Affiliation' ;
    rdfs:comment 'The labor union or guild to which the crew member belongs for this assignment. Determines applicable minimum rates, working conditions, residuals obligations, and benefit fund contributions. DGA = Directors Guild of America; IATSE = International Alliance of Theatrical Stage Employees; SAG-AFTRA = Screen Actors Guild–American Federation of Television and Radio Artists; WGA = Writers Guild of America; NABET = National Association of Broadcast Employees and Technicians; Teamsters = International Brotherhood of Teamsters. [ENUM-REF-CANDIDATE: DGA|IATSE|SAG-AFTRA|WGA|NABET|Teamsters|non_union — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPermitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Work Permit Expiry Date' ;
    rdfs:comment 'The expiration date of the crew member\'s work permit or visa authorization. Used to trigger renewal alerts and ensure continuous legal work authorization throughout the assignment period.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Work Permit Number' ;
    rdfs:comment 'The official government-issued work permit or visa authorization number for the crew member in the production jurisdiction. Nullable when work_permit_required is False. Required for compliance audits and production insurance.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPermitRequired rdf:type rdf:Property ;
    rdfs:label 'Work Permit Required' ;
    rdfs:comment 'Indicates whether a work permit or visa authorization is required for this crew member to legally work on this production in the filming jurisdiction. True = permit required; False = no permit required (domestic/citizen crew). Triggers compliance workflow in HR.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dailyProductionReportId rdf:type rdf:Property ;
    rdfs:label 'Daily Production Report Id' ;
    rdfs:comment 'Unique identifier for the daily production report. Primary key for this entity.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDailyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Daily Employee Id' ;
    rdfs:comment 'Reference to the director responsible for this shoot day.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryDailyApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Daily Approved By User Employee Id' ;
    rdfs:comment 'Reference to the user who approved this daily production report.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryDailySubmittedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Daily Submitted By User Employee Id' ;
    rdfs:comment 'Reference to the user who submitted this daily production report for approval.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accidentsIncidentsDescription rdf:type rdf:Property ;
    rdfs:label 'Accidents Incidents Description' ;
    rdfs:comment 'Detailed description of any accidents, injuries, or safety incidents that occurred, if applicable.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accidentsIncidentsFlag rdf:type rdf:Property ;
    rdfs:label 'Accidents Incidents Flag' ;
    rdfs:comment 'Indicates whether any accidents, injuries, or safety incidents occurred during this shoot day.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adNotes rdf:type rdf:Property ;
    rdfs:label 'Ad Notes' ;
    rdfs:comment 'Notes from the first assistant director regarding logistics, schedule adherence, crew performance, and operational issues.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundActorsCount rdf:type rdf:Property ;
    rdfs:label 'Background Actors Count' ;
    rdfs:comment 'Number of background actors (extras) used on this shoot day.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callTime rdf:type rdf:Property ;
    rdfs:label 'Call Time' ;
    rdfs:comment 'Scheduled crew call time for the start of the shoot day.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:digitalMediaConsumedTb rdf:type rdf:Property ;
    rdfs:label 'Digital Media Consumed Tb' ;
    rdfs:comment 'Total terabytes of digital media captured during the shoot day, if shooting digitally.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directorNotes rdf:type rdf:Property ;
    rdfs:label 'Director Notes' ;
    rdfs:comment 'Notes and observations from the director regarding the shoot day, creative decisions, and performance.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filmStockConsumedFeet rdf:type rdf:Property ;
    rdfs:label 'Film Stock Consumed Feet' ;
    rdfs:comment 'Total feet of film stock consumed during the shoot day, if shooting on film.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastShotTime rdf:type rdf:Property ;
    rdfs:label 'Last Shot Time' ;
    rdfs:comment 'Actual timestamp when the final shot of the day was captured.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mealBreakEnd rdf:type rdf:Property ;
    rdfs:label 'Meal Break End' ;
    rdfs:comment 'Timestamp when the primary meal break ended and shooting resumed.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mealBreakStart rdf:type rdf:Property ;
    rdfs:label 'Meal Break Start' ;
    rdfs:comment 'Timestamp when the primary meal break began.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mealPenaltyIncurredFlag rdf:type rdf:Property ;
    rdfs:label 'Meal Penalty Incurred Flag' ;
    rdfs:comment 'Indicates whether a meal penalty was incurred due to late or missed meal breaks per union rules.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Total overtime hours incurred across all crew members on this shoot day.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pagesShot rdf:type rdf:Property ;
    rdfs:label 'Pages Shot' ;
    rdfs:comment 'Number of script pages (in eighths) completed during this shoot day, the primary measure of production progress.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportDate rdf:type rdf:Property ;
    rdfs:label 'Report Date' ;
    rdfs:comment 'The shoot date for which this daily production report was generated. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scenesCompleted rdf:type rdf:Property ;
    rdfs:label 'Scenes Completed' ;
    rdfs:comment 'Comma-separated list or range of scene numbers completed during this shoot day (e.g., 12, 14A, 15-17).' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Days' ;
    rdfs:comment 'Number of days ahead or behind schedule after this shoot day. Positive values indicate ahead of schedule, negative values indicate behind schedule.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:setupsCompleted rdf:type rdf:Property ;
    rdfs:label 'Setups Completed' ;
    rdfs:comment 'Total number of camera setups completed during the shoot day.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCrewHours rdf:type rdf:Property ;
    rdfs:label 'Total Crew Hours' ;
    rdfs:comment 'Aggregate crew hours worked across all crew members on this shoot day.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherConditions rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions' ;
    rdfs:comment 'Description of weather conditions during the shoot day, relevant for exterior shoots and schedule impact.' ;
    rdfs:domain ind:DailyProductionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wrapTime rdf:type rdf:Property ;
    rdfs:label 'Wrap Time' ;
    rdfs:comment 'Actual wrap time when the shoot day concluded and crew was dismissed.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliverableId rdf:type rdf:Property ;
    rdfs:label 'Deliverable Id' ;
    rdfs:comment 'Unique identifier for the production deliverable. Primary key.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deliverable .

ind:formatSpecId rdf:type rdf:Property ;
    rdfs:label 'Format Spec Id' ;
    rdfs:comment 'Foreign key linking to production.format_spec. Business justification: Normalization opportunity. Deliverable currently has target_format (STRING). FK to format_spec allows retrieving full technical specification (resolution, frame_rate, codec, etc.) and ensures delivera' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormatSpec .

ind:recipientPartnerId rdf:type rdf:Property ;
    rdfs:label 'Recipient Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Deliverables are sent to distribution partners, broadcasters, streaming platforms, and licensees. Linking enables delivery obligation tracking, SLA compliance monitoring, acceptance workflow managemen' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:targetOttPlatformId rdf:type rdf:Property ;
    rdfs:label 'Target Ott Platform Id' ;
    rdfs:comment 'Foreign key linking to distribution.ott_platform. Business justification: Deliverables are formatted for specific platforms with platform-specific technical requirements (resolution, codec, DRM). Real business process: platform-specific asset preparation, transcoding, and d' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OttPlatform .

ind:audioDescriptionFlag rdf:type rdf:Property ;
    rdfs:label 'Audio Description Flag' ;
    rdfs:comment 'Indicates whether an audio description track for visually impaired viewers is included. True = audio description present; False = no audio description.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedCaptionFlag rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Flag' ;
    rdfs:comment 'Indicates whether closed captions for accessibility are included in this deliverable. True = closed captions present; False = no closed captions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCertificateFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certificate Flag' ;
    rdfs:comment 'Indicates whether a regulatory compliance certificate (e.g., FCC, Ofcom, content rating) accompanies this deliverable. True = certificate included; False = no certificate.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliverableName rdf:type rdf:Property ;
    rdfs:label 'Deliverable Name' ;
    rdfs:comment 'Human-readable name or title of the deliverable (e.g., \'Broadcast Master HD\', \'Promo Cut 30s\', \'Closed Caption SRT File\').' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableType rdf:type rdf:Property ;
    rdfs:label 'Deliverable Type' ;
    rdfs:comment 'Category of deliverable output. Broadcast master = final linear transmission file; streaming master = OTT/VOD optimized file; promo cut = promotional excerpt; trailer = marketing preview; EPK = Electronic Press Kit; closed caption file = accessibility text; audio description track = visually impaired narration; subtitle file = translation text; M&E track = Music and Effects (no dialogue); textless version = graphics-free master; compliance certificate = regulatory approval document; QC report = Quality Control validation; as-run log = actual playout record. [ENUM-REF-CANDIDATE: broadcast_master|streaming_master|promo_cut|trailer|epk|closed_caption_file|audio_description_track|subtitle_file|me_track|textless_version|compliance_certificate|qc_report|as_run_log|other — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcOperatorName rdf:type rdf:Property ;
    rdfs:label 'Qc Operator Name' ;
    rdfs:comment 'Name of the quality control technician or automated system that performed the QC validation.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcPerformedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Performed Timestamp' ;
    rdfs:comment 'Date and time when quality control validation was completed for this deliverable.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revisionNotes rdf:type rdf:Property ;
    rdfs:label 'Revision Notes' ;
    rdfs:comment 'Description of changes made in this revision of the deliverable (e.g., \'Corrected audio sync issue\', \'Updated end credits\', \'Re-encoded for HDR\').' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Timestamp' ;
    rdfs:comment 'Planned date and time for delivery of this deliverable to the recipient or platform.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:equipmentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Equipment Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each equipment allocation record. Primary key for the equipment_allocation data product in the production domain.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentItemId rdf:type rdf:Property ;
    rdfs:label 'Equipment Item Id' ;
    rdfs:comment 'Reference to the master equipment item record (camera body, lens, lighting rig, sound package, jib, drone, editing workstation, encoding hardware) being allocated.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentItem .

ind:shootDayId rdf:type rdf:Property ;
    rdfs:label 'Shoot Day Id' ;
    rdfs:comment 'Reference to the specific shoot day or production schedule entry for which the equipment is allocated. Enables day-level cost tracking and scheduling conflict detection.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShootDay .

ind:allocationEndDate rdf:type rdf:Property ;
    rdfs:label 'Allocation End Date' ;
    rdfs:comment 'The date on which the equipment allocation ends — i.e., the last day the equipment is assigned to the production. Used for rental cost calculation and return scheduling.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationStartDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Start Date' ;
    rdfs:comment 'The date on which the equipment allocation begins — i.e., the first day the equipment is available to the production. Used for rental rate calculation and scheduling conflict detection.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetTagCode rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Code' ;
    rdfs:comment 'Internal asset tag or barcode label affixed to owned equipment for physical inventory tracking. Format: {CC}-{NNNNNN} where CC is category code. Null for rented equipment.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutCondition rdf:type rdf:Property ;
    rdfs:label 'Checkout Condition' ;
    rdfs:comment 'Assessed physical condition of the equipment at the time of checkout. Establishes the baseline condition for damage assessment upon return. Recorded by the equipment manager.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checkout Timestamp' ;
    rdfs:comment 'Exact date and time the equipment was physically checked out from the equipment room or rental house. Serves as the principal business event timestamp for the allocation lifecycle.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:damageClaimAmount rdf:type rdf:Property ;
    rdfs:label 'Damage Claim Amount' ;
    rdfs:comment 'Monetary value of the damage or loss claim raised against this allocation, in the currency specified by currency_code. Null when no damage claim exists. Used for financial reconciliation and insurance recovery.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Free-text description of any damage, loss, or malfunction identified at return. Null when equipment is returned in acceptable condition. Used to support insurance claims and vendor dispute resolution.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Category' ;
    rdfs:comment 'High-level classification of the equipment type being allocated. Drives cost centre coding, insurance grouping, and crew department assignment. [ENUM-REF-CANDIDATE: camera|lens|lighting|sound|grip|drone|editing_workstation|encoding_hardware|other — promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentName rdf:type rdf:Property ;
    rdfs:label 'Equipment Name' ;
    rdfs:comment 'Human-readable name or model designation of the equipment item (e.g., ARRI ALEXA Mini LF, Cooke S4/i 32mm, Litepanels Astra 6X). Supports crew call sheets and production reports.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceValue rdf:type rdf:Property ;
    rdfs:label 'Insurance Value' ;
    rdfs:comment 'Declared replacement value of the equipment for insurance purposes, in the currency specified by currency_code. Used to calculate insurance premiums and process loss/damage claims.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isInsuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Is Insurance Required' ;
    rdfs:comment 'Indicates whether specific insurance coverage must be arranged for this equipment allocation (True) or whether it falls under the production\'s blanket policy (False). Relevant for high-value or specialist equipment.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOwnedAsset rdf:type rdf:Property ;
    rdfs:label 'Is Owned Asset' ;
    rdfs:comment 'Indicates whether the equipment is owned by the production company (True) or rented from an external vendor (False). Drives depreciation accounting vs. rental cost booking in SAP S/4HANA FI.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionDepartment rdf:type rdf:Property ;
    rdfs:label 'Production Department' ;
    rdfs:comment 'The production department responsible for the equipment allocation (e.g., camera, lighting, grip, sound). Used for departmental budget tracking and cost centre allocation in SAP S/4HANA CO. [ENUM-REF-CANDIDATE: camera|lighting|grip|sound|art|vfx|post_production|production_office|other — promote to reference product]' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rentalRateAmount rdf:type rdf:Property ;
    rdfs:label 'Rental Rate Amount' ;
    rdfs:comment 'The agreed rental rate per day or per week (per rental_rate_type) for the equipment, in the production\'s base currency. Used for production budget tracking and vendor cost reconciliation in SAP S/4HANA.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentalRateType rdf:type rdf:Property ;
    rdfs:label 'Rental Rate Type' ;
    rdfs:comment 'Indicates whether the rental rate is charged on a daily, weekly, or flat-fee basis. Determines how the total rental cost is computed for budget tracking and vendor invoice reconciliation.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnCondition rdf:type rdf:Property ;
    rdfs:label 'Return Condition' ;
    rdfs:comment 'Assessed physical condition of the equipment at the time of return. Compared against checkout_condition to identify damage or deterioration. Triggers damage claim workflow if degraded. [ENUM-REF-CANDIDATE: new|excellent|good|fair|poor|damaged|lost — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Timestamp' ;
    rdfs:comment 'Exact date and time the equipment was physically returned to the equipment room or rental house. Null until the equipment is returned. Used to calculate actual rental duration and late return penalties.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shootLocation rdf:type rdf:Property ;
    rdfs:label 'Shoot Location' ;
    rdfs:comment 'Name or description of the physical location where the equipment will be used (e.g., Stage 4 - Pinewood Studios, Exterior - Canary Wharf, OB Van Unit 3). Supports logistics planning and insurance coverage verification.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'SAP S/4HANA Work Breakdown Structure (WBS) element code identifying the specific production phase or deliverable to which this equipment cost is attributed (e.g., pre-production, principal photography, post-production).' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityBookingId rdf:type rdf:Property ;
    rdfs:label 'Facility Booking Id' ;
    rdfs:comment 'Unique surrogate identifier for each facility booking record in the production domain. Primary key for the facility_booking data product.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFacilityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Facility Employee Id' ;
    rdfs:comment 'Identifier of the production coordinator or scheduler who created this facility booking. Used for accountability, approval workflows, and audit trail purposes.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'The final invoiced or accrued cost of the facility booking after actual usage is confirmed. Includes any overtime charges or adjustments. Reconciled against estimated_cost for budget variance reporting in SAP S/4HANA CO.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEnd rdf:type rdf:Property ;
    rdfs:label 'Actual End' ;
    rdfs:comment 'The actual date and time the facility usage concluded, as recorded by the facility operator or production coordinator. Used for overtime calculation, billing reconciliation, and schedule variance reporting.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStart rdf:type rdf:Property ;
    rdfs:label 'Actual Start' ;
    rdfs:comment 'The actual date and time the facility usage commenced, as recorded by the facility operator or production coordinator. May differ from booking_start due to delays or early starts. Used for variance analysis and billing reconciliation.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingEnd rdf:type rdf:Property ;
    rdfs:label 'Booking End' ;
    rdfs:comment 'The scheduled date and time at which the facility booking period ends. Combined with booking_start to compute duration and detect scheduling conflicts across productions.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingReference rdf:type rdf:Property ;
    rdfs:label 'Booking Reference' ;
    rdfs:comment 'Externally visible alphanumeric reference code assigned to this booking, used in communications with facility operators, vendors, and production coordinators. Corresponds to the booking order number in SAP S/4HANA MM module.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingStart rdf:type rdf:Property ;
    rdfs:label 'Booking Start' ;
    rdfs:comment 'The scheduled date and time at which the facility booking period begins. Used for conflict detection, crew scheduling, and playout coordination. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Status' ;
    rdfs:comment 'Current lifecycle state of the facility booking. \'tentative\' indicates a provisional hold pending confirmation; \'confirmed\' indicates a firm reservation; \'cancelled\' indicates the booking was withdrawn; \'completed\' indicates the facility usage has concluded; \'on_hold\' indicates a temporary pause pending decision.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date on which the facility booking was formally cancelled. Used to determine whether cancellation fees apply per the vendor contract terms and for financial accrual reversal in SAP S/4HANA.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationFee rdf:type rdf:Property ;
    rdfs:label 'Cancellation Fee' ;
    rdfs:comment 'Monetary penalty charged by the facility vendor when a confirmed booking is cancelled within the contractual notice period. Recorded for financial reconciliation and budget variance reporting.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text explanation for why the booking was cancelled. Populated only when booking_status is \'cancelled\'. Used for production post-mortem analysis and vendor dispute resolution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPersons rdf:type rdf:Property ;
    rdfs:label 'Capacity Persons' ;
    rdfs:comment 'Maximum number of persons the facility can accommodate during the booking period. Used for crew planning, health and safety compliance, and resource allocation decisions.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'The projected total cost of the facility booking at the time of reservation, calculated from rate_amount and the planned booking duration. Used for production budget planning and greenlight approvals.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityLocation rdf:type rdf:Property ;
    rdfs:label 'Facility Location' ;
    rdfs:comment 'Physical location or campus of the facility (e.g., \'Burbank Studio Lot\', \'London Soho Post\'). Used for logistics planning, travel coordination, and geographic cost allocation.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the production facility being booked. Drives resource conflict detection logic and cost allocation rules. [ENUM-REF-CANDIDATE: soundstage|editing_suite|dubbing_stage|color_grading_suite|adr_studio|screening_room|post_production_bay — promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Amount' ;
    rdfs:comment 'The contracted rate charged for the facility per the applicable rate_type unit (e.g., cost per hour or cost per day). Sourced from the facility rate card or negotiated contract. Used for budget estimation and cost allocation.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalSpecs rdf:type rdf:Property ;
    rdfs:label 'Technical Specs' ;
    rdfs:comment 'Free-text description of the technical capabilities and equipment configuration of the facility at the time of booking (e.g., \'Dolby Atmos 7.1.4 mixing console, Pro Tools HDX, 4K DI suite\'). Sourced from Dalet Galaxy facility metadata.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abrProfile rdf:type rdf:Property ;
    rdfs:label 'Abr Profile' ;
    rdfs:comment 'The adaptive bitrate streaming profile or ladder configuration associated with this format specification.' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bitDepth rdf:type rdf:Property ;
    rdfs:label 'Bit Depth' ;
    rdfs:comment 'The number of bits used to represent color information per channel (e.g., 8, 10, 12, 16).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chromaSubsampling rdf:type rdf:Property ;
    rdfs:label 'Chroma Subsampling' ;
    rdfs:comment 'The chroma subsampling scheme defining color resolution relative to luminance (e.g., 4:2:0, 4:2:2, 4:4:4).' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionStandard rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Standard' ;
    rdfs:comment 'The closed captioning or subtitle standard supported by this format (e.g., CEA-608, CEA-708, DVB Subtitles, TTML).' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'List of regulatory or industry compliance requirements that this format specification satisfies (e.g., FCC broadcast standards, ATSC 3.0, DVB-T2).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletFormatProfileReference rdf:type rdf:Property ;
    rdfs:label 'Dalet Format Profile Reference' ;
    rdfs:comment 'The corresponding format profile identifier in Dalet Galaxy MAM system used for workflow orchestration and transcoding.' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatStatus rdf:type rdf:Property ;
    rdfs:label 'Format Status' ;
    rdfs:comment 'The current lifecycle status of this format specification within the production environment.' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'Classification of the format specification by its intended use in the production workflow.' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultFormat rdf:type rdf:Property ;
    rdfs:label 'Is Default Format' ;
    rdfs:comment 'Boolean flag indicating whether this format specification is the default or recommended format for its type and resolution class.' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalNotes rdf:type rdf:Property ;
    rdfs:label 'Technical Notes' ;
    rdfs:comment 'Additional technical notes, specifications, or guidance for production teams using this format specification.' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timecodeFormat rdf:type rdf:Property ;
    rdfs:label 'Timecode Format' ;
    rdfs:comment 'The timecode standard and format used for frame-accurate synchronization and editing.' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestRecordId rdf:type rdf:Property ;
    rdfs:label 'Ingest Record Id' ;
    rdfs:comment 'Unique identifier for the media ingest record in the Dalet Galaxy MAM system. Primary key.' ;
    rdfs:domain ind:IngestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioSampleRate rdf:type rdf:Property ;
    rdfs:label 'Audio Sample Rate' ;
    rdfs:comment 'Audio sample rate in Hz. Common values include 44100, 48000, 96000.' ;
    rdfs:domain ind:IngestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ingestNumber rdf:type rdf:Property ;
    rdfs:label 'Ingest Number' ;
    rdfs:comment 'Human-readable business identifier for the ingest event, typically formatted as ING-YYYYMMDD-sequence for tracking and reference purposes.' ;
    rdfs:domain ind:IngestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestOperatorName rdf:type rdf:Property ;
    rdfs:label 'Ingest Operator Name' ;
    rdfs:comment 'Name of the operator or technician who initiated the ingest operation. Used for accountability and workflow tracking.' ;
    rdfs:domain ind:IngestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestPriority rdf:type rdf:Property ;
    rdfs:label 'Ingest Priority' ;
    rdfs:comment 'Priority level assigned to the ingest operation. Determines processing queue order and resource allocation.' ;
    rdfs:domain ind:IngestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Check Status' ;
    rdfs:comment 'Status of automated or manual quality control checks performed on the ingested media. Ensures technical compliance before downstream use.' ;
    rdfs:domain ind:IngestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDevice rdf:type rdf:Property ;
    rdfs:label 'Source Device' ;
    rdfs:comment 'Name or identifier of the camera, recorder, or device that captured the source media. Examples include camera model, recorder serial number, or external vendor name.' ;
    rdfs:domain ind:IngestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceMediaType rdf:type rdf:Property ;
    rdfs:label 'Source Media Type' ;
    rdfs:comment 'Classification of the source media being ingested. Indicates the nature and origin of the content. [ENUM-REF-CANDIDATE: camera-footage|audio-recording|graphics|b-roll|stock-footage|archive|external-delivery — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IngestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTapeCode rdf:type rdf:Property ;
    rdfs:label 'Source Tape Code' ;
    rdfs:comment 'Identifier of the physical tape or media card from which content was ingested. Used for legacy tape-based workflows and physical media tracking.' ;
    rdfs:domain ind:IngestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timecodeEnd rdf:type rdf:Property ;
    rdfs:label 'Timecode End' ;
    rdfs:comment 'Ending timecode of the ingested media in HH:MM:SS:FF format. Used for synchronization and editorial reference.' ;
    rdfs:domain ind:IngestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurancePolicyId rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Id' ;
    rdfs:comment 'Primary key for insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brokerContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: When insurance brokers are internal employees (common in large media companies with in-house risk management), tracking for vendor management, compliance reporting, and contact continuity.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:insurerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Insurer Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Insurance carriers are partners providing production insurance (E&O, general liability, equipment). Linking enables tracking all policies with that carrier, claims history analysis, renewal negotiatio' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:additionalInsuredParties rdf:type rdf:Property ;
    rdfs:label 'Additional Insured Parties' ;
    rdfs:comment 'List of additional parties named as insured under this policy, such as broadcasters, distributors, or co-production partners. Comma-separated list.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Email' ;
    rdfs:comment 'Primary email address for the insurance broker handling this policy. Used for policy inquiries and claims coordination.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Phone' ;
    rdfs:comment 'Primary phone number for the insurance broker handling this policy.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerName rdf:type rdf:Property ;
    rdfs:label 'Broker Name' ;
    rdfs:comment 'The name of the insurance broker or agent who facilitated the policy placement.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'The date when the Certificate of Insurance was issued for this policy.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateOfInsuranceIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Insurance Issued Flag' ;
    rdfs:comment 'Indicates whether a Certificate of Insurance has been issued for this policy. Required for broadcaster delivery compliance and vendor contracts.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimHistoryFlag rdf:type rdf:Property ;
    rdfs:label 'Claim History Flag' ;
    rdfs:comment 'Indicates whether any claims have been filed against this policy. True if claims exist, False if no claims.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceRequirementMetFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Met Flag' ;
    rdfs:comment 'Indicates whether this policy meets all broadcaster delivery and regulatory compliance requirements for the production. True if compliant, False if deficiencies exist.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Amount' ;
    rdfs:comment 'The maximum liability or coverage limit provided by this policy, expressed in the policy currency.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageTerritory rdf:type rdf:Property ;
    rdfs:label 'Coverage Territory' ;
    rdfs:comment 'Geographic territory or jurisdictions where the insurance coverage applies. May be worldwide or limited to specific countries/regions.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'The deductible or excess amount that must be paid by the insured before the insurance coverage applies, expressed in the policy currency.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionsSummary rdf:type rdf:Property ;
    rdfs:label 'Exclusions Summary' ;
    rdfs:comment 'Summary of key exclusions or limitations in the insurance coverage. Describes what is NOT covered by this policy.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Policy Document Url' ;
    rdfs:comment 'URL or file path to the digital copy of the full insurance policy document stored in the Media Asset Management (MAM) system or document repository.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Policy Effective Date' ;
    rdfs:comment 'The date when the insurance coverage begins and the policy becomes active.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Policy Expiration Date' ;
    rdfs:comment 'The date when the insurance coverage ends and the policy is no longer in force.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'The unique policy number assigned by the insurance carrier. This is the externally-known identifier for the policy.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyTermDays rdf:type rdf:Property ;
    rdfs:label 'Policy Term Days' ;
    rdfs:comment 'The total duration of the insurance policy coverage period, measured in days.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'The category of insurance coverage provided by this policy. Defines the risk domain covered. [ENUM-REF-CANDIDATE: cast_insurance|errors_and_omissions|general_liability|equipment_coverage|negative_film_protection|workers_compensation|completion_bond — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumAmount rdf:type rdf:Property ;
    rdfs:label 'Premium Amount' ;
    rdfs:comment 'The total premium cost paid for this insurance policy, expressed in the policy currency.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Prior Policy Number' ;
    rdfs:comment 'The policy number of the previous insurance policy if this is a renewal. Null for new policies.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Flag' ;
    rdfs:comment 'Indicates whether this policy is a renewal of a previous policy. True if renewed, False if new policy.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Sap Policy Reference' ;
    rdfs:comment 'Reference number or identifier for this insurance policy in the SAP S/4HANA ERP system, used for financial reconciliation and cost tracking.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Any special conditions, endorsements, or riders attached to this policy that modify standard coverage terms.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalClaimsFiled rdf:type rdf:Property ;
    rdfs:label 'Total Claims Filed' ;
    rdfs:comment 'The total number of insurance claims filed against this policy to date.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalClaimsPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Total Claims Paid Amount' ;
    rdfs:comment 'The cumulative amount paid out by the insurer for all claims under this policy, expressed in the policy currency.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwriterName rdf:type rdf:Property ;
    rdfs:label 'Underwriter Name' ;
    rdfs:comment 'The name of the underwriter at the insurance carrier who approved and underwrote this policy.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Owner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Location owners and management companies are partners who lease filming locations. Linking enables tracking all locations managed by that partner, payment processing for location fees, permit coordina' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the production location including street number and name.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information such as suite, building, or unit number.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCampCapacity rdf:type rdf:Property ;
    rdfs:label 'Base Camp Capacity' ;
    rdfs:comment 'Number of trailers or mobile units that can be accommodated at the base camp area near the location for cast, crew, wardrobe, makeup, and catering.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the location is situated.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Indicates whether the location owner requires specific production insurance coverage or certificates of insurance before filming can commence.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the location in decimal degrees format, used for mapping, navigation, and sunrise/sunset calculations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current lifecycle status of the location: scouted (identified by location scout), approved (approved for use by director/producer), contracted (agreement signed with owner), active (currently in use for shooting), wrapped (shooting completed), rejected (not suitable for production).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the location based on its physical characteristics and usage: practical interior (real indoor space), practical exterior (real outdoor space), backlot (studio-controlled outdoor set), remote (distant or hard-to-access site), international (foreign location), studio exterior (controlled outdoor studio space).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the location in decimal degrees format, used for mapping, navigation, and logistics planning.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerNotes rdf:type rdf:Property ;
    rdfs:label 'Manager Notes' ;
    rdfs:comment 'Free-text notes and observations from the location manager regarding access, restrictions, special requirements, or other relevant production considerations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiseAssessment rdf:type rdf:Property ;
    rdfs:label 'Noise Assessment' ;
    rdfs:comment 'Assessment of ambient noise levels at the location: quiet (minimal background noise, suitable for dialogue recording), moderate (some noise, may require sound treatment), noisy (significant noise, requires ADR or sound mitigation), unacceptable (excessive noise, unsuitable for production).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Contact Email' ;
    rdfs:comment 'Primary email address for the location owner or authorized representative for contract and coordination communications.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Owner Contact Phone' ;
    rdfs:comment 'Primary phone number for the location owner or authorized representative for coordination and emergency contact during production.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingCapacity rdf:type rdf:Property ;
    rdfs:label 'Parking Capacity' ;
    rdfs:comment 'Number of vehicle parking spaces available at or near the location for crew, cast, and equipment trucks.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitAuthority rdf:type rdf:Property ;
    rdfs:label 'Permit Authority' ;
    rdfs:comment 'Name of the governmental or regulatory authority responsible for issuing filming permits for this location (e.g., \'Los Angeles Film Office\', \'NYC Mayor Office of Media and Entertainment\').' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Permit Expiry Date' ;
    rdfs:comment 'Date when the filming permit expires and is no longer valid for production use.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitIssueDate rdf:type rdf:Property ;
    rdfs:label 'Permit Issue Date' ;
    rdfs:comment 'Date when the filming permit was officially issued by the permitting authority.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'Official permit or authorization number issued by the permitting authority for filming at this location.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current status of filming permits required for this location: not required (no permit needed), pending (application submitted), approved (permit granted), denied (permit rejected), expired (permit validity lapsed).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the location address.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerAvailability rdf:type rdf:Property ;
    rdfs:label 'Power Availability' ;
    rdfs:comment 'Assessment of electrical power availability at the location: grid (connected to utility power), generator required (no grid power, generators needed), limited (some power available but insufficient for full production), none (no power infrastructure).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Broader geographic region or area classification (e.g., \'Southern California\', \'Pacific Northwest\', \'New England\') used for production planning and logistics.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restorationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Restoration Required Flag' ;
    rdfs:comment 'Indicates whether the production is contractually obligated to restore the location to its original condition after filming concludes.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restroomFacilities rdf:type rdf:Property ;
    rdfs:label 'Restroom Facilities' ;
    rdfs:comment 'Assessment of restroom availability: on site (permanent facilities available), portable required (portable restrooms must be brought in), nearby (facilities within walking distance), none (no facilities available).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Safety Assessment Date' ;
    rdfs:comment 'Date when the safety assessment was conducted by the production safety officer or third-party assessor.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Assessment Status' ;
    rdfs:comment 'Status of the safety and risk assessment conducted for this location: not assessed (no evaluation performed), in progress (assessment underway), passed (meets safety requirements), failed (does not meet safety standards), conditional (approved with specific safety measures required).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoutApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Scout Approval Status' ;
    rdfs:comment 'Approval status from the location scout assessment: pending (awaiting review), approved (meets production requirements), rejected (does not meet requirements), conditional (approved with specific conditions or modifications).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region of the location.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterAvailability rdf:type rdf:Property ;
    rdfs:label 'Water Availability' ;
    rdfs:comment 'Assessment of water access at the location: available (connected to water supply), limited (some water but insufficient for full crew), trucked in required (no water infrastructure, must be transported), none (no water access).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Primary key for milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predecessorMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Milestone Id' ;
    rdfs:comment 'Reference to another milestone that must be completed before this milestone can begin or be achieved.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Milestone .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'The date on which the milestone was actually achieved or completed. Null if milestone has not yet been reached.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Usd' ;
    rdfs:comment 'Estimated financial impact or cost associated with achieving this milestone, or cost of delay if milestone is missed.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Flag' ;
    rdfs:comment 'Indicates whether this milestone is on the critical path of the production schedule, meaning any delay directly impacts final delivery date.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliverableDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverable Description' ;
    rdfs:comment 'Detailed description of the tangible output or deliverable associated with this milestone (e.g., locked picture file, final audio mix stems, QC report).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableFormat rdf:type rdf:Property ;
    rdfs:label 'Deliverable Format' ;
    rdfs:comment 'Technical format or specification of the deliverable (e.g., ProRes 422 HQ, IMF package, DCP, broadcast master tape format).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyCount rdf:type rdf:Property ;
    rdfs:label 'Dependency Count' ;
    rdfs:comment 'Number of other milestones or tasks that are dependent on the completion of this milestone.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'Current projected or estimated date for milestone completion based on latest production progress and risk assessment.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Human-readable name or title of the milestone event (e.g., Greenlight Approval, Picture Lock, Final Delivery).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current lifecycle status of the milestone indicating whether it is pending, on track, delayed, completed, or no longer applicable.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Categorical classification of the milestone within the production lifecycle. Defines the phase or gate this milestone represents. [ENUM-REF-CANDIDATE: greenlight|pre_production_start|principal_photography_start|principal_photography_end|picture_lock|audio_mix_complete|vfx_complete|color_grading_complete|final_qc_pass|delivery_to_broadcaster|archive_complete|post_production_start|rough_cut_complete|final_cut_complete|mastering_complete — promote to reference product]' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Mitigation Plan' ;
    rdfs:comment 'Description of actions or contingency plans in place to address identified risks and ensure milestone is achieved.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'Originally scheduled or target date for achieving this milestone as defined during production planning.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed explanation of identified risks, issues, or blockers that may prevent timely achievement of this milestone.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Notification Flag' ;
    rdfs:comment 'Indicates whether stakeholders (network executives, distributors, talent) must be notified when this milestone is achieved or at risk.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceDays rdf:type rdf:Property ;
    rdfs:label 'Variance Days' ;
    rdfs:comment 'Number of days difference between planned date and actual date (positive indicates delay, negative indicates early completion). Calculated field for reporting purposes.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postProductionTaskId rdf:type rdf:Property ;
    rdfs:label 'Post Production Task Id' ;
    rdfs:comment 'Unique identifier for the post-production task within the Dalet Galaxy workflow orchestration pipeline.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PostProductionTask .

ind:parentTaskPostProductionTaskId rdf:type rdf:Property ;
    rdfs:label 'Parent Task Post Production Task Id' ;
    rdfs:comment 'Reference to the parent post-production task if this task is a sub-task or dependent task in a hierarchical workflow.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PostProductionTask .

ind:primaryPostEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Post Employee Id' ;
    rdfs:comment 'Reference to the crew member or operator assigned to execute this post-production task.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:scriptId rdf:type rdf:Property ;
    rdfs:label 'Script Id' ;
    rdfs:comment 'Foreign key linking to production.script. Business justification: Post-production tasks reference scripts for scene/dialogue context. Optional FK (nullable) — provides editorial context for tasks. Enables linking task to script version for continuity.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Script .

ind:vfxShotId rdf:type rdf:Property ;
    rdfs:label 'Vfx Shot Id' ;
    rdfs:comment 'Foreign key linking to production.vfx_shot. Business justification: VFX-specific post-production tasks (compositing, rendering, etc.) are shot-specific. Optional FK (nullable) — only VFX tasks populate this. Enables linking Dalet workflow tasks to VFX shot tracking.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VfxShot .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Actual date and time when the post-production task was completed and submitted for review or approval.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDurationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Hours' ;
    rdfs:comment 'Actual number of hours spent completing the post-production task, used for cost tracking and performance analysis.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daletWorkflowTaskReference rdf:type rdf:Property ;
    rdfs:label 'Dalet Workflow Task Reference' ;
    rdfs:comment 'External system identifier from Dalet Galaxy workflow orchestration system for this specific task instance.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyType rdf:type rdf:Property ;
    rdfs:label 'Dependency Type' ;
    rdfs:comment 'Type of scheduling dependency relationship this task has with its predecessor tasks in the workflow.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Planned number of hours required to complete the post-production task, used for resource planning and scheduling.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputMediaPath rdf:type rdf:Property ;
    rdfs:label 'Output Media Path' ;
    rdfs:comment 'File system path or MAM location where the completed output files or deliverables from this task are stored.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDueDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Due Date' ;
    rdfs:comment 'Target completion date for the post-production task as defined in the production schedule.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date when the post-production task is scheduled to begin.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordering position of this task within the overall post-production workflow or within a parent task group.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceMediaPath rdf:type rdf:Property ;
    rdfs:label 'Source Media Path' ;
    rdfs:comment 'File system path or Media Asset Management (MAM) location of the source media files or assets for this task.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskNotes rdf:type rdf:Property ;
    rdfs:label 'Task Notes' ;
    rdfs:comment 'General operational notes, instructions, or context information related to the execution of this post-production task.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Human-readable business identifier for the post-production task, often used for tracking and communication purposes.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the post-production task within the workflow pipeline. [ENUM-REF-CANDIDATE: queued|in_progress|review|approved|rejected|complete|on_hold|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the post-production work task indicating the specific type of creative or technical operation being performed. [ENUM-REF-CANDIDATE: offline_edit|online_conform|vfx_composite|color_grade|audio_mix|adr_record|subtitle_burn_in|qc_review|transcode|archive_ingest|foley_record|sound_design|title_graphics|versioning — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSpecification rdf:type rdf:Property ;
    rdfs:label 'Technical Specification' ;
    rdfs:comment 'Detailed technical requirements and parameters for the task output, such as resolution, frame rate, codec, color space, or audio format.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workstationCode rdf:type rdf:Property ;
    rdfs:label 'Workstation Code' ;
    rdfs:comment 'Identifier of the specific editing suite, color grading bay, or audio mixing console assigned for this task.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionClearanceId rdf:type rdf:Property ;
    rdfs:label 'Production Clearance Id' ;
    rdfs:comment 'Unique identifier for the production clearance record. Primary key for tracking rights clearance throughout the clearance lifecycle.' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requested By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Rights clearance requests track requester employee for workflow routing, approval escalation, and audit trails—standard in legal/business affairs operations. Replaces denormalized requested_by name.' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rightsHolderPartnerId rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Rights clearances are obtained from IP owners, music publishers, stock footage libraries, and clearance agencies (partners). Linking enables tracking all clearances from that partner, payment processi' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:attributionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Attribution Required Flag' ;
    rdfs:comment 'Indicates whether the clearance agreement requires on-screen or end-credit attribution to the rights holder or original creator. True if attribution is mandatory; false if not required.' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attributionText rdf:type rdf:Property ;
    rdfs:label 'Attribution Text' ;
    rdfs:comment 'Exact text required for on-screen or end-credit attribution as specified by the rights holder. Must be displayed verbatim to comply with clearance terms.' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceNumber rdf:type rdf:Property ;
    rdfs:label 'Clearance Number' ;
    rdfs:comment 'Business-facing unique reference number for the clearance record, used in legal documentation and rights management correspondence.' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeUsd rdf:type rdf:Property ;
    rdfs:label 'Fee Usd' ;
    rdfs:comment 'Total fee paid to the rights holder for clearance, expressed in US dollars. Includes all licensing costs, synchronization fees, master use fees, and any negotiated payments.' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipDescription rdf:type rdf:Property ;
    rdfs:label 'Ip Description' ;
    rdfs:comment 'Detailed description of the third-party intellectual property being cleared, including title, artist, duration, usage context, and specific elements requiring clearance.' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iswc rdf:type rdf:Property ;
    rdfs:label 'Iswc' ;
    rdfs:comment 'International Standard Musical Work Code for musical compositions being cleared. Unique identifier for musical works used in synchronization license clearances.' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaTypeCleared rdf:type rdf:Property ;
    rdfs:label 'Media Type Cleared' ;
    rdfs:comment 'Distribution channels and platforms for which the clearance is valid, specified as comma-separated values (e.g., broadcast,SVOD,AVOD,theatrical,FAST,social_media). Defines the media formats and delivery methods authorized under this clearance.' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether the clearance requires periodic renewal or renegotiation. True if the clearance has a fixed term and must be renewed; false if perpetual or automatically renewing.' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictions rdf:type rdf:Property ;
    rdfs:label 'Restrictions' ;
    rdfs:comment 'Any usage restrictions, limitations, or conditions imposed by the rights holder, such as prohibited contexts, content rating requirements, editorial approval rights, or blackout periods.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightslineClearanceReference rdf:type rdf:Property ;
    rdfs:label 'Rightsline Clearance Reference' ;
    rdfs:comment 'External identifier for this clearance record in the Rightsline rights and royalties management system. Used for cross-system reconciliation and audit trail.' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDescription rdf:type rdf:Property ;
    rdfs:label 'Usage Description' ;
    rdfs:comment 'Detailed description of how the intellectual property will be used within the production, including scene context, duration, prominence, and creative treatment. Critical for rights holder approval and compliance verification.' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Reference to the parent production project (series, mini-series, anthology, or episodic documentary) to which this episode belongs. Establishes the episode-to-project hierarchy.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:syndicationLicenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Syndication License Agreement Id' ;
    rdfs:comment 'Foreign key linking to rights.license_agreement. Business justification: Individual episodes may have separate syndication or international license agreements distinct from the series-level agreement. Real business need: episode-level rights tracking for syndication deals,' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:actualCostUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Usd' ;
    rdfs:comment 'Total actual production cost incurred for this episode in US dollars, as recorded in SAP S/4HANA. Used for budget variance analysis, EBITDA reporting, and production cost per minute calculations.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualRunningTimeSec rdf:type rdf:Property ;
    rdfs:label 'Actual Running Time Sec' ;
    rdfs:comment 'Final delivered running time of the episode in seconds as measured from the completed master file. May differ from target due to editorial decisions made during post-production. Used for playout scheduling reconciliation and delivery compliance verification.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Usd' ;
    rdfs:comment 'Total approved production budget for this episode in US dollars, as sanctioned at greenlight. Used for budget vs. actual variance analysis in SAP S/4HANA CO and financial reporting under SOX compliance.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audioLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Audio Language Code' ;
    rdfs:comment 'ISO 639-2 three-letter language code for the primary audio track of this episode. Used for distribution rights matching, subtitle/dubbing workflow triggering, and EPG metadata population.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioMixCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Audio Mix Completion Date' ;
    rdfs:comment 'Date on which the final audio mix (including dialogue, music, and effects) was completed and approved. Prerequisite for final mastering and delivery. Tracked as a post-production milestone in Dalet Galaxy.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedCaptioningCompliant rdf:type rdf:Property ;
    rdfs:label 'Closed Captioning Compliant' ;
    rdfs:comment 'Indicates whether this episode meets FCC closed captioning requirements (47 CFR Part 79) and Ofcom subtitling standards. Required for broadcast clearance and regulatory compliance reporting.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:colorGradeCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Color Grade Completion Date' ;
    rdfs:comment 'Date on which color grading (digital color correction and finishing) was completed and approved. Required before final mastering and transcode for delivery. Tracked as a post-production milestone in Dalet Galaxy.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:episodeCode rdf:type rdf:Property ;
    rdfs:label 'Episode Code' ;
    rdfs:comment 'Internal production code assigned by the production team to uniquely identify this episode within the production management system (e.g., Dalet Galaxy asset code). Used for workflow routing, asset tagging, and facility booking references.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstAirDate rdf:type rdf:Property ;
    rdfs:label 'First Air Date' ;
    rdfs:comment 'Date on which this episode first aired or was made available to audiences on any platform (linear broadcast, VOD, OTT). Marks the start of the content windowing lifecycle and triggers residuals calculation in Rightsline.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:greenlightDate rdf:type rdf:Property ;
    rdfs:label 'Greenlight Date' ;
    rdfs:comment 'Date on which executive approval (greenlight) was granted to proceed with production of this episode. Marks the official start of the production lifecycle and triggers budget release in SAP S/4HANA.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:masterFormat rdf:type rdf:Property ;
    rdfs:label 'Master Format' ;
    rdfs:comment 'Technical format specification of the delivered episode master file (e.g., UHD HDR, HD 1080p). Determines transcode profiles required for multi-platform distribution and CDN delivery via Akamai.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pictureLockDate rdf:type rdf:Property ;
    rdfs:label 'Picture Lock Date' ;
    rdfs:comment 'Date on which the final edited picture was locked, freezing all visual edits. Triggers downstream post-production workflows including VFX, color grading, and audio mixing. Critical milestone for delivery scheduling.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionStatus rdf:type rdf:Property ;
    rdfs:label 'Production Status' ;
    rdfs:comment 'Current lifecycle stage of the episode within the end-to-end production workflow. Drives workflow routing in Dalet Galaxy and milestone reporting to production management. [ENUM-REF-CANDIDATE: development|pre_production|principal_photography|post_production|picture_lock|delivered|archived — promote to reference product]' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scriptLockDate rdf:type rdf:Property ;
    rdfs:label 'Script Lock Date' ;
    rdfs:comment 'Date on which the final shooting script was locked, freezing all creative changes. Triggers pre-production scheduling, crew assignments, and facility bookings. Key milestone for production planning.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shootCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shoot Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the primary country where principal photography was conducted. Used for production tax credit eligibility, co-production treaty compliance, and content origin classification.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shootEndDate rdf:type rdf:Property ;
    rdfs:label 'Shoot End Date' ;
    rdfs:comment 'Scheduled or actual end date of principal photography (picture wrap) for this episode. Used to confirm transition to post-production and trigger post-production workflow initiation in Dalet Galaxy.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shootStartDate rdf:type rdf:Property ;
    rdfs:label 'Shoot Start Date' ;
    rdfs:comment 'Scheduled or actual start date of principal photography for this episode. Used for crew scheduling, facility booking, and production budget burn-rate tracking in SAP S/4HANA.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:showrunnerName rdf:type rdf:Property ;
    rdfs:label 'Showrunner Name' ;
    rdfs:comment 'Full name of the showrunner (executive producer with creative oversight) responsible for this episode. Key accountability reference for production governance and editorial decisions.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRunningTimeSec rdf:type rdf:Property ;
    rdfs:label 'Target Running Time Sec' ;
    rdfs:comment 'Planned editorial running time of the episode in seconds, excluding commercial breaks. Used for scheduling slot allocation, playout automation configuration in Ericsson MediaFirst, and delivery specification compliance.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vfxCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Vfx Completion Date' ;
    rdfs:comment 'Date on which all visual effects shots were completed and approved for integration into the picture lock. Tracked as a post-production milestone. Null if the episode contains no VFX work.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writerName rdf:type rdf:Property ;
    rdfs:label 'Writer Name' ;
    rdfs:comment 'Full name of the credited writer(s) for this episode. Used for residuals calculation, WGA/guild compliance reporting, and rights attribution in Rightsline.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterLicenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Master License Agreement Id' ;
    rdfs:comment 'Foreign key linking to rights.license_agreement. Business justification: Projects often have master license agreements governing distribution rights (co-production deals, pre-sales, output deals). Real business need: tracking which license agreements fund or govern a produ' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:primaryTitleId rdf:type rdf:Property ;
    rdfs:label 'Primary Title Id' ;
    rdfs:comment 'FK to content.title.title_id — Critical production-to-content traceability: must answer \'what content title does this production project produce?\' for scheduling, rights clearance, and financial reporting workflows.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:productionCompanyPartnerId rdf:type rdf:Property ;
    rdfs:label 'Production Company Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Production projects are executed by or with external production companies (partners). Linking enables contract management, payment processing, co-production tracking, and rights negotiation. The `prod' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:projectTitleId rdf:type rdf:Property ;
    rdfs:label 'Project Title Id' ;
    rdfs:comment 'Foreign key linking to content.title. Business justification: Production projects create content titles - this is the master link for tracking which title a production project is creating. Essential for content delivery tracking, rights management, and productio' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:showrunnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Showrunner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Showrunner is a formal employment role in episodic production tracked in HR systems for compensation, guild reporting (WGA/DGA), and on-screen credits—critical for series content.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Usd' ;
    rdfs:comment 'Cumulative actual expenditure incurred against this production project to date, denominated in US Dollars. Sourced from SAP S/4HANA cost postings. Compared against approved_budget_usd for variance and financial reconciliation reporting.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coProductionFlag rdf:type rdf:Property ;
    rdfs:label 'Co Production Flag' ;
    rdfs:comment 'Indicates whether this production project is a co-production involving one or more external production partners. Triggers co-production agreement workflows, shared rights structures, and split budget reporting in SAP S/4HANA.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmRequired rdf:type rdf:Property ;
    rdfs:label 'Drm Required' ;
    rdfs:comment 'Indicates whether Digital Rights Management (DRM) protection must be applied to the delivered content assets. Drives technical delivery specifications for CDN, streaming platform configuration, and Akamai CDN security settings.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fccLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Fcc License Required' ;
    rdfs:comment 'Indicates whether this production requires FCC broadcast licensing compliance review prior to linear broadcast distribution. Applicable to content intended for over-the-air or cable transmission in the United States.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:greenlightStatus rdf:type rdf:Property ;
    rdfs:label 'Greenlight Status' ;
    rdfs:comment 'Executive approval status of the production project. Indicates whether the project has received formal greenlight authorization to proceed, is pending approval, is on hold, or has been cancelled. Controls budget release and resource mobilization.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalIpFlag rdf:type rdf:Property ;
    rdfs:label 'Original Ip Flag' ;
    rdfs:comment 'Indicates whether this production is based on original intellectual property owned by the organization, as opposed to licensed or adapted IP. Affects rights ownership, residuals obligations, and long-term asset valuation.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postProductionStartDate rdf:type rdf:Property ;
    rdfs:label 'Post Production Start Date' ;
    rdfs:comment 'Scheduled or actual date on which post-production activities commenced, including editing, VFX, color grading, audio mixing, and transcoding. Used for facility booking and deliverable milestone planning.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preProductionStartDate rdf:type rdf:Property ;
    rdfs:label 'Pre Production Start Date' ;
    rdfs:comment 'Scheduled or actual date on which pre-production activities commenced, including casting, location scouting, script breakdown, and crew hiring. Used for production planning and milestone tracking.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:principalPhotographyEndDate rdf:type rdf:Property ;
    rdfs:label 'Principal Photography End Date' ;
    rdfs:comment 'Scheduled or actual date on which principal photography concluded (picture wrap). Triggers transition to post-production phase and initiates post-production resource scheduling.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:principalPhotographyStartDate rdf:type rdf:Property ;
    rdfs:label 'Principal Photography Start Date' ;
    rdfs:comment 'Scheduled or actual date on which principal photography (primary filming) commenced. A key production milestone used for crew scheduling, facility booking, and insurance activation.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionCountry rdf:type rdf:Property ;
    rdfs:label 'Production Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the primary country in which the production is being executed. Determines applicable regulatory frameworks, tax incentive eligibility, and co-production treaty benefits.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionFormat rdf:type rdf:Property ;
    rdfs:label 'Production Format' ;
    rdfs:comment 'Primary technical production format and resolution specification (e.g., 4K UHD, HD 1080p, HDR10). Determines post-production pipeline, transcoding requirements, and delivery specifications for broadcast and streaming platforms. [ENUM-REF-CANDIDATE: 4K_UHD|HD_1080p|HD_720p|SD|HDR10|Dolby_Vision|IMAX — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the content production project by format and genre category. Drives production workflow templates, budget models, rights structures, and scheduling logic. [ENUM-REF-CANDIDATE: scripted_series|feature_film|documentary|live_event|news_segment|unscripted_series|short_form — promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synopsis rdf:type rdf:Property ;
    rdfs:label 'Synopsis' ;
    rdfs:comment 'Short narrative description of the content production project\'s story, subject matter, or editorial concept. Used for internal greenlight documentation, sales pitches, EPG metadata, and Dalet Galaxy asset metadata.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Target Delivery Date' ;
    rdfs:comment 'Contractually committed or internally planned date by which the finished content must be delivered to distribution, broadcast, or streaming platforms. Drives post-production scheduling, windowing strategy, and SLA compliance.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcReviewId rdf:type rdf:Property ;
    rdfs:label 'Qc Review Id' ;
    rdfs:comment 'Unique identifier for the quality control review record. Primary key.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetAbrProfileId rdf:type rdf:Property ;
    rdfs:label 'Target Abr Profile Id' ;
    rdfs:comment 'Foreign key linking to distribution.abr_profile. Business justification: QC reviews validate deliverables against target ABR profile specifications for distribution readiness. Real business process: quality assurance for streaming assets, technical compliance validation, a' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbrProfile .

ind:audioDescriptionComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Audio Description Compliance Flag' ;
    rdfs:comment 'Indicates whether audio description track meets accessibility standards. True if compliant, False if missing or non-compliant.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedCaptionComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Compliance Flag' ;
    rdfs:comment 'Indicates whether closed captions meet accessibility and regulatory standards (FCC, CVAA). True if compliant, False if violations detected.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:errorCodes rdf:type rdf:Property ;
    rdfs:label 'Error Codes' ;
    rdfs:comment 'Comma-separated list of specific error codes identified during the review, aligned with EBU R128, ATSC A/85, and ITU-R BT.1788 standards (e.g., V001 for video freeze, A002 for loudness violation, C003 for closed caption sync error).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Final Approval Date' ;
    rdfs:comment 'Date when the deliverable received final approval for distribution. Null if not yet approved.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Final Approval Status' ;
    rdfs:comment 'Final approval status of the deliverable after QC review and any remediation: approved (ready for distribution), rejected (does not meet standards), pending approval (awaiting sign-off), or conditional approval (approved with minor caveats).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loudnessComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Loudness Compliance Flag' ;
    rdfs:comment 'Indicates whether the deliverable meets loudness standards (EBU R128 or ATSC A/85). True if compliant, False if violations detected.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:p1CriticalErrorCount rdf:type rdf:Property ;
    rdfs:label 'P1 Critical Error Count' ;
    rdfs:comment 'Number of P1 critical errors that prevent broadcast or distribution (e.g., audio dropout, video corruption, missing segments).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:p2MajorErrorCount rdf:type rdf:Property ;
    rdfs:label 'P2 Major Error Count' ;
    rdfs:comment 'Number of P2 major errors that significantly impact quality but may not prevent distribution (e.g., color grading inconsistencies, audio sync issues).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:p3MinorErrorCount rdf:type rdf:Property ;
    rdfs:label 'P3 Minor Error Count' ;
    rdfs:comment 'Number of P3 minor errors that have minimal impact on viewer experience (e.g., minor subtitle timing issues, cosmetic artifacts).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcPlatform rdf:type rdf:Property ;
    rdfs:label 'Qc Platform' ;
    rdfs:comment 'Name of the QC platform or tool used to perform the review (e.g., Dalet Galaxy QC module, Tektronix Sentry, Interra Baton).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcResult rdf:type rdf:Property ;
    rdfs:label 'Qc Result' ;
    rdfs:comment 'Overall result of the QC review: pass (no issues), fail (critical issues preventing distribution), conditional pass (minor issues requiring remediation), or pending review (awaiting final approval).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reQcDate rdf:type rdf:Property ;
    rdfs:label 'Re Qc Date' ;
    rdfs:comment 'Date when the deliverable was re-reviewed after remediation. Null if no re-QC has been performed.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationNotes rdf:type rdf:Property ;
    rdfs:label 'Remediation Notes' ;
    rdfs:comment 'Detailed notes describing the remediation actions required to address identified errors and bring the deliverable into compliance.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Flag' ;
    rdfs:comment 'Indicates whether the deliverable requires remediation or correction before final approval. True if remediation needed, False if no action required.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Review Duration Minutes' ;
    rdfs:comment 'Total duration of the QC review session in minutes.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review End Timestamp' ;
    rdfs:comment 'Timestamp when the QC operator completed the review session.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Business identifier for the QC review, typically formatted as a human-readable reference code.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Start Timestamp' ;
    rdfs:comment 'Timestamp when the QC operator began the review session.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalErrorCount rdf:type rdf:Property ;
    rdfs:label 'Total Error Count' ;
    rdfs:comment 'Total number of errors identified across all severity levels during the QC review.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:videoFrameRate rdf:type rdf:Property ;
    rdfs:label 'Video Frame Rate' ;
    rdfs:comment 'Measured video frame rate (e.g., 23.976, 25, 29.97, 50, 59.94 fps).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Rating Submission Id' ;
    rdfs:comment 'Primary key for rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRatingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rating Employee Id' ;
    rdfs:comment 'Identifier of the user or staff member who submitted the content for rating.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appealDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Date' ;
    rdfs:comment 'Date when the appeal was formally filed with the rating authority.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:broadcastClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Broadcast Clearance Required Flag' ;
    rdfs:comment 'Indicates whether this rating is required for broadcast clearance and compliance with Federal Communications Commission (FCC) or equivalent regulatory requirements.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'Date when the rating certificate expires and content must be re-submitted for re-rating if applicable. Null if certificate does not expire.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contentRuntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Content Runtime Minutes' ;
    rdfs:comment 'Total runtime of the submitted content in minutes.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coppaApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Applicable Flag' ;
    rdfs:comment 'Indicates whether the content is subject to COPPA regulations due to being directed at children under 13.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cutsDescription rdf:type rdf:Property ;
    rdfs:label 'Cuts Description' ;
    rdfs:comment 'Detailed description of the cuts, edits, or modifications required by the rating authority. Includes timecodes, scene descriptions, and nature of changes.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cuts Required Flag' ;
    rdfs:comment 'Indicates whether the rating authority required editorial cuts or modifications to the content to achieve the assigned rating.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Distribution Clearance Required Flag' ;
    rdfs:comment 'Indicates whether this rating is required for distribution clearance across platforms (theatrical, OTT, SVOD, AVOD, linear broadcast).' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingConditions rdf:type rdf:Property ;
    rdfs:label 'Rating Conditions' ;
    rdfs:comment 'Any conditions, restrictions, or requirements imposed by the rating authority for the assigned rating. Examples: specific scenes must be cut, warning messages required, restricted broadcast hours.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerNotes rdf:type rdf:Property ;
    rdfs:label 'Reviewer Notes' ;
    rdfs:comment 'Internal notes or feedback provided by the rating authority reviewers regarding the content evaluation. May include guidance for future submissions.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Submission Fee Amount' ;
    rdfs:comment 'Fee charged by the rating authority for processing the rating submission.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Submission Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the submission fee.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Reference Number' ;
    rdfs:comment 'External reference number or tracking code assigned by the submitter or rating authority for this submission.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the rating submission. Tracks progression from draft through submission, review, and final decision. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|appealed|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedContentTitle rdf:type rdf:Property ;
    rdfs:label 'Submitted Content Title' ;
    rdfs:comment 'The title of the content as submitted to the rating authority. May differ from production working title.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedContentVersion rdf:type rdf:Property ;
    rdfs:label 'Submitted Content Version' ;
    rdfs:comment 'Version identifier of the content submitted for rating (e.g., theatrical cut, director\'s cut, TV edit, unrated version).' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underlyingRightsHolderId rdf:type rdf:Property ;
    rdfs:label 'Underlying Rights Holder Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_holder. Business justification: Scripts are often based on underlying IP owned by rights holders (novels, plays, life rights, true stories, existing franchises). Real business need: tracking the rights holder of the underlying IP be' ;
    rdfs:domain ind:Script ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:writerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Writer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: When writers are staff employees (vs. freelance), tracking employment relationship is essential for WGA residuals calculation, benefits administration, and tax reporting—common in animation and daytim' ;
    rdfs:domain ind:Script ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'The confidentiality classification of the script document (public, internal, confidential, restricted).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Dalet Document Reference' ;
    rdfs:comment 'The unique document identifier or reference in the Dalet Galaxy Media Asset Management (MAM) system linking this script record to the digital script file.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionRestriction rdf:type rdf:Property ;
    rdfs:label 'Distribution Restriction' ;
    rdfs:comment 'Any restrictions or limitations on the distribution or sharing of the script (e.g., internal use only, NDA required).' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftType rdf:type rdf:Property ;
    rdfs:label 'Draft Type' ;
    rdfs:comment 'The classification of the script draft stage (outline, first draft, revised draft, shooting script, post-production script, final draft).' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRuntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Runtime Minutes' ;
    rdfs:comment 'The estimated runtime of the production in minutes based on the script length and pacing.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'The production format for which the script is intended (feature film, television episode, miniseries, web series, documentary, commercial, short film). [ENUM-REF-CANDIDATE: feature film|television episode|miniseries|web series|documentary|commercial|short film — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genre rdf:type rdf:Property ;
    rdfs:label 'Genre' ;
    rdfs:comment 'The genre or category of the script (e.g., drama, comedy, thriller, documentary).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockDate rdf:type rdf:Property ;
    rdfs:label 'Lock Date' ;
    rdfs:comment 'The date on which the script was locked and finalized for production.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockStatus rdf:type rdf:Property ;
    rdfs:label 'Lock Status' ;
    rdfs:comment 'Indicates whether the script is locked for production (true) or still open for revisions (false).' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sceneCount rdf:type rdf:Property ;
    rdfs:label 'Scene Count' ;
    rdfs:comment 'The total number of scenes defined in the script.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scriptNumber rdf:type rdf:Property ;
    rdfs:label 'Script Number' ;
    rdfs:comment 'The externally-known unique identifier or code assigned to this script for production tracking and reference purposes.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scriptStatus rdf:type rdf:Property ;
    rdfs:label 'Script Status' ;
    rdfs:comment 'Current lifecycle status of the script (draft, in review, approved, locked, archived, rejected).' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wgaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Wga Registration Number' ;
    rdfs:comment 'The WGA registration number assigned to this script for copyright and intellectual property protection.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writerCredits rdf:type rdf:Property ;
    rdfs:label 'Writer Credits' ;
    rdfs:comment 'The names and credits of the writer(s) who authored or contributed to the script.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryShootEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Shoot Employee Id' ;
    rdfs:comment 'Reference to the director assigned to lead principal photography on this shoot day. Supports crew assignment and talent tracking.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualExtrasCount rdf:type rdf:Property ;
    rdfs:label 'Actual Extras Count' ;
    rdfs:comment 'The actual number of background performers (extras) who worked on this shoot day. Used for payroll reconciliation, SAG-AFTRA reporting, and production cost tracking.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualShootHours rdf:type rdf:Property ;
    rdfs:label 'Actual Shoot Hours' ;
    rdfs:comment 'The actual number of hours spent in principal photography for the day. Used for budget reconciliation, overtime calculation, and production efficiency analysis.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualWrapTime rdf:type rdf:Property ;
    rdfs:label 'Actual Wrap Time' ;
    rdfs:comment 'The actual time at which principal photography concluded for the day. Compared against scheduled wrap time to calculate overtime and assess schedule adherence.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dayOutOfDaysType rdf:type rdf:Property ;
    rdfs:label 'Day Out Of Days Type' ;
    rdfs:comment 'Industry-standard Day Out of Days (DOOD) designation indicating the cast/crew work status for this shoot day. SW=Start Work, W=Work, WF=Work Finish, F=Finish, H=Hold, D=Drop, SWF=Start Work Finish. Used for talent scheduling, residuals calculation, and SAG-AFTRA compliance. [ENUM-REF-CANDIDATE: SW|W|WF|F|H|D|SWF — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedExtrasCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Extras Count' ;
    rdfs:comment 'The planned number of background performers (extras) required for this shoot day. Used for casting coordination, catering planning, and SAG-AFTRA background performer compliance.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedShootHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Shoot Hours' ;
    rdfs:comment 'The planned number of shooting hours for the day, used for budget forecasting, crew scheduling, and facility booking. Expressed in decimal hours (e.g., 10.50 = 10 hours 30 minutes).' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOvertimeDay rdf:type rdf:Property ;
    rdfs:label 'Is Overtime Day' ;
    rdfs:comment 'Indicates whether this shoot day resulted in overtime hours for cast or crew, triggering additional compensation obligations under union agreements (SAG-AFTRA, DGA, IATSE). Derived operationally but stored for compliance and payroll audit purposes.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mealPenaltyFlag rdf:type rdf:Property ;
    rdfs:label 'Meal Penalty Flag' ;
    rdfs:comment 'Indicates whether a meal penalty was incurred on this shoot day due to failure to provide a meal break within the union-mandated interval (typically 6 hours). Triggers additional compensation obligations under SAG-AFTRA and IATSE agreements.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionNotes rdf:type rdf:Property ;
    rdfs:label 'Production Notes' ;
    rdfs:comment 'Free-text field capturing significant events, issues, or observations from the shoot day, including equipment failures, weather delays, cast illness, or creative changes. Sourced from the daily production report.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionVersion rdf:type rdf:Property ;
    rdfs:label 'Revision Version' ;
    rdfs:comment 'The version identifier of this shoot schedule revision (e.g., \'v1\', \'v3-BLUE\', \'Rev-7\'). Production schedules are revised frequently; tracking version enables audit of changes and comparison of planned vs. actual across revisions.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this shoot schedule record, used in production paperwork, call sheets, and cross-system references (e.g., SS-2024-0042).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledWrapTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Wrap Time' ;
    rdfs:comment 'The planned time at which principal photography is expected to conclude for the day. Used for facility booking, crew scheduling, and overtime cost estimation.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shootType rdf:type rdf:Property ;
    rdfs:label 'Shoot Type' ;
    rdfs:comment 'Classifies the nature of the shoot day environment. Distinguishes between controlled studio environments and on-location shoots, which have different logistical, permitting, and cost implications.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalApprovedShootDays rdf:type rdf:Property ;
    rdfs:label 'Total Approved Shoot Days' ;
    rdfs:comment 'The total number of principal photography days approved in the production greenlight. Used to calculate schedule completion percentage and identify overages requiring executive approval.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorPartnerId rdf:type rdf:Property ;
    rdfs:label 'Vendor Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: VFX shots are outsourced to external VFX vendors (partners). Linking enables bid comparison across vendors, delivery tracking, payment processing, vendor performance evaluation, and shot allocation op' ;
    rdfs:domain ind:VfxShot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:approvedCost rdf:type rdf:Property ;
    rdfs:label 'Approved Cost' ;
    rdfs:comment 'Final approved budget allocation for the VFX shot after negotiation and production approval. This is the committed cost against which actual expenditure is tracked.' ;
    rdfs:domain ind:VfxShot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedTeamName rdf:type rdf:Property ;
    rdfs:label 'Assigned Team Name' ;
    rdfs:comment 'Name of the in-house VFX team or department assigned to execute this shot. Null if the shot is outsourced to an external vendor.' ;
    rdfs:domain ind:VfxShot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidCost rdf:type rdf:Property ;
    rdfs:label 'Bid Cost' ;
    rdfs:comment 'Initial bid or estimated cost for the VFX shot as quoted by the vendor or estimated by the in-house team during pre-production planning. Expressed in the production\'s base currency.' ;
    rdfs:domain ind:VfxShot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:briefIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Brief Issued Date' ;
    rdfs:comment 'Date when the VFX shot brief and requirements were issued to the vendor or in-house team, marking the start of the VFX production timeline.' ;
    rdfs:domain ind:VfxShot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complexityTier rdf:type rdf:Property ;
    rdfs:label 'Complexity Tier' ;
    rdfs:comment 'Classification of the VFX shot complexity level used for resource planning and cost estimation. Simple: basic compositing or cleanup. Moderate: multi-layer compositing or simple CGI. Complex: advanced CGI, multiple effects layers, or intricate integration. Hero: signature shots requiring top-tier artistry and extensive iteration.' ;
    rdfs:domain ind:VfxShot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryVersion rdf:type rdf:Property ;
    rdfs:label 'Delivery Version' ;
    rdfs:comment 'Version number of the VFX shot delivery. Increments with each iteration submitted for review. Final approved version is recorded here.' ;
    rdfs:domain ind:VfxShot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalFrameCount rdf:type rdf:Property ;
    rdfs:label 'Final Frame Count' ;
    rdfs:comment 'Total number of frames in the final approved VFX shot. Used for billing, workload estimation, and archival metadata.' ;
    rdfs:domain ind:VfxShot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionCount rdf:type rdf:Property ;
    rdfs:label 'Revision Count' ;
    rdfs:comment 'Total number of revision iterations the VFX shot underwent from initial submission to final approval. Used for workload analysis and vendor performance evaluation.' ;
    rdfs:domain ind:VfxShot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sceneReference rdf:type rdf:Property ;
    rdfs:label 'Scene Reference' ;
    rdfs:comment 'Reference to the scene number or identifier in the script or production schedule to which this VFX shot belongs.' ;
    rdfs:domain ind:VfxShot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shotCode rdf:type rdf:Property ;
    rdfs:label 'Shot Code' ;
    rdfs:comment 'Unique business identifier for the VFX shot, typically following a hierarchical naming convention such as sequence_scene_shot (e.g., SQ010_SC020_0150). Used across production, post-production, and vendor communication.' ;
    rdfs:domain ind:VfxShot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shotName rdf:type rdf:Property ;
    rdfs:label 'Shot Name' ;
    rdfs:comment 'Human-readable descriptive name or title for the VFX shot, providing context about the shot content (e.g., \'Hero flies over city\', \'Explosion in warehouse\').' ;
    rdfs:domain ind:VfxShot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shotStatus rdf:type rdf:Property ;
    rdfs:label 'Shot Status' ;
    rdfs:comment 'Current lifecycle status of the VFX shot. Brief issued: initial requirements provided. In-progress: active work by vendor or team. Vendor review: internal QA at vendor. Client review: submitted to production for approval. Approved: final sign-off received. Archived: shot completed and archived.' ;
    rdfs:domain ind:VfxShot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:takeReference rdf:type rdf:Property ;
    rdfs:label 'Take Reference' ;
    rdfs:comment 'Reference to the specific camera take or plate footage that serves as the base for this VFX shot.' ;
    rdfs:domain ind:VfxShot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vfxCategory rdf:type rdf:Property ;
    rdfs:label 'Vfx Category' ;
    rdfs:comment 'Primary category of visual effects work required for this shot: compositing (layering multiple elements), CGI (computer-generated imagery), matte painting (digital background painting), motion capture (performance capture), de-aging (digital age reduction), or green screen key (chroma key extraction).' ;
    rdfs:domain ind:VfxShot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceRequestId rdf:type rdf:Property ;
    rdfs:label 'Clearance Request Id' ;
    rdfs:comment 'Unique identifier for the rights clearance request. Primary key for the clearance request workflow record.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conflictId rdf:type rdf:Property ;
    rdfs:label 'Conflict Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_conflict. Business justification: Clearance requests may be blocked by detected conflicts. Each clearance request may reference one blocking conflict that prevents exploitation. This FK enables tracing clearance denials back to the sp' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Conflict .

ind:holdbackId rdf:type rdf:Property ;
    rdfs:label 'Holdback Id' ;
    rdfs:comment 'Foreign key linking to rights.holdback. Business justification: Clearance requests may be blocked by specific holdbacks. Each clearance request may reference one blocking holdback that prevents exploitation. This FK enables tracing clearance denials back to the sp' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holdback .

ind:musicSyncLicenseId rdf:type rdf:Property ;
    rdfs:label 'Music Sync License Id' ;
    rdfs:comment 'Foreign key linking to rights.music_sync_license. Business justification: Clearance requests may require music sync licenses. Each request may reference one music sync license that must be validated. This FK enables tracing clearance requirements back to the specific music ' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MusicSyncLicense .

ind:primaryClearanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Clearance Employee Id' ;
    rdfs:comment 'Identifier of the employee or system user who submitted the clearance request. Enables accountability and follow-up communication.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:analystNotes rdf:type rdf:Property ;
    rdfs:label 'Analyst Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the clearance analyst during review. May include references to specific contract clauses, communications with rights holders, or special handling instructions.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingCategory rdf:type rdf:Property ;
    rdfs:label 'Blocking Category' ;
    rdfs:comment 'Classification of the primary reason for clearance denial. Enables reporting on common rights obstacles and process improvement. [ENUM-REF-CANDIDATE: holdback_period|territory_restriction|window_unavailable|rights_expired|music_sync_missing|talent_approval_required|residuals_unpaid|clearance_incomplete — promote to reference product]' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceDecision rdf:type rdf:Property ;
    rdfs:label 'Clearance Decision' ;
    rdfs:comment 'Final determination made by the clearance analyst regarding whether the content may be exploited as requested. Approved with conditions may require specific usage restrictions or additional payments.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalRequirements rdf:type rdf:Property ;
    rdfs:label 'Conditional Requirements' ;
    rdfs:comment 'Specific conditions or restrictions that must be met for conditional clearance approval. May include required credits, usage limitations, geographic blackouts, or additional royalty payments.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the clearance request was escalated to senior rights management or legal counsel due to complexity, ambiguity, or high business impact. Null if no escalation occurred.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedAudienceReach rdf:type rdf:Property ;
    rdfs:label 'Estimated Audience Reach' ;
    rdfs:comment 'Projected number of unique viewers or households expected to access the content in the requested exploitation. Used for royalty calculations and rights holder reporting.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedResidualsAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Residuals Amount' ;
    rdfs:comment 'Projected total residual payments owed to talent if the clearance is approved and content is distributed. Used for financial planning and budget approval workflows.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exploitationType rdf:type rdf:Property ;
    rdfs:label 'Exploitation Type' ;
    rdfs:comment 'The intended method of content distribution or monetization requiring clearance. Defines the rights window and licensing requirements that must be verified (e.g., SVOD - Subscription Video On Demand, AVOD - Advertising-Supported Video On Demand, TVOD - Transactional Video On Demand). [ENUM-REF-CANDIDATE: linear_broadcast|svod|avod|tvod|theatrical|syndication|vod|simulcast|fast|digital_download — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Status' ;
    rdfs:comment 'Status of data synchronization between Rightsline clearance system and downstream scheduling and playout systems (Ericsson MediaFirst). Ensures cleared content is automatically released to scheduling workflows.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Music Clearance Required' ;
    rdfs:comment 'Indicates whether separate music synchronization licenses must be verified before content can be cleared for distribution. True if content contains licensed music requiring additional clearance.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformChannel rdf:type rdf:Property ;
    rdfs:label 'Platform Channel' ;
    rdfs:comment 'Specific platform, channel, or outlet where the content is intended to be distributed (e.g., HBO Max, NBC Network, YouTube, Hulu). Used to verify platform-specific licensing restrictions.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Submitted Timestamp' ;
    rdfs:comment 'Date and time when the clearance request was initially submitted into the workflow system. Marks the start of the clearance review lifecycle and SLA clock.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedAirDate rdf:type rdf:Property ;
    rdfs:label 'Requested Air Date' ;
    rdfs:comment 'The target date when the content is scheduled to be broadcast, streamed, or published. Critical for verifying that rights are available within the requested window and that no holdback periods are violated.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedAirTime rdf:type rdf:Property ;
    rdfs:label 'Requested Air Time' ;
    rdfs:comment 'Precise timestamp for the intended broadcast or streaming start time, including time zone. Used for daypart-specific rights verification and scheduling coordination.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestingDepartment rdf:type rdf:Property ;
    rdfs:label 'Requesting Department' ;
    rdfs:comment 'Business unit or department initiating the clearance request. Identifies which operational area needs rights verification before proceeding with content exploitation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualsTriggered rdf:type rdf:Property ;
    rdfs:label 'Residuals Triggered' ;
    rdfs:comment 'Indicates whether the requested exploitation will trigger residual payments to talent per guild agreements. True if reuse payments are required for this distribution window.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Started Timestamp' ;
    rdfs:comment 'Date and time when a clearance analyst began active review of the request. Used to measure queue time and analyst response performance.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaMet rdf:type rdf:Property ;
    rdfs:label 'Sla Met' ;
    rdfs:comment 'Indicates whether the clearance request was resolved within the defined SLA target hours. Used for operational performance reporting and process improvement.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Number of business hours within which the clearance request must be resolved per service level agreement. Varies by priority level (urgent requests have shorter SLA targets).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:talentApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Talent Approval Required' ;
    rdfs:comment 'Indicates whether talent (actors, directors, producers) approval or notification is contractually required before the requested exploitation. True if talent has approval rights per guild agreements or individual contracts.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exploitationReportId rdf:type rdf:Property ;
    rdfs:label 'Exploitation Report Id' ;
    rdfs:comment 'Unique identifier for the exploitation report. Primary key for this entity.' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holderId rdf:type rdf:Property ;
    rdfs:label 'Holder Id' ;
    rdfs:comment 'Reference to the rights holder or licensor to whom this exploitation report is being submitted, identifying the recipient of royalty payments.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:reportingMarketCoverageId rdf:type rdf:Property ;
    rdfs:label 'Reporting Market Coverage Id' ;
    rdfs:comment 'Foreign key linking to audience.market_coverage. Business justification: Exploitation reports break down viewership by DMA (market coverage) for territory-specific license agreements and royalty calculations. Real business process: rights holders receive market-level explo' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketCoverage .

ind:rightsContentWindowId rdf:type rdf:Property ;
    rdfs:label 'Rights Content Window Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_content_window. Business justification: Exploitation reports document usage within specific content windows. Each report may relate to one rights content window that defines the exploitation parameters. This FK enables tracing exploitation ' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsContentWindow .

ind:royaltyStatementId rdf:type rdf:Property ;
    rdfs:label 'Royalty Statement Id' ;
    rdfs:comment 'Foreign key linking to rights.royalty_statement. Business justification: Exploitation reports feed into royalty statements. Each report may feed one statement, providing the raw usage data for royalty calculation. This FK enables tracing exploitation data to the resulting ' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyStatement .

ind:validatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Validated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Exploitation reports from distribution partners require validation by royalty analysts before acceptance for payment processing. Business needs to track who validated each report for quality control, ' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentNotes rdf:type rdf:Property ;
    rdfs:label 'Amendment Notes' ;
    rdfs:comment 'Documentation of changes made to the exploitation report after initial submission, typically in response to disputes or data corrections.' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentTitle rdf:type rdf:Property ;
    rdfs:label 'Content Title' ;
    rdfs:comment 'The title of the content asset being reported, captured for readability and quick reference without requiring joins to the content master.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Revenue Amount' ;
    rdfs:comment 'Total revenue attributed to the exploitation of this content during the reporting period before any deductions, used as the basis for royalty calculations.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Net Revenue Amount' ;
    rdfs:comment 'Revenue after contractually defined deductions (distribution fees, marketing costs, platform fees) that forms the royalty calculation base per the license agreement.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportFormatVersion rdf:type rdf:Property ;
    rdfs:label 'Report Format Version' ;
    rdfs:comment 'Version number of the exploitation report template or schema used, ensuring compatibility and correct interpretation of report fields over time.' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the exploitation report indicating its purpose: usage submission to rights holders, usage receipt from distributors, royalty evidence documentation, audit support materials, reconciliation reports, or ad-hoc custom reports.' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingEntityName rdf:type rdf:Property ;
    rdfs:label 'Reporting Entity Name' ;
    rdfs:comment 'Name of the organization that submitted the report, captured for audit trail and report header display.' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBroadcasts rdf:type rdf:Property ;
    rdfs:label 'Total Broadcasts' ;
    rdfs:comment 'Total number of linear broadcast transmissions of the content during the reporting period. Null for on-demand exploitation.' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStreams rdf:type rdf:Property ;
    rdfs:label 'Total Streams' ;
    rdfs:comment 'Total number of individual stream starts or playback initiations for on-demand content during the reporting period. Null for linear broadcast exploitation.' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalViewingHours rdf:type rdf:Property ;
    rdfs:label 'Total Viewing Hours' ;
    rdfs:comment 'Aggregate number of hours that audiences spent viewing the content during the reporting period, calculated as sum of all viewing durations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uniqueViewers rdf:type rdf:Property ;
    rdfs:label 'Unique Viewers' ;
    rdfs:comment 'Count of distinct individual viewers or households that accessed the content during the reporting period, representing reach metric.' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:automatedEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Enforcement Flag' ;
    rdfs:comment 'Indicates whether this holdback restriction is automatically enforced by scheduling and distribution systems or requires manual review.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageNegotiationReference rdf:type rdf:Property ;
    rdfs:label 'Carriage Negotiation Reference' ;
    rdfs:comment 'Reference identifier to the MVPD or vMVPD carriage negotiation that established this holdback restriction.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Workflow Status' ;
    rdfs:comment 'Status of the clearance workflow process that validates whether content can be scheduled or distributed despite this holdback restriction.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Conflict Resolution Notes' ;
    rdfs:comment 'Documentation of any conflicts with other rights, windows, or holdbacks and how they were resolved.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementStatus rdf:type rdf:Property ;
    rdfs:label 'Enforcement Status' ;
    rdfs:comment 'Current enforcement state of the holdback restriction, indicating whether it is actively blocking content exploitation or has been modified.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackCode rdf:type rdf:Property ;
    rdfs:label 'Holdback Code' ;
    rdfs:comment 'Business identifier code for the holdback restriction, used for external reference and clearance workflows.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedChannel rdf:type rdf:Property ;
    rdfs:label 'Restricted Channel' ;
    rdfs:comment 'Specific broadcast or distribution channel that is restricted from airing or distributing the content during the holdback period.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedFormat rdf:type rdf:Property ;
    rdfs:label 'Restricted Format' ;
    rdfs:comment 'Distribution format or delivery method that is restricted during the holdback period, supporting windowing strategies. [ENUM-REF-CANDIDATE: theatrical|linear_tv|svod|avod|tvod|vod|physical_media|syndication|streaming|broadcast — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedPlatform rdf:type rdf:Property ;
    rdfs:label 'Restricted Platform' ;
    rdfs:comment 'Name or identifier of the platform, distributor, or service that is restricted from exploiting the content during the holdback period. Applies to platform_holdback restriction types.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Classification of the holdback restriction type that defines the nature of the exclusivity period.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringWindowType rdf:type rdf:Property ;
    rdfs:label 'Triggering Window Type' ;
    rdfs:comment 'Type of content window that triggers or activates this holdback restriction, defining the sequential release strategy. [ENUM-REF-CANDIDATE: theatrical|svod|avod|tvod|linear|syndication|home_video|pay_per_view|free_tv|premium_tv — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the person or role who authorized the waiver or override of the holdback restriction.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved Date' ;
    rdfs:comment 'Date when the waiver or override of the holdback restriction was officially approved.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Business justification or explanation for waiving or overriding the holdback restriction, if applicable.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowingStrategyNotes rdf:type rdf:Property ;
    rdfs:label 'Windowing Strategy Notes' ;
    rdfs:comment 'Additional notes or context explaining how this holdback fits into the overall content windowing and sequential release strategy.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLicenseHolderId rdf:type rdf:Property ;
    rdfs:label 'Primary License Holder Id' ;
    rdfs:comment 'Reference to the party granting rights under this agreement (studio, distributor, music publisher, talent guild, production company).' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:primaryLicenseePartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Primary Licensee Partner Partner Id' ;
    rdfs:comment 'FK to partner.partner_partner' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:advancePaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Amount' ;
    rdfs:comment 'Upfront payment made upon execution of the agreement, typically recoupable against future royalties or license fees.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Clearance Required Flag' ;
    rdfs:comment 'Indicates whether additional rights clearance verification is required before content can be broadcast or distributed under this agreement. True = clearance workflow required, False = no additional clearance needed.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentRatingRestriction rdf:type rdf:Property ;
    rdfs:label 'Content Rating Restriction' ;
    rdfs:comment 'Content rating limitations imposed by this agreement (e.g., PG-13 and below only, no R-rated content). Comma-separated list of allowed ratings per MPA or TV Parental Guidelines.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaRightsGranted rdf:type rdf:Property ;
    rdfs:label 'Media Rights Granted' ;
    rdfs:comment 'Comma-separated list of media exploitation rights included in this agreement (e.g., linear broadcast, SVOD, AVOD, TVOD, theatrical, home video, digital download, mobile streaming).' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicSyncLicenseFlag rdf:type rdf:Property ;
    rdfs:label 'Music Sync License Flag' ;
    rdfs:comment 'Indicates whether this agreement includes music synchronization rights for use of musical compositions in audiovisual content. True = music sync rights included, False = no music sync rights.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perEpisodeFee rdf:type rdf:Property ;
    rdfs:label 'Per Episode Fee' ;
    rdfs:comment 'License fee charged per episode for episodic content. Applicable to syndication and first-run syndication agreements.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months of each automatic renewal period if auto_renewal_flag is true. Null if agreement does not auto-renew.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:royaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Royalty Calculation Method' ;
    rdfs:comment 'Method used to calculate ongoing royalty payments to the licensor. Determines how revenue is shared or how usage is monetized.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyPercentage rdf:type rdf:Property ;
    rdfs:label 'Royalty Percentage' ;
    rdfs:comment 'Percentage of revenue or receipts paid to the licensor as ongoing royalties. Applicable when royalty_calculation_method is percentage-based.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runCountLimit rdf:type rdf:Property ;
    rdfs:label 'Run Count Limit' ;
    rdfs:comment 'Maximum number of times each episode or program may be broadcast or streamed under this agreement. Common in syndication deals. Null indicates unlimited runs.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLicenseFee rdf:type rdf:Property ;
    rdfs:label 'Total License Fee' ;
    rdfs:comment 'Total contractual payment obligation for the license rights over the full term of the agreement. Sum of all payment milestones.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseAmendmentId rdf:type rdf:Property ;
    rdfs:label 'License Amendment Id' ;
    rdfs:comment 'Unique identifier for the license amendment record. Primary key.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseePartyPartnerId rdf:type rdf:Property ;
    rdfs:label 'Licensee Party Partner Id' ;
    rdfs:comment 'Reference to the content distributor or broadcaster party executing this amendment. Represents the organization acquiring or modifying rights.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:licensorRightsHolderId rdf:type rdf:Property ;
    rdfs:label 'Licensor Rights Holder Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_holder. Business justification: Amendments track licensor party changes. Each amendment relates to one licensor rights holder. This FK enables tracing amendment parties back to the authoritative rights holder record. Using licensor_' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:supersededByAmendmentLicenseAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Amendment License Amendment Id' ;
    rdfs:comment 'Reference to a subsequent amendment that supersedes or replaces this one. Null if this is the current active amendment.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAmendment .

ind:amendedLicenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Amended License Fee Amount' ;
    rdfs:comment 'The new total license fee or minimum guarantee amount after this amendment. Null if the amendment does not modify financial terms.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendedTermEndDate rdf:type rdf:Property ;
    rdfs:label 'Amended Term End Date' ;
    rdfs:comment 'The new license agreement end date after this amendment takes effect. Null if the amendment does not modify term duration.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Business justification or trigger for the amendment. Examples: market opportunity, performance renegotiation, rights holder request, regulatory change, strategic partnership expansion.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedTermsSummary rdf:type rdf:Property ;
    rdfs:label 'Changed Terms Summary' ;
    rdfs:comment 'Narrative summary of the specific terms modified by this amendment. Captures key changes for quick reference without requiring full legal document review. Examples: \'Extended term by 24 months\', \'Added AVOD rights for UK territory\', \'Reduced minimum guarantee by 15%\'.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Adjustment Amount' ;
    rdfs:comment 'The incremental change in license fee resulting from this amendment. Positive for increases, negative for reductions. Calculated as amended_license_fee_amount minus original_license_fee_amount.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdbackPeriodChangeDays rdf:type rdf:Property ;
    rdfs:label 'Holdback Period Change Days' ;
    rdfs:comment 'Change in holdback or exclusivity period measured in days. Positive for extensions, negative for reductions. Null if holdback terms unchanged.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Legal Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the executed legal amendment document stored in the document management system or MAM.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalLicenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Original License Fee Amount' ;
    rdfs:comment 'The total license fee or minimum guarantee amount before this amendment. Captured for financial audit and royalty recalculation.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalTermEndDate rdf:type rdf:Property ;
    rdfs:label 'Original Term End Date' ;
    rdfs:comment 'The license agreement end date before this amendment. Captured for audit trail and to calculate term extension impact.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformsAdded rdf:type rdf:Property ;
    rdfs:label 'Platforms Added' ;
    rdfs:comment 'Comma-separated list of distribution platforms or windows added by this amendment. Examples: SVOD, AVOD, TVOD, Linear, FAST, Theatrical. Empty if no platform expansion.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformsRemoved rdf:type rdf:Property ;
    rdfs:label 'Platforms Removed' ;
    rdfs:comment 'Comma-separated list of distribution platforms or windows removed or restricted by this amendment. Empty if no platform reduction.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresRoyaltyRecalculation rdf:type rdf:Property ;
    rdfs:label 'Requires Royalty Recalculation' ;
    rdfs:comment 'Indicates whether this amendment triggers retroactive royalty recalculation for past periods. True when financial terms are modified with retroactive effective dates.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyRateChangePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Change Percent' ;
    rdfs:comment 'Percentage point change in royalty rate resulting from this amendment. Positive for increases, negative for decreases. Null if royalty terms unchanged.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territoriesAdded rdf:type rdf:Property ;
    rdfs:label 'Territories Added' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes for territories added by this amendment. Empty if no territory expansion.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoriesRemoved rdf:type rdf:Property ;
    rdfs:label 'Territories Removed' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes for territories removed or restricted by this amendment. Empty if no territory reduction.' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'License Fee Schedule Id' ;
    rdfs:comment 'Unique identifier for the license fee schedule entry. Primary key.' ;
    rdfs:domain ind:LicenseFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Payment Date' ;
    rdfs:comment 'The date on which the payment was actually made to the licensor. Null if payment has not yet been completed.' ;
    rdfs:domain ind:LicenseFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generalLedgerAccount rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account' ;
    rdfs:comment 'The general ledger account code to which this payment expense is posted.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Late Fee Applicable' ;
    rdfs:comment 'Indicates whether late fees or penalties apply if payment is not made by the scheduled date.' ;
    rdfs:domain ind:LicenseFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Late Fee Percentage' ;
    rdfs:comment 'Percentage rate applied to the payment amount for late payment penalties. Null if late fees are not applicable.' ;
    rdfs:domain ind:LicenseFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Detailed description of the payment milestone or trigger event, such as contract signing, delivery of content, broadcast commencement, or anniversary date.' ;
    rdfs:domain ind:LicenseFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Approval Status' ;
    rdfs:comment 'Internal approval workflow status for the payment: pending approval (awaiting authorization), approved (cleared for payment), or rejected (payment denied).' ;
    rdfs:domain ind:LicenseFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the payment obligation: advance (upfront payment), minimum guarantee installment (periodic MG payment), per-episode fee (unit-based payment), annual license fee (recurring annual payment), milestone payment (event-triggered payment), or royalty payment (revenue-share payment).' ;
    rdfs:domain ind:LicenseFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Payment Date' ;
    rdfs:comment 'The contractually agreed date on which the payment is due to the licensor.' ;
    rdfs:domain ind:LicenseFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cleared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Music clearance workflows require tracking which music clearance coordinator negotiated and approved each sync license for accountability, performance metrics, and routing follow-up issues. Standard p' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:clearanceApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Approved Date' ;
    rdfs:comment 'Date when the music synchronization license was officially cleared and approved for use. Nullable if not yet approved.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceNotes rdf:type rdf:Property ;
    rdfs:label 'Clearance Notes' ;
    rdfs:comment 'Free-text notes documenting clearance workflow details, restrictions, special conditions, or communications with rights holders during the licensing process.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceRequestedDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Requested Date' ;
    rdfs:comment 'Date when the music synchronization license clearance was initially requested from the rights holder or clearance team.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:composerName rdf:type rdf:Property ;
    rdfs:label 'Composer Name' ;
    rdfs:comment 'Name of the composer or songwriter who created the musical composition.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositionTitle rdf:type rdf:Property ;
    rdfs:label 'Composition Title' ;
    rdfs:comment 'The title of the musical composition or work being licensed for synchronization use.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cueSheetRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cue Sheet Required Flag' ;
    rdfs:comment 'Indicates whether a cue sheet (detailed music usage report) must be filed with performance rights organizations for this license, typically required for broadcast and public performance.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iswcCode rdf:type rdf:Property ;
    rdfs:label 'Iswc Code' ;
    rdfs:comment 'International Standard Musical Work Code uniquely identifying the musical composition being licensed. Format: T-NNNNNNNNN-C where N is digit and C is check digit.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'License Fee Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the license fee amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedPlatforms rdf:type rdf:Property ;
    rdfs:label 'Licensed Platforms' ;
    rdfs:comment 'Comma-separated list of distribution platforms and channels where the licensed music may be used (e.g., linear broadcast, SVOD, AVOD, TVOD, theatrical, home video, social media).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proAffiliation rdf:type rdf:Property ;
    rdfs:label 'Pro Affiliation' ;
    rdfs:comment 'Name of the Performance Rights Organization (e.g., ASCAP, BMI, SESAC, PRS, SOCAN) with which the composer or publisher is affiliated for performance royalty collection.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolderType rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Type' ;
    rdfs:comment 'Classification of the rights holder entity (publisher for composition rights, record label for master recording rights, PRO for performance rights organization, independent artist for self-owned rights, production company for commissioned works, collective for rights societies).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyBasis rdf:type rdf:Property ;
    rdfs:label 'Royalty Basis' ;
    rdfs:comment 'The metric or revenue base upon which ongoing royalties are calculated (gross revenue, net revenue, per-stream count, per-download, per-unit sold, or flat fee with no ongoing royalties).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageType rdf:type rdf:Property ;
    rdfs:label 'Usage Type' ;
    rdfs:comment 'Classification of how the music is used within the content asset (background music, theme song, featured performance, promotional use, trailer, opening/closing credits).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualId rdf:type rdf:Property ;
    rdfs:label 'Residual Id' ;
    rdfs:comment 'Unique identifier for the residual payment obligation record. Primary key.' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:royaltyRuleId rdf:type rdf:Property ;
    rdfs:label 'Royalty Rule Id' ;
    rdfs:comment 'Foreign key linking to rights.royalty_rule. Business justification: Residuals are calculated using royalty rules. Each residual uses one royalty rule that defines the calculation formula. This FK enables tracing residual calculations back to the authoritative royalty ' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyRule .

ind:calculatedResidualAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Residual Amount' ;
    rdfs:comment 'The computed residual payment amount owed to the talent based on the formula type, calculation basis, and applicable rates.' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis Amount' ;
    rdfs:comment 'The base revenue or gross receipts amount used as the input to the residual formula calculation.' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationBasisCurrency rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the calculation basis amount (e.g., USD, GBP, CAD).' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'The date when the residual amount was calculated by the royalty system.' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractCycle rdf:type rdf:Property ;
    rdfs:label 'Contract Cycle' ;
    rdfs:comment 'The collective bargaining agreement cycle or contract period under which this residual is calculated (e.g., 2020-2023, 2023-2026).' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the calculated residual amount (e.g., USD, GBP, CAD).' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exhibitionCount rdf:type rdf:Property ;
    rdfs:label 'Exhibition Count' ;
    rdfs:comment 'The number of times the content was exhibited or broadcast during the residual calculation period, used for per-exhibition or tiered formulas.' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exploitationEndDate rdf:type rdf:Property ;
    rdfs:label 'Exploitation End Date' ;
    rdfs:comment 'The date when the content exploitation period that triggered this residual ended. Nullable for ongoing exploitation.' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exploitationStartDate rdf:type rdf:Property ;
    rdfs:label 'Exploitation Start Date' ;
    rdfs:comment 'The date when the content exploitation period that triggered this residual began (e.g., first streaming availability date, first rerun air date).' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formulaType rdf:type rdf:Property ;
    rdfs:label 'Formula Type' ;
    rdfs:comment 'The calculation method used to determine the residual amount (fixed amount, percentage of gross receipts, percentage of distributor gross, tiered scale based on exhibition count, per-exhibition fee, minimum guarantee).' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Guild Report Submission Date' ;
    rdfs:comment 'The date when the residual payment was reported to the guild or union. Nullable if not yet reported.' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guildReportSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Guild Report Submitted Flag' ;
    rdfs:comment 'Indicates whether this residual payment has been included in the mandatory guild reporting submission (True/False).' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guildUnionCode rdf:type rdf:Property ;
    rdfs:label 'Guild Union Code' ;
    rdfs:comment 'The guild or union governing this residual obligation (SAG-AFTRA for actors, WGA for writers, DGA for directors, IATSE for crew, AFM for musicians, ACTRA for Canadian talent). [ENUM-REF-CANDIDATE: SAG-AFTRA|WGA|DGA|IATSE|AFM|ACTRA|OTHER — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'The percentage rate applied to the calculation basis when the formula type is percentage-based (e.g., 0.0350 for 3.5%).' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The financial or royalty reporting period to which this residual obligation belongs (e.g., Q1-2024, 2024-H1), used for guild reporting and financial reconciliation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsAuditEventId rdf:type rdf:Property ;
    rdfs:label 'Rights Audit Event Id' ;
    rdfs:comment 'Unique identifier for the rights audit event record. Primary key.' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRightsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rights Employee Id' ;
    rdfs:comment 'The system user identifier of the person or service account that initiated the rights change. May reference an employee ID, service account, or external system identifier.' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedEntityBusinessKey rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Business Key' ;
    rdfs:comment 'The human-readable business identifier of the affected entity (e.g., agreement number, grant number, window name) for easier audit trail interpretation.' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedEntityReference rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Reference' ;
    rdfs:comment 'The unique identifier of the specific rights domain entity that was modified (e.g., the rights_grant_id, license_agreement_id, or holdback_id).' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedEntityType rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Type' ;
    rdfs:comment 'The type of rights domain entity that was modified by this audit event (e.g., rights grant, license agreement, content window, holdback record).' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Reference Number' ;
    rdfs:comment 'Unique reference number or workflow ticket ID associated with the approval process for cross-system traceability.' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverUserName rdf:type rdf:Property ;
    rdfs:label 'Approver User Name' ;
    rdfs:comment 'The full name or display name of the approver for human-readable audit trail reporting. NULL if approval not required or still pending.' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Audit Retention Period Days' ;
    rdfs:comment 'Number of days this audit record must be retained per regulatory or legal requirements. Drives data lifecycle management policies.' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the rights change. [ENUM-REF-CANDIDATE: contract_amendment|rights_expiration|territory_expansion|territory_restriction|holdback_negotiation|clearance_issue|royalty_adjustment|windowing_strategy_update|compliance_requirement|legal_dispute|system_correction|data_migration — promote to reference product]' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Free-text explanation providing additional context and business justification for the rights change event.' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedFieldName rdf:type rdf:Property ;
    rdfs:label 'Changed Field Name' ;
    rdfs:comment 'The name of the specific attribute or field within the affected entity that was modified (e.g., grant_end_date, holdback_start_date, royalty_rate_percent).' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'The regulatory or compliance framework that mandates audit logging of this rights change event (e.g., SOX for financial controls, FCC for broadcast licensing, Ofcom for UK broadcasting standards).' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference Number' ;
    rdfs:comment 'Reference number or case identifier for any legal dispute or rights conflict associated with this change. NULL if no dispute exists.' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Flag' ;
    rdfs:comment 'Indicates whether this rights change has direct financial implications (e.g., royalty rate change, license fee adjustment, minimum guarantee modification). True if financial impact exists, False otherwise.' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatingSystem rdf:type rdf:Property ;
    rdfs:label 'Initiating System' ;
    rdfs:comment 'The source system or application that generated the rights change event (e.g., Rightsline, SAP, manual entry, API integration).' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingUserName rdf:type rdf:Property ;
    rdfs:label 'Initiating User Name' ;
    rdfs:comment 'The full name or display name of the user who initiated the rights change, for human-readable audit trail reporting.' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newValue rdf:type rdf:Property ;
    rdfs:label 'New Value' ;
    rdfs:comment 'The value of the changed field after the modification occurred. Stored as string representation to accommodate all data types. NULL for deletion events.' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousValue rdf:type rdf:Property ;
    rdfs:label 'Previous Value' ;
    rdfs:comment 'The value of the changed field before the modification occurred. Stored as string representation to accommodate all data types. NULL for new record creation events.' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordHash rdf:type rdf:Property ;
    rdfs:label 'Record Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the audit event record to ensure immutability and detect tampering. Supports forensic integrity verification.' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryAffected rdf:type rdf:Property ;
    rdfs:label 'Territory Affected' ;
    rdfs:comment 'Geographic territory or market affected by the rights change (e.g., USA, GBR, Worldwide). Uses three-letter ISO 3166-1 alpha-3 country codes or territory groupings.' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'Unique identifier for the database transaction or batch operation that committed this change. Enables grouping of related audit events within a single transaction.' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowTypeAffected rdf:type rdf:Property ;
    rdfs:label 'Window Type Affected' ;
    rdfs:comment 'The content distribution window type affected by this rights change (e.g., theatrical, SVOD, AVOD, TVOD, linear broadcast, syndication). NULL if change does not affect windowing. [ENUM-REF-CANDIDATE: theatrical|SVOD|AVOD|TVOD|linear|syndication|home_video — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RightsAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advertisingAllowed rdf:type rdf:Property ;
    rdfs:label 'Advertising Allowed' ;
    rdfs:comment 'Indicates whether advertising insertion (pre-roll, mid-roll, post-roll) is permitted during content playback for this availability window. True = ads allowed, False = ad-free distribution only.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availabilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Availability End Date' ;
    rdfs:comment 'The date when the content asset is no longer available for exploitation on the specified platform and territory. Represents the end of the net exploitable window. Nullable for perpetual rights.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availabilityStartDate rdf:type rdf:Property ;
    rdfs:label 'Availability Start Date' ;
    rdfs:comment 'The date when the content asset becomes available for exploitation on the specified platform and territory. Represents the beginning of the net exploitable window.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blackoutIndicator rdf:type rdf:Property ;
    rdfs:label 'Blackout Indicator' ;
    rdfs:comment 'Indicates whether a geographic broadcast restriction (blackout) applies to this availability window. True = blackout in effect, False = no blackout restriction.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Applicable' ;
    rdfs:comment 'Indicates whether a carriage fee (distribution payment to the content provider) applies to this availability window. True = carriage fee required, False = no carriage fee.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:computedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Computed Timestamp' ;
    rdfs:comment 'The timestamp when this availability window record was computed from the intersection of upstream rights grants, holdbacks, and content windows. Represents the calculation execution time.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downloadToOwnAllowed rdf:type rdf:Property ;
    rdfs:label 'Download To Own Allowed' ;
    rdfs:comment 'Indicates whether permanent download (download-to-own, DTO) is permitted during this availability window. True = DTO allowed, False = streaming-only distribution.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Expiration Notification Sent' ;
    rdfs:comment 'Indicates whether an expiration notification has been sent to scheduling and distribution systems alerting them that this availability window is approaching its end date. True = notification sent, False = not yet notified.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verified Timestamp' ;
    rdfs:comment 'The timestamp when this availability window was last verified against upstream rights and clearance records. Used for audit and compliance tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:offlineViewingAllowed rdf:type rdf:Property ;
    rdfs:label 'Offline Viewing Allowed' ;
    rdfs:comment 'Indicates whether temporary offline viewing (download for offline playback with expiration) is permitted during this availability window. True = offline viewing allowed, False = online streaming only.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:simulcastAllowed rdf:type rdf:Property ;
    rdfs:label 'Simulcast Allowed' ;
    rdfs:comment 'Indicates whether simultaneous multi-platform broadcast (simulcast) is permitted during this availability window. True = simulcast allowed, False = platform-exclusive distribution only.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:syndicationAllowed rdf:type rdf:Property ;
    rdfs:label 'Syndication Allowed' ;
    rdfs:comment 'Indicates whether the content can be syndicated (resold to multiple outlets) during this availability window. True = syndication permitted, False = syndication prohibited.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightsBlackoutRuleId rdf:type rdf:Property ;
    rdfs:label 'Rights Blackout Rule Id' ;
    rdfs:comment 'Unique identifier for the blackout rule record. Primary key.' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRightsMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Rights Media Asset Id' ;
    rdfs:comment 'Reference to the specific content asset subject to blackout restriction.' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:rightsSyndicationDealId rdf:type rdf:Property ;
    rdfs:label 'Rights Syndication Deal Id' ;
    rdfs:comment 'Foreign key linking to rights.syndication_deal. Business justification: Blackout rules may arise from syndication deals. Each blackout rule may reference one syndication deal that defines the blackout restrictions. This FK enables tracing blackout rules back to the source' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsSyndicationDeal .

ind:blackoutDurationHours rdf:type rdf:Property ;
    rdfs:label 'Blackout Duration Hours' ;
    rdfs:comment 'Calculated duration of the blackout period in hours, derived from start and end datetime. Used for reporting and analytics.' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Blackout End Datetime' ;
    rdfs:comment 'Precise date and time when the blackout restriction expires. Nullable for indefinite blackouts. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blackoutMessageText rdf:type rdf:Property ;
    rdfs:label 'Blackout Message Text' ;
    rdfs:comment 'Viewer-facing message or notification text to be displayed when content is unavailable due to this blackout restriction. Used for customer communication and transparency.' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutRuleCode rdf:type rdf:Property ;
    rdfs:label 'Blackout Rule Code' ;
    rdfs:comment 'Business-assigned unique code identifying this blackout rule for operational reference and reporting.' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Blackout Start Datetime' ;
    rdfs:comment 'Precise date and time when the blackout restriction becomes effective. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blackoutType rdf:type rdf:Property ;
    rdfs:label 'Blackout Type' ;
    rdfs:comment 'Classification of the blackout restriction: sports local market blackout (home team market protection), affiliate exclusivity blackout (local station rights), regulatory blackout (government-mandated restriction), territorial holdback (geographic windowing), competitive protection (anti-siphoning), or league-imposed (sports league rule).' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementMethod rdf:type rdf:Property ;
    rdfs:label 'Enforcement Method' ;
    rdfs:comment 'Technical mechanism used to enforce the blackout: geo-blocking (IP-based restriction), content suppression (removal from catalog), redirect (alternate content substitution), alternate feed (different broadcast signal), or manual override (operator intervention).' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeTeamMarketFlag rdf:type rdf:Property ;
    rdfs:label 'Home Team Market Flag' ;
    rdfs:comment 'Indicates whether this blackout applies to the home team\'s local market to protect local broadcast rights. True for home market blackouts, False otherwise. Applicable to sports content.' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentDatetime rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Datetime' ;
    rdfs:comment 'Date and time when automated notifications about this blackout rule were dispatched to downstream systems and stakeholders. Nullable if notifications not yet sent. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sportsLeagueCode rdf:type rdf:Property ;
    rdfs:label 'Sports League Code' ;
    rdfs:comment 'Code identifying the sports league or governing body that mandates this blackout rule (e.g., NFL, NBA, MLB, NHL, MLS, NCAA). Applicable only for sports-related blackouts.' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringRightsClause rdf:type rdf:Property ;
    rdfs:label 'Triggering Rights Clause' ;
    rdfs:comment 'Reference to the specific contractual clause, section, or provision in the license agreement that mandates this blackout restriction. May include clause number and brief description.' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Flag' ;
    rdfs:comment 'Indicates whether an exception or waiver has been granted to bypass this blackout rule. True if waiver approved, False otherwise.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Conflict Employee Id' ;
    rdfs:comment 'Reference to the rights analyst or user responsible for reviewing and resolving this conflict.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:conflictLegalReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Conflict Legal Reviewer Employee Id' ;
    rdfs:comment 'Reference to the legal department staff member who reviewed the conflict. Null if no legal review was performed.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:conflictResolvedByAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Conflict Resolved By Analyst Employee Id' ;
    rdfs:comment 'Reference to the rights analyst or user who ultimately resolved or closed the conflict. Null if conflict remains open.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryRightsGrantId rdf:type rdf:Property ;
    rdfs:label 'Primary Rights Grant Id' ;
    rdfs:comment 'Reference to the first rights grant involved in the conflict.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grant .

ind:affectedDistributionPartners rdf:type rdf:Property ;
    rdfs:label 'Affected Distribution Partners' ;
    rdfs:comment 'Comma-separated list of distribution partner names or identifiers affected by this conflict (e.g., streaming platforms, broadcasters, MVPD partners).' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPriority rdf:type rdf:Property ;
    rdfs:label 'Business Priority' ;
    rdfs:comment 'Business priority classification for resolving the conflict: critical (blocks major release or high-value content), high (impacts significant revenue or strategic content), medium (standard business impact), or low (minimal business impact).' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictType rdf:type rdf:Property ;
    rdfs:label 'Conflict Type' ;
    rdfs:comment 'Classification of the type of rights conflict detected: territorial overlap (same territory granted to multiple parties), platform overlap (same platform rights conflict), holdback violation (content released during holdback period), window gap (gap between sequential windows), exclusivity breach (non-exclusive grant conflicts with exclusive grant), or duration overlap (time period overlap).' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'The precise date and time when the rights conflict was first detected by the system or identified by a rights analyst.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalOpinionSummary rdf:type rdf:Property ;
    rdfs:label 'Legal Opinion Summary' ;
    rdfs:comment 'Summary of the legal department\'s assessment and recommendations regarding the conflict. Contains privileged attorney-client communication.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'The date and time when stakeholder notifications were sent. Null if no notifications have been sent.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Resolution Method' ;
    rdfs:comment 'The approach used to resolve the conflict: contract amendment (modify existing agreement terms), rights buyback (purchase back conflicting rights), window adjustment (change release timing), territory restriction (limit geographic availability), platform exclusion (remove platform from grant), holdback extension (extend exclusivity period), or negotiated settlement (mutual agreement between parties). [ENUM-REF-CANDIDATE: contract_amendment|rights_buyback|window_adjustment|territory_restriction|platform_exclusion|holdback_extension|negotiated_settlement — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResolutionDeadline rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Deadline' ;
    rdfs:comment 'The target date and time by which the conflict must be resolved according to internal service level agreements, based on business priority and content release schedules.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this window record is currently active and should be considered in availability calculations. False if the window has been superseded, cancelled, or archived.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'The computed net availability status of the content for this window, considering window dates, holdbacks, and blackouts. Refreshed whenever upstream rights or holdback records change. Directly consumed by scheduling and distribution domains to validate playout eligibility.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutReason rdf:type rdf:Property ;
    rdfs:label 'Blackout Reason' ;
    rdfs:comment 'The business or regulatory reason for the blackout restriction (e.g., sports event local blackout, contractual exclusivity, regulatory compliance). Populated only when blackout_flag is true.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoBlockingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Geo Blocking Required Flag' ;
    rdfs:comment 'Indicates whether geographic blocking technology must be enforced to restrict access to the specified territory. True if geo-blocking is mandatory; false if not required.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdbackEndDate rdf:type rdf:Property ;
    rdfs:label 'Holdback End Date' ;
    rdfs:comment 'The date when a holdback period ends and distribution is re-authorized. Marks the conclusion of the exclusivity restriction.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdbackStartDate rdf:type rdf:Property ;
    rdfs:label 'Holdback Start Date' ;
    rdfs:comment 'The date when a holdback period begins, temporarily restricting distribution even within an open window. Used to enforce exclusivity periods and prevent simultaneous exploitation across competing platforms.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAvailabilityRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Availability Refresh Timestamp' ;
    rdfs:comment 'The timestamp when the availability_status was last recalculated. Updated whenever upstream rights, holdback, or blackout records change. Used to track data freshness for scheduling and distribution systems.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:usageCapType rdf:type rdf:Property ;
    rdfs:label 'Usage Cap Type' ;
    rdfs:comment 'The unit of measure for the usage cap (e.g., streams for SVOD, broadcasts for linear, screenings for theatrical). Defines how usage is counted against the cap.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCapUnits rdf:type rdf:Property ;
    rdfs:label 'Usage Cap Units' ;
    rdfs:comment 'The maximum number of usage units (streams, downloads, broadcasts, screenings) permitted during this window. Used to enforce contractual usage limits.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowExtensionCount rdf:type rdf:Property ;
    rdfs:label 'Window Extension Count' ;
    rdfs:comment 'The number of times this window has been extended beyond its original close date. Tracks amendments and extensions to the original window terms.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutApplicable rdf:type rdf:Property ;
    rdfs:label 'Blackout Applicable' ;
    rdfs:comment 'Indicates whether geographic or temporal blackout restrictions apply to this grant (e.g., sports blackouts, regional restrictions).' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityIndicator rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Indicator' ;
    rdfs:comment 'Indicates whether the grant is exclusive (true) or non-exclusive (false). Exclusive grants prevent other parties from exploiting the same rights in the same territory and window.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Number' ;
    rdfs:comment 'Business identifier for the rights grant, typically a human-readable code used in Rightsline and operational workflows.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantStatus rdf:type rdf:Property ;
    rdfs:label 'Grant Status' ;
    rdfs:comment 'Current lifecycle status of the rights grant. Reflects whether the grant is currently in force, expired, or otherwise inactive.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackApplicable rdf:type rdf:Property ;
    rdfs:label 'Holdback Applicable' ;
    rdfs:comment 'Indicates whether a holdback period applies to this grant. Holdbacks restrict exploitation during specific windows to protect other distribution channels.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaType rdf:type rdf:Property ;
    rdfs:label 'Media Type' ;
    rdfs:comment 'The media format or delivery mechanism covered by this grant (e.g., television, film, digital streaming, audio).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicSyncLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Music Sync License Required' ;
    rdfs:comment 'Indicates whether a separate music synchronization license is required for the music tracks embedded in the content.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightType rdf:type rdf:Property ;
    rdfs:label 'Right Type' ;
    rdfs:comment 'Type of distribution or exploitation right granted. Defines the platform or medium for which the content may be used. [ENUM-REF-CANDIDATE: broadcast|svod|avod|tvod|theatrical|home_video|music_sync|podcast|linear|non_linear|vod — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensePermitted rdf:type rdf:Property ;
    rdfs:label 'Sublicense Permitted' ;
    rdfs:comment 'Indicates whether the licensee is permitted to sublicense the rights to third parties.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:talentResidualsApplicable rdf:type rdf:Property ;
    rdfs:label 'Talent Residuals Applicable' ;
    rdfs:comment 'Indicates whether talent residual payments (reuse payments to actors, directors, writers) are triggered by this grant.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windowName rdf:type rdf:Property ;
    rdfs:label 'Window Name' ;
    rdfs:comment 'Named distribution window (e.g., Theatrical, Premium VOD, Pay-TV, Free-TV) that this grant falls within. Used for windowing strategy enforcement.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountName rdf:type rdf:Property ;
    rdfs:label 'Bank Account Name' ;
    rdfs:comment 'Name on the bank account designated for royalty payments. Must match legal entity name for payment processing compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Bank account number for royalty payment remittance. Encrypted at rest and in transit per PCI DSS requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearancePriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Clearance Priority Level' ;
    rdfs:comment 'Priority level assigned to clearance requests for content from this rights holder. VIP and critical levels receive accelerated processing.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultRoyaltyRate rdf:type rdf:Property ;
    rdfs:label 'Default Royalty Rate' ;
    rdfs:comment 'Default royalty rate percentage applied to new agreements with this rights holder. Can be overridden at the contract level.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityPreference rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Preference' ;
    rdfs:comment 'Rights holder\'s stated preference for exclusivity terms in licensing agreements. Influences windowing strategy and holdback negotiations.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildAffiliation rdf:type rdf:Property ;
    rdfs:label 'Guild Affiliation' ;
    rdfs:comment 'Name of talent guild or performing rights organization (PRO) that this rights holder is affiliated with. Determines residual payment rules and reporting requirements. [ENUM-REF-CANDIDATE: sag_aftra|wga|dga|afm|ascap|bmi|sesac|gema|prs|socan — promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteeThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Threshold' ;
    rdfs:comment 'Minimum guarantee amount threshold below which this rights holder will not enter licensing agreements. Used for deal structuring and negotiation.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mostFavoredNationsFlag rdf:type rdf:Property ;
    rdfs:label 'Most Favored Nations Flag' ;
    rdfs:comment 'Indicates whether this rights holder has most favored nations clause requiring rate parity with other similar rights holders. True triggers rate comparison workflows.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'Three-letter ISO currency code representing the rights holder\'s preferred currency for royalty payments and contract valuations.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrantIdentifier rdf:type rdf:Property ;
    rdfs:label 'Registrant Identifier' ;
    rdfs:comment 'The ISAN or ISRC registrant identifier assigned to the rights holder by the respective international registration authority. Used for global rights tracking and content identification.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolderCode rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Code' ;
    rdfs:comment 'Internal business identifier code assigned to the rights holder for operational reference and system integration across Rightsline and billing systems.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolderStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Status' ;
    rdfs:comment 'Current lifecycle status of the rights holder relationship. Active status is required for new license agreements and royalty payments.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Classification' ;
    rdfs:comment 'Tax withholding classification for royalty payments. Determines applicable withholding rates based on tax treaties and domestic regulations.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingRate rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Rate' ;
    rdfs:comment 'Applicable tax withholding rate percentage for royalty payments to this rights holder. Derived from tax treaties and domestic law based on withholding classification.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territoryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Territory Of Incorporation' ;
    rdfs:comment 'Three-letter ISO country code representing the legal jurisdiction where the rights holder entity is incorporated or registered. Determines applicable tax treaties and withholding requirements.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'The financial or usage metric upon which the royalty calculation is based (e.g., gross revenue, net revenue, subscriber count, stream count, GRP). [ENUM-REF-CANDIDATE: gross_revenue|net_revenue|subscriber_count|stream_count|grp|unit_sales|advertising_revenue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Deduction Allowed Flag' ;
    rdfs:comment 'Indicates whether deductions (e.g., distribution costs, marketing expenses) are allowed before calculating the royalty. True if deductions are permitted, False otherwise.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Deduction Percentage' ;
    rdfs:comment 'The percentage of revenue or basis that may be deducted before applying the royalty rate. Nullable if no deduction applies.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumCapAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Cap Amount' ;
    rdfs:comment 'The maximum royalty payment cap for this rule. Royalty calculations will not exceed this amount. Nullable if no cap applies.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTiming rdf:type rdf:Property ;
    rdfs:label 'Payment Timing' ;
    rdfs:comment 'The timing of royalty payments relative to the calculation period (e.g., advance, arrears, upon delivery, upon release, milestone-based).' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'The unit of measure for the rate value (e.g., percentage, per stream, per subscriber, per unit, per GRP, flat amount).' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'The numeric rate or percentage applied in the royalty calculation. For percentage-based royalties, this is the percentage (e.g., 15.5 for 15.5%). For per-unit rates, this is the amount per unit.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoupmentFlag rdf:type rdf:Property ;
    rdfs:label 'Recoupment Flag' ;
    rdfs:comment 'Indicates whether this royalty rule includes recoupment provisions (e.g., advance payments must be recouped before additional royalties are paid). True if recoupment applies, False otherwise.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recoupmentThreshold rdf:type rdf:Property ;
    rdfs:label 'Recoupment Threshold' ;
    rdfs:comment 'The monetary threshold that must be recouped before additional royalty payments are made. Nullable if no recoupment applies.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualFormula rdf:type rdf:Property ;
    rdfs:label 'Residual Formula' ;
    rdfs:comment 'The formula or calculation logic for residual payments to talent (actors, directors, writers) based on reuse, reruns, or secondary exploitation. Nullable if not applicable.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Royalty Rule Status' ;
    rdfs:comment 'Current lifecycle status of the royalty rule (e.g., draft, active, suspended, expired, terminated).' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyType rdf:type rdf:Property ;
    rdfs:label 'Royalty Type' ;
    rdfs:comment 'The type of royalty calculation method applied by this rule. Determines how the royalty amount is computed.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business-assigned unique code or identifier for this royalty rule, used for reference in contracts and reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name or title of the royalty rule, describing its purpose or scope (e.g., \'SVOD Revenue Share - Tier 1\', \'Per-Stream Rate - Music Sync\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulePriority rdf:type rdf:Property ;
    rdfs:label 'Rule Priority' ;
    rdfs:comment 'The priority or precedence of this royalty rule when multiple rules may apply to the same content or transaction. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'The unit of measure for the threshold value (e.g., revenue, subscriber count, stream count, unit count, GRP).' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advanceRecoupmentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Recoupment Amount' ;
    rdfs:comment 'Amount deducted from gross royalties to recoup advances previously paid to the rights holder under the agreement.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentTitleBreakdown rdf:type rdf:Property ;
    rdfs:label 'Content Title Breakdown' ;
    rdfs:comment 'Structured breakdown of royalties by content title or asset. Stored as JSON or delimited string for detailed reporting.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exploitationTypeBreakdown rdf:type rdf:Property ;
    rdfs:label 'Exploitation Type Breakdown' ;
    rdfs:comment 'Structured breakdown of royalties by exploitation type (theatrical, SVOD, AVOD, TVOD, linear, syndication, home video, etc.). Stored as JSON or delimited string for detailed reporting.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Royalty Amount' ;
    rdfs:comment 'Total royalty amount earned by the rights holder before any deductions, recoupments, or adjustments.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumGuaranteeShortfall rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Shortfall' ;
    rdfs:comment 'The difference between the contractual minimum guarantee and actual royalties earned for the period. A positive value indicates the rights holder is entitled to a minimum guarantee payment.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Net Royalty Amount' ;
    rdfs:comment 'Final royalty amount payable to the rights holder after all deductions, recoupments, taxes, and adjustments. This is the amount that will be paid.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementDueDate rdf:type rdf:Property ;
    rdfs:label 'Statement Due Date' ;
    rdfs:comment 'The date by which payment of the royalties on this statement is contractually due to the rights holder.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementFrequency rdf:type rdf:Property ;
    rdfs:label 'Statement Frequency' ;
    rdfs:comment 'The reporting frequency for this royalty statement as defined in the underlying rights agreement.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementIssueDate rdf:type rdf:Property ;
    rdfs:label 'Statement Issue Date' ;
    rdfs:comment 'The date on which this royalty statement was officially issued to the rights holder.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementNotes rdf:type rdf:Property ;
    rdfs:label 'Statement Notes' ;
    rdfs:comment 'Free-text notes or comments related to this royalty statement, including explanations of unusual adjustments, special circumstances, or clarifications for the rights holder.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'Externally-known unique business identifier for this royalty statement, used for reference in correspondence and payment processing.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period End Date' ;
    rdfs:comment 'The last date of the reporting period covered by this royalty statement.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period Start Date' ;
    rdfs:comment 'The first date of the reporting period covered by this royalty statement.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementStatus rdf:type rdf:Property ;
    rdfs:label 'Statement Status' ;
    rdfs:comment 'Current lifecycle status of the royalty statement. Draft statements are under review, approved statements are ready for payment, disputed statements have objections from rights holders, paid statements have been settled, and cancelled statements have been voided.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryBreakdown rdf:type rdf:Property ;
    rdfs:label 'Territory Breakdown' ;
    rdfs:comment 'Structured breakdown of royalties by geographic territory or market. Stored as JSON or delimited string for detailed reporting.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyStatementLineId rdf:type rdf:Property ;
    rdfs:label 'Royalty Statement Line Id' ;
    rdfs:comment 'Unique identifier for the royalty statement line item. Primary key for this entity.' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentsAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustments Amount' ;
    rdfs:comment 'Additional adjustments applied to the royalty calculation, such as corrections from prior periods, contractual bonuses, penalties, or dispute resolutions. Can be positive or negative.' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Royalty Amount' ;
    rdfs:comment 'Royalty amount calculated by applying the royalty rate to the net revenue. Represents the gross royalty obligation before advance recoupment or adjustments.' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Deductions Amount' ;
    rdfs:comment 'Total deductions applied to gross revenue before calculating royalty base. May include distribution fees, marketing costs, platform fees, or other contractually allowed deductions.' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exploitationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Exploitation Period End Date' ;
    rdfs:comment 'End date of the period during which the exploitation activity occurred. Defines the end of the reporting window for this royalty line.' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exploitationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Exploitation Period Start Date' ;
    rdfs:comment 'Start date of the period during which the exploitation activity occurred. Defines the beginning of the reporting window for this royalty line.' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdbackStatus rdf:type rdf:Property ;
    rdfs:label 'Holdback Status' ;
    rdfs:comment 'Status of any holdback or exclusivity period applicable to this exploitation. Indicates whether the content was exploited within or outside of contractual holdback restrictions.' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPayableAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payable Amount' ;
    rdfs:comment 'Final net amount payable to the rights holder for this line item after all deductions, advance recoupment, and adjustments. This is the amount that will be paid out.' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualType rdf:type rdf:Property ;
    rdfs:label 'Residual Type' ;
    rdfs:comment 'Classification of residual payment type for talent royalties. Indicates the nature of the reuse payment under guild agreements (SAG-AFTRA, WGA, DGA). [ENUM-REF-CANDIDATE: initial_use|rerun|foreign|supplemental|new_media|streaming|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percentage' ;
    rdfs:comment 'Percentage rate applied to the royalty base to calculate the royalty amount. Derived from the underlying rights agreement and may vary by territory, platform, and exploitation type.' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsExploited rdf:type rdf:Property ;
    rdfs:label 'Units Exploited' ;
    rdfs:comment 'Quantity of exploitation units for this line item. Interpretation depends on exploitation type: streams for SVOD/AVOD, broadcasts for linear, downloads for TVOD, tickets for theatrical.' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealExecutiveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Deal Executive Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Syndication deals require tracking the syndication sales executive responsible for the deal for commission calculations, territory assignment, renewal routing, and performance management. Standard pra' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:syndicationPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Syndication Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Syndication deals are partner-facing distribution agreements requiring direct FK to identify the syndication partner (licensee). Enables partner-centric syndication reporting, partner performance anal' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:autoRenewalIndicator rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Indicator' ;
    rdfs:comment 'Indicates whether the deal automatically renews for an additional term unless either party provides notice (True) or requires explicit renewal negotiation (False).' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutDescription rdf:type rdf:Property ;
    rdfs:label 'Blackout Description' ;
    rdfs:comment 'Detailed description of any blackout restrictions, including affected territories, time periods, or triggering events.' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentPackageDescription rdf:type rdf:Property ;
    rdfs:label 'Content Package Description' ;
    rdfs:comment 'Detailed description of the content included in the syndication deal, including titles, episode counts, and any exclusions.' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealEndDate rdf:type rdf:Property ;
    rdfs:label 'Deal End Date' ;
    rdfs:comment 'Date on which the syndication rights expire and the licensee must cease distribution. Null indicates an open-ended or perpetual deal.' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealNotes rdf:type rdf:Property ;
    rdfs:label 'Deal Notes' ;
    rdfs:comment 'Free-text field for additional notes, special terms, or contextual information about the syndication deal.' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealStartDate rdf:type rdf:Property ;
    rdfs:label 'Deal Start Date' ;
    rdfs:comment 'Date on which the syndication rights become effective and the licensee may begin distribution.' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealTermMonths rdf:type rdf:Property ;
    rdfs:label 'Deal Term Months' ;
    rdfs:comment 'Duration of the syndication deal in months, calculated from start date to end date. Facilitates term-based reporting and renewal planning.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeStructureType rdf:type rdf:Property ;
    rdfs:label 'Fee Structure Type' ;
    rdfs:comment 'Model for syndication compensation: flat fee (single payment for entire deal), per-episode (payment per episode delivered), per-run (payment per broadcast), revenue share (percentage of licensee revenue), barter (ad inventory exchange), or hybrid (combination of models).' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatRestrictions rdf:type rdf:Property ;
    rdfs:label 'Format Restrictions' ;
    rdfs:comment 'Restrictions on the format or presentation of the content (e.g., no-editing, no-dubbing, original-aspect-ratio-only).' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required for termination or non-renewal of the syndication deal. Null if not applicable.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformRestrictions rdf:type rdf:Property ;
    rdfs:label 'Platform Restrictions' ;
    rdfs:comment 'Comma-separated list of platforms or distribution channels where the licensee is restricted from distributing the content (e.g., linear-only, no-streaming, no-mobile).' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runsUsed rdf:type rdf:Property ;
    rdfs:label 'Runs Used' ;
    rdfs:comment 'Cumulative count of runs (broadcasts) executed by the licensee to date. Used to track compliance with run limits.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:syndicationType rdf:type rdf:Property ;
    rdfs:label 'Syndication Type' ;
    rdfs:comment 'Classification of the syndication arrangement: first-run syndication (original content distributed directly to local stations), off-network syndication (previously aired network content), international syndication (cross-border distribution), digital syndication (online/streaming platforms), barter (ad inventory exchange), or cash-plus-barter (hybrid model).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Blackout Restricted Flag' ;
    rdfs:comment 'Indicates whether the territory is subject to geographic blackout restrictions for certain content (e.g., sports events, theatrical windows). True if blackouts apply, False otherwise.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable Flag' ;
    rdfs:comment 'Indicates whether the territory is subject to GDPR data privacy regulations (EU member states and EEA). True if GDPR applies, False otherwise. Governs audience data collection and consent management.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdbackEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Holdback Eligible Flag' ;
    rdfs:comment 'Indicates whether the territory is eligible for holdback periods in windowing strategies (e.g., delaying SVOD release to protect theatrical revenue). True if holdbacks apply, False otherwise.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internetPenetrationPercent rdf:type rdf:Property ;
    rdfs:label 'Internet Penetration Percent' ;
    rdfs:comment 'Percentage of the population with internet access in the territory (e.g., 95.00 for USA, 60.00 for India). Used for OTT and streaming market opportunity assessment.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isoAlpha2Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 2 Code' ;
    rdfs:comment 'Two-letter ISO 3166-1 alpha-2 country code (e.g., US, GB, CA). Used for system integrations and data exchange with distribution platforms.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoAlpha3Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 3 Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code (e.g., USA, GBR, CAN). Provides additional clarity for territories with similar two-letter codes.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoNumericCode rdf:type rdf:Property ;
    rdfs:label 'Iso Numeric Code' ;
    rdfs:comment 'Three-digit ISO 3166-1 numeric country code (e.g., 840 for USA, 826 for GBR). Language-independent identifier for international systems.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageSecondary rdf:type rdf:Property ;
    rdfs:label 'Language Secondary' ;
    rdfs:comment 'ISO 639-1 or ISO 639-2 code for a secondary or co-official language in the territory (e.g., fr for Canada, ca for Spain). Supports multi-language content delivery and compliance.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ottMarketMaturity rdf:type rdf:Property ;
    rdfs:label 'Ott Market Maturity' ;
    rdfs:comment 'Classification of the territory\'s OTT streaming market maturity: mature (high penetration, competitive), developing (growing adoption), emerging (early stage), nascent (minimal infrastructure). Informs distribution strategy and rights pricing.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:population rdf:type rdf:Property ;
    rdfs:label 'Population' ;
    rdfs:comment 'Total population of the territory. Used for audience reach estimation, market sizing, and rights valuation.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quotaPercentage rdf:type rdf:Property ;
    rdfs:label 'Quota Percentage' ;
    rdfs:comment 'Minimum percentage of local or regional content required by regulation in the territory (e.g., 30.00 for EU, 0.00 for territories without quotas). Used for compliance reporting and content acquisition planning.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Quota Requirement Flag' ;
    rdfs:comment 'Indicates whether the territory mandates local content quotas for broadcasters and streaming platforms (e.g., EU Audiovisual Media Services Directive requiring 30% European content). True if quotas apply, False otherwise.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightsTerritoryStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Territory Status' ;
    rdfs:comment 'Current operational status of the territory in the rights management system: active (available for licensing), inactive (not currently used), restricted (subject to special clearance), pending (under review for activation).' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryGroup rdf:type rdf:Property ;
    rdfs:label 'Territory Group' ;
    rdfs:comment 'Regional grouping of the territory used for rights aggregation and windowing strategies (e.g., EMEA, LATAM, North America, Worldwide, APAC). Enables multi-territory licensing and holdback management. [ENUM-REF-CANDIDATE: worldwide|north_america|latin_america|emea|apac|europe|asia|africa|middle_east|oceania — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Full official name of the territory (e.g., United States, United Kingdom, Canada). Human-readable identifier used in contracts and reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of the territory scope: country (single nation), region (multi-country group), worldwide (global rights), or custom (bespoke territory definition).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Vat Applicable Flag' ;
    rdfs:comment 'Indicates whether Value-Added Tax (VAT) or Goods and Services Tax (GST) applies to transactions in the territory. True if VAT/GST applies, False otherwise. Used for royalty and subscription billing calculations.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vatRatePercent rdf:type rdf:Property ;
    rdfs:label 'Vat Rate Percent' ;
    rdfs:comment 'Standard VAT or GST rate percentage applicable in the territory (e.g., 20.00 for UK, 19.00 for Germany, 0.00 for territories without VAT). Used for financial reconciliation and revenue recognition.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRatePercent rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate Percent' ;
    rdfs:comment 'Standard withholding tax rate percentage applied to royalty payments to rights holders in the territory (e.g., 30.00 for USA non-resident aliens, 0.00 for domestic). Used for talent residuals and royalty calculations.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upfrontCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Upfront Commitment Id' ;
    rdfs:comment 'Foreign key linking to sales.upfront_commitment. Business justification: Ad sales orders are often drawn down from upfront commitments. This FK links the executed order back to the advance commitment that funded it. Nullable because not all ad sales orders come from upfron' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UpfrontCommitment .

ind:affidavitRequired rdf:type rdf:Property ;
    rdfs:label 'Affidavit Required' ;
    rdfs:comment 'Indicates whether proof-of-broadcast affidavits are required for this order to verify that ads were delivered as contracted.' ;
    rdfs:domain ind:AdSalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractSignedDate rdf:type rdf:Property ;
    rdfs:label 'Contract Signed Date' ;
    rdfs:comment 'The date when the advertising sales contract was executed and signed by both parties.' ;
    rdfs:domain ind:AdSalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grpGuarantee rdf:type rdf:Property ;
    rdfs:label 'Grp Guarantee' ;
    rdfs:comment 'The guaranteed Gross Rating Points committed to the advertiser, representing the total percentage of the target audience reached multiplied by frequency.' ;
    rdfs:domain ind:AdSalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressionGuarantee rdf:type rdf:Property ;
    rdfs:label 'Impression Guarantee' ;
    rdfs:comment 'The total number of impressions guaranteed to be delivered under this advertising order.' ;
    rdfs:domain ind:AdSalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:makegoodProvisions rdf:type rdf:Property ;
    rdfs:label 'Makegood Provisions' ;
    rdfs:comment 'The contractual provisions defining how compensatory ad spots will be provided if the broadcaster fails to deliver the guaranteed audience or impressions.' ;
    rdfs:domain ind:AdSalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preemptionRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Preemption Risk Level' ;
    rdfs:comment 'The level of risk that this order may be preempted by higher-priority advertising inventory. Non-preemptible orders have guaranteed placement, while high-risk orders may be bumped for premium advertisers.' ;
    rdfs:domain ind:AdSalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityClass rdf:type rdf:Property ;
    rdfs:label 'Priority Class' ;
    rdfs:comment 'The priority classification of this order in the ad scheduling and trafficking system, determining placement precedence during inventory conflicts.' ;
    rdfs:domain ind:AdSalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyCommissionId rdf:type rdf:Property ;
    rdfs:label 'Agency Commission Id' ;
    rdfs:comment 'Unique identifier for the agency commission record. Primary key.' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableDealTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Deal Types' ;
    rdfs:comment 'Comma-separated list of deal types to which this commission structure applies (e.g., upfront, scatter, sponsorship, programmatic). Empty indicates all deal types are eligible.' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'The date and time when the commission amount was calculated by the system. Used for audit trail and version control.' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:commissionAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Amount' ;
    rdfs:comment 'The total commission amount earned by the agency for this order, calculated based on commission rate and basis. Expressed in the transaction currency.' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionBasis rdf:type rdf:Property ;
    rdfs:label 'Commission Basis' ;
    rdfs:comment 'The financial basis on which the commission is calculated. Gross billings includes all charges before discounts; net billings deducts agency commission; net net deducts both agency commission and cash discount; revenue recognized uses the accounting revenue figure.' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionStatus rdf:type rdf:Property ;
    rdfs:label 'Commission Status' ;
    rdfs:comment 'Current lifecycle status of the commission record. Pending indicates awaiting calculation; calculated means amount determined but not approved; approved is ready for payment; paid indicates payment completed; disputed flags reconciliation issues; reversed indicates a reversal transaction; cancelled means the commission was voided. [ENUM-REF-CANDIDATE: pending|calculated|approved|paid|disputed|reversed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionStructureCode rdf:type rdf:Property ;
    rdfs:label 'Commission Structure Code' ;
    rdfs:comment 'Business identifier for the commission structure applied to this record. Used for reporting and reconciliation across systems.' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionType rdf:type rdf:Property ;
    rdfs:label 'Commission Type' ;
    rdfs:comment 'Classification of the commission structure. Standard represents the typical 15% agency commission; negotiated indicates custom rates; tiered applies different rates based on volume; performance-based ties commission to campaign outcomes; flat fee is a fixed amount; hybrid combines multiple methods.' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Order Gross Amount' ;
    rdfs:comment 'The gross billing amount of the associated ad order before any deductions. Used as the basis for commission calculation when commission_basis is gross_billings.' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNetAmount rdf:type rdf:Property ;
    rdfs:label 'Order Net Amount' ;
    rdfs:comment 'The net billing amount of the associated ad order after agency commission deduction. Used as the basis for commission calculation when commission_basis is net_billings.' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Override Approved By' ;
    rdfs:comment 'Name or identifier of the authorized person who approved the commission override. Required for audit compliance when override_flag is true.' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this commission record was manually overridden from the standard calculation. True when a manual adjustment was applied; false for standard automated calculation.' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Business justification for manual override of the commission calculation. Required when override_flag is true. Documents special circumstances, contractual exceptions, or correction rationale.' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The unique identifier of this record in the source operational system. Used for traceability and data lineage.' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availId rdf:type rdf:Property ;
    rdfs:label 'Avail Id' ;
    rdfs:comment 'Unique identifier for the advertising inventory availability record.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Avail Employee Id' ;
    rdfs:comment 'Reference to the user who created this availability record.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:availLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Avail Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this availability record.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:availCode rdf:type rdf:Property ;
    rdfs:label 'Avail Code' ;
    rdfs:comment 'Business identifier code for this availability record, typically generated by the traffic system.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakType rdf:type rdf:Property ;
    rdfs:label 'Break Type' ;
    rdfs:comment 'Type of commercial break where this inventory is positioned (opening, mid-break, closing, standalone).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorCpmUsd rdf:type rdf:Property ;
    rdfs:label 'Floor Cpm Usd' ;
    rdfs:comment 'Minimum Cost Per Thousand Impressions (CPM) rate in USD that the seller will accept for this inventory.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorRateUsd rdf:type rdf:Property ;
    rdfs:label 'Floor Rate Usd' ;
    rdfs:comment 'Minimum unit rate in USD that the seller will accept for this advertising slot.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Expiry Timestamp' ;
    rdfs:comment 'Date and time when the current hold on this inventory will expire if not confirmed.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdPlacedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Placed Timestamp' ;
    rdfs:comment 'Date and time when the current hold was placed on this inventory.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preemptibleFlag rdf:type rdf:Property ;
    rdfs:label 'Preemptible Flag' ;
    rdfs:comment 'Indicates whether this inventory can be preempted by higher-priority advertising (true) or is guaranteed (false).' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:projectedGrp rdf:type rdf:Property ;
    rdfs:label 'Projected Grp' ;
    rdfs:comment 'Estimated Gross Rating Points this slot is expected to deliver, representing the percentage of the target audience reached multiplied by frequency.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedImpressions rdf:type rdf:Property ;
    rdfs:label 'Projected Impressions' ;
    rdfs:comment 'Estimated number of viewer impressions this advertising slot is expected to deliver based on historical audience data.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Unit Length Seconds' ;
    rdfs:comment 'Duration of the advertising unit in seconds (e.g., 15, 30, 60 for traditional spots).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carriageDealId rdf:type rdf:Property ;
    rdfs:label 'Carriage Deal Id' ;
    rdfs:comment 'Unique identifier for the carriage deal. Primary key for this entity.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarriageDeal .

ind:originationBroadcastFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origination Broadcast Facility Id' ;
    rdfs:comment 'Foreign key linking to technology.broadcast_facility. Business justification: Carriage agreements specify the origination facility for signal delivery to distribution partners. Required for signal handoff coordination, technical specifications, SLA monitoring, and operational e' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastFacility .

ind:advertisingRevenueSharePct rdf:type rdf:Property ;
    rdfs:label 'Advertising Revenue Share Pct' ;
    rdfs:comment 'Percentage of advertising revenue generated on the carried channel(s) that is shared with the operator, if applicable.' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Frequency at which carriage fees are invoiced to the operator: monthly (standard), quarterly, or annually.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutZoneRestrictions rdf:type rdf:Property ;
    rdfs:label 'Blackout Zone Restrictions' ;
    rdfs:comment 'Geographic regions or designated market areas (DMAs) where content must be blacked out due to territorial rights restrictions or sports blackout rules.' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageStatus rdf:type rdf:Property ;
    rdfs:label 'Carriage Status' ;
    rdfs:comment 'Current lifecycle state of the carriage agreement: draft (initial proposal), negotiation (under discussion), executed (signed but not yet effective), active (currently in force), suspended (temporarily paused), expired (term ended), terminated (cancelled before term end), or renewed (extended for additional term). [ENUM-REF-CANDIDATE: draft|negotiation|executed|active|suspended|expired|terminated|renewed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Duration of the carriage agreement in months, from effective start to end date.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hdTierFlag rdf:type rdf:Property ;
    rdfs:label 'Hd Tier Flag' ;
    rdfs:comment 'Indicates whether the channel(s) are carried in the operators high-definition tier.' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mostFavoredNationClause rdf:type rdf:Property ;
    rdfs:label 'Most Favored Nation Clause' ;
    rdfs:comment 'Indicates whether the agreement includes a most-favored-nation clause guaranteeing the operator receives terms no less favorable than those offered to other operators.' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mustCarryDesignation rdf:type rdf:Property ;
    rdfs:label 'Must Carry Designation' ;
    rdfs:comment 'Indicates whether this carriage is mandated under FCC must-carry rules, requiring cable operators to carry local broadcast stations without compensation.' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTermsNetDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Net Days' ;
    rdfs:comment 'Number of days from invoice date within which the operator must remit carriage fee payment (e.g., Net 30, Net 60).' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceGuaranteeSla rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Sla' ;
    rdfs:comment 'Service level agreement terms specifying uptime, signal quality, and technical performance guarantees for channel delivery.' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOptionDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Date' ;
    rdfs:comment 'Date by which either party must exercise renewal option or provide notice of non-renewal.' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retransmissionConsentDesignation rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Designation' ;
    rdfs:comment 'Indicates whether this carriage is governed by retransmission consent rules, allowing broadcasters to negotiate compensation for signal rebroadcast.' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retransmissionConsentFee rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Fee' ;
    rdfs:comment 'Specific fee negotiated under retransmission consent rules for rebroadcast authorization of over-the-air signals. May be same as or distinct from general carriage fee.' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdTierFlag rdf:type rdf:Property ;
    rdfs:label 'Sd Tier Flag' ;
    rdfs:comment 'Indicates whether the channel(s) are carried in the operators standard-definition tier.' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierPlacement rdf:type rdf:Property ;
    rdfs:label 'Tier Placement' ;
    rdfs:comment 'Operator service tier in which the channel(s) are placed: basic (lowest tier), expanded basic, digital, premium, or specialized tiers (sports, news, entertainment), or a-la-carte (individual channel purchase). [ENUM-REF-CANDIDATE: basic|expanded_basic|digital|premium|sports|news|entertainment|a_la_carte — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentLicenseDealId rdf:type rdf:Property ;
    rdfs:label 'Content License Deal Id' ;
    rdfs:comment 'Unique identifier for the content license deal. Primary key for this entity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentLicenseDeal .

ind:contentLibraryId rdf:type rdf:Property ;
    rdfs:label 'Content Library Id' ;
    rdfs:comment 'Reference to a content library or collection being licensed. May be null if the deal covers a single title rather than a library.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentLibrary .

ind:licensorPartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Licensor Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Content license deals are negotiated with content owners/licensors who are formal partners (studios, production companies, distributors). Critical for tracking licensor relationships, managing royalty' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:salesTeamId rdf:type rdf:Property ;
    rdfs:label 'Sales Team Id' ;
    rdfs:comment 'Reference to the sales team or business unit responsible for this content license deal.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTeam .

ind:commissionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible Flag' ;
    rdfs:comment 'Indicates whether this deal is eligible for sales commission calculation and payout.' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percentage' ;
    rdfs:comment 'The commission rate percentage applicable to this deal for sales compensation purposes.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Deal Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the deal value amount.' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executedDate rdf:type rdf:Property ;
    rdfs:label 'Executed Date' ;
    rdfs:comment 'The date when the contract was formally executed and signed by all parties, making it legally binding.' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseFeeStructure rdf:type rdf:Property ;
    rdfs:label 'License Fee Structure' ;
    rdfs:comment 'The pricing model or fee structure governing how the licensee compensates the licensor for the content rights.' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformRightsAvod rdf:type rdf:Property ;
    rdfs:label 'Platform Rights Avod' ;
    rdfs:comment 'Indicates whether the license grants rights for Advertising-Supported Video On Demand (AVOD) distribution.' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformRightsFast rdf:type rdf:Property ;
    rdfs:label 'Platform Rights Fast' ;
    rdfs:comment 'Indicates whether the license grants rights for Free Ad-Supported Streaming Television (FAST) channels.' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformRightsLinear rdf:type rdf:Property ;
    rdfs:label 'Platform Rights Linear' ;
    rdfs:comment 'Indicates whether the license grants rights for traditional scheduled linear broadcasting.' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformRightsSvod rdf:type rdf:Property ;
    rdfs:label 'Platform Rights Svod' ;
    rdfs:comment 'Indicates whether the license grants rights for Subscription Video On Demand (SVOD) distribution.' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformRightsTvod rdf:type rdf:Property ;
    rdfs:label 'Platform Rights Tvod' ;
    rdfs:comment 'Indicates whether the license grants rights for Transactional Video On Demand (TVOD) distribution.' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastId rdf:type rdf:Property ;
    rdfs:label 'Forecast Id' ;
    rdfs:comment 'Unique identifier for the revenue forecast record.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_territory. Business justification: Forecasts are often segmented by sales territory for territory-level revenue projections and quota tracking. This FK enables territory-based forecasting. N:1 relationship. New attribute needed to esta' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTerritory .

ind:accountSegment rdf:type rdf:Property ;
    rdfs:label 'Account Segment' ;
    rdfs:comment 'Segmentation of the account type for this forecast: enterprise (large advertisers), mid-market, small business, agency (media buying agencies), direct (direct-to-advertiser).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attainmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Attainment Percentage' ;
    rdfs:comment 'Percentage of quota represented by the total forecasted revenue (forecasted revenue / quota * 100).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bestCaseRevenue rdf:type rdf:Property ;
    rdfs:label 'Best Case Revenue' ;
    rdfs:comment 'Revenue amount in the best case forecast category (optimistic scenario including stretch opportunities).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:broadcastYear rdf:type rdf:Property ;
    rdfs:label 'Broadcast Year' ;
    rdfs:comment 'Broadcast year (September to August cycle) this forecast applies to, represented as the starting calendar year.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carriageRevenue rdf:type rdf:Property ;
    rdfs:label 'Carriage Revenue' ;
    rdfs:comment 'Forecasted revenue from carriage fee agreements (distribution payments from cable/satellite providers).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closedRevenue rdf:type rdf:Property ;
    rdfs:label 'Closed Revenue' ;
    rdfs:comment 'Revenue amount from deals already closed and won during this forecast period.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitRevenue rdf:type rdf:Property ;
    rdfs:label 'Commit Revenue' ;
    rdfs:comment 'Revenue amount in the commit forecast category (high confidence deals expected to close).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'Fiscal quarter this forecast applies to (Q1, Q2, Q3, Q4).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastCategory rdf:type rdf:Property ;
    rdfs:label 'Forecast Category' ;
    rdfs:comment 'Classification of the forecast confidence level: commit (high confidence), best case (optimistic), pipeline (possible), omitted (excluded from forecast), closed (already won).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastName rdf:type rdf:Property ;
    rdfs:label 'Forecast Name' ;
    rdfs:comment 'Descriptive name for the forecast record, typically including period and rep name.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Number' ;
    rdfs:comment 'Business-readable unique identifier for the forecast submission.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle status of the forecast record.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingRevenue rdf:type rdf:Property ;
    rdfs:label 'Licensing Revenue' ;
    rdfs:comment 'Forecasted revenue from content licensing deals (selling rights to broadcast or distribute content).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerOverrideAmount rdf:type rdf:Property ;
    rdfs:label 'Manager Override Amount' ;
    rdfs:comment 'Revenue amount adjusted by sales manager override, used when manager believes rep forecast needs correction.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Manager Override Reason' ;
    rdfs:comment 'Explanation provided by sales manager for any override adjustment to the forecast.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineRevenue rdf:type rdf:Property ;
    rdfs:label 'Pipeline Revenue' ;
    rdfs:comment 'Revenue amount in the pipeline forecast category (possible deals still in early stages).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaAmount rdf:type rdf:Property ;
    rdfs:label 'Quota Amount' ;
    rdfs:comment 'Assigned sales quota target for this sales rep and period.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scatterRevenue rdf:type rdf:Property ;
    rdfs:label 'Scatter Revenue' ;
    rdfs:comment 'Forecasted revenue from scatter market deals (last-minute ad inventory sales outside upfront commitments).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:syndicationRevenue rdf:type rdf:Property ;
    rdfs:label 'Syndication Revenue' ;
    rdfs:comment 'Forecasted revenue from syndication deals (reselling content to multiple outlets).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalForecastedRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Forecasted Revenue' ;
    rdfs:comment 'Total projected revenue amount for this forecast period across all deal types and categories.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updateFrequency rdf:type rdf:Property ;
    rdfs:label 'Update Frequency' ;
    rdfs:comment 'Expected frequency of forecast updates for this period: weekly (standard selling periods), daily (upfront season), monthly (long-range planning), ad hoc (as needed).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfrontRevenue rdf:type rdf:Property ;
    rdfs:label 'Upfront Revenue' ;
    rdfs:comment 'Forecasted revenue from upfront deals (advance advertising commitments made during upfront season).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToQuota rdf:type rdf:Property ;
    rdfs:label 'Variance To Quota' ;
    rdfs:comment 'Difference between total forecasted revenue and quota amount (positive indicates over-quota forecast, negative indicates gap).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightedPipelineValue rdf:type rdf:Property ;
    rdfs:label 'Weighted Pipeline Value' ;
    rdfs:comment 'Total pipeline value adjusted by probability weights for each opportunity, providing a risk-adjusted forecast.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignObjective rdf:type rdf:Property ;
    rdfs:label 'Campaign Objective' ;
    rdfs:comment 'Primary marketing objective the advertiser aims to achieve with this campaign. Influences creative strategy, placement selection, and success metrics. [ENUM-REF-CANDIDATE: brand_awareness|product_launch|direct_response|lead_generation|traffic|engagement|video_views|app_installs — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Target date by which the sales team expects to close this opportunity (win or lose). Used for pipeline forecasting and sales velocity tracking. Updated as negotiations progress.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitiveDisplacement rdf:type rdf:Property ;
    rdfs:label 'Competitive Displacement' ;
    rdfs:comment 'Free-text notes capturing competitive intelligence about which competitor this deal may displace or compete against. Used for win/loss analysis and competitive strategy.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Value' ;
    rdfs:comment 'Total estimated revenue value of the opportunity in USD. For advertising deals, represents total campaign spend; for content licensing, represents license fee. Used for revenue forecasting and quota tracking.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isUpfront rdf:type rdf:Property ;
    rdfs:label 'Is Upfront' ;
    rdfs:comment 'Boolean flag indicating whether this opportunity is part of the annual upfront sales season. True = upfront commitment; False = scatter market or other deal type. Used for upfront tracking and reporting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent sales activity (call, email, meeting) logged against this opportunity. Used for pipeline hygiene monitoring and stale opportunity identification.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Origin channel of this sales opportunity. Tracks how the lead was generated for marketing attribution and lead source ROI analysis. [ENUM-REF-CANDIDATE: inbound|outbound|referral|event|partner|renewal|upsell — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossNotes rdf:type rdf:Property ;
    rdfs:label 'Loss Notes' ;
    rdfs:comment 'Free-text detailed explanation of why the opportunity was lost. Captures competitive intelligence, pricing feedback, and strategic insights for future deals.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Primary reason for losing the opportunity if stage is closed-lost. Used for loss analysis, competitive intelligence, and sales process improvement. Null for won or open opportunities.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStep rdf:type rdf:Property ;
    rdfs:label 'Next Step' ;
    rdfs:comment 'Description of the next action or milestone required to advance this opportunity. Used for sales activity tracking and pipeline hygiene. Updated regularly by sales executive.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Descriptive name of the sales opportunity, typically including advertiser name, campaign type, and time period (e.g., \'Acme Corp Q4 Upfront Buy\').' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'Human-readable business identifier for the opportunity, typically auto-generated in format OPP-YYYYNNNN. Used in sales communications and reporting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probability rdf:type rdf:Property ;
    rdfs:label 'Probability' ;
    rdfs:comment 'Estimated likelihood of closing this opportunity as a percentage (0.00 to 100.00). Typically aligned with stage (e.g., Proposal = 40%, Negotiation = 60%). Used for weighted pipeline forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresMakegood rdf:type rdf:Property ;
    rdfs:label 'Requires Makegood' ;
    rdfs:comment 'Boolean flag indicating whether this opportunity includes makegood provisions for audience delivery shortfalls. True = makegoods may be required if audience guarantees are not met. Used for inventory planning.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage in the sales pipeline lifecycle. Tracks progression from initial prospecting through closure. Used for pipeline forecasting and sales funnel analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Line Id' ;
    rdfs:comment 'Unique identifier for the order line item. Primary key for the order line entity.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposalLineId rdf:type rdf:Property ;
    rdfs:label 'Proposal Line Id' ;
    rdfs:comment 'Foreign key linking to sales.proposal_line. Business justification: Order lines are the executed versions of proposal lines. This FK enables tracing order line execution back to the original proposal line. N:1 relationship (one proposal line can lead to multiple order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProposalLine .

ind:airEndDate rdf:type rdf:Property ;
    rdfs:label 'Air End Date' ;
    rdfs:comment 'End date of the flight period for this ad unit. Defines the conclusion of the campaign window.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airStartDate rdf:type rdf:Property ;
    rdfs:label 'Air Start Date' ;
    rdfs:comment 'Start date of the flight period for this ad unit. Used for campaigns spanning multiple days or weeks.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteedFlag rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Flag' ;
    rdfs:comment 'Indicates whether this line item has a guaranteed delivery commitment (impressions, GRPs, or placement) versus best-effort delivery.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programmaticFlag rdf:type rdf:Property ;
    rdfs:label 'Programmatic Flag' ;
    rdfs:comment 'Indicates whether this line item was sold through programmatic advertising channels (automated bidding and buying).' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesType rdf:type rdf:Property ;
    rdfs:label 'Sales Type' ;
    rdfs:comment 'Type of sales transaction: upfront (advance commitment), scatter (last-minute inventory), direct, programmatic, sponsorship, or barter.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Type of advertising unit being sold: a 30-second spot, digital pre-roll, sponsorship billboard, branded content integration, or other ad format. [ENUM-REF-CANDIDATE: spot|pre_roll|mid_roll|post_roll|sponsorship|billboard|branded_content|overlay|companion_banner|native_ad — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Licensed Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Individual proposal lines in content licensing proposals specify which media assets are included in each license grant. This enables line-level asset availability checking, format specification matchi' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:primaryProposalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Proposal Employee Id' ;
    rdfs:comment 'Reference to the sales user who created this proposal line item.' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:unitQuantity rdf:type rdf:Property ;
    rdfs:label 'Unit Quantity' ;
    rdfs:comment 'Number of advertising units or spots being proposed in this line (e.g., 30 spots, 5 sponsorships).' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repId rdf:type rdf:Property ;
    rdfs:label 'Rep Id' ;
    rdfs:comment 'Primary key for rep' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:managerRepId rdf:type rdf:Property ;
    rdfs:label 'Manager Rep Id' ;
    rdfs:comment 'Foreign key reference to the sales manager or team lead who supervises this sales representative. Self-referential relationship within the sales rep hierarchy.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:accountPortfolioSegment rdf:type rdf:Property ;
    rdfs:label 'Account Portfolio Segment' ;
    rdfs:comment 'Classification of the account portfolio managed by the sales representative. Indicates whether they manage agency relationships, direct advertiser accounts, distribution partners (MVPD/vMVPD), OTT platforms, syndication buyers, or other client segments. [ENUM-REF-CANDIDATE: agency|direct_advertiser|mvpd|vmvpd|ott_platform|syndicator|international|government — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Quota Amount' ;
    rdfs:comment 'Total annual revenue quota assigned to the sales representative for the current quota period. Measured in the company\'s reporting currency.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionPlanType rdf:type rdf:Property ;
    rdfs:label 'Commission Plan Type' ;
    rdfs:comment 'Type of commission structure applied to the sales representative. Defines how commissions are calculated based on sales performance (e.g., base salary plus commission, commission-only, tiered rates, accelerators for exceeding quota).' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealTypeSpecialization rdf:type rdf:Property ;
    rdfs:label 'Deal Type Specialization' ;
    rdfs:comment 'Primary deal type or sales channel specialization for the representative. Indicates whether they focus on national TV advertising, digital campaigns, content licensing, syndication deals, or other revenue streams. [ENUM-REF-CANDIDATE: national_tv|local_tv|digital|syndication|licensing|upfront|scatter|programmatic|sponsorship|multi_platform — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Certified Flag' ;
    rdfs:comment 'Boolean flag indicating whether the sales representative is certified and authorized to sell digital advertising inventory, including OTT, streaming, and programmatic channels.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the sales representative was hired or onboarded into the sales organization.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Performance classification or tier assigned to the sales representative based on quota attainment and sales metrics. Used for recognition, compensation adjustments, and coaching.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quota Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the quota amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Quota Period End Date' ;
    rdfs:comment 'End date of the current quota period for the sales representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotaPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Quota Period Start Date' ;
    rdfs:comment 'Start date of the current quota period for the sales representative. Typically aligns with fiscal year or calendar year.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repName rdf:type rdf:Property ;
    rdfs:label 'Rep Name' ;
    rdfs:comment 'Full legal name of the sales representative as it appears in business records and communications.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repStatus rdf:type rdf:Property ;
    rdfs:label 'Rep Status' ;
    rdfs:comment 'Current operational status of the sales representative within the sales organization. Indicates whether they are actively selling, on leave, or no longer with the company.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceUserReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce User Reference' ;
    rdfs:comment 'Unique user identifier in Salesforce Media Cloud CRM system. Links the sales rep record to their Salesforce user profile for opportunity tracking and pipeline management.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryAssignment rdf:type rdf:Property ;
    rdfs:label 'Territory Assignment' ;
    rdfs:comment 'Geographic or market territory assigned to the sales representative. May be defined by region, DMA (Designated Market Area), or account segment.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfrontCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Upfront Certified Flag' ;
    rdfs:comment 'Boolean flag indicating whether the sales representative is certified and authorized to negotiate and close upfront advertising deals. Upfront deals are advance commitments made during the annual upfront sales event.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:awardDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Award Decision Date' ;
    rdfs:comment 'Date when the advertiser or agency communicated their final decision on the RFP (awarded or lost). Nullable until decision is made.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardedAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Amount' ;
    rdfs:comment 'Total dollar value of the campaign if the RFP was awarded to the broadcaster. Nullable if RFP was lost or still pending. Used for revenue forecasting and sales performance tracking.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetRangeMax rdf:type rdf:Property ;
    rdfs:label 'Budget Range Max' ;
    rdfs:comment 'Maximum budget amount the advertiser is willing to commit for the campaign. Defines the upper bound for proposal pricing.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetRangeMin rdf:type rdf:Property ;
    rdfs:label 'Budget Range Min' ;
    rdfs:comment 'Minimum budget amount the advertiser is willing to commit for the campaign. Used for opportunity qualification and inventory allocation.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveSeparationRequirements rdf:type rdf:Property ;
    rdfs:label 'Competitive Separation Requirements' ;
    rdfs:comment 'Rules for separating this advertiser\'s spots from competing brands within the same ad pod or program. Typically specifies minimum time separation or exclusivity within a break.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentAdjacencyRestrictions rdf:type rdf:Property ;
    rdfs:label 'Content Adjacency Restrictions' ;
    rdfs:comment 'Advertiser-specified restrictions on content types or genres where ads should not appear (e.g., no violent content, no political programming, no competitive sports). Used for brand safety and compliance.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartRequirements rdf:type rdf:Property ;
    rdfs:label 'Daypart Requirements' ;
    rdfs:comment 'Specific broadcast daypart preferences or requirements (e.g., Prime Time, Early Morning, Late Night, Weekend). Dayparts are time segments of the broadcast day used for scheduling and pricing.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:desiredFrequency rdf:type rdf:Property ;
    rdfs:label 'Desired Frequency' ;
    rdfs:comment 'Target average number of times each unique viewer should be exposed to the advertisement during the campaign. Frequency is a key metric for message reinforcement.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:desiredGrpTarget rdf:type rdf:Property ;
    rdfs:label 'Desired Grp Target' ;
    rdfs:comment 'Target Gross Rating Points the advertiser seeks to achieve. GRP is a standard audience measurement metric representing the sum of all rating points delivered by a campaign.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:desiredImpressions rdf:type rdf:Property ;
    rdfs:label 'Desired Impressions' ;
    rdfs:comment 'Total number of ad impressions the advertiser seeks to purchase. An impression represents a single ad view by a viewer.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:desiredReachPercent rdf:type rdf:Property ;
    rdfs:label 'Desired Reach Percent' ;
    rdfs:comment 'Target percentage of unique audience members the advertiser wants to reach at least once during the campaign. Reach is a key audience delivery metric.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingModelPreference rdf:type rdf:Property ;
    rdfs:label 'Pricing Model Preference' ;
    rdfs:comment 'Advertiser\'s preferred pricing structure for the campaign. Options include Cost Per Mille (CPM), Cost Per Rating Point (CPRP), flat rate, performance-based, or hybrid models.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Date when the broadcaster submitted their proposal response to the RFP. Nullable until response is completed. Used to track response turnaround time.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfpNumber rdf:type rdf:Property ;
    rdfs:label 'Rfp Number' ;
    rdfs:comment 'Business identifier for the RFP, typically assigned by the source system or agency. Used for external reference and tracking.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpSource rdf:type rdf:Property ;
    rdfs:label 'Rfp Source' ;
    rdfs:comment 'Origin channel through which the RFP was received. Distinguishes between agency-mediated, direct advertiser, programmatic platform, upfront market, scatter market, or network referral submissions.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpStatus rdf:type rdf:Property ;
    rdfs:label 'Rfp Status' ;
    rdfs:comment 'Current lifecycle status of the RFP in the sales pipeline. Tracks progression from receipt through final disposition.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAgeRange rdf:type rdf:Property ;
    rdfs:label 'Target Age Range' ;
    rdfs:comment 'Specific age demographic range requested by the advertiser (e.g., 18-34, 25-54, 35-49). Used for audience targeting and rate card selection.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceDescription rdf:type rdf:Property ;
    rdfs:label 'Target Audience Description' ;
    rdfs:comment 'Narrative description of the desired audience demographics and psychographics, including age range, gender, household income (HHI), geography, interests, and behavioral attributes.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGender rdf:type rdf:Property ;
    rdfs:label 'Target Gender' ;
    rdfs:comment 'Gender demographic targeting requirement specified in the RFP. May be male, female, all genders, or unspecified.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGeography rdf:type rdf:Property ;
    rdfs:label 'Target Geography' ;
    rdfs:comment 'Geographic targeting requirements, including designated market areas (DMAs), regions, states, or national coverage. May include multiple geographies separated by delimiters.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountSalesAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Sales Account Id' ;
    rdfs:comment 'Reference to the parent sales account in a hierarchical account structure. Used to model agency networks, holding company subsidiaries, and multi-location advertiser organizations.' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesAccount .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'The strategic tier or classification of the account based on revenue potential, relationship depth, and strategic importance. Higher tiers receive preferential pricing, dedicated support, and priority inventory access.' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenuePotential rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Potential' ;
    rdfs:comment 'The estimated annual revenue opportunity from this account based on historical spend, market share, and sales forecasts. Used for territory planning and quota allocation.' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Phone' ;
    rdfs:comment 'The phone number of the primary billing contact for urgent payment or invoice inquiries.' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingCompanyName rdf:type rdf:Property ;
    rdfs:label 'Holding Company Name' ;
    rdfs:comment 'The name of the parent holding company or corporate group to which this account belongs. Used to aggregate spend and manage relationships at the holding company level (e.g., WPP, Omnicom, Publicis Groupe for agencies).' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'The primary industry vertical or business sector of the account (e.g., Automotive, Financial Services, Retail, Pharmaceutical, Technology). Used for competitive separation and industry-specific rate cards.' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceAccountReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Reference' ;
    rdfs:comment 'The source system identifier from Salesforce Media Cloud CRM. This is the external key used to synchronize account data between the lakehouse and the operational CRM system.' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'The tax identification number (TIN), employer identification number (EIN), or value-added tax (VAT) registration number for this account. Used for tax reporting and compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesContactId rdf:type rdf:Property ;
    rdfs:label 'Sales Contact Id' ;
    rdfs:comment 'Unique identifier for the sales contact record. Primary key.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesContact .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the system user who most recently modified this contact record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetAuthorityUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Authority Usd' ;
    rdfs:comment 'Estimated annual advertising budget the contact controls or influences, in USD. Used for opportunity sizing and account prioritization.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contactSource rdf:type rdf:Property ;
    rdfs:label 'Contact Source' ;
    rdfs:comment 'Origin or acquisition channel through which this contact was first captured. Used for lead source attribution and ROI analysis.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Decision Authority Level' ;
    rdfs:comment 'Level of purchasing authority the contact holds within their organization. Critical for routing proposals and negotiating upfront commitments.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Master suppression flag indicating the contact has requested no further outreach. Overrides all other opt-in settings.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line1' ;
    rdfs:comment 'Primary street address line for physical correspondence and contract delivery.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line2' ;
    rdfs:comment 'Secondary address line for suite, floor, or department information.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City name for the contact\'s mailing address.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the contact\'s mailing address (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the contact\'s mailing address.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Mailing State Province' ;
    rdfs:comment 'State, province, or region for the contact\'s mailing address.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Next Follow Up Date' ;
    rdfs:comment 'Scheduled date for the next planned outreach or follow-up activity with this contact.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Indicates whether the contact has explicitly consented to receive marketing and promotional emails.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInPhone rdf:type rdf:Property ;
    rdfs:label 'Opt In Phone' ;
    rdfs:comment 'Indicates whether the contact has consented to receive phone calls for sales and marketing purposes.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Indicates whether the contact has consented to receive SMS text messages for time-sensitive sales notifications.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'Contact\'s stated preference for how they wish to be reached for sales discussions and proposal reviews.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'Indicates whether this contact is the primary point of contact for their account. Used for proposal routing and commission attribution.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipTier rdf:type rdf:Property ;
    rdfs:label 'Relationship Tier' ;
    rdfs:comment 'Classification of the contact\'s relationship strength and priority level. Strategic contacts receive white-glove service and early access to upfront inventory.' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesDealApprovalId rdf:type rdf:Property ;
    rdfs:label 'Sales Deal Approval Id' ;
    rdfs:comment 'Unique identifier for the sales deal approval workflow record.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quaternarySalesCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Sales Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created the approval workflow record. Typically the sales representative or system automation that initiated the approval request.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinarySalesLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Sales Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the approval record. Tracks who made the most recent update for audit and accountability purposes.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:salesSyndicationDealId rdf:type rdf:Property ;
    rdfs:label 'Sales Syndication Deal Id' ;
    rdfs:comment 'Reference to the syndication deal requiring approval. Used for content licensing and syndication agreements that exceed standard authority levels.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesSyndicationDeal .

ind:tertiarySalesSubmittedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Sales Submitted By User Employee Id' ;
    rdfs:comment 'Identifier of the sales representative or user who submitted the deal for approval. Tracks originator for accountability and commission purposes.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalDecisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Decision Timestamp' ;
    rdfs:comment 'Date and time when the approver made their decision (approved, rejected, or escalated). Used to calculate approval cycle time and SLA compliance.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Expiry Timestamp' ;
    rdfs:comment 'Date and time by which the approval decision must be made. If no decision is rendered by this time, the approval may auto-escalate or expire.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Number' ;
    rdfs:comment 'Business identifier for the approval workflow instance. Format: APV-YYYYMMDD followed by sequence number for tracking and audit purposes.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTier rdf:type rdf:Property ;
    rdfs:label 'Approval Tier' ;
    rdfs:comment 'Hierarchical approval level triggered by deal characteristics. Higher tiers required for larger values, extended terms, or non-standard conditions.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTriggerReason rdf:type rdf:Property ;
    rdfs:label 'Approval Trigger Reason' ;
    rdfs:comment 'Business justification for why this deal requires management approval. May include multiple reasons such as value threshold exceeded, below-floor pricing, extended payment terms, custom barter arrangement, or non-standard cancellation options.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:belowFloorPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Below Floor Pricing Flag' ;
    rdfs:comment 'Indicates whether the negotiated rate falls below the established rate card floor, requiring pricing exception approval.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Required Flag' ;
    rdfs:comment 'Indicates whether the deal requires compliance review for regulatory adherence, political advertising rules, or industry standards compliance.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customBarterArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Custom Barter Arrangement Flag' ;
    rdfs:comment 'Indicates whether the deal involves non-cash barter or trade arrangements requiring special approval and valuation review.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalatedToTier rdf:type rdf:Property ;
    rdfs:label 'Escalated To Tier' ;
    rdfs:comment 'The higher approval tier to which this request has been escalated. Tracks the escalation path through the approval hierarchy.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedPaymentTermsFlag rdf:type rdf:Property ;
    rdfs:label 'Extended Payment Terms Flag' ;
    rdfs:comment 'Indicates whether the deal includes payment terms that exceed standard credit policy, requiring finance approval.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonStandardCancellationFlag rdf:type rdf:Property ;
    rdfs:label 'Non Standard Cancellation Flag' ;
    rdfs:comment 'Indicates whether the deal includes cancellation options or terms that deviate from standard contract provisions.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the approval decision was made within the target SLA timeframe. Used for performance monitoring and process improvement.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valueThresholdExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Value Threshold Exceeded Flag' ;
    rdfs:comment 'Indicates whether the deal value exceeds the sales representative\'s approval authority limit, triggering escalation to management.' ;
    rdfs:domain ind:SalesDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentPackageId rdf:type rdf:Property ;
    rdfs:label 'Content Package Id' ;
    rdfs:comment 'Reference to the content package (series, strip, specials, or program bundle) being syndicated under this deal.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:syndicationMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Syndication Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Syndication deals license specific program assets to local stations/broadcasters. While content_package_id references the editorial package, syndication_media_asset_id links to the actual broadcast ma' ;
    rdfs:domain ind:SalesSyndicationDeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:barterSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Barter Split Percentage' ;
    rdfs:comment 'Percentage of advertising inventory retained by the syndicator versus sold by the station. For example, 70/30 split means syndicator retains 70% of ad inventory and station sells 30%. Null for pure cash deals.' ;
    rdfs:domain ind:SalesSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashLicenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Cash License Fee Amount' ;
    rdfs:comment 'Total cash license fee paid by the station or station group to the syndicator for the content rights over the deal term. Null for pure barter deals.' ;
    rdfs:domain ind:SalesSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearancePercentageTarget rdf:type rdf:Property ;
    rdfs:label 'Clearance Percentage Target' ;
    rdfs:comment 'Target percentage of U.S. television households or market coverage that must be achieved for the syndication deal to be considered successful. Clearance is the percentage of the national audience that has access to the syndicated program.' ;
    rdfs:domain ind:SalesSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runsPerEpisode rdf:type rdf:Property ;
    rdfs:label 'Runs Per Episode' ;
    rdfs:comment 'Number of times each episode may be broadcast during the deal term. Common values are 2, 4, 6, or unlimited.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stationCount rdf:type rdf:Property ;
    rdfs:label 'Station Count' ;
    rdfs:comment 'Number of broadcast stations or outlets that have committed to air the syndicated content under this deal.' ;
    rdfs:domain ind:SalesSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedSalesTeamId rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Team Id' ;
    rdfs:comment 'Identifier of the sales team collectively responsible for this territory, if team-based assignment is used.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTeam .

ind:parentTerritorySalesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Territory Sales Territory Id' ;
    rdfs:comment 'Identifier of the parent territory in a hierarchical territory structure. Null for top-level territories.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTerritory .

ind:accountCount rdf:type rdf:Property ;
    rdfs:label 'Account Count' ;
    rdfs:comment 'Number of active advertiser or agency accounts assigned to this territory.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dmaList rdf:type rdf:Property ;
    rdfs:label 'Dma List' ;
    rdfs:comment 'Comma-separated list of Nielsen DMA codes or names included in this territory for broadcast market segmentation.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineFocus rdf:type rdf:Property ;
    rdfs:label 'Product Line Focus' ;
    rdfs:comment 'Primary advertising product lines or inventory types this territory is authorized to sell (e.g., Linear TV, Digital Video, OTT/Streaming, Radio, Display, Sponsorships). Comma-separated for multiple product lines.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Amount' ;
    rdfs:comment 'Annual or period revenue quota assigned to this territory, used for quota allocation and performance tracking.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueTargetCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the revenue target amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scatterMarketFlag rdf:type rdf:Property ;
    rdfs:label 'Scatter Market Flag' ;
    rdfs:comment 'Indicates whether this territory handles scatter market (last-minute, short-term) ad inventory sales. True if scatter sales are part of territory scope.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Description' ;
    rdfs:comment 'Detailed textual description of the territory scope, coverage rules, special conditions, and strategic objectives.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the territory: active (in use), inactive (not currently assigned), pending (awaiting activation), suspended (temporarily disabled), or archived (historical record).' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfrontParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Upfront Participation Flag' ;
    rdfs:comment 'Indicates whether this territory participates in annual upfront advertising sales events. True if territory is included in upfront planning and commitments.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verticalIndustryFocus rdf:type rdf:Property ;
    rdfs:label 'Vertical Industry Focus' ;
    rdfs:comment 'Primary industry vertical or sector this territory specializes in (e.g., Automotive, Pharmaceutical, Retail, Entertainment, Financial Services, Technology). Used for vertical-based territory models.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustedCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjusted Commitment Amount' ;
    rdfs:comment 'The current binding commitment amount after all option exercises and cancellations have been applied. Calculated as total_committed_spend minus total_cancelled_amount.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationOptionPercentage rdf:type rdf:Property ;
    rdfs:label 'Cancellation Option Percentage' ;
    rdfs:comment 'The percentage of the total commitment that the advertiser has the option to cancel at defined option dates, typically 50%.' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitmentNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Number' ;
    rdfs:comment 'Business identifier for the upfront commitment, used in sales and billing communications.' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the upfront commitment. [ENUM-REF-CANDIDATE: draft|pending_approval|confirmed|active|partially_fulfilled|fulfilled|cancelled|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedGrpVolume rdf:type rdf:Property ;
    rdfs:label 'Committed Grp Volume' ;
    rdfs:comment 'The total GRP volume committed by the advertiser across the upfront period. GRP represents the sum of ratings achieved by the campaign.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedImpressionVolume rdf:type rdf:Property ;
    rdfs:label 'Committed Impression Volume' ;
    rdfs:comment 'The total number of impressions committed by the advertiser across the upfront period, typically used for digital and streaming platforms.' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daypartAllocation rdf:type rdf:Property ;
    rdfs:label 'Daypart Allocation' ;
    rdfs:comment 'The broadcast daypart segments allocated for this upfront commitment (e.g., Prime Time, Early Morning, Late Night). Multiple dayparts may be specified.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredSpendToDate rdf:type rdf:Property ;
    rdfs:label 'Delivered Spend To Date' ;
    rdfs:comment 'The cumulative dollar amount that has been delivered against this upfront commitment through actual ad orders and campaigns.' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Digital Allocation Amount' ;
    rdfs:comment 'The portion of the total committed spend allocated to digital platform inventory.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstOptionDate rdf:type rdf:Property ;
    rdfs:label 'First Option Date' ;
    rdfs:comment 'The first date on which the advertiser may exercise their cancellation option.' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteedCpm rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Cpm' ;
    rdfs:comment 'The guaranteed CPM rate negotiated for this upfront commitment. CPM represents the cost per thousand impressions.' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linearAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Linear Allocation Amount' ;
    rdfs:comment 'The portion of the total committed spend allocated to linear (traditional broadcast) television inventory.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingCommitmentBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Commitment Balance' ;
    rdfs:comment 'The remaining dollar amount yet to be fulfilled against the adjusted commitment. Calculated as adjusted_commitment_amount minus delivered_spend_to_date.' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondOptionDate rdf:type rdf:Property ;
    rdfs:label 'Second Option Date' ;
    rdfs:comment 'The second date on which the advertiser may exercise their cancellation option, if applicable.' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:streamingAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Streaming Allocation Amount' ;
    rdfs:comment 'The portion of the total committed spend allocated to streaming (OTT, SVOD, AVOD) platform inventory.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thirdOptionDate rdf:type rdf:Property ;
    rdfs:label 'Third Option Date' ;
    rdfs:comment 'The third date on which the advertiser may exercise their cancellation option, if applicable.' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalCancelledAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cancelled Amount' ;
    rdfs:comment 'The cumulative dollar amount that has been cancelled by the advertiser across all option exercise events.' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalExercisedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Exercised Amount' ;
    rdfs:comment 'The cumulative dollar amount that has been exercised (confirmed for delivery) across all option exercise events.' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upfrontYear rdf:type rdf:Property ;
    rdfs:label 'Upfront Year' ;
    rdfs:comment 'The broadcast season year for this upfront commitment, typically formatted as YYYY-YYYY (e.g., 2024-2025).' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfrontOptionExerciseId rdf:type rdf:Property ;
    rdfs:label 'Upfront Option Exercise Id' ;
    rdfs:comment 'Unique identifier for the upfront option exercise record. Primary key.' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tertiaryUpfrontLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Upfront Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who most recently modified this option exercise record.' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Amendment Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the contract amendment document associated with this option exercise, if applicable.' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason the advertiser cancelled or reduced this option window commitment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Notes' ;
    rdfs:comment 'Free-text explanation providing additional context for the cancellation or reduction decision. Captured from sales representative or advertiser communication.' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledAmount rdf:type rdf:Property ;
    rdfs:label 'Cancelled Amount' ;
    rdfs:comment 'The dollar amount the advertiser cancelled or declined to commit for this option window. Calculated as original_committed_spend minus exercised_amount.' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancelledGrpVolume rdf:type rdf:Property ;
    rdfs:label 'Cancelled Grp Volume' ;
    rdfs:comment 'The Gross Rating Point volume cancelled or declined for this option window. Calculated as committed_grp_volume minus exercised_grp_volume.' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractAmendmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Amendment Required Flag' ;
    rdfs:comment 'Indicates whether this option exercise triggers a formal contract amendment or addendum to the original upfront agreement. True for material changes that require legal documentation.' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exerciseMethod rdf:type rdf:Property ;
    rdfs:label 'Exercise Method' ;
    rdfs:comment 'The communication channel or method through which the advertiser submitted their option exercise decision (e.g., email notification, phone call, self-service portal, in-person meeting, automatic per contract terms).' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exerciseStatus rdf:type rdf:Property ;
    rdfs:label 'Exercise Status' ;
    rdfs:comment 'Current status of this option exercise. Confirmed means the advertiser exercised the full option amount; partially_confirmed means a reduced amount was exercised; cancelled means the option was declined; expired means the deadline passed without action; pending means the option window is open but not yet exercised.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exercisedAmount rdf:type rdf:Property ;
    rdfs:label 'Exercised Amount' ;
    rdfs:comment 'The dollar amount the advertiser confirmed and committed to spend for this option window. May equal original_committed_spend (full exercise) or be less (partial exercise).' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exercisedGrpVolume rdf:type rdf:Property ;
    rdfs:label 'Exercised Grp Volume' ;
    rdfs:comment 'The Gross Rating Point volume the advertiser confirmed for this option window after exercise. May be less than committed_grp_volume if partially exercised.' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Inventory Release Date' ;
    rdfs:comment 'The date on which cancelled inventory from this option exercise was released to scatter market availability. Critical for scatter market inventory planning and sales.' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryReleasedFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Released Flag' ;
    rdfs:comment 'Indicates whether the cancelled inventory from this option exercise has been released back to scatter market availability. True means inventory is available for scatter sales; False means it is still held or being reallocated.' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Option Deadline Date' ;
    rdfs:comment 'The contractual deadline date by which the advertiser must exercise this option window. Failure to exercise by this date may result in automatic cancellation or confirmation per contract terms.' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionExerciseDate rdf:type rdf:Property ;
    rdfs:label 'Option Exercise Date' ;
    rdfs:comment 'The date on which the advertiser exercised (confirmed or cancelled) this option window. This is the business event date when the decision was made.' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionExerciseNumber rdf:type rdf:Property ;
    rdfs:label 'Option Exercise Number' ;
    rdfs:comment 'Business identifier for this option exercise event, typically formatted as commitment number plus option window sequence.' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionWindowNumber rdf:type rdf:Property ;
    rdfs:label 'Option Window Number' ;
    rdfs:comment 'Sequential number of the option window within the upfront commitment (e.g., 1 for first option, 2 for second option, 3 for third option). Upfront deals typically have multiple option dates where advertisers can confirm or cancel portions of their commitment.' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalCommittedSpend rdf:type rdf:Property ;
    rdfs:label 'Original Committed Spend' ;
    rdfs:comment 'The original dollar amount committed for this option window at the time the upfront deal was signed. This is the baseline amount subject to the option exercise decision.' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adBreakId rdf:type rdf:Property ;
    rdfs:label 'Ad Break Id' ;
    rdfs:comment 'Unique surrogate identifier for the ad break (ad pod) record within the scheduling domain. Primary key for this entity.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAdScteMarkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Ad Scte Marker Id' ;
    rdfs:comment 'The identifier of the SCTE-35 splice_insert or time_signal cue-out marker that signals the start of the ad break to downstream distribution systems and Dynamic Ad Insertion (DAI) platforms. References the specific SCTE-35 message that triggers break entry.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScteMarker .

ind:trafficManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Traffic Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Ad breaks are managed by traffic personnel who handle avail sales, makegoods, and preemptions. Core advertising operations workflow requires tracking responsible traffic manager for each break for acc' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Seconds' ;
    rdfs:comment 'The actual total duration of the ad break as recorded during playout by the Ericsson MediaFirst automation system. Used for post-log reconciliation, affidavit generation, and makegood assessment when actual duration deviates from planned.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affidavitGenerated rdf:type rdf:Property ;
    rdfs:label 'Affidavit Generated' ;
    rdfs:comment 'Indicates whether a proof-of-broadcast affidavit has been generated for this ad break in the Wide Orbit traffic system following confirmed playout. Affidavits are required for advertiser billing reconciliation and regulatory compliance.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automationEventCode rdf:type rdf:Property ;
    rdfs:label 'Automation Event Code' ;
    rdfs:comment 'The event identifier assigned by the Ericsson MediaFirst playout automation system to the break trigger event. Used to correlate the scheduled ad break with the actual playout automation log for post-log reconciliation and technical fault analysis.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availCount rdf:type rdf:Property ;
    rdfs:label 'Avail Count' ;
    rdfs:comment 'The total number of individual advertising avail slots (unit positions) within this ad break pod. Each avail represents a discrete sellable unit (e.g., a 30-second spot position). Used for inventory capacity planning and traffic scheduling.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutRestricted rdf:type rdf:Property ;
    rdfs:label 'Blackout Restricted' ;
    rdfs:comment 'Indicates whether this ad break is subject to geographic blackout restrictions that prevent its broadcast or streaming in specific markets or regions. When true, downstream distribution systems must apply blackout logic per rights and regulatory obligations.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakStatus rdf:type rdf:Property ;
    rdfs:label 'Break Status' ;
    rdfs:comment 'Current lifecycle status of the ad break within the scheduling and playout workflow. \'scheduled\' = planned but not yet confirmed; \'confirmed\' = traffic-confirmed with sold inventory; \'aired\' = playout completed and affidavit-eligible; \'cancelled\' = removed from schedule; \'hold\' = temporarily suspended pending resolution.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Content Restriction Code' ;
    rdfs:comment 'A code indicating any content category restrictions applicable to advertising within this break (e.g., no alcohol ads during children\'s programming, no competitor ads). Enforced by the traffic system during ad assignment. [ENUM-REF-CANDIDATE: NO_ALCOHOL|NO_GAMBLING|NO_PHARMA|NO_COMPETITOR|CHILDREN_SAFE|NONE — promote to reference product]' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daiEligible rdf:type rdf:Property ;
    rdfs:label 'Dai Eligible' ;
    rdfs:comment 'Indicates whether this ad break is enabled for Dynamic Ad Insertion (DAI), allowing server-side ad replacement for OTT/streaming simulcast audiences. When true, the break is eligible for addressable advertising via DAI platforms such as those integrated with Akamai CDN.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epgBreakLabel rdf:type rdf:Property ;
    rdfs:label 'Epg Break Label' ;
    rdfs:comment 'The human-readable label or descriptor for this ad break as it appears in the Electronic Program Guide (EPG) and scheduling rundown. Used by traffic coordinators and scheduling operators to identify breaks in the EPG interface.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpTarget rdf:type rdf:Property ;
    rdfs:label 'Grp Target' ;
    rdfs:comment 'The target Gross Rating Point (GRP) value for this ad break, representing the expected total audience delivery as a percentage of the total target population. Used for audience guarantee tracking and campaign delivery reporting against Nielsen ratings.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodRequired rdf:type rdf:Property ;
    rdfs:label 'Makegood Required' ;
    rdfs:comment 'Indicates whether a makegood (compensatory ad spot) is required for this break due to a failure to air as contracted — for example, due to preemption, technical failure, or underdelivery. Triggers makegood workflow in Wide Orbit.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Max Duration Seconds' ;
    rdfs:comment 'The maximum allowable duration of the ad break in seconds, representing the hard ceiling for total ad content that may be inserted. Exceeding this value would cause schedule overrun. May differ from planned duration when flex time is permitted.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Seconds' ;
    rdfs:comment 'The planned total duration of the ad break (ad pod) in seconds as defined in the program schedule. Represents the total sellable commercial time allocated to this break. Standard pod durations are typically 30, 60, 90, 120, or 180 seconds.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:podNumber rdf:type rdf:Property ;
    rdfs:label 'Pod Number' ;
    rdfs:comment 'The pod number identifying this ad break within the broadcast day for the channel. Distinct from sequence_number (which is relative to the program); pod_number is the channel-day-level ordinal used in traffic scheduling and affidavit reporting.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:simulcastEligible rdf:type rdf:Property ;
    rdfs:label 'Simulcast Eligible' ;
    rdfs:comment 'Indicates whether this ad break is included in the simultaneous multi-platform broadcast (simulcast) of the channel. When false, the break may be suppressed or replaced on simulcast streams (e.g., OTT, vMVPD).' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soldAvailCount rdf:type rdf:Property ;
    rdfs:label 'Sold Avail Count' ;
    rdfs:comment 'The number of individual avail slots within this break that have been sold and assigned to advertiser spots in the Wide Orbit traffic system. Used with avail_count to compute sellout rate and unsold inventory.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soldDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Sold Duration Seconds' ;
    rdfs:comment 'The total duration in seconds of ad inventory within this break that has been sold to advertisers via the Wide Orbit traffic system. Used to calculate unsold (remnant) inventory and sellout rate for revenue assurance reporting.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wideOrbitBreakCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Break Code' ;
    rdfs:comment 'The externally-known break identifier assigned by the Wide Orbit traffic and billing system. Used to reconcile ad break inventory between the scheduling domain and the ad sales/traffic fulfillment workflow. This is the BUSINESS_IDENTIFIER for the break as known to the traffic system.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adBreakDurationSec rdf:type rdf:Property ;
    rdfs:label 'Ad Break Duration Sec' ;
    rdfs:comment 'Default duration in seconds of a standard ad pod (ad break) for this channel. Used by Wide Orbit traffic system for ad scheduling, inventory management, and avail calculation. Typical values are 120 (2 minutes) or 180 (3 minutes).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affiliateNetworkCode rdf:type rdf:Property ;
    rdfs:label 'Affiliate Network Code' ;
    rdfs:comment 'Code identifying the parent broadcast network or affiliate group this channel belongs to (e.g., NBC, CBS, ABC, FOX). Used for network affiliation reporting, retransmission consent negotiations, and carriage fee calculations.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutEnabled rdf:type rdf:Property ;
    rdfs:label 'Blackout Enabled' ;
    rdfs:comment 'Indicates whether geographic broadcast blackout restrictions are applicable to this channel. When true, blackout rules must be enforced during playout and OTT delivery to restrict content in specific geographic markets per rights agreements.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastTimezone rdf:type rdf:Property ;
    rdfs:label 'Broadcast Timezone' ;
    rdfs:comment 'IANA timezone identifier for the channel\'s primary broadcast timezone (e.g., America/New_York, Europe/London). Governs daypart definitions, schedule generation, and EPG time display for the channel\'s primary market.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational lifecycle state of the channel. Drives playout automation eligibility, EPG publication, and scheduling availability in Ericsson MediaFirst.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletChannelCode rdf:type rdf:Property ;
    rdfs:label 'Dalet Channel Code' ;
    rdfs:comment 'The channel identifier as configured in Dalet Galaxy Media Asset Management system. Used to link this channel to content ingest workflows, metadata management, archive operations, and rundown generation in Dalet.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmEnabled rdf:type rdf:Property ;
    rdfs:label 'Drm Enabled' ;
    rdfs:comment 'Indicates whether Digital Rights Management (DRM) encryption is applied to this channel\'s content stream for OTT/streaming delivery. Drives content protection configuration in Akamai CDN and subscriber entitlement enforcement in Zuora.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epgEnabled rdf:type rdf:Property ;
    rdfs:label 'Epg Enabled' ;
    rdfs:comment 'Indicates whether this channel is published to the Electronic Program Guide (EPG) for audience-facing schedule display. Channels under testing or decommissioned may be excluded from EPG publication.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hlsStreamUrl rdf:type rdf:Property ;
    rdfs:label 'Hls Stream Url' ;
    rdfs:comment 'The HLS (HTTP Live Streaming) manifest URL for this channel\'s live stream, used for Apple device and browser-based OTT delivery via Akamai CDN. Supports ABR (Adaptive Bitrate Streaming) for adaptive quality delivery.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logicalChannelNumber rdf:type rdf:Property ;
    rdfs:label 'Logical Channel Number' ;
    rdfs:comment 'The numeric channel position assigned to this channel in the Electronic Program Guide (EPG) and set-top box channel lineup. Used by MVPDs and vMVPDs for channel navigation and must-carry compliance reporting.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxAdLoadPct rdf:type rdf:Property ;
    rdfs:label 'Max Ad Load Pct' ;
    rdfs:comment 'Maximum percentage of total broadcast hour that may be allocated to advertising on this channel. Governs inventory capacity planning, FCC commercial limits compliance (children\'s programming), and upfront/scatter market sales commitments.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediafirstChannelCode rdf:type rdf:Property ;
    rdfs:label 'Mediafirst Channel Code' ;
    rdfs:comment 'The channel identifier as configured in the Ericsson MediaFirst playout automation system. Used to link this master channel record to the playout engine for schedule execution, automation triggers, graphics insertion, and failover configuration.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpegDashStreamUrl rdf:type rdf:Property ;
    rdfs:label 'Mpeg Dash Stream Url' ;
    rdfs:comment 'The MPEG-DASH (Dynamic Adaptive Streaming over HTTP) manifest URL for this channel\'s live stream, used for Android, Smart TV, and cross-platform OTT delivery via Akamai CDN.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryStatus rdf:type rdf:Property ;
    rdfs:label 'Must Carry Status' ;
    rdfs:comment 'Indicates whether this channel is subject to must-carry obligations requiring MVPDs to include it in their channel lineup. Drives compliance reporting and carriage fee negotiations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkName rdf:type rdf:Property ;
    rdfs:label 'Network Name' ;
    rdfs:comment 'Human-readable name of the broadcast network or channel brand (e.g., CNN, BBC One, ESPN). Used as the primary identity label for display in EPG, scheduling tools, and audience-facing interfaces.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenStationCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Station Code' ;
    rdfs:comment 'The unique station identifier assigned by Nielsen Media Research for audience measurement, ratings reporting, and GRP/TRP calculations. Links this channel to Nielsen ratings data for advertising sales and audience analytics.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutAutomationEnabled rdf:type rdf:Property ;
    rdfs:label 'Playout Automation Enabled' ;
    rdfs:comment 'Indicates whether the channel is configured for automated playout via Ericsson MediaFirst. When true, schedule execution, ad insertion cues, and failover are handled automatically. When false, manual playout operation is required.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionProfile rdf:type rdf:Property ;
    rdfs:label 'Resolution Profile' ;
    rdfs:comment 'Video resolution classification of the channel output. SD (Standard Definition), HD (High Definition 1080i/720p), UHD (Ultra High Definition 4K/8K). Determines encoding profiles, CDN delivery tiers, and subscriber package eligibility.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionStandard rdf:type rdf:Property ;
    rdfs:label 'Transmission Standard' ;
    rdfs:comment 'Technical broadcast transmission standard used to deliver the channel signal. ATSC and ATSC 3.0 apply to North American over-the-air broadcast; DVB-T/T2 and DVB-S/S2 apply to European terrestrial and satellite; QAM applies to cable distribution; IP applies to OTT/streaming delivery. [ENUM-REF-CANDIDATE: ATSC|ATSC3|DVB-T|DVB-T2|DVB-S|DVB-S2|QAM|IP — promote to reference product]' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitStationCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Station Code' ;
    rdfs:comment 'The station code as configured in the Wide Orbit traffic and billing system. Used to link this channel master record to ad scheduling, sales orders, affidavit generation, and invoicing workflows in Wide Orbit.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adPodMaxCount rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Max Count' ;
    rdfs:comment 'The maximum number of ad pods (commercial breaks) permitted per hour within this daypart. Used by Wide Orbit for ad scheduling capacity planning and by Ericsson MediaFirst for playout rundown validation. Supports FCC commercial time compliance monitoring.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adPodMaxDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Max Duration Seconds' ;
    rdfs:comment 'The maximum allowable total duration in seconds for an ad pod (group of ads in a break) within this daypart. Governs commercial break length limits enforced by Ericsson MediaFirst playout automation and Wide Orbit ad scheduling. Aligns with FCC commercial time limits for children\'s programming dayparts.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableDays rdf:type rdf:Property ;
    rdfs:label 'Applicable Days' ;
    rdfs:comment 'Pipe-delimited list of days of the week on which this daypart definition applies, using three-letter abbreviations (e.g., MON|TUE|WED|THU|FRI for weekday dayparts, SAT|SUN for weekend). Governs schedule generation in Ericsson MediaFirst and ad inventory availability in Wide Orbit. [ENUM-REF-CANDIDATE: MON|TUE|WED|THU|FRI|SAT|SUN — promote to reference product]' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avgAudience000 rdf:type rdf:Property ;
    rdfs:label 'Avg Audience 000' ;
    rdfs:comment 'The average audience size in thousands of viewers (000s) expected during this daypart, based on Nielsen Media Research Platform historical ratings data. Used as the principal quantitative measurement of daypart audience value for ad sales, GRP calculations, and content scheduling decisions.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCpmUsd rdf:type rdf:Property ;
    rdfs:label 'Base Cpm Usd' ;
    rdfs:comment 'The baseline CPM (Cost Per Mille) rate in US dollars for advertising inventory sold within this daypart, before application of the rate_multiplier or audience demographic adjustments. Represents the floor pricing reference used in Salesforce Media Cloud upfront and scatter market proposals.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutEligible rdf:type rdf:Property ;
    rdfs:label 'Blackout Eligible' ;
    rdfs:comment 'Indicates whether geographic broadcast blackout restrictions can be applied to content scheduled within this daypart. When True, blackout rules (e.g., sports rights geographic exclusivity) may be enforced by the distribution platform. Aligns with must-carry and retransmission consent obligations.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coppaRestricted rdf:type rdf:Property ;
    rdfs:label 'Coppa Restricted' ;
    rdfs:comment 'Indicates whether this daypart is subject to COPPA (Children\'s Online Privacy Protection Act) restrictions due to programming directed at children under 13. When True, audience data collection, behavioral targeting, and ad pod duration limits are governed by COPPA compliance rules and FCC children\'s television regulations.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dayCategory rdf:type rdf:Property ;
    rdfs:label 'Day Category' ;
    rdfs:comment 'High-level classification of the day-of-week applicability for the daypart. \'weekday\' covers Monday–Friday, \'weekend\' covers Saturday–Sunday, \'all_week\' applies every day, and \'holiday\' applies on designated public holidays. Used for rate card segmentation and audience demographic profiling.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartDescription rdf:type rdf:Property ;
    rdfs:label 'Daypart Description' ;
    rdfs:comment 'Free-text narrative description of the daypart, including its programming characteristics, audience profile, and scheduling context. Used for internal documentation, Salesforce Media Cloud proposal narratives, and EPG metadata. Example: \'Prime Time (8PM-11PM) — highest-rated evening programming block targeting Adults 18-49.\'' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartName rdf:type rdf:Property ;
    rdfs:label 'Daypart Name' ;
    rdfs:comment 'Human-readable label for the daypart segment as displayed in the Electronic Program Guide (EPG), ad sales proposals, and scheduling interfaces. Examples: Early Morning, Morning Drive, Daytime, Prime Time, Late Fringe, Overnight.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartStatus rdf:type rdf:Property ;
    rdfs:label 'Daypart Status' ;
    rdfs:comment 'Current lifecycle state of the daypart definition. \'active\' indicates the daypart is in operational use for scheduling and ad sales. \'inactive\' means temporarily suspended. \'draft\' means under review before activation. \'deprecated\' means retired from use but retained for historical reference.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartType rdf:type rdf:Property ;
    rdfs:label 'Daypart Type' ;
    rdfs:comment 'Classifies the daypart by broadcast delivery mode. \'linear\' applies to traditional scheduled broadcast, \'non_linear\' to on-demand programming windows, \'simulcast\' to simultaneous multi-platform broadcast segments, and \'vod_window\' to VOD availability windows governed by this daypart definition.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'The clock time (HH:mm:ss, 24-hour or extended broadcast-day format) at which the daypart ends. Supports broadcast day overflow notation (e.g., 25:59:59 for content airing past midnight within the same broadcast day). Paired with start_time to define the daypart boundary.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:epgDisplayOrder rdf:type rdf:Property ;
    rdfs:label 'Epg Display Order' ;
    rdfs:comment 'The sequential display order of this daypart within the Electronic Program Guide (EPG) channel grid, used by Ericsson MediaFirst for schedule presentation and by digital EPG distribution systems. Lower values appear earlier in the broadcast day display.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nielsenDaypartCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Daypart Code' ;
    rdfs:comment 'The standardized daypart code as defined by Nielsen Media Research taxonomy (e.g., PRIME, EARLY_NEWS, LATE_NEWS, DAYTIME, EARLY_FRINGE, LATE_FRINGE, OVERNIGHT). Used to align internal scheduling definitions with Nielsen audience measurement reports and ratings data ingested from the Nielsen Media Research Platform.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Rate Multiplier' ;
    rdfs:comment 'Pricing multiplier applied to the base CPM (Cost Per Mille) rate card for ad inventory sold within this daypart. A value of 1.0000 represents the base rate; Prime Time typically carries a multiplier greater than 1.0 (e.g., 2.5000), while Overnight may be below 1.0 (e.g., 0.3000). Used in Salesforce Media Cloud proposal generation and Wide Orbit billing.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scatterEligible rdf:type rdf:Property ;
    rdfs:label 'Scatter Eligible' ;
    rdfs:comment 'Indicates whether unsold ad inventory within this daypart is available for scatter market (last-minute) sales. Governs Wide Orbit inventory availability rules for short-notice ad placement and makegood scheduling.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scte35CueEnabled rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue Enabled' ;
    rdfs:comment 'Indicates whether SCTE-35 digital program insertion cue markers are enabled for ad break signaling within this daypart. When True, Ericsson MediaFirst playout automation inserts SCTE-35 splice_insert commands at ad pod boundaries, enabling Dynamic Ad Insertion (DAI) for OTT and streaming distribution via Akamai CDN.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'The clock time (HH:mm:ss, 24-hour format) at which the daypart begins each applicable day. Used by Ericsson MediaFirst for automated playout boundary detection and by Wide Orbit for ad scheduling slot assignment. Stored as STRING to support broadcast day conventions (e.g., 25:00:00 for post-midnight).' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:timezoneCode rdf:type rdf:Property ;
    rdfs:label 'Timezone Code' ;
    rdfs:comment 'The IANA timezone identifier (e.g., America/New_York, America/Los_Angeles, Europe/London) governing the clock boundaries of this daypart. Critical for multi-market broadcast operations where the same daypart definition must be applied across different time zones for network affiliates and regional channels.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfrontEligible rdf:type rdf:Property ;
    rdfs:label 'Upfront Eligible' ;
    rdfs:comment 'Indicates whether ad inventory within this daypart is offered during the upfront advance advertising sales event. Prime Time and key dayparts are typically upfront-eligible. Drives Salesforce Media Cloud opportunity and proposal configuration for annual upfront sales cycles.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wideOrbitDaypartCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Daypart Code' ;
    rdfs:comment 'The corresponding daypart identifier as configured in the Wide Orbit traffic and billing system. Used to reconcile internal daypart definitions with ad scheduling, sales orders, and affidavit records in Wide Orbit. Enables cross-system traceability for revenue assurance.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgEntryId rdf:type rdf:Property ;
    rdfs:label 'Epg Entry Id' ;
    rdfs:comment 'Unique surrogate identifier for each Electronic Program Guide (EPG) entry record in the scheduling domain. Serves as the primary key for this Silver Layer data product.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adPodCount rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Count' ;
    rdfs:comment 'The number of ad pods (groups of advertisements within a break) scheduled within this program. Used for advertising inventory planning, Wide Orbit traffic scheduling, and revenue forecasting.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionWindow rdf:type rdf:Property ;
    rdfs:label 'Distribution Window' ;
    rdfs:comment 'The distribution window or release strategy under which this EPG entry is being broadcast, reflecting the windowing strategy for sequential content release. Determines rights availability and platform eligibility per Rightsline contract terms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'The current lifecycle status of this EPG entry within the scheduling workflow. \'draft\' indicates pending review; \'approved\' indicates cleared for distribution; \'published\' indicates actively distributed to EPG feeds; \'cancelled\' indicates removed from schedule; \'expired\' indicates the broadcast window has passed.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgEntryCode rdf:type rdf:Property ;
    rdfs:label 'Epg Entry Code' ;
    rdfs:comment 'Externally distributed business identifier for this EPG entry, used in feeds delivered to MVPDs, vMVPDs, set-top boxes, and digital platforms for program discovery. Format: EPG-{CHANNEL}-{YYYYMMDD}-{HHMMSS}.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgFeedVersion rdf:type rdf:Property ;
    rdfs:label 'Epg Feed Version' ;
    rdfs:comment 'The version number of this EPG entry record as distributed in the EPG feed. Incremented each time the entry is updated and redistributed to MVPDs, vMVPDs, and digital platforms. Enables downstream systems to detect and apply updates.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeTitle rdf:type rdf:Property ;
    rdfs:label 'Episode Title' ;
    rdfs:comment 'The title of the specific episode within a series, as displayed in the EPG. Null for non-episodic content such as feature films or standalone specials.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreSecondary rdf:type rdf:Property ;
    rdfs:label 'Genre Secondary' ;
    rdfs:comment 'An optional secondary genre sub-classification providing more granular content categorization for EPG discovery and audience targeting (e.g., Crime Drama, Political Comedy, Investigative Documentary).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlackout rdf:type rdf:Property ;
    rdfs:label 'Is Blackout' ;
    rdfs:comment 'Indicates whether geographic broadcast restrictions (blackout) apply to this EPG entry (True). When True, the program is subject to blackout rules that restrict distribution in specific geographic markets per rights agreements managed in Rightsline.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isClosedCaption rdf:type rdf:Property ;
    rdfs:label 'Is Closed Caption' ;
    rdfs:comment 'Indicates whether closed captioning (CC) is available for this program (True). Distributed in EPG feeds for accessibility compliance and viewer information. Required for FCC closed captioning regulatory compliance.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHdr rdf:type rdf:Property ;
    rdfs:label 'Is Hdr' ;
    rdfs:comment 'Indicates whether this program is available in High Dynamic Range (HDR) format (True). Distributed in EPG feeds to inform viewers and set-top boxes of enhanced picture quality availability.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLive rdf:type rdf:Property ;
    rdfs:label 'Is Live' ;
    rdfs:comment 'Indicates whether this EPG entry represents a live broadcast event (True) as opposed to a pre-recorded or time-shifted program (False). Drives playout automation configuration in Ericsson MediaFirst and is distributed in EPG feeds for viewer-facing live indicators.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNewEpisode rdf:type rdf:Property ;
    rdfs:label 'Is New Episode' ;
    rdfs:comment 'Indicates whether this EPG entry represents a new, first-run episode (True) or a repeat/rerun broadcast (False). Distributed in EPG feeds for viewer-facing \'NEW\' indicators and drives audience measurement prioritization.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSimulcast rdf:type rdf:Property ;
    rdfs:label 'Is Simulcast' ;
    rdfs:comment 'Indicates whether this program is being simultaneously broadcast across multiple platforms or channels (simulcast). When True, the same content is distributed concurrently on linear and digital/OTT platforms.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'The date and time when this EPG entry was first published and distributed to external EPG feeds (MVPDs, vMVPDs, set-top boxes, digital platforms). Serves as the record audit created timestamp for this data product.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rightsWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Rights Window End' ;
    rdfs:comment 'The end date of the broadcast rights window during which this content is cleared for transmission on this channel. After this date, the content enters a holdback period and cannot be broadcast without rights renewal in Rightsline.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsWindowStart rdf:type rdf:Property ;
    rdfs:label 'Rights Window Start' ;
    rdfs:comment 'The start date of the broadcast rights window during which this content is cleared for transmission on this channel. Derived from Rightsline contract availabilities and used to validate schedule compliance.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scte35CueOutTime rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue Out Time' ;
    rdfs:comment 'The timestamp of the SCTE-35 splice_insert cue-out signal marking the start of an ad break opportunity within this program. Used by Dynamic Ad Insertion (DAI) systems and Wide Orbit traffic systems for ad pod placement and automated ad scheduling.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:seriesName rdf:type rdf:Property ;
    rdfs:label 'Series Name' ;
    rdfs:comment 'The name of the parent series or franchise to which this episode belongs. Enables series-level grouping and discovery in EPG interfaces. Null for non-series content.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAdBreakDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Ad Break Duration Seconds' ;
    rdfs:comment 'The total cumulative duration in seconds of all scheduled ad breaks within this program. Used for advertising inventory management, compliance with ad load regulations, and Wide Orbit traffic scheduling.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playoutEventId rdf:type rdf:Property ;
    rdfs:label 'Playout Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each as-run playout event record in the Ericsson MediaFirst as-run log. Serves as the primary key for this table.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPlayoutTitleId rdf:type rdf:Property ;
    rdfs:label 'Primary Playout Title Id' ;
    rdfs:comment 'Reference to the content asset (programme, advertisement, interstitial, or filler) that was transmitted in this playout event. Links to the content master in the Digital Asset Management system.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:daletAssetCode rdf:type rdf:Property ;
    rdfs:label 'Dalet Asset Code' ;
    rdfs:comment 'Asset identifier in the Dalet Galaxy Media Asset Management system for the content transmitted in this playout event. Used for digital asset reconciliation and archive linkage.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failoverActivated rdf:type rdf:Property ;
    rdfs:label 'Failover Activated' ;
    rdfs:comment 'Indicates whether the Ericsson MediaFirst failover/backup playout system was active during this event. When true, the primary playout chain was unavailable and the backup system handled transmission.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediafirstEventCode rdf:type rdf:Property ;
    rdfs:label 'Mediafirst Event Code' ;
    rdfs:comment 'Native event identifier assigned by Ericsson MediaFirst automation system for this as-run log entry. Used for reconciliation with the source playout system.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryFlag rdf:type rdf:Property ;
    rdfs:label 'Must Carry Flag' ;
    rdfs:comment 'Indicates whether this playout event was subject to must-carry obligations requiring mandatory channel inclusion by MVPDs. Used for regulatory compliance reporting to the FCC.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playoutStatus rdf:type rdf:Property ;
    rdfs:label 'Playout Status' ;
    rdfs:comment 'Outcome status of the playout event as recorded in the Ericsson MediaFirst as-run log. \'aired\' = transmitted as planned; \'skipped\' = omitted from transmission; \'substituted\' = replaced with alternate content; \'failed\' = transmission error; \'partial\' = incomplete transmission; \'delayed\' = transmitted late.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Scheduled Duration Seconds' ;
    rdfs:comment 'Planned duration of the playout event in seconds as defined in the program schedule rundown. Used as the baseline for duration deviation analysis.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:simulcastFlag rdf:type rdf:Property ;
    rdfs:label 'Simulcast Flag' ;
    rdfs:comment 'Indicates whether this playout event was simultaneously broadcast across multiple platforms (simulcast). When true, the event was transmitted on additional channels or OTT platforms concurrently.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startDeviationSeconds rdf:type rdf:Property ;
    rdfs:label 'Start Deviation Seconds' ;
    rdfs:comment 'Difference in seconds between actual_start_time and scheduled_start_time. Positive values indicate late start; negative values indicate early start. Key metric for schedule adherence and SLA reporting.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substitutionReason rdf:type rdf:Property ;
    rdfs:label 'Substitution Reason' ;
    rdfs:comment 'Reason code explaining why the originally scheduled content was substituted with alternate content. Populated only when playout_status is \'substituted\'. Used for rights compliance and editorial audit trails.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionType rdf:type rdf:Property ;
    rdfs:label 'Transmission Type' ;
    rdfs:comment 'Mode of content delivery for this playout event. \'linear\' = traditional scheduled broadcast; \'vod\' = Video On Demand; \'simulcast\' = simultaneous multi-platform; \'ott\' = Over-The-Top streaming; \'fast\' = Free Ad-Supported Streaming Television.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitLogCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Log Code' ;
    rdfs:comment 'Corresponding log entry identifier in Wide Orbit Traffic and Billing system. Used for advertiser billing reconciliation and affidavit generation.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programRundownId rdf:type rdf:Property ;
    rdfs:label 'Program Rundown Id' ;
    rdfs:comment 'Unique surrogate identifier for the program rundown record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramRundown .

ind:producerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Producer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Program rundowns are created by producers/directors for live and taped programs. Fundamental production workflow tracking requires linking rundown to responsible producer for coordination, approval ro' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:daletStoryCode rdf:type rdf:Property ;
    rdfs:label 'Dalet Story Code' ;
    rdfs:comment 'The story or rundown identifier in Dalet Galaxy Media Asset Management system. Enables traceability from the Silver Layer back to the MAM workflow for metadata, archive, and ingest operations.' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyAlertReady rdf:type rdf:Property ;
    rdfs:label 'Emergency Alert Ready' ;
    rdfs:comment 'Indicates whether the rundown and playout configuration supports Emergency Alert System (EAS) interruption. Required for FCC broadcast compliance and emergency preparedness.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liveFlag rdf:type rdf:Property ;
    rdfs:label 'Live Flag' ;
    rdfs:comment 'Indicates whether the program is transmitted live (True) or is a pre-recorded/tape playback (False). Drives Ericsson MediaFirst live playout mode and affects DAI eligibility and failover configuration.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediafirstRundownCode rdf:type rdf:Property ;
    rdfs:label 'Mediafirst Rundown Code' ;
    rdfs:comment 'The native rundown identifier assigned by Ericsson MediaFirst playout automation system. Used for bidirectional reconciliation between the Silver Layer and the operational playout system.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutFailoverMode rdf:type rdf:Property ;
    rdfs:label 'Playout Failover Mode' ;
    rdfs:comment 'Defines the failover strategy configured in Ericsson MediaFirst if the primary playout source fails during this program. \'none\' = no failover; \'backup_channel\' = switch to backup feed; \'filler_loop\' = play filler content; \'manual\' = operator intervention required.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programContentSeconds rdf:type rdf:Property ;
    rdfs:label 'Program Content Seconds' ;
    rdfs:comment 'Total planned duration of editorial/program content segments in seconds, excluding commercial breaks and credits. Used for content-to-ad ratio compliance reporting.' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rundownCode rdf:type rdf:Property ;
    rdfs:label 'Rundown Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the rundown, used by production teams and Ericsson MediaFirst automation to reference the show rundown. Unique within a broadcast date and channel.' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rundownNotes rdf:type rdf:Property ;
    rdfs:label 'Rundown Notes' ;
    rdfs:comment 'Free-text production notes associated with the rundown, capturing special instructions, last-minute changes, talent notes, or technical advisories for the production and playout teams.' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rundownStatus rdf:type rdf:Property ;
    rdfs:label 'Rundown Status' ;
    rdfs:comment 'Current lifecycle state of the rundown. \'draft\' = in preparation; \'approved\' = signed off by producer; \'locked\' = no further edits permitted; \'transmitted\' = playout completed; \'archived\' = retained for compliance.' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rundownType rdf:type rdf:Property ;
    rdfs:label 'Rundown Type' ;
    rdfs:comment 'Classification of the program rundown by genre or production format. Drives template selection in Ericsson MediaFirst and informs segment structure expectations. [ENUM-REF-CANDIDATE: news|sports|entertainment|talk_show|documentary|magazine|special — promote to reference product]' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rundownVersion rdf:type rdf:Property ;
    rdfs:label 'Rundown Version' ;
    rdfs:comment 'Incremental version number of the rundown, incremented each time the rundown is revised. Enables version tracking and rollback for production teams and playout automation.' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scte35CueCount rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue Count' ;
    rdfs:comment 'Number of SCTE-35 digital program insertion cue markers planned in this rundown. Used for Dynamic Ad Insertion (DAI) triggering and ad break signaling to downstream distribution systems.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentCount rdf:type rdf:Property ;
    rdfs:label 'Segment Count' ;
    rdfs:comment 'Total number of rundown items (segments) defined in this rundown, including news blocks, interviews, commercial breaks, tosses, and credits. Used for production planning and playout validation.' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAdTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Ad Time Seconds' ;
    rdfs:comment 'Total planned advertising time in seconds across all ad pods in the rundown. Used for FCC/Ofcom advertising minutage compliance and Wide Orbit traffic reconciliation.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRuntimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Runtime Seconds' ;
    rdfs:comment 'Total planned duration of the program in seconds, encompassing all segments including program content, commercial breaks, and credits. Must match the EPG slot allocation.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmitted Timestamp' ;
    rdfs:comment 'The actual date and time when playout of this program rundown commenced transmission. Populated by Ericsson MediaFirst upon broadcast start. Used for as-run reconciliation and affidavit generation.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schedulerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Scheduler Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Program schedules are created by specific scheduling coordinators. Critical for workflow tracking, quality control, and accountability when schedule conflicts or errors occur. Standard broadcast traff' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:asRunConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'As Run Confirmed Timestamp' ;
    rdfs:comment 'Timestamp when the as-run log was confirmed and reconciled against the planned schedule. Marks the transition to \'as-run\' status. Used for Wide Orbit affidavit generation, Nielsen ratings reconciliation, and revenue assurance.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contentRatingAdvisory rdf:type rdf:Property ;
    rdfs:label 'Content Rating Advisory' ;
    rdfs:comment 'The highest content rating advisory applicable to any program in this schedule for the broadcast day. Used for parental control systems, V-chip compliance, and FCC content standards reporting. Ratings follow the TV Parental Guidelines system mandated by the FCC.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletWorkflowCode rdf:type rdf:Property ;
    rdfs:label 'Dalet Workflow Code' ;
    rdfs:comment 'Reference identifier for the Dalet Galaxy media asset management workflow instance associated with this schedule\'s content preparation and ingest activities. Links the schedule to the MAM workflow for asset readiness validation prior to playout.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgGridCode rdf:type rdf:Property ;
    rdfs:label 'Epg Grid Code' ;
    rdfs:comment 'External identifier assigned to this schedule in the Electronic Program Guide (EPG) distribution system. Used by downstream EPG aggregators, set-top box providers, and digital guide services to reference the channel day grid. Aligns with DVB SI/EIT table identifiers.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fccChildrenProgrammingCompliant rdf:type rdf:Property ;
    rdfs:label 'Fcc Children Programming Compliant' ;
    rdfs:comment 'Indicates whether this schedule meets FCC children\'s educational and informational (E/I) programming requirements for the broadcast date. True = minimum required hours of qualifying children\'s programming are scheduled. Required for FCC license renewal compliance reporting.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mustCarryCompliant rdf:type rdf:Property ;
    rdfs:label 'Must Carry Compliant' ;
    rdfs:comment 'Indicates whether this schedule satisfies must-carry obligations for the channel on this broadcast date. Must-carry is the mandatory channel inclusion requirement imposed on cable and satellite MVPDs by the FCC. True = compliant; False = compliance issue requiring resolution.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleEndTime rdf:type rdf:Property ;
    rdfs:label 'Schedule End Time' ;
    rdfs:comment 'The planned end timestamp of the broadcast schedule for this channel day, including timezone offset. Typically 23:59:59 local broadcast time but may extend past midnight for overnight programming blocks. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Schedule Notes' ;
    rdfs:comment 'Free-text operational notes entered by scheduling staff regarding special instructions, exceptions, or context for this schedule (e.g., \'Breaking news override applied to 8PM slot\', \'Live sports event extends prime block by 30 min\'). Not used for automated processing.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleSource rdf:type rdf:Property ;
    rdfs:label 'Schedule Source' ;
    rdfs:comment 'Indicates how this schedule was generated. \'manual\' = built by scheduling staff; \'automated\' = generated by Ericsson MediaFirst automated schedule engine; \'imported\' = ingested from an external programming supplier or network feed; \'template\' = derived from a recurring schedule template.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStartTime rdf:type rdf:Property ;
    rdfs:label 'Schedule Start Time' ;
    rdfs:comment 'The planned start timestamp of the broadcast schedule for this channel day, including timezone offset. Typically 00:00:00 local broadcast time but may differ for overnight schedules that begin at a non-midnight boundary. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the schedule by programming strategy type. \'standard\' = regular broadcast day; \'special_event\' = live event or breaking news override; \'holiday\' = holiday programming grid; \'sweeps\' = Nielsen sweeps period intensive ratings schedule; \'upfront_preview\' = advance advertising sales event programming.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simulcastPlatformCount rdf:type rdf:Property ;
    rdfs:label 'Simulcast Platform Count' ;
    rdfs:comment 'Number of platforms on which this schedule is simultaneously broadcast when simulcast_flag is True. Used for multi-platform distribution planning and rights compliance verification across linear, OTT, and vMVPD delivery channels.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for the broadcast timezone in which this schedule\'s times are expressed (e.g., \'America/New_York\', \'Europe/London\'). Critical for accurate EPG display, daypart classification, and regulatory compliance reporting across markets.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalProgramTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Program Time Seconds' ;
    rdfs:comment 'Total planned programming (non-commercial) airtime in seconds for this channel day schedule. Equals total_runtime_seconds minus total_ad_time_seconds. Used for content utilization reporting and rights compliance verification.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rundownItemId rdf:type rdf:Property ;
    rdfs:label 'Rundown Item Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual segment or item within a program rundown. Primary key for the rundown_item entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adPodFlag rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Flag' ;
    rdfs:comment 'Indicates whether this rundown item represents an Ad Pod (a group of commercial spots within a break). When true, triggers SCTE-35 cue marker insertion and Dynamic Ad Insertion (DAI) eligibility checks.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adPodSpotCount rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Spot Count' ;
    rdfs:comment 'Number of individual commercial spots scheduled within this ad pod break. Used for ad load monitoring, Wide Orbit traffic log validation, and FCC children\'s programming ad limit compliance.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backtimeFlag rdf:type rdf:Property ;
    rdfs:label 'Backtime Flag' ;
    rdfs:comment 'Indicates whether this rundown item is backtimed — i.e., its start time is calculated backwards from a fixed end point (e.g., top-of-hour news break or programme end). Critical for live show timing control in Ericsson MediaFirst.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cueText rdf:type rdf:Property ;
    rdfs:label 'Cue Text' ;
    rdfs:comment 'Editorial cue or introduction text read by the presenter or director to introduce this rundown item. Stored as the production script reference for live show execution and post-broadcast archive.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationVarianceSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Variance Seconds' ;
    rdfs:comment 'Difference in seconds between actual_duration_seconds and planned_duration_seconds (actual minus planned). Positive values indicate overrun; negative values indicate underrun. Used for show timing analysis and rundown optimisation.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eomTimecode rdf:type rdf:Property ;
    rdfs:label 'Eom Timecode' ;
    rdfs:comment 'SMPTE timecode marking the End of Message (EOM) — the precise out-point of the media asset for this rundown item. Used alongside som_timecode for frame-accurate duration calculation and playout control.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgDescription rdf:type rdf:Property ;
    rdfs:label 'Epg Description' ;
    rdfs:comment 'Short editorial description of this rundown item for display in the Electronic Program Guide (EPG). Populated for story packages and feature segments; used by EPG aggregators and on-screen guide systems.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current production lifecycle state of the rundown item as managed in the live show production control system. Drives automation decisions in Ericsson MediaFirst and Dalet Galaxy workflow.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemTitle rdf:type rdf:Property ;
    rdfs:label 'Item Title' ;
    rdfs:comment 'Human-readable editorial title or slug for the rundown item as displayed in the production control system and Electronic Program Guide (EPG). Used by producers and directors during live show execution.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemType rdf:type rdf:Property ;
    rdfs:label 'Item Type' ;
    rdfs:comment 'Classification of the discrete production element represented by this rundown item. Determines playout behaviour, automation triggers, and ad pod eligibility. [ENUM-REF-CANDIDATE: story_package|live_shot|interview|commercial_break|graphic|music_bed|filler|open|close — promote to reference product]' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediafirstItemCode rdf:type rdf:Property ;
    rdfs:label 'Mediafirst Item Code' ;
    rdfs:comment 'Native item identifier assigned by the Ericsson MediaFirst playout automation system for this rundown element. Used for reconciliation between the Silver Layer data product and the operational playout system.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'Scheduled wall-clock start time for this rundown item based on the pre-production rundown. Used for Electronic Program Guide (EPG) display, backtime calculations, and SCTE-35 cue marker pre-positioning.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scte35CueInTime rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue In Time' ;
    rdfs:comment 'Timestamp at which the SCTE-35 splice_insert cue-in signal is triggered to mark the return to programme content after an ad break. Used for DAI reconciliation and ad delivery verification.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:segmentFormat rdf:type rdf:Property ;
    rdfs:label 'Segment Format' ;
    rdfs:comment 'Production format classification of the rundown item using broadcast newsroom terminology. Determines the technical playout configuration and graphics overlay requirements in Ericsson MediaFirst. [ENUM-REF-CANDIDATE: pkg|vo|vosot|sot|live|standup|anchor_read|graphic_full|lower_third — promote to reference product]' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skipReason rdf:type rdf:Property ;
    rdfs:label 'Skip Reason' ;
    rdfs:comment 'Reason code explaining why this rundown item was skipped during playout. Populated only when item_status = skipped. Used for post-broadcast editorial review and rights compliance audit.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:somTimecode rdf:type rdf:Property ;
    rdfs:label 'Som Timecode' ;
    rdfs:comment 'SMPTE timecode marking the Start of Message (SOM) — the precise in-point of the media asset to be played for this rundown item. Used by Ericsson MediaFirst for frame-accurate playout cueing.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeNumber rdf:type rdf:Property ;
    rdfs:label 'Tape Number' ;
    rdfs:comment 'Physical or virtual media identifier (tape ID, clip ID, or server ID) for the pre-recorded asset associated with this rundown item in the Dalet Galaxy MAM system. Used for media retrieval and playout server cueing.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitSpotCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Spot Code' ;
    rdfs:comment 'Identifier from the Wide Orbit Traffic and Billing system for commercial spots or ad pod items within this rundown. Populated only for item_type = commercial_break; used for affidavit generation and billing reconciliation.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Traffic Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Traffic coordinators assign and manage individual schedule slots, handle preemptions, and coordinate with sales. Standard broadcast traffic operations workflow requires tracking who manages each slot ' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:easAlertType rdf:type rdf:Property ;
    rdfs:label 'Eas Alert Type' ;
    rdfs:comment 'Type of Emergency Alert System (EAS) message associated with this slot when slot_type is \'eas\' (e.g., EAN — Emergency Action Notification, NPT — National Periodic Test, RWT — Required Weekly Test). Null for non-EAS slots. Mandatory for FCC EAS compliance logging. [ENUM-REF-CANDIDATE: EAN|NPT|RWT|SVR|TOR|FFW|HUW|WSW — promote to reference product]' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRepeat rdf:type rdf:Property ;
    rdfs:label 'Is Repeat' ;
    rdfs:comment 'Indicates whether this slot is a repeat airing of previously broadcast content (True) rather than a first-run premiere (False). Affects talent residuals calculations in Rightsline and Nielsen audience measurement weighting.' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'Scheduled end date and time for this slot as defined in the EPG rundown. Derived from planned_start_time plus planned_duration_seconds but stored explicitly to support EPG grid queries and boundary validation.' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:secondaryAudioFlag rdf:type rdf:Property ;
    rdfs:label 'Secondary Audio Flag' ;
    rdfs:comment 'Indicates whether a Secondary Audio Program (SAP) track is available for this slot (True), typically used for audio description (AD) for visually impaired viewers or alternate language audio. Required for FCC video description compliance reporting.' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slotSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Slot Sequence Number' ;
    rdfs:comment 'Ordinal position of this slot within the daily rundown for the channel. Determines the playout order in Ericsson MediaFirst automation. Sequence numbers are contiguous integers starting at 1 for each broadcast day.' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slotStatus rdf:type rdf:Property ;
    rdfs:label 'Slot Status' ;
    rdfs:comment 'Current lifecycle state of the schedule slot within the EPG workflow. Values: scheduled (initial EPG entry), confirmed (locked for playout), on_air (currently broadcasting), completed (as-run recorded), cancelled (removed from schedule), replaced (substituted with alternate content). Drives Ericsson MediaFirst automation state machine.' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotType rdf:type rdf:Property ;
    rdfs:label 'Slot Type' ;
    rdfs:comment 'Classification of the schedule slot by content category. Values: program (primary editorial content), promo (promotional spot), commercial_break (paid advertising break), filler (interstitial padding content), psa (Public Service Announcement), eas (Emergency Alert System message). Drives playout automation logic and ad insertion rules in Ericsson MediaFirst.' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Traffic Order Number' ;
    rdfs:comment 'Wide Orbit traffic system order number associated with this slot when it carries a commercial or promotional spot. Links the EPG slot to the ad sales order for affidavit generation, billing reconciliation, and makegood processing.' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adBreakMaxDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Ad Break Max Duration Seconds' ;
    rdfs:comment 'The maximum allowable duration in seconds for a single ad break (ad pod) within the content during this availability window. Used to enforce ad load limits and viewer experience standards on AVOD and FAST platforms.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:akamaiStreamUrl rdf:type rdf:Property ;
    rdfs:label 'Akamai Stream Url' ;
    rdfs:comment 'The Akamai CDN origin stream URL for delivering the content during this availability window. Specifies the endpoint used for HLS or MPEG-DASH adaptive bitrate streaming to end-user devices.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusive Flag' ;
    rdfs:comment 'Indicates whether this availability window grants exclusive rights to the platform for the specified territory and window period. When True, the content must not be made available on any competing platform during this window.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdbackFlag rdf:type rdf:Property ;
    rdfs:label 'Holdback Flag' ;
    rdfs:comment 'Indicates whether this window represents a holdback period during which the content is explicitly withheld from the platform or service tier. When True, the content must not be made available regardless of other scheduling parameters.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightslineWindowRef rdf:type rdf:Property ;
    rdfs:label 'Rightsline Window Ref' ;
    rdfs:comment 'The native window reference identifier from the Rightsline Rights and Royalties Management system. Used for cross-system reconciliation between the scheduling domain and the rights domain to ensure operational parameters align with contractual rights.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTierCode rdf:type rdf:Property ;
    rdfs:label 'Service Tier Code' ;
    rdfs:comment 'Identifies the specific subscription or service tier within the platform on which this window applies (e.g., BASIC, STANDARD, PREMIUM, AD_FREE). Aligns with Zuora subscription plan tiers for entitlement enforcement.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staggerOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Stagger Offset Days' ;
    rdfs:comment 'For staggered windowing strategy, the number of days this platform\'s availability window is offset relative to the primary release platform or theatrical/linear premiere date. Zero indicates simultaneous release; positive values indicate delayed release.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowCloseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Window Close Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone offset) at which the content title expires and is no longer available on the specified platform. Null indicates an open-ended window with no defined expiry.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:windowNotes rdf:type rdf:Property ;
    rdfs:label 'Window Notes' ;
    rdfs:comment 'Free-text operational notes or comments associated with this availability window, capturing scheduling rationale, rights exceptions, platform-specific instructions, or escalation context for scheduling operations teams.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Window Open Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone offset) at which the content title becomes available on the specified platform. This is the principal business event timestamp for the availability window lifecycle.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schedulingBlackoutRuleId rdf:type rdf:Property ;
    rdfs:label 'Scheduling Blackout Rule Id' ;
    rdfs:comment 'Unique surrogate identifier for the blackout rule record in the scheduling domain. Primary key for the scheduling_blackout_rule data product.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySchedulingTitleId rdf:type rdf:Property ;
    rdfs:label 'Primary Scheduling Title Id' ;
    rdfs:comment 'Reference to the content asset subject to the blackout restriction, as catalogued in Dalet Galaxy Media Asset Management. Links to the master content record for the program, film, or event being blacked out.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:akamaiRuleCode rdf:type rdf:Property ;
    rdfs:label 'Akamai Rule Code' ;
    rdfs:comment 'The corresponding rule identifier in Akamai CDN configuration that enforces this blackout at the content delivery network level for OTT and streaming platforms. Enables traceability between the scheduling blackout rule and its CDN enforcement policy.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Blackout End Timestamp' ;
    rdfs:comment 'The exact date and time (exclusive) at which the blackout restriction is lifted and normal playout/streaming of the content in the restricted territory may resume. Nullable for open-ended holdback obligations. Enforced by Ericsson MediaFirst and Akamai CDN.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blackoutStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Blackout Start Timestamp' ;
    rdfs:comment 'The exact date and time (inclusive) at which the blackout restriction becomes effective and playout/streaming of the content in the restricted territory must be suppressed. Enforced by Ericsson MediaFirst at playout and Akamai CDN at delivery. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daiOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Dai Override Flag' ;
    rdfs:comment 'Indicates whether Dynamic Ad Insertion (DAI) should be overridden or suppressed during the blackout window for the restricted territory. When True, DAI ad pods are not inserted into the substitute content stream, preventing ad revenue leakage or compliance violations during blackout periods.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enforcementScope rdf:type rdf:Property ;
    rdfs:label 'Enforcement Scope' ;
    rdfs:comment 'Defines where the blackout rule is enforced in the distribution chain. \'playout_only\' restricts at Ericsson MediaFirst broadcast playout; \'cdn_only\' restricts at Akamai CDN for streaming; \'playout_and_cdn\' enforces at both layers; \'epg_suppression\' additionally removes the program from EPG listings in the restricted territory.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgSuppressionFlag rdf:type rdf:Property ;
    rdfs:label 'Epg Suppression Flag' ;
    rdfs:comment 'Indicates whether the program should be suppressed from the Electronic Program Guide (EPG) listing in the restricted territory during the blackout window. When True, the program title and metadata are hidden from viewer-facing EPG displays in the blacked-out market.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdbackType rdf:type rdf:Property ;
    rdfs:label 'Holdback Type' ;
    rdfs:comment 'The specific type of holdback obligation driving this blackout rule. \'exclusivity\' indicates a contractual exclusivity period; \'windowing\' indicates a sequential release window restriction; \'league_mandate\' indicates a sports league blackout mandate; \'regulatory\' indicates an FCC or Ofcom regulatory requirement; \'carriage_agreement\' indicates a distribution carriage fee agreement restriction.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediafirstRuleCode rdf:type rdf:Property ;
    rdfs:label 'Mediafirst Rule Code' ;
    rdfs:comment 'The corresponding blackout rule identifier in Ericsson MediaFirst playout automation system. Used to synchronize blackout enforcement between the scheduling data product and the playout automation layer.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Must Carry Exempt Flag' ;
    rdfs:comment 'Indicates whether this blackout rule is exempt from must-carry obligations under FCC regulations. When True, the blackout may override must-carry requirements for the specified territory, typically applicable to sports blackout rules under 47 CFR Part 76.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedPlatformType rdf:type rdf:Property ;
    rdfs:label 'Restricted Platform Type' ;
    rdfs:comment 'The distribution platform category on which the blackout is enforced. Supports platform-specific blackout enforcement across linear broadcast, SVOD (Subscription Video On Demand), AVOD (Advertising-Supported Video On Demand), TVOD (Transactional Video On Demand), OTT (Over-The-Top), MVPD (Multichannel Video Programming Distributor), vMVPD (Virtual MVPD), and FAST (Free Ad-Supported Streaming Television) channels. [ENUM-REF-CANDIDATE: linear|svod|avod|tvod|ott|mvpd|vmvpd|fast — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Restricted Territory Code' ;
    rdfs:comment 'The specific geographic territory code where the blackout is enforced, aligned with the restricted_territory_type. For DMA, this is the Nielsen DMA code (e.g., \'501\' for New York); for country, this is ISO 3166-1 alpha-3 (e.g., \'GBR\'); for state/province, this is ISO 3166-2 (e.g., \'US-CA\'). Used by Akamai CDN for geo-fencing enforcement.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedTerritoryName rdf:type rdf:Property ;
    rdfs:label 'Restricted Territory Name' ;
    rdfs:comment 'Human-readable name of the restricted geographic territory (e.g., \'New York DMA\', \'United Kingdom\', \'California\'). Used in EPG displays, rights clearance reports, and operational dashboards.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedTerritoryType rdf:type rdf:Property ;
    rdfs:label 'Restricted Territory Type' ;
    rdfs:comment 'Granularity level of the geographic restriction applied by this blackout rule. \'dma\' refers to Nielsen Designated Market Area; \'country\' uses ISO 3166-1 alpha-3; \'postal_region\' uses postal code ranges; \'state_province\' uses ISO 3166-2 subdivision codes; \'designated_zone\' refers to a custom broadcast zone defined in the rights contract.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Flag' ;
    rdfs:comment 'Indicates whether this blackout rule is linked to a retransmission consent agreement. When True, the blackout is enforced as a condition of the retransmission consent negotiation between the broadcaster and the MVPD or vMVPD distributor.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightslineRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Rightsline Restriction Code' ;
    rdfs:comment 'The restriction or holdback record identifier in Rightsline Rights and Royalties Management system that is the source of record for this blackout obligation. Enables bidirectional traceability between scheduling enforcement and rights contract management.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleNotes rdf:type rdf:Property ;
    rdfs:label 'Rule Notes' ;
    rdfs:comment 'Free-text operational notes providing additional context for the blackout rule, such as specific contractual conditions, exceptions, or instructions for the scheduling and playout teams. Not used for enforcement logic.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle state of the blackout rule. \'draft\' indicates the rule is being configured; \'active\' indicates it is currently enforced at playout and CDN; \'suspended\' indicates temporary non-enforcement; \'expired\' indicates the rule window has passed; \'cancelled\' indicates the rule was voided before activation.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the blackout rule by its originating business driver. \'rights_holdback\' indicates a contractual windowing restriction from Rightsline; \'regulatory\' indicates FCC or Ofcom mandate; \'sports_blackout\' indicates league-mandated local market blackout; \'network_exclusivity\' indicates carriage agreement exclusivity; \'geographic_restriction\' indicates a general territorial restriction. [ENUM-REF-CANDIDATE: rights_holdback|regulatory|sports_blackout|network_exclusivity|geographic_restriction — promote to reference product]' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scte35CueCode rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue Code' ;
    rdfs:comment 'The SCTE-35 splice_event_id or cue identifier associated with this blackout rule, used by Ericsson MediaFirst to insert the blackout signal into the transport stream at the correct splice point. Enables automated blackout triggering at playout.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simulcastBlackoutFlag rdf:type rdf:Property ;
    rdfs:label 'Simulcast Blackout Flag' ;
    rdfs:comment 'Indicates whether the blackout rule applies to simulcast transmissions of the content across multiple platforms simultaneously. When True, the blackout is enforced on all simulcast streams in addition to the primary broadcast channel.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:substituteContentType rdf:type rdf:Property ;
    rdfs:label 'Substitute Content Type' ;
    rdfs:comment 'Classification of the substitute content to be delivered during the blackout window. \'alternate_program\' is a scheduled replacement; \'local_affiliate_feed\' is a local station feed; \'blackout_slate\' is a static or animated blackout message; \'network_filler\' is generic filler programming; \'none\' indicates no substitute is configured.' ;
    rdfs:domain ind:SchedulingBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoReturn rdf:type rdf:Property ;
    rdfs:label 'Auto Return' ;
    rdfs:comment 'Indicates whether the playout system should automatically return to network programming at the end of the break_duration without waiting for an explicit splice-in command. When True, the break is time-bounded; when False, an explicit splice-in SCTE-35 message is required.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availNum rdf:type rdf:Property ;
    rdfs:label 'Avail Num' ;
    rdfs:comment 'The avail_num field from the SCTE-35 splice_insert() command, indicating the sequential number of this ad avail within the current program. Used alongside avails_expected to track avail inventory completeness for a given program break sequence.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availsExpected rdf:type rdf:Property ;
    rdfs:label 'Avails Expected' ;
    rdfs:comment 'The avails_expected field from the SCTE-35 splice_insert() command, indicating the total number of ad avails expected within the current program. Enables DAI systems and Wide Orbit to validate that all avail windows have been signalled and filled.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutRegionCode rdf:type rdf:Property ;
    rdfs:label 'Blackout Region Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code or proprietary DMA/region code identifying the geographic area subject to the blackout restriction signalled by this marker. Populated only when blackout_flag is True. Used for MVPD compliance and retransmission consent enforcement.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakDurationMs rdf:type rdf:Property ;
    rdfs:label 'Break Duration Ms' ;
    rdfs:comment 'The total duration of the ad break or content replacement window in milliseconds, as signalled in the SCTE-35 break_duration() structure. Defines the length of the avail window available for ad pod insertion. Used by Wide Orbit traffic system for avail reconciliation.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentCount rdf:type rdf:Property ;
    rdfs:label 'Component Count' ;
    rdfs:comment 'Number of elementary stream components (video, audio tracks, data) included in the splice command when component_splice_flag is set. Indicates multi-component splice operations for multi-language or multi-audio broadcast streams.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cwIndex rdf:type rdf:Property ;
    rdfs:label 'Cw Index' ;
    rdfs:comment 'The cw_index field from the SCTE-35 splice_info_section, referencing the encryption control word used when the splice message is encrypted. A value of 0xFF indicates no encryption. Relevant for DRM-protected transport streams.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:descriptorLoopLength rdf:type rdf:Property ;
    rdfs:label 'Descriptor Loop Length' ;
    rdfs:comment 'The total byte length of the splice descriptor loop in the SCTE-35 splice_info_section. Indicates the presence and size of additional descriptors such as segmentation_descriptor, DTMF_descriptor, or avail_descriptor. Used for message parsing validation.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:encryptedPacket rdf:type rdf:Property ;
    rdfs:label 'Encrypted Packet' ;
    rdfs:comment 'Indicates whether the SCTE-35 splice_info_section payload is encrypted. When True, the cw_index field identifies the applicable decryption key. Relevant for secure ad insertion in DRM-protected broadcast streams.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfNetwork rdf:type rdf:Property ;
    rdfs:label 'Out Of Network' ;
    rdfs:comment 'The out_of_network_indicator bit from the SCTE-35 splice_insert() command. True indicates the splice point transitions to out-of-network content (e.g., local ad insertion); False indicates a return to in-network programming. Fundamental for MVPD local ad insertion compliance.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preRollDurationMs rdf:type rdf:Property ;
    rdfs:label 'Pre Roll Duration Ms' ;
    rdfs:comment 'The pre-roll duration in milliseconds between the time the SCTE-35 message is detected and the actual splice point. Allows downstream DAI systems and MVPDs sufficient lead time to prepare and insert the ad content before the avail window opens.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingErrorCode rdf:type rdf:Property ;
    rdfs:label 'Processing Error Code' ;
    rdfs:comment 'Proprietary error code assigned when processing_status is \'failed\'. Identifies the specific failure reason (e.g., CRC mismatch, invalid PTS, unsupported command type, descriptor parse error). Used for operational monitoring and SLA compliance reporting.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current processing lifecycle status of this SCTE-35 marker record in the Silver layer pipeline. \'received\' = ingested from transport stream; \'validated\' = passed SCTE-35 structural validation; \'processed\' = forwarded to DAI/MVPD systems; \'failed\' = processing error; \'skipped\' = intentionally bypassed (e.g., duplicate or test signal).' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programNumber rdf:type rdf:Property ;
    rdfs:label 'Program Number' ;
    rdfs:comment 'The MPEG-2 program_number (PAT/PMT) identifying the specific program within the transport stream to which this SCTE-35 message applies. Enables precise association of the splice event with the correct elementary stream in multi-programme multiplexes.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ptsTime rdf:type rdf:Property ;
    rdfs:label 'Pts Time' ;
    rdfs:comment 'The 33-bit Presentation Time Stamp (PTS) value in 90 kHz clock ticks at which the splice event is to occur in the MPEG-2 transport stream. Stored as BIGINT to accommodate the full 33-bit range. Fundamental for frame-accurate ad insertion by DAI systems and Akamai CDN delivery.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ptsTimeUtc rdf:type rdf:Property ;
    rdfs:label 'Pts Time Utc' ;
    rdfs:comment 'Wall-clock UTC timestamp derived from the PTS value after applying the PCR/PTS offset for the channel. Enables correlation of splice events with EPG schedules, ad trafficking records in Wide Orbit, and audience measurement windows in Nielsen.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:segmentationTypeCode rdf:type rdf:Property ;
    rdfs:label 'Segmentation Type Code' ;
    rdfs:comment 'Numeric segmentation_type_id from the SCTE-35 segmentation_descriptor (SCTE-104 descriptor table). Identifies the semantic purpose of the marker: e.g., 0x10 = Program Start, 0x11 = Program End, 0x20 = Chapter Start, 0x30 = Provider Advertisement Start, 0x34 = Distributor Advertisement Start. Critical for MVPD ad insertion compliance and blackout enforcement.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentationTypeLabel rdf:type rdf:Property ;
    rdfs:label 'Segmentation Type Label' ;
    rdfs:comment 'Human-readable label corresponding to the segmentation_type_id, derived from the SCTE-35 segmentation descriptor table (e.g., \'Provider Advertisement Start\', \'Program Blackout Override\', \'Chapter Start\'). Facilitates operational reporting and EPG reconciliation without requiring lookup joins.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentationUpidType rdf:type rdf:Property ;
    rdfs:label 'Segmentation Upid Type' ;
    rdfs:comment 'Numeric code identifying the type of the segmentation UPID carried in the segmentation_descriptor, per SCTE-35 Table 22. Common values: 0x01=URI, 0x03=Ad-ID, 0x08=ISAN, 0x09=TID, 0x0A=TI, 0x0C=MPU, 0x0E=ADS Information. Determines how the segmentation_upid_value should be interpreted.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentationUpidValue rdf:type rdf:Property ;
    rdfs:label 'Segmentation Upid Value' ;
    rdfs:comment 'The actual UPID value carried in the segmentation_descriptor, interpreted according to segmentation_upid_type. May contain an Ad-ID, ISAN, URI, or other content identifier. Used to link the splice event to content records in Dalet Galaxy MAM and rights records in Rightsline.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signalDetectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signal Detected Timestamp' ;
    rdfs:comment 'Wall-clock UTC timestamp at which the SCTE-35 splice_info_section was first detected and extracted from the transport stream by the playout or monitoring system. Represents the business event time of signal receipt. Used for pre-roll lead time calculation and SLA monitoring.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:spliceCommandType rdf:type rdf:Property ;
    rdfs:label 'Splice Command Type' ;
    rdfs:comment 'The SCTE-35 splice command type encoded in the splice_info_section. Determines the action to be taken by downstream DAI and playout systems. splice_insert signals a direct ad avail; time_signal carries segmentation descriptors; bandwidth_reservation reserves capacity. [ENUM-REF-CANDIDATE: splice_null|splice_insert|time_signal|bandwidth_reservation|private_command — promote to reference product if additional vendor-specific types are required]' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spliceEventNumber rdf:type rdf:Property ;
    rdfs:label 'Splice Event Number' ;
    rdfs:comment 'Unique 32-bit splice_event_id as defined in the SCTE-35 splice_insert() command structure. Identifies the specific splice event within the transport stream and is used by Dynamic Ad Insertion (DAI) systems to correlate splice-in and splice-out pairs.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spliceImmediate rdf:type rdf:Property ;
    rdfs:label 'Splice Immediate' ;
    rdfs:comment 'Indicates whether the splice should occur immediately upon receipt of the SCTE-35 message (True) rather than at the specified PTS time (False). When True, the pts_time field is not applicable. Used for emergency override and live event boundary signalling.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spliceInsertType rdf:type rdf:Property ;
    rdfs:label 'Splice Insert Type' ;
    rdfs:comment 'Indicates whether this splice_insert command is a splice-out (entering an ad avail or blackout) or splice-in (returning to network programming). Applicable when splice_command_type is splice_insert. Used by DAI systems to bracket the ad pod window.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'The 12-bit tier field from the SCTE-35 splice_info_section, used to address specific MVPDs or distribution tiers. A value of 0xFFF indicates the message applies to all tiers. Enables selective ad insertion targeting for specific distribution partners.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportStreamNumber rdf:type rdf:Property ;
    rdfs:label 'Transport Stream Number' ;
    rdfs:comment 'The MPEG-2 transport stream identifier in which this SCTE-35 message was embedded. Used to correlate the splice event with the specific multiplex or virtual channel carrying the broadcast signal, particularly relevant for DVB and ATSC multi-programme transport streams.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uniqueProgramCode rdf:type rdf:Property ;
    rdfs:label 'Unique Program Code' ;
    rdfs:comment 'The unique_program_id field from the SCTE-35 splice_insert() command, identifying the program associated with this splice event. Used by MVPDs and DAI systems to associate the avail with a specific program for audience targeting and ad campaign attribution.' ;
    rdfs:domain ind:ScteMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:simulcastConfigId rdf:type rdf:Property ;
    rdfs:label 'Simulcast Config Id' ;
    rdfs:comment 'Unique surrogate identifier for the simulcast configuration record. Primary key for this entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originBroadcastFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origin Broadcast Facility Id' ;
    rdfs:comment 'Foreign key linking to technology.broadcast_facility. Business justification: Simulcast originates from specific facility - required for signal routing, redundancy planning, facility failover configuration, and multi-platform distribution. Role prefix \'origin_\' distinguishes fr' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastFacility .

ind:primarySimulcastBackupSourceChannelId rdf:type rdf:Property ;
    rdfs:label 'Primary Simulcast Backup Source Channel Id' ;
    rdfs:comment 'Reference to the backup or secondary source channel used by Ericsson MediaFirst failover automation when the primary source channel becomes unavailable. Supports broadcast continuity and SLA compliance.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:simulcastPartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Simulcast Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Simulcast distribution agreements are with specific partners (cable operators, streaming platforms, syndication partners). Critical for multi-platform distribution tracking, partner SLA compliance, an' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:sourceChannelId rdf:type rdf:Property ;
    rdfs:label 'Source Channel Id' ;
    rdfs:comment 'Reference to the originating linear broadcast channel whose feed is being simulcast to one or more target channels or platforms. Drives Ericsson MediaFirst multi-feed automation as the master playout source.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:targetChannelId rdf:type rdf:Property ;
    rdfs:label 'Target Channel Id' ;
    rdfs:comment 'Reference to the destination channel or platform that receives the simulcast feed from the source channel. May represent a linear channel, OTT platform feed, HD/SD variant, or secondary distribution outlet.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:technicalDirectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Technical Director Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Simulcast configurations are managed by technical operations/engineering staff responsible for multi-platform distribution. Broadcast engineering workflow requires tracking responsible technical direc' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adPodSubstitution rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Substitution' ;
    rdfs:comment 'Indicates whether the ad pods (groups of ads in a break) from the source linear feed are substituted with alternative ad content on the target simulcast feed. Distinct from DAI — covers cases where static alternate ad content replaces source pods without dynamic targeting.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioDescriptionPassthrough rdf:type rdf:Property ;
    rdfs:label 'Audio Description Passthrough' ;
    rdfs:comment 'Indicates whether the audio description (video description) secondary audio track is passed through from the source to the target simulcast feed. Required for FCC accessibility compliance for visually impaired audiences on qualifying broadcast and MVPD platforms.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioProfileCode rdf:type rdf:Property ;
    rdfs:label 'Audio Profile Code' ;
    rdfs:comment 'Reference to the audio encoding and channel configuration profile applied to the target simulcast feed (e.g., stereo, 5.1 surround, Dolby Atmos, audio description track). Ensures correct audio mapping from source to target platform.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutEnforced rdf:type rdf:Property ;
    rdfs:label 'Blackout Enforced' ;
    rdfs:comment 'Indicates whether geographic broadcast blackout restrictions are enforced on the target simulcast feed. When true, blackout rules (e.g., sports rights geographic restrictions) are applied to suppress content in restricted territories on the target platform.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdnOriginPath rdf:type rdf:Property ;
    rdfs:label 'Cdn Origin Path' ;
    rdfs:comment 'The Akamai CDN origin ingest path or stream key for the target simulcast feed. Used to route the encoded simulcast stream from Ericsson MediaFirst playout to the CDN origin for OTT and digital distribution.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionPassthrough rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Passthrough' ;
    rdfs:comment 'Indicates whether closed caption data from the source channel feed is passed through to the target simulcast feed. Required for FCC accessibility compliance on all broadcast and MVPD distribution platforms.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configCode rdf:type rdf:Property ;
    rdfs:label 'Config Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this simulcast configuration, used in Ericsson MediaFirst automation rules, runsheets, and operational documentation. Unique across all active configurations.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configDescription rdf:type rdf:Property ;
    rdfs:label 'Config Description' ;
    rdfs:comment 'Free-text operational description of the simulcast configuration, including business rationale, special handling instructions, and notes for scheduling and playout operations teams.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configName rdf:type rdf:Property ;
    rdfs:label 'Config Name' ;
    rdfs:comment 'Human-readable descriptive name for the simulcast configuration (e.g., \'CNN HD to CNN SD Full-Feed\', \'Linear to OTT Time-Shifted +1hr\'). Used in EPG management and scheduling operations.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPlatform rdf:type rdf:Property ;
    rdfs:label 'Distribution Platform' ;
    rdfs:comment 'The delivery platform type of the target channel or feed. Distinguishes linear broadcast from OTT (Over-The-Top), MVPD (Multichannel Video Programming Distributor), vMVPD (Virtual MVPD), FAST (Free Ad-Supported Streaming Television), cable, satellite, IPTV, or web delivery. [ENUM-REF-CANDIDATE: linear|ott|mvpd|vmvpd|fast|cable|satellite|iptv|web — promote to reference product]' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgSyncEnabled rdf:type rdf:Property ;
    rdfs:label 'Epg Sync Enabled' ;
    rdfs:comment 'Indicates whether the Electronic Program Guide (EPG) metadata from the source channel schedule is automatically synchronized to the target simulcast channel\'s EPG. When true, program titles, descriptions, and ratings are mirrored to the target channel grid.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:graphicsPassthrough rdf:type rdf:Property ;
    rdfs:label 'Graphics Passthrough' ;
    rdfs:comment 'Indicates whether on-screen graphics, lower-thirds, and channel branding overlays from the source channel are passed through to the target simulcast feed. When false, the target feed may apply its own branding or suppress source graphics.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediafirstConfigRef rdf:type rdf:Property ;
    rdfs:label 'Mediafirst Config Ref' ;
    rdfs:comment 'The external configuration reference identifier assigned by Ericsson MediaFirst playout automation system to this simulcast configuration. Used for reconciliation between the data lakehouse Silver Layer and the operational playout system.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Rights Territory Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code identifying the geographic territory in which this simulcast configuration is licensed to operate. Enforces windowing and holdback obligations managed in Rightsline.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scte35CuePassthrough rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue Passthrough' ;
    rdfs:comment 'Indicates whether SCTE-35 digital program insertion cue markers from the source channel are passed through to the target simulcast feed. When true, ad break triggers and blackout signals are propagated to the target. Critical for DAI (Dynamic Ad Insertion) on OTT platforms.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:simulcastConfigStatus rdf:type rdf:Property ;
    rdfs:label 'Simulcast Config Status' ;
    rdfs:comment 'Current lifecycle state of the simulcast configuration record. Active configurations are processed by Ericsson MediaFirst automation. Suspended configurations are temporarily halted (e.g., rights blackout). Draft configurations are under review prior to activation.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simulcastType rdf:type rdf:Property ;
    rdfs:label 'Simulcast Type' ;
    rdfs:comment 'Classification of the simulcast relationship: full_feed (identical content and timing), partial (selected programs only), time_shifted (offset delay applied), simulcast_only (live events only), ad_substituted (DAI replaces linear ad pods on target). Drives automation logic in Ericsson MediaFirst.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeOffsetSeconds rdf:type rdf:Property ;
    rdfs:label 'Time Offset Seconds' ;
    rdfs:comment 'The delay in seconds applied to the target feed relative to the source channel. Zero for true simultaneous simulcast. Positive values indicate a time-shifted delay (e.g., +3600 for a +1 hour catch-up feed). Used by Ericsson MediaFirst to schedule playout offset.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:videoProfileCode rdf:type rdf:Property ;
    rdfs:label 'Video Profile Code' ;
    rdfs:comment 'Reference to the video encoding and resolution profile applied to the target simulcast feed (e.g., HD 1080i, SD 576p, UHD 4K, HDR10). Drives transcode and format conversion settings in Ericsson MediaFirst and Akamai CDN delivery.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:watermarkEnabled rdf:type rdf:Property ;
    rdfs:label 'Watermark Enabled' ;
    rdfs:comment 'Indicates whether a forensic or visible watermark is applied to the target simulcast feed for content protection, piracy detection, and rights enforcement tracking. Supports MPA anti-piracy compliance.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:churnEventId rdf:type rdf:Property ;
    rdfs:label 'Churn Event Id' ;
    rdfs:comment 'Unique identifier for the subscriber churn event record.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastViewedTitleId rdf:type rdf:Property ;
    rdfs:label 'Last Viewed Title Id' ;
    rdfs:comment 'Foreign key linking to content.title. Business justification: Churn analysis tracks last content engagement to identify content gaps and inform win-back campaigns. Critical for retention analytics, content investment decisions, and personalized re-engagement off' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:retentionAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Retention Agent Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Retention specialists (workforce) are assigned to at-risk subscribers for win-back campaigns. Critical for churn prevention workflow tracking, agent performance metrics, and retention campaign ROI ana' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:winBackOfferId rdf:type rdf:Property ;
    rdfs:label 'Win Back Offer Id' ;
    rdfs:comment 'Reference to the specific retention or win-back offer that was presented to the subscriber. Null if no offer was presented.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WinBackOffer .

ind:autoRenewDisabledDate rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Disabled Date' ;
    rdfs:comment 'The date when the subscriber disabled auto-renewal for their subscription. Null if auto-renewal was never disabled. Used to identify planned churn versus reactive churn.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationChannel rdf:type rdf:Property ;
    rdfs:label 'Cancellation Channel' ;
    rdfs:comment 'The interface or channel through which the cancellation was initiated. Supports analysis of churn patterns by customer touchpoint. [ENUM-REF-CANDIDATE: web_self_service|mobile_app|customer_care|email|chat|ivr|mvpd_drop|system_automated — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Description' ;
    rdfs:comment 'Free-text description or additional details provided by the subscriber explaining the reason for cancellation. Supports qualitative churn analysis.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Flag' ;
    rdfs:comment 'Boolean indicator of whether the subscriber exercised CCPA opt-out rights regarding data sale or sharing. Used for privacy compliance and marketing eligibility.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:churnPredictionScore rdf:type rdf:Property ;
    rdfs:label 'Churn Prediction Score' ;
    rdfs:comment 'The machine learning model-generated churn risk score that was assigned to the subscriber prior to the churn event. Range 0.0000 to 1.0000, where higher values indicate higher churn risk. Used for model validation and predictive accuracy assessment.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:churnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Churn Timestamp' ;
    rdfs:comment 'The exact date and time when the subscriber cancellation or lapse event occurred. This is the business event timestamp representing when the subscriber relationship ended.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:churnType rdf:type rdf:Property ;
    rdfs:label 'Churn Type' ;
    rdfs:comment 'Classification of the churn event based on the nature of cancellation. Voluntary indicates subscriber-initiated cancellation, involuntary indicates business-initiated termination, payment failure indicates cancellation due to billing issues.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorServiceMentionedFlag rdf:type rdf:Property ;
    rdfs:label 'Competitor Service Mentioned Flag' ;
    rdfs:comment 'Boolean indicator of whether the subscriber mentioned switching to a competitor service during the cancellation process. Used for competitive intelligence and market positioning analysis.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerCareContactCount rdf:type rdf:Property ;
    rdfs:label 'Customer Care Contact Count' ;
    rdfs:comment 'The number of customer care interactions the subscriber had in the 30 days prior to churn. Used to identify service quality issues and early warning signals.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysSinceLastViewing rdf:type rdf:Property ;
    rdfs:label 'Days Since Last Viewing' ;
    rdfs:comment 'The number of days between the last viewing activity and the churn event. Used for engagement-based churn prediction models.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceCountAtChurn rdf:type rdf:Property ;
    rdfs:label 'Device Count At Churn' ;
    rdfs:comment 'The number of registered devices associated with the subscriber at the time of churn. Used for multi-device engagement analysis.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalAccessDate rdf:type rdf:Property ;
    rdfs:label 'Final Access Date' ;
    rdfs:comment 'The last date the subscriber had active access to content and services. May differ from churn_timestamp due to grace periods or paid-through dates.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprDataDeletionRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Deletion Requested Flag' ;
    rdfs:comment 'Boolean indicator of whether the subscriber requested deletion of their personal data under GDPR right to erasure at the time of churn. Used for privacy compliance tracking.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastViewingDate rdf:type rdf:Property ;
    rdfs:label 'Last Viewing Date' ;
    rdfs:comment 'The date of the subscribers last content viewing activity before churn. Used to identify engagement drop-off patterns and at-risk subscriber signals.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentalControlEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Control Enabled Flag' ;
    rdfs:comment 'Boolean indicator of whether parental controls were enabled on the subscription at the time of churn. Used for family-oriented subscriber segmentation and churn analysis.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentFailureCount rdf:type rdf:Property ;
    rdfs:label 'Payment Failure Count' ;
    rdfs:comment 'The number of consecutive payment failures that occurred before the churn event. Used to identify involuntary churn patterns and dunning effectiveness.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalDiscountActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Discount Active Flag' ;
    rdfs:comment 'Boolean indicator of whether the subscriber had an active promotional discount at the time of churn. Used to analyze price sensitivity and promotional effectiveness.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reactivationEligibilityDate rdf:type rdf:Property ;
    rdfs:label 'Reactivation Eligibility Date' ;
    rdfs:comment 'The date when the churned subscriber becomes eligible for reactivation campaigns or promotional offers. Used for win-back campaign targeting and timing.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionTenureMonths rdf:type rdf:Property ;
    rdfs:label 'Subscription Tenure Months' ;
    rdfs:comment 'The total number of months the subscriber maintained an active subscription before churning. Used for cohort analysis and LTV (Lifetime Value) calculations.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLifetimeRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Lifetime Revenue' ;
    rdfs:comment 'The cumulative revenue generated from this subscriber across their entire subscription tenure. Used for LTV (Lifetime Value) analysis and churn impact assessment.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:winBackOfferAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Win Back Offer Accepted Flag' ;
    rdfs:comment 'Boolean indicator of whether the subscriber accepted the win-back offer. True indicates acceptance and retention, False indicates rejection and churn completion. Null if no offer was presented.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:winBackOfferPresentedFlag rdf:type rdf:Property ;
    rdfs:label 'Win Back Offer Presented Flag' ;
    rdfs:comment 'Boolean indicator of whether a retention or win-back offer was presented to the subscriber during the cancellation process. True indicates an offer was made, False indicates no offer was presented.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Communication Preference Id' ;
    rdfs:comment 'Unique identifier for the communication preference record.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aepSegmentId rdf:type rdf:Property ;
    rdfs:label 'Aep Segment Id' ;
    rdfs:comment 'External identifier linking this preference to a specific audience segment in Adobe Experience Platform for personalization and targeting.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:updatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Updated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Customer service representatives update communication preferences during support calls. Required for customer care quality assurance, preference change audit trails, and agent training on privacy comp' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aepJourneySuppressionFlag rdf:type rdf:Property ;
    rdfs:label 'Aep Journey Suppression Flag' ;
    rdfs:comment 'Indicates whether this subscriber should be suppressed from Adobe Experience Platform automated journey orchestration for this preference type.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentIpAddress rdf:type rdf:Property ;
    rdfs:label 'Consent Ip Address' ;
    rdfs:comment 'IP address from which the subscriber provided or updated this communication preference, used for audit and compliance verification.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'Channel or touchpoint through which the subscriber provided or updated this communication preference (web signup, mobile app, customer service interaction, account creation, preference center, or third-party integration).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentUserAgent rdf:type rdf:Property ;
    rdfs:label 'Consent User Agent' ;
    rdfs:comment 'Browser or application user agent string captured when the subscriber provided or updated this communication preference, used for audit and compliance verification.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInConfirmed rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmed' ;
    rdfs:comment 'Indicates whether the subscriber has confirmed their opt-in through a double opt-in verification process (e.g., email confirmation link).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Timestamp' ;
    rdfs:comment 'Date and time when the subscriber confirmed their opt-in through the double opt-in verification process, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Indicates whether the subscriber has opted in to receive email communications for this preference type.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyPreference rdf:type rdf:Property ;
    rdfs:label 'Frequency Preference' ;
    rdfs:comment 'Subscriber\'s preferred frequency for receiving communications of this type (daily, weekly, biweekly, monthly, quarterly, or as needed).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inAppMessagingOptIn rdf:type rdf:Property ;
    rdfs:label 'In App Messaging Opt In' ;
    rdfs:comment 'Indicates whether the subscriber has opted in to receive in-app messages within the OTT (Over-The-Top) or SVOD (Subscription Video On Demand) application for this preference type.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCommunicationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Communication Sent Timestamp' ;
    rdfs:comment 'Date and time when the last communication of this preference type was successfully sent to the subscriber, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mobilePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone Number' ;
    rdfs:comment 'The mobile phone number to which SMS and push notifications should be sent when those channels are opted in.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Postal Address Line1' ;
    rdfs:comment 'First line of the postal mailing address for physical mail communications when postal mail opt-in is enabled.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Postal Address Line2' ;
    rdfs:comment 'Second line of the postal mailing address (apartment, suite, unit number) for physical mail communications.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCity rdf:type rdf:Property ;
    rdfs:label 'Postal City' ;
    rdfs:comment 'City name for the postal mailing address.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCountryCode rdf:type rdf:Property ;
    rdfs:label 'Postal Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the postal mailing address (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalMailOptIn rdf:type rdf:Property ;
    rdfs:label 'Postal Mail Opt In' ;
    rdfs:comment 'Indicates whether the subscriber has opted in to receive physical postal mail communications for this preference type.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalStateProvince rdf:type rdf:Property ;
    rdfs:label 'Postal State Province' ;
    rdfs:comment 'State or province code for the postal mailing address.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle status of this communication preference record (active and in use, inactive, pending verification through double opt-in, or suspended due to bounce or compliance issue).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceType rdf:type rdf:Property ;
    rdfs:label 'Preference Type' ;
    rdfs:comment 'Category of communication this preference applies to (marketing campaigns, transactional notifications, service updates, editorial content, promotional offers, or administrative messages).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactTime rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Time' ;
    rdfs:comment 'Time of day the subscriber prefers to receive communications (morning, afternoon, evening, night, or anytime).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code (optionally with ISO 3166-1 alpha-2 country code) indicating the subscriber\'s preferred language for communications (e.g., en, en-US, es, fr-CA).' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationOptIn rdf:type rdf:Property ;
    rdfs:label 'Push Notification Opt In' ;
    rdfs:comment 'Indicates whether the subscriber has opted in to receive push notifications on registered devices for this preference type.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smsOptIn rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In' ;
    rdfs:comment 'Indicates whether the subscriber has opted in to receive SMS text messages for this preference type.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unsubscribeFlag rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Flag' ;
    rdfs:comment 'Indicates whether the subscriber has globally unsubscribed from all communications of this preference type across all channels.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unsubscribeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Timestamp' ;
    rdfs:comment 'Date and time when the subscriber unsubscribed from this communication preference type, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviceRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Device Registration Id' ;
    rdfs:comment 'Unique identifier for the device registration record. Primary key.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceRegistration .

ind:adTrackingConsent rdf:type rdf:Property ;
    rdfs:label 'Ad Tracking Consent' ;
    rdfs:comment 'Indicates whether the user has consented to advertising tracking on this device. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:advertisingDeviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Advertising Device Identifier' ;
    rdfs:comment 'Device advertising identifier (IDFA for iOS, AAID for Android). Used for targeted advertising and attribution tracking. Subject to user consent per GDPR and CCPA.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioCodecSupport rdf:type rdf:Property ;
    rdfs:label 'Audio Codec Support' ;
    rdfs:comment 'Comma-separated list of audio codecs supported by the device (e.g., AAC, Dolby Digital, Dolby Atmos, DTS). Determines audio track selection.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deregistrationReason rdf:type rdf:Property ;
    rdfs:label 'Deregistration Reason' ;
    rdfs:comment 'Reason why the device was deregistered. Used for churn analysis and fraud investigation. [ENUM-REF-CANDIDATE: user_initiated|account_closure|fraud_detected|device_limit_exceeded|inactivity|admin_action|device_lost_stolen — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deregistrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deregistration Timestamp' ;
    rdfs:comment 'Date and time when the device was deregistered or removed from the subscriber account. Null if device is still registered.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviceFingerprint rdf:type rdf:Property ;
    rdfs:label 'Device Fingerprint' ;
    rdfs:comment 'Unique cryptographic hash or identifier that uniquely identifies the physical device. Used for device authentication and fraud prevention.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceLimitEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Device Limit Enforcement Flag' ;
    rdfs:comment 'Indicates whether this device counts toward the subscribers per-account device limit. Used to exempt customer service test devices or promotional devices.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceNickname rdf:type rdf:Property ;
    rdfs:label 'Device Nickname' ;
    rdfs:comment 'User-assigned friendly name for the device (e.g., Living Room TV, Johns iPhone). Improves device management user experience.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Drm Certificate Reference' ;
    rdfs:comment 'Reference to the DRM device certificate used for secure content decryption. Required for protected content playback.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmSecurityLevel rdf:type rdf:Property ;
    rdfs:label 'Drm Security Level' ;
    rdfs:comment 'Security level of the DRM implementation on the device. Determines maximum content quality and protection level (e.g., Widevine L1 for HD, L3 for SD).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Calculated fraud risk score for this device registration (0.00 to 100.00). Higher scores indicate higher likelihood of fraudulent activity.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicLocation rdf:type rdf:Property ;
    rdfs:label 'Geographic Location' ;
    rdfs:comment 'Geographic location derived from IP address or device GPS (country, region, city). Used for content windowing and blackout restrictions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdrSupport rdf:type rdf:Property ;
    rdfs:label 'Hdr Support' ;
    rdfs:comment 'Indicates whether the device supports HDR video playback (HDR10, Dolby Vision, HLG). Enables premium content delivery.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Active Timestamp' ;
    rdfs:comment 'Date and time of the most recent authenticated activity from this device. Used to identify inactive devices and enforce inactivity policies.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxDownloadCount rdf:type rdf:Property ;
    rdfs:label 'Max Download Count' ;
    rdfs:comment 'Maximum number of titles that can be downloaded for offline viewing on this device. Enforced per subscription plan terms.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxResolutionSupported rdf:type rdf:Property ;
    rdfs:label 'Max Resolution Supported' ;
    rdfs:comment 'Highest video resolution the device can decode and display. Used for adaptive bitrate streaming (ABR) profile selection.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offlineDownloadEnabled rdf:type rdf:Property ;
    rdfs:label 'Offline Download Enabled' ;
    rdfs:comment 'Indicates whether this device is authorized for offline content downloads. Subject to plan entitlements and DRM restrictions.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalControlPinHash rdf:type rdf:Property ;
    rdfs:label 'Parental Control Pin Hash' ;
    rdfs:comment 'Cryptographic hash of the parental control PIN. Used to authenticate access to restricted content without storing the PIN in plaintext.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationToken rdf:type rdf:Property ;
    rdfs:label 'Push Notification Token' ;
    rdfs:comment 'Device-specific token for sending push notifications (APNS for iOS, FCM for Android). Used for engagement campaigns and service alerts.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationSource rdf:type rdf:Property ;
    rdfs:label 'Registration Source' ;
    rdfs:comment 'Channel or interface through which the device was registered. Used for registration workflow analytics and fraud detection.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the device registration. Determines whether the device is authorized for playback.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Timestamp' ;
    rdfs:comment 'Date and time when the device was first registered by the subscriber. Follows ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entitlementId rdf:type rdf:Property ;
    rdfs:label 'Entitlement Id' ;
    rdfs:comment 'Unique identifier for the entitlement record. Primary key.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelPackageId rdf:type rdf:Property ;
    rdfs:label 'Channel Package Id' ;
    rdfs:comment 'Reference to the channel package or bundle that this entitlement provides access to.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:vodLibraryId rdf:type rdf:Property ;
    rdfs:label 'Vod Library Id' ;
    rdfs:comment 'Reference to the VOD library collection that this entitlement grants access to.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VodLibrary .

ind:accessLevel rdf:type rdf:Property ;
    rdfs:label 'Access Level' ;
    rdfs:comment 'Degree of access granted by this entitlement: full (complete access), preview (sample or trailer only), limited (restricted features or duration), or premium (enhanced quality or early access).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adFree rdf:type rdf:Property ;
    rdfs:label 'Ad Free' ;
    rdfs:comment 'Indicates whether this entitlement provides ad-free viewing experience. False indicates AVOD (Advertising-Supported Video On Demand) model applies.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationCount rdf:type rdf:Property ;
    rdfs:label 'Authorization Count' ;
    rdfs:comment 'Total number of playback authorization requests processed for this entitlement since activation.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenew rdf:type rdf:Property ;
    rdfs:label 'Auto Renew' ;
    rdfs:comment 'Indicates whether this entitlement will automatically renew upon expiration based on the underlying subscription plan.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutExempt rdf:type rdf:Property ;
    rdfs:label 'Blackout Exempt' ;
    rdfs:comment 'Indicates whether this entitlement is exempt from geographic blackout restrictions typically applied to live sports or regional content.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFlags rdf:type rdf:Property ;
    rdfs:label 'Compliance Flags' ;
    rdfs:comment 'Comma-separated list of compliance requirements applicable to this entitlement (e.g., \'GDPR\', \'CCPA\', \'COPPA\'). Used to enforce data privacy and regulatory obligations.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceLimit rdf:type rdf:Property ;
    rdfs:label 'Device Limit' ;
    rdfs:comment 'Maximum number of concurrent devices that can use this entitlement. Null indicates no device limit.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downloadEnabled rdf:type rdf:Property ;
    rdfs:label 'Download Enabled' ;
    rdfs:comment 'Indicates whether offline download is permitted for content under this entitlement.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyAccessEnabled rdf:type rdf:Property ;
    rdfs:label 'Early Access Enabled' ;
    rdfs:comment 'Indicates whether this entitlement grants early access to content before general release.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Entitlement Status' ;
    rdfs:comment 'Current lifecycle status of the entitlement: active (currently valid), suspended (temporarily disabled), expired (past end date), revoked (administratively cancelled), or pending (awaiting activation).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementType rdf:type rdf:Property ;
    rdfs:label 'Entitlement Type' ;
    rdfs:comment 'Classification of the entitlement based on how it was granted: subscription (standard plan), promotional (marketing grant), bundle (package deal), addon (premium add-on), mvpd_carriage (Multichannel Video Programming Distributor carriage agreement), or trial (free trial period).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalEntitlementReference rdf:type rdf:Property ;
    rdfs:label 'External Entitlement Reference' ;
    rdfs:comment 'Unique identifier for this entitlement in the originating external system (e.g., Zuora subscription ID, MVPD authorization token).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this entitlement is valid. Empty indicates no geographic restriction.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantReason rdf:type rdf:Property ;
    rdfs:label 'Grant Reason' ;
    rdfs:comment 'Business justification or reason code for why this entitlement was granted (e.g., \'Annual Subscription\', \'Promotional Campaign Q4-2024\', \'Customer Retention Offer\', \'MVPD Carriage Agreement\').' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuthorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Authorization Timestamp' ;
    rdfs:comment 'Timestamp of the most recent playback authorization request that validated this entitlement at the CDN/DRM layer.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parentalControlLevel rdf:type rdf:Property ;
    rdfs:label 'Parental Control Level' ;
    rdfs:comment 'Maximum content rating level accessible under this entitlement based on parental control settings. Follows Motion Picture Association (MPA) and TV Parental Guidelines ratings. [ENUM-REF-CANDIDATE: none|g|pg|pg13|r|nc17|tv_y|tv_y7|tv_g|tv_pg|tv_14|tv_ma — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityTier rdf:type rdf:Property ;
    rdfs:label 'Quality Tier' ;
    rdfs:comment 'Maximum video quality level allowed by this entitlement: sd (standard definition), hd (high definition 1080p), 4k (ultra high definition), or 8k (8K resolution).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Reason why the entitlement was revoked or suspended, if applicable (e.g., \'Payment Failure\', \'Terms of Service Violation\', \'Subscriber Request\', \'Rights Expiration\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revokedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Revoked Timestamp' ;
    rdfs:comment 'Timestamp when the entitlement was permanently revoked, if applicable.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:suspendedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Suspended Timestamp' ;
    rdfs:comment 'Timestamp when the entitlement was suspended, if applicable.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trialEntitlement rdf:type rdf:Property ;
    rdfs:label 'Trial Entitlement' ;
    rdfs:comment 'Indicates whether this is a trial entitlement granted as part of a free trial period.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primarySubscriberId rdf:type rdf:Property ;
    rdfs:label 'Primary Subscriber Id' ;
    rdfs:comment 'Reference to the primary account holder or subscriber who owns this household account. This subscriber has administrative privileges for the household.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:accountCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Account Created Date' ;
    rdfs:comment 'Date when the household account was first created in the system. Used for tenure analysis and customer lifetime value (LTV) calculations.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:averageRevenuePerUser rdf:type rdf:Property ;
    rdfs:label 'Average Revenue Per User' ;
    rdfs:comment 'Average monthly revenue generated by this household, calculated as total revenue divided by number of active months. Key metric for household value assessment.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the household has consented to sharing their viewing data with third parties for analytics and advertising purposes. Required for privacy compliance.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:householdName rdf:type rdf:Property ;
    rdfs:label 'Household Name' ;
    rdfs:comment 'Human-readable name or label for the household, typically derived from the primary account holder\'s name or a custom household designation.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdStatus rdf:type rdf:Property ;
    rdfs:label 'Household Status' ;
    rdfs:comment 'Current lifecycle status of the household account. Determines access rights and billing state.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdType rdf:type rdf:Property ;
    rdfs:label 'Household Type' ;
    rdfs:comment 'Classification of the household based on its composition and purpose. Determines applicable service tier rules and entitlement models.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO 639-1 language code representing the household\'s preferred content and interface language. Used for content recommendations and UI localization.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Login Timestamp' ;
    rdfs:comment 'Timestamp of the most recent authentication event for any member of this household. Used for engagement tracking and inactive account identification.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lifetimeValue rdf:type rdf:Property ;
    rdfs:label 'Lifetime Value' ;
    rdfs:comment 'Total revenue generated by this household since account creation, including subscription fees, transactional purchases (TVOD), and advertising revenue attribution. Used for customer segmentation and retention investment decisions.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the household has consented to receive marketing communications and promotional offers. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxContentRating rdf:type rdf:Property ;
    rdfs:label 'Max Content Rating' ;
    rdfs:comment 'Highest content rating level allowed for viewing in this household when parental controls are active. Based on Motion Picture Association (MPA) and TV Parental Guidelines ratings. [ENUM-REF-CANDIDATE: G|PG|PG-13|R|NC-17|TV-Y|TV-Y7|TV-G|TV-PG|TV-14|TV-MA — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxRegisteredDevices rdf:type rdf:Property ;
    rdfs:label 'Max Registered Devices' ;
    rdfs:comment 'Maximum number of devices that can be registered to this household account. Used to enforce device limits per service tier.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mvpdAffiliation rdf:type rdf:Property ;
    rdfs:label 'Mvpd Affiliation' ;
    rdfs:comment 'Name of the MVPD or vMVPD provider if this household accesses content through a cable/satellite/virtual provider authentication. Used for TV Everywhere entitlement validation.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalControlPin rdf:type rdf:Property ;
    rdfs:label 'Parental Control Pin' ;
    rdfs:comment 'Encrypted PIN code required to access age-restricted content when parental controls are enabled. Stored in hashed format for security.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Number of registered members or subscribers within this household. Used for family plan eligibility and simultaneous stream limit enforcement.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriptionEndDate rdf:type rdf:Property ;
    rdfs:label 'Subscription End Date' ;
    rdfs:comment 'Date when the household\'s current subscription is scheduled to end or renew. Null for active auto-renewing subscriptions.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionStartDate rdf:type rdf:Property ;
    rdfs:label 'Subscription Start Date' ;
    rdfs:comment 'Date when the household\'s current paid subscription began. May differ from account creation date if there was a trial period or reactivation.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mvpdAffiliationId rdf:type rdf:Property ;
    rdfs:label 'Mvpd Affiliation Id' ;
    rdfs:comment 'Unique identifier for the MVPD affiliation record. Primary key.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affiliationChannel rdf:type rdf:Property ;
    rdfs:label 'Affiliation Channel' ;
    rdfs:comment 'The platform or device type through which the subscriber first authenticated with the MVPD provider.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliationEndDate rdf:type rdf:Property ;
    rdfs:label 'Affiliation End Date' ;
    rdfs:comment 'The date when the MVPD affiliation ended or is scheduled to end. Null for active affiliations.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affiliationSource rdf:type rdf:Property ;
    rdfs:label 'Affiliation Source' ;
    rdfs:comment 'The method by which the MVPD affiliation was established (direct subscriber login, single sign-on, API provisioning from MVPD, bulk import, or partner integration).' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliationStartDate rdf:type rdf:Property ;
    rdfs:label 'Affiliation Start Date' ;
    rdfs:comment 'The date when the MVPD affiliation became active. Represents when the subscriber first authenticated through the MVPD provider.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affiliationStatus rdf:type rdf:Property ;
    rdfs:label 'Affiliation Status' ;
    rdfs:comment 'Current lifecycle status of the MVPD affiliation. Active indicates valid authentication; expired or revoked indicates the subscriber must re-authenticate.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationFailureCount rdf:type rdf:Property ;
    rdfs:label 'Authentication Failure Count' ;
    rdfs:comment 'The cumulative number of failed authentication attempts since the last successful authentication. Reset to zero on successful authentication.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authenticationFailureReason rdf:type rdf:Property ;
    rdfs:label 'Authentication Failure Reason' ;
    rdfs:comment 'The reason code or message for the most recent authentication failure (e.g., invalid credentials, account suspended, service unavailable).' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'The technical authentication protocol used for TV Everywhere login (SAML 2.0, OAuth 2.0, OpenID Connect, or proprietary MVPD method).' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationToken rdf:type rdf:Property ;
    rdfs:label 'Authentication Token' ;
    rdfs:comment 'The encrypted or hashed authentication token issued by the MVPD provider during TV Everywhere login. Used for session validation and entitlement checks.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled Flag' ;
    rdfs:comment 'Indicates whether the MVPD affiliation is set to automatically renew authentication tokens. True if auto-renewal is enabled.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Opt Out Flag' ;
    rdfs:comment 'Indicates whether the subscriber has opted out of data sharing with the MVPD provider. True if the subscriber has opted out.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementPackageCode rdf:type rdf:Property ;
    rdfs:label 'Entitlement Package Code' ;
    rdfs:comment 'The code representing the subscriber\'s entitlement package from the MVPD (e.g., basic, premium, sports tier). Determines which content the subscriber can access.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementPackageName rdf:type rdf:Property ;
    rdfs:label 'Entitlement Package Name' ;
    rdfs:comment 'Human-readable name of the entitlement package (e.g., Premium Plus, Sports Bundle, Basic Cable).' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction Code' ;
    rdfs:comment 'Code representing geographic or blackout restrictions imposed by the MVPD provider (e.g., DMA code, zip code range). Used to enforce regional content availability.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeDmaCode rdf:type rdf:Property ;
    rdfs:label 'Home Dma Code' ;
    rdfs:comment 'The Nielsen DMA code representing the subscriber\'s home market as reported by the MVPD provider. Used for local content and blackout enforcement.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuthenticationFailureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Authentication Failure Timestamp' ;
    rdfs:comment 'The timestamp of the most recent failed authentication attempt with the MVPD provider.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastAuthenticationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Authentication Timestamp' ;
    rdfs:comment 'The timestamp of the most recent successful authentication event with the MVPD provider.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mvpdAffiliateIdentifier rdf:type rdf:Property ;
    rdfs:label 'Mvpd Affiliate Identifier' ;
    rdfs:comment 'The unique subscriber identifier assigned by the MVPD provider for TV Everywhere authentication. This is the external identifier used in SAML assertions and OAuth flows.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextVerificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Verification Due Date' ;
    rdfs:comment 'The date when the next verification check with the MVPD provider is due. Calculated from last_verified_timestamp plus verification_frequency_days.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:privacyConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Privacy Consent Flag' ;
    rdfs:comment 'Indicates whether the subscriber has provided consent for sharing viewing data with the MVPD provider. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyConsentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Privacy Consent Timestamp' ;
    rdfs:comment 'The timestamp when the subscriber provided or updated their privacy consent for MVPD data sharing.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:verificationFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Verification Frequency Days' ;
    rdfs:comment 'The number of days between required re-verification checks with the MVPD provider. Typically 30, 60, or 90 days depending on provider policy.' ;
    rdfs:domain ind:MvpdAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Offer Redemption Id' ;
    rdfs:comment 'Unique identifier for the offer redemption transaction. Primary key for the offer redemption record.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerId rdf:type rdf:Property ;
    rdfs:label 'Offer Id' ;
    rdfs:comment 'Reference to the promotional offer or discount campaign that was redeemed. Links to the offer master record.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offer .

ind:qualifyingTitleId rdf:type rdf:Property ;
    rdfs:label 'Qualifying Title Id' ;
    rdfs:comment 'Foreign key linking to content.title. Business justification: Promotional offers often require viewing or purchasing specific titles (e.g., "watch premiere to unlock discount"). Supports campaign attribution, content-driven acquisition, and partnership promotion' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:resultingSubscriptionPlanId rdf:type rdf:Property ;
    rdfs:label 'Resulting Subscription Plan Id' ;
    rdfs:comment 'Reference to the subscription plan that the subscriber enrolled in or upgraded to as a result of this offer redemption. Links to the subscription plan master record.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubscriptionPlan .

ind:salesAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sales Agent Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Sales and retention agents process promotional offer redemptions via phone/chat channels. Required for agent commission calculations, sales performance tracking, and offer redemption audit trails in s' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appliedDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Discount Amount' ;
    rdfs:comment 'The monetary value of the discount applied to the subscription as a result of this redemption. Expressed in the subscription currency.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributionSource rdf:type rdf:Property ;
    rdfs:label 'Attribution Source' ;
    rdfs:comment 'The marketing source or touchpoint that led to this offer redemption. Examples include email campaign, social media ad, affiliate link, or organic search. Used for marketing attribution analysis.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Discount Duration Months' ;
    rdfs:comment 'The number of months for which the discount will be applied to the subscription. Null for one-time discounts or permanent pricing changes.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'The type of discount mechanism applied through this offer redemption. Determines how the discount value is calculated and applied to the subscription.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityFailureReason rdf:type rdf:Property ;
    rdfs:label 'Eligibility Failure Reason' ;
    rdfs:comment 'Detailed explanation of why the redemption was rejected or marked ineligible. Null if redemption was successful. Used for customer service and offer optimization.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verified Flag' ;
    rdfs:comment 'Indicates whether the subscribers eligibility for the offer was verified at the time of redemption. True if eligibility checks passed, False otherwise.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstTimeSubscriberFlag rdf:type rdf:Property ;
    rdfs:label 'First Time Subscriber Flag' ;
    rdfs:comment 'Indicates whether this redemption resulted in a new subscriber acquisition (True) or was redeemed by an existing subscriber (False). Critical for Customer Acquisition Cost (CAC) and Lifetime Value (LTV) analysis.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offerExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Offer Expiration Date' ;
    rdfs:comment 'The date on which the promotional offer expires and can no longer be redeemed. Used to validate redemption eligibility and track expired redemption attempts.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redemptionChannel rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel' ;
    rdfs:comment 'The platform or channel through which the subscriber redeemed the offer. Enables channel effectiveness analysis for promotional campaigns.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCode rdf:type rdf:Property ;
    rdfs:label 'Redemption Code' ;
    rdfs:comment 'The unique promotional code or voucher code entered by the subscriber at the time of redemption. Used for tracking and validation.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionDeviceType rdf:type rdf:Property ;
    rdfs:label 'Redemption Device Type' ;
    rdfs:comment 'The type of device used by the subscriber to redeem the offer. Supports device-specific campaign optimization and user experience analysis.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionIpAddress rdf:type rdf:Property ;
    rdfs:label 'Redemption Ip Address' ;
    rdfs:comment 'The IP address from which the redemption request originated. Used for fraud detection and geographic analysis. May be considered Personally Identifiable Information (PII) under General Data Protection Regulation (GDPR).' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current lifecycle status of the offer redemption. Tracks whether the redemption was successfully applied, expired before use, reversed due to policy violation, or rejected due to eligibility failure.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'The exact date and time when the subscriber successfully redeemed the promotional offer. Represents the business event time of redemption.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Amount' ;
    rdfs:comment 'The estimated impact on revenue resulting from this offer redemption. Negative values represent revenue reduction due to discounts; positive values may represent incremental revenue from new subscriptions or upgrades.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'The date and time when the offer redemption was reversed or cancelled. Null if the redemption remains active. Used for chargeback and refund reconciliation.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:termsAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted Flag' ;
    rdfs:comment 'Indicates whether the subscriber explicitly accepted the terms and conditions associated with the promotional offer at the time of redemption. Required for compliance and dispute resolution.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms Version' ;
    rdfs:comment 'The version identifier of the offer terms and conditions that the subscriber agreed to at redemption. Format: v1.0, v2.1, etc. Used for legal audit trails.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zuoraSubscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Zuora Subscription Number' ;
    rdfs:comment 'The subscription identifier in the Zuora billing system that was created or modified as a result of this offer redemption. Used for billing reconciliation and revenue recognition.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalControlId rdf:type rdf:Property ;
    rdfs:label 'Parental Control Id' ;
    rdfs:comment 'Unique identifier for the parental control configuration record. Primary key.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allowedViewingEndTime rdf:type rdf:Property ;
    rdfs:label 'Allowed Viewing End Time' ;
    rdfs:comment 'End time of the daily viewing window in HH:MM format (24-hour clock). Content access is blocked after this time. Null if viewing_time_restriction_enabled is False.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allowedViewingStartTime rdf:type rdf:Property ;
    rdfs:label 'Allowed Viewing Start Time' ;
    rdfs:comment 'Start time of the daily viewing window in HH:MM format (24-hour clock). Content access is permitted starting at this time. Null if viewing_time_restriction_enabled is False.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoplayEnabled rdf:type rdf:Property ;
    rdfs:label 'Autoplay Enabled' ;
    rdfs:comment 'Indicates whether automatic playback of next episode or recommended content is enabled for this profile. True if autoplay is on, False if disabled (often disabled for child profiles to limit binge-watching).' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedContentCategories rdf:type rdf:Property ;
    rdfs:label 'Blocked Content Categories' ;
    rdfs:comment 'Comma-separated list of content genre or category codes that are explicitly blocked for this profile (e.g., \'horror\', \'violence\', \'adult\'). Provides granular control beyond rating thresholds.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentLanguageRestriction rdf:type rdf:Property ;
    rdfs:label 'Content Language Restriction' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 language codes (e.g., \'en\', \'es\', \'fr\') to which content access is restricted. Null if no language restrictions apply. Used to limit content to specific languages for child profiles.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingThreshold rdf:type rdf:Property ;
    rdfs:label 'Content Rating Threshold' ;
    rdfs:comment 'Maximum content rating allowed for viewing under this configuration. Based on Motion Picture Association (MPA) film ratings (G, PG, PG-13, R, NC-17) and TV Parental Guidelines (TV-Y, TV-Y7, TV-G, TV-PG, TV-14, TV-MA). Content rated above this threshold is blocked. [ENUM-REF-CANDIDATE: G|PG|PG-13|R|NC-17|TV-Y|TV-Y7|TV-G|TV-PG|TV-14|TV-MA — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaChildProfileFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Child Profile Flag' ;
    rdfs:comment 'Indicates whether this profile is designated as belonging to a child under 13 years of age, triggering COPPA compliance requirements. True if the profile is for a child under 13, False otherwise.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceRestrictionEnabled rdf:type rdf:Property ;
    rdfs:label 'Device Restriction Enabled' ;
    rdfs:comment 'Indicates whether this parental control configuration restricts viewing to specific registered devices. True if device restrictions are enforced, False if profile can be accessed from any device.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the account holder has provided explicit consent for processing parental control data under GDPR. True if consent is granted, False otherwise. Required for EU subscribers.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maturityLevelOverride rdf:type rdf:Property ;
    rdfs:label 'Maturity Level Override' ;
    rdfs:comment 'Custom maturity level designation that overrides standard rating thresholds for specific content. Used for granular exceptions (e.g., allowing a specific R-rated film for educational purposes). Null if no override is set.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDailyViewingMinutes rdf:type rdf:Property ;
    rdfs:label 'Max Daily Viewing Minutes' ;
    rdfs:comment 'Maximum number of minutes of content viewing allowed per day for this profile. Null if no daily limit is set. Used to enforce screen time limits for child profiles.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationEmail rdf:type rdf:Property ;
    rdfs:label 'Notification Email' ;
    rdfs:comment 'Email address to which parental control alerts and notifications are sent (e.g., when a child attempts to access restricted content). Null if notifications are disabled.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalControlStatus rdf:type rdf:Property ;
    rdfs:label 'Parental Control Status' ;
    rdfs:comment 'Current lifecycle status of this parental control configuration. Active indicates the configuration is enforced; Inactive indicates it is saved but not enforced; Suspended indicates temporary deactivation by system or admin.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinCodeHash rdf:type rdf:Property ;
    rdfs:label 'Pin Code Hash' ;
    rdfs:comment 'Cryptographic hash of the parental control PIN. Stored as a one-way hash for security. Never stored in plaintext. Used to authenticate access to restricted content or settings changes.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinProtectionEnabled rdf:type rdf:Property ;
    rdfs:label 'Pin Protection Enabled' ;
    rdfs:comment 'Indicates whether a PIN is required to access content above the rating threshold or to modify parental control settings. True if PIN protection is active, False otherwise.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchaseLockEnabled rdf:type rdf:Property ;
    rdfs:label 'Purchase Lock Enabled' ;
    rdfs:comment 'Indicates whether transactional purchases (TVOD - Transactional Video On Demand) are blocked for this profile. True if purchase lock is active (preventing rentals/purchases), False if purchases are allowed.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:searchRestrictionEnabled rdf:type rdf:Property ;
    rdfs:label 'Search Restriction Enabled' ;
    rdfs:comment 'Indicates whether search functionality is restricted to only show age-appropriate content. True if search results are filtered by parental controls, False if unrestricted search is allowed.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:viewingTimeRestrictionEnabled rdf:type rdf:Property ;
    rdfs:label 'Viewing Time Restriction Enabled' ;
    rdfs:comment 'Indicates whether time-of-day viewing restrictions are enforced for this profile. True if time restrictions are active, False otherwise.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Payment Instrument Id' ;
    rdfs:comment 'Unique identifier for the payment instrument record. Primary key.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zuoraPaymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Zuora Payment Method Id' ;
    rdfs:comment 'External identifier for this payment method in the Zuora subscription billing system. Used for system integration and reconciliation.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:bankAccountType rdf:type rdf:Property ;
    rdfs:label 'Bank Account Type' ;
    rdfs:comment 'Type of bank account for direct debit or ACH payment methods. Null for card-based payment methods.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Gateway Reference Code' ;
    rdfs:comment 'External reference identifier assigned by the payment gateway for this payment instrument. Used for gateway-specific operations and reconciliation.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftCardBalance rdf:type rdf:Property ;
    rdfs:label 'Gift Card Balance' ;
    rdfs:comment 'Remaining balance on the gift card or prepaid card. Updated after each transaction. Null for non-gift-card payment methods.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftCardCode rdf:type rdf:Property ;
    rdfs:label 'Gift Card Code' ;
    rdfs:comment 'Masked gift card or prepaid card code. Full code is tokenized per PCI DSS requirements.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandateAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Mandate Acceptance Date' ;
    rdfs:comment 'Date when the subscriber accepted the direct debit mandate. Required for regulatory compliance and dispute resolution.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maskedAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Masked Account Number' ;
    rdfs:comment 'Masked representation of the card or account number showing only the last 4 digits (e.g., ****1234). Full number is tokenized and stored securely per PCI DSS requirements.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentInstrumentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Instrument Status' ;
    rdfs:comment 'Current lifecycle status of the payment instrument. Active instruments can be charged; expired or suspended instruments require update or replacement.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentToken rdf:type rdf:Property ;
    rdfs:label 'Payment Token' ;
    rdfs:comment 'PCI DSS compliant tokenization reference for the actual payment instrument details. Used to process transactions without exposing sensitive cardholder data.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paypalEmail rdf:type rdf:Property ;
    rdfs:label 'Paypal Email' ;
    rdfs:comment 'Email address associated with the PayPal account. Used for PayPal payment method identification and processing.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paypalPayerReference rdf:type rdf:Property ;
    rdfs:label 'Paypal Payer Reference' ;
    rdfs:comment 'Unique PayPal payer identifier for the linked PayPal account. Used for PayPal billing agreement reference.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adobeProfileReference rdf:type rdf:Property ;
    rdfs:label 'Adobe Profile Reference' ;
    rdfs:comment 'External identifier linking this subscriber to their unified profile in Adobe Experience Platform. Used for personalization, segmentation, and journey orchestration.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Timestamp' ;
    rdfs:comment 'Date and time when CCPA opt-out was recorded. Required for audit trail and compliance reporting.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coppaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Compliant Flag' ;
    rdfs:comment 'Indicates whether this subscriber account is subject to COPPA restrictions (under 13 years old). When true, data collection and advertising are restricted.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Subscriber\'s date of birth. Used for age verification, parental controls, COPPA compliance, and demographic segmentation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Timestamp' ;
    rdfs:comment 'Date and time when GDPR consent was obtained. Required for audit trail and consent management.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Subscriber\'s self-identified gender. Used for demographic analytics and content personalization. Optional field respecting subscriber privacy preferences.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastViewingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Viewing Timestamp' ;
    rdfs:comment 'Date and time of subscriber\'s most recent content viewing session. Used for engagement analysis and retention modeling.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ltv rdf:type rdf:Property ;
    rdfs:label 'Ltv' ;
    rdfs:comment 'Predicted total revenue this subscriber will generate over their entire relationship with the service. Used for acquisition cost justification and retention prioritization.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriberConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Subscriber Consent Record Id' ;
    rdfs:comment 'Unique identifier for the subscriber consent record. Primary key for the immutable audit trail of consent events.' ;
    rdfs:domain ind:SubscriberConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionChannel rdf:type rdf:Property ;
    rdfs:label 'Collection Channel' ;
    rdfs:comment 'The channel or interface through which the consent was collected. Identifies the touchpoint where the subscriber provided or withdrew consent. [ENUM-REF-CANDIDATE: web|mobile_app|call_center|email|in_person|api|third_party — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SubscriberConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationChannelPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Channel Preference' ;
    rdfs:comment 'The subscribers preferred communication channel for receiving messages related to this consent type. Governs operational routing of communications.' ;
    rdfs:domain ind:SubscriberConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentAuditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Consent Audit Trail Reference' ;
    rdfs:comment 'External reference or identifier linking this consent record to detailed audit logs or supporting documentation. Supports regulatory audit and compliance verification.' ;
    rdfs:domain ind:SubscriberConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Consent Scope Description' ;
    rdfs:comment 'Detailed description of the scope and purpose of the data processing covered by this consent. Provides business context for the consent type.' ;
    rdfs:domain ind:SubscriberConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSourceIpAddress rdf:type rdf:Property ;
    rdfs:label 'Consent Source Ip Address' ;
    rdfs:comment 'The IP address from which the consent action was initiated. Used for fraud detection and audit trail verification.' ;
    rdfs:domain ind:SubscriberConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTextPresented rdf:type rdf:Property ;
    rdfs:label 'Consent Text Presented' ;
    rdfs:comment 'The exact text of the consent disclosure or opt-in language presented to the subscriber at the time of consent. Immutable record for legal compliance and audit.' ;
    rdfs:domain ind:SubscriberConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the consent policy or terms presented to the subscriber at the time of consent. Enables tracking of consent under different policy versions.' ;
    rdfs:domain ind:SubscriberConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Days' ;
    rdfs:comment 'The number of days for which subscriber data may be retained under this consent. Nullable if no specific retention period applies. Governs data lifecycle management.' ;
    rdfs:domain ind:SubscriberConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doubleOptInConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmation Timestamp' ;
    rdfs:comment 'The date and time when the subscriber confirmed their consent via double opt-in. Nullable if double opt-in is not required or not yet confirmed.' ;
    rdfs:domain ind:SubscriberConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:doubleOptInConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmed Flag' ;
    rdfs:comment 'Indicates whether the subscriber has confirmed their consent through a double opt-in process (e.g., email confirmation link). True if double opt-in is complete.' ;
    rdfs:domain ind:SubscriberConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInMethod rdf:type rdf:Property ;
    rdfs:label 'Opt In Method' ;
    rdfs:comment 'The method by which the subscriber provided consent. Distinguishes between explicit opt-in, implicit acceptance, and other consent mechanisms.' ;
    rdfs:domain ind:SubscriberConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Required Flag' ;
    rdfs:comment 'Indicates whether parental or guardian consent is required for this subscriber under COPPA or equivalent regulations. True if the subscriber is a minor requiring parental consent.' ;
    rdfs:domain ind:SubscriberConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Verified Flag' ;
    rdfs:comment 'Indicates whether parental consent has been verified through an acceptable verification method. True if verification is complete and valid.' ;
    rdfs:domain ind:SubscriberConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyProcessorName rdf:type rdf:Property ;
    rdfs:label 'Third Party Processor Name' ;
    rdfs:comment 'Name of the third-party data processor or partner to whom data may be shared under this consent. Nullable if consent does not involve third-party sharing.' ;
    rdfs:domain ind:SubscriberConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Free-text or coded reason provided by the subscriber for withdrawing consent. Nullable for granted consents. Supports churn analysis and compliance reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'Marketing channel or source through which the subscriber acquired this subscription (e.g., web, mobile app, partner referral, promotional campaign).' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether the subscription will automatically renew at the end of the current term. True = auto-renew enabled, False = manual renewal required.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rate Amount' ;
    rdfs:comment 'The standard subscription rate amount per billing cycle, in the billing currency, before any discounts or promotions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationInitiatedBy rdf:type rdf:Property ;
    rdfs:label 'Cancellation Initiated By' ;
    rdfs:comment 'Entity that initiated the cancellation: subscriber (voluntary), system (automated), admin (manual intervention), payment_failure (billing issue), fraud_detection (security). Null for active subscriptions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentTermEndDate rdf:type rdf:Property ;
    rdfs:label 'Current Term End Date' ;
    rdfs:comment 'End date of the current billing term or subscription period. Represents the next renewal or expiration date.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentTermStartDate rdf:type rdf:Property ;
    rdfs:label 'Current Term Start Date' ;
    rdfs:comment 'Start date of the current billing term or subscription period.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date when the subscriber first enrolled in this subscription plan. Represents the start of the contractual relationship.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gracePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Grace Period End Date' ;
    rdfs:comment 'Date when the grace period ends after a payment failure or cancellation, after which access is fully revoked. Null if no grace period applies.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalRateAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Rate Amount' ;
    rdfs:comment 'The discounted subscription rate amount during the promotional period, in the billing currency. Null if no promotion is active.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalRateFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Rate Flag' ;
    rdfs:comment 'Indicates whether the subscription is currently on a promotional or discounted rate. True = promotional pricing active, False = standard pricing.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Date when the subscription is scheduled to renew for the next billing cycle.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Subscription Number' ;
    rdfs:comment 'Human-readable business identifier for the subscription, displayed to subscribers and customer service representatives.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle state of the subscription: active (in service), suspended (temporarily paused), cancelled (terminated by subscriber or system), expired (end date reached), trialing (in trial period), pending (awaiting activation).' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Free-text explanation for why the subscription was suspended (e.g., payment failure, subscriber request, fraud investigation). Null for non-suspended subscriptions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialEndDate rdf:type rdf:Property ;
    rdfs:label 'Trial End Date' ;
    rdfs:comment 'Date when the trial period ends and billing begins, if applicable. Null for non-trial subscriptions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialStartDate rdf:type rdf:Property ;
    rdfs:label 'Trial Start Date' ;
    rdfs:comment 'Date when the trial period began, if applicable. Null for non-trial subscriptions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:zuoraSubscriptionReference rdf:type rdf:Property ;
    rdfs:label 'Zuora Subscription Reference' ;
    rdfs:comment 'External subscription identifier from Zuora billing system for revenue recognition and invoicing integration.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionChangeId rdf:type rdf:Property ;
    rdfs:label 'Subscription Change Id' ;
    rdfs:comment 'Unique identifier for the subscription change event. Primary key.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addOnId rdf:type rdf:Property ;
    rdfs:label 'Add On Id' ;
    rdfs:comment 'Reference to the add-on product attached or detached during this change. Populated only for add-on attach and add-on detach change types.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AddOn .

ind:primarySubscriptionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Subscription Employee Id' ;
    rdfs:comment 'Reference to the user account (subscriber self-service or internal agent) that initiated the subscription change. Used for audit trails and agent performance tracking.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySubscriptionPlanId rdf:type rdf:Property ;
    rdfs:label 'Primary Subscription Plan Id' ;
    rdfs:comment 'Reference to the subscription plan that was active before this change. Null for new subscriptions or add-on attach events.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubscriptionPlan .

ind:appliedDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Applied Discount Percentage' ;
    rdfs:comment 'The percentage discount applied to the new plan subscription fee. Used for promotion effectiveness analysis and revenue impact modeling.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeChannel rdf:type rdf:Property ;
    rdfs:label 'Change Channel' ;
    rdfs:comment 'The channel through which the subscription change was initiated. Enables channel effectiveness analysis and self-service adoption tracking. [ENUM-REF-CANDIDATE: web|mobile app|call center|chat|email|api|admin portal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Change Effective Date' ;
    rdfs:comment 'The date when the subscription change became effective and billing adjustments were applied. Critical for revenue recognition and proration calculations.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:changeNotes rdf:type rdf:Property ;
    rdfs:label 'Change Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the agent or system during the change process. Captures context, customer feedback, and special handling instructions.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Change Processed Timestamp' ;
    rdfs:comment 'The exact date and time when the system completed processing the change and updated the subscription state. Used for operational efficiency metrics.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Change Request Timestamp' ;
    rdfs:comment 'The exact date and time when the subscriber or agent initiated the change request. Used for time-to-fulfillment analysis and customer experience tracking.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contentEntitlementChange rdf:type rdf:Property ;
    rdfs:label 'Content Entitlement Change' ;
    rdfs:comment 'Describes changes to content library access, premium channel entitlements, or windowing rights resulting from this subscription change. Critical for content licensing and rights management.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceLimitNew rdf:type rdf:Property ;
    rdfs:label 'Device Limit New' ;
    rdfs:comment 'The maximum number of concurrent devices allowed under the new subscription plan. Enables analysis of device limit impact on upgrade and downgrade decisions.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceLimitPrevious rdf:type rdf:Property ;
    rdfs:label 'Device Limit Previous' ;
    rdfs:comment 'The maximum number of concurrent devices allowed under the previous subscription plan. Used to track device entitlement changes and household sharing patterns.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrrImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Mrr Impact Amount' ;
    rdfs:comment 'The net change in monthly recurring revenue resulting from this subscription change. Positive for upgrades, negative for downgrades. Calculated as new_monthly_recurring_revenue minus previous_monthly_recurring_revenue.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newBillingPeriod rdf:type rdf:Property ;
    rdfs:label 'New Billing Period' ;
    rdfs:comment 'The billing frequency of the new subscription plan. Enables analysis of billing period changes and their impact on cash flow and retention.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newMonthlyRecurringRevenue rdf:type rdf:Property ;
    rdfs:label 'New Monthly Recurring Revenue' ;
    rdfs:comment 'The monthly recurring revenue amount from the new plan after this change. Used to calculate MRR expansion, contraction, and net revenue retention metrics.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offerCode rdf:type rdf:Property ;
    rdfs:label 'Offer Code' ;
    rdfs:comment 'The promotional code or coupon code entered by the subscriber during the change process. Used for campaign tracking and fraud detection.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerRedemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Redemption Status' ;
    rdfs:comment 'The status of promotional offer redemption at the time of subscription change. Tracks successful and failed offer applications for campaign effectiveness measurement.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousBillingPeriod rdf:type rdf:Property ;
    rdfs:label 'Previous Billing Period' ;
    rdfs:comment 'The billing frequency of the previous subscription plan. Used to analyze billing period migration patterns and payment preference trends.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousMonthlyRecurringRevenue rdf:type rdf:Property ;
    rdfs:label 'Previous Monthly Recurring Revenue' ;
    rdfs:comment 'The monthly recurring revenue amount from the previous plan before this change. Critical for MRR movement analysis and revenue waterfall reporting.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalOfferCode rdf:type rdf:Property ;
    rdfs:label 'Promotional Offer Code' ;
    rdfs:comment 'Reference to the promotional offer or retention campaign that was redeemed during this subscription change. Null if no offer was applied.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prorationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Proration Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the proration amount. Supports multi-currency subscription operations.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTierChange rdf:type rdf:Property ;
    rdfs:label 'Service Tier Change' ;
    rdfs:comment 'Describes the service tier transition for this subscription change. Specific to media streaming business models including AVOD (Advertising-Supported Video On Demand), SVOD (Subscription Video On Demand), and tiered SVOD offerings.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zuoraAmendmentReference rdf:type rdf:Property ;
    rdfs:label 'Zuora Amendment Reference' ;
    rdfs:comment 'The unique identifier of the Zuora subscription amendment record that represents this change. Enables reconciliation with the billing system of record.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDemographicSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Demographic Segment Id' ;
    rdfs:comment 'Foreign key linking to audience.demographic_segment. Business justification: Subscription tiers are designed targeting specific Nielsen demographics (A18-49, A25-54 key demos). Required for pricing strategy, tier optimization, and validating that plan design attracts target au' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemographicSegment .

ind:adSupported rdf:type rdf:Property ;
    rdfs:label 'Ad Supported' ;
    rdfs:comment 'Indicates whether this subscription plan includes advertising (AVOD/FAST model) or is ad-free (SVOD model).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addonEligible rdf:type rdf:Property ;
    rdfs:label 'Addon Eligible' ;
    rdfs:comment 'Indicates whether this plan can be purchased as an add-on to another base subscription plan (e.g., premium sports channel add-on).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioQualityMax rdf:type rdf:Property ;
    rdfs:label 'Audio Quality Max' ;
    rdfs:comment 'Maximum audio quality format available under this subscription plan (e.g., stereo, surround 5.1, Dolby Atmos, DTS:X).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether subscriptions under this plan automatically renew at the end of each billing period by default.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'Standard recurring price for the subscription plan before any discounts, promotions, or taxes. Expressed in the default currency.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundledPlan rdf:type rdf:Property ;
    rdfs:label 'Bundled Plan' ;
    rdfs:comment 'Indicates whether this is a bundled subscription plan that combines multiple services or content packages (e.g., streaming + live TV + music).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationPolicy rdf:type rdf:Property ;
    rdfs:label 'Cancellation Policy' ;
    rdfs:comment 'Policy governing subscriber cancellation: anytime (immediate), end of billing period, no refund, or prorated refund.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:churnRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Category' ;
    rdfs:comment 'Assessed churn risk category for subscribers on this plan based on historical churn rate analysis (low, medium, high).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentLibraryScope rdf:type rdf:Property ;
    rdfs:label 'Content Library Scope' ;
    rdfs:comment 'Defines the scope of content library access granted by this plan (e.g., full catalog, limited selection, premium content only, sports only, news only, kids only).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceRegistrationLimit rdf:type rdf:Property ;
    rdfs:label 'Device Registration Limit' ;
    rdfs:comment 'Maximum number of devices that can be registered to a subscriber account under this plan. Null indicates unlimited device registrations.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downloadLimit rdf:type rdf:Property ;
    rdfs:label 'Download Limit' ;
    rdfs:comment 'Maximum number of titles that can be downloaded for offline viewing at any given time. Null if download_enabled is false or unlimited.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyTerminationFee rdf:type rdf:Property ;
    rdfs:label 'Early Termination Fee' ;
    rdfs:comment 'Fee charged to subscribers who cancel before the end of the contract term. Null if no early termination fee applies.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicAvailability rdf:type rdf:Property ;
    rdfs:label 'Geographic Availability' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this subscription plan is available for purchase (e.g., USA,CAN,GBR,AUS). Empty indicates global availability.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known unique business identifier for the subscription plan used in billing systems and customer communications. Managed in Zuora product catalog.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the subscription plan features, benefits, and included content for subscriber-facing materials and internal reference.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable marketing name of the subscription plan displayed to subscribers (e.g., Premium Plus, Family Bundle, Sports Add-On).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the subscription plan: active (available for new subscriptions), inactive (temporarily unavailable), deprecated (no longer offered but existing subscriptions continue), sunset (being phased out), coming soon (announced but not yet available).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Business model classification: SVOD (Subscription Video On Demand), AVOD (Advertising-Supported Video On Demand), TVOD (Transactional Video On Demand), FAST (Free Ad-Supported Streaming Television), hybrid, or add-on plan.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalPlan rdf:type rdf:Property ;
    rdfs:label 'Promotional Plan' ;
    rdfs:comment 'Indicates whether this is a limited-time promotional subscription plan offered at a special price or with enhanced features.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetArpu rdf:type rdf:Property ;
    rdfs:label 'Target Arpu' ;
    rdfs:comment 'Target average revenue per user (ARPU) metric for financial planning and performance tracking of this subscription plan.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLtv rdf:type rdf:Property ;
    rdfs:label 'Target Ltv' ;
    rdfs:comment 'Target lifetime value (LTV) metric representing the projected total revenue from a subscriber over the duration of their subscription to this plan.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trialDurationDays rdf:type rdf:Property ;
    rdfs:label 'Trial Duration Days' ;
    rdfs:comment 'Number of days for the free trial period if trial_eligible is true. Null if no trial is offered.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trialEligible rdf:type rdf:Property ;
    rdfs:label 'Trial Eligible' ;
    rdfs:comment 'Indicates whether this subscription plan is eligible for a free trial period for new subscribers.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:videoQualityMax rdf:type rdf:Property ;
    rdfs:label 'Video Quality Max' ;
    rdfs:comment 'Maximum video resolution quality available under this subscription plan (e.g., SD, HD, Full HD, 4K, 8K).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:favoriteGenreId rdf:type rdf:Property ;
    rdfs:label 'Favorite Genre Id' ;
    rdfs:comment 'Foreign key linking to content.genre. Business justification: Personalization and recommendation engines require explicit genre preferences. Drives content discovery, homepage curation, and email marketing. Complements behavioral signals with declared preference' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Genre .

ind:aepSegmentIds rdf:type rdf:Property ;
    rdfs:label 'Aep Segment Ids' ;
    rdfs:comment 'Comma-separated list of Adobe Experience Platform segment IDs that this viewer profile belongs to. Used for personalized content recommendations, targeted advertising, and dynamic user experience customization.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoplayPreviewsEnabled rdf:type rdf:Property ;
    rdfs:label 'Autoplay Previews Enabled' ;
    rdfs:comment 'Boolean flag indicating whether automatic preview playback is enabled when browsing content. True enables preview autoplay; false disables previews.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:avatarUrl rdf:type rdf:Property ;
    rdfs:label 'Avatar Url' ;
    rdfs:comment 'URL reference to the profile avatar image stored in the Media Asset Management (MAM) system or Content Delivery Network (CDN). Used for visual identification in profile selection interfaces.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSaverMode rdf:type rdf:Property ;
    rdfs:label 'Data Saver Mode' ;
    rdfs:comment 'Boolean flag indicating whether data saver mode is enabled to reduce bandwidth consumption. True limits video quality and disables high-bandwidth features; false allows full quality streaming.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genrePreferences rdf:type rdf:Property ;
    rdfs:label 'Genre Preferences' ;
    rdfs:comment 'Comma-separated list of preferred content genre identifiers for personalization and recommendation algorithms. Derived from viewing history and explicit user selections. Used by Adobe Experience Platform for segment targeting.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultProfile rdf:type rdf:Property ;
    rdfs:label 'Is Default Profile' ;
    rdfs:comment 'Boolean flag indicating whether this is the default profile that is automatically selected when the subscriber logs in. True for default profile; false for secondary profiles. Only one profile per subscriber should be marked as default.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKidsProfile rdf:type rdf:Property ;
    rdfs:label 'Is Kids Profile' ;
    rdfs:comment 'Boolean flag indicating whether this is a dedicated kids profile with enhanced parental controls, age-appropriate content filtering, and COPPA (Children\'s Online Privacy Protection Act) compliance enforcement. True for kids profiles; false for adult/general profiles.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPlatform rdf:type rdf:Property ;
    rdfs:label 'Last Platform' ;
    rdfs:comment 'Platform type of the last device used to access this viewer profile. Used for platform-specific analytics and Over-The-Top (OTT) distribution tracking. [ENUM-REF-CANDIDATE: web|mobile_ios|mobile_android|smart_tv|roku|fire_tv|apple_tv|chromecast|gaming_console — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingConsent rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent' ;
    rdfs:comment 'Boolean flag indicating whether the viewer profile has consented to receive marketing communications and promotional content. True allows marketing; false opts out. Required for GDPR (General Data Protection Regulation) and CCPA (California Consumer Privacy Act) compliance.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maturityRatingLevel rdf:type rdf:Property ;
    rdfs:label 'Maturity Rating Level' ;
    rdfs:comment 'Maximum content maturity rating level allowed for this viewer profile. Enforces parental controls and content filtering based on Motion Picture Association (MPA) film ratings and TV Parental Guidelines. Content exceeding this rating is blocked from playback. [ENUM-REF-CANDIDATE: G|PG|PG-13|R|NC-17|TV-Y|TV-Y7|TV-G|TV-PG|TV-14|TV-MA — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDownloads rdf:type rdf:Property ;
    rdfs:label 'Max Downloads' ;
    rdfs:comment 'Maximum number of content titles that can be downloaded for offline viewing on this profile. Enforces subscription tier limits and storage management policies.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personalizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Personalization Enabled' ;
    rdfs:comment 'Boolean flag indicating whether personalized content recommendations and user experience customization are enabled for this profile. True enables Adobe Experience Platform personalization; false provides generic content discovery. Impacts GDPR (General Data Protection Regulation) and CCPA (California Consumer Privacy Act) consent requirements.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pinEnabled rdf:type rdf:Property ;
    rdfs:label 'Pin Enabled' ;
    rdfs:comment 'Boolean flag indicating whether PIN protection is enabled for this profile. True requires PIN entry for profile access; false allows unrestricted access.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profileSortOrder rdf:type rdf:Property ;
    rdfs:label 'Profile Sort Order' ;
    rdfs:comment 'Integer value determining the display order of this profile in the profile selection interface. Lower values appear first. Used for user experience optimization.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subtitlePreference rdf:type rdf:Property ;
    rdfs:label 'Subtitle Preference' ;
    rdfs:comment 'Default subtitle display preference for this viewer profile. Off disables subtitles; on always displays subtitles; auto displays subtitles based on content language and user language mismatch.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoQualityPreference rdf:type rdf:Property ;
    rdfs:label 'Video Quality Preference' ;
    rdfs:comment 'Preferred video streaming quality for this profile. Auto uses Adaptive Bitrate Streaming (ABR) based on bandwidth; low/medium/high/ultra_hd enforce specific quality tiers. Impacts Content Delivery Network (CDN) delivery and bandwidth consumption.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewingHistoryEnabled rdf:type rdf:Property ;
    rdfs:label 'Viewing History Enabled' ;
    rdfs:comment 'Boolean flag indicating whether viewing history is tracked and stored for this profile. True enables history tracking for recommendations and resume playback; false disables tracking for privacy. Impacts GDPR (General Data Protection Regulation) and CCPA (California Consumer Privacy Act) compliance.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appearanceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Appearance Schedule Id' ;
    rdfs:comment 'Unique identifier for the appearance schedule record. Primary key for the appearance schedule entity.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Production coordinators/schedulers create appearance schedules. Required for scheduling accountability, workload management, audit trails, and dispute resolution. Column created_by_user is denormalize' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rescheduledFromAppearanceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Rescheduled From Appearance Schedule Id' ;
    rdfs:comment 'Reference to the original appearance schedule record if this schedule is a rescheduled version of a previous booking.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AppearanceSchedule .

ind:resultingMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Resulting Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Links scheduled talent appearances (talk shows, live events, promotional shoots) to the resulting recorded media assets. Required for archival cross-reference, rights verification, and tracking which ' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:appearanceType rdf:type rdf:Property ;
    rdfs:label 'Appearance Type' ;
    rdfs:comment 'Classification of the type of appearance or activity scheduled for the talent. ADR (Automated Dialogue Replacement) refers to post-production voice recording sessions. [ENUM-REF-CANDIDATE: principal_photography|adr_session|promotional_appearance|press_junket|live_broadcast|table_read|rehearsal|wardrobe_fitting|makeup_test|screen_test — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Availability Window End' ;
    rdfs:comment 'The end date of the period during which the talent has indicated availability for scheduling.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availabilityWindowStart rdf:type rdf:Property ;
    rdfs:label 'Availability Window Start' ;
    rdfs:comment 'The start date of the period during which the talent has indicated availability for scheduling.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:callDate rdf:type rdf:Property ;
    rdfs:label 'Call Date' ;
    rdfs:comment 'The scheduled date on which the talent is required to appear for the activity. Follows yyyy-MM-dd format.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'The date and time when this appearance schedule was cancelled, if applicable.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Current lifecycle status of the appearance schedule indicating whether the booking is pending confirmation, confirmed, cancelled, rescheduled, completed, or resulted in a no-show.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityConflictFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Conflict Flag' ;
    rdfs:comment 'Boolean flag indicating whether this appearance schedule conflicts with any exclusivity clauses in the talent\'s contract.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guildNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Guild Notification Required' ;
    rdfs:comment 'Boolean flag indicating whether guild notification is required for this appearance per union agreements (SAG-AFTRA, WGA, DGA).' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guildNotificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Guild Notification Sent Timestamp' ;
    rdfs:comment 'The date and time when notification was sent to the relevant guild regarding this appearance schedule.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdLevel rdf:type rdf:Property ;
    rdfs:label 'Hold Level' ;
    rdfs:comment 'Priority level of the talent booking indicating the strength of the commitment. First hold is highest priority, second and third holds are lower priority backups, first refusal gives talent right to accept or decline before offering to others.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutSystemSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Playout System Sync Status' ;
    rdfs:comment 'Status indicating whether this appearance schedule has been synchronized with the playout and channel management system (Ericsson MediaFirst) for live broadcast coordination.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutSystemSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Playout System Sync Timestamp' ;
    rdfs:comment 'The date and time when this appearance schedule was last synchronized with the playout system.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseTrackingStatus rdf:type rdf:Property ;
    rdfs:label 'Release Tracking Status' ;
    rdfs:comment 'Status of obtaining necessary talent releases, waivers, or permissions required for the appearance, particularly for promotional and publicity activities.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingNotes rdf:type rdf:Property ;
    rdfs:label 'Scheduling Notes' ;
    rdfs:comment 'Free-text field for additional scheduling information, special requirements, or coordination notes relevant to this appearance.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unavailabilityReason rdf:type rdf:Property ;
    rdfs:label 'Unavailability Reason' ;
    rdfs:comment 'Free-text explanation of why the talent is unavailable during certain periods, such as personal commitments, conflicting bookings, or contractual exclusivity.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbaRateCardId rdf:type rdf:Property ;
    rdfs:label 'Cba Rate Card Id' ;
    rdfs:comment 'Unique identifier for the CBA rate card entry. Primary key.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CbaRateCard .

ind:supersededByRateCardCbaRateCardId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Card Cba Rate Card Id' ;
    rdfs:comment 'Reference to the newer CBA rate card entry that replaces this one, if applicable.' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CbaRateCard .

ind:budgetTier rdf:type rdf:Property ;
    rdfs:label 'Budget Tier' ;
    rdfs:comment 'Production budget classification that determines applicable rates (e.g., high budget, low budget, ultra-low budget, modified low budget).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbaCode rdf:type rdf:Property ;
    rdfs:label 'Cba Code' ;
    rdfs:comment 'Standardized code identifying the specific collective bargaining agreement (e.g., SAG_AFTRA_TV, DGA_BASIC, WGA_MBA, IATSE_BASIC).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbaName rdf:type rdf:Property ;
    rdfs:label 'Cba Name' ;
    rdfs:comment 'Full legal name of the collective bargaining agreement (e.g., SAG-AFTRA Television Agreement, DGA Basic Agreement, WGA Minimum Basic Agreement).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbaRatificationDate rdf:type rdf:Property ;
    rdfs:label 'Cba Ratification Date' ;
    rdfs:comment 'Date when the CBA was ratified by the guild membership.' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cbaVersion rdf:type rdf:Property ;
    rdfs:label 'Cba Version' ;
    rdfs:comment 'Version identifier of the CBA document (e.g., 2023-2026, v4.2).' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forcedCallPenaltyMultiplier rdf:type rdf:Property ;
    rdfs:label 'Forced Call Penalty Multiplier' ;
    rdfs:comment 'Multiplier applied when talent is called back to work before the minimum turnaround period has elapsed.' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goldenTimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Golden Time Multiplier' ;
    rdfs:comment 'Multiplier applied to base rate for hours worked beyond double-time threshold (e.g., 3.0 for triple-time), applicable in certain guild agreements.' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guildCode rdf:type rdf:Property ;
    rdfs:label 'Guild Code' ;
    rdfs:comment 'Code representing the labor guild or union that negotiated this CBA (SAG-AFTRA, DGA, WGA, IATSE, NABET, AFM, OTHER). [ENUM-REF-CANDIDATE: SAG-AFTRA|DGA|WGA|IATSE|NABET|AFM|OTHER — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobClassification rdf:type rdf:Property ;
    rdfs:label 'Job Classification' ;
    rdfs:comment 'Specific job title or classification within the performer category (e.g., Series Regular, Guest Star, Co-Star, Director of Photography, Script Supervisor).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localChapter rdf:type rdf:Property ;
    rdfs:label 'Local Chapter' ;
    rdfs:comment 'Local guild chapter or regional office that administers this rate (e.g., SAG-AFTRA Los Angeles, IATSE Local 600).' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mealPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Meal Penalty Amount' ;
    rdfs:comment 'Penalty payment owed to talent when meal breaks are not provided within the CBA-mandated timeframe.' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumScaleRate rdf:type rdf:Property ;
    rdfs:label 'Minimum Scale Rate' ;
    rdfs:comment 'Minimum compensation amount defined by the CBA for this rate type and performer category.' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Multiplier' ;
    rdfs:comment 'Multiplier applied to base rate for overtime hours (e.g., 1.5 for time-and-a-half, 2.0 for double-time).' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Threshold Hours' ;
    rdfs:comment 'Number of hours worked before overtime rates apply (e.g., 8.0 for daily overtime, 40.0 for weekly overtime).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pensionHealthContributionRate rdf:type rdf:Property ;
    rdfs:label 'Pension Health Contribution Rate' ;
    rdfs:comment 'Percentage of gross compensation that the employer must contribute to pension and health funds as mandated by the CBA (e.g., 0.1850 for 18.5%).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performerCategory rdf:type rdf:Property ;
    rdfs:label 'Performer Category' ;
    rdfs:comment 'Classification of the talent role covered by this rate (e.g., principal performer, day player, stunt performer, background actor, director, writer, producer, crew member).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of this rate card entry (active, expired, superseded, pending, draft).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Eligibility Flag' ;
    rdfs:comment 'Indicates whether this rate category qualifies for residual payments under the CBA (True/False).' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualFormulaCode rdf:type rdf:Property ;
    rdfs:label 'Residual Formula Code' ;
    rdfs:comment 'Code identifying the residual calculation formula applicable to this rate (e.g., NETWORK_PRIME, BASIC_CABLE, SVOD_HIGH_BUDGET).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationStructureId rdf:type rdf:Property ;
    rdfs:label 'Compensation Structure Id' ;
    rdfs:comment 'Unique identifier for the compensation structure record. Primary key.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Business affairs employees modify compensation structures. Required for audit trails, approval workflows, financial controls, and compliance tracking. Column modified_by_user is denormalized employee ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:backendGrossParticipationPct rdf:type rdf:Property ;
    rdfs:label 'Backend Gross Participation Pct' ;
    rdfs:comment 'The percentage of adjusted gross receipts or backend profits the talent is entitled to receive (e.g., 0.05 for 5% backend participation). Null if no backend participation is granted.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseEpisodeFee rdf:type rdf:Property ;
    rdfs:label 'Base Episode Fee' ;
    rdfs:comment 'The guaranteed compensation amount per episode for episodic talent (actors, writers, directors). Expressed in the contract currency.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'The fixed or maximum bonus amount payable when the bonus threshold is met. Expressed in the contract currency. Null if no bonus provision exists.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusThresholdDescription rdf:type rdf:Property ;
    rdfs:label 'Bonus Threshold Description' ;
    rdfs:comment 'Textual description of the performance or milestone thresholds that trigger bonus payments (e.g., \'Nielsen rating above 2.0 in key demo\', \'box office exceeds $100M domestic\').' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyRate rdf:type rdf:Property ;
    rdfs:label 'Daily Rate' ;
    rdfs:comment 'The guaranteed daily compensation amount for talent engaged on a day-player or daily basis. Expressed in the contract currency.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Compensation Amount' ;
    rdfs:comment 'The total amount of compensation deferred to a future payment date or contingent event (e.g., series pickup, profitability milestone). Expressed in the contract currency.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredPaymentTrigger rdf:type rdf:Property ;
    rdfs:label 'Deferred Payment Trigger' ;
    rdfs:comment 'The business event or milestone that triggers payment of deferred compensation (e.g., \'series_pickup\', \'profitability_threshold_met\', \'syndication_sale\', \'specific_date\').' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Clause Flag' ;
    rdfs:comment 'Indicates whether this compensation structure includes an exclusivity provision restricting the talent from working on competing projects (True) or not (False).' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payOrPlayFlag rdf:type rdf:Property ;
    rdfs:label 'Pay Or Play Flag' ;
    rdfs:comment 'Indicates whether this compensation structure includes a pay-or-play provision, guaranteeing payment even if the talent is not used (True) or not (False).' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pensionHealthRate rdf:type rdf:Property ;
    rdfs:label 'Pension Health Rate' ;
    rdfs:comment 'The percentage rate of gross compensation contributed to the guild pension and health plan (e.g., 0.185 for 18.5% SAG-AFTRA P&H). Used to calculate employer contributions.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualBaseFormula rdf:type rdf:Property ;
    rdfs:label 'Residual Base Formula' ;
    rdfs:comment 'The formula or method used to calculate the residual base for reuse payments (e.g., \'initial_compensation\', \'applicable_minimum\', \'pro_rata_share\'). Defines how residuals are computed per guild rules.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepUpAmount rdf:type rdf:Property ;
    rdfs:label 'Step Up Amount' ;
    rdfs:comment 'The incremental compensation increase amount when the step-up trigger is met. Expressed in the contract currency. Null if no step-up provision exists.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepUpTrigger rdf:type rdf:Property ;
    rdfs:label 'Step Up Trigger' ;
    rdfs:comment 'The condition or event that triggers an automatic increase in compensation (e.g., \'season_2_pickup\', \'episode_13_renewal\', \'ratings_threshold\'). Null if no step-up provision exists.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureName rdf:type rdf:Property ;
    rdfs:label 'Structure Name' ;
    rdfs:comment 'Business-friendly name or label for this compensation structure (e.g., \'Series Regular Season 1\', \'Guest Star Rate Card\').' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureStatus rdf:type rdf:Property ;
    rdfs:label 'Structure Status' ;
    rdfs:comment 'Current lifecycle status of the compensation structure: draft (under negotiation), active (in force), amended (modified after execution), superseded (replaced by a newer structure), or terminated (no longer applicable).' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsScope rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Scope' ;
    rdfs:comment 'Description of the media usage rights covered by this compensation structure (e.g., \'initial broadcast only\', \'all media in perpetuity\', \'theatrical and SVOD\', \'domestic free television\'). Defines what exploitation is covered by the base compensation.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeklyGuarantee rdf:type rdf:Property ;
    rdfs:label 'Weekly Guarantee' ;
    rdfs:comment 'The guaranteed weekly compensation amount for talent engaged on a weekly basis (e.g., series regulars, production staff). Expressed in the contract currency.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Contract Amendment Id' ;
    rdfs:comment 'Unique identifier for the contract amendment record. Primary key.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByAmendmentContractAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Amendment Contract Amendment Id' ;
    rdfs:comment 'Reference to a subsequent amendment that replaces or supersedes this amendment. Used to maintain amendment version history and prevent application of outdated terms.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAmendment .

ind:amendedClauseReference rdf:type rdf:Property ;
    rdfs:label 'Amended Clause Reference' ;
    rdfs:comment 'Specific section, paragraph, or clause number from the original contract that this amendment modifies (e.g., Section 3.2, Paragraph 5(a), Exhibit B).' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendedTermValue rdf:type rdf:Property ;
    rdfs:label 'Amended Term Value' ;
    rdfs:comment 'The new contractual term or value established by this amendment. Replaces or supplements the original term value.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Detailed narrative description of the contractual changes being made, including the business rationale and specific terms being modified or added.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAffairsApproverName rdf:type rdf:Property ;
    rdfs:label 'Business Affairs Approver Name' ;
    rdfs:comment 'Name of the business affairs executive who reviewed and approved this amendment on behalf of the production company or network.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companySignatureDate rdf:type rdf:Property ;
    rdfs:label 'Company Signature Date' ;
    rdfs:comment 'Date on which the authorized company representative signed the amendment. Execution date is typically the later of talent and company signature dates.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compensationImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Impact Amount' ;
    rdfs:comment 'Net financial impact of the amendment on total talent compensation. Positive values indicate increases, negative indicate reductions. Used for budget reconciliation and residual calculations.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Compensation Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the compensation impact amount (e.g., USD, GBP, CAD).' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceUri rdf:type rdf:Property ;
    rdfs:label 'Document Reference Uri' ;
    rdfs:comment 'URI or file path to the executed amendment document stored in the media asset management or document management system.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Guild Notification Date' ;
    rdfs:comment 'Date on which the amendment was formally reported to the applicable talent guild. Required for compliance with CBA notification timelines.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guildNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Guild Notification Required Flag' ;
    rdfs:comment 'Indicates whether the amendment must be reported to the talent guild per collective bargaining agreement (CBA) requirements. True for material changes to compensation, credit, or working conditions.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalTermValue rdf:type rdf:Property ;
    rdfs:label 'Original Term Value' ;
    rdfs:comment 'The original contractual term or value being replaced or modified by this amendment. Captured for audit trail and comparison purposes.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualCalculationImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Calculation Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment affects residual payment calculations. True triggers recalculation of residual formulas and payment schedules.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:talentRepresentativeAgency rdf:type rdf:Property ;
    rdfs:label 'Talent Representative Agency' ;
    rdfs:comment 'Name of the talent agency or law firm representing the talent in this amendment negotiation.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Talent Representative Name' ;
    rdfs:comment 'Name of the talent agent, manager, or attorney who negotiated and approved this amendment on behalf of the talent.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Talent Signature Date' ;
    rdfs:comment 'Date on which the talent or their authorized representative signed the amendment.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractOptionId rdf:type rdf:Property ;
    rdfs:label 'Contract Option Id' ;
    rdfs:comment 'Unique identifier for the contract option record. Primary key.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessAffairsContact rdf:type rdf:Property ;
    rdfs:label 'Business Affairs Contact' ;
    rdfs:comment 'Name or identifier of the business affairs executive or legal representative responsible for managing this option and coordinating exercise decisions.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationStepUpPercentage rdf:type rdf:Property ;
    rdfs:label 'Compensation Step Up Percentage' ;
    rdfs:comment 'Percentage increase in base compensation upon exercise of the option, relative to the prior contract period or base rate. Common in multi-season series deals where talent compensation escalates with each renewal.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exerciseApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Exercise Approval Date' ;
    rdfs:comment 'The date on which the option exercise was formally approved by the authorized business affairs or executive authority. May differ from notification date in organizations requiring multi-level approval.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exerciseCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Exercise Compensation Amount' ;
    rdfs:comment 'The base compensation amount payable to the talent if the option is exercised. Represents the step-up or incremental payment beyond the option fee for the additional work commitment.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exerciseCompensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Exercise Compensation Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the exercise compensation (e.g., USD, GBP, EUR, CAD).' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exerciseNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Exercise Notification Date' ;
    rdfs:comment 'The date on which the production company formally notified the talent (or their representative) of the decision to exercise the option. Triggers contractual obligations and payment schedules.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exerciseNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Exercise Notification Method' ;
    rdfs:comment 'The communication channel or mechanism used to deliver the option exercise notification, as required by the contract terms. Important for legal compliance and dispute resolution.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lapseDate rdf:type rdf:Property ;
    rdfs:label 'Lapse Date' ;
    rdfs:comment 'The actual date on which the option lapsed due to non-exercise within the option window. Recorded for audit and contract history purposes.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lapseReason rdf:type rdf:Property ;
    rdfs:label 'Lapse Reason' ;
    rdfs:comment 'Business rationale or explanation for why the option was allowed to lapse without exercise. May include creative decisions, budget constraints, performance issues, or strategic pivots.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionDescription rdf:type rdf:Property ;
    rdfs:label 'Option Description' ;
    rdfs:comment 'Detailed narrative description of the option terms, scope, and conditions. May include specific deliverables, performance triggers, or creative commitments associated with the option.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Option Fee Amount' ;
    rdfs:comment 'The monetary consideration paid to the talent to secure the option right, regardless of whether the option is ultimately exercised. Typically non-refundable and may be applied against future compensation if exercised.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optionFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Option Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the option fee (e.g., USD, GBP, EUR, CAD).' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionNumber rdf:type rdf:Property ;
    rdfs:label 'Option Number' ;
    rdfs:comment 'Sequential number of this option within the contract (e.g., 1 for first option, 2 for second option). Used to track multi-year or multi-project option sequences.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optionType rdf:type rdf:Property ;
    rdfs:label 'Option Type' ;
    rdfs:comment 'Classification of the option based on its business purpose: series pickup option for additional seasons, sequel option for follow-on films, spin-off option for derivative content, overall deal extension for multi-project agreements, season renewal for episodic content, or project continuation for phased productions.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Option Window End Date' ;
    rdfs:comment 'The final date by which the option must be exercised or it will lapse. Critical deadline for business affairs teams to track to avoid inadvertent loss of talent commitments.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Option Window Start Date' ;
    rdfs:comment 'The earliest date on which the option can be exercised by the production company or network. Marks the beginning of the exercise window.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceTriggerDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Trigger Description' ;
    rdfs:comment 'Description of any performance-based conditions or milestones that must be met before the option can be exercised (e.g., minimum ratings thresholds, box office targets, critical acclaim metrics, audience engagement benchmarks).' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceTriggerMetFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Trigger Met Flag' ;
    rdfs:comment 'Indicates whether all performance-based conditions have been satisfied, enabling the option to be exercised. True if triggers are met or not applicable, False if triggers exist but are not yet satisfied.' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditAttributionId rdf:type rdf:Property ;
    rdfs:label 'Credit Attribution Id' ;
    rdfs:comment 'Unique identifier for the credit attribution record. Primary key.' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingBlock rdf:type rdf:Property ;
    rdfs:label 'Billing Block' ;
    rdfs:comment 'The section or block within the credits where this attribution appears: above title, title card, opening sequence, closing sequence, end crawl, or promotional materials.' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardSizePercentage rdf:type rdf:Property ;
    rdfs:label 'Card Size Percentage' ;
    rdfs:comment 'The size of the talent credit card relative to the title card, expressed as a percentage (e.g., 100.00 means same size as title, 75.00 means 75% of title size). Contractually mandated for high-profile talent.' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditDeterminationMethod rdf:type rdf:Property ;
    rdfs:label 'Credit Determination Method' ;
    rdfs:comment 'The method by which this credit was determined: contractual (per talent agreement), guild arbitration (resolved by guild dispute process), mutual agreement (negotiated between parties), or statutory (mandated by regulation).' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Credit Duration Seconds' ;
    rdfs:comment 'The minimum duration in seconds that the credit card must be displayed on screen, as contractually required.' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditFormat rdf:type rdf:Property ;
    rdfs:label 'Credit Format' ;
    rdfs:comment 'The format in which the credit is displayed: single card (talent alone), shared card (multiple talents on one card), alphabetical (ordered alphabetically with peers), or separate card (dedicated card for this talent).' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditPlacement rdf:type rdf:Property ;
    rdfs:label 'Credit Placement' ;
    rdfs:comment 'Specifies where the credit must appear: opening credits, closing credits, both, or promotional materials only.' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Credit Source System' ;
    rdfs:comment 'The operational system of record from which this credit attribution was sourced (e.g., Dalet Galaxy, Rightsline, production management system).' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditText rdf:type rdf:Property ;
    rdfs:label 'Credit Text' ;
    rdfs:comment 'The exact contractually mandated credit language or text that must appear on screen or in promotional materials (e.g., \'Directed by\', \'Written by\', \'Starring\', \'A Film By\', \'Executive Producer\').' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditWaiverFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Waiver Flag' ;
    rdfs:comment 'Indicates whether the talent has waived their contractual right to receive this credit (e.g., for creative or personal reasons).' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditWaiverReason rdf:type rdf:Property ;
    rdfs:label 'Credit Waiver Reason' ;
    rdfs:comment 'The documented reason for the credit waiver, if applicable (e.g., \'Creative decision\', \'Pseudonym requested\', \'Guild arbitration outcome\').' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgDisplayFlag rdf:type rdf:Property ;
    rdfs:label 'Epg Display Flag' ;
    rdfs:comment 'Indicates whether this credit should be displayed in the Electronic Program Guide (EPG) metadata for linear and on-demand platforms.' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:possessoryCreditFlag rdf:type rdf:Property ;
    rdfs:label 'Possessory Credit Flag' ;
    rdfs:comment 'Indicates whether this is a possessory credit (e.g., \'A Film By [Name]\'), which is a special contractual entitlement typically reserved for directors or executive producers with significant creative control.' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalMaterialsFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Materials Flag' ;
    rdfs:comment 'Indicates whether this credit must appear in promotional materials (posters, trailers, advertisements) as contractually required.' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pseudonym rdf:type rdf:Property ;
    rdfs:label 'Pseudonym' ;
    rdfs:comment 'The pseudonym or stage name to be used in the credit if the talent does not wish to use their legal name (e.g., \'Alan Smithee\' for directors, pen names for writers).' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamingMetadataFlag rdf:type rdf:Property ;
    rdfs:label 'Streaming Metadata Flag' ;
    rdfs:comment 'Indicates whether this credit should be included in streaming platform metadata (e.g., Netflix, Hulu, Disney+) for title cards and cast/crew information.' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityClauseId rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Clause Id' ;
    rdfs:comment 'Unique identifier for the exclusivity clause record. Primary key.' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Breach Incident Count' ;
    rdfs:comment 'The cumulative number of times the talent has breached this exclusivity clause. Used to track compliance history and inform enforcement decisions.' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clauseNumber rdf:type rdf:Property ;
    rdfs:label 'Clause Number' ;
    rdfs:comment 'The business identifier or reference number assigned to this exclusivity clause within the contract document (e.g., Section 5.2, Clause EX-001). Used for legal and operational reference.' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityType rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Type' ;
    rdfs:comment 'The category of exclusivity restriction imposed by this clause. Category exclusivity restricts talent from working in specific content genres or categories. Network exclusivity restricts talent from appearing on competing networks. Platform exclusivity restricts talent from appearing on competing streaming or distribution platforms. Geographic exclusivity restricts talent from working in specific territories. Time exclusivity restricts talent during specific dayparts or time windows. Project exclusivity restricts talent from working on competing projects or productions.' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Holdback Window End Date' ;
    rdfs:comment 'The date on which the exclusivity or holdback restriction expires. After this date, the talent is no longer bound by the exclusivity terms of this clause. Nullable for open-ended or perpetual exclusivity.' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdbackWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Holdback Window Start Date' ;
    rdfs:comment 'The date on which the exclusivity or holdback restriction becomes effective. Marks the beginning of the period during which the talent is bound by the exclusivity terms.' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed Flag' ;
    rdfs:comment 'Boolean indicator of whether this exclusivity clause has been reviewed and approved by legal counsel. True indicates legal review is complete; False indicates pending or no review.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyProvision rdf:type rdf:Property ;
    rdfs:label 'Penalty Provision' ;
    rdfs:comment 'Detailed description of the financial or contractual penalties that apply if the talent breaches the exclusivity clause. May include liquidated damages amounts, contract termination rights, or other remedies available to the broadcaster.' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedCarveoutActivities rdf:type rdf:Property ;
    rdfs:label 'Permitted Carveout Activities' ;
    rdfs:comment 'Textual description of specific activities, roles, or engagements that are explicitly exempted or carved out from the exclusivity restriction. Examples include charity appearances, personal social media, pre-existing commitments, or non-competing content categories.' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedCompetitorList rdf:type rdf:Property ;
    rdfs:label 'Restricted Competitor List' ;
    rdfs:comment 'Comma-separated or structured list of specific competitors, networks, platforms, or entities with whom the talent is prohibited from engaging during the exclusivity period. May include network names, streaming platform identifiers, production company names, or brand names.' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverGrantedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Date' ;
    rdfs:comment 'The date on which a waiver or exception to the exclusivity clause was officially granted. Nullable if no waiver has been granted.' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guildAffiliationId rdf:type rdf:Property ;
    rdfs:label 'Guild Affiliation Id' ;
    rdfs:comment 'Unique identifier for the guild affiliation record. Primary key.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuildAffiliation .

ind:cbaEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Cba Effective Date' ;
    rdfs:comment 'Date when the current collective bargaining agreement became effective for this membership.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cbaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Cba Expiration Date' ;
    rdfs:comment 'Date when the current collective bargaining agreement expires. Used to track contract renewal cycles and potential rate changes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:duesPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Dues Payment Status' ;
    rdfs:comment 'Current status of membership dues payment obligations. Current (all dues paid up to date), overdue (payment past due but within grace period), delinquent (significantly past due, may affect standing), exempt (not required to pay dues), waived (dues forgiven by guild).' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildName rdf:type rdf:Property ;
    rdfs:label 'Guild Name' ;
    rdfs:comment 'Full legal name of the guild or union organization.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthBenefitsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Health Benefits Eligible Flag' ;
    rdfs:comment 'Indicates whether the talent is eligible for guild-provided health insurance benefits based on this membership and earnings thresholds. True if eligible, false otherwise.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:joinDate rdf:type rdf:Property ;
    rdfs:label 'Join Date' ;
    rdfs:comment 'Date when the talent officially became a member of this guild. Used to determine seniority and eligibility for certain benefits.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDuesPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Dues Payment Date' ;
    rdfs:comment 'Date of the most recent membership dues payment received by the guild.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipNumber rdf:type rdf:Property ;
    rdfs:label 'Membership Number' ;
    rdfs:comment 'Unique membership identifier assigned by the guild to the talent member. Required for residual payment processing and production compliance verification.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current standing of the talent within the guild. Good standing (active member in compliance), suspended (temporarily barred due to dues or violations), resigned (voluntarily terminated membership), expelled (involuntarily removed), inactive (not currently active but not terminated), pending (application under review).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipTier rdf:type rdf:Property ;
    rdfs:label 'Membership Tier' ;
    rdfs:comment 'Classification of membership level within the guild. Full member (standard active membership with full benefits), fi-core (financial core member with limited participation), apprentice (trainee or provisional member), honorary (recognition membership), lifetime (permanent membership status), emeritus (retired member with recognition).' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDuesPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Next Dues Payment Date' ;
    rdfs:comment 'Date when the next membership dues payment is due.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pensionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Pension Eligible Flag' ;
    rdfs:comment 'Indicates whether the talent is eligible for guild pension plan contributions and benefits. True if eligible, false otherwise.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pensionHealthContributionId rdf:type rdf:Property ;
    rdfs:label 'Pension Health Contribution Id' ;
    rdfs:comment 'Unique identifier for the pension and health contribution record.' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contributionPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Contribution Period End Date' ;
    rdfs:comment 'The end date of the earnings period for which this pension and health contribution is calculated.' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Contribution Period Start Date' ;
    rdfs:comment 'The start date of the earnings period for which this pension and health contribution is calculated.' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contribution Reference Number' ;
    rdfs:comment 'External reference number assigned by the guild benefit fund for tracking and reconciliation purposes.' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionType rdf:type rdf:Property ;
    rdfs:label 'Contribution Type' ;
    rdfs:comment 'Classification of the contribution based on the nature of the underlying compensation (initial work, residual payment, reuse, etc.).' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'The dollar amount withheld from the talent\'s compensation and contributed to the guild benefit fund, if applicable.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeContributionRate rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Rate' ;
    rdfs:comment 'The percentage rate applied to the gross compensation base to calculate the employee\'s (talent\'s) pension and health contribution, if applicable.' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'The dollar amount contributed by the employer to the guild benefit fund on behalf of the talent.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionRate rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Rate' ;
    rdfs:comment 'The percentage rate applied to the gross compensation base to calculate the employer\'s pension and health contribution obligation.' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossCompensationBase rdf:type rdf:Property ;
    rdfs:label 'Gross Compensation Base' ;
    rdfs:comment 'The gross earnings amount upon which the pension and health contribution is calculated, before any deductions or adjustments.' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guildAcknowledgmentNumber rdf:type rdf:Property ;
    rdfs:label 'Guild Acknowledgment Number' ;
    rdfs:comment 'Confirmation or acknowledgment number provided by the guild benefit fund upon receipt and processing of the contribution.' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildFundCode rdf:type rdf:Property ;
    rdfs:label 'Guild Fund Code' ;
    rdfs:comment 'Code identifying the specific guild benefit fund to which the contribution is remitted (e.g., SAG-AFTRA Health Plan, SAG-Producers Pension Plan, DGA-Producer Pension and Health Plan, WGA Pension Plan). [ENUM-REF-CANDIDATE: SAG_HEALTH|SAG_PENSION|DGA_PENSION_HEALTH|WGA_PENSION|WGA_HEALTH|IATSE_PENSION|IATSE_HEALTH|AFM_PENSION|AFM_HEALTH — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildFundName rdf:type rdf:Property ;
    rdfs:label 'Guild Fund Name' ;
    rdfs:comment 'Full name of the guild benefit fund receiving the contribution.' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latePaymentPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Amount' ;
    rdfs:comment 'Penalty amount assessed by the guild benefit fund for late remittance of the contribution, if applicable.' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Due Date' ;
    rdfs:comment 'The contractual due date by which the contribution must be remitted to the guild benefit fund to avoid penalties.' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Contribution Amount' ;
    rdfs:comment 'The combined total of employer and employee contributions remitted to the guild benefit fund for this contribution record.' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workType rdf:type rdf:Property ;
    rdfs:label 'Work Type' ;
    rdfs:comment 'The type of work performed by the talent that generated the compensation base for this contribution.' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Representation Agreement Id' ;
    rdfs:comment 'Unique identifier for the representation agreement record. Primary key.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:talentAgencyId rdf:type rdf:Property ;
    rdfs:label 'Talent Agency Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_agency. Business justification: representation_agreement currently has agency_name (STRING) duplicating data from talent_agency. Adding FK enables normalization - agency legal name, DBA name, contact details, and franchise status sh' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentAgency .

ind:agentContactEmail rdf:type rdf:Property ;
    rdfs:label 'Agent Contact Email' ;
    rdfs:comment 'Primary email address for the agent or representative, used for deal negotiation and residual routing communications.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentContactPhone rdf:type rdf:Property ;
    rdfs:label 'Agent Contact Phone' ;
    rdfs:comment 'Primary phone number for the agent or representative.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentName rdf:type rdf:Property ;
    rdfs:label 'Agent Name' ;
    rdfs:comment 'Full name of the individual agent, manager, or attorney assigned as primary contact for this representation.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionCapAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Cap Amount' ;
    rdfs:comment 'Maximum commission amount per engagement or per year, if a cap is specified in the agreement. Null if no cap applies.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionPercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Percentage' ;
    rdfs:comment 'Percentage of talent earnings paid to the representative as commission (typically 10% for agents, 15% for managers per industry standards).' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDocumentUri rdf:type rdf:Property ;
    rdfs:label 'Contract Document Uri' ;
    rdfs:comment 'URI or file path to the signed representation agreement contract document stored in the Media Asset Management (MAM) system or document repository.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildFranchiseFlag rdf:type rdf:Property ;
    rdfs:label 'Guild Franchise Flag' ;
    rdfs:comment 'Indicates whether the agency or representative is franchised by a talent guild (SAG-AFTRA, WGA, DGA). Franchised agents must comply with guild-mandated commission caps and contract terms.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:representationAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Representation Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the representation agreement: active (in force), expired (end date reached), terminated (ended early by either party), suspended (temporarily inactive), or pending (signed but not yet effective).' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representationType rdf:type rdf:Property ;
    rdfs:label 'Representation Type' ;
    rdfs:comment 'Classification of the representation relationship: exclusive agent (sole representation), co-agent (shared representation), manager (career management), entertainment attorney (legal counsel), business manager (financial management), or publicist (public relations).' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRoutingFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Routing Flag' ;
    rdfs:comment 'Indicates whether residual payments for work performed during this representation period should be routed through this representative for commission deduction.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeOfServices rdf:type rdf:Property ;
    rdfs:label 'Scope Of Services' ;
    rdfs:comment 'Detailed description of services the representative will provide: deal negotiation, career guidance, audition scheduling, contract review, brand partnerships, etc.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingDate rdf:type rdf:Property ;
    rdfs:label 'Signing Date' ;
    rdfs:comment 'Date when the representation agreement was signed by both parties.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the representation agreement (commonly 30, 60, or 90 days).' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Residual Eligibility Id' ;
    rdfs:comment 'Unique identifier for the residual eligibility record.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResidualEligibility .

ind:buyoutAmount rdf:type rdf:Property ;
    rdfs:label 'Buyout Amount' ;
    rdfs:comment 'The one-time payment amount paid to the talent in lieu of ongoing residual payments for specified uses, if a buyout was applied.' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyoutApplied rdf:type rdf:Property ;
    rdfs:label 'Buyout Applied' ;
    rdfs:comment 'Indicates whether a residual buyout was negotiated and applied, eliminating ongoing residual payment obligations for specified uses.' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Determination Date' ;
    rdfs:comment 'The date on which residual eligibility was determined and recorded for this talent and content asset.' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Status' ;
    rdfs:comment 'Current status of the residual eligibility determination for this talent-content-use combination.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityClauseApplies rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Clause Applies' ;
    rdfs:comment 'Indicates whether an exclusivity clause in the talent contract affects residual eligibility or payment terms for this content asset.' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthContributionApplicable rdf:type rdf:Property ;
    rdfs:label 'Health Contribution Applicable' ;
    rdfs:comment 'Indicates whether health and welfare contributions are required to be calculated and remitted based on this residual payment per guild agreement.' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthContributionRate rdf:type rdf:Property ;
    rdfs:label 'Health Contribution Rate' ;
    rdfs:comment 'The percentage rate applied to the residual payment for health and welfare fund contribution calculation.' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumResidualThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Residual Threshold' ;
    rdfs:comment 'The minimum payment amount below which residuals are not processed or paid, as defined by guild rules or contract terms.' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pensionContributionApplicable rdf:type rdf:Property ;
    rdfs:label 'Pension Contribution Applicable' ;
    rdfs:comment 'Indicates whether pension contributions are required to be calculated and remitted based on this residual payment per guild agreement.' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pensionContributionRate rdf:type rdf:Property ;
    rdfs:label 'Pension Contribution Rate' ;
    rdfs:comment 'The percentage rate applied to the residual payment for pension fund contribution calculation.' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Residual Base Amount' ;
    rdfs:comment 'The base monetary amount used as the foundation for residual calculation, typically derived from the original compensation or a guild-defined minimum.' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualFormulaType rdf:type rdf:Property ;
    rdfs:label 'Residual Formula Type' ;
    rdfs:comment 'The specific residual calculation formula applicable to this eligibility record, determined by guild agreement, content type, and distribution channel.' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualPercentage rdf:type rdf:Property ;
    rdfs:label 'Residual Percentage' ;
    rdfs:comment 'The percentage of the base amount payable as residual for this specific use, as defined by guild agreement or contract negotiation.' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rightslineIntegrationCode rdf:type rdf:Property ;
    rdfs:label 'Rightsline Integration Code' ;
    rdfs:comment 'External identifier used to link this residual eligibility record to the Rightsline rights and royalties management system for automated royalty calculation workflow.' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPayablesReference rdf:type rdf:Property ;
    rdfs:label 'Sap Payables Reference' ;
    rdfs:comment 'Reference identifier linking this residual eligibility to SAP S/4HANA accounts payable processing for payment execution.' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useType rdf:type rdf:Property ;
    rdfs:label 'Use Type' ;
    rdfs:comment 'The type of content usage that triggers residual payment eligibility (Rerun, Foreign Broadcast, Home Video, Subscription Video On Demand, Advertising-Supported Video On Demand, Transactional Video On Demand, Free Ad-Supported Streaming Television, Theatrical, Syndication, or Clip Use). [ENUM-REF-CANDIDATE: Rerun|Foreign Broadcast|Home Video|SVOD|AVOD|TVOD|FAST|Theatrical|Syndication|Clip Use — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualPaymentId rdf:type rdf:Property ;
    rdfs:label 'Residual Payment Id' ;
    rdfs:comment 'Unique identifier for the residual payment transaction.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentCycleId rdf:type rdf:Property ;
    rdfs:label 'Payment Cycle Id' ;
    rdfs:comment 'Reference to the payment cycle or batch in which this residual was processed.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cycle .

ind:achTraceNumber rdf:type rdf:Property ;
    rdfs:label 'Ach Trace Number' ;
    rdfs:comment 'The ACH trace number if the payment method is ACH or direct deposit, used for reconciliation and audit.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Agent Commission Amount' ;
    rdfs:comment 'The agent or manager commission amount deducted from the residual payment, if applicable.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditReportDate rdf:type rdf:Property ;
    rdfs:label 'Audit Report Date' ;
    rdfs:comment 'The date on which this residual payment was included in a guild audit report.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditReportFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Report Flag' ;
    rdfs:comment 'Indicates whether this residual payment has been included in a guild audit report (SAG-AFTRA, WGA, DGA).' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exhibitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Exhibition End Date' ;
    rdfs:comment 'The end date of the exhibition period for which this residual is calculated.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exhibitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Exhibition Start Date' ;
    rdfs:comment 'The start date of the exhibition period for which this residual is calculated.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossResidualAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Residual Amount' ;
    rdfs:comment 'The gross residual amount calculated before deductions, in the payment currency.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDeductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Other Deductions Amount' ;
    rdfs:comment 'Any other deductions applied to the residual payment (e.g., union dues, garnishments, advances).' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the residual payment (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pensionHealthAmount rdf:type rdf:Property ;
    rdfs:label 'Pension Health Amount' ;
    rdfs:comment 'The pension and health contribution amount deducted from the gross residual, as required by guild agreements.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceAdviceSentDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Sent Date' ;
    rdfs:comment 'The date on which the remittance advice was sent to the talent.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remittanceAdviceSentFlag rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Sent Flag' ;
    rdfs:comment 'Indicates whether a remittance advice document was sent to the talent for this payment.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyCalculationReference rdf:type rdf:Property ;
    rdfs:label 'Royalty Calculation Reference' ;
    rdfs:comment 'Reference to the Rightsline royalty calculation record that generated this residual payment.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wireReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Wire Reference Number' ;
    rdfs:comment 'The wire transfer reference number if the payment method is wire transfer, used for reconciliation and audit.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'The trade name or doing-business-as name under which the agency operates, if different from the legal name.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'The date on which the talent agency was originally established or incorporated.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'The fax number for the agency, used for contract transmission and official correspondence in jurisdictions where fax is still required.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Effective Date' ;
    rdfs:comment 'The date on which the SAG-AFTRA franchise agreement became effective for this agency.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Expiration Date' ;
    rdfs:comment 'The date on which the current SAG-AFTRA franchise agreement expires and must be renewed.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseNumber rdf:type rdf:Property ;
    rdfs:label 'Franchise Number' ;
    rdfs:comment 'The unique franchise identification number issued by SAG-AFTRA to franchised talent agencies.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseStatus rdf:type rdf:Property ;
    rdfs:label 'Franchise Status' ;
    rdfs:comment 'Indicates whether the agency holds a valid SAG-AFTRA franchise agreement, which authorizes the agency to represent union talent. Franchised agencies agree to standard commission rates and contract terms.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'License Effective Date' ;
    rdfs:comment 'The date on which the state talent agency license became effective.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'License Expiration Date' ;
    rdfs:comment 'The date on which the state talent agency license expires and must be renewed.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseState rdf:type rdf:Property ;
    rdfs:label 'License State' ;
    rdfs:comment 'The state or province that issued the talent agency license. Use standard two-letter state/province codes.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'The job title or role of the primary contact person (e.g., President, Partner, Agent, Business Affairs Manager).' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'The primary email address for official correspondence, contract delivery, and residual payment notifications.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'The primary telephone number for the agency, including country and area codes.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterSize rdf:type rdf:Property ;
    rdfs:label 'Roster Size' ;
    rdfs:comment 'The approximate number of talent clients currently represented by the agency. Used for agency scale assessment and negotiation context.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialization rdf:type rdf:Property ;
    rdfs:label 'Specialization' ;
    rdfs:comment 'The primary area of talent specialization or focus for the agency (e.g., film and television actors, commercial talent, voice-over artists, writers, directors, below-the-line crew, music artists). Free-text field to accommodate multiple specializations.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Standard Commission Rate' ;
    rdfs:comment 'The standard commission rate percentage that the agency charges for talent representation, typically 10% for franchised agencies under SAG-AFTRA rules. Expressed as a percentage (e.g., 10.00 for 10%).' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Status Effective Date' ;
    rdfs:comment 'The date on which the current status became effective.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:talentAgencyStatus rdf:type rdf:Property ;
    rdfs:label 'Talent Agency Status' ;
    rdfs:comment 'The current operational status of the talent agency: active (currently representing talent), inactive (not currently operating), suspended (temporarily not authorized), pending_verification (under review), or dissolved (permanently closed).' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityId rdf:type rdf:Property ;
    rdfs:label 'Availability Id' ;
    rdfs:comment 'Unique identifier for the talent availability record. Primary key.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityType rdf:type rdf:Property ;
    rdfs:label 'Availability Type' ;
    rdfs:comment 'Classification of the availability status: available (talent is free), hold (production has placed a hold), first_refusal (talent has granted first right to book), confirmed_booking (talent is booked), personal_unavailability (talent is unavailable for personal reasons), conflicting_production (talent is committed to another production).' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingConfirmedDate rdf:type rdf:Property ;
    rdfs:label 'Booking Confirmed Date' ;
    rdfs:comment 'The date when the booking was confirmed and the talent was officially committed to the production. Null if not yet confirmed.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictProductionNetwork rdf:type rdf:Property ;
    rdfs:label 'Conflict Production Network' ;
    rdfs:comment 'Network or studio associated with the conflicting production. Used to identify potential exclusivity clause violations.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictProductionTitle rdf:type rdf:Property ;
    rdfs:label 'Conflict Production Title' ;
    rdfs:comment 'Title of the conflicting production when availability_type is conflicting_production. Null if not applicable.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Hold Expiration Date' ;
    rdfs:comment 'The date by which the production must confirm the booking or the hold will expire. Null if not applicable.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdPlacedDate rdf:type rdf:Property ;
    rdfs:label 'Hold Placed Date' ;
    rdfs:comment 'The date when the hold was initially placed on the talent. Null if availability_type is not hold or first_refusal.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdReleasedDate rdf:type rdf:Property ;
    rdfs:label 'Hold Released Date' ;
    rdfs:comment 'The date when the hold was released or dropped by the requesting production. Null if hold was not released.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Requesting Contact Email' ;
    rdfs:comment 'Email address of the production contact who placed the availability request.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Requesting Contact Phone' ;
    rdfs:comment 'Phone number of the production contact who placed the availability request.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingProducerName rdf:type rdf:Property ;
    rdfs:label 'Requesting Producer Name' ;
    rdfs:comment 'Name of the producer or production manager who requested the availability hold or booking.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentClearanceId rdf:type rdf:Property ;
    rdfs:label 'Talent Clearance Id' ;
    rdfs:comment 'Unique identifier for the talent clearance record. Primary key.' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearedMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Cleared Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Talent clearances are often asset-specific (theatrical cut vs TV edit, domestic vs international versions, trailer vs feature). Different assets may require separate clearances based on usage rights, ' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:requestedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requested By User Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Production or legal employees request talent clearances. Supports clearance workflow tracking, workload analysis, compliance audits, and accountability. Column requested_by_user is denormalized employ' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:usageRightId rdf:type rdf:Property ;
    rdfs:label 'Usage Right Id' ;
    rdfs:comment 'Foreign key linking to talent.usage_right. Business justification: talent_clearance records the rights verification process for talent usage. usage_right defines the granted rights with usage_scope, territory, platform, and window dates. Currently clearance has usage' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UsageRight .

ind:grantedBy rdf:type rdf:Property ;
    rdfs:label 'Granted By' ;
    rdfs:comment 'Name or identifier of the individual or department who authorized the clearance.' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantedDate rdf:type rdf:Property ;
    rdfs:label 'Granted Date' ;
    rdfs:comment 'Date when the clearance was officially approved and granted for the specified usage.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Guild Clearance Required Flag' ;
    rdfs:comment 'Indicates whether guild or union clearance is required based on collective bargaining agreement terms.' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guildClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Guild Clearance Status' ;
    rdfs:comment 'Current status of guild or union clearance verification for this usage.' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Guild Reference Number' ;
    rdfs:comment 'Reference or tracking number provided by the guild or union for this clearance request.' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:likenessUsageFlag rdf:type rdf:Property ;
    rdfs:label 'Likeness Usage Flag' ;
    rdfs:comment 'Indicates whether the clearance includes usage of the talent\'s physical likeness or image.' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nameUsageFlag rdf:type rdf:Property ;
    rdfs:label 'Name Usage Flag' ;
    rdfs:comment 'Indicates whether the clearance includes usage of the talent\'s name in promotional or marketing materials.' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceUsageFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Usage Flag' ;
    rdfs:comment 'Indicates whether the clearance includes usage of the talent\'s recorded performance or voice.' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualPaymentTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Payment Triggered Flag' ;
    rdfs:comment 'Indicates whether this clearance triggers residual payment obligations under guild agreements.' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewedByLegalFlag rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Legal Flag' ;
    rdfs:comment 'Indicates whether the clearance request has been reviewed and approved by the legal department.' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:talentApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Talent Approval Date' ;
    rdfs:comment 'Date when the talent provided their explicit approval or consent for the specified usage.' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:talentApprovalReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Talent Approval Received Flag' ;
    rdfs:comment 'Indicates whether the required talent approval has been obtained and documented.' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:talentApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Talent Approval Required Flag' ;
    rdfs:comment 'Indicates whether explicit talent consent or approval is required before usage can proceed.' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageCategory rdf:type rdf:Property ;
    rdfs:label 'Usage Category' ;
    rdfs:comment 'Classification of the intended usage based on broadcast and distribution business models.' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financeProductionBudgetId rdf:type rdf:Property ;
    rdfs:label 'Finance Production Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.production_budget. Business justification: Talent contracts are charged against production budgets for cost control, variance analysis, and financial reporting. Every above-the-line deal must track to a specific budget for production accountin' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionBudget .

ind:backendParticipationPercentage rdf:type rdf:Property ;
    rdfs:label 'Backend Participation Percentage' ;
    rdfs:comment 'The percentage of net profits, adjusted gross, or other revenue streams the talent is entitled to receive after recoupment of production costs. Common for above-the-line talent.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backendParticipationType rdf:type rdf:Property ;
    rdfs:label 'Backend Participation Type' ;
    rdfs:comment 'The revenue calculation basis for backend participation. Net profits are after all costs; adjusted gross is after specific deductions; gross receipts are from first dollar. None indicates no backend participation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Base Compensation Amount' ;
    rdfs:comment 'The guaranteed base fee or salary payable to the talent for services rendered under this contract, excluding bonuses, backend participation, and residuals.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCreditPosition rdf:type rdf:Property ;
    rdfs:label 'Billing Credit Position' ;
    rdfs:comment 'The contractually specified position and format of the talent\'s on-screen credit (e.g., \'First Position Main Title\', \'Shared Card\', \'Single Card\', \'Above the Title\'). Critical for talent reputation and guild compliance.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the base compensation amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationStructure rdf:type rdf:Property ;
    rdfs:label 'Compensation Structure' ;
    rdfs:comment 'The payment model for the base compensation. Flat fee is a single lump sum; per-episode is paid per episode produced; weekly/annual/day/hourly rates define periodic payment schedules.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current stage of the contract in its lifecycle. Deal memo represents initial short-form agreement; countersigned indicates mutual acceptance; long-form executed is the final detailed contract; amended reflects modifications; suspended indicates temporary hold; terminated is early cancellation; expired is natural end. [ENUM-REF-CANDIDATE: deal_memo|countersigned|long_form_executed|amended|suspended|terminated|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditPlacementRequirements rdf:type rdf:Property ;
    rdfs:label 'Credit Placement Requirements' ;
    rdfs:comment 'Detailed contractual requirements for credit placement, including main title vs end credits, paid advertising inclusion, promotional materials, and any special formatting or adjacency requirements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditSizePercentage rdf:type rdf:Property ;
    rdfs:label 'Credit Size Percentage' ;
    rdfs:comment 'The minimum size of the talent\'s on-screen credit as a percentage of the title or other reference credit size. Null if not contractually specified.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementRole rdf:type rdf:Property ;
    rdfs:label 'Engagement Role' ;
    rdfs:comment 'The specific role or position the talent is contracted to perform (e.g., Lead Actor, Director, Showrunner, Writer, Executive Producer, Director of Photography, Host).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingCba rdf:type rdf:Property ;
    rdfs:label 'Governing Cba' ;
    rdfs:comment 'The specific collective bargaining agreement that governs this contract, including version and effective date (e.g., SAG-AFTRA Television Agreement 2020-2023). Defines minimum compensation, working conditions, and residual structures.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedEpisodes rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Episodes' ;
    rdfs:comment 'The minimum number of episodes for which the talent is guaranteed compensation, regardless of actual production. Common in series regular deals. Null for non-episodic contracts.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optionExerciseStatus rdf:type rdf:Property ;
    rdfs:label 'Option Exercise Status' ;
    rdfs:comment 'Current status of the most recent option period. Not applicable if no options exist; pending if decision deadline has not passed; exercised if company extended; declined if company chose not to extend; expired if deadline passed without action.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionPeriodsCount rdf:type rdf:Property ;
    rdfs:label 'Option Periods Count' ;
    rdfs:comment 'The number of option periods (typically annual) the company holds to extend the contract beyond the initial term. Common in series regular and overall deals.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealMemoId rdf:type rdf:Property ;
    rdfs:label 'Deal Memo Id' ;
    rdfs:comment 'Unique identifier for the talent deal memo record. Primary key.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:longFormContractId rdf:type rdf:Property ;
    rdfs:label 'Long Form Contract Id' ;
    rdfs:comment 'Reference to the executed long-form talent contract that supersedes this deal memo. Null if the long-form contract has not yet been executed.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:compensationAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount' ;
    rdfs:comment 'The primary monetary compensation amount agreed in the deal memo (e.g., total fee, per-episode rate, or guaranteed minimum).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationSummary rdf:type rdf:Property ;
    rdfs:label 'Compensation Summary' ;
    rdfs:comment 'High-level summary of the compensation structure agreed in the deal memo (e.g., per-episode fee, flat fee, day rate, backend participation). Detailed breakdowns are captured in the long-form contract.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countersignedDate rdf:type rdf:Property ;
    rdfs:label 'Countersigned Date' ;
    rdfs:comment 'The date on which the deal memo was countersigned by both the talent (or agent) and the production company, making it a binding interim agreement. Null if not yet countersigned.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealDate rdf:type rdf:Property ;
    rdfs:label 'Deal Date' ;
    rdfs:comment 'The date on which the deal terms were verbally agreed or the deal memo was initially drafted.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Deal Memo Number' ;
    rdfs:comment 'Externally-known unique business identifier for the deal memo, typically generated by the CRM or legal system.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealMemoStatus rdf:type rdf:Property ;
    rdfs:label 'Deal Memo Status' ;
    rdfs:comment 'Current lifecycle status of the deal memo: draft (under negotiation), countersigned (binding interim agreement), superseded_by_long_form (replaced by executed contract), expired (lapsed without execution), cancelled (deal fell through).' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementEndDate rdf:type rdf:Property ;
    rdfs:label 'Engagement End Date' ;
    rdfs:comment 'The date on which the talent engagement is scheduled to end. Null for open-ended or option-based engagements.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementStartDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Date' ;
    rdfs:comment 'The date on which the talent engagement is scheduled to begin (first day of work, rehearsal, or availability).' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivitySummary rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Summary' ;
    rdfs:comment 'High-level summary of exclusivity terms (e.g., exclusive to network during production, non-exclusive, first-look, holdback period). Detailed clauses are in the long-form contract.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionTerms rdf:type rdf:Property ;
    rdfs:label 'Option Terms' ;
    rdfs:comment 'Summary of any option clauses (e.g., network option for additional seasons, talent option to extend, mutual option). Null if no options are included.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleFunction rdf:type rdf:Property ;
    rdfs:label 'Role Function' ;
    rdfs:comment 'The specific role or function the talent will perform (e.g., Lead Actor, Director, Writer, Executive Producer, Host, Correspondent, Camera Operator).' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededDate rdf:type rdf:Property ;
    rdfs:label 'Superseded Date' ;
    rdfs:comment 'The date on which the deal memo was superseded by the execution of a long-form contract. Null if not yet superseded.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:talentGrievanceId rdf:type rdf:Property ;
    rdfs:label 'Talent Grievance Id' ;
    rdfs:comment 'Unique identifier for the talent grievance record. Primary key.' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arbitrationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Arbitration Reference Number' ;
    rdfs:comment 'Unique reference number assigned by the arbitration body or guild for tracking this grievance through the dispute resolution process.' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitratorName rdf:type rdf:Property ;
    rdfs:label 'Arbitrator Name' ;
    rdfs:comment 'Name of the arbitrator or mediator assigned to hear and decide this grievance.' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Flag' ;
    rdfs:comment 'Indicates whether this grievance is subject to confidentiality or non-disclosure provisions (True if confidential, False if not).' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputedCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Disputed Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the disputed amount (e.g., USD, GBP, CAD).' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPartyName rdf:type rdf:Property ;
    rdfs:label 'Filing Party Name' ;
    rdfs:comment 'Name of the individual or organization that filed the grievance.' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPartyType rdf:type rdf:Property ;
    rdfs:label 'Filing Party Type' ;
    rdfs:comment 'Type of entity that initiated the grievance: talent (individual), guild (on behalf of member), production company, network, or studio.' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceDescription rdf:type rdf:Property ;
    rdfs:label 'Grievance Description' ;
    rdfs:comment 'Detailed narrative description of the grievance, including the nature of the dispute, alleged violations, and relief sought.' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceNumber rdf:type rdf:Property ;
    rdfs:label 'Grievance Number' ;
    rdfs:comment 'Externally-known unique business identifier for this grievance, used in legal correspondence and guild communications.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceType rdf:type rdf:Property ;
    rdfs:label 'Grievance Type' ;
    rdfs:comment 'Classification of the grievance by subject matter: compensation dispute, credit dispute, working condition violation, residual underpayment, exclusivity breach, or contract breach.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildRepresentativeContact rdf:type rdf:Property ;
    rdfs:label 'Guild Representative Contact' ;
    rdfs:comment 'Contact information (email or phone) for the guild representative managing this grievance.' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Guild Representative Name' ;
    rdfs:comment 'Name of the guild representative or business agent handling this grievance on behalf of the talent.' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hearingDate rdf:type rdf:Property ;
    rdfs:label 'Hearing Date' ;
    rdfs:comment 'Scheduled or actual date of the arbitration hearing or mediation session for this grievance.' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalCounselName rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Name' ;
    rdfs:comment 'Name of the legal counsel or attorney representing the filing party in this grievance.' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionTitle rdf:type rdf:Property ;
    rdfs:label 'Production Title' ;
    rdfs:comment 'Title of the production (film, series, episode) to which this grievance relates, if applicable.' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondingPartyName rdf:type rdf:Property ;
    rdfs:label 'Responding Party Name' ;
    rdfs:comment 'Name of the individual or organization against whom the grievance was filed.' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondingPartyType rdf:type rdf:Property ;
    rdfs:label 'Responding Party Type' ;
    rdfs:comment 'Type of entity against whom the grievance was filed: talent (individual), guild, production company, network, or studio.' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'Monetary amount agreed upon or awarded as part of the grievance settlement or arbitration award, if applicable.' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the settlement amount (e.g., USD, GBP, CAD).' ;
    rdfs:domain ind:TalentGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biometricConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Consent Flag' ;
    rdfs:comment 'Indicates whether the talent has provided consent for collection and use of biometric data (facial recognition, voice prints) for digital effects, deepfake prevention, and AI training. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderIdentity rdf:type rdf:Property ;
    rdfs:label 'Gender Identity' ;
    rdfs:comment 'The talent\'s self-identified gender. Used for diversity reporting, casting analytics, and compliance with equal opportunity regulations.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdbIdentifier rdf:type rdf:Property ;
    rdfs:label 'Imdb Identifier' ;
    rdfs:comment 'The talent\'s unique identifier in the Internet Movie Database (IMDb). Used for cross-referencing filmography, public profile linking, and industry data integration.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Flag' ;
    rdfs:comment 'Indicates whether the talent is currently covered by production insurance (liability, workers compensation, errors and omissions). Required for on-set work authorization.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isniCode rdf:type rdf:Property ;
    rdfs:label 'Isni Code' ;
    rdfs:comment 'The International Standard Name Identifier (ISNI) for the talent. A globally unique identifier for creators used in rights management and royalty distribution systems.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'The talent\'s nationality represented as a 3-letter ISO country code. Used for work authorization, tax treaty eligibility, and international co-production compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageName rdf:type rdf:Property ;
    rdfs:label 'Stage Name' ;
    rdfs:comment 'The professional or stage name used by the talent for public appearances, credits, and marketing materials. May differ from legal name.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentTier rdf:type rdf:Property ;
    rdfs:label 'Talent Tier' ;
    rdfs:comment 'The classification tier of the talent based on industry recognition, box office draw, and compensation level. Used for budgeting, marketing strategy, and billing rate determination.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentType rdf:type rdf:Property ;
    rdfs:label 'Talent Type' ;
    rdfs:comment 'The primary professional category or role type of the talent. Determines applicable guild rules, contract templates, and credit attribution standards. [ENUM-REF-CANDIDATE: actor|director|writer|producer|host|correspondent|crew|voice_artist|composer|cinematographer — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionAffiliation rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation' ;
    rdfs:comment 'The primary labor union or guild affiliation of the talent. Determines contract terms, minimum compensation, residual eligibility, and working conditions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMemberNumber rdf:type rdf:Property ;
    rdfs:label 'Union Member Number' ;
    rdfs:comment 'The talent\'s membership identifier within their primary union or guild. Required for residual payment processing and contract compliance verification.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Status' ;
    rdfs:comment 'The talent\'s current work authorization status in the primary production jurisdiction. Determines eligibility for employment and production participation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workVisaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Work Visa Expiration Date' ;
    rdfs:comment 'The expiration date of the talent\'s work visa. Critical for production scheduling and compliance with immigration regulations.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workVisaType rdf:type rdf:Property ;
    rdfs:label 'Work Visa Type' ;
    rdfs:comment 'The specific type of work visa held by the talent (e.g., O-1, P-1, H-1B). Used for compliance tracking and production planning for international talent.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aboveTheLineFlag rdf:type rdf:Property ;
    rdfs:label 'Above The Line Flag' ;
    rdfs:comment 'Indicates whether this role is classified as above-the-line (creative principals: actors, directors, writers, producers) or below-the-line (technical crew and support staff). Impacts budget allocation and residual calculations.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appearanceCount rdf:type rdf:Property ;
    rdfs:label 'Appearance Count' ;
    rdfs:comment 'Total number of episodes, segments, or appearances in which this talent role is featured. Used for episodic and recurring roles.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:characterName rdf:type rdf:Property ;
    rdfs:label 'Character Name' ;
    rdfs:comment 'The name of the character portrayed by the talent for on-screen roles. Null for off-screen roles such as crew, directors, or producers.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeScopeEnd rdf:type rdf:Property ;
    rdfs:label 'Episode Scope End' ;
    rdfs:comment 'The last episode number in which this talent role appears. Null indicates ongoing engagement or single-episode appearance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeScopeStart rdf:type rdf:Property ;
    rdfs:label 'Episode Scope Start' ;
    rdfs:comment 'The first episode number in which this talent role appears. Used for episodic content to define the scope of the talent\'s engagement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Eligible Flag' ;
    rdfs:comment 'Indicates whether this role is eligible for residual payments based on subsequent distribution, reuse, or syndication of the content. Determined by guild agreements and contract terms.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualRateCode rdf:type rdf:Property ;
    rdfs:label 'Residual Rate Code' ;
    rdfs:comment 'Code identifying the residual payment rate schedule applicable to this role based on guild agreements, role category, and distribution windows.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleCategory rdf:type rdf:Property ;
    rdfs:label 'Role Category' ;
    rdfs:comment 'Classification of the role type indicating the nature and scope of the talent\'s engagement. Determines compensation structure, credit placement, and residual eligibility. [ENUM-REF-CANDIDATE: series_regular|recurring|guest_star|day_player|featured_extra|host|correspondent|narrator|voice_artist|director|writer|showrunner|executive_producer|line_producer|cinematographer|editor|composer|production_designer|costume_designer|makeup_artist|stunt_coordinator|other — promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleName rdf:type rdf:Property ;
    rdfs:label 'Role Name' ;
    rdfs:comment 'The specific role or function the talent is engaged to perform (e.g., Lead Actor, Director, Executive Producer, Cinematographer, Script Supervisor).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleStatus rdf:type rdf:Property ;
    rdfs:label 'Role Status' ;
    rdfs:comment 'Current lifecycle status of the talent role assignment indicating the stage of engagement from negotiation through completion. [ENUM-REF-CANDIDATE: confirmed|tentative|in_negotiation|contracted|active|completed|cancelled|suspended — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Screen Time Minutes' ;
    rdfs:comment 'Total on-screen time in minutes for this talent role across all appearances. Used for on-screen talent to measure prominence and for residual calculations.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stuntDoubleFlag rdf:type rdf:Property ;
    rdfs:label 'Stunt Double Flag' ;
    rdfs:comment 'Indicates whether this role involves stunt work or if a stunt double is used for this character. Impacts insurance, safety protocols, and credit attribution.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageRightsDurationYears rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Duration Years' ;
    rdfs:comment 'Number of years for which usage rights are granted. Null indicates perpetual rights.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageRightsMedia rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Media' ;
    rdfs:comment 'Media platforms and formats for which usage rights are granted (e.g., \'Theatrical, Home Video, Streaming, Broadcast TV\').' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsTerritory rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Territory' ;
    rdfs:comment 'Geographic territories in which the content featuring this talent role may be distributed and exploited (e.g., \'Worldwide\', \'North America\', \'USA and Canada\').' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voiceOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Voice Only Flag' ;
    rdfs:comment 'Indicates whether this is a voice-only role (voice-over, narration, animation, ADR) with no on-screen physical appearance by the talent.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceGrantedBy rdf:type rdf:Property ;
    rdfs:label 'Clearance Granted By' ;
    rdfs:comment 'Name or identifier of the person or system that granted clearance for this usage right.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceGrantedDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Granted Date' ;
    rdfs:comment 'Date when clearance was granted for this usage right. Null if not yet cleared.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentObtainedDate rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Date' ;
    rdfs:comment 'Date when talent consent was obtained for this usage right. Null if consent not obtained or not required.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Flag' ;
    rdfs:comment 'Indicates whether required consent has been obtained from the talent (True) or not (False). Null if consent not required.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Required Flag' ;
    rdfs:comment 'Indicates whether explicit talent consent is required for each use under this right (True) or if blanket consent was granted (False).' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditAttributionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Attribution Required Flag' ;
    rdfs:comment 'Indicates whether talent credit attribution is contractually required when this usage right is exercised (True) or not (False).' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditAttributionText rdf:type rdf:Property ;
    rdfs:label 'Credit Attribution Text' ;
    rdfs:comment 'Specific credit text that must be displayed when this usage right is exercised (e.g., \'Starring John Doe\'). Null if not required.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRateType rdf:type rdf:Property ;
    rdfs:label 'Residual Rate Type' ;
    rdfs:comment 'Type of residual payment structure for this usage right (e.g., flat fee, percentage of revenue, per-use rate, tiered schedule, or none).' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageLimitType rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Type' ;
    rdfs:comment 'Type of usage limitation applied to this right (e.g., unlimited, limited by number of runs, time duration, impressions, or revenue cap).' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageLimitUnit rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Unit' ;
    rdfs:comment 'Unit of measure for the usage limit value (e.g., runs, days, impressions, currency code). Null if unlimited.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageLimitValue rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Value' ;
    rdfs:comment 'Numeric value of the usage limit (e.g., 10 runs, 365 days, 1000000 impressions, 50000 USD revenue cap). Null if unlimited.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageScope rdf:type rdf:Property ;
    rdfs:label 'Usage Scope' ;
    rdfs:comment 'Detailed description of what the usage right covers (e.g., likeness, voice, name, performance, image).' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessControlSystem rdf:type rdf:Property ;
    rdfs:label 'Access Control System' ;
    rdfs:comment 'Type of physical access control system deployed: biometric (fingerprint, iris, facial recognition), card_reader (RFID badge), keypad (PIN entry), security_guard (manual verification), none (unrestricted), multi_factor (combination of methods).' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupPowerDurationHours rdf:type rdf:Property ;
    rdfs:label 'Backup Power Duration Hours' ;
    rdfs:comment 'Maximum duration in hours that backup power systems can sustain full facility operations during a primary power outage.' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backupPowerType rdf:type rdf:Property ;
    rdfs:label 'Backup Power Type' ;
    rdfs:comment 'Type of backup power system installed: generator (diesel or natural gas), ups (Uninterruptible Power Supply), battery (battery bank), solar (solar panels with storage), none (no backup), hybrid (combination of systems).' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date when the facility was officially commissioned and became operational. Used for asset lifecycle tracking and depreciation calculations.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:controlRoomCount rdf:type rdf:Property ;
    rdfs:label 'Control Room Count' ;
    rdfs:comment 'Number of master control rooms or playout control rooms within the facility. Used for operational capacity assessment.' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coolingCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Cooling Capacity Tons' ;
    rdfs:comment 'Total HVAC cooling capacity in refrigeration tons. Critical for equipment reliability and data center operations.' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevationMeters rdf:type rdf:Property ;
    rdfs:label 'Elevation Meters' ;
    rdfs:comment 'Elevation above sea level in meters. Critical for transmission site coverage calculations and antenna height planning.' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the facility across systems and external partners. Used for operational reference and integration.' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Facility Manager Email' ;
    rdfs:comment 'Primary email address of the facility manager for operational communications and escalations.' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityManagerName rdf:type rdf:Property ;
    rdfs:label 'Facility Manager Name' ;
    rdfs:comment 'Full name of the person responsible for day-to-day facility operations and management. Business reference, not direct PII.' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityManagerPhone rdf:type rdf:Property ;
    rdfs:label 'Facility Manager Phone' ;
    rdfs:comment 'Primary contact phone number for the facility manager. Used for emergency notifications and operational coordination.' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Human-readable name of the broadcast facility (e.g., \'Downtown Studio A\', \'Mountain Peak Transmission Site\').' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionSystem rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression System' ;
    rdfs:comment 'Type of fire suppression system installed: sprinkler (water-based), gas (clean agent like FM-200 or Novec 1230), foam (for flammable liquid areas), water_mist (fine water droplets), none (no automated system).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Expiration date of the facility lease agreement if the facility is leased. Null if the facility is owned. Used for real estate planning and renewal tracking.' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:networkConnectivityGbps rdf:type rdf:Property ;
    rdfs:label 'Network Connectivity Gbps' ;
    rdfs:comment 'Total network bandwidth capacity in gigabits per second. Includes all uplink and interconnection circuits. Critical for content distribution and streaming operations.' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date for the next mandatory regulatory or safety inspection. Used for compliance calendar management.' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership arrangement: owned (company-owned property), leased (long-term lease), colocation (shared data center space), shared (joint venture or partnership facility).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerCapacityKva rdf:type rdf:Property ;
    rdfs:label 'Power Capacity Kva' ;
    rdfs:comment 'Total electrical power capacity available to the facility in kilovolt-amperes. Includes primary and backup power systems.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redundancyTier rdf:type rdf:Property ;
    rdfs:label 'Redundancy Tier' ;
    rdfs:comment 'Uptime Institute tier classification for infrastructure redundancy and availability: tier_1 (basic), tier_2 (redundant components), tier_3 (concurrently maintainable), tier_4 (fault tolerant), not_applicable (non-data center facilities).' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClassification rdf:type rdf:Property ;
    rdfs:label 'Security Classification' ;
    rdfs:comment 'Physical security classification level: high (24/7 armed security, biometric access, CCTV, perimeter fencing), medium (access control, CCTV, security personnel during business hours), low (basic access control).' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studioCount rdf:type rdf:Property ;
    rdfs:label 'Studio Count' ;
    rdfs:comment 'Number of production studios within the facility. Applicable to studio and master control facility types.' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFloorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Total Floor Area Sqm' ;
    rdfs:comment 'Total usable floor space of the facility in square meters. Used for capacity planning and space utilization analysis.' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmissionPowerKw rdf:type rdf:Property ;
    rdfs:label 'Transmission Power Kw' ;
    rdfs:comment 'Maximum authorized transmission power output in kilowatts. Applicable to transmission sites. Governed by FCC or regional broadcast authority licensing.' ;
    rdfs:domain ind:BroadcastFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessibilityFeatures rdf:type rdf:Property ;
    rdfs:label 'Accessibility Features' ;
    rdfs:comment 'Accessibility features supported by this standard (e.g., closed captioning, subtitles, audio description, sign language). Applicable to captioning and accessibility standards.' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adoptionDate rdf:type rdf:Property ;
    rdfs:label 'Adoption Date' ;
    rdfs:comment 'Date when Media Broadcasting officially adopted this standard for use in operations. May differ from effective_date.' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adoptionStatus rdf:type rdf:Property ;
    rdfs:label 'Adoption Status' ;
    rdfs:comment 'Current adoption status of the standard within the organization\'s technology stack (mandatory for compliance, recommended best practice, optional, deprecated/phasing out, sunset/retired, emerging/pilot).' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityDomain rdf:type rdf:Property ;
    rdfs:label 'Applicability Domain' ;
    rdfs:comment 'Business or technical domain(s) where this standard applies within Media Broadcasting operations (e.g., linear broadcast transmission, OTT streaming, studio production, post-production, archival, playout automation).' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioChannelsSupported rdf:type rdf:Property ;
    rdfs:label 'Audio Channels Supported' ;
    rdfs:comment 'Audio channel configurations supported by this standard (e.g., stereo, 5.1, 7.1, Dolby Atmos object-based). Applicable to audio standards. Null otherwise.' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bandwidthRequirementMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Requirement Mbps' ;
    rdfs:comment 'Typical or minimum bandwidth requirement in megabits per second (Mbps) for transmission or streaming using this standard. Null if not applicable.' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Flag' ;
    rdfs:comment 'Indicates whether adherence to this standard is required for regulatory compliance or broadcast licensing (True if compliance-driven, False if voluntary/best-practice).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compressionAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Compression Algorithm' ;
    rdfs:comment 'Compression or codec algorithm specified by this standard (e.g., H.264/AVC, H.265/HEVC, AAC, Dolby AC-4). Applicable to encoding standards. Null otherwise.' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCompatibility rdf:type rdf:Property ;
    rdfs:label 'Equipment Compatibility' ;
    rdfs:comment 'Notes on broadcast equipment, encoders, decoders, or infrastructure components compatible with or required for this standard.' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'Name of the standards organization or governing body that publishes and maintains this standard (e.g., ATSC, DVB, SMPTE, SCTE, IETF, ISO, IEC, ITU).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationComplexity rdf:type rdf:Property ;
    rdfs:label 'Implementation Complexity' ;
    rdfs:comment 'Assessed complexity level for implementing this standard in broadcast operations (low, medium, high, very-high) based on technical requirements, infrastructure changes, and integration effort.' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interoperabilityNotes rdf:type rdf:Property ;
    rdfs:label 'Interoperability Notes' ;
    rdfs:comment 'Notes on interoperability with other standards, backward compatibility, and integration considerations for implementation.' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latencyClass rdf:type rdf:Property ;
    rdfs:label 'Latency Class' ;
    rdfs:comment 'Latency classification for streaming or transmission standards (ultra-low <1s, low 1-3s, standard 3-10s, high >10s). Not-applicable for non-streaming standards.' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'License Requirement Flag' ;
    rdfs:comment 'Indicates whether use of this standard requires licensing fees, patent royalties, or commercial agreements (True if licensing required, False if royalty-free or open standard).' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationUrl rdf:type rdf:Property ;
    rdfs:label 'Specification Url' ;
    rdfs:comment 'Web URL linking to the official specification document or standards body publication page for this standard.' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCode rdf:type rdf:Property ;
    rdfs:label 'Standard Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the broadcast standard (e.g., ATSC-3.0, DVB-T2, HEVC, ST-2110).' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardType rdf:type rdf:Property ;
    rdfs:label 'Standard Type' ;
    rdfs:comment 'Categorical classification of the standard\'s primary technical domain (transmission, encoding, compression, streaming, audio, captioning, metadata, transport, interface, quality). [ENUM-REF-CANDIDATE: transmission|encoding|compression|streaming|audio|captioning|metadata|transport|interface|quality — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successorStandardCode rdf:type rdf:Property ;
    rdfs:label 'Successor Standard Code' ;
    rdfs:comment 'Standard code of the successor or next version that supersedes this standard. Null if this is the current version or no successor exists yet.' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedColorSpaces rdf:type rdf:Property ;
    rdfs:label 'Supported Color Spaces' ;
    rdfs:comment 'Color space specifications supported (e.g., Rec. 709, Rec. 2020, DCI-P3). Applicable to video and HDR standards. Null for non-video standards.' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedFrameRates rdf:type rdf:Property ;
    rdfs:label 'Supported Frame Rates' ;
    rdfs:comment 'Frame rates supported by this standard (e.g., 24fps, 30fps, 60fps, 120fps). Applicable to video standards. Null for non-video standards.' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSummary rdf:type rdf:Property ;
    rdfs:label 'Technical Summary' ;
    rdfs:comment 'Brief technical summary describing the purpose, key features, and capabilities of this broadcast standard.' ;
    rdfs:domain ind:BroadcastStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPlanId rdf:type rdf:Property ;
    rdfs:label 'Capacity Plan Id' ;
    rdfs:comment 'Unique identifier for the infrastructure capacity planning assessment record. Primary key for the capacity plan entity.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Capacity Threshold Percentage' ;
    rdfs:comment 'The utilization percentage threshold that triggers capacity expansion or optimization actions. Typically set based on Service Level Agreement (SLA) requirements and operational best practices (e.g., 80% for storage, 70% for network to maintain performance headroom).' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'The unit of measurement for capacity and utilization values. TB/PB for storage (terabytes/petabytes), Gbps/Mbps for network bandwidth, cores/vCPU for compute, studio_hours for production facility time, channels for playout capacity, streams for concurrent delivery capacity, transcode_hours for encoding capacity. [ENUM-REF-CANDIDATE: tb|pb|gbps|mbps|cores|vcpu|studio_hours|channels|streams|transcode_hours — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCapacityValue rdf:type rdf:Property ;
    rdfs:label 'Current Capacity Value' ;
    rdfs:comment 'The current total capacity available in the infrastructure domain, expressed in the unit specified by capacity_unit (e.g., terabytes for storage, gigabits per second for network, compute cores for processing).' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Current Utilization Percentage' ;
    rdfs:comment 'The current utilization expressed as a percentage of total available capacity (current_utilization_value / current_capacity_value * 100). Key metric for determining proximity to capacity thresholds.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentUtilizationValue rdf:type rdf:Property ;
    rdfs:label 'Current Utilization Value' ;
    rdfs:comment 'The current amount of capacity being consumed or utilized, expressed in the same unit as current_capacity_value.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'The sensitivity classification of this capacity plan document. Public: shareable externally; Internal: for employee access only; Confidential: restricted to authorized personnel; Restricted: highly sensitive, executive access only.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCapexAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Capex Amount' ;
    rdfs:comment 'The estimated capital expenditure required to implement the recommended action, including hardware, software, installation, and integration costs. Critical for budget planning and investment approval processes.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedOpexAnnualAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Opex Annual Amount' ;
    rdfs:comment 'The estimated annual operating expenditure impact of the recommended action, including maintenance, support, power, cooling, and licensing costs. Used for total cost of ownership (TCO) analysis.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationPriority rdf:type rdf:Property ;
    rdfs:label 'Implementation Priority' ;
    rdfs:comment 'The urgency level for implementing the capacity plan. Critical: immediate action required to prevent service disruption; High: needed within current quarter; Medium: planned for next quarter; Low: long-term strategic initiative.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infrastructureDomain rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Domain' ;
    rdfs:comment 'The category of broadcast infrastructure being assessed in this capacity plan. Network covers transmission bandwidth and connectivity; Storage covers Media Asset Management (MAM) and archive systems; Compute covers processing and rendering resources; Studio covers production facilities and equipment; Transmission covers broadcast towers and signal distribution; CDN covers Content Delivery Network edge caching; Playout covers channel automation systems; Encoding covers transcoding and ABR (Adaptive Bitrate Streaming) infrastructure. [ENUM-REF-CANDIDATE: network|storage|compute|studio|transmission|cdn|mam|playout|encoding — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'The date when this capacity plan was last reviewed and validated by the plan owner or governance committee. Used to ensure plans remain current and aligned with business needs.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planOwner rdf:type rdf:Property ;
    rdfs:label 'Plan Owner' ;
    rdfs:comment 'Name or identifier of the individual responsible for developing, maintaining, and executing this capacity plan. Typically an Infrastructure Manager, Network Operations Center (NOC) Manager, or Engineering Director.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Plan Owner Department' ;
    rdfs:comment 'The organizational department or division responsible for this capacity plan (e.g., Network Operations, Broadcast Engineering, IT Infrastructure, Media Technology, Studio Operations).' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning End Date' ;
    rdfs:comment 'The last day of the planning period covered by this capacity assessment. Defines the planning horizon endpoint.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodType rdf:type rdf:Property ;
    rdfs:label 'Planning Period Type' ;
    rdfs:comment 'The time horizon granularity for this capacity planning cycle (quarterly, half-yearly, annual, biennial, or multi-year strategic planning).' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Start Date' ;
    rdfs:comment 'The first day of the planning period covered by this capacity assessment. Used to define the temporal scope of the plan.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectedDemandValue rdf:type rdf:Property ;
    rdfs:label 'Projected Demand Value' ;
    rdfs:comment 'The forecasted capacity demand at the end of the planning period, calculated by applying the projected growth rate to current utilization. Expressed in the same unit as capacity_unit.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedGrowthRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Projected Growth Rate Percentage' ;
    rdfs:comment 'The anticipated percentage increase in demand or utilization over the planning period, based on historical trends, content production forecasts, audience growth projections, and strategic initiatives (e.g., new channel launches, OTT expansion, 4K/8K content migration).' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'The strategic recommendation for addressing capacity needs. Expand: add new infrastructure capacity; Optimize: improve efficiency of existing resources; Consolidate: merge underutilized resources; Decommission: retire obsolete infrastructure; Monitor: continue observation without immediate action; Migrate: move workloads to alternative infrastructure (e.g., cloud, CDN).' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedCapacityAddition rdf:type rdf:Property ;
    rdfs:label 'Recommended Capacity Addition' ;
    rdfs:comment 'The amount of additional capacity recommended to be added, expressed in the same unit as capacity_unit. Null if the recommended action does not involve expansion.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyPlatform rdf:type rdf:Property ;
    rdfs:label 'Technology Platform' ;
    rdfs:comment 'The specific technology platform or product being planned for capacity expansion (e.g., \'Dalet Galaxy MAM\', \'Akamai CDN\', \'Ericsson MediaFirst Playout\', \'AWS EC2\', \'NetApp FAS Storage\').' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdBreachDate rdf:type rdf:Property ;
    rdfs:label 'Threshold Breach Date' ;
    rdfs:comment 'The projected date when utilization is forecasted to exceed the capacity threshold, requiring intervention. Calculated based on current utilization, growth rate, and threshold percentage. Null if no breach is anticipated within the planning period.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedChannelId rdf:type rdf:Property ;
    rdfs:label 'Assigned Channel Id' ;
    rdfs:comment 'Reference to the linear broadcast channel or streaming channel that this encoder is configured to serve.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:assignedStreamName rdf:type rdf:Property ;
    rdfs:label 'Assigned Stream Name' ;
    rdfs:comment 'Name of the specific stream or service feed that this encoder produces (e.g., main program feed, backup feed, regional variant).' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationProfile rdf:type rdf:Property ;
    rdfs:label 'Configuration Profile' ;
    rdfs:comment 'Named configuration profile or preset applied to the encoder defining encoding parameters, quality settings, and output specifications.' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encoderCode rdf:type rdf:Property ;
    rdfs:label 'Encoder Code' ;
    rdfs:comment 'Unique business identifier or asset tag code for the encoder used in inventory and configuration management systems.' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encoderName rdf:type rdf:Property ;
    rdfs:label 'Encoder Name' ;
    rdfs:comment 'Human-readable name assigned to the encoder for operational identification and reference.' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encoderType rdf:type rdf:Property ;
    rdfs:label 'Encoder Type' ;
    rdfs:comment 'Classification of the encoder deployment model: hardware-based encoder appliance, software encoder running on server, or cloud-based encoding instance.' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Firmware Version' ;
    rdfs:comment 'Current firmware or software version installed on the encoder, used for compatibility tracking and update management.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputFormat rdf:type rdf:Property ;
    rdfs:label 'Input Format' ;
    rdfs:comment 'Video and audio input format accepted by the encoder (e.g., SDI, HDMI, IP/RTP, RTMP, file-based).' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent maintenance or service performed on the encoder.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latencyMode rdf:type rdf:Property ;
    rdfs:label 'Latency Mode' ;
    rdfs:comment 'Encoding latency profile configured for the encoder: low-latency for live sports and interactive content, ultra-low-latency for real-time applications, or standard for non-time-sensitive content.' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementUrl rdf:type rdf:Property ;
    rdfs:label 'Management Url' ;
    rdfs:comment 'Web-based management interface URL for accessing the encoder configuration and monitoring dashboard.' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next planned maintenance or firmware update for the encoder.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outputBitrateLadder rdf:type rdf:Property ;
    rdfs:label 'Output Bitrate Ladder' ;
    rdfs:comment 'Comma-separated list of output bitrates in kbps or Mbps defining the Adaptive Bitrate (ABR) ladder for multi-quality streaming (e.g., 500kbps, 1Mbps, 2.5Mbps, 5Mbps, 8Mbps).' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputCodec rdf:type rdf:Property ;
    rdfs:label 'Output Codec' ;
    rdfs:comment 'Primary video codec used for encoding output streams (H.264/AVC, HEVC/H.265, AV1, VP9, MPEG-2).' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputProtocol rdf:type rdf:Property ;
    rdfs:label 'Output Protocol' ;
    rdfs:comment 'Streaming protocol used for encoder output delivery (e.g., HLS, MPEG-DASH, RTMP, SRT, Zixi).' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformAssignment rdf:type rdf:Property ;
    rdfs:label 'Platform Assignment' ;
    rdfs:comment 'Name of the streaming platform, channel, or service to which this encoder is assigned (e.g., OTT platform, linear channel, FAST channel).' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerConsumptionWatts rdf:type rdf:Property ;
    rdfs:label 'Power Consumption Watts' ;
    rdfs:comment 'Typical power consumption of the encoder hardware in watts, used for capacity planning and energy cost calculation.' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rackLocation rdf:type rdf:Property ;
    rdfs:label 'Rack Location' ;
    rdfs:comment 'Physical rack and unit position where the hardware encoder is installed in the data center or broadcast facility (e.g., Rack-12-U24).' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportContractNumber rdf:type rdf:Property ;
    rdfs:label 'Support Contract Number' ;
    rdfs:comment 'Reference number for the active maintenance or technical support contract covering this encoder.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date when the manufacturer warranty or extended warranty coverage expires for the encoder hardware.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetTagAssigned rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Assigned' ;
    rdfs:comment 'Unique asset tag or inventory control number assigned to the equipment upon receipt for tracking and asset management purposes.' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetReference rdf:type rdf:Property ;
    rdfs:label 'Budget Reference' ;
    rdfs:comment 'Reference to the budget line item, cost center, or capital project against which this procurement is charged.' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentDescription rdf:type rdf:Property ;
    rdfs:label 'Equipment Description' ;
    rdfs:comment 'Detailed textual description of the equipment being procured, including make, model, specifications, and intended use.' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Planned or promised delivery date for the equipment as agreed with the vendor.' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptConfirmed rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Confirmed' ;
    rdfs:comment 'Flag indicating whether goods receipt has been confirmed in the system (true = received and confirmed, false = not yet received).' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'Date when goods receipt was formally recorded in the system, triggering inventory and financial postings.' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procurementStatus rdf:type rdf:Property ;
    rdfs:label 'Procurement Status' ;
    rdfs:comment 'Current lifecycle status of the procurement transaction in the workflow from draft through goods receipt and installation. [ENUM-REF-CANDIDATE: draft|approved|ordered|in_transit|received|installed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Classification of procurement transaction by financial treatment: capital expenditure (capex), operational expenditure (opex), lease, rental, maintenance, or upgrade.' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingLocationName rdf:type rdf:Property ;
    rdfs:label 'Receiving Location Name' ;
    rdfs:comment 'Name of the facility or location where equipment is being delivered.' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Reference number of the internal purchase requisition that initiated this procurement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionerName rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Name' ;
    rdfs:comment 'Name of the person or department who requested this equipment procurement.' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCost rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost' ;
    rdfs:comment 'Freight and shipping charges for delivery of the equipment.' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Total cost for all units in this procurement transaction (quantity × unit cost), before taxes and fees.' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Cost per single unit of equipment in the procurement currency.' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Duration of manufacturer or vendor warranty coverage in months from delivery or installation date.' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'High-level classification of the IT asset type distinguishing between hardware, software, licenses, peripherals, network devices, and storage systems.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTag rdf:type rdf:Property ;
    rdfs:label 'Asset Tag' ;
    rdfs:comment 'Physical or logical tag identifier affixed to or assigned to the asset for tracking and inventory purposes. Unique business identifier used for asset management and audits.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'Business unit, department, or team responsible for or using this asset (e.g., Production, Post-Production, Network Operations Center, IT Infrastructure, Playout Operations).' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedUser rdf:type rdf:Property ;
    rdfs:label 'Assigned User' ;
    rdfs:comment 'Name or identifier of the employee or contractor to whom this asset is currently assigned for operational use.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Required' ;
    rdfs:comment 'Indicates whether this asset is subject to specific regulatory compliance requirements (e.g., FCC equipment authorization, broadcast technical standards, data security regulations).' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Business criticality classification of the asset based on its impact to operations if unavailable (critical for broadcast continuity, high for major workflows, medium for standard operations, low for non-essential).' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostname rdf:type rdf:Property ;
    rdfs:label 'Hostname' ;
    rdfs:comment 'Network hostname or computer name assigned to the asset for identification on the network and in system management tools.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent physical or logical audit verification of this asset, used for compliance and inventory accuracy tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseKey rdf:type rdf:Property ;
    rdfs:label 'License Key' ;
    rdfs:comment 'Activation or license key for software assets, required for installation and compliance verification. Highly confidential to prevent unauthorized use.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Detailed physical location within the facility (e.g., Server Room A, Rack 12, Edit Suite 3, NOC Floor 2, Studio B Control Room).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macAddress rdf:type rdf:Property ;
    rdfs:label 'Mac Address' ;
    rdfs:comment 'Hardware MAC address of the network interface, unique identifier for network devices used in asset discovery and security management.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Manufacturer\'s model number or designation for the asset, identifying the specific product line and configuration.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osVersion rdf:type rdf:Property ;
    rdfs:label 'Os Version' ;
    rdfs:comment 'Version of the operating system installed on hardware assets or firmware version for network devices and embedded systems. Critical for patch management and compatibility tracking.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementCost rdf:type rdf:Property ;
    rdfs:label 'Procurement Cost' ;
    rdfs:comment 'Original purchase price or acquisition cost of the asset in the organization\'s base currency, used for financial reporting and depreciation.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementDate rdf:type rdf:Property ;
    rdfs:label 'Procurement Date' ;
    rdfs:comment 'Date when the asset was purchased or acquired by the organization, used for depreciation calculations and lifecycle tracking.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Version number of the software application or license, used for compatibility verification, upgrade planning, and support entitlement.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'Date when the manufacturer or vendor warranty coverage begins for this asset.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule Id' ;
    rdfs:comment 'Unique identifier for the maintenance schedule record. Primary key for the maintenance schedule entity.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceSchedule .

ind:primaryMaintenanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Maintenance Employee Id' ;
    rdfs:comment 'Reference to the staff member or engineer who owns or is accountable for this maintenance schedule. Links to employee or staff master record.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryMaintenanceLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Maintenance Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that last modified this maintenance schedule record. Used for audit trail and accountability.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complianceStandardReference rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard Reference' ;
    rdfs:comment 'Reference to regulatory or industry standard that mandates or guides this maintenance activity (e.g., \'FCC 47 CFR Part 73.1350\', \'ATSC A/53\', \'Manufacturer SLA\', \'OSHA 1910.147\').' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated cost (e.g., \'USD\', \'GBP\', \'EUR\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Downtime Required Flag' ;
    rdfs:comment 'Indicates whether the maintenance activity requires taking the equipment or system offline (True) or can be performed while operational (False). Critical for broadcast continuity planning.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Downtime Hours' ;
    rdfs:comment 'Expected duration in hours that the equipment or system will be offline during maintenance. Used for broadcast scheduling and redundancy planning.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPerformedDate rdf:type rdf:Property ;
    rdfs:label 'Last Performed Date' ;
    rdfs:comment 'Date when the maintenance activity was most recently completed. Used to calculate next due date and track maintenance history.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Maintenance Procedure Reference' ;
    rdfs:comment 'Reference to detailed maintenance procedure document, work instruction, or manufacturer service manual that guides the execution of the maintenance activity.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the maintenance schedule: active (in use), inactive (temporarily disabled), suspended (on hold), under_review (being evaluated), or retired (no longer applicable).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Type' ;
    rdfs:comment 'Classification of the maintenance activity: preventive (scheduled routine), corrective (repair), predictive (data-driven), condition-based (triggered by monitoring), emergency (unplanned critical), or regulatory (compliance-driven).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'Calculated or scheduled date when the next maintenance activity is due. Critical for proactive maintenance planning and compliance tracking.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Notification Lead Time Days' ;
    rdfs:comment 'Number of days in advance that stakeholders (operations, engineering, management) should be notified before the scheduled maintenance activity.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partsRequiredDescription rdf:type rdf:Property ;
    rdfs:label 'Parts Required Description' ;
    rdfs:comment 'Description of spare parts, consumables, or materials required for the maintenance activity (e.g., \'Transmitter tubes\', \'Air filters\', \'Cooling fluid\', \'Backup batteries\').' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredMaintenanceWindow rdf:type rdf:Property ;
    rdfs:label 'Preferred Maintenance Window' ;
    rdfs:comment 'Preferred time window for performing maintenance to minimize broadcast impact (e.g., \'Overnight 2AM-6AM\', \'Weekend\', \'Off-peak hours\'). Aligns with broadcast schedule and audience patterns.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceInterval rdf:type rdf:Property ;
    rdfs:label 'Recurrence Interval' ;
    rdfs:comment 'Numeric interval for the recurrence pattern (e.g., \'2\' for every 2 weeks, \'3\' for every 3 months). Used in conjunction with recurrence_pattern for flexible scheduling.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recurrencePattern rdf:type rdf:Property ;
    rdfs:label 'Recurrence Pattern' ;
    rdfs:comment 'Frequency at which the maintenance activity repeats: daily, weekly, biweekly, monthly, quarterly, semiannual (twice yearly), annual, or biennial (every two years). [ENUM-REF-CANDIDATE: daily|weekly|biweekly|monthly|quarterly|semiannual|annual|biennial — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether this maintenance schedule is mandated by regulatory requirements (True) or is voluntary/best-practice (False). Critical for compliance prioritization.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredCrewSize rdf:type rdf:Property ;
    rdfs:label 'Required Crew Size' ;
    rdfs:comment 'Number of technicians or engineers required to perform the maintenance activity safely and efficiently.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredSkillSet rdf:type rdf:Property ;
    rdfs:label 'Required Skill Set' ;
    rdfs:comment 'Technical skills, certifications, or qualifications required to perform the maintenance (e.g., \'FCC General Radiotelephone Operator License\', \'Broadcast Engineer\', \'HVAC Technician\', \'RF Specialist\').' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRequirements rdf:type rdf:Property ;
    rdfs:label 'Safety Requirements' ;
    rdfs:comment 'Safety protocols, personal protective equipment (PPE), or special precautions required for the maintenance activity (e.g., \'High voltage lockout/tagout\', \'RF exposure limits\', \'Confined space entry\').' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Unique business identifier or code for the maintenance schedule used for external reference and reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorServiceProvider rdf:type rdf:Property ;
    rdfs:label 'Vendor Service Provider' ;
    rdfs:comment 'Name of external vendor or service provider responsible for performing the maintenance, if not performed by internal staff (e.g., equipment manufacturer, specialized contractor).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tertiaryMaintenanceApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Maintenance Approved By Employee Id' ;
    rdfs:comment 'Reference to the manager, engineer, or operations supervisor who approved this work order for execution. Required when approval_required_flag is true, particularly for emergency work or work requiring broadcast service interruption.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual date and time when maintenance work was completed and asset returned to operational status. Marks the end of the maintenance window and restoration of service availability.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual date and time when maintenance work physically commenced. Used to measure schedule adherence, calculate actual labor duration, and determine precise downtime windows for broadcast operations impact analysis.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Detailed narrative documentation of work performed, findings, corrective actions taken, parts replaced, test results, and any follow-up recommendations. Serves as permanent maintenance history record for the asset.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Minutes' ;
    rdfs:comment 'Total duration in minutes that the asset or facility was unavailable for broadcast operations due to this maintenance activity. Critical metric for Service Level Agreement (SLA) compliance, availability reporting, and operational impact assessment.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultCode rdf:type rdf:Property ;
    rdfs:label 'Fault Code' ;
    rdfs:comment 'Standardized fault classification code from organizational taxonomy or equipment manufacturer fault code library. Enables categorization, trending analysis, and root cause identification across maintenance events.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultDescription rdf:type rdf:Property ;
    rdfs:label 'Fault Description' ;
    rdfs:comment 'Detailed narrative description of the fault, issue, or maintenance requirement that triggered this work order. Includes symptoms observed, error codes, alarm messages, or condition assessment findings reported by operators or monitoring systems.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'Total labor cost for this maintenance work order, including internal technician time and external vendor service charges. Used for maintenance budget management and cost per asset analysis.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborHours rdf:type rdf:Property ;
    rdfs:label 'Labor Hours' ;
    rdfs:comment 'Total labor hours expended by technicians and engineers on this maintenance work order. Used for cost allocation, resource utilization analysis, and maintenance budget tracking. May include multiple technicians working concurrently.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceWorkOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Order Status' ;
    rdfs:comment 'Current lifecycle state of the maintenance work order. Tracks progression from initial creation through assignment, execution, completion, and closure. On_hold indicates temporary suspension pending parts, approvals, or external dependencies. [ENUM-REF-CANDIDATE: draft|scheduled|assigned|in_progress|on_hold|completed|cancelled|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Outage Required Flag' ;
    rdfs:comment 'Indicates whether this maintenance work requires taking the asset or facility offline, resulting in broadcast service interruption. True requires coordination with Network Operations Center (NOC) and scheduling during approved maintenance windows.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partsCostAmount rdf:type rdf:Property ;
    rdfs:label 'Parts Cost Amount' ;
    rdfs:comment 'Total cost of replacement parts, components, and materials consumed during this maintenance activity. Excludes labor costs. Used for maintenance cost analysis, budget tracking, and asset lifecycle costing.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Indicates whether a safety incident occurred during execution of this maintenance work order. True triggers mandatory incident investigation, reporting to safety committee, and potential regulatory notification per Occupational Safety and Health Administration (OSHA) requirements.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'Planned date and time when maintenance work is expected to be completed. Used for resource planning, outage window management, and coordination with broadcast operations to minimize service disruption.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'Planned date and time when maintenance work is scheduled to begin. For preventive maintenance, aligns with maintenance calendar; for corrective work, represents target response time based on priority and Service Level Agreement (SLA).' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Indicates whether this work order was completed within the defined Service Level Agreement (SLA) target times for response and resolution. False indicates SLA breach requiring management review and potential customer credits or penalties.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetResolutionMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Minutes' ;
    rdfs:comment 'Target resolution time in minutes from work order creation to completion, as defined by Service Level Agreement (SLA) for this priority level and asset class. Critical metric for measuring maintenance effectiveness and meeting operational commitments.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetResponseMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Response Minutes' ;
    rdfs:comment 'Target response time in minutes from work order creation to actual start of work, as defined by Service Level Agreement (SLA) for this priority level and asset class. Used to measure maintenance team responsiveness and SLA compliance.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cost Amount' ;
    rdfs:comment 'Total cost of this maintenance work order, including parts, labor, vendor charges, and any other direct costs. Primary metric for maintenance expense tracking and asset total cost of ownership analysis.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'Indicates whether this maintenance work is covered under manufacturer or vendor warranty, enabling cost recovery. True triggers warranty claim process and excludes costs from internal maintenance budget allocation.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Externally visible business identifier for the work order, used for tracking and communication with technicians, vendors, and operations teams. Typically follows format WO-YYYYMMDD or similar organizational standard.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the maintenance work order by nature of activity: preventive (scheduled routine maintenance), corrective (repair of known issue), emergency (unplanned critical repair), inspection (compliance or condition assessment), upgrade (enhancement or modernization), decommission (asset retirement).' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Average Utilization Percent' ;
    rdfs:comment 'Average bandwidth utilization as a percentage of provisioned capacity over the most recent measurement period (typically 30 days). Used for capacity planning and right-sizing decisions. Range 0.00 to 100.00.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierProviderName rdf:type rdf:Property ;
    rdfs:label 'Carrier Provider Name' ;
    rdfs:comment 'Name of the telecommunications carrier or service provider that provisions and maintains the circuit (e.g., AT&T, Verizon, Level 3, Comcast Business, Intelsat).' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierTroubleTicketUrl rdf:type rdf:Property ;
    rdfs:label 'Carrier Trouble Ticket Url' ;
    rdfs:comment 'Web URL for the carriers trouble ticket or service portal where incidents and service requests for this circuit can be submitted and tracked.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitIdentifier rdf:type rdf:Property ;
    rdfs:label 'Circuit Identifier' ;
    rdfs:comment 'Business identifier or circuit ID assigned by the carrier or internal network operations team. This is the externally-known reference number used in carrier documentation, trouble tickets, and billing statements.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitPurpose rdf:type rdf:Property ;
    rdfs:label 'Circuit Purpose' ;
    rdfs:comment 'Business purpose or use case for the circuit. Examples: live broadcast contribution feed, studio-to-transmitter link (STL), content distribution network (CDN) interconnect, remote production backhaul, disaster recovery link, office internet access, inter-facility MPLS backbone.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitType rdf:type rdf:Property ;
    rdfs:label 'Circuit Type' ;
    rdfs:comment 'Classification of the network circuit technology. MPLS (Multiprotocol Label Switching) for managed IP networks, dark fiber for unlit fiber optic infrastructure, satellite for space-based transmission, internet transit for public internet connectivity, dedicated broadcast contribution for live content feeds, ethernet for layer-2 connectivity, wavelength for DWDM optical circuits. [ENUM-REF-CANDIDATE: MPLS|dark_fiber|satellite|internet_transit|dedicated_broadcast_contribution|ethernet|wavelength — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedInformationRateMbps rdf:type rdf:Property ;
    rdfs:label 'Committed Information Rate Mbps' ;
    rdfs:comment 'Guaranteed minimum bandwidth committed by the carrier under the SLA, measured in megabits per second. For burstable circuits, this is the sustained rate; peak burst rate may be higher. Equal to bandwidth_mbps for non-burstable circuits.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demarcationPoint rdf:type rdf:Property ;
    rdfs:label 'Demarcation Point' ;
    rdfs:comment 'Physical location description of the network demarcation point where carrier responsibility ends and customer responsibility begins. Typically a patch panel, network interface device (NID), or equipment rack location.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationFacilityAddress rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Address' ;
    rdfs:comment 'Physical street address of the destination facility including street, city, state/province, and postal code. Required for carrier provisioning and site access coordination.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationFacilityName rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Name' ;
    rdfs:comment 'Name of the destination facility, remote site, transmission tower, or endpoint where the circuit terminates. This is the Z-end of the circuit. For point-to-multipoint circuits, this represents the primary destination.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityRouteIndicator rdf:type rdf:Property ;
    rdfs:label 'Diversity Route Indicator' ;
    rdfs:comment 'Identifier or description of the physical route diversity for this circuit. Used to ensure redundant circuits do not share common failure points (e.g., same conduit, same central office). Examples: Route A, Route B, North Path, South Path.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationCost rdf:type rdf:Property ;
    rdfs:label 'Installation Cost' ;
    rdfs:comment 'One-time installation or provisioning cost in USD. Includes circuit installation, equipment installation, site survey, and activation fees. Does not include monthly recurring charges.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interfaceType rdf:type rdf:Property ;
    rdfs:label 'Interface Type' ;
    rdfs:comment 'Physical media type of the circuit interface at the customer premises. Fiber optic (single-mode or multi-mode), copper (ethernet over copper), coaxial (cable modem), wireless (microwave or radio), satellite dish (VSAT terminal).' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddressRange rdf:type rdf:Property ;
    rdfs:label 'Ip Address Range' ;
    rdfs:comment 'IP address range or subnet assigned to this circuit in CIDR notation (e.g., 10.50.100.0/24). Applicable for routed IP circuits. Null for layer-2 or non-IP circuits.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryPath rdf:type rdf:Property ;
    rdfs:label 'Is Primary Path' ;
    rdfs:comment 'Boolean flag indicating whether this circuit is the primary (active) path in a redundant configuration. True for primary circuits, false for backup/standby circuits. Null if redundancy does not apply.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Monitoring Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this circuit is actively monitored by network operations center (NOC) monitoring systems for availability, performance, and threshold alerts. True if monitored, false if not.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monthlyRecurringCost rdf:type rdf:Property ;
    rdfs:label 'Monthly Recurring Cost' ;
    rdfs:comment 'Monthly recurring charge for the circuit service in USD. Includes port fees, bandwidth charges, and managed service fees. Does not include one-time installation costs or usage-based overage charges.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next planned maintenance window for this circuit. Used for change management coordination and service availability planning.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originFacilityAddress rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Address' ;
    rdfs:comment 'Physical street address of the origin facility including street, city, state/province, and postal code. Required for carrier provisioning and site access coordination.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originFacilityName rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Name' ;
    rdfs:comment 'Name of the originating facility, studio, broadcast center, or network operations center (NOC) where the circuit originates. This is the A-end of the circuit.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Peak Utilization Percent' ;
    rdfs:comment 'Peak bandwidth utilization as a percentage of provisioned capacity over the most recent measurement period (typically 30 days). Identifies capacity constraints and congestion risk. Range 0.00 to 100.00.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisioningDate rdf:type rdf:Property ;
    rdfs:label 'Provisioning Date' ;
    rdfs:comment 'Date when the circuit was successfully provisioned, tested, and turned up for production use. This is the service activation date, not the order date.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redundancyGroup rdf:type rdf:Property ;
    rdfs:label 'Redundancy Group' ;
    rdfs:comment 'Identifier for the redundancy or failover group this circuit belongs to. Circuits in the same redundancy group provide backup for each other. Null if the circuit is not part of a redundant configuration.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactEmail rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Email' ;
    rdfs:comment 'Email address of the internal technical contact responsible for this circuit. Used for automated alerts and incident notifications.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactName rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Name' ;
    rdfs:comment 'Name of the internal technical contact or network engineer responsible for this circuit. Used for escalation and coordination during incidents or maintenance.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vlanNumber rdf:type rdf:Property ;
    rdfs:label 'Vlan Number' ;
    rdfs:comment 'VLAN identifier used for layer-2 segmentation on this circuit. Applicable for ethernet and MPLS circuits. Range 1-4094 per IEEE 802.1Q standard. Null for non-VLAN circuits.' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedChannelId rdf:type rdf:Property ;
    rdfs:label 'Affected Channel Id' ;
    rdfs:comment 'Identifier of the broadcast channel or service impacted by the alert event. May be null for infrastructure alerts not tied to a specific channel.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:impactedSubscriberId rdf:type rdf:Property ;
    rdfs:label 'Impacted Subscriber Id' ;
    rdfs:comment 'Foreign key linking to subscriber.subscriber. Business justification: Critical streaming service alerts require identifying specific affected subscribers for proactive customer care outreach, SLA credit processing, and personalized service recovery. Incident management ' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:primaryNocEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Noc Employee Id' ;
    rdfs:comment 'Identifier of the NOC operator or engineer who acknowledged the alert. Null if not yet acknowledged.' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:signalPathId rdf:type rdf:Property ;
    rdfs:label 'Signal Path Id' ;
    rdfs:comment 'Foreign key linking to technology.signal_path. Business justification: NOC alerts monitor signal paths for broadcast feeds. The \'monitor_name\' and \'affected_channel_name\' fields suggest signal path monitoring. Adding FK to link alerts to the specific signal path experien' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SignalPath .

ind:acknowledgedByUserName rdf:type rdf:Property ;
    rdfs:label 'Acknowledged By User Name' ;
    rdfs:comment 'Full name of the NOC operator or engineer who acknowledged the alert, providing audit trail for incident response.' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'The date and time when a NOC operator or engineer acknowledged receipt of the alert and began investigation. Null if not yet acknowledged.' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affectedViewerCountEstimate rdf:type rdf:Property ;
    rdfs:label 'Affected Viewer Count Estimate' ;
    rdfs:comment 'Estimated number of viewers or subscribers impacted by the alert event, based on audience measurement data and service reach. Used for prioritization and business impact analysis.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertSeverity rdf:type rdf:Property ;
    rdfs:label 'Alert Severity' ;
    rdfs:comment 'The priority level assigned to the alert event, typically classified as P1 (critical - immediate service impact), P2 (high - significant degradation), P3 (medium - minor impact), or P4 (low - informational). Determines escalation and response urgency.' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'The current lifecycle state of the alert event within the NOC incident management workflow. Tracks progression from initial detection through acknowledgment, investigation, resolution, and closure. [ENUM-REF-CANDIDATE: open|acknowledged|in_progress|resolved|closed|auto_resolved|escalated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoResolutionFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Resolution Flag' ;
    rdfs:comment 'Boolean indicator of whether the alert was automatically resolved by the monitoring platform or automation system without human intervention (True) or required manual resolution (False).' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the equipment unit that experienced the fault, used for warranty claims and maintenance tracking.' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationHistory rdf:type rdf:Property ;
    rdfs:label 'Escalation History' ;
    rdfs:comment 'Chronological log of escalation events, including timestamps, escalation reasons, and personnel notified. Captures the full escalation chain for audit and process improvement.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultLocation rdf:type rdf:Property ;
    rdfs:label 'Fault Location' ;
    rdfs:comment 'Physical or logical location where the fault was detected, such as facility name, rack identifier, transmission site, or network segment. Aids in dispatch and troubleshooting.' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitorName rdf:type rdf:Property ;
    rdfs:label 'Monitor Name' ;
    rdfs:comment 'Human-readable name or label of the monitoring probe or sensor that triggered the alert, providing operational context for NOC staff.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Resolution Duration Minutes' ;
    rdfs:comment 'The total elapsed time in minutes from alert timestamp to resolved timestamp, used for SLA compliance tracking and performance analysis. Null if not yet resolved.' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolvedByUserName rdf:type rdf:Property ;
    rdfs:label 'Resolved By User Name' ;
    rdfs:comment 'Full name of the NOC operator, engineer, or technician who resolved the alert, providing audit trail for incident resolution.' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'The date and time when the alert was marked as resolved, indicating the fault condition has been corrected and service restored. Null if not yet resolved.' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Minutes' ;
    rdfs:comment 'The contractual or operational SLA target resolution time in minutes for this alert severity level, used as the benchmark for performance measurement.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Alert Notification Enabled' ;
    rdfs:comment 'Indicates whether alert notifications are currently enabled for this monitor. When false, alerts are logged but not sent to NOC teams.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Value' ;
    rdfs:comment 'Numeric threshold that, when exceeded or not met, triggers an alert. Interpretation depends on threshold_metric (e.g., packet loss percentage, bitrate Mbps, uptime percentage).' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedNocTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Noc Team' ;
    rdfs:comment 'Name or identifier of the NOC team responsible for responding to alerts from this monitor. Used for routing notifications and incident assignment.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRemediationEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Remediation Enabled' ;
    rdfs:comment 'Indicates whether automated remediation actions (e.g., service restart, failover trigger) are enabled for this monitor. When true, the NOC system may take corrective action without human intervention.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessServiceName rdf:type rdf:Property ;
    rdfs:label 'Business Service Name' ;
    rdfs:comment 'Name of the business service or channel that depends on this monitored entity. Links technical monitoring to business impact analysis.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceTags rdf:type rdf:Property ;
    rdfs:label 'Compliance Tags' ;
    rdfs:comment 'Comma-separated list of regulatory or compliance frameworks this monitor supports (e.g., FCC_BROADCAST_LICENSE, ATSC_STANDARDS, SOX_CONTROLS). Used for compliance reporting and audit preparation.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentModel rdf:type rdf:Property ;
    rdfs:label 'Equipment Model' ;
    rdfs:comment 'Model number or product name of the monitored device. Helps identify firmware versions and known issues during incident response.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTier rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier' ;
    rdfs:comment 'Priority level for alert escalation. Determines which NOC team or management level receives notifications when this monitor triggers an alert.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedUptimePercent rdf:type rdf:Property ;
    rdfs:label 'Expected Uptime Percent' ;
    rdfs:comment 'Target uptime percentage defined in the SLA for this monitored service or device. Used to calculate SLA compliance and trigger breach alerts.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitorCategory rdf:type rdf:Property ;
    rdfs:label 'Monitor Category' ;
    rdfs:comment 'High-level functional category of the monitored entity within the broadcast infrastructure. Used for dashboard organization and reporting rollups.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitorCode rdf:type rdf:Property ;
    rdfs:label 'Monitor Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying this monitor within the NOC system. Used for system integration and API references.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitorDescription rdf:type rdf:Property ;
    rdfs:label 'Monitor Description' ;
    rdfs:comment 'Detailed textual description of what this monitor tracks, its business purpose, and any special configuration notes. Provides context for NOC operators.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitorStatus rdf:type rdf:Property ;
    rdfs:label 'Monitor Status' ;
    rdfs:comment 'Current operational status of the monitor configuration. Active monitors generate alerts; inactive or suspended monitors do not trigger notifications.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoredEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Monitored Endpoint Url' ;
    rdfs:comment 'Network address or URL of the monitored service or device. May be an IP address, streaming URL, or API endpoint. Confidential as it exposes internal infrastructure topology.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoredEntityType rdf:type rdf:Property ;
    rdfs:label 'Monitored Entity Type' ;
    rdfs:comment 'Classification of the infrastructure component or signal path being monitored. Determines the applicable monitoring protocols and alert thresholds.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoredIpAddress rdf:type rdf:Property ;
    rdfs:label 'Monitored Ip Address' ;
    rdfs:comment 'IPv4 address of the monitored device or service endpoint. Used for network-level monitoring and diagnostics. Confidential infrastructure data.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoredPort rdf:type rdf:Property ;
    rdfs:label 'Monitored Port' ;
    rdfs:comment 'TCP or UDP port number on which the monitored service listens. Used in conjunction with IP address for endpoint identification.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringProtocol rdf:type rdf:Property ;
    rdfs:label 'Monitoring Protocol' ;
    rdfs:comment 'Technical protocol or method used to collect telemetry and status data from the monitored entity. Examples include SNMP (Simple Network Management Protocol) for device polling, MPEG-TS probe for transport stream analysis, SCTE-35 listener for ad insertion markers.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'Communication channel or integration used to deliver alert notifications to the assigned NOC team. Multiple channels may be configured per monitor.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pollingIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Polling Interval Seconds' ;
    rdfs:comment 'Frequency in seconds at which the NOC system queries or samples the monitored entity. Lower intervals provide faster fault detection but increase system load.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remediationScriptPath rdf:type rdf:Property ;
    rdfs:label 'Remediation Script Path' ;
    rdfs:comment 'File system path or identifier of the automated remediation script executed when this monitor triggers an alert. Confidential as it exposes automation logic.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdMetric rdf:type rdf:Property ;
    rdfs:label 'Threshold Metric' ;
    rdfs:comment 'The specific performance or quality metric being measured against the alert threshold. Examples: packet_loss_percent, bitrate_mbps, uptime_percent, latency_ms, error_rate.' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedGeographicRegion rdf:type rdf:Property ;
    rdfs:label 'Affected Geographic Region' ;
    rdfs:comment 'Geographic area or market impacted by the outage, such as specific DMA (Designated Market Area), country, or global scope.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedServiceName rdf:type rdf:Property ;
    rdfs:label 'Affected Service Name' ;
    rdfs:comment 'Specific name or identifier of the service, channel, stream, facility, or circuit affected by the outage.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedServiceType rdf:type rdf:Property ;
    rdfs:label 'Affected Service Type' ;
    rdfs:comment 'Category of broadcast or IT service impacted by the outage: linear channel, OTT (Over-The-Top) stream, VOD (Video On Demand) platform, CDN (Content Delivery Network), playout system, uplink transmission, facility infrastructure, or network circuit. [ENUM-REF-CANDIDATE: linear_channel|ott_stream|vod_platform|cdn|playout|uplink|facility|network_circuit — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedToEngineer rdf:type rdf:Property ;
    rdfs:label 'Assigned To Engineer' ;
    rdfs:comment 'Name or identifier of the engineer or technician assigned as primary owner for resolving the outage.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedToTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned To Team' ;
    rdfs:comment 'Name of the technical team or department responsible for investigating and resolving the outage (e.g., NOC, Engineering, Transmission, IT Operations).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedBy rdf:type rdf:Property ;
    rdfs:label 'Detected By' ;
    rdfs:comment 'Source that first detected the outage: automated monitoring system, NOC (Network Operations Center) operator, customer complaint, or third-party notification.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the outage was first detected by monitoring systems or personnel, which may differ from the actual outage start time.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedRevenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue Impact Amount' ;
    rdfs:comment 'Estimated financial impact of the outage in terms of lost advertising revenue, subscription credits, or contractual penalties.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactSeverity rdf:type rdf:Property ;
    rdfs:label 'Impact Severity' ;
    rdfs:comment 'Business impact severity level of the outage based on service criticality, audience reach, and revenue implications.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Outage Duration Minutes' ;
    rdfs:comment 'Total duration of the outage event measured in minutes, calculated from start to end timestamp.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Outage End Timestamp' ;
    rdfs:comment 'Date and time when the outage event ended and service was restored. Null if outage is still ongoing.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outageReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Outage Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for the outage event, used for tracking and communication with stakeholders.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Outage Start Timestamp' ;
    rdfs:comment 'Date and time when the outage event began, marking the start of service disruption or planned maintenance window.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outageStatus rdf:type rdf:Property ;
    rdfs:label 'Outage Status' ;
    rdfs:comment 'Current lifecycle status of the outage event in the incident management workflow.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageType rdf:type rdf:Property ;
    rdfs:label 'Outage Type' ;
    rdfs:comment 'Classification of the outage event: planned maintenance window, unplanned service disruption, or emergency intervention.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postIncidentReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Post Incident Review Status' ;
    rdfs:comment 'Status of the post-incident review process to analyze root cause, document lessons learned, and implement preventive measures.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submission Date' ;
    rdfs:comment 'Date when the outage incident report was submitted to the regulatory authority, if required.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Indicator of whether the outage event must be reported to regulatory authorities such as FCC (Federal Communications Commission) or Ofcom due to severity, duration, or public safety implications.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Description of the corrective action taken to resolve the outage and restore service, including technical steps and workarounds applied.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated revenue impact amount.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Target Uptime Percentage' ;
    rdfs:comment 'Contractual target uptime percentage defined in the SLA (Service Level Agreement) for the affected service, typically expressed as a percentage (e.g., 99.95%).' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Ticket Number' ;
    rdfs:comment 'External ticket or case number assigned by the third-party vendor for tracking their investigation and resolution efforts.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bandwidthMhz rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Mhz' ;
    rdfs:comment 'Total bandwidth capacity of the transponder in megahertz. Determines the data throughput and number of channels that can be multiplexed on this transponder.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierProvider rdf:type rdf:Property ;
    rdfs:label 'Carrier Provider' ;
    rdfs:comment 'Name of the satellite operator or service provider leasing the transponder capacity (e.g., SES, Intelsat, Eutelsat, Telesat). Primary vendor contact for technical support and service issues.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centerFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Center Frequency Mhz' ;
    rdfs:comment 'Center operating frequency of the transponder in megahertz. Used for uplink/downlink tuning and interference coordination with adjacent transponders.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelCapacity rdf:type rdf:Property ;
    rdfs:label 'Channel Capacity' ;
    rdfs:comment 'Number of standard-definition or high-definition channels that can be multiplexed on this transponder given current encoding parameters. Used for channel lineup planning.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the transponder capacity was retired from active service. Nullable for active transponders. Used for asset lifecycle tracking and capacity planning.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:downlinkCoverageFootprint rdf:type rdf:Property ;
    rdfs:label 'Downlink Coverage Footprint' ;
    rdfs:comment 'Geographic coverage area of the transponders downlink beam (e.g., North America, Europe, Asia-Pacific, CONUS). Defines the audience reach and distribution territory.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eirpDbw rdf:type rdf:Property ;
    rdfs:label 'Eirp Dbw' ;
    rdfs:comment 'Effective Isotropic Radiated Power of the transponder in decibels relative to one watt. Measures the signal strength at the coverage area, critical for reception quality planning.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseEndDate rdf:type rdf:Property ;
    rdfs:label 'Lease End Date' ;
    rdfs:comment 'Date when the transponder lease or capacity agreement expires. Nullable for owned capacity or indefinite agreements. Used for renewal planning and capacity forecasting.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Lease Start Date' ;
    rdfs:comment 'Date when the transponder lease or capacity agreement becomes effective. Critical for capacity planning and financial forecasting.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leasedCapacityMbps rdf:type rdf:Property ;
    rdfs:label 'Leased Capacity Mbps' ;
    rdfs:comment 'Amount of transponder capacity leased by Media Broadcasting in megabits per second. Represents the contracted data rate available for broadcast distribution.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modulationScheme rdf:type rdf:Property ;
    rdfs:label 'Modulation Scheme' ;
    rdfs:comment 'Digital modulation technique used (e.g., QPSK, 8PSK, 16APSK, 32APSK). Higher-order modulation increases throughput but requires better signal-to-noise ratio.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyLeaseCost rdf:type rdf:Property ;
    rdfs:label 'Monthly Lease Cost' ;
    rdfs:comment 'Monthly recurring cost for leasing the transponder capacity. Used for budget planning, cost allocation, and financial reporting. Excludes one-time setup fees.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orbitalSlot rdf:type rdf:Property ;
    rdfs:label 'Orbital Slot' ;
    rdfs:comment 'Geostationary orbital position of the satellite in degrees (e.g., 101.0W, 28.2E). Defines the satellites fixed position relative to Earth for broadcast coverage planning.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryService rdf:type rdf:Property ;
    rdfs:label 'Primary Service' ;
    rdfs:comment 'Primary broadcast service or channel distribution purpose for this transponder (e.g., Linear TV Distribution, VOD Delivery, Contribution Feed, Occasional Use). Supports capacity allocation and service planning.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redundancyConfiguration rdf:type rdf:Property ;
    rdfs:label 'Redundancy Configuration' ;
    rdfs:comment 'Redundancy role of this transponder in the broadcast distribution architecture. 1+1 provides full hot backup, N+1 shares backup across multiple primaries, None indicates no redundancy.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory License Number' ;
    rdfs:comment 'FCC or equivalent regulatory authority license number authorizing the use of this transponder for broadcast transmission. Required for compliance reporting and spectrum management.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satelliteName rdf:type rdf:Property ;
    rdfs:label 'Satellite Name' ;
    rdfs:comment 'Name of the satellite hosting this transponder (e.g., SES-1, Intelsat 21, Eutelsat 7B). Critical for uplink/downlink coordination and transmission planning.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transponderCode rdf:type rdf:Property ;
    rdfs:label 'Transponder Code' ;
    rdfs:comment 'Business identifier code for the transponder, typically assigned by the satellite operator or internal asset management system. Used for operational reference and capacity planning.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transponderName rdf:type rdf:Property ;
    rdfs:label 'Transponder Name' ;
    rdfs:comment 'Human-readable name or designation for the transponder, often including satellite name and transponder number for easy identification by broadcast operations teams.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transponderType rdf:type rdf:Property ;
    rdfs:label 'Transponder Type' ;
    rdfs:comment 'Technology classification of the transponder: Analog (legacy FM), Digital (DVB-S/S2), or Hybrid (supporting both). Modern broadcast operations primarily use digital transponders.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uplinkAntennaSizeMeters rdf:type rdf:Property ;
    rdfs:label 'Uplink Antenna Size Meters' ;
    rdfs:comment 'Diameter of the uplink antenna dish in meters. Larger antennas provide higher gain and better signal quality for satellite transmission.' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceTransmissionEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Source Transmission Equipment Id' ;
    rdfs:comment 'Foreign key linking to technology.transmission_equipment. Business justification: Signal paths originate from transmission equipment (encoder, multiplexer). The \'source_endpoint\' field should reference specific equipment. Adding FK to link the signal path to its source equipment, e' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransmissionEquipment .

ind:assignedChannel rdf:type rdf:Property ;
    rdfs:label 'Assigned Channel' ;
    rdfs:comment 'Broadcast channel, frequency, or logical channel identifier associated with this signal path for transmission or distribution purposes.' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationEndpoint rdf:type rdf:Property ;
    rdfs:label 'Destination Endpoint' ;
    rdfs:comment 'Identifier or address of the terminating endpoint where the signal exits this path. May be a transmitter, encoder, playout server, or distribution output.' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCorrectionEnabled rdf:type rdf:Property ;
    rdfs:label 'Error Correction Enabled' ;
    rdfs:comment 'Boolean flag indicating whether forward error correction (FEC) or other error correction mechanisms are enabled on this signal path to ensure signal integrity.' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intermediateNodes rdf:type rdf:Property ;
    rdfs:label 'Intermediate Nodes' ;
    rdfs:comment 'Comma-separated list or description of intermediate processing equipment, routers, switches, or nodes that the signal traverses between source and destination.' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFailureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Failure Timestamp' ;
    rdfs:comment 'Timestamp of the most recent failure or outage event recorded for this signal path, used for reliability analysis and maintenance planning.' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:latencyMs rdf:type rdf:Property ;
    rdfs:label 'Latency Ms' ;
    rdfs:comment 'Measured or target end-to-end latency for signal transmission through this path, expressed in milliseconds. Important for live broadcast synchronization and quality of service.' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceSchedule rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule' ;
    rdfs:comment 'Description or reference to the planned maintenance schedule for this signal path, including frequency and maintenance windows.' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathCode rdf:type rdf:Property ;
    rdfs:label 'Path Code' ;
    rdfs:comment 'Unique business identifier or code used to reference this signal path in operational systems, scheduling, and technical documentation.' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathName rdf:type rdf:Property ;
    rdfs:label 'Path Name' ;
    rdfs:comment 'Human-readable name or label assigned to this signal routing path for operational identification and reference.' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathType rdf:type rdf:Property ;
    rdfs:label 'Path Type' ;
    rdfs:comment 'Classification of the signal path based on its operational purpose: contribution (incoming feeds), distribution (outgoing delivery), interstitial (internal routing), backhaul (remote site return), studio-to-transmitter link, or satellite uplink.' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPathIndicator rdf:type rdf:Property ;
    rdfs:label 'Primary Path Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this signal path is designated as the primary (true) or backup/secondary (false) path in a redundant configuration.' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signalFormat rdf:type rdf:Property ;
    rdfs:label 'Signal Format' ;
    rdfs:comment 'Technical format specification of the signal carried on this path, such as HD-SDI 1080i, 4K UHD, MPEG-2 TS, H.264, H.265/HEVC, or audio format specifications.' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceEndpoint rdf:type rdf:Property ;
    rdfs:label 'Source Endpoint' ;
    rdfs:comment 'Identifier or address of the originating endpoint where the signal enters this path. May be an ingest port, satellite receiver, remote contribution feed, or studio source.' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContact rdf:type rdf:Property ;
    rdfs:label 'Technical Contact' ;
    rdfs:comment 'Name or identifier of the technical contact person or team responsible for troubleshooting and maintenance of this signal path.' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Uptime Percentage' ;
    rdfs:comment 'Calculated uptime percentage for this signal path over a defined measurement period, used for SLA compliance reporting and performance analysis.' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaPerformanceRecordId rdf:type rdf:Property ;
    rdfs:label 'Sla Performance Record Id' ;
    rdfs:comment 'Unique identifier for the SLA performance measurement record.' ;
    rdfs:domain ind:SlaPerformanceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualMttrMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Mttr Minutes' ;
    rdfs:comment 'The actual mean time to repair measured during the period, representing the average time taken to restore service after an incident.' ;
    rdfs:domain ind:SlaPerformanceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachRootCause rdf:type rdf:Property ;
    rdfs:label 'Breach Root Cause' ;
    rdfs:comment 'Detailed description of the root cause analysis for the SLA breach, identifying the underlying technical or operational issue.' ;
    rdfs:domain ind:SlaPerformanceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachRootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Breach Root Cause Category' ;
    rdfs:comment 'High-level categorization of the root cause for the SLA breach. [ENUM-REF-CANDIDATE: hardware_failure|software_defect|network_issue|power_outage|human_error|third_party|planned_maintenance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SlaPerformanceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCount rdf:type rdf:Property ;
    rdfs:label 'Incident Count' ;
    rdfs:comment 'The total number of incidents that occurred during the measurement period affecting the SLA.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measuredAvailabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Measured Availability Percentage' ;
    rdfs:comment 'The actual availability percentage achieved during the measurement period, calculated as (total uptime / total period) * 100.' ;
    rdfs:domain ind:SlaPerformanceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'The date when this SLA performance data was submitted to regulatory authorities for compliance reporting.' ;
    rdfs:domain ind:SlaPerformanceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Date' ;
    rdfs:comment 'The date when the remediation action was completed and verified.' ;
    rdfs:domain ind:SlaPerformanceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedToStakeholder rdf:type rdf:Property ;
    rdfs:label 'Reported To Stakeholder' ;
    rdfs:comment 'Indicates whether this SLA performance record has been formally reported to internal stakeholders or regulatory bodies.' ;
    rdfs:domain ind:SlaPerformanceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reporting Timestamp' ;
    rdfs:comment 'The date and time when this SLA performance record was generated and reported.' ;
    rdfs:domain ind:SlaPerformanceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Service Credit Amount' ;
    rdfs:comment 'The monetary value of service credits or penalties applied due to SLA breach, in US dollars.' ;
    rdfs:domain ind:SlaPerformanceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceCreditApplicable rdf:type rdf:Property ;
    rdfs:label 'Service Credit Applicable' ;
    rdfs:comment 'Indicates whether a service credit or penalty is applicable due to SLA breach in this measurement period.' ;
    rdfs:domain ind:SlaPerformanceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stakeholderNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Notification Date' ;
    rdfs:comment 'The date when stakeholders were notified of this SLA performance result, particularly important for breach notifications.' ;
    rdfs:domain ind:SlaPerformanceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetAvailabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Availability Percentage' ;
    rdfs:comment 'The target availability percentage defined in the SLA for this measurement period.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMttrMinutes rdf:type rdf:Property ;
    rdfs:label 'Target Mttr Minutes' ;
    rdfs:comment 'The target mean time to repair defined in the SLA for this measurement period.' ;
    rdfs:domain ind:SlaPerformanceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDowntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Downtime Minutes' ;
    rdfs:comment 'The cumulative downtime in minutes during the measurement period.' ;
    rdfs:domain ind:SlaPerformanceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activeUserCount rdf:type rdf:Property ;
    rdfs:label 'Active User Count' ;
    rdfs:comment 'The current number of unique users actively using this software license, tracked for compliance and utilization analysis.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualMaintenanceCostUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Maintenance Cost Usd' ;
    rdfs:comment 'The yearly cost for software maintenance, support, and updates in United States Dollars.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedDepartment rdf:type rdf:Property ;
    rdfs:label 'Assigned Department' ;
    rdfs:comment 'The business department or operational unit responsible for this software license (e.g., Broadcast Operations, Post-Production, IT Infrastructure, News, Engineering).' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentScope rdf:type rdf:Property ;
    rdfs:label 'Deployment Scope' ;
    rdfs:comment 'The technical deployment model for this software: on-premise (installed locally), cloud (vendor-hosted), hybrid (mixed), SaaS (Software as a Service subscription), desktop (workstation), server (data center), or mobile (device apps). [ENUM-REF-CANDIDATE: on_premise|cloud|hybrid|saas|desktop|server|mobile — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installedInstanceCount rdf:type rdf:Property ;
    rdfs:label 'Installed Instance Count' ;
    rdfs:comment 'The actual number of software installations or active instances currently deployed across Media Broadcasting infrastructure.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastComplianceAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Audit Date' ;
    rdfs:comment 'The date when this software license was last audited for compliance with vendor terms and internal Software Asset Management (SAM) policies.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseAgreementUrl rdf:type rdf:Property ;
    rdfs:label 'License Agreement Url' ;
    rdfs:comment 'The URL or document repository link to the End User License Agreement (EULA) or master license contract governing this software usage.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseCostUsd rdf:type rdf:Property ;
    rdfs:label 'License Cost Usd' ;
    rdfs:comment 'The total cost of the software license in United States Dollars, including initial purchase or annual subscription fee.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseNotes rdf:type rdf:Property ;
    rdfs:label 'License Notes' ;
    rdfs:comment 'Additional free-text notes, special terms, restrictions, or operational comments related to this software license.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current operational state of the software license: active (in use and compliant), expired (past end date), suspended (temporarily disabled), pending renewal (approaching expiry), cancelled (terminated), trial (evaluation period), or non-compliant (usage exceeds entitlement). [ENUM-REF-CANDIDATE: active|expired|suspended|pending_renewal|cancelled|trial|non_compliant — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Maintenance Included Flag' ;
    rdfs:comment 'Indicates whether software maintenance, support, and version updates are included in the license agreement. True if included, False if purchased separately.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextComplianceAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Audit Date' ;
    rdfs:comment 'The scheduled date for the next compliance audit or license verification review.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryUsageCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Usage Category' ;
    rdfs:comment 'The primary functional category or business purpose for which this software is used within Media Broadcasting operations. [ENUM-REF-CANDIDATE: broadcast_automation|media_asset_management|video_editing|audio_production|graphics_design|playout_control|traffic_billing|enterprise_resource_planning|customer_relationship_management|content_delivery|digital_rights_management|cloud_infrastructure|collaboration|security|other — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'The date when the software license was originally purchased or acquired by Media Broadcasting.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Renewal Owner Email' ;
    rdfs:comment 'The email address of the renewal owner for license management communications and notifications.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOwnerName rdf:type rdf:Property ;
    rdfs:label 'Renewal Owner Name' ;
    rdfs:comment 'The name of the individual or role responsible for managing license renewal, vendor negotiations, and contract administration.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatCount rdf:type rdf:Property ;
    rdfs:label 'Seat Count' ;
    rdfs:comment 'The number of authorized users, installations, or concurrent sessions permitted under this license agreement.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:softwareProductName rdf:type rdf:Property ;
    rdfs:label 'Software Product Name' ;
    rdfs:comment 'The commercial name of the licensed software product (e.g., Ericsson MediaFirst, Dalet Galaxy, Adobe Premiere Pro, Avid Media Composer).' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSupportContact rdf:type rdf:Property ;
    rdfs:label 'Vendor Support Contact' ;
    rdfs:comment 'The primary vendor support contact information (email, phone, or portal URL) for technical assistance and license inquiries.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessControlLevel rdf:type rdf:Property ;
    rdfs:label 'Access Control Level' ;
    rdfs:comment 'Security access level required to enter the studio space (public, restricted, secure, or high security).' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupPowerAvailable rdf:type rdf:Property ;
    rdfs:label 'Backup Power Available' ;
    rdfs:comment 'Indicates whether the studio has backup power (UPS or generator) for continuity during outages.' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bookingAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Booking Availability Flag' ;
    rdfs:comment 'Indicates whether the studio space is currently available for booking and scheduling.' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buildingSection rdf:type rdf:Property ;
    rdfs:label 'Building Section' ;
    rdfs:comment 'Named section or wing of the broadcast facility building where the studio is located (e.g., North Wing, Tower B, Production Block).' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cameraPositions rdf:type rdf:Property ;
    rdfs:label 'Camera Positions' ;
    rdfs:comment 'Number of fixed or standard camera positions configured in the studio layout.' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ceilingHeightFt rdf:type rdf:Property ;
    rdfs:label 'Ceiling Height Ft' ;
    rdfs:comment 'Clear ceiling height of the studio space measured in feet, critical for lighting rig and set design.' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlRoomAdjacent rdf:type rdf:Property ;
    rdfs:label 'Control Room Adjacent' ;
    rdfs:comment 'Indicates whether the studio has a dedicated control room directly adjacent or integrated.' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dailyBookingRateUsd rdf:type rdf:Property ;
    rdfs:label 'Daily Booking Rate Usd' ;
    rdfs:comment 'Standard daily rate charged for booking the studio space in US dollars. Used for internal cost allocation and external rental pricing.' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqft' ;
    rdfs:comment 'Total usable floor area of the studio space measured in square feet.' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorNumber rdf:type rdf:Property ;
    rdfs:label 'Floor Number' ;
    rdfs:comment 'Floor level within the broadcast facility building where the studio is located.' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:greenScreenAvailable rdf:type rdf:Property ;
    rdfs:label 'Green Screen Available' ;
    rdfs:comment 'Indicates whether the studio has permanent or semi-permanent green screen (chroma key) capability installed.' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hourlyBookingRateUsd rdf:type rdf:Property ;
    rdfs:label 'Hourly Booking Rate Usd' ;
    rdfs:comment 'Standard hourly rate charged for booking the studio space in US dollars. Used for internal cost allocation and external rental pricing.' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hvacType rdf:type rdf:Property ;
    rdfs:label 'Hvac Type' ;
    rdfs:comment 'Type of heating, ventilation, and air conditioning system installed (standard, silent for audio recording, climate-controlled, or none).' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lightingCapacityKw rdf:type rdf:Property ;
    rdfs:label 'Lighting Capacity Kw' ;
    rdfs:comment 'Maximum electrical capacity available for lighting equipment measured in kilowatts.' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lightingRigType rdf:type rdf:Property ;
    rdfs:label 'Lighting Rig Type' ;
    rdfs:comment 'Type of lighting infrastructure installed in the studio (fixed grid, motorized grid, track lighting, LED panel system, hybrid, or none).' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkConnectivity rdf:type rdf:Property ;
    rdfs:label 'Network Connectivity' ;
    rdfs:comment 'Network bandwidth capacity available in the studio for content transfer and live streaming (1Gbps, 10Gbps, 25Gbps, 40Gbps, 100Gbps).' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Scheduled date for the next maintenance or inspection of the studio facility.' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity' ;
    rdfs:comment 'Maximum number of audience or crew seats available in the studio space. Null for studios without seating.' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soundproofRating rdf:type rdf:Property ;
    rdfs:label 'Soundproof Rating' ;
    rdfs:comment 'Level of acoustic isolation and soundproofing quality of the studio space.' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studioCode rdf:type rdf:Property ;
    rdfs:label 'Studio Code' ;
    rdfs:comment 'Short alphanumeric code used for scheduling and booking systems (e.g., STA, NS1, GR3).' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studioType rdf:type rdf:Property ;
    rdfs:label 'Studio Type' ;
    rdfs:comment 'Classification of the studio space by its primary function and use case.' ;
    rdfs:domain ind:StudioFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:techAssetLifecycleId rdf:type rdf:Property ;
    rdfs:label 'Tech Asset Lifecycle Id' ;
    rdfs:comment 'Unique identifier for the technology asset lifecycle event record.' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTechEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Tech Employee Id' ;
    rdfs:comment 'Identifier of the user or technician who performed or authorized the lifecycle event.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryTechLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Tech Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this lifecycle event record.' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryTechCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Tech Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created this lifecycle event record in the system.' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedByUserName rdf:type rdf:Property ;
    rdfs:label 'Approved By User Name' ;
    rdfs:comment 'Name of the manager or executive who approved this lifecycle event.' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Depreciation Impact Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event affects the depreciation schedule of the asset (e.g., upgrade extends useful life, disposal triggers final depreciation).' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disposalCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Disposal Certificate Number' ;
    rdfs:comment 'Certificate or documentation number proving compliant disposal of the asset (applicable for disposal events requiring regulatory proof).' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCostAmount rdf:type rdf:Property ;
    rdfs:label 'Event Cost Amount' ;
    rdfs:comment 'Direct cost incurred for this lifecycle event (e.g., procurement price, installation labor cost, repair cost, disposal fee).' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventNotes rdf:type rdf:Property ;
    rdfs:label 'Event Notes' ;
    rdfs:comment 'Free-text notes providing additional context, observations, or details about this lifecycle event (e.g., reason for relocation, issues encountered during deployment, special handling instructions).' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleEventType rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Event Type' ;
    rdfs:comment 'Type of lifecycle state transition event: procurement (initial acquisition), deployment (put into service), relocation (moved to new location), upgrade (hardware/software enhancement), repair (corrective action), maintenance (preventive service), decommission (removed from service), disposal (final disposition). [ENUM-REF-CANDIDATE: procurement|deployment|relocation|upgrade|repair|maintenance|decommission|disposal — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performedByUserName rdf:type rdf:Property ;
    rdfs:label 'Performed By User Name' ;
    rdfs:comment 'Name of the user or technician who performed or authorized the lifecycle event.' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Impact Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event affects the warranty status of the asset (e.g., unauthorized repair voids warranty, upgrade extends warranty).' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualDowntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Downtime Minutes' ;
    rdfs:comment 'Actual duration in minutes that systems or services were unavailable during the change implementation. Compared against estimated downtime to measure accuracy of planning and identify process improvements.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualEffortHours rdf:type rdf:Property ;
    rdfs:label 'Actual Effort Hours' ;
    rdfs:comment 'Actual number of person-hours spent on planning, implementing, testing, and validating the change. Compared against estimated effort to improve future estimation accuracy.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the change implementation was completed. Compared against scheduled end time to measure execution efficiency and identify delays.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affectedSystems rdf:type rdf:Property ;
    rdfs:label 'Affected Systems' ;
    rdfs:comment 'Comma-separated list or detailed description of all technology systems, applications, infrastructure components, broadcast equipment, and network elements that will be impacted by the change. Includes upstream and downstream dependencies.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedToEmail rdf:type rdf:Property ;
    rdfs:label 'Assigned To Email' ;
    rdfs:comment 'Email address of the technical resource assigned to implement the change for coordination and status updates.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedToName rdf:type rdf:Property ;
    rdfs:label 'Assigned To Name' ;
    rdfs:comment 'Full name of the technical resource or team lead assigned to implement the change. Responsible for executing the implementation plan and coordinating technical activities.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Cab Approval Status' ;
    rdfs:comment 'Decision outcome from the Change Advisory Board review. Approved changes proceed to scheduling; rejected changes are closed; conditional approvals require additional information or modifications; deferred changes are postponed to future CAB meetings.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabComments rdf:type rdf:Property ;
    rdfs:label 'Cab Comments' ;
    rdfs:comment 'Feedback, conditions, concerns, or recommendations provided by the Change Advisory Board during their review. Captures the rationale behind approval decisions and any stipulations for implementation.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabReviewDate rdf:type rdf:Property ;
    rdfs:label 'Cab Review Date' ;
    rdfs:comment 'Date when the change request was formally reviewed and evaluated by the Change Advisory Board. Records when the approval decision was made.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'Technical domain classification of the change request indicating which technology area is affected. Infrastructure includes servers and storage; broadcast includes playout and transmission systems; network includes routers and switches; software includes applications and middleware.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Change Request Number' ;
    rdfs:comment 'Externally-known unique identifier for the change request, typically formatted as CHG followed by numeric sequence. Used for tracking and communication across IT teams and business stakeholders.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the change request was formally closed after successful implementation and post-implementation review. Marks the end of the change request lifecycle.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeRequired rdf:type rdf:Property ;
    rdfs:label 'Downtime Required' ;
    rdfs:comment 'Indicates whether the change implementation requires taking systems or broadcast services offline. Critical for scheduling changes during off-peak hours or maintenance windows to minimize audience impact.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDowntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Downtime Minutes' ;
    rdfs:comment 'Expected duration in minutes that systems or services will be unavailable during the change implementation. Used for planning maintenance windows and communicating impact to stakeholders.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Effort Hours' ;
    rdfs:comment 'Estimated number of person-hours required to plan, implement, test, and validate the change. Used for resource planning and cost estimation.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationOutcome rdf:type rdf:Property ;
    rdfs:label 'Implementation Outcome' ;
    rdfs:comment 'Final result of the change implementation. Successful indicates the change was implemented as planned; successful with issues indicates minor problems were encountered but resolved; failed indicates the change could not be completed; rolled back indicates the change was reverted; partially completed indicates some components were implemented.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postImplementationReviewDate rdf:type rdf:Property ;
    rdfs:label 'Post Implementation Review Date' ;
    rdfs:comment 'Date when the formal post-implementation review was conducted to assess the success of the change and capture lessons learned.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postImplementationReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Post Implementation Review Outcome' ;
    rdfs:comment 'Summary findings from the post-implementation review conducted after the change is deployed. Evaluates whether the change achieved its objectives, identifies lessons learned, and documents any unexpected issues or benefits.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterDepartment rdf:type rdf:Property ;
    rdfs:label 'Requester Department' ;
    rdfs:comment 'Business department or organizational unit of the change request submitter. Helps identify which business function is driving the change and aids in cost allocation and reporting.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterEmail rdf:type rdf:Property ;
    rdfs:label 'Requester Email' ;
    rdfs:comment 'Email address of the change request submitter for communication regarding the change status, approvals, and implementation updates.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterName rdf:type rdf:Property ;
    rdfs:label 'Requester Name' ;
    rdfs:comment 'Full name of the individual who submitted the change request. Typically a business stakeholder, technical lead, or operations manager identifying a need for technology change.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackPlan rdf:type rdf:Property ;
    rdfs:label 'Rollback Plan' ;
    rdfs:comment 'Detailed procedure for reverting the change and restoring systems to their pre-change state if the implementation fails or causes unexpected issues. Essential for minimizing broadcast disruption and ensuring business continuity.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Planned date and time when the change implementation is expected to be completed. Defines the maintenance window duration and helps coordinate resource allocation.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:techChangeRequestDescription rdf:type rdf:Property ;
    rdfs:label 'Tech Change Request Description' ;
    rdfs:comment 'Detailed narrative description of the technology change being requested, including technical specifications, scope of work, and specific systems or components to be modified. Provides comprehensive context for CAB review and implementation teams.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingPlan rdf:type rdf:Property ;
    rdfs:label 'Testing Plan' ;
    rdfs:comment 'Comprehensive testing strategy and test cases to validate the change before and after implementation. Includes functional testing, integration testing, performance testing, and user acceptance testing criteria.' ;
    rdfs:domain ind:TechChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quaternaryTechClosedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Tech Closed By User Employee Id' ;
    rdfs:comment 'Identifier of the user who formally closed the incident record. Links to user/employee master data.' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relatedChangeTechChangeRequestId rdf:type rdf:Property ;
    rdfs:label 'Related Change Tech Change Request Id' ;
    rdfs:comment 'Identifier of the related change request if this incident was caused by or resolved through a change in the ITIL change management process.' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechChangeRequest .

ind:relatedProblemId rdf:type rdf:Property ;
    rdfs:label 'Related Problem Id' ;
    rdfs:comment 'Identifier of the related problem record if this incident is linked to a known problem in the ITIL problem management process.' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechProblem .

ind:tertiaryTechResolvedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Tech Resolved By User Employee Id' ;
    rdfs:comment 'Identifier of the technician or engineer who resolved the incident. Links to user/employee master data.' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedService rdf:type rdf:Property ;
    rdfs:label 'Affected Service' ;
    rdfs:comment 'Name of the business service or technical service impacted by the incident (e.g., Live News Broadcast, VOD Streaming Platform, Ad Insertion Service, Network Operations Center Monitoring).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedResolverTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Resolver Team' ;
    rdfs:comment 'Name of the technical support team or resolver group currently assigned to investigate and resolve the incident (e.g., Broadcast Engineering, Network Operations, IT Infrastructure, Cybersecurity).' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closure Timestamp' ;
    rdfs:comment 'Date and time when the incident was formally closed after confirmation that the resolution was successful and no further action is required.' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactMethod rdf:type rdf:Property ;
    rdfs:label 'Contact Method' ;
    rdfs:comment 'Channel through which the incident was reported: phone call, email, self-service portal, automated monitoring system, or escalated from NOC alert.' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCategory rdf:type rdf:Property ;
    rdfs:label 'Incident Category' ;
    rdfs:comment 'High-level classification of the incident type: broadcast signal failures, IT system outages, network disruptions, cybersecurity events, infrastructure faults, or playout automation issues.' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentSubcategory rdf:type rdf:Property ;
    rdfs:label 'Incident Subcategory' ;
    rdfs:comment 'Detailed classification within the incident category (e.g., signal loss, server crash, DDoS attack, power failure, encoder malfunction).' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postIncidentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Post Incident Review Date' ;
    rdfs:comment 'Scheduled or completed date of the post-incident review meeting.' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postIncidentReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Post Incident Review Flag' ;
    rdfs:comment 'Indicates whether a formal post-incident review (PIR) or post-mortem is required for this incident. True = PIR required (typically for P1/P2 incidents), False = no PIR needed.' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedByName rdf:type rdf:Property ;
    rdfs:label 'Reported By Name' ;
    rdfs:comment 'Full name of the person or system that reported the incident.' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the incident was first reported to the service desk or detected by monitoring systems. This is the principal business event timestamp for the incident lifecycle.' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed narrative of the actions taken to resolve the incident, including troubleshooting steps, fixes applied, and workarounds implemented.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedByName rdf:type rdf:Property ;
    rdfs:label 'Resolved By Name' ;
    rdfs:comment 'Full name of the technician or engineer who resolved the incident.' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:techIncidentStatus rdf:type rdf:Property ;
    rdfs:label 'Tech Incident Status' ;
    rdfs:comment 'Current lifecycle state of the incident within the ITIL workflow: new (just reported), assigned (routed to resolver), in_progress (actively being worked), pending (awaiting external input), resolved (fix applied), closed (confirmed resolved), cancelled (invalid/duplicate). [ENUM-REF-CANDIDATE: new|assigned|in_progress|pending|resolved|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workaroundApplied rdf:type rdf:Property ;
    rdfs:label 'Workaround Applied' ;
    rdfs:comment 'Indicates whether a temporary workaround was applied to restore service before a permanent fix. True = workaround used, False = permanent fix applied immediately.' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workaroundDescription rdf:type rdf:Property ;
    rdfs:label 'Workaround Description' ;
    rdfs:comment 'Description of the temporary workaround applied to restore service while a permanent fix is developed.' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date when the technology project was completed and closed, which may differ from the planned end date due to schedule variance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetVarianceUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Usd' ;
    rdfs:comment 'Difference between total approved budget and forecast total cost in US dollars, indicating over-budget (negative) or under-budget (positive) status.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessSponsorName rdf:type rdf:Property ;
    rdfs:label 'Business Sponsor Name' ;
    rdfs:comment 'Name of the executive or senior leader sponsoring the technology project and providing business direction and funding approval.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalExpenditureUsd rdf:type rdf:Property ;
    rdfs:label 'Capital Expenditure Usd' ;
    rdfs:comment 'Portion of the project budget allocated to capital expenditure (CapEx) for long-term infrastructure assets such as broadcast equipment, servers, and network hardware.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeManagementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Change Management Required Flag' ;
    rdfs:comment 'Indicates whether formal organizational change management activities are required due to significant process, workflow, or operational changes introduced by the technology project.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Completion Date' ;
    rdfs:comment 'Current projected completion date for the technology project based on actual progress and remaining work, updated regularly during execution.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastTotalCostUsd rdf:type rdf:Property ;
    rdfs:label 'Forecast Total Cost Usd' ;
    rdfs:comment 'Current projected total cost for the technology project at completion in US dollars, based on actual spend and estimated remaining costs.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthIndicator rdf:type rdf:Property ;
    rdfs:label 'Health Indicator' ;
    rdfs:comment 'RAG (Red-Amber-Green) status indicator summarizing overall project health across schedule, budget, scope, and quality dimensions: green (on track), yellow (at risk), red (critical issues).' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationComplexity rdf:type rdf:Property ;
    rdfs:label 'Integration Complexity' ;
    rdfs:comment 'Assessment of the technical complexity of integrating the new technology with existing broadcast systems, workflows, and infrastructure: low, medium, high, or very high.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastStatusUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Status Update Date' ;
    rdfs:comment 'Date of the most recent project status update or progress report, used to track reporting currency and governance compliance.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneSummary rdf:type rdf:Property ;
    rdfs:label 'Milestone Summary' ;
    rdfs:comment 'High-level summary of key project milestones achieved and upcoming, providing snapshot of progress for executive reporting and stakeholder communication.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalExpenditureUsd rdf:type rdf:Property ;
    rdfs:label 'Operational Expenditure Usd' ;
    rdfs:comment 'Portion of the project budget allocated to operational expenditure (OpEx) for recurring costs such as cloud services, software licenses, and maintenance contracts.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Originally scheduled date for the technology project to complete and close, as defined during project planning phase.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectManagerName rdf:type rdf:Property ;
    rdfs:label 'Project Manager Name' ;
    rdfs:comment 'Name of the project manager responsible for day-to-day coordination, scheduling, and delivery of the technology project.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectPhase rdf:type rdf:Property ;
    rdfs:label 'Project Phase' ;
    rdfs:comment 'Current lifecycle phase of the technology project following PMI PMBOK methodology: initiation, planning, execution, monitoring and control, closure, on hold, or cancelled. [ENUM-REF-CANDIDATE: initiation|planning|execution|monitoring_and_control|closure|on_hold|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Overall risk assessment for the technology project based on identified risks, mitigation effectiveness, and potential impact to schedule, budget, or scope.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendToDateUsd rdf:type rdf:Property ;
    rdfs:label 'Spend To Date Usd' ;
    rdfs:comment 'Cumulative actual expenditure on the technology project to date in US dollars, tracked against the total approved budget.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyOwnerName rdf:type rdf:Property ;
    rdfs:label 'Technology Owner Name' ;
    rdfs:comment 'Name of the technology leader or architect responsible for technical delivery and infrastructure outcomes of the project.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyStack rdf:type rdf:Property ;
    rdfs:label 'Technology Stack' ;
    rdfs:comment 'Description of the core technologies, platforms, and systems being deployed or upgraded as part of the project (e.g., SMPTE ST 2110 IP infrastructure, AWS cloud platform, ATSC 3.0 transmitters).' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Total Budget Usd' ;
    rdfs:comment 'Total approved budget for the technology infrastructure project in US dollars, including capital expenditure and operational expenditure components.' ;
    rdfs:domain ind:TechProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachPenaltyDefinition rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Definition' ;
    rdfs:comment 'Description of penalties, remediation actions, or service credits applied when SLA targets are not met. May include financial penalties, escalation procedures, or compensatory measures.' ;
    rdfs:domain ind:TechSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Percentage' ;
    rdfs:comment 'Percentage threshold below target availability that triggers a formal SLA breach (e.g., if target is 99.99% and breach threshold is 99.90%, falling below 99.90% triggers breach penalties).' ;
    rdfs:domain ind:TechSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessUnitServed rdf:type rdf:Property ;
    rdfs:label 'Business Unit Served' ;
    rdfs:comment 'Name of the internal business unit or division that this SLA serves (e.g., News Division, Sports Production, Digital Streaming, Linear Broadcast Operations).' ;
    rdfs:domain ind:TechSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'Description of circumstances, events, or conditions excluded from SLA measurement (e.g., planned maintenance windows, force majeure events, third-party vendor outages).' ;
    rdfs:domain ind:TechSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when this SLA was last formally reviewed by stakeholders.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringTool rdf:type rdf:Property ;
    rdfs:label 'Monitoring Tool' ;
    rdfs:comment 'Name of the monitoring system or tool used to measure and track SLA performance (e.g., Nagios, SolarWinds, Splunk, custom NOC dashboard).' ;
    rdfs:domain ind:TechSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtbfTargetHours rdf:type rdf:Property ;
    rdfs:label 'Mtbf Target Hours' ;
    rdfs:comment 'Target mean time between failures in hours - the average operational time between system failures or service interruptions.' ;
    rdfs:domain ind:TechSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mttrTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Mttr Target Minutes' ;
    rdfs:comment 'Target mean time to repair in minutes - the average time committed to restore service after an incident or failure.' ;
    rdfs:domain ind:TechSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:owningTechnologyTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Technology Team' ;
    rdfs:comment 'Name of the technology team or department responsible for delivering and maintaining this SLA (e.g., Broadcast Engineering, Network Operations Center, IT Infrastructure, Master Control).' ;
    rdfs:domain ind:TechSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimeTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Target Minutes' ;
    rdfs:comment 'Target resolution time in minutes for fully resolving and closing an incident or service request.' ;
    rdfs:domain ind:TechSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseTimeTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Response Time Target Minutes' ;
    rdfs:comment 'Target response time in minutes for NOC or helpdesk to acknowledge and begin addressing an incident or service request.' ;
    rdfs:domain ind:TechSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Frequency at which the SLA definition and targets are formally reviewed and potentially revised (monthly, quarterly, semi-annual, annual).' ;
    rdfs:domain ind:TechSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Service Scope Description' ;
    rdfs:comment 'Detailed description of the technology services, systems, and infrastructure components covered by this SLA.' ;
    rdfs:domain ind:TechSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Status' ;
    rdfs:comment 'Current lifecycle status of the SLA definition (active, inactive, draft, under review, expired, suspended).' ;
    rdfs:domain ind:TechSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertification rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification' ;
    rdfs:comment 'Regulatory compliance and safety certifications held by the transmission equipment (e.g., FCC Part 15, CE Mark, UL Listed). Demonstrates conformance to technical and safety standards.' ;
    rdfs:domain ind:TransmissionEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Classification of the transmission equipment by its primary function in the broadcast signal chain. Determines operational role and maintenance requirements. [ENUM-REF-CANDIDATE: transmitter|encoder|multiplexer|modulator|satellite_uplink|rf_amplifier|antenna_system|signal_processor|exciter|combiner|filter|switch — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransmissionEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fccLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Fcc License Number' ;
    rdfs:comment 'FCC broadcast license authorization number under which this transmission equipment is permitted to operate. Required for regulatory compliance and spectrum usage authorization.' ;
    rdfs:domain ind:TransmissionEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the transmission equipment was physically installed and commissioned at the facility. Used for depreciation calculation and lifecycle tracking.' ;
    rdfs:domain ind:TransmissionEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceContractNumber rdf:type rdf:Property ;
    rdfs:label 'Maintenance Contract Number' ;
    rdfs:comment 'Reference number for the active maintenance or service level agreement (SLA) covering this transmission equipment. Links to vendor support entitlements and response time commitments.' ;
    rdfs:domain ind:TransmissionEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Operating Frequency Mhz' ;
    rdfs:comment 'Specific center frequency in megahertz at which the transmission equipment is configured to operate. Must align with FCC license authorization.' ;
    rdfs:domain ind:TransmissionEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerOutputKw rdf:type rdf:Property ;
    rdfs:label 'Power Output Kw' ;
    rdfs:comment 'Maximum rated transmission power output of the equipment measured in kilowatts. Critical for coverage area calculation and FCC licensing compliance.' ;
    rdfs:domain ind:TransmissionEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redundancyRole rdf:type rdf:Property ;
    rdfs:label 'Redundancy Role' ;
    rdfs:comment 'Role of this equipment in the redundancy and failover architecture. Defines automatic switchover behavior during primary equipment failure to ensure broadcast continuity.' ;
    rdfs:domain ind:TransmissionEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snmpCommunityString rdf:type rdf:Property ;
    rdfs:label 'Snmp Community String' ;
    rdfs:comment 'Authentication credential for SNMP-based monitoring and management of the transmission equipment. Restricted access credential for NOC operations.' ;
    rdfs:domain ind:TransmissionEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryVendorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Vendor Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for managing this vendor contract, monitoring performance, and coordinating renewals. Typically a technology manager or procurement specialist.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualValue rdf:type rdf:Property ;
    rdfs:label 'Annual Value' ;
    rdfs:comment 'Total annual financial commitment for the vendor contract in USD, including recurring fees, maintenance charges, and subscription costs. Used for budget planning and vendor spend analysis.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coveredAssets rdf:type rdf:Property ;
    rdfs:label 'Covered Assets' ;
    rdfs:comment 'Textual description of broadcast infrastructure equipment, IT systems, or services covered under this contract (e.g., transmission towers, studio cameras, network switches, CDN services, MAM software licenses).' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Escalation Rate Percent' ;
    rdfs:comment 'Annual percentage increase in contract value for multi-year agreements. Used for budget forecasting and cost modeling. Null if fixed pricing.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyProvisions rdf:type rdf:Property ;
    rdfs:label 'Penalty Provisions' ;
    rdfs:comment 'Description of financial penalties or service credits applicable when vendor fails to meet SLA commitments or contractual obligations.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementMethod rdf:type rdf:Property ;
    rdfs:label 'Procurement Method' ;
    rdfs:comment 'Method used to award the contract: RFP (Request for Proposal), RFQ (Request for Quotation), sole_source (single vendor), competitive_bid (multiple bidders), framework_agreement (pre-negotiated terms), direct_award (non-competitive).' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Hours' ;
    rdfs:comment 'Maximum time in hours for vendor to respond to critical incidents or support requests under SLA terms. Null if not applicable to contract type.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceScope rdf:type rdf:Property ;
    rdfs:label 'Service Scope' ;
    rdfs:comment 'Detailed description of services provided under the contract including maintenance activities, support coverage, managed service responsibilities, or license entitlements.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uptimeGuaranteePercent rdf:type rdf:Property ;
    rdfs:label 'Uptime Guarantee Percent' ;
    rdfs:comment 'Contractually guaranteed system or service availability percentage (e.g., 99.9% for three-nines uptime). Used to measure vendor performance and trigger SLA credits.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicantId rdf:type rdf:Property ;
    rdfs:label 'Applicant Id' ;
    rdfs:comment 'Unique identifier for each job applicant who has applied to a Media Broadcasting requisition. Primary key for the applicant master record.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Applicant .

ind:referralEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Referral Employee Id' ;
    rdfs:comment 'Employee ID of the internal staff member who referred this applicant. Nullable if not an employee referral.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requisitionId rdf:type rdf:Property ;
    rdfs:label 'Requisition Id' ;
    rdfs:comment 'Reference to the job requisition this applicant applied for. Links to the open position posting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requisition .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'First line of applicant\'s current residential address (street number and name).' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Second line of applicant\'s address (apartment, suite, unit number). Nullable.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternatePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Alternate Phone Number' ;
    rdfs:comment 'Secondary contact phone number for the applicant. Optional backup contact method.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date when the applicant submitted their application for the requisition. Business event timestamp for application lifecycle.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Externally-visible unique application tracking number assigned when candidate submits application. Format: APP-YYYYMMDD-sequence.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationSource rdf:type rdf:Property ;
    rdfs:label 'Application Source' ;
    rdfs:comment 'Channel or platform through which the applicant submitted their application (e.g., LinkedIn, Indeed, employee referral, recruitment agency).' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the application in the recruitment workflow (e.g., new, screening, interviewed, offer extended, rejected). [ENUM-REF-CANDIDATE: new|screening|interview_scheduled|interviewed|offer_extended|offer_accepted|offer_declined|rejected|withdrawn — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckConsent rdf:type rdf:Property ;
    rdfs:label 'Background Check Consent' ;
    rdfs:comment 'Indicates whether the applicant has provided consent for a background check as part of the hiring process. Required for compliance.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverLetterReference rdf:type rdf:Property ;
    rdfs:label 'Cover Letter Reference' ;
    rdfs:comment 'Reference identifier or URI to the applicant\'s cover letter document. Nullable if not provided.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentEmployer rdf:type rdf:Property ;
    rdfs:label 'Current Employer' ;
    rdfs:comment 'Name of the organization where the applicant is currently employed. Nullable if unemployed or not disclosed.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentJobTitle rdf:type rdf:Property ;
    rdfs:label 'Current Job Title' ;
    rdfs:comment 'Job title or role the applicant currently holds at their present employer. Nullable if unemployed.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:degreeField rdf:type rdf:Property ;
    rdfs:label 'Degree Field' ;
    rdfs:comment 'Major or field of study for the applicant\'s highest degree (e.g., Communications, Journalism, Film Production, Business Administration).' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:desiredSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Desired Salary Amount' ;
    rdfs:comment 'Salary amount the applicant is seeking for the position. Used for compensation alignment during offer stage.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:desiredSalaryCurrency rdf:type rdf:Property ;
    rdfs:label 'Desired Salary Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the desired salary amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Disability Status' ;
    rdfs:comment 'Self-reported disability status for OFCCP Section 503 compliance reporting. Collected separately for accommodation and compliance purposes.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earliestStartDate rdf:type rdf:Property ;
    rdfs:label 'Earliest Start Date' ;
    rdfs:comment 'Earliest date the applicant is available to begin employment if an offer is extended.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eeocEthnicity rdf:type rdf:Property ;
    rdfs:label 'Eeoc Ethnicity' ;
    rdfs:comment 'Self-reported ethnicity for EEOC applicant flow reporting. Used for diversity and compliance tracking.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeocGender rdf:type rdf:Property ;
    rdfs:label 'Eeoc Gender' ;
    rdfs:comment 'Self-reported gender for EEOC applicant flow reporting. Collected separately from application data for compliance purposes.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeocRace rdf:type rdf:Property ;
    rdfs:label 'Eeoc Race' ;
    rdfs:comment 'Self-reported race for EEOC applicant flow reporting. Collected for diversity and compliance tracking purposes.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highestEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Highest Education Level' ;
    rdfs:comment 'Highest level of formal education completed by the applicant (e.g., high school, bachelor, master, doctorate).' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalFirstName rdf:type rdf:Property ;
    rdfs:label 'Legal First Name' ;
    rdfs:comment 'Applicant\'s legal first name as it appears on government-issued identification documents.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalLastName rdf:type rdf:Property ;
    rdfs:label 'Legal Last Name' ;
    rdfs:comment 'Applicant\'s legal last name (surname/family name) as it appears on government-issued identification.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalMiddleName rdf:type rdf:Property ;
    rdfs:label 'Legal Middle Name' ;
    rdfs:comment 'Applicant\'s legal middle name or initial. Nullable if not provided.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'Name the applicant prefers to be called during the recruitment process. May differ from legal name.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruitmentAgencyName rdf:type rdf:Property ;
    rdfs:label 'Recruitment Agency Name' ;
    rdfs:comment 'Name of the external recruitment or staffing agency that sourced this applicant. Nullable if not agency-sourced.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resumeDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Resume Document Reference' ;
    rdfs:comment 'Reference identifier or URI to the applicant\'s resume/CV document stored in the Media Asset Management (MAM) or document management system.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:universityName rdf:type rdf:Property ;
    rdfs:label 'University Name' ;
    rdfs:comment 'Name of the educational institution where the applicant earned their highest degree.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veteranStatus rdf:type rdf:Property ;
    rdfs:label 'Veteran Status' ;
    rdfs:comment 'Self-reported veteran status for OFCCP (Office of Federal Contract Compliance Programs) compliance reporting.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:willingToRelocate rdf:type rdf:Property ;
    rdfs:label 'Willing To Relocate' ;
    rdfs:comment 'Indicates whether the applicant is willing to relocate for the position if required.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of relevant professional work experience reported by the applicant. Used for qualification screening.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Id' ;
    rdfs:comment 'Unique identifier for the benefit enrollment record. Primary key for this entity.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitPlanId rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Id' ;
    rdfs:comment 'Reference to the specific benefit plan in which the employee is enrolling. Links to the benefit plan master record.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPlan .

ind:annualElectionAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Election Amount' ;
    rdfs:comment 'For FSA, HSA, or other contribution-based plans, the total annual amount the employee elected to contribute for the plan year. Expressed in USD. Nullable for non-contribution plans.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'The name of the insurance carrier or benefits provider administering this plan (e.g., Blue Cross Blue Shield, Aetna, Fidelity, Vanguard). Used for vendor management and claims coordination.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingentBeneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Contingent Beneficiary Name' ;
    rdfs:comment 'The full legal name of the contingent (secondary) beneficiary who receives benefits if the primary beneficiary is deceased or unable to receive benefits. Nullable if no contingent beneficiary designated.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingentBeneficiaryRelationship rdf:type rdf:Property ;
    rdfs:label 'Contingent Beneficiary Relationship' ;
    rdfs:comment 'The relationship of the contingent beneficiary to the employee. [ENUM-REF-CANDIDATE: spouse|child|parent|sibling|domestic_partner|other_relative|friend|estate|trust|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'The level of coverage selected by the employee, determining who is covered under the benefit plan (employee only, employee plus spouse, employee plus children, full family, or employee plus domestic partner).' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeContributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Frequency' ;
    rdfs:comment 'The frequency at which the employee contribution is deducted from payroll or paid by the employee.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerContributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Frequency' ;
    rdfs:comment 'The frequency at which the employer contribution is made toward the benefit plan.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Confirmation Number' ;
    rdfs:comment 'A confirmation or transaction number provided by the benefits administration system or carrier when the enrollment is processed. Used for audit trail and employee inquiries.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Human-readable business identifier for the benefit enrollment, typically used in HR systems and employee communications. Format: BEN-YYYYNNNN where YYYY is year and NNNN is sequence.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSource rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source' ;
    rdfs:comment 'The triggering event or process that allowed this enrollment to occur. New hire indicates initial employment enrollment; open enrollment indicates annual election period; qualifying life event (QLE) indicates mid-year change due to marriage, birth, etc.; plan change indicates employee-initiated modification; rehire indicates return to employment.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the benefit enrollment. Pending indicates awaiting approval or effective date; active indicates currently in force; terminated indicates coverage has ended; suspended indicates temporary hold; cancelled indicates enrollment was voided before becoming active; waived indicates employee declined coverage.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceOfInsurabilityRequired rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Required' ;
    rdfs:comment 'Boolean flag indicating whether the employee must provide medical evidence of insurability (health questionnaire, medical exam) to qualify for this coverage level. Typically required for supplemental life insurance above guaranteed issue amounts.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceOfInsurabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Status' ;
    rdfs:comment 'If evidence_of_insurability_required is true, this field tracks the status of the EOI submission and approval process. Not_required indicates no EOI needed; pending indicates awaiting carrier review; approved indicates coverage granted; denied indicates coverage declined; incomplete indicates additional information needed.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'The calendar or fiscal year for which this enrollment is effective. Used to track enrollments across annual benefit cycles and open enrollment periods. Format: YYYY.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBeneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Primary Beneficiary Name' ;
    rdfs:comment 'The full legal name of the primary beneficiary designated to receive benefits in the event of the employees death. Applicable primarily to life insurance and retirement plans. Nullable if no beneficiary designated.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBeneficiaryPercentage rdf:type rdf:Property ;
    rdfs:label 'Primary Beneficiary Percentage' ;
    rdfs:comment 'The percentage of benefits allocated to the primary beneficiary. Typically 100 for single beneficiary or split among multiple. Value range 0.00 to 100.00.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryBeneficiaryRelationship rdf:type rdf:Property ;
    rdfs:label 'Primary Beneficiary Relationship' ;
    rdfs:comment 'The relationship of the primary beneficiary to the employee. Used for compliance and verification purposes. [ENUM-REF-CANDIDATE: spouse|child|parent|sibling|domestic_partner|other_relative|friend|estate|trust|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingEventDate rdf:type rdf:Property ;
    rdfs:label 'Qualifying Event Date' ;
    rdfs:comment 'The date on which the qualifying life event occurred (e.g., marriage date, birth date, loss of coverage date). Nullable for non-QLE enrollments. Used to validate enrollment timing compliance.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingEventType rdf:type rdf:Property ;
    rdfs:label 'Qualifying Event Type' ;
    rdfs:comment 'If enrollment_source is qualifying_life_event, this field specifies the type of life event that triggered the mid-year enrollment change. Nullable for non-QLE enrollments. [ENUM-REF-CANDIDATE: marriage|divorce|birth|adoption|death_of_dependent|loss_of_coverage|employment_status_change|dependent_age_limit|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tobaccoUserFlag rdf:type rdf:Property ;
    rdfs:label 'Tobacco User Flag' ;
    rdfs:comment 'Boolean flag indicating whether the employee declared tobacco use during enrollment. Used for premium rating and wellness program eligibility. Protected health information under HIPAA.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Total Premium Amount' ;
    rdfs:comment 'The total cost of the benefit plan per pay period, representing the sum of employee and employer contributions. Expressed in USD. Used for financial reporting and cost analysis.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wellnessProgramParticipantFlag rdf:type rdf:Property ;
    rdfs:label 'Wellness Program Participant Flag' ;
    rdfs:comment 'Boolean flag indicating whether the employee is participating in employer-sponsored wellness programs that may affect premium rates or provide incentives.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Unique identifier for the professional certification record. Primary key for the certification entity.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Url' ;
    rdfs:comment 'Web URL or digital link to the electronic certificate or credential badge. Used for digital verification and display of credentials.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationCategory rdf:type rdf:Property ;
    rdfs:label 'Certification Category' ;
    rdfs:comment 'Functional domain or technical discipline that the certification covers. Used to align certifications with job roles and departmental needs. [ENUM-REF-CANDIDATE: broadcast_engineering|it_infrastructure|cloud_computing|network_engineering|audio_engineering|video_engineering|rf_transmission|compliance_regulatory|project_management|cybersecurity — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationCode rdf:type rdf:Property ;
    rdfs:label 'Certification Code' ;
    rdfs:comment 'Short code or abbreviation for the certification type. Examples: GROL, CBNT, CBT, CPBE, AWS-SAA, SMPTE-CTS. Used for internal classification and reporting.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'Proficiency or seniority level represented by the certification. Entry-level certifications demonstrate foundational knowledge; expert and master levels indicate advanced expertise and leadership capability.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Full official name of the professional certification, license, or credential. Examples: FCC General Radiotelephone Operator License (GROL), SBE Certified Broadcast Networking Technologist (CBNT), AWS Certified Solutions Architect, SMPTE Certified Technology Specialist.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Unique certificate or license number issued by the certifying body. This is the official credential identifier that can be used for verification purposes.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Classification of the certification based on its nature and purpose. Regulatory licenses are legally required for specific broadcast operations; professional certifications demonstrate industry expertise; technical certifications validate specialized technical skills; vendor certifications are product-specific credentials; industry credentials are association-based qualifications.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours Completed' ;
    rdfs:comment 'Number of continuing education hours the employee has completed toward the current renewal cycle. Used to track progress toward recertification requirements.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:continuingEducationHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours Required' ;
    rdfs:comment 'Number of continuing education or professional development hours required to maintain or renew the certification. Null for certifications without continuing education requirements.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentStoragePath rdf:type rdf:Property ;
    rdfs:label 'Document Storage Path' ;
    rdfs:comment 'File path or document management system reference to the scanned or digital copy of the physical certificate. Used for record retention and audit purposes.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerSponsored rdf:type rdf:Property ;
    rdfs:label 'Employer Sponsored' ;
    rdfs:comment 'Indicates whether the certification was sponsored or paid for by the employer. True if the company funded the certification; false if the employee self-funded it.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:examScore rdf:type rdf:Property ;
    rdfs:label 'Exam Score' ;
    rdfs:comment 'Score achieved on the certification exam, if applicable. May be a percentage, numeric score, or standardized score depending on the certification body. Null for certifications that do not have scored exams.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRegulatoryRequired rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Required' ;
    rdfs:comment 'Indicates whether this certification is required by law or regulation for the employee to perform specific duties. True for FCC licenses and other legally mandated credentials; false for voluntary professional certifications.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRequiredForRole rdf:type rdf:Property ;
    rdfs:label 'Is Required For Role' ;
    rdfs:comment 'Indicates whether this certification is a mandatory requirement for the employees current job role. True for certifications that are job prerequisites (e.g., FCC GROL for broadcast engineers); false for optional or supplementary credentials.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'Date by which the certification must be renewed to maintain active status. Used for proactive renewal reminders and compliance monitoring.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passingScore rdf:type rdf:Property ;
    rdfs:label 'Passing Score' ;
    rdfs:comment 'Minimum score required to pass the certification exam. Used to contextualize the exam score and assess performance relative to the standard.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'Name of the organization or institution that provided the training or preparation for the certification exam. May be the same as the issuing body or a separate training vendor.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationPlanId rdf:type rdf:Property ;
    rdfs:label 'Compensation Plan Id' ;
    rdfs:comment 'Unique identifier for the compensation plan record. Primary key for the compensation plan entity.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jobProfileId rdf:type rdf:Property ;
    rdfs:label 'Job Profile Id' ;
    rdfs:comment 'Reference to the job profile or position that this compensation plan is associated with. Used when the plan is defined at the job level rather than individual employee level.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Reference to the department or organizational unit where this compensation plan applies. Used for departmental compensation structures.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:baseSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Base Salary Amount' ;
    rdfs:comment 'Annual base salary amount for salaried employees. Null for hourly or commission-only plans.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusEligible rdf:type rdf:Property ;
    rdfs:label 'Bonus Eligible' ;
    rdfs:comment 'Indicates whether the employee under this plan is eligible for performance bonuses, annual bonuses, or incentive compensation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flsaClassification rdf:type rdf:Property ;
    rdfs:label 'Flsa Classification' ;
    rdfs:comment 'FLSA classification determining overtime eligibility: exempt (not eligible for overtime) or non-exempt (eligible for overtime pay).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hourlyRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate' ;
    rdfs:comment 'Hourly wage rate for hourly employees. Null for salaried or commission-only plans.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'Frequency at which compensation is paid to the employee: weekly (52 times/year), bi-weekly (26 times/year), semi-monthly (24 times/year), or monthly (12 times/year).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Pay grade or band assigned to this compensation plan within the organization\'s compensation structure (e.g., \'Grade 5\', \'Band C\', \'Level 3\').' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payStep rdf:type rdf:Property ;
    rdfs:label 'Pay Step' ;
    rdfs:comment 'Step or increment within the pay grade, typically representing progression based on tenure or performance (e.g., \'Step 1\', \'Step 2\').' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDifferentialEligible rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Eligible' ;
    rdfs:comment 'Indicates whether the employee is eligible for shift differential pay for working non-standard hours (evening, night, weekend shifts).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shiftDifferentialRate rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Rate' ;
    rdfs:comment 'Additional hourly rate or percentage added for shift differential pay. Null if shift differential not applicable.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Standard Hours Per Week' ;
    rdfs:comment 'Standard number of hours per week expected under this compensation plan (e.g., 40.00 for full-time, 20.00 for part-time).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetBonusPercent rdf:type rdf:Property ;
    rdfs:label 'Target Bonus Percent' ;
    rdfs:comment 'Target bonus as a percentage of base salary for bonus-eligible employees. Represents the expected bonus at 100% performance achievement.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionCode rdf:type rdf:Property ;
    rdfs:label 'Union Code' ;
    rdfs:comment 'Code identifying the labor union or collective bargaining unit governing this compensation plan (e.g., IATSE, SAG-AFTRA, NABET-CWA). Null if non-union.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionScaleApplicable rdf:type rdf:Property ;
    rdfs:label 'Union Scale Applicable' ;
    rdfs:comment 'Indicates whether this compensation plan is subject to union scale rates and collective bargaining agreement terms.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workScheduleType rdf:type rdf:Property ;
    rdfs:label 'Work Schedule Type' ;
    rdfs:comment 'Type of work schedule associated with this compensation plan: full-time (standard 40 hours/week), part-time (less than full-time), seasonal (recurring periods), temporary (fixed duration), or on-call (as-needed).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryActionId rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Id' ;
    rdfs:comment 'Unique identifier for the disciplinary action record. Primary key for the disciplinary action entity.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDisciplinaryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Disciplinary Employee Id' ;
    rdfs:comment 'Identifier of the Media Broadcasting employee who is the subject of this disciplinary action.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryDisciplinaryIssuingManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Disciplinary Issuing Manager Employee Id' ;
    rdfs:comment 'Identifier of the manager or supervisor who issued the disciplinary action to the employee.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionDate rdf:type rdf:Property ;
    rdfs:label 'Action Date' ;
    rdfs:comment 'Date the disciplinary action was formally issued to the employee. This is the official date of record for the action and starts any applicable timelines.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business identifier for the disciplinary action, formatted as DA-YYYYNNNN for external reference and case tracking.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle state of the disciplinary action: draft (being prepared), pending review (awaiting HR/legal approval), active (in effect), completed (action fulfilled or time elapsed), overturned (reversed on appeal), or expired (no longer on employee record per retention policy).' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealFiledDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Date' ;
    rdfs:comment 'Date the employee filed a formal appeal or grievance. Null if no appeal has been filed.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Date' ;
    rdfs:comment 'Date the employee signed or electronically acknowledged the disciplinary action documentation. Null if not yet acknowledged.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the employee has acknowledged receipt and review of the disciplinary action documentation. True if acknowledged, false if not yet acknowledged.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeResponse rdf:type rdf:Property ;
    rdfs:label 'Employee Response' ;
    rdfs:comment 'Written response or statement provided by the employee regarding the disciplinary action. May include explanations, disagreements, or mitigating circumstances. Null if no response provided.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationSummary rdf:type rdf:Property ;
    rdfs:label 'Investigation Summary' ;
    rdfs:comment 'Summary of the investigation conducted prior to issuing the disciplinary action, including interviews, evidence reviewed, and findings. Documents due process and fair treatment.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipEndDate rdf:type rdf:Property ;
    rdfs:label 'Pip End Date' ;
    rdfs:comment 'End date of the performance improvement plan period if action type is PIP. Typically 30, 60, or 90 days from start. Null for non-PIP actions.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pipStartDate rdf:type rdf:Property ;
    rdfs:label 'Pip Start Date' ;
    rdfs:comment 'Start date of the performance improvement plan period if action type is PIP. Null for non-PIP actions.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyViolated rdf:type rdf:Property ;
    rdfs:label 'Policy Violated' ;
    rdfs:comment 'Reference to the specific company policy, code of conduct section, or employment agreement clause that was violated. Includes policy number and title for traceability.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordRetentionDate rdf:type rdf:Property ;
    rdfs:label 'Record Retention Date' ;
    rdfs:comment 'Date until which this disciplinary action record must be retained in the employee file per employment law and company policy. After this date, record may be purged or archived per retention schedule.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'Date by which the employee must provide a written response, complete required corrective actions, or demonstrate improvement. Null if no response is required.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'End date of suspension period if action type is suspension. Null for non-suspension actions.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionPaidFlag rdf:type rdf:Property ;
    rdfs:label 'Suspension Paid Flag' ;
    rdfs:comment 'Indicates whether the suspension is paid (true) or unpaid (false). Null for non-suspension actions. Paid suspensions are typically used during investigations; unpaid for disciplinary purposes.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'Start date of suspension period if action type is suspension. Null for non-suspension actions.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Termination Triggered Flag' ;
    rdfs:comment 'Indicates whether this disciplinary action resulted in or triggered employee termination. True if termination occurred, false otherwise. Feeds termination workflow when true.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Union Notification Required Flag' ;
    rdfs:comment 'Indicates whether union notification is required for this disciplinary action per collective bargaining agreement. True for union-represented employees in positions covered by CBA disciplinary procedures.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Union Notified Date' ;
    rdfs:comment 'Date the union representative was formally notified of the disciplinary action. Null if union notification is not required or not yet completed.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unionRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Union Representative Name' ;
    rdfs:comment 'Name of the union representative notified and involved in the disciplinary action process. Null if not applicable.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCategory rdf:type rdf:Property ;
    rdfs:label 'Violation Category' ;
    rdfs:comment 'High-level classification of the policy violation type: attendance (tardiness, absenteeism), performance (failure to meet job standards), conduct (behavioral issues), safety (workplace safety violations), compliance (regulatory or legal violations), confidentiality (data/information breach), or harassment (workplace harassment or discrimination). [ENUM-REF-CANDIDATE: attendance|performance|conduct|safety|compliance|confidentiality|harassment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationId rdf:type rdf:Property ;
    rdfs:label 'Work Location Id' ;
    rdfs:comment 'Reference to the primary physical location where the employee is based. Used for facilities management, real estate planning, and regional workforce analytics.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Full name of the person to be contacted in case of employee emergency. Critical for workplace safety and incident response.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Phone number of the emergency contact. Primary method for reaching emergency contact in case of workplace incident or employee emergency.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactRelationship rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Relationship' ;
    rdfs:comment 'Relationship of the emergency contact to the employee (e.g., spouse, parent, sibling, friend). Provides context for emergency communications.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeNumber rdf:type rdf:Property ;
    rdfs:label 'Employee Number' ;
    rdfs:comment 'Business-assigned unique employee number used for HR operations, payroll, and external reporting. Format: two-letter prefix followed by six digits (e.g., MB123456).' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current lifecycle status of the employee\'s relationship with Media Broadcasting. Active indicates currently working; other statuses indicate various non-working states.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the employee\'s employment arrangement. Determines benefits eligibility, work schedule expectations, and contract terms.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Home Address Line1' ;
    rdfs:comment 'First line of the employee\'s residential address (street number and name). Used for payroll tax calculations, benefits administration, and emergency contact.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Home Address Line2' ;
    rdfs:comment 'Second line of the employee\'s residential address (apartment, suite, unit number). Optional field. Used for accurate mail delivery and address verification.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeCity rdf:type rdf:Property ;
    rdfs:label 'Home City' ;
    rdfs:comment 'City or municipality of the employee\'s residential address. Used for payroll tax calculations, benefits administration, and geographic workforce analytics.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Home Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the employee\'s residential address (e.g., USA, GBR, CAN). Used for international payroll, tax compliance, and global workforce analytics.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homePostalCode rdf:type rdf:Property ;
    rdfs:label 'Home Postal Code' ;
    rdfs:comment 'Postal code or ZIP code of the employee\'s residential address. Used for payroll tax calculations, benefits administration, and mail delivery.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeStateProvince rdf:type rdf:Property ;
    rdfs:label 'Home State Province' ;
    rdfs:comment 'State, province, or region of the employee\'s residential address. Used for payroll tax withholding, benefits eligibility, and regional workforce reporting.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hrSystemCode rdf:type rdf:Property ;
    rdfs:label 'Hr System Code' ;
    rdfs:comment 'Unique identifier for this employee in the source HR system (SAP S/4HANA HR). Used for system integration, data reconciliation, and cross-system reference.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobLevel rdf:type rdf:Property ;
    rdfs:label 'Job Level' ;
    rdfs:comment 'Hierarchical level of the employee\'s position within the organization. Used for compensation benchmarking, career pathing, and organizational structure analysis. [ENUM-REF-CANDIDATE: Entry|Associate|Mid|Senior|Lead|Manager|Director|VP|SVP|C-Level — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'National Id Number' ;
    rdfs:comment 'Government-issued national identification number (e.g., Social Security Number in USA, National Insurance Number in UK). Used for tax reporting, payroll, and legal compliance. Format varies by jurisdiction.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalEmail rdf:type rdf:Property ;
    rdfs:label 'Personal Email' ;
    rdfs:comment 'Employee\'s personal email address. Used for emergency communications, benefits notifications, and post-employment correspondence. Must be kept current.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalPhone rdf:type rdf:Property ;
    rdfs:label 'Personal Phone' ;
    rdfs:comment 'Employee\'s personal mobile or home phone number. Used for emergency contact, urgent work communications, and HR notifications.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAuthorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Expiry Date' ;
    rdfs:comment 'Date when the employee\'s work authorization (visa, permit) expires. Null for citizens and permanent residents. Used for compliance tracking and renewal planning. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workEmail rdf:type rdf:Property ;
    rdfs:label 'Work Email' ;
    rdfs:comment 'Corporate email address assigned to the employee for business communications. Primary contact method for internal and external work-related correspondence.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhone rdf:type rdf:Property ;
    rdfs:label 'Work Phone' ;
    rdfs:comment 'Corporate phone number assigned to the employee. May be desk phone, mobile, or extension. Used for business communications and internal directory.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentRecordId rdf:type rdf:Property ;
    rdfs:label 'Employment Record Id' ;
    rdfs:comment 'Unique identifier for each distinct employment engagement or assignment. Primary key for the employment record.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Reference to the specific position held in this employment engagement. Links to the position master record.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:primaryEmploymentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Employment Employee Id' ;
    rdfs:comment 'Reference to the employee who holds this employment record. Links to the employee master record.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionEffectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Effective Timestamp' ;
    rdfs:comment 'The precise date and time when the employment action became effective in the HR system. Used for audit trails and compliance reporting.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actionProcessedBy rdf:type rdf:Property ;
    rdfs:label 'Action Processed By' ;
    rdfs:comment 'The HR administrator or system user who processed and recorded this employment action. Used for audit trails and accountability.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeGroup rdf:type rdf:Property ;
    rdfs:label 'Employee Group' ;
    rdfs:comment 'High-level classification of the employee type (e.g., active employees, retirees, external workers). Used for payroll processing and benefits eligibility determination.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeSubgroup rdf:type rdf:Property ;
    rdfs:label 'Employee Subgroup' ;
    rdfs:comment 'Detailed classification within the employee group (e.g., salaried, hourly, union, non-union). Determines specific payroll rules and time management policies.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentActionReason rdf:type rdf:Property ;
    rdfs:label 'Employment Action Reason' ;
    rdfs:comment 'Detailed reason or justification for the employment action. Provides context for why the hire, transfer, promotion, or other action occurred.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentActionType rdf:type rdf:Property ;
    rdfs:label 'Employment Action Type' ;
    rdfs:comment 'The type of employment action that created this employment record. Indicates whether this is an initial hire, internal transfer, promotion, demotion, secondment, or rehire event.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftePercentage rdf:type rdf:Property ;
    rdfs:label 'Fte Percentage' ;
    rdfs:comment 'The full-time equivalency percentage for this employment engagement. Represents the proportion of a full-time workload, expressed as a percentage (e.g., 100.00 for full-time, 50.00 for half-time).' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payScaleArea rdf:type rdf:Property ;
    rdfs:label 'Pay Scale Area' ;
    rdfs:comment 'Geographic or organizational area that determines the applicable pay scale. Used for regional compensation adjustments and cost-of-living considerations.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payScaleType rdf:type rdf:Property ;
    rdfs:label 'Pay Scale Type' ;
    rdfs:comment 'The type of pay scale or compensation structure applied to this employment engagement. May reference union agreements, executive compensation plans, or standard salary structures.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personnelArea rdf:type rdf:Property ;
    rdfs:label 'Personnel Area' ;
    rdfs:comment 'The personnel area representing the geographic or administrative grouping for HR administration. Used for payroll processing, benefits administration, and compliance reporting.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personnelSubarea rdf:type rdf:Property ;
    rdfs:label 'Personnel Subarea' ;
    rdfs:comment 'Subdivision of the personnel area providing finer-grained administrative grouping. Used for location-specific HR policies and time management rules.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probationEndDate rdf:type rdf:Property ;
    rdfs:label 'Probation End Date' ;
    rdfs:comment 'The date when the probationary period for this employment engagement ends. Nullable if no probation period applies or if the employee has already completed probation.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Record Active Flag' ;
    rdfs:comment 'Indicates whether this employment record is currently active and valid. Used for filtering current vs historical employment engagements in reporting and analytics.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteWorkEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for remote or work-from-home arrangements during this employment period. Reflects organizational policy and role requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionMembershipFlag rdf:type rdf:Property ;
    rdfs:label 'Union Membership Flag' ;
    rdfs:comment 'Indicates whether the employee is a member of a labor union during this employment period. Used for collective bargaining agreement compliance and benefits administration.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weeklyHours rdf:type rdf:Property ;
    rdfs:label 'Weekly Hours' ;
    rdfs:comment 'The standard number of hours per week the employee is contracted to work during this employment period. Used for full-time equivalency calculations.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Work Schedule Code' ;
    rdfs:comment 'Code representing the work schedule pattern assigned to the employee during this employment period. Defines working hours, shift patterns, and time allocation.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workScheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Work Schedule Description' ;
    rdfs:comment 'Human-readable description of the work schedule. Provides details about working hours, shift patterns, or flexible work arrangements.' ;
    rdfs:domain ind:EmploymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalId rdf:type rdf:Property ;
    rdfs:label 'Goal Id' ;
    rdfs:comment 'Unique identifier for the employee performance goal record. Primary key.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Goal Employee Id' ;
    rdfs:comment 'Reference to the employee to whom this goal is assigned. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:goalManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Goal Manager Employee Id' ;
    rdfs:comment 'Reference to the manager or supervisor who approved and is monitoring this goal. Links to the employee master record for the manager.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewCycleId rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Id' ;
    rdfs:comment 'Reference to the performance review cycle or period to which this goal belongs (e.g., 2024 Annual Review, Q2 2024 Quarterly Review). Links to the review cycle master record.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cycle .

ind:achievementPercentage rdf:type rdf:Property ;
    rdfs:label 'Achievement Percentage' ;
    rdfs:comment 'Calculated percentage of goal completion based on current value relative to target value. Values over 100% indicate the goal was exceeded. Used for performance scoring and reporting.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'Starting or current value of the metric at the time the goal was set. Provides context for measuring progress and improvement (e.g., current audience reach before the goal period).' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentValue rdf:type rdf:Property ;
    rdfs:label 'Current Value' ;
    rdfs:comment 'Most recent measured value of the target metric, reflecting progress toward the goal. Updated periodically as performance data becomes available.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeNotes rdf:type rdf:Property ;
    rdfs:label 'Employee Notes' ;
    rdfs:comment 'Free-text notes from the employee documenting progress, challenges encountered, resources needed, or self-assessment. Supports employee self-reflection and two-way performance dialogue.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalCategory rdf:type rdf:Property ;
    rdfs:label 'Goal Category' ;
    rdfs:comment 'Classification of the goal scope and level. Individual goals are personal performance targets; team goals are shared across a work group; organizational goals cascade from company-wide objectives; departmental goals align with division priorities; project goals are tied to specific initiatives; strategic goals support long-term business strategy.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalDescription rdf:type rdf:Property ;
    rdfs:label 'Goal Description' ;
    rdfs:comment 'Detailed narrative description of the goal, including context, expected outcomes, and success criteria. Provides comprehensive understanding of what the employee is expected to achieve.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalType rdf:type rdf:Property ;
    rdfs:label 'Goal Type' ;
    rdfs:comment 'Nature of the goal measurement. Quantitative goals have numeric targets (e.g., revenue, ratings); qualitative goals are assessed subjectively (e.g., leadership quality); behavioral goals focus on conduct and values; developmental goals target skill acquisition; operational goals improve processes; strategic goals advance long-term positioning.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this goal is mandatory (required for all employees in a role or department) or optional (individually selected). Mandatory goals often relate to compliance, training, or core job functions.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStretchGoal rdf:type rdf:Property ;
    rdfs:label 'Is Stretch Goal' ;
    rdfs:comment 'Indicates whether this is a stretch goal (aspirational target beyond normal expectations). Stretch goals are typically weighted differently in performance evaluations and partial achievement is often considered successful.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the target value (e.g., \'percent\', \'viewers\', \'hours\', \'episodes\', \'dollars\', \'rating points\'). Clarifies how the numeric target should be interpreted.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:okrAlignment rdf:type rdf:Property ;
    rdfs:label 'Okr Alignment' ;
    rdfs:comment 'Reference to the company-level or department-level OKR (Objectives and Key Results) that this goal supports. Ensures goal alignment with organizational strategy. May reference specific objective identifiers or descriptive text.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:progressStatus rdf:type rdf:Property ;
    rdfs:label 'Progress Status' ;
    rdfs:comment 'Current state of goal progress. Not started: work has not begun; in progress: actively being worked on; on track: progressing as expected; at risk: may not meet target; behind: falling short of milestones; completed: target achieved; exceeded: surpassed target; cancelled: goal no longer applicable. [ENUM-REF-CANDIDATE: not_started|in_progress|on_track|at_risk|behind|completed|exceeded|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetric rdf:type rdf:Property ;
    rdfs:label 'Target Metric' ;
    rdfs:comment 'The specific measurable indicator or key performance indicator (KPI) used to assess goal achievement (e.g., \'Audience Reach\', \'Content Production Volume\', \'System Uptime Percentage\', \'Training Completion Rate\').' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Visibility Level' ;
    rdfs:comment 'Defines who can view this goal. Private: only employee and manager; manager: visible to management chain; department: visible to department members; organization: visible company-wide; public: visible to external stakeholders.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightPercentage rdf:type rdf:Property ;
    rdfs:label 'Weight Percentage' ;
    rdfs:comment 'Relative importance or weight of this goal within the employees overall performance review, expressed as a percentage (e.g., 25.00 means this goal represents 25% of the total performance score). All goals for an employee typically sum to 100%.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headcountPlanId rdf:type rdf:Property ;
    rdfs:label 'Headcount Plan Id' ;
    rdfs:comment 'Unique identifier for the headcount plan record. Primary key for the headcount plan entity.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedFteCount rdf:type rdf:Property ;
    rdfs:label 'Approved Fte Count' ;
    rdfs:comment 'The approved target headcount expressed in Full-Time Equivalent (FTE) units for this org unit, job family, and fiscal year. Represents the authorized staffing level approved by finance and executive leadership.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attritionAssumptionPercentage rdf:type rdf:Property ;
    rdfs:label 'Attrition Assumption Percentage' ;
    rdfs:comment 'The assumed annual attrition rate (as a percentage) used in workforce planning for this org unit and job family. Informs net hiring targets and replacement planning.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'The total budgeted compensation and benefits amount allocated for this headcount plan (org unit, job family, fiscal year). Expressed in the budget currency and used for financial planning and variance analysis.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractorFteCount rdf:type rdf:Property ;
    rdfs:label 'Contractor Fte Count' ;
    rdfs:comment 'The planned or approved headcount for contractors and contingent workers expressed in FTE units. Tracked separately from permanent employee FTE for total workforce visibility.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Role Flag' ;
    rdfs:comment 'Indicates whether this headcount plan record covers critical or hard-to-fill roles that require special attention in workforce planning and talent acquisition. True if critical; False otherwise.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentFilledFte rdf:type rdf:Property ;
    rdfs:label 'Current Filled Fte' ;
    rdfs:comment 'The current actual headcount in FTE units as of the plan snapshot date. Used to calculate variance against approved FTE and identify open capacity.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversityHiringTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Diversity Hiring Target Percentage' ;
    rdfs:comment 'The target percentage of new hires from underrepresented groups for this org unit and job family. Supports diversity, equity, and inclusion (DEI) goals and regulatory compliance.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internFteCount rdf:type rdf:Property ;
    rdfs:label 'Intern Fte Count' ;
    rdfs:comment 'The planned or approved headcount for interns and temporary student workers expressed in FTE units. Supports talent pipeline and early career program planning.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'The job family or functional category for which headcount is planned (e.g., Broadcast Operations, Content Production, Engineering, Sales). Aligns with Media Broadcasting\'s job architecture and talent segmentation. [ENUM-REF-CANDIDATE: broadcast_operations|content_production|engineering|sales|finance|hr|legal|marketing|it|executive — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netHiringTarget rdf:type rdf:Property ;
    rdfs:label 'Net Hiring Target' ;
    rdfs:comment 'The net number of new hires required to achieve the approved FTE count after accounting for attrition and current filled FTE. Calculated as (approved_fte_count - current_filled_fte + expected_attrition).' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openRequisitionCount rdf:type rdf:Property ;
    rdfs:label 'Open Requisition Count' ;
    rdfs:comment 'The number of open job requisitions currently in the recruitment pipeline for this org unit and job family. Tracks active hiring efforts against the approved plan.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Approval Status' ;
    rdfs:comment 'The current approval status of this headcount plan record in the budget and planning workflow. Tracks progression from draft through executive approval.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEffectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan Effective End Date' ;
    rdfs:comment 'The date through which this headcount plan remains effective. Typically aligns with the end of the fiscal year or planning period. Null indicates an open-ended plan.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Effective Start Date' ;
    rdfs:comment 'The date from which this headcount plan becomes effective. Typically aligns with the start of the fiscal year or the beginning of a planning period.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text notes and commentary on this headcount plan record. Captures business context, assumptions, constraints, or special considerations for workforce planning.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersionCode rdf:type rdf:Property ;
    rdfs:label 'Plan Version Code' ;
    rdfs:comment 'Version identifier for the headcount plan (e.g., FY2024-V1, FY2024-V2-REVISED). Supports multiple iterations of the annual plan as revisions are made during budget cycles.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningScenario rdf:type rdf:Property ;
    rdfs:label 'Planning Scenario' ;
    rdfs:comment 'The business scenario or strategic context for this headcount plan (e.g., Baseline, Growth, Cost Reduction, Restructuring, Merger Integration). Supports scenario-based workforce planning.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkFteCount rdf:type rdf:Property ;
    rdfs:label 'Remote Work Fte Count' ;
    rdfs:comment 'The number of FTEs in this plan designated for remote or hybrid work arrangements. Supports workforce flexibility planning and real estate optimization.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:successionPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Succession Plan Required Flag' ;
    rdfs:comment 'Indicates whether roles in this headcount plan require formal succession planning due to business criticality or leadership pipeline needs. True if succession planning is required; False otherwise.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionFteCount rdf:type rdf:Property ;
    rdfs:label 'Union Fte Count' ;
    rdfs:comment 'The number of FTEs in this plan covered by collective bargaining agreements or union membership. Critical for labor relations planning and compliance in broadcast operations.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceFte rdf:type rdf:Property ;
    rdfs:label 'Variance Fte' ;
    rdfs:comment 'The variance between approved FTE count and current filled FTE. Calculated as (approved_fte_count - current_filled_fte). Positive values indicate unfilled capacity; negative values indicate overstaffing.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interviewEventId rdf:type rdf:Property ;
    rdfs:label 'Interview Event Id' ;
    rdfs:comment 'Unique identifier for each interview event conducted as part of the hiring process.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryInterviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Interviewer Employee Id' ;
    rdfs:comment 'Reference to the lead interviewer responsible for conducting and documenting this interview.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advanceToNextRound rdf:type rdf:Property ;
    rdfs:label 'Advance To Next Round' ;
    rdfs:comment 'Indicates whether the candidate should proceed to the next interview round based on this interview\'s outcome.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentCompletionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Assessment Completion Time Minutes' ;
    rdfs:comment 'Time taken by the candidate to complete any technical assessment or skills test, measured in minutes.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numerical score from any technical assessment, coding challenge, or skills test administered during the interview.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:candidateConsentRecorded rdf:type rdf:Property ;
    rdfs:label 'Candidate Consent Recorded' ;
    rdfs:comment 'Indicates whether the candidate provided consent for interview recording and data processing in compliance with privacy regulations.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationSkillsRating rdf:type rdf:Property ;
    rdfs:label 'Communication Skills Rating' ;
    rdfs:comment 'Evaluation of the candidate\'s verbal and written communication abilities during the interview.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concernsSummary rdf:type rdf:Property ;
    rdfs:label 'Concerns Summary' ;
    rdfs:comment 'Summary of any concerns, weaknesses, or red flags identified during the interview process.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:culturalFitRating rdf:type rdf:Property ;
    rdfs:label 'Cultural Fit Rating' ;
    rdfs:comment 'Assessment of how well the candidate aligns with Media Broadcasting\'s organizational culture and values.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedbackNotes rdf:type rdf:Property ;
    rdfs:label 'Feedback Notes' ;
    rdfs:comment 'Detailed qualitative feedback and observations recorded by the interviewer(s) regarding the candidate\'s performance, strengths, and areas of concern.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Feedback Submitted Timestamp' ;
    rdfs:comment 'Date and time when the interviewer submitted their feedback and ratings for this interview.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hireRecommendation rdf:type rdf:Property ;
    rdfs:label 'Hire Recommendation' ;
    rdfs:comment 'Interviewer\'s recommendation on whether to proceed with hiring this candidate.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewFormat rdf:type rdf:Property ;
    rdfs:label 'Interview Format' ;
    rdfs:comment 'Delivery method used to conduct the interview (phone, video conference, in-person meeting, or hybrid).' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewLocation rdf:type rdf:Property ;
    rdfs:label 'Interview Location' ;
    rdfs:comment 'Physical location, office address, or virtual meeting platform where the interview was conducted.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewPanelSize rdf:type rdf:Property ;
    rdfs:label 'Interview Panel Size' ;
    rdfs:comment 'Total number of interviewers participating in this interview event.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewRecordingAvailable rdf:type rdf:Property ;
    rdfs:label 'Interview Recording Available' ;
    rdfs:comment 'Indicates whether a recording of the interview is available for review, subject to consent and compliance requirements.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interviewRoundNumber rdf:type rdf:Property ;
    rdfs:label 'Interview Round Number' ;
    rdfs:comment 'Sequential number indicating which round of interviews this represents in the hiring process (e.g., 1 for phone screen, 2 for panel interview, 3 for executive interview).' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewStatus rdf:type rdf:Property ;
    rdfs:label 'Interview Status' ;
    rdfs:comment 'Current lifecycle status of the interview event itself.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewType rdf:type rdf:Property ;
    rdfs:label 'Interview Type' ;
    rdfs:comment 'Classification of the interview format and purpose conducted during this event.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewerCalibrationSession rdf:type rdf:Property ;
    rdfs:label 'Interviewer Calibration Session' ;
    rdfs:comment 'Reference to any calibration session where this interview was reviewed to ensure consistent evaluation standards across hiring panels.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Composite numerical rating assigned to the candidate based on interview performance, typically on a scale (e.g., 1.00 to 5.00).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The date on which the interview was originally scheduled to occur.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:schedulingStatus rdf:type rdf:Property ;
    rdfs:label 'Scheduling Status' ;
    rdfs:comment 'Current state of the interview scheduling and execution process.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthsSummary rdf:type rdf:Property ;
    rdfs:label 'Strengths Summary' ;
    rdfs:comment 'Summary of the candidate\'s key strengths and positive attributes identified during the interview.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalCompetencyRating rdf:type rdf:Property ;
    rdfs:label 'Technical Competency Rating' ;
    rdfs:comment 'Rating of the candidate\'s technical skills and job-specific competencies demonstrated during the interview.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoConferenceLink rdf:type rdf:Property ;
    rdfs:label 'Video Conference Link' ;
    rdfs:comment 'URL or meeting link for virtual interviews conducted via video conferencing platforms.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportsToJobProfileId rdf:type rdf:Property ;
    rdfs:label 'Reports To Job Profile Id' ;
    rdfs:comment 'Foreign key reference to the job profile of the direct supervisor or manager for this role. Establishes reporting hierarchy and organizational structure.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:bonusEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Bonus Eligible Flag' ;
    rdfs:comment 'Indicates whether this role is eligible for annual performance bonuses or incentive compensation. Used for total rewards planning and compensation design.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eeoJobCategory rdf:type rdf:Property ;
    rdfs:label 'Eeo Job Category' ;
    rdfs:comment 'Standard EEO-1 job category used for federal equal employment opportunity reporting to the EEOC. Required for compliance with Title VII of the Civil Rights Act. [ENUM-REF-CANDIDATE: executive_senior_level_officials_and_managers|first_mid_level_officials_and_managers|professionals|technicians|sales_workers|administrative_support_workers|craft_workers|operatives|laborers_and_helpers|service_workers — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Equity Eligible Flag' ;
    rdfs:comment 'Indicates whether this role is eligible for equity compensation such as stock options, restricted stock units (RSUs), or employee stock purchase plans (ESPP).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gradeBand rdf:type rdf:Property ;
    rdfs:label 'Grade Band' ;
    rdfs:comment 'Compensation grade or pay band assigned to this job profile. Links to salary range tables and determines eligibility for benefits, bonuses, and equity compensation.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobCode rdf:type rdf:Property ;
    rdfs:label 'Job Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying this job profile within the organization\'s job taxonomy. Used for HR systems integration, payroll processing, and workforce planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobDescription rdf:type rdf:Property ;
    rdfs:label 'Job Description' ;
    rdfs:comment 'Comprehensive narrative describing the role\'s purpose, key responsibilities, deliverables, and scope of work. Used for recruitment, performance management, and role clarity.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Job Profile Status' ;
    rdfs:comment 'Current lifecycle status of this job profile. Active profiles are available for hiring and workforce planning; inactive or obsolete profiles are retained for historical reference only.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Education Level' ;
    rdfs:comment 'Minimum educational qualification required for this role. Used for candidate screening and workforce planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Minimum Years Experience' ;
    rdfs:comment 'Minimum number of years of relevant professional experience required for this role. Used for candidate qualification and talent acquisition.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalDemands rdf:type rdf:Property ;
    rdfs:label 'Physical Demands' ;
    rdfs:comment 'Description of physical requirements and working conditions for this role. Examples: ability to lift 50 lbs, prolonged standing, work in outdoor weather conditions, operate heavy equipment. Required for ADA compliance and workplace safety.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSkills rdf:type rdf:Property ;
    rdfs:label 'Preferred Skills' ;
    rdfs:comment 'Comma-separated list of additional skills that are desirable but not mandatory. Used to identify high-potential candidates and development opportunities.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Comma-separated list of professional certifications, licenses, or credentials required or preferred for this role. Examples: FCC General Radiotelephone Operator License, Certified Broadcast Networking Technician (CBNT), Society of Broadcast Engineers (SBE) Certification.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSkills rdf:type rdf:Property ;
    rdfs:label 'Required Skills' ;
    rdfs:comment 'Comma-separated list of technical, functional, and soft skills required for successful performance in this role. Examples: video editing, broadcast automation systems, Adobe Premiere, Final Cut Pro, project management, stakeholder communication.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryBandMaximum rdf:type rdf:Property ;
    rdfs:label 'Salary Band Maximum' ;
    rdfs:comment 'Maximum annual base salary for this job profile in USD. Represents the ceiling for this role\'s compensation range.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryBandMidpoint rdf:type rdf:Property ;
    rdfs:label 'Salary Band Midpoint' ;
    rdfs:comment 'Midpoint or target annual base salary for this job profile in USD. Represents the market-competitive rate for fully competent performance.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryBandMinimum rdf:type rdf:Property ;
    rdfs:label 'Salary Band Minimum' ;
    rdfs:comment 'Minimum annual base salary for this job profile in USD. Used for compensation planning, budgeting, and pay equity analysis.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Salary Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for salary band amounts. Supports multi-currency compensation structures for global operations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Percentage' ;
    rdfs:comment 'Expected percentage of work time requiring business travel. Used for candidate expectations, expense budgeting, and work-life balance planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Union Eligible Flag' ;
    rdfs:comment 'Indicates whether this role is eligible for union membership or collective bargaining representation. Critical for labor relations, contract negotiations, and compliance with National Labor Relations Act (NLRA).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionName rdf:type rdf:Property ;
    rdfs:label 'Union Name' ;
    rdfs:comment 'Name of the labor union or collective bargaining unit representing this role, if applicable. Examples: International Brotherhood of Electrical Workers (IBEW), National Association of Broadcast Employees and Technicians (NABET-CWA), Writers Guild of America (WGA).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveBalanceId rdf:type rdf:Property ;
    rdfs:label 'Leave Balance Id' ;
    rdfs:comment 'Unique identifier for the leave balance record. Primary key.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualCap rdf:type rdf:Property ;
    rdfs:label 'Accrual Cap' ;
    rdfs:comment 'Maximum leave balance that can be accrued for this leave type per Media Broadcasting policy. Once reached, no further accrual occurs until balance drops below cap.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accrualPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Period End Date' ;
    rdfs:comment 'End date of the current accrual period. Balances may reset, roll over, or be forfeited at this boundary per policy.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Period Start Date' ;
    rdfs:comment 'Start date of the current accrual period (e.g., calendar year, fiscal year, or anniversary year depending on Media Broadcasting policy).' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualRate rdf:type rdf:Property ;
    rdfs:label 'Accrual Rate' ;
    rdfs:comment 'Rate at which leave accrues per pay period or per hour worked, based on employee tenure and policy tier. Expressed in hours or days per unit time.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accruedCurrentPeriod rdf:type rdf:Property ;
    rdfs:label 'Accrued Current Period' ;
    rdfs:comment 'Total leave hours or days accrued during the current period based on accrual rate and service time. Updated each pay period by payroll system.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedBalance rdf:type rdf:Property ;
    rdfs:label 'Adjusted Balance' ;
    rdfs:comment 'Manual adjustments to the leave balance (positive or negative) made by HR for corrections, policy exceptions, or one-time grants. Includes adjustment reason in notes.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableBalance rdf:type rdf:Property ;
    rdfs:label 'Available Balance' ;
    rdfs:comment 'Current available leave balance that the employee can request. Calculated as: opening_balance + accrued_current_period - used_current_period + adjusted_balance - pending_requests.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Balance As Of Date' ;
    rdfs:comment 'The date as of which this leave balance snapshot is accurate. Typically updated at the end of each pay period or after a leave transaction.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carriedOverBalance rdf:type rdf:Property ;
    rdfs:label 'Carried Over Balance' ;
    rdfs:comment 'Leave balance carried forward from the prior accrual period. Subject to carryover caps per Media Broadcasting policy (e.g., maximum 40 hours vacation carryover).' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carryoverCap rdf:type rdf:Property ;
    rdfs:label 'Carryover Cap' ;
    rdfs:comment 'Maximum leave balance that can be carried over to the next accrual period. Any balance above this cap is forfeited per policy.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forfeitedBalance rdf:type rdf:Property ;
    rdfs:label 'Forfeited Balance' ;
    rdfs:comment 'Leave hours or days forfeited at the end of the prior period due to exceeding carryover caps or use-it-or-lose-it policy. Represents lost leave liability.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAccrualDate rdf:type rdf:Property ;
    rdfs:label 'Last Accrual Date' ;
    rdfs:comment 'Date of the most recent leave accrual transaction for this employee and leave type. Typically aligns with pay period end date.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUsageDate rdf:type rdf:Property ;
    rdfs:label 'Last Usage Date' ;
    rdfs:comment 'Date of the most recent leave usage (deduction) for this employee and leave type. Helps identify stale balances and usage patterns.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaveTypeCode rdf:type rdf:Property ;
    rdfs:label 'Leave Type Code' ;
    rdfs:comment 'Code representing the type of leave (e.g., VAC for vacation, SICK for sick leave, PTO for paid time off, FLOAT for floating holiday, COMP for compensatory time). Standardized codes per Media Broadcasting HR policy.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveTypeName rdf:type rdf:Property ;
    rdfs:label 'Leave Type Name' ;
    rdfs:comment 'Human-readable name of the leave type (e.g., Vacation, Sick Leave, Personal Time Off, Floating Holiday, Compensatory Time).' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Amount' ;
    rdfs:comment 'Monetary value of the current available leave balance, calculated as available_balance multiplied by the employees hourly or daily rate. Represents financial liability for Media Broadcasting.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'Leave balance at the start of the current accrual period, including any carryover from the prior period. Expressed in hours or days per unit of measure.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pendingRequests rdf:type rdf:Property ;
    rdfs:label 'Pending Requests' ;
    rdfs:comment 'Total leave hours or days currently requested but not yet approved or denied. Represents potential future deductions from available balance.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyTier rdf:type rdf:Property ;
    rdfs:label 'Policy Tier' ;
    rdfs:comment 'The accrual policy tier applicable to this employee for this leave type, typically based on tenure or job level (e.g., Tier 1: 0-2 years, Tier 2: 3-5 years, Tier 3: 6+ years).' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedYearEndBalance rdf:type rdf:Property ;
    rdfs:label 'Projected Year End Balance' ;
    rdfs:comment 'Forecasted leave balance at the end of the current accrual period, assuming no further usage. Used for liability planning and to alert employees of potential forfeitures.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usedCurrentPeriod rdf:type rdf:Property ;
    rdfs:label 'Used Current Period' ;
    rdfs:comment 'Total leave hours or days used (taken) by the employee during the current period. Sourced from approved leave requests and time-tracking system.' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveRequestId rdf:type rdf:Property ;
    rdfs:label 'Leave Request Id' ;
    rdfs:comment 'Unique identifier for the leave request. Primary key for the leave request transaction.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLeaveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Leave Employee Id' ;
    rdfs:comment 'Identifier of the employee submitting the leave request. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLeaveSubstituteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Leave Substitute Employee Id' ;
    rdfs:comment 'Identifier of the employee designated to cover the absent employee\'s responsibilities during the leave period. Null if no formal substitute assigned.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDaysTaken rdf:type rdf:Property ;
    rdfs:label 'Actual Days Taken' ;
    rdfs:comment 'Actual number of leave days taken, calculated from time and attendance records. Used for leave balance deduction and payroll processing.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualHoursTaken rdf:type rdf:Property ;
    rdfs:label 'Actual Hours Taken' ;
    rdfs:comment 'Actual number of leave hours taken, calculated from time and attendance records. Used for hourly leave balance deduction and payroll processing.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text comments or notes provided by the employee when submitting the leave request, such as reason for leave or special circumstances.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Standardized categorical reason for denial: staffing_shortage (inadequate coverage), blackout_period (restricted dates such as sweeps or upfront periods), insufficient_notice (did not meet advance notice policy), policy_violation (does not meet eligibility or usage rules), other (see denial_reason for details).' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmlaCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Fmla Certification Date' ;
    rdfs:comment 'Date when FMLA medical certification was received and approved by HR. Null for non-FMLA leave or if certification not yet approved.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fmlaCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Fmla Certification Status' ;
    rdfs:comment 'Status of required medical certification for FMLA leave: not_required (non-FMLA leave), pending (certification requested but not yet received), received (certification submitted by employee), approved (HR approved certification), insufficient (certification does not meet requirements).' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmlaProtectedFlag rdf:type rdf:Property ;
    rdfs:label 'Fmla Protected Flag' ;
    rdfs:comment 'Indicates whether this leave request is protected under the Family and Medical Leave Act. True if FMLA-eligible and certified.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intermittentLeaveFlag rdf:type rdf:Property ;
    rdfs:label 'Intermittent Leave Flag' ;
    rdfs:comment 'Indicates whether this is an intermittent leave request (multiple non-consecutive absences for the same condition) rather than a continuous block of leave. Common for FMLA medical treatment schedules.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Leave Balance After' ;
    rdfs:comment 'Employee\'s remaining leave balance in days or hours after this request was approved and taken. Used for leave accrual and entitlement tracking.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Leave Balance Before' ;
    rdfs:comment 'Employee\'s available leave balance in days or hours before this request was approved and taken. Snapshot for audit and balance tracking.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveSubtype rdf:type rdf:Property ;
    rdfs:label 'Leave Subtype' ;
    rdfs:comment 'Optional granular classification within the leave type, such as maternity vs paternity under parental leave, or continuous vs intermittent under FMLA.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Category of leave being requested: vacation (paid time off), sick (illness or medical appointments), FMLA (Family and Medical Leave Act protected leave), parental (maternity/paternity/adoption), bereavement (death of family member), jury_duty (civic duty), military (military service), unpaid (leave without pay).' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerComments rdf:type rdf:Property ;
    rdfs:label 'Manager Comments' ;
    rdfs:comment 'Free-text comments or notes provided by the approving manager when reviewing the leave request, such as approval conditions or coverage arrangements.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidLeaveFlag rdf:type rdf:Property ;
    rdfs:label 'Paid Leave Flag' ;
    rdfs:comment 'Indicates whether this leave is paid (employee receives regular compensation) or unpaid (no compensation during absence). Drives payroll deduction calculations.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollPeriod rdf:type rdf:Property ;
    rdfs:label 'Payroll Period' ;
    rdfs:comment 'Payroll period (YYYY-MM format) in which this leave was processed for compensation adjustments. Used to reconcile leave with payroll cycles.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollProcessedFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Processed Flag' ;
    rdfs:comment 'Indicates whether this leave request has been processed by payroll for deductions or adjustments. True once payroll cycle has incorporated the leave.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reducedScheduleFlag rdf:type rdf:Property ;
    rdfs:label 'Reduced Schedule Flag' ;
    rdfs:comment 'Indicates whether this leave request involves a reduced work schedule (working fewer hours per day or days per week) rather than full-day absences. Common for FMLA return-to-work transitions.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedEndDate rdf:type rdf:Property ;
    rdfs:label 'Requested End Date' ;
    rdfs:comment 'Last date of the requested leave period. Employee intends to return to work the following business day.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedStartDate rdf:type rdf:Property ;
    rdfs:label 'Requested Start Date' ;
    rdfs:comment 'First date of the requested leave period. Employee intends to be absent starting this date.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalDaysRequested rdf:type rdf:Property ;
    rdfs:label 'Total Days Requested' ;
    rdfs:comment 'Total number of leave days requested, calculated as business days between start and end dates. May include fractional days for partial-day leave.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHoursRequested rdf:type rdf:Property ;
    rdfs:label 'Total Hours Requested' ;
    rdfs:comment 'Total number of leave hours requested, used for hourly leave tracking and partial-day absences. Supports intermittent FMLA leave measured in hours.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingTaskId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Task Id' ;
    rdfs:comment 'Unique identifier for each onboarding task assigned to a new hire or rehire at Media Broadcasting. Primary key for the onboarding task record.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dependencyTaskId rdf:type rdf:Property ;
    rdfs:label 'Dependency Task Id' ;
    rdfs:comment 'Reference to another onboarding task that must be completed before this task can begin. Null if this task has no prerequisites. Enables sequencing of onboarding activities (e.g., system access setup depends on background check clearance).' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OnboardingTask .

ind:primaryOnboardingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Onboarding Employee Id' ;
    rdfs:comment 'Reference to the employee (new hire or rehire) to whom this onboarding task is assigned. Links to the employee master record.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryOnboardingApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Onboarding Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee (manager, HR director, compliance officer) who approved the completion of this task. Null if approval is not required or not yet granted. Links to the employee master record.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryOnboardingCompletedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Onboarding Completed By Employee Id' ;
    rdfs:comment 'Reference to the employee who actually completed the task. May differ from assigned owner if task was delegated or reassigned. Links to the employee master record.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualHours rdf:type rdf:Property ;
    rdfs:label 'Actual Hours' ;
    rdfs:comment 'Actual number of hours spent completing this onboarding task. Used to refine future estimates and identify process improvement opportunities.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'Date when the onboarding task was assigned to the employee and owner. Typically triggered by hire date confirmation or completion of a prerequisite task.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedOwnerRole rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Role' ;
    rdfs:comment 'Functional role of the person assigned to complete this onboarding task. Indicates which department or function is responsible for task execution. [ENUM-REF-CANDIDATE: hr_specialist|it_administrator|hiring_manager|facilities_coordinator|training_coordinator|union_representative|payroll_administrator — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirementCode rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Code' ;
    rdfs:comment 'Code identifying the regulatory or compliance requirement that mandates this onboarding task (e.g., IRCA for I-9 verification, FCC for broadcast license verification, OSHA for safety training, GDPR for data privacy training). Null for non-compliance tasks.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Hours' ;
    rdfs:comment 'Estimated number of hours required to complete this onboarding task. Used for workload planning and resource allocation across HR, IT, and facilities teams.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBlockingTask rdf:type rdf:Property ;
    rdfs:label 'Is Blocking Task' ;
    rdfs:comment 'Boolean flag indicating whether this task must be completed before subsequent onboarding tasks can begin. True for critical path tasks (e.g., I-9 verification, background check clearance, system access setup); false for tasks that can proceed in parallel.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taskCategory rdf:type rdf:Property ;
    rdfs:label 'Task Category' ;
    rdfs:comment 'High-level category grouping onboarding tasks by functional area: compliance (I-9, background checks), hr_administration (benefits enrollment, payroll setup), it_provisioning (system access, equipment), facilities (badge, workspace), training (orientation, safety, compliance), union_processing (union card, dues setup).' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCode rdf:type rdf:Property ;
    rdfs:label 'Task Code' ;
    rdfs:comment 'Standardized code identifying the type of onboarding task (e.g., I9_VERIFY, BG_CHECK, EQUIP_PROV, SYS_ACCESS, BENEFITS_ENROLL, COMPLIANCE_TRAIN, FACILITY_ORIENT, UNION_CARD). Used for task categorization and reporting.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Detailed description of the onboarding task, including specific actions required, documentation needed, and any special instructions for completion.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskName rdf:type rdf:Property ;
    rdfs:label 'Task Name' ;
    rdfs:comment 'Human-readable name of the onboarding task (e.g., I-9 Employment Eligibility Verification, Background Check Clearance, Equipment Provisioning, System Access Setup, Benefits Enrollment, Mandatory Compliance Training, Broadcast Facility Orientation, Union Card Processing).' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the hierarchy. Enables traversal of the organizational tree structure from child to parent. Null for top-level units.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:headCountActual rdf:type rdf:Property ;
    rdfs:label 'Head Count Actual' ;
    rdfs:comment 'Current actual number of employees assigned to this organizational unit, used for variance analysis against budget.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headCountBudget rdf:type rdf:Property ;
    rdfs:label 'Head Count Budget' ;
    rdfs:comment 'Approved budgeted number of full-time equivalent employees allocated to this organizational unit for workforce planning and cost management.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path representation of the organizational units position in the hierarchy, typically a delimited string of ancestor unit codes for efficient tree traversal.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBroadcastOperations rdf:type rdf:Property ;
    rdfs:label 'Is Broadcast Operations' ;
    rdfs:comment 'Flag indicating whether this organizational unit is directly involved in broadcast playout, transmission, or on-air operations.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isContentProduction rdf:type rdf:Property ;
    rdfs:label 'Is Content Production' ;
    rdfs:comment 'Flag indicating whether this organizational unit is engaged in content creation, production, or post-production activities.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours or shift pattern for this organizational unit, relevant for broadcast operations, production schedules, and workforce planning.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitDescription rdf:type rdf:Property ;
    rdfs:label 'Org Unit Description' ;
    rdfs:comment 'Detailed description of the organizational units purpose, responsibilities, and scope of operations within the media broadcasting enterprise.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Business identifier code for the organizational unit used in financial systems, reporting, and internal references. Typically alphanumeric and unique across the enterprise.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Full official name of the organizational unit as used in corporate communications, org charts, and HR systems.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitShortName rdf:type rdf:Property ;
    rdfs:label 'Unit Short Name' ;
    rdfs:comment 'Abbreviated or short name of the organizational unit for display in constrained UI contexts, reports, and dashboards.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRecordId rdf:type rdf:Property ;
    rdfs:label 'Payroll Record Id' ;
    rdfs:comment 'Unique identifier for each payroll processing event. Primary key for the payroll record entity.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bonusPay rdf:type rdf:Property ;
    rdfs:label 'Bonus Pay' ;
    rdfs:comment 'Discretionary or performance-based bonus payments included in this payroll cycle.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionPay rdf:type rdf:Property ;
    rdfs:label 'Commission Pay' ;
    rdfs:comment 'Sales commission earnings included in this payroll payment, typically for sales or revenue-generating roles.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dentalInsuranceDeduction rdf:type rdf:Property ;
    rdfs:label 'Dental Insurance Deduction' ;
    rdfs:comment 'Employee portion of dental insurance premium deducted from payroll.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doubleTimeHours rdf:type rdf:Property ;
    rdfs:label 'Double Time Hours' ;
    rdfs:comment 'Total number of hours worked that qualify for double-time premium pay, typically for holidays or excessive overtime.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:federalIncomeTax rdf:type rdf:Property ;
    rdfs:label 'Federal Income Tax' ;
    rdfs:comment 'Amount withheld for federal income tax based on employee W-4 elections and IRS tax tables.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fsaDeduction rdf:type rdf:Property ;
    rdfs:label 'Fsa Deduction' ;
    rdfs:comment 'Pre-tax contribution to Flexible Spending Account for healthcare or dependent care expenses.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:garnishmentDeduction rdf:type rdf:Property ;
    rdfs:label 'Garnishment Deduction' ;
    rdfs:comment 'Court-ordered or legally mandated wage garnishment for child support, tax levies, or other obligations.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPay rdf:type rdf:Property ;
    rdfs:label 'Gross Pay' ;
    rdfs:comment 'Total earnings before any deductions or withholdings. Sum of all pay components for the period.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthInsuranceDeduction rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Deduction' ;
    rdfs:comment 'Employee portion of health insurance premium deducted from payroll.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsaDeduction rdf:type rdf:Property ;
    rdfs:label 'Hsa Deduction' ;
    rdfs:comment 'Pre-tax contribution to Health Savings Account for qualified medical expenses.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localIncomeTax rdf:type rdf:Property ;
    rdfs:label 'Local Income Tax' ;
    rdfs:comment 'Amount withheld for local or municipal income tax where applicable.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicareTax rdf:type rdf:Property ;
    rdfs:label 'Medicare Tax' ;
    rdfs:comment 'Employee portion of Medicare tax withheld under the Federal Insurance Contributions Act (FICA).' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPay rdf:type rdf:Property ;
    rdfs:label 'Net Pay' ;
    rdfs:comment 'Take-home pay after all deductions and withholdings. The amount actually disbursed to the employee.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDeductions rdf:type rdf:Property ;
    rdfs:label 'Other Deductions' ;
    rdfs:comment 'Miscellaneous voluntary or involuntary deductions not categorized elsewhere.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherEarnings rdf:type rdf:Property ;
    rdfs:label 'Other Earnings' ;
    rdfs:comment 'Miscellaneous additional earnings not categorized as regular, overtime, bonus, or commission pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimePay rdf:type rdf:Property ;
    rdfs:label 'Overtime Pay' ;
    rdfs:comment 'Additional earnings from overtime hours worked, typically calculated at 1.5x the regular rate.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'The last day of the work period covered by this payroll payment. Defines the end of the earnings period.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'The first day of the work period covered by this payroll payment. Defines the beginning of the earnings period.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollRunDate rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Date' ;
    rdfs:comment 'The date on which the payroll calculations were executed and this record was generated.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollStatus rdf:type rdf:Property ;
    rdfs:label 'Payroll Status' ;
    rdfs:comment 'Current processing status of this payroll record in its lifecycle from calculation through payment.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptoHours rdf:type rdf:Property ;
    rdfs:label 'Pto Hours' ;
    rdfs:comment 'Number of paid time off hours used during this pay period, including vacation, sick leave, and personal days.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularHours rdf:type rdf:Property ;
    rdfs:label 'Regular Hours' ;
    rdfs:comment 'Total number of standard work hours performed during the pay period at the base rate of pay.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularPay rdf:type rdf:Property ;
    rdfs:label 'Regular Pay' ;
    rdfs:comment 'Earnings from regular hours worked at the base hourly or salary rate. Excludes overtime and other premium pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirement401kDeduction rdf:type rdf:Property ;
    rdfs:label 'Retirement 401k Deduction' ;
    rdfs:comment 'Employee pre-tax or Roth contribution to 401(k) retirement savings plan.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSecurityTax rdf:type rdf:Property ;
    rdfs:label 'Social Security Tax' ;
    rdfs:comment 'Employee portion of Social Security tax withheld under the Federal Insurance Contributions Act (FICA).' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateIncomeTax rdf:type rdf:Property ;
    rdfs:label 'State Income Tax' ;
    rdfs:comment 'Amount withheld for state income tax based on state tax regulations and employee elections.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Deductions' ;
    rdfs:comment 'Sum of all tax withholdings and voluntary deductions subtracted from gross pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visionInsuranceDeduction rdf:type rdf:Property ;
    rdfs:label 'Vision Insurance Deduction' ;
    rdfs:comment 'Employee portion of vision insurance premium deducted from payroll.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique identifier for the performance review record. Primary key for the performance review entity.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Identifier of the employee being reviewed. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'The date on which the performance review rating was calibrated through management review session.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Status indicating whether the review has undergone calibration process to ensure rating consistency across the organization. Calibration involves peer review of ratings by management.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationRating rdf:type rdf:Property ;
    rdfs:label 'Collaboration Rating' ;
    rdfs:comment 'Competency rating for teamwork, communication, and cross-functional collaboration on a 1-5 scale.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationAdjustmentRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Adjustment Recommended Flag' ;
    rdfs:comment 'Boolean indicator of whether a compensation adjustment (salary increase, bonus) is recommended based on this performance review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'The timestamp when the performance review was marked as completed, indicating all required steps including approval and acknowledgement are finished.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:developmentPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Development Plan Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a formal performance improvement or development plan is required as an outcome of this review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeComments rdf:type rdf:Property ;
    rdfs:label 'Dispute Comments' ;
    rdfs:comment 'Narrative explanation provided by the employee if they dispute the performance review rating or feedback.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgementFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee has acknowledged the performance review. Required for review completion.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeComments rdf:type rdf:Property ;
    rdfs:label 'Employee Comments' ;
    rdfs:comment 'Narrative comments and self-reflection provided by the employee as part of their self-assessment in the performance review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeDisputeFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Dispute Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee has formally disputed the performance review rating or feedback.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeSelfAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Employee Self Assessment Score' ;
    rdfs:comment 'The self-rating provided by the employee on a 1-5 scale as part of the performance review process. Captures employee\'s own perception of their performance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalApprovedRating rdf:type rdf:Property ;
    rdfs:label 'Final Approved Rating' ;
    rdfs:comment 'The final overall performance rating after calibration and approval by senior management. This is the official rating used for compensation and promotion decisions.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goalAchievementScore rdf:type rdf:Property ;
    rdfs:label 'Goal Achievement Score' ;
    rdfs:comment 'Percentage score representing the degree to which the employee achieved their performance goals during the review period. Calculated as weighted average of individual goal completion rates.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:innovationRating rdf:type rdf:Property ;
    rdfs:label 'Innovation Rating' ;
    rdfs:comment 'Competency rating for creativity, problem-solving, and innovative thinking on a 1-5 scale.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadershipRating rdf:type rdf:Property ;
    rdfs:label 'Leadership Rating' ;
    rdfs:comment 'Competency rating for leadership capabilities, people management, and influence on a 1-5 scale. Applicable to employees in leadership roles or demonstrating leadership potential.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preCalibrationRating rdf:type rdf:Property ;
    rdfs:label 'Pre Calibration Rating' ;
    rdfs:comment 'The initial overall rating assigned by the reviewer before the calibration process. Retained for audit trail and calibration impact analysis.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee is eligible for promotion consideration based on this performance review outcome.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendedCompensationAdjustmentPercent rdf:type rdf:Property ;
    rdfs:label 'Recommended Compensation Adjustment Percent' ;
    rdfs:comment 'The recommended percentage increase in base compensation resulting from this performance review. Used to inform compensation planning decisions.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Review Acknowledgement Date' ;
    rdfs:comment 'The date on which the employee formally acknowledged receipt and review of their performance evaluation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'The end date of the performance period being evaluated in this review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'The start date of the performance period being evaluated in this review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'The type or category of performance review being conducted. Determines the review cycle and evaluation criteria applied.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerComments rdf:type rdf:Property ;
    rdfs:label 'Reviewer Comments' ;
    rdfs:comment 'Detailed narrative feedback provided by the reviewer regarding the employee\'s performance, strengths, areas for improvement, and development recommendations.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionPlanningFlag rdf:type rdf:Property ;
    rdfs:label 'Succession Planning Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee should be included in succession planning discussions based on this performance review outcome.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalSkillsRating rdf:type rdf:Property ;
    rdfs:label 'Technical Skills Rating' ;
    rdfs:comment 'Competency rating for technical skills and job-specific expertise on a 1-5 scale. Evaluates proficiency in role-required technical capabilities.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incumbentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incumbent Employee Id' ;
    rdfs:comment 'Reference to the employee currently occupying this position. Null if the position is vacant. Enables tracking of position-to-person assignments and vacancy analysis.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reportsToPositionId rdf:type rdf:Property ;
    rdfs:label 'Reports To Position Id' ;
    rdfs:comment 'Reference to the supervisory position to which this position reports. Enables construction of organizational reporting hierarchies and span-of-control analysis.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:budgetedAnnualSalary rdf:type rdf:Property ;
    rdfs:label 'Budgeted Annual Salary' ;
    rdfs:comment 'The annual salary amount budgeted for this position in the organization\'s financial plan. Used for headcount cost forecasting and budget variance analysis. Business-confidential.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'The date on which this position record was first created in the HR system. Used for audit trail and position history tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteAllocation rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation' ;
    rdfs:comment 'The full-time equivalent allocation for this position, expressed as a decimal (e.g., 1.00 for full-time, 0.50 for half-time). Used for headcount budgeting and workforce capacity planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isExempt rdf:type rdf:Property ;
    rdfs:label 'Is Exempt' ;
    rdfs:comment 'Boolean flag indicating whether the position is exempt from overtime pay requirements under the Fair Labor Standards Act (FLSA). True if exempt (salaried professional/managerial), False if non-exempt (hourly/overtime-eligible).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRemoteEligible rdf:type rdf:Property ;
    rdfs:label 'Is Remote Eligible' ;
    rdfs:comment 'Boolean flag indicating whether the position is eligible for remote or hybrid work arrangements. True if remote work is permitted, False if on-site presence is required.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnionPosition rdf:type rdf:Property ;
    rdfs:label 'Is Union Position' ;
    rdfs:comment 'Boolean flag indicating whether this position is covered by a collective bargaining agreement. True if union-represented, False otherwise. Used for labor cost modeling and contract compliance.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'The date on which this position record was most recently updated. Used for change tracking and data quality monitoring.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Externally-known unique business identifier for the position, used in HR systems, budget planning, and workforce reporting. Typically alphanumeric code assigned by HR.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionDescription rdf:type rdf:Property ;
    rdfs:label 'Position Description' ;
    rdfs:comment 'Detailed narrative description of the position\'s purpose, key responsibilities, and scope. Used for job postings, performance management, and organizational documentation.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the position: active (approved and available), vacant (approved but unfilled), filled (occupied by employee), frozen (temporarily suspended), obsolete (retired), or pending-approval (awaiting budget authorization).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Classification of the position based on employment duration and nature: permanent (ongoing), temporary (fixed-term), contract (external contractor slot), seasonal (recurring short-term), project-based (tied to specific initiative), or internship.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredQualifications rdf:type rdf:Property ;
    rdfs:label 'Preferred Qualifications' ;
    rdfs:comment 'Summary of the desired (but not mandatory) education, certifications, experience, and skills that would enhance candidate suitability. Used for recruitment and candidate ranking.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredQualifications rdf:type rdf:Property ;
    rdfs:label 'Required Qualifications' ;
    rdfs:comment 'Summary of the minimum education, certifications, experience, and skills required for the position. Used for recruitment screening and candidate evaluation.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresSecurityClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Security Clearance' ;
    rdfs:comment 'Boolean flag indicating whether the position requires a security clearance or background check due to access to sensitive content, facilities, or systems. True if clearance required, False otherwise.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salaryGrade rdf:type rdf:Property ;
    rdfs:label 'Salary Grade' ;
    rdfs:comment 'Compensation grade or band assigned to the position, defining the salary range. Used for pay equity analysis and budget planning. Business-confidential.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vacancyPostedDate rdf:type rdf:Property ;
    rdfs:label 'Vacancy Posted Date' ;
    rdfs:comment 'The date on which the position was posted as a job opening for recruitment. Null if the position has never been vacant or posted. Used for time-to-fill analysis and recruitment metrics.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requisition Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who provided final approval for this requisition, typically a senior manager or HR director.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requisitionHiringManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requisition Hiring Manager Employee Id' ;
    rdfs:comment 'Reference to the employee who is the hiring manager responsible for this requisition and will supervise the new hire.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requisitionRecruiterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requisition Recruiter Employee Id' ;
    rdfs:comment 'Reference to the HR recruiter or talent acquisition specialist assigned to manage this requisition.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedHeadcountSource rdf:type rdf:Property ;
    rdfs:label 'Approved Headcount Source' ;
    rdfs:comment 'Source of headcount authorization indicating whether the position is funded from annual budget, supplemental budget, backfill allocation, reallocation, or new approval.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityEligible rdf:type rdf:Property ;
    rdfs:label 'Equity Eligible' ;
    rdfs:comment 'Indicates whether the position is eligible for equity compensation such as stock options or restricted stock units.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfOpenings rdf:type rdf:Property ;
    rdfs:label 'Number Of Openings' ;
    rdfs:comment 'Total number of positions to be filled under this requisition. Supports bulk hiring for multiple identical roles.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openingsFilled rdf:type rdf:Property ;
    rdfs:label 'Openings Filled' ;
    rdfs:comment 'Number of positions that have been successfully filled and closed under this requisition.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingDescription rdf:type rdf:Property ;
    rdfs:label 'Posting Description' ;
    rdfs:comment 'Full job description text used in external job postings, including responsibilities, qualifications, and company information.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingTitle rdf:type rdf:Property ;
    rdfs:label 'Posting Title' ;
    rdfs:comment 'Public-facing job title used in job postings and external advertisements, which may differ from internal job profile title.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkEligible rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligible' ;
    rdfs:comment 'Indicates whether the position allows remote or hybrid work arrangements.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the requisition indicating its stage in the talent acquisition pipeline. [ENUM-REF-CANDIDATE: draft|pending_approval|open|on_hold|filled|cancelled|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the requisition indicating whether it is for a new position, backfill of a departed employee, replacement, contract-to-hire conversion, internal transfer, or seasonal hire.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryRangeMaximum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Maximum' ;
    rdfs:comment 'Maximum annual salary or hourly rate for the position, defining the upper bound of the compensation band.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryRangeMinimum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Minimum' ;
    rdfs:comment 'Minimum annual salary or hourly rate for the position, used for candidate expectations and budget planning.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Required' ;
    rdfs:comment 'Indicates whether the position requires a security clearance or background check due to access to sensitive broadcast content or systems.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourcingChannels rdf:type rdf:Property ;
    rdfs:label 'Sourcing Channels' ;
    rdfs:comment 'Comma-separated list of authorized sourcing channels for candidate recruitment (e.g., internal job board, LinkedIn, agency, referral, campus recruiting).' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'Desired start date for the new hire to begin employment. Used for workforce planning and onboarding preparation.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unionPosition rdf:type rdf:Property ;
    rdfs:label 'Union Position' ;
    rdfs:comment 'Indicates whether the position is covered by a collective bargaining agreement or union contract.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:separationRecordId rdf:type rdf:Property ;
    rdfs:label 'Separation Record Id' ;
    rdfs:comment 'Unique identifier for the employee separation record. Primary key for the separation_record product.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alt5SeparationModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alt5 Separation Modified By User Employee Id' ;
    rdfs:comment 'The system user ID of the person who last modified this separation record. Audit trail for accountability.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySeparationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Separation Employee Id' ;
    rdfs:comment 'Reference to the employee who is separating from Media Broadcasting. Links to the employee master record.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternarySeparationInitiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Separation Initiated By Employee Id' ;
    rdfs:comment 'Reference to the employee or HR user who initiated the separation record in the system.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinarySeparationApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Separation Approved By Employee Id' ;
    rdfs:comment 'Reference to the manager or HR leader who approved the separation. Null if not yet approved.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySeparationHrBusinessPartnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Separation Hr Business Partner Employee Id' ;
    rdfs:comment 'Reference to the HR business partner who managed the separation process and documentation.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:badgeAccessRevocationDate rdf:type rdf:Property ;
    rdfs:label 'Badge Access Revocation Date' ;
    rdfs:comment 'The date physical building access badges and credentials were deactivated. Important for facility security.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobraEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for COBRA health insurance continuation coverage under federal law.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobraNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Cobra Notification Date' ;
    rdfs:comment 'The date COBRA continuation coverage notification was sent to the employee. Required within 14 days of separation for compliance.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentReturnDate rdf:type rdf:Property ;
    rdfs:label 'Equipment Return Date' ;
    rdfs:comment 'The date all company equipment was returned by the employee. Null if equipment has not been fully returned.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentReturnStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Return Status' ;
    rdfs:comment 'Status of company equipment return: all returned (complete), partially returned (some items outstanding), not returned (no items returned), or not applicable (no equipment issued).' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitInterviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Completed Flag' ;
    rdfs:comment 'Indicates whether an exit interview was conducted with the departing employee. True if completed, False if not completed or declined.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exitInterviewDate rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Date' ;
    rdfs:comment 'The date the exit interview was conducted. Null if no exit interview was completed.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitInterviewSentiment rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Sentiment' ;
    rdfs:comment 'Overall sentiment classification from the exit interview: positive (employee left on good terms), neutral (professional departure), negative (employee expressed dissatisfaction), or not applicable (no interview conducted).' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitInterviewSummary rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Summary' ;
    rdfs:comment 'Summary of key themes and feedback from the exit interview. Confidential HR information used for organizational improvement.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalPaycheckAmount rdf:type rdf:Property ;
    rdfs:label 'Final Paycheck Amount' ;
    rdfs:comment 'Total gross amount of the final paycheck before deductions. Includes regular pay, accrued PTO payout, and any other final compensation.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalPaycheckDate rdf:type rdf:Property ;
    rdfs:label 'Final Paycheck Date' ;
    rdfs:comment 'The date the employee\'s final paycheck was issued, including all outstanding wages, accrued paid time off, and other compensation.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastWorkingDate rdf:type rdf:Property ;
    rdfs:label 'Last Working Date' ;
    rdfs:comment 'The last date the employee physically worked or performed duties. May differ from separation date if employee is on garden leave or paid time off during notice period.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonCompeteAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Non Compete Agreement Flag' ;
    rdfs:comment 'Indicates whether the employee is bound by a non-compete agreement that restricts employment with competitors for a specified period.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonCompeteExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Non Compete Expiry Date' ;
    rdfs:comment 'The date the non-compete agreement expires and the employee is free to work for competitors. Null if no non-compete exists.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonDisclosureAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Non Disclosure Agreement Flag' ;
    rdfs:comment 'Indicates whether the employee is bound by a non-disclosure agreement protecting Media Broadcasting\'s confidential information and trade secrets.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noticeDate rdf:type rdf:Property ;
    rdfs:label 'Notice Date' ;
    rdfs:comment 'The date the employee or employer provided notice of the separation. May be null for immediate terminations or unexpected events.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rehireEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligibility Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for rehire at Media Broadcasting. True if eligible, False if ineligible due to performance, conduct, or policy violations.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rehireEligibilityReason rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligibility Reason' ;
    rdfs:comment 'Explanation for the rehire eligibility determination. Confidential HR information documenting the basis for the decision.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationDate rdf:type rdf:Property ;
    rdfs:label 'Separation Date' ;
    rdfs:comment 'The official date the employee\'s employment relationship with Media Broadcasting ended. Last day of active employment.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:separationNumber rdf:type rdf:Property ;
    rdfs:label 'Separation Number' ;
    rdfs:comment 'Business-facing unique identifier for the separation event, used in HR documentation and communications. Format: SEP-YYYYNNNN.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Separation Reason Code' ;
    rdfs:comment 'Detailed reason code for the separation, providing granular classification beyond separation type (e.g., performance, relocation, better opportunity, misconduct, reduction in force).' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Separation Reason Description' ;
    rdfs:comment 'Free-text description providing additional context and details about the separation reason. Confidential business information.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationStatus rdf:type rdf:Property ;
    rdfs:label 'Separation Status' ;
    rdfs:comment 'Current workflow status of the separation record: initiated, pending approval, approved, processing (offboarding in progress), completed (all tasks done), or cancelled.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationType rdf:type rdf:Property ;
    rdfs:label 'Separation Type' ;
    rdfs:comment 'High-level classification of the separation event: voluntary resignation, involuntary termination, retirement, layoff, end of contract, or death.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severanceAmount rdf:type rdf:Property ;
    rdfs:label 'Severance Amount' ;
    rdfs:comment 'Total severance payment amount provided to the employee. Null if no severance was offered or employee was ineligible.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:severanceEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Severance Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for a severance package based on separation type, tenure, and company policy.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severancePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Severance Payment Date' ;
    rdfs:comment 'The date the severance payment was issued to the employee. Null if no severance was provided.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:severanceWeeks rdf:type rdf:Property ;
    rdfs:label 'Severance Weeks' ;
    rdfs:comment 'Number of weeks of pay provided as severance, typically calculated based on tenure and position level.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systemAccessRevocationDate rdf:type rdf:Property ;
    rdfs:label 'System Access Revocation Date' ;
    rdfs:comment 'The date all system access, credentials, and permissions were revoked for the employee. Critical for security and compliance.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unemploymentClaimFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Unemployment Claim Filed Flag' ;
    rdfs:comment 'Indicates whether the employee filed for unemployment benefits following separation. Used for tracking and responding to claims.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unemploymentClaimStatus rdf:type rdf:Property ;
    rdfs:label 'Unemployment Claim Status' ;
    rdfs:comment 'Current status of the unemployment benefits claim: approved, denied, pending review, contested by employer, or not filed.' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timesheetId rdf:type rdf:Property ;
    rdfs:label 'Timesheet Id' ;
    rdfs:comment 'Unique identifier for the timesheet record. Primary key.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timesheetApprovingManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Timesheet Approving Manager Employee Id' ;
    rdfs:comment 'Identifier of the manager or supervisor who approved or is responsible for approving this timesheet. Links to employee master record.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:timesheetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Timesheet Employee Id' ;
    rdfs:comment 'Identifier of the employee who submitted this timesheet. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:timesheetModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Timesheet Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified this timesheet record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:holidayHours rdf:type rdf:Property ;
    rdfs:label 'Holiday Hours' ;
    rdfs:comment 'Total number of paid holiday hours included in this timesheet period for recognized company holidays.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onCallHours rdf:type rdf:Property ;
    rdfs:label 'On Call Hours' ;
    rdfs:comment 'Total number of on-call hours during the pay period. Relevant for broadcast engineers and technical staff required to be available for emergency playout or transmission issues.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDifferentialHours rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Hours' ;
    rdfs:comment 'Total number of hours worked during shifts eligible for differential pay (e.g., night shift, weekend shift). Common in 24/7 broadcast operations.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timesheetNumber rdf:type rdf:Property ;
    rdfs:label 'Timesheet Number' ;
    rdfs:comment 'Human-readable business identifier for the timesheet, typically formatted as TS-YYYYMMDD or similar pattern for external reference and reporting.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalHoursApproved rdf:type rdf:Property ;
    rdfs:label 'Total Hours Approved' ;
    rdfs:comment 'Total number of hours approved by the manager for payroll processing. May differ from submitted hours if adjustments were made during approval.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHoursSubmitted rdf:type rdf:Property ;
    rdfs:label 'Total Hours Submitted' ;
    rdfs:comment 'Total number of hours submitted by the employee across all categories (regular, overtime, double-time, on-call, shift differential, PTO, holiday, unpaid leave). Sum of all hour types.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unpaidLeaveHours rdf:type rdf:Property ;
    rdfs:label 'Unpaid Leave Hours' ;
    rdfs:comment 'Total number of unpaid leave hours recorded in this timesheet period, such as unpaid personal leave or leave without pay.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCourseId rdf:type rdf:Property ;
    rdfs:label 'Training Course Id' ;
    rdfs:comment 'Unique identifier for the training course. Primary key.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCourse .

ind:applicableDaypartId rdf:type rdf:Property ;
    rdfs:label 'Applicable Daypart Id' ;
    rdfs:comment 'Foreign key linking to scheduling.daypart. Business justification: Training courses for broadcast operations may be daypart-specific (e.g., "Prime Time Programming Strategy", "Morning Show Production Techniques"). Specialized training curriculum design requires linki' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Daypart .

ind:certificationAwarded rdf:type rdf:Property ;
    rdfs:label 'Certification Awarded' ;
    rdfs:comment 'Name of the certification, credential, or certificate of completion awarded upon successful course completion (e.g., FCC Broadcast Operator License, SCTE Broadband Transportation Specialist, Media Broadcasting Editorial Standards Certificate). Null if no formal certification is awarded.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationCredits rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Credits' ;
    rdfs:comment 'Number of continuing education units (CEUs) or professional development hours (PDHs) awarded upon course completion, recognized by industry associations or regulatory bodies. Null if no formal credits are awarded.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerParticipant rdf:type rdf:Property ;
    rdfs:label 'Cost Per Participant' ;
    rdfs:comment 'Standard cost charged per participant for enrollment in the training course, in USD. Includes tuition, materials, and vendor fees. Used for training budget planning and cost allocation. Null if the course is provided at no charge.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the training course for catalog and registration purposes (e.g., BC-101, FCC-REG-2023, EEO-COMP).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseDescription rdf:type rdf:Property ;
    rdfs:label 'Course Description' ;
    rdfs:comment 'Comprehensive narrative description of the training course content, topics covered, instructional approach, and target audience. Used in the learning catalog and course registration materials.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total instructional time required to complete the training course, measured in hours (e.g., 2.5 hours for a half-day workshop, 40 hours for a week-long certification program).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:learningObjectives rdf:type rdf:Property ;
    rdfs:label 'Learning Objectives' ;
    rdfs:comment 'Detailed description of the knowledge, skills, and competencies that participants will acquire upon successful completion of the training course. Defines the expected learning outcomes.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether the training course is mandatory for specific job roles or all employees (True) or optional/elective (False). Mandatory courses are typically driven by regulatory requirements (FCC, EEO, COPPA) or critical operational competencies.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxEnrollment rdf:type rdf:Property ;
    rdfs:label 'Max Enrollment' ;
    rdfs:comment 'Maximum number of participants that can be enrolled in a single offering or session of the training course. Null if there is no enrollment cap (e.g., for self-paced e-learning courses).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prerequisites rdf:type rdf:Property ;
    rdfs:label 'Prerequisites' ;
    rdfs:comment 'Description of prerequisite courses, certifications, or experience required before an employee can enroll in this training course (e.g., Must complete BC-100 Introduction to Broadcasting, Requires 6 months experience in playout operations). Null if no prerequisites.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Name of the organization or entity that developed or delivers the training course (e.g., Media Broadcasting Learning & Development, Dalet Academy, Society of Cable Telecommunications Engineers).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Source of the training course: internal (developed and delivered by Media Broadcasting HR/L&D), external (third-party training vendor), vendor (system vendor training such as Dalet or Ericsson), industry association (MPA, ATSC, SCTE), or regulatory body (FCC-mandated training).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Period Months' ;
    rdfs:comment 'Number of months after which the certification or training must be renewed or retaken to maintain compliance or currency (e.g., 12 months for annual cybersecurity awareness, 36 months for FCC regulatory training). Null if no recertification is required.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCourseCategory rdf:type rdf:Property ;
    rdfs:label 'Training Course Category' ;
    rdfs:comment 'Primary classification of the training course by subject area: broadcast operations (playout, scheduling, transmission), regulatory compliance (FCC, EEO, COPPA), technical skills (MAM, CDN, encoding), leadership development, cybersecurity awareness, or editorial standards.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCourseStatus rdf:type rdf:Property ;
    rdfs:label 'Training Course Status' ;
    rdfs:comment 'Current lifecycle status of the training course: active (available for enrollment), inactive (temporarily unavailable), under development (being created or updated), retired (permanently discontinued), or suspended (on hold pending review or update).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Training Enrollment Id' ;
    rdfs:comment 'Unique identifier for the training enrollment record. Primary key for this entity.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousEnrollmentTrainingEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Previous Enrollment Training Enrollment Id' ;
    rdfs:comment 'Identifier of the previous training enrollment record that this recertification enrollment supersedes. Used to track recertification history and lineage. Null for initial enrollments.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingEnrollment .

ind:assessmentResult rdf:type rdf:Property ;
    rdfs:label 'Assessment Result' ;
    rdfs:comment 'Outcome of the training assessment indicating whether the employee passed, failed, has a pending assessment, did not require assessment for completion, or has an incomplete assessment.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendancePercentage rdf:type rdf:Property ;
    rdfs:label 'Attendance Percentage' ;
    rdfs:comment 'Percentage of scheduled training sessions or modules that the employee attended or completed. Calculated as (hours completed / hours scheduled) * 100. Used for compliance verification and completion criteria.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateIssued rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued' ;
    rdfs:comment 'Boolean flag indicating whether a training completion certificate was issued to the employee upon successful completion. True if certificate was issued, False otherwise.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrolledByUser rdf:type rdf:Property ;
    rdfs:label 'Enrolled By User' ;
    rdfs:comment 'Username or identifier of the person who initiated the enrollment (e.g., HR administrator, manager, or self-enrollment by employee). Used for audit trail and enrollment source tracking.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Type' ;
    rdfs:comment 'Classification of the enrollment indicating whether the training is mandatory (required by policy or regulation), voluntary (employee-initiated), recommended (suggested by manager), or compliance-driven (regulatory requirement such as FCC or EEO training).' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'Name of the instructor, facilitator, or trainer who delivered the training session. Null for self-paced online courses without instructor involvement.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecertification rdf:type rdf:Property ;
    rdfs:label 'Is Recertification' ;
    rdfs:comment 'Boolean flag indicating whether this enrollment represents a recertification or refresher training for a previously completed course. True for recertification enrollments, False for initial certifications.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfAttempts rdf:type rdf:Property ;
    rdfs:label 'Number Of Attempts' ;
    rdfs:comment 'Count of how many times the employee attempted the training assessment or examination. Used for tracking learning progress and identifying employees who may need additional support.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score required to pass the training assessment and achieve completion status. Used to determine pass/fail result. Null if no assessment is required for completion.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned date when the training session or learning program is scheduled to conclude for this enrollment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Training Delivery Method' ;
    rdfs:comment 'Method by which the training content is delivered to the employee. Includes in-person classroom sessions, virtual instructor-led training, self-paced online courses, blended learning combining multiple methods, or on-the-job practical training.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Training Hours Completed' ;
    rdfs:comment 'Actual number of training hours completed by the employee. Used for tracking progress, compliance reporting, and crediting continuing education units.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingHoursScheduled rdf:type rdf:Property ;
    rdfs:label 'Training Hours Scheduled' ;
    rdfs:comment 'Total number of training hours scheduled for this enrollment based on the course curriculum. Used for planning and resource allocation.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'Physical or virtual location where the training is conducted. For in-person training, includes facility name or address. For virtual training, may include platform name (e.g., Zoom, Microsoft Teams). Null for self-paced online courses.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date when the employee withdrew from the training course before completion. Null if the enrollment was not withdrawn.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unionMembershipId rdf:type rdf:Property ;
    rdfs:label 'Union Membership Id' ;
    rdfs:comment 'Unique identifier for the union membership record. Primary key for tracking each employee\'s union affiliation within Media Broadcasting.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bargainingUnitCode rdf:type rdf:Property ;
    rdfs:label 'Bargaining Unit Code' ;
    rdfs:comment 'Code identifying the specific bargaining unit to which this employee belongs. A bargaining unit is a group of employees with a clear community of interest who are represented by a union for collective bargaining purposes. Large employers may have multiple bargaining units for different job families, locations, or divisions.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbaEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Cba Effective Start Date' ;
    rdfs:comment 'Date when the current collective bargaining agreement became effective and binding. CBAs are typically negotiated for multi-year terms and this date marks the beginning of the current contract period.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cbaReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Cba Reference Code' ;
    rdfs:comment 'Reference code or identifier for the specific collective bargaining agreement that governs this employee\'s terms and conditions of employment. Multiple CBAs may exist for different unions, job classifications, or facilities within Media Broadcasting.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duesDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Dues Deduction Amount' ;
    rdfs:comment 'Amount of union dues deducted from the employee\'s paycheck each pay period. May be a flat amount or a percentage of gross earnings as specified in the collective bargaining agreement. Null if dues deduction is not authorized.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:duesDeductionAuthorized rdf:type rdf:Property ;
    rdfs:label 'Dues Deduction Authorized' ;
    rdfs:comment 'Indicates whether the employee has authorized automatic payroll deduction of union dues. True means the employee has signed a dues checkoff authorization form and Media Broadcasting deducts dues from each paycheck and remits to the union. False means the employee pays dues directly to the union.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:duesDeductionFrequency rdf:type rdf:Property ;
    rdfs:label 'Dues Deduction Frequency' ;
    rdfs:comment 'Frequency at which union dues are deducted from the employee\'s paycheck. Must align with the employee\'s pay frequency and union requirements.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairShareFeePayer rdf:type rdf:Property ;
    rdfs:label 'Fair Share Fee Payer' ;
    rdfs:comment 'Indicates whether the employee pays a fair share or agency fee rather than full union dues. In some jurisdictions and under some CBAs, non-members who are covered by the union contract must pay a fee to cover the cost of representation, but this fee is typically lower than full membership dues. This practice varies by state right-to-work laws and recent Supreme Court rulings.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grievanceEligible rdf:type rdf:Property ;
    rdfs:label 'Grievance Eligible' ;
    rdfs:comment 'Indicates whether the employee is eligible to file grievances under the collective bargaining agreement\'s grievance and arbitration procedures. True for members in good standing. False for employees in probationary periods, suspended members, or those who have opted out of union representation where permitted by law.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthWelfarePlanParticipant rdf:type rdf:Property ;
    rdfs:label 'Health Welfare Plan Participant' ;
    rdfs:comment 'Indicates whether the employee participates in a union-sponsored health and welfare benefit plan. Many unions maintain multi-employer health plans that provide medical, dental, vision, and other benefits funded by employer contributions.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Initiation Fee Amount' ;
    rdfs:comment 'One-time initiation fee paid by the employee when joining the union. This fee covers administrative costs of processing the membership application and is typically specified in the union constitution. May be paid in a lump sum or through payroll deduction installments.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiationFeePaidDate rdf:type rdf:Property ;
    rdfs:label 'Initiation Fee Paid Date' ;
    rdfs:comment 'Date when the employee completed payment of the union initiation fee. Membership may not be fully active until this fee is paid in full.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Job Classification Code' ;
    rdfs:comment 'Union job classification code that determines the employee\'s pay scale, work rules, and benefits under the collective bargaining agreement. Job classifications define specific roles, skill levels, and wage rates negotiated between the union and employer.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobClassificationTitle rdf:type rdf:Property ;
    rdfs:label 'Job Classification Title' ;
    rdfs:comment 'Descriptive title of the union job classification under which the employee is covered. Examples include Camera Operator, Audio Engineer, Production Assistant, Broadcast Technician, Grip, Electrician, Driver, etc. This may differ from the employee\'s official job title in HR systems.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipEndDate rdf:type rdf:Property ;
    rdfs:label 'Membership End Date' ;
    rdfs:comment 'Date when the employee\'s union membership ended, either through withdrawal, termination of employment, or conversion to retired status. Null for active memberships.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipInitiationDate rdf:type rdf:Property ;
    rdfs:label 'Membership Initiation Date' ;
    rdfs:comment 'Date when the employee was formally initiated into union membership and became a full member. This may differ from the hire date if there was a probationary period or if the employee joined the union after starting employment.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pensionPlanParticipant rdf:type rdf:Property ;
    rdfs:label 'Pension Plan Participant' ;
    rdfs:comment 'Indicates whether the employee participates in a union-sponsored pension or retirement plan. Many unions, particularly in broadcasting and entertainment, maintain multi-employer pension plans funded by employer contributions negotiated in the CBA.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:probationaryPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Probationary Period End Date' ;
    rdfs:comment 'Date when the employee\'s probationary period under the collective bargaining agreement ends. During probation, employees may have limited rights and protections. After probation ends, employees typically gain full seniority rights, just cause protection, and full grievance rights.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightToWorkState rdf:type rdf:Property ;
    rdfs:label 'Right To Work State' ;
    rdfs:comment 'Indicates whether the employee works in a right-to-work state where union membership and dues payment cannot be required as a condition of employment. This affects whether union security clauses in the CBA apply to this employee.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seniorityDate rdf:type rdf:Property ;
    rdfs:label 'Seniority Date' ;
    rdfs:comment 'Date used to calculate the employee\'s seniority for purposes of layoffs, recalls, shift bidding, vacation scheduling, and other seniority-based rights under the collective bargaining agreement. May be the original hire date or adjusted for breaks in service.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unionLocalNumber rdf:type rdf:Property ;
    rdfs:label 'Union Local Number' ;
    rdfs:comment 'The local chapter or lodge number of the union to which the employee belongs. Local unions represent members in specific geographic regions or facilities and handle local grievances and contract administration.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionStewardFlag rdf:type rdf:Property ;
    rdfs:label 'Union Steward Flag' ;
    rdfs:comment 'Indicates whether the employee serves as a union steward or shop steward. Union stewards are elected or appointed members who represent fellow workers in grievances, workplace disputes, and contract enforcement. Stewards have special protections under labor law and may have release time for union duties.' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workScheduleId rdf:type rdf:Property ;
    rdfs:label 'Work Schedule Id' ;
    rdfs:comment 'Unique identifier for the work schedule pattern. Primary key.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDaypartId rdf:type rdf:Property ;
    rdfs:label 'Primary Daypart Id' ;
    rdfs:comment 'Foreign key linking to scheduling.daypart. Business justification: Broadcast work schedules align with dayparts (morning shift covers morning daypart, prime time shift covers prime daypart). 24/7 operations shift planning requires mapping work schedules to broadcast ' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Daypart .

ind:applicableJobFamilies rdf:type rdf:Property ;
    rdfs:label 'Applicable Job Families' ;
    rdfs:comment 'Comma-separated list of job families or roles this schedule is designed for (e.g., Broadcast Engineer, Playout Operator, Master Control Technician, Production Staff, Administrative). Supports role-based schedule assignment.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableOrgUnits rdf:type rdf:Property ;
    rdfs:label 'Applicable Org Units' ;
    rdfs:comment 'Comma-separated list of organizational unit codes or names where this schedule is used (e.g., Broadcast Operations, Playout Engineering, News Production, Corporate Office). Enables filtering schedules by department or division.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total duration of unpaid breaks during the shift, measured in minutes (e.g., 30 for half-hour lunch, 60 for one-hour lunch). Used to calculate net working hours and compliance with labor regulations.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daypartClassification rdf:type rdf:Property ;
    rdfs:label 'Daypart Classification' ;
    rdfs:comment 'Broadcast industry daypart classification for the schedule: morning (6-9 AM), daytime (9 AM-4 PM), early_fringe (4-7 PM), prime_access (7-8 PM), prime_time (8-11 PM), late_fringe (11 PM-1 AM), overnight (1-6 AM). Aligns shift schedules with programming and advertising dayparts. [ENUM-REF-CANDIDATE: morning|daytime|early_fringe|prime_access|prime_time|late_fringe|overnight — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Days Of Week' ;
    rdfs:comment 'Comma-separated list of days this schedule applies to (e.g., Mon,Tue,Wed,Thu,Fri for standard office; Mon,Tue,Wed,Thu for compressed week; Sat,Sun for weekend shift). Supports broadcast operations requiring 24/7 coverage.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayWorkRequired rdf:type rdf:Property ;
    rdfs:label 'Holiday Work Required' ;
    rdfs:comment 'Indicates whether employees on this schedule are expected to work on company-recognized holidays. True for essential broadcast operations (playout, master control), false for administrative roles.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mealBreakRequired rdf:type rdf:Property ;
    rdfs:label 'Meal Break Required' ;
    rdfs:comment 'Indicates whether a meal break is legally or contractually required for this schedule. True for shifts exceeding a certain duration (typically 6+ hours), false for shorter shifts. Ensures compliance with labor regulations.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onCallFrequency rdf:type rdf:Property ;
    rdfs:label 'On Call Frequency' ;
    rdfs:comment 'Frequency of on-call duty for schedules that include on-call rotation: none (no on-call), weekly (one week per rotation), biweekly (one week every two weeks), monthly (one week per month), as_needed (ad-hoc). Relevant for broadcast engineering and technical support roles.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onCallResponseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'On Call Response Time Minutes' ;
    rdfs:comment 'Maximum time in minutes an on-call employee must respond to a call-out (e.g., 30 for 30-minute response, 60 for one-hour response). Null for schedules without on-call duty. Critical for broadcast continuity and Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeCalculationBasis rdf:type rdf:Property ;
    rdfs:label 'Overtime Calculation Basis' ;
    rdfs:comment 'Basis for calculating overtime: daily (hours beyond threshold in a single day), weekly (hours beyond threshold in a work week), biweekly (hours beyond threshold in a two-week pay period). Determines when premium pay rates apply.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidBreakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Paid Break Duration Minutes' ;
    rdfs:comment 'Total duration of paid breaks during the shift, measured in minutes (e.g., 15 for two 15-minute breaks). Separate from unpaid meal breaks; included in compensable time.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresBroadcastLicense rdf:type rdf:Property ;
    rdfs:label 'Requires Broadcast License' ;
    rdfs:comment 'Indicates whether employees assigned to this schedule must hold a valid broadcast engineering or operator license (e.g., FCC General Radiotelephone Operator License). True for technical playout and transmission roles, false for administrative and production roles.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restPeriodBetweenShiftsHours rdf:type rdf:Property ;
    rdfs:label 'Rest Period Between Shifts Hours' ;
    rdfs:comment 'Minimum number of hours required between the end of one shift and the start of the next for employees on this schedule (e.g., 8 for eight-hour rest, 11 for eleven-hour rest). Ensures compliance with labor regulations and employee well-being, especially for rotating broadcast shifts.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rotationCycleDays rdf:type rdf:Property ;
    rdfs:label 'Rotation Cycle Days' ;
    rdfs:comment 'Number of days in the rotation cycle for rotating shift schedules (e.g., 7 for weekly rotation, 14 for bi-weekly, 28 for four-week cycle). Null for fixed schedules. Broadcast operations often use 7, 14, or 21-day cycles to ensure equitable distribution of overnight and weekend shifts.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Schedule Description' ;
    rdfs:comment 'Detailed description of the work schedule pattern, including any special conditions, rotation details, or operational notes (e.g., \'Four 10-hour shifts Monday-Thursday with Friday off; on-call rotation every fourth week; requires FCC license\').' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftEndTime rdf:type rdf:Property ;
    rdfs:label 'Shift End Time' ;
    rdfs:comment 'Standard end time for the work shift in HH:MM 24-hour format (e.g., 17:00 for 5 PM, 06:00 for 6 AM next day). For rotating or flexible schedules, this represents the primary or latest end time.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTime rdf:type rdf:Property ;
    rdfs:label 'Shift Start Time' ;
    rdfs:comment 'Standard start time for the work shift in HH:MM 24-hour format (e.g., 09:00 for 9 AM, 22:00 for 10 PM). For rotating or flexible schedules, this represents the primary or earliest start time.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalWeeklyHours rdf:type rdf:Property ;
    rdfs:label 'Total Weekly Hours' ;
    rdfs:comment 'Total number of hours per week defined by this schedule pattern. Standard full-time is typically 40 hours; broadcast operations may have 37.5, 40, or 42 hours depending on shift structure and break policies.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weekendWorkRequired rdf:type rdf:Property ;
    rdfs:label 'Weekend Work Required' ;
    rdfs:comment 'Indicates whether this schedule includes regular weekend work (Saturday and/or Sunday). True for broadcast operations requiring 24/7 coverage, false for standard Monday-Friday office schedules.' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workforceGrievanceId rdf:type rdf:Property ;
    rdfs:label 'Workforce Grievance Id' ;
    rdfs:comment 'Unique identifier for the workforce grievance record. Primary key for the workforce grievance entity.' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryWorkforceComplainantEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Complainant Employee Id' ;
    rdfs:comment 'Identifier of the employee who filed the grievance. Links to the employee master record.' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryWorkforceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Workforce Employee Id' ;
    rdfs:comment 'Identifier of the HR investigator or case manager assigned to investigate and resolve the grievance. Links to the employee master record.' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Detailed narrative description of the grievance, including the nature of the complaint, circumstances, and impact on the complainant.' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryActionTaken rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Taken' ;
    rdfs:comment 'Type of disciplinary action taken against the respondent if the grievance was substantiated.' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAgencyName rdf:type rdf:Property ;
    rdfs:label 'External Agency Name' ;
    rdfs:comment 'Name of the external agency to which the grievance was reported (e.g., EEOC, OSHA, state labor department).' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAgencyReportedFlag rdf:type rdf:Property ;
    rdfs:label 'External Agency Reported Flag' ;
    rdfs:comment 'Indicates whether the grievance was also reported to an external regulatory or enforcement agency such as EEOC, OSHA, or state labor board.' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grievanceStatus rdf:type rdf:Property ;
    rdfs:label 'Grievance Status' ;
    rdfs:comment 'Current lifecycle status of the grievance case in the investigation and resolution workflow.' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentLocation rdf:type rdf:Property ;
    rdfs:label 'Incident Location' ;
    rdfs:comment 'Physical or virtual location where the alleged incident occurred (e.g., studio, office, remote work, production site).' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationEndDate rdf:type rdf:Property ;
    rdfs:label 'Investigation End Date' ;
    rdfs:comment 'The date when the investigation was completed and findings were documented.' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationFindings rdf:type rdf:Property ;
    rdfs:label 'Investigation Findings' ;
    rdfs:comment 'Summary of the investigation findings, evidence collected, witness statements, and conclusions reached by the investigator.' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'The date when the formal investigation of the grievance commenced.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalCounselInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Involved Flag' ;
    rdfs:comment 'Indicates whether legal counsel was engaged by either party during the grievance process.' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:respondentType rdf:type rdf:Property ;
    rdfs:label 'Respondent Type' ;
    rdfs:comment 'Classification of the respondent entity: individual employee, manager, department, organization-level, or external party.' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retaliationReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Retaliation Reported Flag' ;
    rdfs:comment 'Indicates whether the complainant reported retaliation following the filing of the grievance.' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Union Involved Flag' ;
    rdfs:comment 'Indicates whether a labor union was involved in the grievance filing or resolution process.' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriesTalentCreditId rdf:type rdf:Property ;
    rdfs:label 'Series Talent Credit Id' ;
    rdfs:comment 'Unique identifier for this series talent credit record. Primary key for the association.' ;
    rdfs:domain ind:SeriesTalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditEndDate rdf:type rdf:Property ;
    rdfs:label 'Credit End Date' ;
    rdfs:comment 'The date when this talent\'s credited involvement in the series ended. Null for ongoing roles. Used for residual eligibility windows.' ;
    rdfs:domain ind:SeriesTalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditStartDate rdf:type rdf:Property ;
    rdfs:label 'Credit Start Date' ;
    rdfs:comment 'The date when this talent\'s credited involvement in the series began. Used for tenure calculation and anniversary tracking.' ;
    rdfs:domain ind:SeriesTalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditId rdf:type rdf:Property ;
    rdfs:label 'Credit Id' ;
    rdfs:comment 'Unique identifier for this talent credit record. Primary key for the credit association.' ;
    rdfs:domain ind:Credit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'The absolute display order of this credit in the end credits sequence. Determines the exact position in the credit roll for broadcast and streaming.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'The date and time when this credit relationship ended or was completed. Used for tracking production timelines and contract fulfillment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'The date and time when this credit relationship became effective. Typically corresponds to the start of the talent\'s work on this title.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partnerRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Partner Relationship Id' ;
    rdfs:comment 'Unique identifier for this talent-partner relationship record. Primary key.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conflictOfInterestFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Flag' ;
    rdfs:comment 'Indicates whether there are known conflicts of interest between this talent and partner that require disclosure or management (e.g., competing projects, contractual restrictions).' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealCount rdf:type rdf:Property ;
    rdfs:label 'Deal Count' ;
    rdfs:comment 'Total number of individual deals or projects executed between this talent and partner under this relationship. Used for relationship strength assessment.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredPartnerFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Partner Flag' ;
    rdfs:comment 'Indicates whether this partner has preferred status for this talent, meaning the talent or their representation prioritizes opportunities from this partner.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Relationship Created Timestamp' ;
    rdfs:comment 'The date and time when this talent-partner relationship record was first created in the system.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:relationshipUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Relationship Updated Timestamp' ;
    rdfs:comment 'The date and time when this talent-partner relationship record was last modified.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalDealValue rdf:type rdf:Property ;
    rdfs:label 'Total Deal Value' ;
    rdfs:comment 'Cumulative monetary value of all deals executed between this talent and partner. Used for strategic tier assessment and relationship ROI analysis.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelCarriageId rdf:type rdf:Property ;
    rdfs:label 'Channel Carriage Id' ;
    rdfs:comment 'Unique surrogate identifier for each channel carriage agreement record. Primary key.' ;
    rdfs:domain ind:ChannelCarriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutRulesOverride rdf:type rdf:Property ;
    rdfs:label 'Blackout Rules Override' ;
    rdfs:comment 'Platform-specific geographic blackout rules that override or supplement the channels default blackout_enabled configuration for this OTT platform. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ChannelCarriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformChannelNumber rdf:type rdf:Property ;
    rdfs:label 'Platform Channel Number' ;
    rdfs:comment 'The logical channel number assigned to this channel specifically on this OTT platform, which may differ from the channels broadcast logical_channel_number. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ChannelCarriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformDisplayName rdf:type rdf:Property ;
    rdfs:label 'Platform Display Name' ;
    rdfs:comment 'The branded channel name displayed to subscribers on this specific OTT platform, which may differ from the channels network_name for branding or licensing reasons. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ChannelCarriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simulcastEnabled rdf:type rdf:Property ;
    rdfs:label 'Simulcast Enabled' ;
    rdfs:comment 'Indicates whether this channel is configured for simultaneous multi-platform broadcast (simulcast). When true, the channel\'s linear feed is distributed concurrently across broadcast, cable, and OTT/streaming platforms. [Moved from channel: This boolean flag on the channel product indicates whether the channel is configured for simulcast, but the actual simulcast configuration is platform-specific. The flag should remain on channel as a capability indicator, but the actual simulcast implementation details (start/end dates, platform-specific settings) belong in the carriage association. However, upon review, this attribute can remain on channel as a general capability flag - no move required.]' ;
    rdfs:domain ind:ChannelCarriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:simulcastEndDate rdf:type rdf:Property ;
    rdfs:label 'Simulcast End Date' ;
    rdfs:comment 'The date on which this channel ceased or will cease simulcast distribution on this OTT platform. Null indicates ongoing carriage. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ChannelCarriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:simulcastStartDate rdf:type rdf:Property ;
    rdfs:label 'Simulcast Start Date' ;
    rdfs:comment 'The date on which this channel began or will begin simulcast distribution on this OTT platform. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ChannelCarriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketDistributionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Market Distribution Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for this market-partner distribution agreement record' ;
    rdfs:domain ind:MarketDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'Date when this market-specific agreement was most recently renewed or renegotiated.' ;
    rdfs:domain ind:MarketDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextNegotiationDate rdf:type rdf:Property ;
    rdfs:label 'Next Negotiation Date' ;
    rdfs:comment 'Scheduled date for the next contract renegotiation or renewal discussion for this market-partner relationship.' ;
    rdfs:domain ind:MarketDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penetrationRate rdf:type rdf:Property ;
    rdfs:label 'Penetration Rate' ;
    rdfs:comment 'Percentage of total TV households in the market that subscribe to this partner\'s service. Calculated as subscriber_count divided by market TV household universe.' ;
    rdfs:domain ind:MarketDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetRightsGrantId rdf:type rdf:Property ;
    rdfs:label 'Asset Rights Grant Id' ;
    rdfs:comment 'Unique identifier for this specific rights grant record' ;
    rdfs:domain ind:AssetRightsGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rightsType rdf:type rdf:Property ;
    rdfs:label 'Rights Type' ;
    rdfs:comment 'Type of distribution rights granted (linear broadcast, video-on-demand, streaming, theatrical, etc.). Determines how the partner may exploit the asset.' ;
    rdfs:domain ind:AssetRightsGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealAssetLicenseId rdf:type rdf:Property ;
    rdfs:label 'Deal Asset License Id' ;
    rdfs:comment 'Unique identifier for this specific asset license within an acquisition deal' ;
    rdfs:domain ind:DealAssetLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rightsRestrictions rdf:type rdf:Property ;
    rdfs:label 'Rights Restrictions' ;
    rdfs:comment 'Specific usage restrictions or limitations for this asset beyond the general deal terms, such as platform restrictions, time-of-day limitations, or promotional restrictions' ;
    rdfs:domain ind:DealAssetLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformDistributionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Platform Distribution Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for each platform distribution agreement record' ;
    rdfs:domain ind:PlatformDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity End Date' ;
    rdfs:comment 'End date of the exclusivity window if exclusivity_flag is true' ;
    rdfs:domain ind:PlatformDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Start Date' ;
    rdfs:comment 'Start date of the exclusivity window if exclusivity_flag is true' ;
    rdfs:domain ind:PlatformDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumSubscriberCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Subscriber Commitment' ;
    rdfs:comment 'Minimum number of subscribers the partner commits to deliver or the platform commits to maintain through this distribution channel, if applicable' ;
    rdfs:domain ind:PlatformDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Platform Launch Date' ;
    rdfs:comment 'The date on which the OTT platform was made available through this specific distribution partner channel. May differ from the platforms overall launch date.' ;
    rdfs:domain ind:PlatformDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:broadcastId rdf:type rdf:Property ;
    rdfs:label 'Broadcast Id' ;
    rdfs:comment 'Primary key for the broadcast association' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rightsWindowId rdf:type rdf:Property ;
    rdfs:label 'Rights Window Id' ;
    rdfs:comment 'Reference to the specific rights window or license agreement governing this broadcast. Same episode may have different rights windows for different territories, platforms, or time periods.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsContentWindow .

ind:broadcastStatus rdf:type rdf:Property ;
    rdfs:label 'Broadcast Status' ;
    rdfs:comment 'Current lifecycle status of this specific broadcast event. Tracks whether the scheduled broadcast occurred as planned or was preempted/cancelled.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editType rdf:type rdf:Property ;
    rdfs:label 'Edit Type' ;
    rdfs:comment 'Classification of editorial modifications applied for this specific broadcast (content edits for standards, time compression, localization). Varies by territory and daypart.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatNumber rdf:type rdf:Property ;
    rdfs:label 'Repeat Number' ;
    rdfs:comment 'Sequential count of how many times this episode has been broadcast on this channel/platform. 0 = original airing, 1+ = repeat. Critical for rights management and audience measurement.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionVersion rdf:type rdf:Property ;
    rdfs:label 'Transmission Version' ;
    rdfs:comment 'The specific editorial version of the episode transmitted in this broadcast (e.g., theatrical cut, TV edit, international version). Different slots may air different versions of the same episode.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalDistributionId rdf:type rdf:Property ;
    rdfs:label 'Proposal Distribution Id' ;
    rdfs:comment 'Unique identifier for this proposal distribution record. Primary key.' ;
    rdfs:domain ind:ProposalDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactSalesContactId rdf:type rdf:Property ;
    rdfs:label 'Contact Sales Contact Id' ;
    rdfs:comment 'Foreign key linking to the sales contact who received the proposal.' ;
    rdfs:domain ind:ProposalDistribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesContact .

ind:primaryProposalSalesProposalId rdf:type rdf:Property ;
    rdfs:label 'Primary Proposal Sales Proposal Id' ;
    rdfs:comment 'Foreign key linking to the sales proposal that was distributed to the contact.' ;
    rdfs:domain ind:ProposalDistribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesProposal .

ind:openedFlag rdf:type rdf:Property ;
    rdfs:label 'Opened Flag' ;
    rdfs:comment 'Indicates whether this contact has opened or viewed the proposal materials. Tracked via email tracking pixels or document management system access logs.' ;
    rdfs:domain ind:ProposalDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'Timestamp of the first time this contact opened or accessed the proposal. Null if never opened. Used for engagement scoring and follow-up prioritization.' ;
    rdfs:domain ind:ProposalDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recipientType rdf:type rdf:Property ;
    rdfs:label 'Recipient Type' ;
    rdfs:comment 'Role of the contact in receiving this proposal: primary recipient, carbon copy, blind carbon copy, internal reviewer, or approver. Determines routing and notification behavior.' ;
    rdfs:domain ind:ProposalDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseType rdf:type rdf:Property ;
    rdfs:label 'Response Type' ;
    rdfs:comment 'Classification of the contacts response to the proposal: accepted, rejected, revision requested, questions raised, or no response. Drives workflow routing and follow-up actions.' ;
    rdfs:domain ind:ProposalDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentDate rdf:type rdf:Property ;
    rdfs:label 'Sent Date' ;
    rdfs:comment 'Timestamp when the proposal was sent or distributed to this specific contact. Used for tracking response time and follow-up scheduling.' ;
    rdfs:domain ind:ProposalDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingLineId rdf:type rdf:Property ;
    rdfs:label 'Billing Line Id' ;
    rdfs:comment 'Unique identifier for this content billing line item. Primary key.' ;
    rdfs:domain ind:BillingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'Total amount for this billing line before taxes and adjustments. Calculated as units_consumed × rate_per_unit, or flat fee for fixed-price licensing.' ;
    rdfs:domain ind:BillingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratePerUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Per Unit' ;
    rdfs:comment 'Billing rate per consumption unit for this title-territory-window combination. Supports consumption-based billing models (per-stream, per-transaction, per-impression, per-subscriber).' ;
    rdfs:domain ind:BillingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsConsumed rdf:type rdf:Property ;
    rdfs:label 'Units Consumed' ;
    rdfs:comment 'Quantity of consumption units for this title during the billing period. Interpretation varies by window type: stream count for SVOD/AVOD, transaction count for TVOD, impression count for advertising, subscriber count for carriage fees.' ;
    rdfs:domain ind:BillingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:titleRightsGrantId rdf:type rdf:Property ;
    rdfs:label 'Title Rights Grant Id' ;
    rdfs:comment 'Unique identifier for this title-grant association record. Primary key.' ;
    rdfs:domain ind:TitleRightsGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grantEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Grant Effective Date' ;
    rdfs:comment 'The date on which this specific title became available under this rights grant. May differ from the grant\'s overall start date if titles are added to an existing grant.' ;
    rdfs:domain ind:TitleRightsGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Grant Expiry Date' ;
    rdfs:comment 'The date on which rights for this specific title expire under this grant. May differ from the grant\'s overall end date if titles have different term lengths.' ;
    rdfs:domain ind:TitleRightsGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runsAllocated rdf:type rdf:Property ;
    rdfs:label 'Runs Allocated' ;
    rdfs:comment 'Number of broadcast or streaming runs allocated for this specific title under this grant. Titles within the same grant may have different run limits.' ;
    rdfs:domain ind:TitleRightsGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:titleAssetUsageId rdf:type rdf:Property ;
    rdfs:label 'Title Asset Usage Id' ;
    rdfs:comment 'Unique identifier for this title-to-asset usage relationship record. Primary key.' ;
    rdfs:domain ind:TitleAssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformTarget rdf:type rdf:Property ;
    rdfs:label 'Platform Target' ;
    rdfs:comment 'Target distribution platform or channel for this asset-title pairing. Examples: \'Linear Broadcast\', \'Netflix\', \'Hulu\', \'Theatrical\', \'YouTube\', \'Social Media\'. Used for format optimization and delivery workflow routing.' ;
    rdfs:domain ind:TitleAssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Flag' ;
    rdfs:comment 'Indicates whether this asset is the primary or canonical representation of the title for the given usage context and territory. Used to identify the default asset when multiple options exist (e.g., primary broadcast master vs. backup).' ;
    rdfs:domain ind:TitleAssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageStatus rdf:type rdf:Property ;
    rdfs:label 'Usage Status' ;
    rdfs:comment 'Current lifecycle status of this asset-title usage relationship. Active=currently valid for distribution, Pending=scheduled for future activation, Expired=past expiry_date, Suspended=temporarily disabled, Archived=historical record only.' ;
    rdfs:domain ind:TitleAssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionLabel rdf:type rdf:Property ;
    rdfs:label 'Version Label' ;
    rdfs:comment 'Human-readable label identifying the specific version or cut of the title represented by this asset. Examples: \'Theatrical Cut\', \'Director\'s Cut\', \'TV Edit\', \'International Version\', \'Trailer 1\', \'Teaser\', \'Behind the Scenes\'. Used for editorial tracking and distribution planning.' ;
    rdfs:domain ind:TitleAssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityComplianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Facility Compliance Obligation Id' ;
    rdfs:comment 'Unique identifier for this facility-obligation compliance tracking record. Primary key.' ;
    rdfs:domain ind:FacilityComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityResponsiblePerson rdf:type rdf:Property ;
    rdfs:label 'Facility Responsible Person' ;
    rdfs:comment 'Name or identifier of the person at this facility responsible for ensuring compliance with this specific obligation (may differ from the corporate responsible_team).' ;
    rdfs:domain ind:FacilityComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionMembershipId rdf:type rdf:Property ;
    rdfs:label 'Collection Membership Id' ;
    rdfs:comment 'Unique identifier for this collection membership record. Primary key.' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addedByUser rdf:type rdf:Property ;
    rdfs:label 'Added By User' ;
    rdfs:comment 'Username or identifier of the user who added this asset to the collection. Supports audit trail and accountability.' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addedDate rdf:type rdf:Property ;
    rdfs:label 'Added Date' ;
    rdfs:comment 'Date when the media asset was added to this collection. Tracks membership history and supports temporal queries.' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:curatorNotes rdf:type rdf:Property ;
    rdfs:label 'Curator Notes' ;
    rdfs:comment 'Free-text notes from the curator about this specific membership, such as editorial decisions, version notes, or special handling instructions.' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionReason rdf:type rdf:Property ;
    rdfs:label 'Inclusion Reason' ;
    rdfs:comment 'Business justification or editorial rationale for including this asset in the collection. Supports curatorial decision tracking.' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipRole rdf:type rdf:Property ;
    rdfs:label 'Membership Role' ;
    rdfs:comment 'Role or purpose of this asset within the collection context. Values: primary (main content), supplemental (supporting material), bonus (extra content), trailer (preview), promo (promotional), archive (historical reference).' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removedByUser rdf:type rdf:Property ;
    rdfs:label 'Removed By User' ;
    rdfs:comment 'Username or identifier of the user who removed this asset from the collection. Null if still active. Supports audit trail.' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removedDate rdf:type rdf:Property ;
    rdfs:label 'Removed Date' ;
    rdfs:comment 'Date when the media asset was removed from this collection. Null if still active. Enables tracking of membership lifecycle.' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:channelAllocationId rdf:type rdf:Property ;
    rdfs:label 'Channel Allocation Id' ;
    rdfs:comment 'Unique identifier for this channel allocation record. Primary key.' ;
    rdfs:domain ind:ChannelAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Budget Amount' ;
    rdfs:comment 'The portion of the total campaign budget allocated to this specific channel. Sum of all channel allocations should equal campaign total_budget_amount.' ;
    rdfs:domain ind:ChannelAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:talentDemographicAppealId rdf:type rdf:Property ;
    rdfs:label 'Talent Demographic Appeal Id' ;
    rdfs:comment 'Unique surrogate identifier for each talent demographic appeal measurement record. Primary key for the association.' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealIndex rdf:type rdf:Property ;
    rdfs:label 'Appeal Index' ;
    rdfs:comment 'Normalized appeal index score measuring the talent\'s overall appeal within this specific demographic segment. Scale and methodology aligned with industry standards for talent appeal measurement.' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awarenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Awareness Percentage' ;
    rdfs:comment 'Percentage of the demographic segment that is aware of or recognizes this talent. Key metric for talent reach and recognition within the target demographic.' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:castingRecommendationFlag rdf:type rdf:Property ;
    rdfs:label 'Casting Recommendation Flag' ;
    rdfs:comment 'Indicates whether this talent is recommended for casting in content targeting this demographic segment based on appeal thresholds. Used by casting directors and programming teams.' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidenceInterval rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval' ;
    rdfs:comment 'Statistical confidence interval (margin of error) for the appeal metrics in this measurement, expressed as a percentage. Used to assess measurement precision.' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:favorabilityRating rdf:type rdf:Property ;
    rdfs:label 'Favorability Rating' ;
    rdfs:comment 'Favorability or likability rating of the talent among respondents in this demographic segment who are aware of the talent. Measures positive sentiment.' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The date when this appeal measurement was conducted or published. Critical for tracking appeal trends over time and ensuring measurement currency.' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementVendor rdf:type rdf:Property ;
    rdfs:label 'Measurement Vendor' ;
    rdfs:comment 'The research vendor or organization that conducted the appeal measurement (e.g., Marketing Evaluations Inc., Nielsen, custom internal research). Used for data provenance and methodology validation.' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qScore rdf:type rdf:Property ;
    rdfs:label 'Q Score' ;
    rdfs:comment 'The Marketing Evaluations Q Score for this talent within this demographic segment. Measures familiarity and appeal, used industry-wide for talent valuation and casting decisions.' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'The directional trend of this talent\'s appeal within this demographic compared to prior measurements (Rising, Stable, Declining). Used for talent investment and booking strategy.' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerDemographicTargetId rdf:type rdf:Property ;
    rdfs:label 'Partner Demographic Target Id' ;
    rdfs:comment 'Unique surrogate identifier for each partner demographic targeting agreement record' ;
    rdfs:domain ind:PartnerDemographicTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guaranteedRating rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Rating' ;
    rdfs:comment 'Contractually guaranteed audience rating percentage for this demographic segment that the broadcaster commits to deliver to the partner. Used for make-good calculations if performance falls short.' ;
    rdfs:domain ind:PartnerDemographicTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceIndex rdf:type rdf:Property ;
    rdfs:label 'Performance Index' ;
    rdfs:comment 'Performance tracking index measuring actual delivery against guaranteed rating for this partner-demographic target. Values above 1.0 indicate over-delivery, below 1.0 indicate under-delivery requiring make-goods.' ;
    rdfs:domain ind:PartnerDemographicTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Priority classification for this demographic target within the partner relationship. Tier 1 represents highest priority demographics for the partner with premium inventory allocation and first-right-of-refusal on premium placements.' ;
    rdfs:domain ind:PartnerDemographicTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStatus rdf:type rdf:Property ;
    rdfs:label 'Target Status' ;
    rdfs:comment 'Current lifecycle status of this demographic targeting agreement. Active indicates currently in-force, Suspended indicates temporarily paused, Expired indicates contract term ended.' ;
    rdfs:domain ind:PartnerDemographicTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreBuyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Genre Buy Agreement Id' ;
    rdfs:comment 'Unique identifier for this advertiser-genre buy agreement record. Primary key.' ;
    rdfs:domain ind:GenreBuyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sales Employee Id' ;
    rdfs:comment 'The identifier of the sales account executive who negotiated and owns this genre buy agreement. Links to employee master data.' ;
    rdfs:domain ind:GenreBuyAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:genreCpmPremiumPercent rdf:type rdf:Property ;
    rdfs:label 'Genre Cpm Premium Percent' ;
    rdfs:comment 'The percentage premium (or discount if negative) applied to the base CPM rate for this advertiser when buying inventory within this specific genre. Reflects negotiated pricing that varies by advertiser-genre combination. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:GenreBuyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumSpendCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Spend Commitment' ;
    rdfs:comment 'The contractually committed minimum advertising spend amount for this advertiser within this genre over the contract period. Used for upfront deal tracking and revenue forecasting. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:GenreBuyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredGenreFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Genre Flag' ;
    rdfs:comment 'Indicates whether this genre has been designated as a preferred or priority genre for this advertiser, typically resulting in preferential ad placement, first-right-of-refusal on premium inventory, or priority scheduling. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:GenreBuyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityLegalAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Facility Legal Assignment Id' ;
    rdfs:comment 'Unique identifier for this facility-legal entity assignment record. Primary key.' ;
    rdfs:domain ind:FacilityLegalAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Percentage' ;
    rdfs:comment 'Percentage of facility operating costs allocated to this legal entity. Used for intercompany charging and cost center allocation. Sum of percentages across all legal entities for a facility should equal 100.00 for shared facilities.' ;
    rdfs:domain ind:FacilityLegalAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyChargeCode rdf:type rdf:Property ;
    rdfs:label 'Intercompany Charge Code' ;
    rdfs:comment 'Code used for intercompany billing and cost allocation transactions related to this facility assignment. Links to the chart of accounts for proper financial posting.' ;
    rdfs:domain ind:FacilityLegalAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseOrOwnFlag rdf:type rdf:Property ;
    rdfs:label 'Lease Or Own Flag' ;
    rdfs:comment 'Boolean indicator of whether the facility is leased (true) or owned (false) by this legal entity. Simplified binary view of ownership_type for financial reporting.' ;
    rdfs:domain ind:FacilityLegalAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryUserFlag rdf:type rdf:Property ;
    rdfs:label 'Primary User Flag' ;
    rdfs:comment 'Indicates whether this legal entity is the primary operational user of the facility. Used to designate the primary responsible entity for regulatory reporting and operational management when multiple entities share a facility.' ;
    rdfs:domain ind:FacilityLegalAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxReportingEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Entity Flag' ;
    rdfs:comment 'Indicates whether this legal entity is responsible for tax reporting obligations related to this facility (property tax, local business tax, etc.). Critical for multi-entity shared facilities.' ;
    rdfs:domain ind:FacilityLegalAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetLegalHoldId rdf:type rdf:Property ;
    rdfs:label 'Asset Legal Hold Id' ;
    rdfs:comment 'Unique identifier for this specific assignment of a legal hold to a media asset. Primary key.' ;
    rdfs:domain ind:AssetLegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:custodianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Custodian Employee Id' ;
    rdfs:comment 'Employee identifier of the custodian responsible for managing this specific asset under this specific legal hold. May differ from the overall legal hold custodian for specialized asset types.' ;
    rdfs:domain ind:AssetLegalHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:custodianAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Custodian Acknowledgment Date' ;
    rdfs:comment 'Date when the assigned custodian formally acknowledged responsibility for preserving this specific asset under this legal hold.' ;
    rdfs:domain ind:AssetLegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdApplicationNotes rdf:type rdf:Property ;
    rdfs:label 'Hold Application Notes' ;
    rdfs:comment 'Detailed notes regarding the application of this legal hold to this specific asset, including any special handling instructions, relevance to the case, or preservation requirements.' ;
    rdfs:domain ind:AssetLegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdAppliedDate rdf:type rdf:Property ;
    rdfs:label 'Hold Applied Date' ;
    rdfs:comment 'Date when this specific legal hold was applied to this specific media asset. Marks the beginning of preservation obligations for this asset under this hold.' ;
    rdfs:domain ind:AssetLegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mamLockApplied rdf:type rdf:Property ;
    rdfs:label 'Mam Lock Applied' ;
    rdfs:comment 'Indicates whether a system-level lock has been successfully applied in the Media Asset Management system to prevent automated retention actions on this specific asset.' ;
    rdfs:domain ind:AssetLegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseAuthorizationReference rdf:type rdf:Property ;
    rdfs:label 'Release Authorization Reference' ;
    rdfs:comment 'Reference number or document identifier for the formal authorization to release this specific asset from this legal hold. Required for audit trail and compliance verification.' ;
    rdfs:domain ind:AssetLegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageInclusionId rdf:type rdf:Property ;
    rdfs:label 'Package Inclusion Id' ;
    rdfs:comment 'Unique identifier for this package inclusion record. Primary key.' ;
    rdfs:domain ind:PackageInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inclusionDate rdf:type rdf:Property ;
    rdfs:label 'Inclusion Date' ;
    rdfs:comment 'The date when this title was added to the package. Used for tracking package evolution and audit purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inclusionStatus rdf:type rdf:Property ;
    rdfs:label 'Inclusion Status' ;
    rdfs:comment 'Current lifecycle status of this title within the package: active (currently included), pending (scheduled for inclusion), expired (inclusion window ended), removed (manually removed), suspended (temporarily unavailable).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseFeeAllocatedUsd rdf:type rdf:Property ;
    rdfs:label 'License Fee Allocated Usd' ;
    rdfs:comment 'The portion of the package license fee allocated to this specific title. Used for revenue allocation, royalty calculations, and content valuation within package deals.' ;
    rdfs:domain ind:PackageInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseOwnershipId rdf:type rdf:Property ;
    rdfs:label 'License Ownership Id' ;
    rdfs:comment 'Unique identifier for this ownership relationship record. Primary key for the license_ownership association.' ;
    rdfs:domain ind:LicenseOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionStatus rdf:type rdf:Property ;
    rdfs:label 'Attribution Status' ;
    rdfs:comment 'Regulatory classification indicating whether this ownership interest is attributable under FCC rules (typically interests above 5% for voting stock, 33% for limited partnerships, or any officer/director position). Values: Attributable, Non-Attributable, Pending Review, Exempt.' ;
    rdfs:domain ind:LicenseOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlRelationshipType rdf:type rdf:Property ;
    rdfs:label 'Control Relationship Type' ;
    rdfs:comment 'Nature of the control or ownership relationship between the partner and the licensed entity. Values: Equity Owner, Parent Company, Officer, Director, General Partner, Limited Partner, Creditor, Other.' ;
    rdfs:domain ind:LicenseOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Disclosure Required' ;
    rdfs:comment 'Indicates whether this ownership interest must be disclosed on FCC Form 323 or equivalent regulatory filings. True if the interest meets attribution thresholds or involves officers/directors.' ;
    rdfs:domain ind:LicenseOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingReference rdf:type rdf:Property ;
    rdfs:label 'Filing Reference' ;
    rdfs:comment 'Reference number or identifier for the regulatory filing (FCC Form 323, license transfer application, etc.) that documents this ownership relationship. Used for audit trail and compliance verification.' ;
    rdfs:domain ind:LicenseOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionTitle rdf:type rdf:Property ;
    rdfs:label 'Position Title' ;
    rdfs:comment 'Official title or position held by the partner representative in the licensed entity (e.g., CEO, Board Member, General Partner). Applicable when control_relationship_type is Officer, Director, or General Partner.' ;
    rdfs:domain ind:LicenseOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votingRightsPercentage rdf:type rdf:Property ;
    rdfs:label 'Voting Rights Percentage' ;
    rdfs:comment 'Percentage of voting rights held by the partner, which may differ from equity ownership percentage in cases of dual-class stock or special voting arrangements. Critical for FCC attribution analysis.' ;
    rdfs:domain ind:LicenseOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:episodeSponsorshipId rdf:type rdf:Property ;
    rdfs:label 'Episode Sponsorship Id' ;
    rdfs:comment 'Unique surrogate identifier for this episode-sponsorship placement record. Primary key.' ;
    rdfs:domain ind:EpisodeSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeProductionEpisodeId rdf:type rdf:Property ;
    rdfs:label 'Episode Production Episode Id' ;
    rdfs:comment 'Foreign key linking to the specific episode receiving sponsorship placement' ;
    rdfs:domain ind:EpisodeSponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionEpisode .

ind:actualImpressions rdf:type rdf:Property ;
    rdfs:label 'Actual Impressions' ;
    rdfs:comment 'Actual number of impressions delivered for this specific episode-sponsorship placement across all distribution platforms.' ;
    rdfs:domain ind:EpisodeSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billboardPlacementTimecode rdf:type rdf:Property ;
    rdfs:label 'Billboard Placement Timecode' ;
    rdfs:comment 'SMPTE timecode indicating the exact placement location of the sponsor billboard within the episode master (e.g., opening, closing, mid-roll). Identified in detection phase.' ;
    rdfs:domain ind:EpisodeSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoDisplayDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Logo Display Duration Seconds' ;
    rdfs:comment 'Duration in seconds that the sponsor logo is displayed during this episode placement. Used for fulfillment verification and sponsor reporting. Identified in detection phase.' ;
    rdfs:domain ind:EpisodeSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodReason rdf:type rdf:Property ;
    rdfs:label 'Makegood Reason' ;
    rdfs:comment 'Description of why a makegood is required for this placement (e.g., technical issue, audience under-delivery, incorrect placement).' ;
    rdfs:domain ind:EpisodeSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementType rdf:type rdf:Property ;
    rdfs:label 'Placement Type' ;
    rdfs:comment 'Classification of the specific type of sponsorship placement within this episode (opening, closing, mid-roll, integration, etc.). Derived from billboard_placement_timecode and deliverables.' ;
    rdfs:domain ind:EpisodeSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productIntegrationSceneNumbers rdf:type rdf:Property ;
    rdfs:label 'Product Integration Scene Numbers' ;
    rdfs:comment 'Comma-separated list of scene numbers where product integration occurs for this sponsor within this episode. Used for production coordination and fulfillment tracking. Identified in detection phase.' ;
    rdfs:domain ind:EpisodeSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectSponsorshipId rdf:type rdf:Property ;
    rdfs:label 'Project Sponsorship Id' ;
    rdfs:comment 'Unique surrogate identifier for the project sponsorship record. Primary key.' ;
    rdfs:domain ind:ProjectSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalRightsLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Rights Level' ;
    rdfs:comment 'Level of creative approval authority granted to the advertiser over content related to their sponsorship (e.g., none, consultation, approval required, creative control). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ProjectSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coProductionAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Co Production Agreement Reference' ;
    rdfs:comment 'External reference identifier or document number for the legal co-production or sponsorship agreement governing this partnership. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ProjectSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableRequirements rdf:type rdf:Property ;
    rdfs:label 'Deliverable Requirements' ;
    rdfs:comment 'Textual description of the specific deliverables the production team must provide to the advertiser (e.g., logo placement duration, product integration scenes, behind-the-scenes content, premiere tickets). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ProjectSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingAmount rdf:type rdf:Property ;
    rdfs:label 'Funding Amount' ;
    rdfs:comment 'Total monetary contribution committed by the advertiser to this production project, denominated in the currency specified in funding_currency_code. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ProjectSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Funding Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the funding amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ProjectSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingPercentage rdf:type rdf:Property ;
    rdfs:label 'Funding Percentage' ;
    rdfs:comment 'Percentage of the total production budget contributed by this advertiser, expressed as a decimal (e.g., 25.00 for 25%). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ProjectSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:logoPlacementSeconds rdf:type rdf:Property ;
    rdfs:label 'Logo Placement Seconds' ;
    rdfs:comment 'Total duration in seconds of advertiser logo or brand placement within the content, as contractually committed.' ;
    rdfs:domain ind:ProjectSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnershipEndDate rdf:type rdf:Property ;
    rdfs:label 'Partnership End Date' ;
    rdfs:comment 'Expiration or completion date of the sponsorship partnership agreement.' ;
    rdfs:domain ind:ProjectSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnershipStartDate rdf:type rdf:Property ;
    rdfs:label 'Partnership Start Date' ;
    rdfs:comment 'Effective start date of the sponsorship partnership agreement.' ;
    rdfs:domain ind:ProjectSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnershipStatus rdf:type rdf:Property ;
    rdfs:label 'Partnership Status' ;
    rdfs:comment 'Current lifecycle status of the sponsorship partnership (e.g., proposed, negotiating, active, fulfilled, terminated).' ;
    rdfs:domain ind:ProjectSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipType rdf:type rdf:Property ;
    rdfs:label 'Partnership Type' ;
    rdfs:comment 'Classification of the sponsorship arrangement indicating the level and nature of the advertiser\'s involvement (e.g., title sponsor, co-production partner, product placement, branded content integration). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ProjectSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityComplianceId rdf:type rdf:Property ;
    rdfs:label 'Facility Compliance Id' ;
    rdfs:comment 'Unique identifier for this facility-obligation compliance record. Primary key.' ;
    rdfs:domain ind:FacilityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstComplianceDate rdf:type rdf:Property ;
    rdfs:label 'First Compliance Date' ;
    rdfs:comment 'Date when this facility first achieved compliance with this obligation. Captures the historical start of the compliance relationship for audit trail and reporting purposes.' ;
    rdfs:domain ind:FacilityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Name of the individual or role responsible for ensuring compliance with this obligation at this specific facility. Responsibility is facility-specific - different facility managers or compliance officers may own the same obligation at different locations.' ;
    rdfs:domain ind:FacilityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityServiceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Facility Service Agreement Id' ;
    rdfs:comment 'Unique identifier for the facility service agreement record. Primary key for the association.' ;
    rdfs:domain ind:FacilityServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedCapacity rdf:type rdf:Property ;
    rdfs:label 'Contracted Capacity' ;
    rdfs:comment 'The amount or extent of facility capacity allocated to this sales account under the agreement. Format varies by service type: hours per month for studio rental, bandwidth allocation for transmission, rack units for colocation, percentage of facility for full lease. This defines the resource commitment.' ;
    rdfs:domain ind:FacilityServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardReference rdf:type rdf:Property ;
    rdfs:label 'Rate Card Reference' ;
    rdfs:comment 'Reference identifier to the pricing rate card or pricing schedule that governs billing for this service agreement. Links to the commercial pricing structure negotiated for this account-facility combination, which may differ from standard rates based on volume commitments or strategic relationship.' ;
    rdfs:domain ind:FacilityServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesCrewAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Series Crew Assignment Id' ;
    rdfs:comment 'Unique identifier for this series crew assignment record. Primary key for the association.' ;
    rdfs:domain ind:SeriesCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Episode Range End' ;
    rdfs:comment 'Ending episode number within the season scope for this crew assignment. Null if assignment covers entire season or is ongoing. Used for episodic directors, writers, and guest crew. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:SeriesCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Episode Range Start' ;
    rdfs:comment 'Starting episode number within the season scope for this crew assignment. Null if assignment covers entire season. Used for episodic directors, writers, and guest crew. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:SeriesCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonScope rdf:type rdf:Property ;
    rdfs:label 'Season Scope' ;
    rdfs:comment 'Identifies which season(s) this crew assignment applies to. May be \'all\', a specific season number, or a range (e.g., \'S1-S3\'). Critical for tracking crew continuity and contract scope. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:SeriesCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointAllocationId rdf:type rdf:Property ;
    rdfs:label 'Endpoint Allocation Id' ;
    rdfs:comment 'Primary key uniquely identifying each endpoint-partner allocation record' ;
    rdfs:domain ind:EndpointAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bandwidthAllocationGbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Allocation Gbps' ;
    rdfs:comment 'Dedicated bandwidth in gigabits per second allocated to this partner for this endpoint. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:EndpointAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endorsementDealId rdf:type rdf:Property ;
    rdfs:label 'Endorsement Deal Id' ;
    rdfs:comment 'Unique identifier for this endorsement deal record. Primary key for the association.' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deal Created Timestamp' ;
    rdfs:comment 'The date and time when this endorsement deal record was first created in the system. Used for audit and deal pipeline tracking.' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dealCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Deal Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the deal value is denominated (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealLastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deal Last Modified Timestamp' ;
    rdfs:comment 'The date and time when this endorsement deal record was last updated. Used for audit and change tracking.' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exclusivityPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Period End' ;
    rdfs:comment 'The end date of the exclusivity period. After this date, the talent may be free to endorse competitors even if the contract is still active.' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Period Start' ;
    rdfs:comment 'The start date of any exclusivity period during which the talent cannot endorse competing brands in the same category. May differ from contract start date.' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moralsClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Morals Clause Flag' ;
    rdfs:comment 'Indicates whether the deal includes a morals clause allowing the advertiser to terminate if the talent engages in conduct that damages their brand reputation.' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceDeliverables rdf:type rdf:Property ;
    rdfs:label 'Performance Deliverables' ;
    rdfs:comment 'Description of the specific deliverables the talent must provide (e.g., \'2 TV commercials, 4 social media posts per month, 1 live event appearance\'). Defines the scope of work for this deal.' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Deadline Date' ;
    rdfs:comment 'The deadline by which the advertiser must exercise their renewal option, if applicable. After this date, the talent is free to negotiate with other advertisers.' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageMediaTypes rdf:type rdf:Property ;
    rdfs:label 'Usage Media Types' ;
    rdfs:comment 'The media channels where the advertiser is permitted to use the talent\'s endorsement (e.g., \'TV, Digital, Print\', \'Social Media Only\', \'All Media\'). Defines the scope of usage rights.' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageTerritory rdf:type rdf:Property ;
    rdfs:label 'Usage Territory' ;
    rdfs:comment 'The geographic territory or market where the advertiser has rights to use the talent\'s likeness and endorsement (e.g., \'North America\', \'Global\', \'EU + UK\'). This is deal-specific and varies by advertiser.' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityAccessId rdf:type rdf:Property ;
    rdfs:label 'Facility Access Id' ;
    rdfs:comment 'Unique identifier for this facility access authorization record. Primary key.' ;
    rdfs:domain ind:FacilityAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Authorized By Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee who authorized this facility access. Used for accountability and audit trail purposes.' ;
    rdfs:domain ind:FacilityAccess ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessStatus rdf:type rdf:Property ;
    rdfs:label 'Access Status' ;
    rdfs:comment 'Current lifecycle status of this facility access authorization. Determines whether the access is currently valid and usable. Values: active, inactive, suspended, revoked.' ;
    rdfs:domain ind:FacilityAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'Date when this facility access authorization was granted.' ;
    rdfs:domain ind:FacilityAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'Date when the most recent background check was completed for this talent at this facility. Required for certain facility types with high security classification.' ;
    rdfs:domain ind:FacilityAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:badgeIssueDate rdf:type rdf:Property ;
    rdfs:label 'Badge Issue Date' ;
    rdfs:comment 'Date when the access badge was issued to the talent for this facility.' ;
    rdfs:domain ind:FacilityAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:badgeNumber rdf:type rdf:Property ;
    rdfs:label 'Badge Number' ;
    rdfs:comment 'Unique physical or digital badge identifier issued to the talent for access to this specific facility. Used by access control systems to grant entry and track movement within the facility.' ;
    rdfs:domain ind:FacilityAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escortRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escort Required Flag' ;
    rdfs:comment 'Indicates whether the talent must be accompanied by an authorized escort when accessing this facility. Used for visitors, contractors, or talent with limited clearance levels.' ;
    rdfs:domain ind:FacilityAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Verified Flag' ;
    rdfs:comment 'Indicates whether production insurance coverage has been verified for this talent at this facility. Required before granting access for production work.' ;
    rdfs:domain ind:FacilityAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelLicenseId rdf:type rdf:Property ;
    rdfs:label 'Channel License Id' ;
    rdfs:comment 'Unique surrogate identifier for each channel license record. Primary key for the association.' ;
    rdfs:domain ind:ChannelLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseFeeUsd rdf:type rdf:Property ;
    rdfs:label 'License Fee Usd' ;
    rdfs:comment 'The total licensing fee paid by the channel to acquire broadcast rights for this title, denominated in US dollars. Used for rights cost allocation and profitability analysis.' ;
    rdfs:domain ind:ChannelLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionPackageId rdf:type rdf:Property ;
    rdfs:label 'Distribution Package Id' ;
    rdfs:comment 'Unique identifier for each title-partner distribution package record. Primary key for the association.' ;
    rdfs:domain ind:DistributionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusionDate rdf:type rdf:Property ;
    rdfs:label 'Exclusion Date' ;
    rdfs:comment 'Date when this title was removed from the distribution package for this partner. Null indicates the title is currently active in the package. Used for windowing strategy and rights expiration tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:courseRequirementId rdf:type rdf:Property ;
    rdfs:label 'Course Requirement Id' ;
    rdfs:comment 'Unique identifier for this course requirement record. Primary key.' ;
    rdfs:domain ind:CourseRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableJobProfiles rdf:type rdf:Property ;
    rdfs:label 'Applicable Job Profiles' ;
    rdfs:comment 'Comma-separated list of job roles, job families, or organizational units for which this training course is applicable or required (e.g., Broadcast Engineers, Content Producers, Ad Sales Representatives, All Employees). Used to auto-assign training to employees based on their job profile. [Moved from training_course: This denormalized STRING field in training_course contains a comma-separated list of job profiles for which the course is applicable. This is the exact relationship data that should be normalized into the course_requirement association, where each job profile becomes a separate record with its own requirement attributes (is_mandatory, completion_deadline_days, etc.). The denormalized field proves the business operates this way but lacks proper normalization.]' ;
    rdfs:domain ind:CourseRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Completion Deadline Days' ;
    rdfs:comment 'Number of days from hire date or role assignment by which the employee must complete this training course. Used for onboarding and compliance tracking.' ;
    rdfs:domain ind:CourseRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionOrderSequence rdf:type rdf:Property ;
    rdfs:label 'Completion Order Sequence' ;
    rdfs:comment 'Recommended or required sequence order for completing this course relative to other courses for this job profile. Supports learning path design where prerequisite courses must be completed before advanced courses.' ;
    rdfs:domain ind:CourseRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requirementRationale rdf:type rdf:Property ;
    rdfs:label 'Requirement Rationale' ;
    rdfs:comment 'Business justification for why this course is required for this job profile. Examples: regulatory compliance (FCC, EEO), operational safety, technical competency, leadership development.' ;
    rdfs:domain ind:CourseRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Allowed Flag' ;
    rdfs:comment 'Indicates whether this requirement can be waived for employees in this job profile based on prior experience or equivalent credentials.' ;
    rdfs:domain ind:CourseRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealComplianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Deal Compliance Obligation Id' ;
    rdfs:comment 'Unique identifier for this deal-specific compliance obligation record. Primary key.' ;
    rdfs:domain ind:DealComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Required' ;
    rdfs:comment 'Indicates whether formal certification or attestation is required for this deal-obligation combination' ;
    rdfs:domain ind:DealComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Verification Date' ;
    rdfs:comment 'Date when compliance with this specific obligation was verified for this acquisition deal' ;
    rdfs:domain ind:DealComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationTriggeredDate rdf:type rdf:Property ;
    rdfs:label 'Obligation Triggered Date' ;
    rdfs:comment 'Date when this regulatory obligation was triggered or became applicable to this acquisition deal, typically aligned with deal execution or content delivery' ;
    rdfs:domain ind:DealComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Name or identifier of the individual or team responsible for ensuring compliance with this obligation for this specific deal' ;
    rdfs:domain ind:DealComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationInventoryId rdf:type rdf:Property ;
    rdfs:label 'Syndication Inventory Id' ;
    rdfs:comment 'Unique identifier for this syndication inventory record. Primary key.' ;
    rdfs:domain ind:SyndicationInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualClearancePercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Clearance Percentage' ;
    rdfs:comment 'Actual percentage of target market coverage achieved for this collection within this syndication deal. Compared against the deal-level clearance_percentage_target to determine if the collection meets clearance requirements.' ;
    rdfs:domain ind:SyndicationInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:barterInventoryAllocation rdf:type rdf:Property ;
    rdfs:label 'Barter Inventory Allocation' ;
    rdfs:comment 'Specific allocation of advertising inventory slots for this collection within this barter or cash-plus-barter syndication deal. Details which ad breaks are retained by syndicator vs. sold by stations for this specific content package.' ;
    rdfs:domain ind:SyndicationInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeSequence rdf:type rdf:Property ;
    rdfs:label 'Episode Sequence' ;
    rdfs:comment 'Sequential order in which episodes from this collection should be delivered or aired within this specific syndication deal. Controls the strip schedule for the station group.' ;
    rdfs:domain ind:SyndicationInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formatSpecification rdf:type rdf:Property ;
    rdfs:label 'Format Specification' ;
    rdfs:comment 'Technical format requirements for delivery of this collection under this syndication deal (e.g., HD 1080i, 4K, specific codec, closed captioning requirements). Format specs are deal-specific as different station groups may have different technical requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentRegulatoryComplianceId rdf:type rdf:Property ;
    rdfs:label 'Segment Regulatory Compliance Id' ;
    rdfs:comment 'Unique surrogate identifier for this segment-obligation compliance record. Primary key.' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Id' ;
    rdfs:comment 'Foreign key to audience_segment. Part of the natural key.' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:auditFindings rdf:type rdf:Property ;
    rdfs:label 'Audit Findings' ;
    rdfs:comment 'Summary of findings from the most recent compliance audit. Documents any violations, concerns, or confirmations of compliance. Used for audit trail and remediation tracking.' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOutHonored rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Honored' ;
    rdfs:comment 'Indicates whether California Consumer Privacy Act (CCPA) opt-out signals are honored when activating this segment for California residents. When True, individuals who have exercised their CCPA right to opt out of sale/sharing of personal information are excluded from segment activation. Required for compliance with CCPA and its amendment CPRA. [Moved from audience_segment: CCPA opt-out handling is a compliance attribute specific to the CCPA regulatory obligation. This should be tracked in the segment-obligation compliance relationship where it can be audited, dated, and linked to the specific CCPA obligation record. The segment itself shouldn\'t carry obligation-specific compliance flags.]' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Exemption Expiration Date' ;
    rdfs:comment 'Date when any granted exemption expires and full compliance is required. Null if no exemption or if exemption is permanent.' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprLawfulBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Lawful Basis' ;
    rdfs:comment 'The GDPR (General Data Protection Regulation) Article 6 lawful basis under which audience data is processed to build and activate this segment for EU audiences. \'consent\' requires explicit opt-in; \'legitimate_interest\' requires a balancing test; \'contract\' applies to subscriber-based segments; \'not_applicable\' for non-EU segments. Required for regulatory compliance reporting. [Moved from audience_segment: GDPR lawful basis is specific to the GDPR regulatory obligation and represents compliance metadata that belongs in the segment-obligation relationship. Different segments may have different lawful bases under GDPR, and this should be tracked as part of the compliance record with audit dates and status, not as a standalone attribute on the segment.]' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCoppaRestricted rdf:type rdf:Property ;
    rdfs:label 'Is Coppa Restricted' ;
    rdfs:comment 'Indicates whether this segment is subject to COPPA (Children\'s Online Privacy Protection Act) restrictions, meaning it includes or may include children under 13. COPPA-restricted segments are prohibited from behavioral targeting and require parental consent mechanisms. Critical compliance flag for ad sales and digital activation workflows. [Moved from audience_segment: This boolean flag indicates COPPA applicability but doesn\'t capture the compliance relationship details. The segment_regulatory_compliance association should track the actual COPPA obligation (via regulatory_obligation_id) with full audit history, compliance status, and exemption basis. The flag in audience_segment can remain as a derived/cached indicator for quick filtering, but the authoritative compliance relationship lives in the association.]' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next compliance audit of this segment under this obligation. Calculated based on obligation compliance_frequency and risk_level.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Deadline by which remediation actions must be completed to avoid penalties or enforcement action. Null if no remediation required.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleComplianceOfficer rdf:type rdf:Property ;
    rdfs:label 'Responsible Compliance Officer' ;
    rdfs:comment 'Name or employee ID of the compliance officer accountable for managing this segment-obligation compliance relationship.' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignFundingId rdf:type rdf:Property ;
    rdfs:label 'Campaign Funding Id' ;
    rdfs:comment 'Unique identifier for this campaign funding allocation record. Primary key.' ;
    rdfs:domain ind:CampaignFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationAmount rdf:type rdf:Property ;
    rdfs:label 'Allocation Amount' ;
    rdfs:comment 'The dollar amount from this opportunity allocated to fund this specific campaign. Sum of all allocation_amounts for an opportunity should not exceed the opportunity\'s estimated_value.' ;
    rdfs:domain ind:CampaignFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignFundingStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Funding Status' ;
    rdfs:comment 'Current status of this funding allocation. Proposed = opportunity not yet closed, Committed = opportunity closed-won and funding committed, Active = campaign is running with this funding, Completed = flight dates passed, Cancelled = allocation removed.' ;
    rdfs:domain ind:CampaignFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Project Assignment Id' ;
    rdfs:comment 'Unique identifier for the project assignment record. Primary key.' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Project Manager Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:billableFlag rdf:type rdf:Property ;
    rdfs:label 'Billable Flag' ;
    rdfs:comment 'Indicates whether the employee\'s time on this project is billable to the project budget or capitalized as part of project costs. Used for cost accounting and capitalization calculations. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:role rdf:type rdf:Property ;
    rdfs:label 'Role' ;
    rdfs:comment 'The specific role or function the employee performs on this capital project. Examples include Project Manager, Technical Lead, Finance Controller, Procurement Specialist. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelAssetPlayoutId rdf:type rdf:Property ;
    rdfs:label 'Channel Asset Playout Id' ;
    rdfs:comment 'Unique identifier for this channel-asset playout configuration record. Primary key.' ;
    rdfs:domain ind:ChannelAssetPlayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeFromDate rdf:type rdf:Property ;
    rdfs:label 'Active From Date' ;
    rdfs:comment 'Date when this asset becomes available for playout on this channel. Supports embargo management and scheduled content releases.' ;
    rdfs:domain ind:ChannelAssetPlayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeToDate rdf:type rdf:Property ;
    rdfs:label 'Active To Date' ;
    rdfs:comment 'Date when this asset is no longer available for playout on this channel. Supports license expiration, seasonal content rotation, and rights window management.' ;
    rdfs:domain ind:ChannelAssetPlayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airCount rdf:type rdf:Property ;
    rdfs:label 'Air Count' ;
    rdfs:comment 'Total number of times this asset has been broadcast on this channel. Used for rights management (license play limits), rotation analytics, and content performance tracking.' ;
    rdfs:domain ind:ChannelAssetPlayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backupAssetFlag rdf:type rdf:Property ;
    rdfs:label 'Backup Asset Flag' ;
    rdfs:comment 'Indicates whether this asset serves as a backup/filler for this channel. Backup assets are used when primary scheduled content is unavailable or to fill unscheduled time slots.' ;
    rdfs:domain ind:ChannelAssetPlayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelSpecificVersion rdf:type rdf:Property ;
    rdfs:label 'Channel Specific Version' ;
    rdfs:comment 'Version identifier for channel-specific edits or adaptations of the media asset (e.g., regional edit, censored version, time-compressed version). Same base asset may have different versions per channel based on content rating, market, or time slot requirements.' ;
    rdfs:domain ind:ChannelAssetPlayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAiredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Aired Timestamp' ;
    rdfs:comment 'Timestamp of the most recent playout of this asset on this channel. Used for rotation management to ensure content freshness and avoid excessive repetition.' ;
    rdfs:domain ind:ChannelAssetPlayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxPlaysPerDay rdf:type rdf:Property ;
    rdfs:label 'Max Plays Per Day' ;
    rdfs:comment 'Maximum number of times this asset may be broadcast on this channel within a 24-hour period. Used to prevent over-rotation and maintain content variety.' ;
    rdfs:domain ind:ChannelAssetPlayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minHoursBetweenPlays rdf:type rdf:Property ;
    rdfs:label 'Min Hours Between Plays' ;
    rdfs:comment 'Minimum number of hours that must elapse between consecutive airings of this asset on this channel. Prevents back-to-back repetition.' ;
    rdfs:domain ind:ChannelAssetPlayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playoutPriority rdf:type rdf:Property ;
    rdfs:label 'Playout Priority' ;
    rdfs:comment 'Channel-specific priority ranking for this asset in automated playout rotation. Lower numbers indicate higher priority. Used by Ericsson MediaFirst to select assets when multiple options are available.' ;
    rdfs:domain ind:ChannelAssetPlayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelAbrAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Channel Abr Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each channel-to-ABR-profile assignment record. Primary key.' ;
    rdfs:domain ind:ChannelAbrAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Free-text explanation of why this ABR profile was assigned to this channel (e.g., \'Upgraded to 4K for premium sports content\', \'Cost optimization - reduced bitrate ladder\', \'New HDR support for flagship channel\').' ;
    rdfs:domain ind:ChannelAbrAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceClassOverride rdf:type rdf:Property ;
    rdfs:label 'Device Class Override' ;
    rdfs:comment 'Optional device class override that restricts this ABR profile assignment to specific device types, overriding the profile\'s default target_device_class. Used when a channel requires different encoding strategies per device class (e.g., mobile-optimized profile for cellular delivery, 4K profile for smart TVs).' ;
    rdfs:domain ind:ChannelAbrAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encodingCostEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Encoding Cost Estimate Usd' ;
    rdfs:comment 'Estimated monthly encoding cost in USD for this channel-profile assignment, calculated based on channel broadcast hours, ABR profile complexity (rendition count, codec), and encoding farm pricing. Used for cost optimization and budget planning.' ;
    rdfs:domain ind:ChannelAbrAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelTargetingId rdf:type rdf:Property ;
    rdfs:label 'Channel Targeting Id' ;
    rdfs:comment 'Unique surrogate identifier for each channel-demographic targeting record. Primary key.' ;
    rdfs:domain ind:ChannelTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daypartStrategy rdf:type rdf:Property ;
    rdfs:label 'Daypart Strategy' ;
    rdfs:comment 'Comma-separated list of dayparts where this channel actively targets this demographic segment (e.g., Prime Time, Late Fringe, Early Morning). Drives programming and ad inventory allocation decisions.' ;
    rdfs:domain ind:ChannelTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryTarget rdf:type rdf:Property ;
    rdfs:label 'Is Primary Target' ;
    rdfs:comment 'Indicates whether this demographic segment is designated as a primary target demographic for this channel (vs. secondary or tertiary). Primary targets drive programming decisions and receive highest sales priority.' ;
    rdfs:domain ind:ChannelTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetRating rdf:type rdf:Property ;
    rdfs:label 'Target Rating' ;
    rdfs:comment 'The target rating point (percentage of demographic universe) that this channel aims to achieve for this specific demographic segment. Used in upfront guarantees and programming performance evaluation.' ;
    rdfs:domain ind:ChannelTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetingStatus rdf:type rdf:Property ;
    rdfs:label 'Targeting Status' ;
    rdfs:comment 'Current lifecycle status of this channel-demographic targeting relationship. Active indicates current targeting, Planned for future seasons, Suspended for temporary holds, Discontinued for ended strategies.' ;
    rdfs:domain ind:ChannelTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationGlMappingId rdf:type rdf:Property ;
    rdfs:label 'Obligation Gl Mapping Id' ;
    rdfs:comment 'Unique identifier for this obligation-to-GL-account mapping record. Primary key.' ;
    rdfs:domain ind:ObligationGlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualRequired rdf:type rdf:Property ;
    rdfs:label 'Accrual Required' ;
    rdfs:comment 'Indicates whether costs for this obligation must be accrued in this GL account prior to cash payment. True for obligations with annual fees that must be accrued monthly, regulatory penalties under dispute, or multi-year license fees. Corresponds to accrual_required_flag from detection data.' ;
    rdfs:domain ind:ObligationGlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costAllocationRule rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Rule' ;
    rdfs:comment 'Business rule describing how costs for this obligation should be allocated to this GL account. May reference allocation keys, cost centers, profit centers, or percentage splits (e.g., \'Allocate 60% to linear TV cost center, 40% to OTT\', \'Direct charge to broadcast operations functional area\'). Corresponds to cost_allocation_rule from detection data.' ;
    rdfs:domain ind:ObligationGlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Amount' ;
    rdfs:comment 'Estimated annual financial impact of this obligation in this GL account, in the account\'s currency. Used for budgeting, forecasting, and materiality assessments. May be null for event-driven obligations with unpredictable costs.' ;
    rdfs:domain ind:ObligationGlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mappingStatus rdf:type rdf:Property ;
    rdfs:label 'Mapping Status' ;
    rdfs:comment 'Current status of this mapping: active (currently in use for financial postings), inactive (no longer used but retained for historical reference), pending_approval (proposed mapping awaiting finance/compliance approval), superseded (replaced by a newer mapping).' ;
    rdfs:domain ind:ObligationGlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingType rdf:type rdf:Property ;
    rdfs:label 'Mapping Type' ;
    rdfs:comment 'Classification of how this obligation maps to this GL account: license_fee (broadcast spectrum fees), compliance_expense (ongoing compliance costs), capital_expenditure (EAS equipment, closed captioning infrastructure), prepaid_regulatory (prepaid license fees), accrued_penalty (potential fines), legal_reserve (litigation reserves), equipment_maintenance (regulatory equipment upkeep), consulting_fee (compliance consultants), audit_cost (regulatory audits), other. Corresponds to obligation_gl_mapping_type from detection data.' ;
    rdfs:domain ind:ObligationGlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingLineItem rdf:type rdf:Property ;
    rdfs:label 'Reporting Line Item' ;
    rdfs:comment 'The financial statement line item or regulatory report line where this obligation-account combination should be reported. Used for external regulatory financial reporting (e.g., FCC Form 323, Ofcom Annual Return) and internal management reporting. Corresponds to reporting_line_item from detection data.' ;
    rdfs:domain ind:ObligationGlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeTransmissionId rdf:type rdf:Property ;
    rdfs:label 'Episode Transmission Id' ;
    rdfs:comment 'Unique identifier for this specific transmission event. Primary key for the episode_transmission association.' ;
    rdfs:domain ind:EpisodeTransmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signalStrengthDbm rdf:type rdf:Property ;
    rdfs:label 'Signal Strength Dbm' ;
    rdfs:comment 'Measured signal strength in dBm for this transmission event. Technical performance metric used for coverage analysis and equipment health monitoring.' ;
    rdfs:domain ind:EpisodeTransmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalIssuesFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Issues Flag' ;
    rdfs:comment 'Flag indicating whether technical issues occurred during this transmission event (signal loss, quality degradation, interruption). Triggers incident investigation and maintenance review.' ;
    rdfs:domain ind:EpisodeTransmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transmissionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Transmission Duration Seconds' ;
    rdfs:comment 'Actual duration of this transmission event in seconds. May differ from episode runtime due to technical issues or scheduling adjustments. Used for as-run log reconciliation.' ;
    rdfs:domain ind:EpisodeTransmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionQuality rdf:type rdf:Property ;
    rdfs:label 'Transmission Quality' ;
    rdfs:comment 'Quality assessment of this specific transmission event based on signal strength, error rates, and technical monitoring. Used for performance analysis and maintenance planning.' ;
    rdfs:domain ind:EpisodeTransmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewerCount rdf:type rdf:Property ;
    rdfs:label 'Viewer Count' ;
    rdfs:comment 'Estimated or measured viewer count for this specific transmission event. Used for audience measurement, advertising rate justification, and content performance analysis.' ;
    rdfs:domain ind:EpisodeTransmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCenterObligationAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Obligation Allocation Id' ;
    rdfs:comment 'Unique identifier for this cost center obligation allocation record. Primary key.' ;
    rdfs:domain ind:CostCenterObligationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Effective Date' ;
    rdfs:comment 'The date from which this cost center obligation allocation becomes effective and active.' ;
    rdfs:domain ind:CostCenterObligationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Compliance Budget Amount' ;
    rdfs:comment 'The budget amount allocated by this cost center specifically for compliance activities related to this regulatory obligation. Denominated in the cost center\'s currency.' ;
    rdfs:domain ind:CostCenterObligationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obligationAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Obligation Allocation Percentage' ;
    rdfs:comment 'The percentage of responsibility for this regulatory obligation allocated to this specific cost center. Used for budget allocation and accountability tracking. Sum of all allocations for a given obligation should equal 100%.' ;
    rdfs:domain ind:CostCenterObligationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Authorization Id' ;
    rdfs:comment 'Unique identifier for this cost center authorization record. Primary key.' ;
    rdfs:domain ind:CostCenterAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grantedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Granted By Employee Id' ;
    rdfs:comment 'Reference to the employee who granted or approved this authorization. Used for audit trail and authorization chain of custody.' ;
    rdfs:domain ind:CostCenterAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:revokedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Revoked By Employee Id' ;
    rdfs:comment 'Reference to the employee who revoked this authorization. Null if authorization has not been revoked.' ;
    rdfs:domain ind:CostCenterAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Limit Amount' ;
    rdfs:comment 'The maximum monetary amount this employee is authorized to approve for transactions against this cost center. Null indicates unlimited approval authority or non-monetary authorization.' ;
    rdfs:domain ind:CostCenterAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Authorization Level' ;
    rdfs:comment 'The hierarchical authorization level granted to this employee for this cost center. Higher levels typically correspond to higher approval limits and broader authority.' ;
    rdfs:domain ind:CostCenterAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current lifecycle status of this authorization indicating whether it is currently in force, suspended temporarily, permanently revoked, or pending activation.' ;
    rdfs:domain ind:CostCenterAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revokedDate rdf:type rdf:Property ;
    rdfs:label 'Revoked Date' ;
    rdfs:comment 'The date on which this authorization was revoked. Null if authorization has not been revoked.' ;
    rdfs:domain ind:CostCenterAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityCostAllocationId rdf:type rdf:Property ;
    rdfs:label 'Facility Cost Allocation Id' ;
    rdfs:comment 'Unique identifier for this cost allocation relationship. Primary key.' ;
    rdfs:domain ind:FacilityCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Allocated Amount' ;
    rdfs:comment 'The calculated monthly cost amount allocated to this cost center from this facility, derived from allocation_percentage applied to facility operating costs. Used for budget tracking and variance analysis.' ;
    rdfs:domain ind:FacilityCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageMetricType rdf:type rdf:Property ;
    rdfs:label 'Usage Metric Type' ;
    rdfs:comment 'The type of metric used to measure and justify the cost allocation: square_footage (floor space occupied), equipment_count (number of devices/racks), booking_hours (studio/control room reservation time), headcount (staff assigned to facility), bandwidth_gbps (network capacity consumed), power_kva (electrical load).' ;
    rdfs:domain ind:FacilityCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageMetricValue rdf:type rdf:Property ;
    rdfs:label 'Usage Metric Value' ;
    rdfs:comment 'The quantitative value of the usage metric for this allocation relationship. Interpretation depends on usage_metric_type (e.g., 2500.00 square feet, 150.00 booking hours per month, 45.00 equipment units).' ;
    rdfs:domain ind:FacilityCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daypartAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Daypart Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for this daypart assignment record. Primary key.' ;
    rdfs:domain ind:DaypartAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDaypartFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Daypart Flag' ;
    rdfs:comment 'Indicates whether this is the employees primary daypart assignment (true) or a secondary/backup assignment (false). Used for scheduling priority and resource allocation. This attribute was explicitly identified in the detection phase relationship data.' ;
    rdfs:domain ind:DaypartAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shiftRole rdf:type rdf:Property ;
    rdfs:label 'Shift Role' ;
    rdfs:comment 'The operational role the employee performs during this daypart assignment. Examples: producer, director, technical_director, master_control_operator, traffic_coordinator. This attribute was explicitly identified in the detection phase relationship data.' ;
    rdfs:domain ind:DaypartAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutId rdf:type rdf:Property ;
    rdfs:label 'Playout Id' ;
    rdfs:comment 'Unique identifier for this playout event record. Primary key.' ;
    rdfs:domain ind:Playout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelComplianceId rdf:type rdf:Property ;
    rdfs:label 'Channel Compliance Id' ;
    rdfs:comment 'Unique identifier for this channel-obligation compliance record. Primary key.' ;
    rdfs:domain ind:ChannelCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextFilingDate rdf:type rdf:Property ;
    rdfs:label 'Next Filing Date' ;
    rdfs:comment 'Scheduled date for the next compliance filing or submission for this channel-obligation combination. Channel-specific deadline that may differ from the general obligation deadline based on channel launch date or exemption status.' ;
    rdfs:domain ind:ChannelCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleContact rdf:type rdf:Property ;
    rdfs:label 'Responsible Contact' ;
    rdfs:comment 'Name or identifier of the individual responsible for ensuring this channel\'s compliance with this specific obligation. May be a channel manager, compliance officer, or legal counsel.' ;
    rdfs:domain ind:ChannelCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalId rdf:type rdf:Property ;
    rdfs:label 'Proposal Id' ;
    rdfs:comment 'Primary key for proposal' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentTemplateId rdf:type rdf:Property ;
    rdfs:label 'Parent Template Id' ;
    rdfs:comment 'Reference to the previous version of this template, enabling version history tracking. Null for initial versions.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommunicationTemplate .

ind:attachmentFileNamePattern rdf:type rdf:Property ;
    rdfs:label 'Attachment File Name Pattern' ;
    rdfs:comment 'Pattern or template for generating attachment file names. May contain merge field placeholders.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Attachment Required Flag' ;
    rdfs:comment 'Indicates whether this template requires an attachment (such as an invoice PDF or payment receipt) to be included when sent.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bccRecipients rdf:type rdf:Property ;
    rdfs:label 'Bcc Recipients' ;
    rdfs:comment 'Comma-separated list of email addresses to be blind copied on communications generated from this template.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyContent rdf:type rdf:Property ;
    rdfs:label 'Body Content' ;
    rdfs:comment 'Main content body of the communication template. May contain HTML markup and merge field placeholders for dynamic data insertion.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccRecipients rdf:type rdf:Property ;
    rdfs:label 'Cc Recipients' ;
    rdfs:comment 'Comma-separated list of email addresses to be copied on communications generated from this template.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Used Timestamp' ;
    rdfs:comment 'Date and time when this template was most recently used to generate a communication.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mergeFields rdf:type rdf:Property ;
    rdfs:label 'Merge Fields' ;
    rdfs:comment 'Comma-separated list of merge field placeholders available in this template for dynamic data insertion (e.g., customer_name, invoice_number, amount_due).' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Allowed Flag' ;
    rdfs:comment 'Indicates whether recipients can opt out of receiving communications generated from this template.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replyToEmail rdf:type rdf:Property ;
    rdfs:label 'Reply To Email' ;
    rdfs:comment 'Email address to which recipient replies are directed.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'Number of days that communications generated from this template must be retained for compliance and audit purposes.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:senderEmail rdf:type rdf:Property ;
    rdfs:label 'Sender Email' ;
    rdfs:comment 'Email address used as the sender for email communications generated from this template.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderName rdf:type rdf:Property ;
    rdfs:label 'Sender Name' ;
    rdfs:comment 'Display name of the sender shown to recipients in the communication.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current lifecycle status of the communication template indicating whether it is available for use.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectLine rdf:type rdf:Property ;
    rdfs:label 'Subject Line' ;
    rdfs:comment 'Subject line or title used for email and portal communications. May contain merge field placeholders.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Unique business identifier code for the template used in system integrations and references.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the communication template.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateType rdf:type rdf:Property ;
    rdfs:label 'Template Type' ;
    rdfs:comment 'Classification of the communication template by its business purpose within billing operations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEvent rdf:type rdf:Property ;
    rdfs:label 'Trigger Event' ;
    rdfs:comment 'Business event or condition that triggers the use of this communication template (e.g., invoice_generated, payment_overdue, dispute_opened).' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Total number of times this template has been used to generate communications.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingSystem rdf:type rdf:Property ;
    rdfs:label 'Billing System' ;
    rdfs:comment 'Source billing system that processes transactions for this product: Zuora (subscription billing), Wide Orbit (advertising billing), SAP S/4HANA (financial posting), legacy (older systems), or manual (manually invoiced).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed business description of the product, including features, benefits, and target audience. Used in marketing materials and billing communications.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBundled rdf:type rdf:Property ;
    rdfs:label 'Is Bundled' ;
    rdfs:comment 'Indicates whether the product is sold as part of a bundle or package. True if bundled, False if sold standalone.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPromotional rdf:type rdf:Property ;
    rdfs:label 'Is Promotional' ;
    rdfs:comment 'Indicates whether the product is offered as a promotional or limited-time offer. True if promotional, False if standard offering.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether the product is subject to sales tax, VAT, or other consumption taxes. True if taxable, False if tax-exempt.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPriceChangeDate rdf:type rdf:Property ;
    rdfs:label 'Last Price Change Date' ;
    rdfs:comment 'Date when the base price was last modified. Used for pricing history tracking and customer communication.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumCommitmentPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Period Months' ;
    rdfs:comment 'Minimum contract commitment period in months required for the product. Null if no minimum commitment.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pciDssScope rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Scope' ;
    rdfs:comment 'Indicates whether the product involves payment card processing and falls under PCI DSS compliance scope. True if in scope, False if out of scope.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformAvailability rdf:type rdf:Property ;
    rdfs:label 'Platform Availability' ;
    rdfs:comment 'Comma-separated list of platforms where the product is available (e.g., iOS, Android, Web, Roku, Apple TV, Fire TV, Smart TV). Used for distribution planning and customer support.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Externally-known unique business identifier for the product, used across billing systems and customer communications.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable name of the product as displayed to customers and used in billing statements.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productOwner rdf:type rdf:Property ;
    rdfs:label 'Product Owner' ;
    rdfs:comment 'Name or identifier of the business unit or individual responsible for managing the product lifecycle, pricing, and strategy.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Classification of the product by revenue model: subscription (recurring subscriber fees), advertising (ad inventory sales), carriage fee (distribution fees from cable/satellite operators), syndication (content licensing), pay-per-view (one-time event purchases), or transactional (on-demand rentals/purchases).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Profit center to which product revenue and costs are allocated for P&L reporting and business unit performance measurement.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresContract rdf:type rdf:Property ;
    rdfs:label 'Requires Contract' ;
    rdfs:comment 'Indicates whether the product requires a formal contract or subscription agreement. True if contract required, False if available without contract.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetMarketSegment rdf:type rdf:Property ;
    rdfs:label 'Target Market Segment' ;
    rdfs:comment 'Primary market segment the product is designed for: consumer (individual subscribers), business (small/medium business), enterprise (large corporations), government (public sector), education (schools/universities), or nonprofit (charitable organizations).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Trial Period Days' ;
    rdfs:comment 'Number of days for free trial period offered for the product. Null if no trial period available.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessibilityStandard rdf:type rdf:Property ;
    rdfs:label 'Accessibility Standard' ;
    rdfs:comment 'Accessibility standard or guideline under audit (e.g., WCAG 2.1, Section 508, CVAA closed captioning).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'Scheduled recurrence pattern for this audit type.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditMethodology rdf:type rdf:Property ;
    rdfs:label 'Audit Methodology' ;
    rdfs:comment 'Primary methodology or approach used to conduct the audit.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Externally-known unique business identifier for the audit, used in regulatory filings and correspondence.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditOpinion rdf:type rdf:Property ;
    rdfs:label 'Audit Opinion' ;
    rdfs:comment 'Formal auditor opinion or conclusion issued for financial or SOX audits.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTitle rdf:type rdf:Property ;
    rdfs:label 'Audit Title' ;
    rdfs:comment 'Human-readable title or name of the audit engagement.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditor Organization' ;
    rdfs:comment 'Classification of the auditing organization (internal audit team, external audit firm, or regulatory body inspection).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRating rdf:type rdf:Property ;
    rdfs:label 'Compliance Rating' ;
    rdfs:comment 'Overall compliance assessment or rating assigned by the auditor based on findings.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingCount rdf:type rdf:Property ;
    rdfs:label 'Critical Finding Count' ;
    rdfs:comment 'Number of critical or high-severity findings that require immediate remediation.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataPrivacyFramework rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Framework' ;
    rdfs:comment 'Data privacy regulation or framework under audit (e.g., GDPR, CCPA, COPPA for children\'s content).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCount rdf:type rdf:Property ;
    rdfs:label 'Finding Count' ;
    rdfs:comment 'Total number of audit findings, observations, or non-conformances identified during the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportFilePath rdf:type rdf:Property ;
    rdfs:label 'Report File Path' ;
    rdfs:comment 'Storage location or file path reference for the audit report document in the document management system.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date on which the formal audit report was issued to management or regulatory body.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentTaxonomyId rdf:type rdf:Property ;
    rdfs:label 'Parent Taxonomy Id' ;
    rdfs:comment 'Reference to the parent taxonomy entry for hierarchical classification structures. Null for top-level taxonomy entries.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Taxonomy .

ind:allowsMultipleAssignment rdf:type rdf:Property ;
    rdfs:label 'Allows Multiple Assignment' ;
    rdfs:comment 'Indicates whether content assets can be tagged with multiple taxonomy entries of this type simultaneously.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalCode rdf:type rdf:Property ;
    rdfs:label 'External Code' ;
    rdfs:comment 'External or industry-standard taxonomy code for interoperability with third-party systems and content metadata standards.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLeafNode rdf:type rdf:Property ;
    rdfs:label 'Is Leaf Node' ;
    rdfs:comment 'Indicates whether this taxonomy entry is a leaf node (has no children) in the hierarchy. True for leaf nodes, false for parent nodes.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metadataTags rdf:type rdf:Property ;
    rdfs:label 'Metadata Tags' ;
    rdfs:comment 'Additional metadata tags or keywords associated with this taxonomy entry for search and discovery, stored as comma-separated values.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'ISO 3166 three-letter country or region code indicating geographic applicability of this taxonomy entry.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardReference rdf:type rdf:Property ;
    rdfs:label 'Standard Reference' ;
    rdfs:comment 'Reference to the industry standard or classification system this taxonomy entry aligns with (e.g., EIDR Genre, ISO 639 Language Code).' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyCode rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Code' ;
    rdfs:comment 'Unique business code for the taxonomy entry used for external reference and integration.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyName rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Name' ;
    rdfs:comment 'Human-readable name of the taxonomy entry.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyType rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Type' ;
    rdfs:comment 'Classification type of the taxonomy entry indicating the categorization dimension (e.g., genre, theme, mood, audience segment, format, language).' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentVendorId rdf:type rdf:Property ;
    rdfs:label 'Parent Vendor Id' ;
    rdfs:comment 'Reference to the parent vendor if this vendor is a subsidiary or division of a larger vendor organization, enabling hierarchical vendor relationships.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:insuranceCertificateExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Expiration Date' ;
    rdfs:comment 'The date on which the vendor\'s current insurance certificate expires, requiring renewal for continued partnership.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minorityOwnedFlag rdf:type rdf:Property ;
    rdfs:label 'Minority Owned Flag' ;
    rdfs:comment 'Boolean indicator of whether the vendor is certified as a minority-owned business enterprise.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'The overall performance rating of the vendor based on delivery quality, timeliness, and service level adherence.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Boolean indicator of whether the vendor has preferred status for priority consideration in content acquisition and partnership opportunities.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smallBusinessFlag rdf:type rdf:Property ;
    rdfs:label 'Small Business Flag' ;
    rdfs:comment 'Boolean indicator of whether the vendor qualifies as a small business under applicable regulatory definitions.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'The externally-known unique business identifier or code assigned to the vendor for operational reference.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current lifecycle status of the vendor relationship indicating whether the vendor is actively engaged, suspended, or terminated.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Classification of the vendor based on their role in the media ecosystem (e.g., studio, syndicator, content provider, MVPD, distributor, production company).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:womanOwnedFlag rdf:type rdf:Property ;
    rdfs:label 'Woman Owned Flag' ;
    rdfs:comment 'Boolean indicator of whether the vendor is certified as a woman-owned business enterprise.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessUnitId rdf:type rdf:Property ;
    rdfs:label 'Business Unit Id' ;
    rdfs:comment 'Reference to the business unit or division that owns and maintains this recurring entry template.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether the recurring entry template generates debit or credit journal entries.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionCount rdf:type rdf:Property ;
    rdfs:label 'Execution Count' ;
    rdfs:comment 'Total number of times journal entries have been successfully generated from this recurring entry template since activation.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Last Execution Date' ;
    rdfs:comment 'Date when a journal entry was most recently generated from this recurring entry template.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Execution Date' ;
    rdfs:comment 'Date when the next journal entry is scheduled to be automatically generated from this recurring entry template based on recurrence frequency.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalPostingDateOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Reversal Posting Date Offset Days' ;
    rdfs:comment 'Number of days after the original posting date when the reversal entry should be posted. Applicable only when reversal_indicator is true.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:templateDescription rdf:type rdf:Property ;
    rdfs:label 'Template Description' ;
    rdfs:comment 'Detailed description of the recurring entry template, including business purpose, accounting treatment, and usage guidelines.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'Code identifying the intercompany trading partner entity for intercompany recurring entries. Applicable only when intercompany_flag is true.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'The number of supporting documents or attachments linked to this source document (e.g., scanned invoices, contracts, receipts).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentAmount rdf:type rdf:Property ;
    rdfs:label 'Document Amount' ;
    rdfs:comment 'The total gross amount of the source document in the document currency before any adjustments or taxes.' ;
    rdfs:domain ind:SourceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle status of the source document indicating its processing state (e.g., draft, pending approval, approved, posted, cancelled, archived).' ;
    rdfs:domain ind:SourceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Human-readable name or title of the partner agreement.' ;
    rdfs:domain ind:PartnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Period Years' ;
    rdfs:comment 'Duration in years that confidentiality obligations remain in effect after agreement termination.' ;
    rdfs:domain ind:PartnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentCategory rdf:type rdf:Property ;
    rdfs:label 'Content Category' ;
    rdfs:comment 'Primary category of content covered by this agreement.' ;
    rdfs:domain ind:PartnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractOwner rdf:type rdf:Property ;
    rdfs:label 'Contract Owner' ;
    rdfs:comment 'Name or identifier of the business unit or individual responsible for managing this agreement.' ;
    rdfs:domain ind:PartnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValueAmount rdf:type rdf:Property ;
    rdfs:label 'Contract Value Amount' ;
    rdfs:comment 'Total monetary value of the partner agreement over its full term.' ;
    rdfs:domain ind:PartnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Contract Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the contract value amount.' ;
    rdfs:domain ind:PartnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction and governing law applicable to this agreement (e.g., State of California, UK Law).' ;
    rdfs:domain ind:PartnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'Maximum liability amount specified in the agreement for breach or damages.' ;
    rdfs:domain ind:PartnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceGuaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Amount' ;
    rdfs:comment 'Monetary value of performance guarantees or minimum commitments specified in the agreement.' ;
    rdfs:domain ind:PartnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advanceAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Amount' ;
    rdfs:comment 'Upfront payment amount advanced to the partner against future royalties or revenue share, to be recouped from subsequent earnings.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Clause Flag' ;
    rdfs:comment 'Indicates whether the payment schedule includes an escalation clause that increases payment amounts over time or based on performance milestones.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationPercentage rdf:type rdf:Property ;
    rdfs:label 'Escalation Percentage' ;
    rdfs:comment 'The percentage increase applied to payment amounts under the escalation clause, if applicable (e.g., 5.00 represents 5% annual increase).' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Account Number' ;
    rdfs:comment 'The partner\'s bank account number or payment account identifier to which payments under this schedule are remitted.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCalculationBasis rdf:type rdf:Property ;
    rdfs:label 'Payment Calculation Basis' ;
    rdfs:comment 'The basis or formula used to calculate payment amounts: fixed amount, gross revenue, net revenue, subscriber count, viewership metrics, per episode, or per season.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPriority rdf:type rdf:Property ;
    rdfs:label 'Payment Priority' ;
    rdfs:comment 'Business priority level assigned to this payment schedule for cash flow management and payment processing sequencing.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Routing Number' ;
    rdfs:comment 'The bank routing number or SWIFT code for the partner\'s payment account, used for wire transfers and ACH transactions.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Payment Trigger Event' ;
    rdfs:comment 'The business event or milestone that triggers payment obligation, such as content delivery, broadcast date, subscriber threshold, or contract execution.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRate rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate' ;
    rdfs:comment 'The royalty rate percentage or per-unit rate applied to calculate royalty payments for content usage, licensing, or distribution.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directorOfPhotographyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Director Of Photography Employee Id' ;
    rdfs:comment 'Reference to the cinematographer or director of photography assigned to this shoot day.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:firstAssistantDirectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'First Assistant Director Employee Id' ;
    rdfs:comment 'Reference to the first assistant director managing the shoot day logistics.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'The budget amount allocated for this specific shoot day.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailiesDeliveredFlag rdf:type rdf:Property ;
    rdfs:label 'Dailies Delivered Flag' ;
    rdfs:comment 'Indicates whether dailies (raw footage review copies) were delivered for this shoot day.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dailiesDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dailies Delivery Timestamp' ;
    rdfs:comment 'The timestamp when dailies were delivered to post-production for this shoot day.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:footageShotMinutes rdf:type rdf:Property ;
    rdfs:label 'Footage Shot Minutes' ;
    rdfs:comment 'Total duration of raw footage captured during this shoot day, measured in minutes.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOvertimeIncurred rdf:type rdf:Property ;
    rdfs:label 'Is Overtime Incurred' ;
    rdfs:comment 'Indicates whether crew overtime was incurred on this shoot day.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mealPenaltyCount rdf:type rdf:Property ;
    rdfs:label 'Meal Penalty Count' ;
    rdfs:comment 'Number of meal penalty violations incurred during this shoot day due to delayed meal breaks.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyIncidentsCount rdf:type rdf:Property ;
    rdfs:label 'Safety Incidents Count' ;
    rdfs:comment 'Number of safety incidents or accidents reported during this shoot day.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scenesCompletedCount rdf:type rdf:Property ;
    rdfs:label 'Scenes Completed Count' ;
    rdfs:comment 'Number of scenes actually completed during this shoot day.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scenesScheduledCount rdf:type rdf:Property ;
    rdfs:label 'Scenes Scheduled Count' ;
    rdfs:comment 'Number of scenes scheduled to be filmed on this shoot day.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scriptPagesCompleted rdf:type rdf:Property ;
    rdfs:label 'Script Pages Completed' ;
    rdfs:comment 'Number of script pages actually completed during this shoot day, measured in eighths of a page.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scriptPagesScheduled rdf:type rdf:Property ;
    rdfs:label 'Script Pages Scheduled' ;
    rdfs:comment 'Number of script pages scheduled to be filmed on this shoot day, measured in eighths of a page.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shootDayStatus rdf:type rdf:Property ;
    rdfs:label 'Shoot Day Status' ;
    rdfs:comment 'Current lifecycle status of the shoot day.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Temperature Fahrenheit' ;
    rdfs:comment 'Average temperature during the shoot day in degrees Fahrenheit.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCastCount rdf:type rdf:Property ;
    rdfs:label 'Total Cast Count' ;
    rdfs:comment 'Total number of cast members (actors, extras) present on this shoot day.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCrewCount rdf:type rdf:Property ;
    rdfs:label 'Total Crew Count' ;
    rdfs:comment 'Total number of crew members present on this shoot day.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalExtrasCount rdf:type rdf:Property ;
    rdfs:label 'Total Extras Count' ;
    rdfs:comment 'Total number of background actors or extras present on this shoot day.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSetupsCount rdf:type rdf:Property ;
    rdfs:label 'Total Setups Count' ;
    rdfs:comment 'Total number of camera setups or shots completed during this shoot day.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weatherCondition rdf:type rdf:Property ;
    rdfs:label 'Weather Condition' ;
    rdfs:comment 'The predominant weather condition during this shoot day, relevant for continuity and scheduling.' ;
    rdfs:domain ind:ShootDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTypeId rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Id' ;
    rdfs:comment 'Reference to the equipment type classification that defines the category and specifications of this equipment item.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentType .

ind:rentalAgreementId rdf:type rdf:Property ;
    rdfs:label 'Rental Agreement Id' ;
    rdfs:comment 'Reference to the rental agreement contract if this equipment item is rented rather than owned.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RentalAgreement .

ind:condition rdf:type rdf:Property ;
    rdfs:label 'Condition' ;
    rdfs:comment 'Assessment of the physical condition and operational readiness of the equipment item.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyRentalRate rdf:type rdf:Property ;
    rdfs:label 'Daily Rental Rate' ;
    rdfs:comment 'Daily rental cost for this equipment item if it is rented, in the organization\'s base currency.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedReturnDate rdf:type rdf:Property ;
    rdfs:label 'Expected Return Date' ;
    rdfs:comment 'Scheduled date when the equipment item is expected to be returned from its current assignment.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiration Date' ;
    rdfs:comment 'Date when the current insurance coverage for this equipment item expires.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isRental rdf:type rdf:Property ;
    rdfs:label 'Is Rental' ;
    rdfs:comment 'Indicates whether this equipment item is rented from an external vendor rather than owned by the organization.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Interval Days' ;
    rdfs:comment 'Standard number of days between scheduled maintenance activities for this equipment item.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'Human-readable name or title of the equipment item for identification and display purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSpecifications rdf:type rdf:Property ;
    rdfs:label 'Technical Specifications' ;
    rdfs:comment 'Detailed technical specifications, capabilities, and features of this equipment item relevant to production use.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUsageHours rdf:type rdf:Property ;
    rdfs:label 'Total Usage Hours' ;
    rdfs:comment 'Cumulative total hours of operational usage recorded for this equipment item since acquisition.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rightsAuditSessionId rdf:type rdf:Property ;
    rdfs:label 'Rights Audit Session Id' ;
    rdfs:comment 'Primary key for rights_audit_session' ;
    rdfs:domain ind:RightsAuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentPortfolioId rdf:type rdf:Property ;
    rdfs:label 'Content Portfolio Id' ;
    rdfs:comment 'Identifier of the specific content portfolio or catalog being audited, if the audit is scoped to a particular content grouping.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentPortfolio .

ind:modifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that last modified this audit session record.' ;
    rdfs:domain ind:RightsAuditSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rightsHolderId rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Id' ;
    rdfs:comment 'Identifier of the rights holder or licensor whose rights portfolio is being audited in this session.' ;
    rdfs:domain ind:RightsAuditSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:auditReportUrl rdf:type rdf:Property ;
    rdfs:label 'Audit Report Url' ;
    rdfs:comment 'URL or file path to the detailed audit report document generated for this session.' ;
    rdfs:domain ind:RightsAuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTeamSize rdf:type rdf:Property ;
    rdfs:label 'Audit Team Size' ;
    rdfs:comment 'Number of auditors and support personnel assigned to this audit session.' ;
    rdfs:domain ind:RightsAuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Overall compliance score for this audit session, expressed as a percentage (0.00 to 100.00) representing the degree of adherence to rights management policies and contractual obligations.' ;
    rdfs:domain ind:RightsAuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical-severity findings that require immediate remediation or represent significant compliance risks.' ;
    rdfs:domain ind:RightsAuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionChannelScope rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Scope' ;
    rdfs:comment 'Distribution channels included in the audit scope (e.g., theatrical, SVOD, AVOD, TVOD, linear television, home video).' ;
    rdfs:domain ind:RightsAuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialDiscrepancyAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Discrepancy Amount' ;
    rdfs:comment 'Total monetary value of financial discrepancies identified during the audit, representing under-payments, over-payments, or unreconciled amounts. Expressed in the reporting currency.' ;
    rdfs:domain ind:RightsAuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findingsCount rdf:type rdf:Property ;
    rdfs:label 'Findings Count' ;
    rdfs:comment 'Total number of audit findings, discrepancies, or issues identified during this audit session.' ;
    rdfs:domain ind:RightsAuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remediationDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Deadline Date' ;
    rdfs:comment 'Target date by which all identified audit findings must be remediated and corrective actions completed.' ;
    rdfs:domain ind:RightsAuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightslineSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Rightsline Sync Status' ;
    rdfs:comment 'Status of data synchronization with the Rightsline rights management system for this audit session: successfully synced, sync pending, sync failed, or not applicable for this audit type.' ;
    rdfs:domain ind:RightsAuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightslineSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rightsline Sync Timestamp' ;
    rdfs:comment 'Timestamp of the last successful synchronization of audit findings with the Rightsline rights management platform.' ;
    rdfs:domain ind:RightsAuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionNumber rdf:type rdf:Property ;
    rdfs:label 'Session Number' ;
    rdfs:comment 'Business-facing unique identifier for the audit session, used for external reference and reporting.' ;
    rdfs:domain ind:RightsAuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRecordsReviewed rdf:type rdf:Property ;
    rdfs:label 'Total Records Reviewed' ;
    rdfs:comment 'Total number of rights records, transactions, or data points examined during this audit session.' ;
    rdfs:domain ind:RightsAuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentBrandId rdf:type rdf:Property ;
    rdfs:label 'Parent Brand Id' ;
    rdfs:comment 'Reference to the parent brand in a brand hierarchy. Used for sub-brands, regional variants, or digital extensions of a master brand. Null for top-level brands.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Short alphanumeric code used as a unique business identifier for the brand in sales systems, rate cards, and trafficking systems. Typically 3-10 uppercase characters.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandDescription rdf:type rdf:Property ;
    rdfs:label 'Brand Description' ;
    rdfs:comment 'Detailed narrative description of the brand, its positioning, audience, and content offering. Used in sales proposals, syndication packages, and agency presentations.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandLogoUrl rdf:type rdf:Property ;
    rdfs:label 'Brand Logo Url' ;
    rdfs:comment 'URL to the official brand logo asset. Used in sales proposals, rate cards, and advertising creative materials.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'The official name of the brand as recognized in the market and used in advertising sales, content licensing, and syndication deals.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandOwner rdf:type rdf:Property ;
    rdfs:label 'Brand Owner' ;
    rdfs:comment 'The legal entity or corporate parent that owns the brand. Used for rights management, licensing, and syndication agreements.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandTagline rdf:type rdf:Property ;
    rdfs:label 'Brand Tagline' ;
    rdfs:comment 'The official marketing tagline or slogan associated with the brand. Used in advertising creative and promotional materials.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandTier rdf:type rdf:Property ;
    rdfs:label 'Brand Tier' ;
    rdfs:comment 'The commercial tier or positioning of the brand in the sales hierarchy. Premium brands command higher CPM rates; value brands offer lower-cost inventory.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandType rdf:type rdf:Property ;
    rdfs:label 'Brand Type' ;
    rdfs:comment 'Classification of the brand by its primary distribution or business model: network (broadcast network), station (local affiliate), digital_platform (online property), streaming_service (SVOD/AVOD), syndication (content distributor), or studio (production house).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Brand Website Url' ;
    rdfs:comment 'The primary website URL for the brand. Used for digital advertising integration, content syndication links, and agency reference.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdSupported rdf:type rdf:Property ;
    rdfs:label 'Is Ad Supported' ;
    rdfs:comment 'Indicates whether the brand carries advertising inventory. True for ad-supported brands (AVOD, linear TV); false for subscription-only or ad-free brands (SVOD).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubscriptionBased rdf:type rdf:Property ;
    rdfs:label 'Is Subscription Based' ;
    rdfs:comment 'Indicates whether the brand operates on a subscription revenue model (SVOD, cable subscription). Used to distinguish revenue streams in sales reporting.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSyndicationEligible rdf:type rdf:Property ;
    rdfs:label 'Is Syndication Eligible' ;
    rdfs:comment 'Indicates whether the brand is eligible for content syndication deals. True if the brand can license content to third-party distributors; false otherwise.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryMarket rdf:type rdf:Property ;
    rdfs:label 'Primary Market' ;
    rdfs:comment 'The primary geographic market or country where the brand operates, represented as a 3-letter ISO country code (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticEnabled rdf:type rdf:Property ;
    rdfs:label 'Programmatic Enabled' ;
    rdfs:comment 'Indicates whether the brand supports programmatic advertising sales through automated buying platforms and real-time bidding (RTB).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesContactEmail rdf:type rdf:Property ;
    rdfs:label 'Sales Contact Email' ;
    rdfs:comment 'Primary email address for sales inquiries and agency outreach for this brand. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesContactPhone rdf:type rdf:Property ;
    rdfs:label 'Sales Contact Phone' ;
    rdfs:comment 'Primary phone number for sales inquiries and agency outreach for this brand. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Code' ;
    rdfs:comment 'The unique Salesforce Account ID linking this brand to the Salesforce Media Cloud CRM system. Used for opportunity tracking, pipeline management, and sales contract association.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfrontParticipation rdf:type rdf:Property ;
    rdfs:label 'Upfront Participation' ;
    rdfs:comment 'Indicates whether the brand participates in the annual upfront advertising sales market. True for brands that sell inventory in upfront commitments; false for scatter-only brands.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioTracksAvailable rdf:type rdf:Property ;
    rdfs:label 'Audio Tracks Available' ;
    rdfs:comment 'Comma-separated list of ISO 639-3 language codes for available audio tracks. Supports multi-language distribution.' ;
    rdfs:domain ind:ContentLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentOwner rdf:type rdf:Property ;
    rdfs:label 'Content Owner' ;
    rdfs:comment 'Legal entity that owns the intellectual property rights to the content asset. Critical for rights management and licensing.' ;
    rdfs:domain ind:ContentLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isrcIdentifier rdf:type rdf:Property ;
    rdfs:label 'Isrc Identifier' ;
    rdfs:comment 'International standard code for sound recordings and music video recordings as defined by ISO 3901. Used for music content identification.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpaRating rdf:type rdf:Property ;
    rdfs:label 'Mpa Rating' ;
    rdfs:comment 'Content rating assigned by the Motion Picture Association indicating age-appropriateness and content advisory.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesTitle rdf:type rdf:Property ;
    rdfs:label 'Series Title' ;
    rdfs:comment 'Title of the parent series for episodic content. Null for standalone content assets.' ;
    rdfs:domain ind:ContentLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleLanguagesAvailable rdf:type rdf:Property ;
    rdfs:label 'Subtitle Languages Available' ;
    rdfs:comment 'Comma-separated list of ISO 639-3 language codes for available subtitle tracks. Supports localization and accessibility requirements.' ;
    rdfs:domain ind:ContentLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryRestrictions rdf:type rdf:Property ;
    rdfs:label 'Territory Restrictions' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where content distribution is restricted due to licensing agreements.' ;
    rdfs:domain ind:ContentLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tvRating rdf:type rdf:Property ;
    rdfs:label 'Tv Rating' ;
    rdfs:comment 'Television content rating as defined by the TV Parental Guidelines system for broadcast and streaming content.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentTeamId rdf:type rdf:Property ;
    rdfs:label 'Parent Team Id' ;
    rdfs:comment 'Identifier of the parent sales team if this team is part of a hierarchical sales organization structure. Null for top-level teams.' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTeam .

ind:channelFocus rdf:type rdf:Property ;
    rdfs:label 'Channel Focus' ;
    rdfs:comment 'The distribution channel or platform this sales team primarily sells inventory or content for.' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionStructure rdf:type rdf:Property ;
    rdfs:label 'Commission Structure' ;
    rdfs:comment 'The commission or incentive structure applied to this sales team (e.g., flat rate per deal, tiered based on quota attainment, revenue share percentage).' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'The market segment or customer category this sales team focuses on (e.g., local advertisers, national agencies, direct clients, programmatic buyers).' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFocus rdf:type rdf:Property ;
    rdfs:label 'Product Focus' ;
    rdfs:comment 'Primary product or content type this sales team specializes in selling (e.g., linear TV spots, streaming inventory, sports programming, news sponsorships).' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriod rdf:type rdf:Property ;
    rdfs:label 'Quota Period' ;
    rdfs:comment 'The time period over which the sales quota is measured (e.g., monthly, quarterly, annual, upfront season).' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceTeamCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Team Code' ;
    rdfs:comment 'External identifier for this sales team in Salesforce Media Cloud, used for integration and synchronization.' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamCode rdf:type rdf:Property ;
    rdfs:label 'Team Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the sales team in systems and reports (e.g., ECAS, NSYN, DSW).' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamName rdf:type rdf:Property ;
    rdfs:label 'Team Name' ;
    rdfs:comment 'Official name of the sales team (e.g., East Coast Advertising Sales, National Syndication Team, Digital Sales West).' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamSize rdf:type rdf:Property ;
    rdfs:label 'Team Size' ;
    rdfs:comment 'Number of active sales representatives or account executives currently assigned to this team.' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:teamType rdf:type rdf:Property ;
    rdfs:label 'Team Type' ;
    rdfs:comment 'Classification of the sales team based on the primary revenue stream or sales function they manage.' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceDemographic rdf:type rdf:Property ;
    rdfs:label 'Audience Demographic' ;
    rdfs:comment 'Target audience demographic profile for the product (e.g., Adults 18-49, Women 25-54).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableFromDate rdf:type rdf:Property ;
    rdfs:label 'Available From Date' ;
    rdfs:comment 'Date when this product becomes available for sale and booking.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availableUntilDate rdf:type rdf:Property ;
    rdfs:label 'Available Until Date' ;
    rdfs:comment 'Date when this product is no longer available for sale, applicable to seasonal or limited-time offerings.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'Standard list price for one unit of the product before discounts, premiums, or negotiated adjustments.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMakegoodEligible rdf:type rdf:Property ;
    rdfs:label 'Is Makegood Eligible' ;
    rdfs:comment 'Indicates whether this product is eligible for makegood compensation if delivery guarantees are not met.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPremium rdf:type rdf:Property ;
    rdfs:label 'Is Premium' ;
    rdfs:comment 'Indicates whether this is a premium product commanding higher rates due to high demand, exclusive positioning, or superior audience quality.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSponsorable rdf:type rdf:Property ;
    rdfs:label 'Is Sponsorable' ;
    rdfs:comment 'Indicates whether this product can be sold as a sponsorship package with brand integration opportunities.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum number of units that can be purchased in a single order for this product, used to manage inventory scarcity.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum number of units that must be purchased in a single order for this product.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productManagerName rdf:type rdf:Property ;
    rdfs:label 'Product Manager Name' ;
    rdfs:comment 'Name of the product manager or business owner responsible for this product offering.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewAfterOffer rdf:type rdf:Property ;
    rdfs:label 'Auto Renew After Offer' ;
    rdfs:comment 'Indicates whether the subscription automatically renews at standard pricing after the win-back offer period expires.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCcpaFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Ccpa Flag' ;
    rdfs:comment 'Indicates whether this win-back offer has been reviewed and approved for CCPA compliance in California market.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCoppaFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Coppa Flag' ;
    rdfs:comment 'Indicates whether this win-back offer has been reviewed and approved for COPPA compliance when targeting households with children under 13.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceGdprFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Gdpr Flag' ;
    rdfs:comment 'Indicates whether this win-back offer has been reviewed and approved for GDPR compliance in European markets.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentRedemptionCount rdf:type rdf:Property ;
    rdfs:label 'Current Redemption Count' ;
    rdfs:comment 'Current number of times this win-back offer has been redeemed by subscribers, tracked against the total redemption cap.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibilityChurnDaysMax rdf:type rdf:Property ;
    rdfs:label 'Eligibility Churn Days Max' ;
    rdfs:comment 'Maximum number of days since churn that a subscriber remains eligible for this win-back offer. Nullable for no upper limit.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibilityChurnDaysMin rdf:type rdf:Property ;
    rdfs:label 'Eligibility Churn Days Min' ;
    rdfs:comment 'Minimum number of days a subscriber must have been churned to be eligible for this win-back offer.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freeTrialDurationDays rdf:type rdf:Property ;
    rdfs:label 'Free Trial Duration Days' ;
    rdfs:comment 'Number of days of free service provided as part of the win-back offer. Nullable if offer type is not free trial.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketingChannel rdf:type rdf:Property ;
    rdfs:label 'Marketing Channel' ;
    rdfs:comment 'Primary marketing channel through which this win-back offer is promoted and delivered to churned subscribers.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxRedemptionsPerSubscriber rdf:type rdf:Property ;
    rdfs:label 'Max Redemptions Per Subscriber' ;
    rdfs:comment 'Maximum number of times a single subscriber can redeem this win-back offer across their lifetime. Nullable for unlimited redemptions.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Offer Duration Months' ;
    rdfs:comment 'Number of months the win-back offer discount or benefit applies before reverting to standard pricing.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerName rdf:type rdf:Property ;
    rdfs:label 'Offer Name' ;
    rdfs:comment 'Human-readable name of the win-back offer displayed to subscribers and used in internal reporting.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerType rdf:type rdf:Property ;
    rdfs:label 'Offer Type' ;
    rdfs:comment 'Classification of the win-back offer type indicating the incentive mechanism used to re-engage churned subscribers.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Requires Payment Method' ;
    rdfs:comment 'Indicates whether the subscriber must provide valid payment method details to redeem this win-back offer.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetArpuLiftPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Arpu Lift Percentage' ;
    rdfs:comment 'Target percentage increase in average revenue per user expected from subscribers who redeem this win-back offer, used for performance measurement.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetContentLibrary rdf:type rdf:Property ;
    rdfs:label 'Target Content Library' ;
    rdfs:comment 'Specific content library or catalog access granted as part of the win-back offer, such as premium channels or exclusive content collections.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLtvImpact rdf:type rdf:Property ;
    rdfs:label 'Target Ltv Impact' ;
    rdfs:comment 'Target incremental lifetime value expected from subscribers who redeem this win-back offer, used for ROI analysis and offer optimization.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetServiceTier rdf:type rdf:Property ;
    rdfs:label 'Target Service Tier' ;
    rdfs:comment 'Subscription service tier that this win-back offer applies to, indicating which type of churned subscribers are eligible.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAndConditionsUrl rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Url' ;
    rdfs:comment 'URL link to the full legal terms and conditions document for this win-back offer, required for regulatory compliance.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRedemptionCap rdf:type rdf:Property ;
    rdfs:label 'Total Redemption Cap' ;
    rdfs:comment 'Maximum total number of redemptions allowed for this win-back offer across all subscribers. Nullable for unlimited total redemptions.' ;
    rdfs:domain ind:WinBackOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zuoraProductRatePlanCode rdf:type rdf:Property ;
    rdfs:label 'Zuora Product Rate Plan Code' ;
    rdfs:comment 'External identifier linking this win-back offer to the corresponding product rate plan in Zuora subscription billing system.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentVersion rdf:type rdf:Property ;
    rdfs:label 'Content Version' ;
    rdfs:comment 'Version identifier for the content asset, tracking theatrical cuts, directors cuts, extended editions, and other variants.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dubbedLanguages rdf:type rdf:Property ;
    rdfs:label 'Dubbed Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639-3 language codes for available dubbed audio tracks.' ;
    rdfs:domain ind:VodLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adobeExperienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Adobe Experience Segment Id' ;
    rdfs:comment 'External identifier linking this offer to the corresponding audience segment in Adobe Experience Platform for personalization.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:adSupportedFlag rdf:type rdf:Property ;
    rdfs:label 'Ad Supported Flag' ;
    rdfs:comment 'Indicates whether this offer includes advertising (AVOD model) or is ad-free.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bundleEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Bundle Eligible Flag' ;
    rdfs:comment 'Indicates whether this offer can be bundled with other service offerings.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Commitment Period Months' ;
    rdfs:comment 'Minimum commitment period in months required for this offer. Nullable for no-commitment offers.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:concurrentStreams rdf:type rdf:Property ;
    rdfs:label 'Concurrent Streams' ;
    rdfs:comment 'Maximum number of simultaneous streams allowed under this offer.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentQuality rdf:type rdf:Property ;
    rdfs:label 'Content Quality' ;
    rdfs:comment 'Maximum video quality resolution available under this offer (Standard Definition, High Definition, 4K Ultra HD, 8K).' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDevices rdf:type rdf:Property ;
    rdfs:label 'Max Devices' ;
    rdfs:comment 'Maximum number of devices that can be registered under this offer.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Amount' ;
    rdfs:comment 'The standard price amount charged for this offer per billing cycle.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adobeOfferId rdf:type rdf:Property ;
    rdfs:label 'Adobe Offer Id' ;
    rdfs:comment 'External offer identifier in Adobe Experience Platform for personalization and marketing campaign tracking.' ;
    rdfs:domain ind:AddOn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offer .

ind:zuoraProductId rdf:type rdf:Property ;
    rdfs:label 'Zuora Product Id' ;
    rdfs:comment 'External product identifier in Zuora subscription billing system for integration and billing synchronization.' ;
    rdfs:domain ind:AddOn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Product .

ind:addOnCode rdf:type rdf:Property ;
    rdfs:label 'Add On Code' ;
    rdfs:comment 'Unique business identifier code for the add-on, used for external references and integrations.' ;
    rdfs:domain ind:AddOn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addOnName rdf:type rdf:Property ;
    rdfs:label 'Add On Name' ;
    rdfs:comment 'Human-readable name of the add-on product displayed to subscribers.' ;
    rdfs:domain ind:AddOn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addOnType rdf:type rdf:Property ;
    rdfs:label 'Add On Type' ;
    rdfs:comment 'Classification of the add-on by product category.' ;
    rdfs:domain ind:AddOn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCount rdf:type rdf:Property ;
    rdfs:label 'Channel Count' ;
    rdfs:comment 'Number of premium channels or content sources included in this add-on. Null if not applicable.' ;
    rdfs:domain ind:AddOn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentHours rdf:type rdf:Property ;
    rdfs:label 'Content Hours' ;
    rdfs:comment 'Total hours of content available in this add-on. Null if not applicable or unlimited.' ;
    rdfs:domain ind:AddOn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFeatured rdf:type rdf:Property ;
    rdfs:label 'Is Featured' ;
    rdfs:comment 'Indicates whether this add-on should be prominently featured in marketing and user interface displays.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStandalone rdf:type rdf:Property ;
    rdfs:label 'Is Standalone' ;
    rdfs:comment 'Indicates whether the add-on can be purchased without a base subscription plan.' ;
    rdfs:domain ind:AddOn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalTag rdf:type rdf:Property ;
    rdfs:label 'Promotional Tag' ;
    rdfs:comment 'Marketing tag or label used to identify promotional campaigns or featured add-ons in user interfaces.' ;
    rdfs:domain ind:AddOn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresBasePlan rdf:type rdf:Property ;
    rdfs:label 'Requires Base Plan' ;
    rdfs:comment 'Indicates whether the add-on requires an active base subscription plan to be purchased.' ;
    rdfs:domain ind:AddOn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Brief marketing description of the add-on for display in user interfaces and promotional materials.' ;
    rdfs:domain ind:AddOn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Display order sequence for presenting add-ons in user interfaces and catalogs.' ;
    rdfs:domain ind:AddOn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uhd4kEnabled rdf:type rdf:Property ;
    rdfs:label 'Uhd 4k Enabled' ;
    rdfs:comment 'Indicates whether Ultra High Definition 4K streaming quality is included with this add-on.' ;
    rdfs:domain ind:AddOn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depreciationScheduleId rdf:type rdf:Property ;
    rdfs:label 'Depreciation Schedule Id' ;
    rdfs:comment 'Primary key for depreciation_schedule' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetId rdf:type rdf:Property ;
    rdfs:label 'Asset Id' ;
    rdfs:comment 'Reference to the fixed asset being depreciated. Links to the asset master record for equipment, facilities, broadcast infrastructure, or production equipment.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:annualDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Depreciation Amount' ;
    rdfs:comment 'The calculated annual depreciation expense for this asset under the specified depreciation method. Used for budgeting and forecasting.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciableBase rdf:type rdf:Property ;
    rdfs:label 'Depreciable Base' ;
    rdfs:comment 'The amount subject to depreciation, calculated as original cost minus salvage value. The total amount to be expensed over the asset\'s useful life.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationBookType rdf:type rdf:Property ;
    rdfs:label 'Depreciation Book Type' ;
    rdfs:comment 'The accounting book or ledger for which this depreciation schedule applies. Supports parallel depreciation for different reporting frameworks.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Depreciation Rate Percent' ;
    rdfs:comment 'The percentage rate applied to calculate depreciation, particularly for declining balance methods. Expressed as a percentage.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Amount' ;
    rdfs:comment 'The amount of impairment loss recognized, reducing the carrying value of the asset. Nullable if no impairment has occurred.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentDate rdf:type rdf:Property ;
    rdfs:label 'Impairment Date' ;
    rdfs:comment 'The date when an impairment loss was recognized for this asset. Nullable if no impairment has occurred.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impairmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator' ;
    rdfs:comment 'Flag indicating whether the asset has been tested for impairment or shows indicators of impairment. Triggers impairment review processes.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDepreciationRunDate rdf:type rdf:Property ;
    rdfs:label 'Last Depreciation Run Date' ;
    rdfs:comment 'The date when depreciation was last calculated and posted for this schedule. Used to track period-end close activities.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDepreciationRunDate rdf:type rdf:Property ;
    rdfs:label 'Next Depreciation Run Date' ;
    rdfs:comment 'The scheduled date for the next depreciation calculation. Used for planning period-end close and financial reporting cycles.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalCost rdf:type rdf:Property ;
    rdfs:label 'Original Cost' ;
    rdfs:comment 'The initial acquisition or construction cost of the asset, including all costs necessary to bring the asset to its intended use.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'The estimated residual value of the asset at the end of its useful life. The amount expected to be recovered through sale or disposal.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usefulLifeUnits rdf:type rdf:Property ;
    rdfs:label 'Useful Life Units' ;
    rdfs:comment 'The estimated total production capacity or usage units over the asset\'s life. Used for units-of-production depreciation method. Nullable for time-based methods.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:techProblemId rdf:type rdf:Property ;
    rdfs:label 'Tech Problem Id' ;
    rdfs:comment 'Primary key for tech_problem' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:knowledgeArticleId rdf:type rdf:Property ;
    rdfs:label 'Knowledge Article Id' ;
    rdfs:comment 'Reference to the knowledge base article created from this problem for future reference and training.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeArticle .

ind:affectedAssetCount rdf:type rdf:Property ;
    rdfs:label 'Affected Asset Count' ;
    rdfs:comment 'Number of technology assets (equipment, systems, facilities) impacted by this problem.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedToIndividual rdf:type rdf:Property ;
    rdfs:label 'Assigned To Individual' ;
    rdfs:comment 'Name of the specific engineer or problem manager assigned as owner for this problem investigation.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedDate rdf:type rdf:Property ;
    rdfs:label 'Detected Date' ;
    rdfs:comment 'Date when the underlying problem condition was first detected in broadcast infrastructure or systems.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:downtimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Minutes' ;
    rdfs:comment 'Total minutes of broadcast service downtime or degradation caused by this problem across all affected services.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impact rdf:type rdf:Property ;
    rdfs:label 'Impact' ;
    rdfs:comment 'Assessment of the business impact scope affecting broadcast operations, audience reach, or revenue.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKnownError rdf:type rdf:Property ;
    rdfs:label 'Is Known Error' ;
    rdfs:comment 'Indicates whether this problem has been documented as a known error with identified root cause and workaround in the knowledge base.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMajorProblem rdf:type rdf:Property ;
    rdfs:label 'Is Major Problem' ;
    rdfs:comment 'Indicates whether this problem is classified as a major problem requiring executive attention and special handling procedures.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permanentSolution rdf:type rdf:Property ;
    rdfs:label 'Permanent Solution' ;
    rdfs:comment 'Documented permanent fix or resolution implemented to eliminate the root cause of the problem.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemCategory rdf:type rdf:Property ;
    rdfs:label 'Problem Category' ;
    rdfs:comment 'High-level classification of the problem domain within media broadcasting technology operations.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemNumber rdf:type rdf:Property ;
    rdfs:label 'Problem Number' ;
    rdfs:comment 'Human-readable unique problem identifier used for external communication and tracking. Format: PRB followed by 8 digits.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemSubcategory rdf:type rdf:Property ;
    rdfs:label 'Problem Subcategory' ;
    rdfs:comment 'Detailed classification within the problem category for granular analysis and routing to specialized teams.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemType rdf:type rdf:Property ;
    rdfs:label 'Problem Type' ;
    rdfs:comment 'Indicates whether the problem was identified reactively (after incidents) or proactively (through analysis and monitoring).' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'Name or identifier of the person who initially reported or identified this technology problem.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date when the problem was first reported or identified in the problem management system.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseIdentifiedDate rdf:type rdf:Property ;
    rdfs:label 'Root Cause Identified Date' ;
    rdfs:comment 'Date when the root cause of the problem was successfully identified and documented.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:urgency rdf:type rdf:Property ;
    rdfs:label 'Urgency' ;
    rdfs:comment 'Time sensitivity for problem resolution based on operational deadlines and broadcast schedules.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workaround rdf:type rdf:Property ;
    rdfs:label 'Workaround' ;
    rdfs:comment 'Temporary solution or procedure to minimize impact of the problem while permanent resolution is developed.' ;
    rdfs:domain ind:TechProblem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualDeductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Deductible Amount' ;
    rdfs:comment 'Annual deductible amount the employee must pay before the plan begins coverage. Applicable to health and insurance plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualOutOfPocketMaximum rdf:type rdf:Property ;
    rdfs:label 'Annual Out Of Pocket Maximum' ;
    rdfs:comment 'Maximum amount the employee will pay out-of-pocket in a plan year. Applicable to health and insurance plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coinsurancePercentage rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Percentage' ;
    rdfs:comment 'Percentage of costs the employee pays after meeting the deductible. Applicable to health and insurance plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Contribution Frequency' ;
    rdfs:comment 'Frequency at which employee and employer contributions are made for this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
    rdfs:comment 'Fixed amount the employee pays for covered services at the time of service. Applicable to health plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageLevel rdf:type rdf:Property ;
    rdfs:label 'Coverage Level' ;
    rdfs:comment 'Tier of coverage indicating who is eligible to be covered under the benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentCloseDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Close Date' ;
    rdfs:comment 'Date when the annual open enrollment period ends for this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentEligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Enrollment Eligibility Criteria' ;
    rdfs:comment 'Textual description of the eligibility requirements for employees to enroll in this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentOpenDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Open Date' ;
    rdfs:comment 'Date when the annual open enrollment period begins for this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planCategory rdf:type rdf:Property ;
    rdfs:label 'Plan Category' ;
    rdfs:comment 'Broader classification grouping for the benefit plan used for reporting and compliance purposes.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Plan Document Url' ;
    rdfs:comment 'Web address or document repository location for the official benefit plan document and summary plan description.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYearEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan Year End Date' ;
    rdfs:comment 'End date of the benefit plan year used for deductibles, maximums, and annual limits.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planYearStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Year Start Date' ;
    rdfs:comment 'Start date of the benefit plan year used for deductibles, maximums, and annual limits.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:providerCode rdf:type rdf:Property ;
    rdfs:label 'Provider Code' ;
    rdfs:comment 'Reference to the benefit provider organization administering this plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Waiting Period Days' ;
    rdfs:comment 'Number of days an employee must wait after hire date before becoming eligible to enroll in this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageLifespanYears rdf:type rdf:Property ;
    rdfs:label 'Average Lifespan Years' ;
    rdfs:comment 'Expected operational lifespan of this equipment type in years under normal production usage conditions.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:category rdf:type rdf:Property ;
    rdfs:label 'Category' ;
    rdfs:comment 'High-level classification grouping equipment types by production function: camera, lighting, audio, grip, electric, or post_production.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Certification Requirements' ;
    rdfs:comment 'Description of required certifications, licenses, or training credentials needed to operate this equipment type.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compatibleAccessories rdf:type rdf:Property ;
    rdfs:label 'Compatible Accessories' ;
    rdfs:comment 'List or description of standard accessories, attachments, or complementary equipment types that are compatible with or commonly used alongside this equipment type.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensions rdf:type rdf:Property ;
    rdfs:label 'Dimensions' ;
    rdfs:comment 'Physical dimensions of the equipment type in standard format (e.g., length x width x height in cm or inches). Used for storage and transport planning.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date on which this equipment type was or will be discontinued and removed from active inventory. Null if still active.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceCategory rdf:type rdf:Property ;
    rdfs:label 'Insurance Category' ;
    rdfs:comment 'Insurance classification for risk assessment and coverage determination: standard (routine equipment), high_value (premium items), specialized (unique/rare), hazardous (elevated risk).' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelDesignation rdf:type rdf:Property ;
    rdfs:label 'Model Designation' ;
    rdfs:comment 'Specific model or product line designation from the manufacturer (e.g., ALEXA Mini LF, FX9, URSA Mini Pro 12K).' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerRequirements rdf:type rdf:Property ;
    rdfs:label 'Power Requirements' ;
    rdfs:comment 'Electrical power specifications including voltage, amperage, and connector type (e.g., 120V AC, 15A, Edison plug; V-Mount battery).' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementCost rdf:type rdf:Property ;
    rdfs:label 'Replacement Cost' ;
    rdfs:comment 'Estimated cost to replace or purchase a new unit of this equipment type. Used for insurance valuation and damage assessment.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Certification' ;
    rdfs:comment 'Indicates whether crew members must hold specific certifications or training credentials to operate this equipment type (e.g., drone pilot license, rigging certification).' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresOperator rdf:type rdf:Property ;
    rdfs:label 'Requires Operator' ;
    rdfs:comment 'Indicates whether this equipment type requires a specialized operator or technician to be allocated alongside the equipment (e.g., Steadicam operator, crane operator).' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageRequirements rdf:type rdf:Property ;
    rdfs:label 'Storage Requirements' ;
    rdfs:comment 'Special storage conditions or requirements for this equipment type (e.g., climate-controlled, shock-resistant case, vertical storage only).' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Detailed classification within the category (e.g., Digital Cinema Camera, LED Panel, Boom Microphone, Dolly, Generator, Color Grading Suite).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportCaseRequired rdf:type rdf:Property ;
    rdfs:label 'Transport Case Required' ;
    rdfs:comment 'Indicates whether this equipment type must be transported in a specialized protective case or container.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying this equipment type across production systems. Used for cataloging and cross-system reference.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeName rdf:type rdf:Property ;
    rdfs:label 'Type Name' ;
    rdfs:comment 'Human-readable name of the equipment type (e.g., Camera, Lighting Rig, Audio Mixer, Drone, Crane).' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeklyRentalRate rdf:type rdf:Property ;
    rdfs:label 'Weekly Rental Rate' ;
    rdfs:comment 'Standard weekly rental rate for this equipment type in the base currency. Typically discounted compared to 7x daily rate.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Standard weight of this equipment type in kilograms. Used for transportation planning, rigging calculations, and crew allocation.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workflowIntegration rdf:type rdf:Property ;
    rdfs:label 'Workflow Integration' ;
    rdfs:comment 'Description of how this equipment type integrates with production workflow systems such as Dalet Galaxy, asset management platforms, or post-production pipelines.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualReturnDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return Date' ;
    rdfs:comment 'Actual date when the rented asset was returned, used to calculate overages or extensions.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether the rental agreement automatically renews unless cancelled.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:damageWaiverFee rdf:type rdf:Property ;
    rdfs:label 'Damage Waiver Fee' ;
    rdfs:comment 'Optional fee paid to waive liability for minor damage to the rented asset.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Amount' ;
    rdfs:comment 'Security deposit or advance payment required to secure the rental agreement.' ;
