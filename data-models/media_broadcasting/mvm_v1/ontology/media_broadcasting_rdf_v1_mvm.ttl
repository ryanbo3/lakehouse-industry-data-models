# RDFS Schema for Business: Media Broadcasting

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/media_broadcasting#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Media Broadcasting ---
ind:MediaBroadcasting rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Media Broadcasting' ;
    rdfs:comment 'Media and Broadcasting is a global content and distribution industry encompassing film studios, television networks, streaming platforms, music labels, news organizations, and digital publishers that produce, license, and deliver entertainment and information to audiences through linear, on-demand, and social channels.' .

# --- Domain Classes ---
ind:Content rdf:type rdfs:Class ;
    rdfs:subClassOf ind:MediaBroadcasting ;
    rdfs:label 'Content' ;
    rdfs:comment 'Single source of truth for all content assets across the enterprise — covering titles, episodes, series, films, clips, music, news segments, and live events. Manages content metadata (EIDR, ISAN, ISRC identifiers), format specifications, versioning, localization, MPA ratings, genre classification, and content lifecycle from acquisition through archival. Serves as the master catalog referenced by scheduling, distribution, rights, and digital asset domains.' .

ind:Production rdf:type rdfs:Class ;
    rdfs:subClassOf ind:MediaBroadcasting ;
    rdfs:label 'Production' ;
    rdfs:comment 'Manages the end-to-end content production and post-production workflow — from greenlight and pre-production planning through principal photography, editing, VFX, color grading, audio mixing, transcoding, and final delivery. Tracks production budgets, crew assignments, shoot schedules, facility bookings, equipment allocation, and deliverable milestones. Integrates with Dalet Galaxy for ingest and workflow orchestration.' .

ind:Scheduling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:MediaBroadcasting ;
    rdfs:label 'Scheduling' ;
    rdfs:comment 'Owns the Electronic Program Guide (EPG) and all playout scheduling logic for linear broadcast channels and on-demand programming windows. Manages dayparts, program rundowns, linear channel grids, ad pod placement, SCTE-35 cue markers, simulcast configurations, and automated schedule generation. Drives Ericsson MediaFirst automation for channel playout and failover, ensuring compliance with must-carry and blackout obligations.' .

ind:Distribution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:MediaBroadcasting ;
    rdfs:label 'Distribution' ;
    rdfs:comment 'Governs multi-platform content delivery across linear broadcast (DVB, ATSC, QAM), OTT streaming (HLS, MPEG-DASH, ABR), MVPD/vMVPD carriage, FAST channel syndication, and OTT platform infrastructure. Manages CDN configuration, DRM enforcement, DAI, streaming endpoints, ABR profiles, device support, QoS monitoring, and all delivery SLAs.' .

ind:Mediaasset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:MediaBroadcasting ;
    rdfs:label 'Mediaasset' ;
    rdfs:comment 'Authoritative repository for all managed media files and digital objects — raw camera footage, mezzanine masters, proxy files, graphics, music beds, and archived assets. Implements MAM (Media Asset Management) via Dalet Galaxy, enforcing storage tiering, format standards (MPEG-4 ISO 14496), checksum integrity, retention policies, format migrations, and chain-of-custody audit trails for regulatory and legal hold compliance.' .

ind:Rights rdf:type rdfs:Class ;
    rdfs:subClassOf ind:MediaBroadcasting ;
    rdfs:label 'Rights' ;
    rdfs:comment 'Single source of truth for all intellectual property rights, licensing agreements, and royalty obligations. Manages content windows (theatrical, SVOD, AVOD, TVOD, linear), holdback periods, territory restrictions, talent residuals, music synchronization licenses, clearance workflows, and royalty calculations. Powered by Rightsline, this domain enforces windowing strategies and feeds availability data to scheduling and distribution.' .

ind:Subscriber rdf:type rdfs:Class ;
    rdfs:subClassOf ind:MediaBroadcasting ;
    rdfs:label 'Subscriber' ;
    rdfs:comment 'SSOT for all subscriber and membership identities across SVOD, AVOD, TVOD, and bundled service tiers. Manages subscriber profiles, household linkage, plan enrollment, authentication credentials, device registrations, viewing entitlements, parental controls, churn tracking, and ARPU/LTV metrics. Integrates with Zuora for subscription billing and Adobe Experience Platform for personalization. Enforces GDPR, CCPA, and COPPA compliance for subscriber data.' .

ind:Audience rdf:type rdfs:Class ;
    rdfs:subClassOf ind:MediaBroadcasting ;
    rdfs:label 'Audience' ;
    rdfs:comment 'Owns audience measurement, ratings intelligence, and viewership data — Nielsen ratings, GRP/TRP/HUT/PUT metrics, sweeps period data, reach and frequency reporting, demographic segmentation, and engagement metrics. Integrates with Nielsen Media Research Platform and Adobe Experience Platform to provide the authoritative audience dataset for ad sales, programming decisions, and regulatory reporting.' .

ind:Talent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:MediaBroadcasting ;
    rdfs:label 'Talent' ;
    rdfs:comment 'Manages all on-screen and off-screen talent relationships — actors, directors, writers, producers, hosts, correspondents, and crew. Tracks talent contracts, guild affiliations (SAG-AFTRA, WGA, DGA), residual payment eligibility, exclusivity clauses, compensation structures, usage rights, appearance schedules, and credit attribution. Serves as the authoritative source for talent identity referenced by production, rights, and royalty workflows.' .

ind:Sales rdf:type rdfs:Class ;
    rdfs:subClassOf ind:MediaBroadcasting ;
    rdfs:label 'Sales' ;
    rdfs:comment 'Manages the commercial sales pipeline for advertising, content licensing, syndication, and distribution deals. Owns accounts, opportunities, proposals, rate cards, upfront commitments, agency relationships, scatter market inventory, commission structures, and executed sales contracts. Powered by Salesforce Media Cloud, this domain tracks deal stages and feeds confirmed orders to advertising trafficking and billing.' .

ind:Billing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:MediaBroadcasting ;
    rdfs:label 'Billing' ;
    rdfs:comment 'Single source of truth for all revenue transactions — subscriber invoices, advertising billing, carriage fee invoicing, syndication license fees, and payment processing. Manages billing cycles, payment methods, PCI DSS-compliant card processing, revenue recognition (ASC 606), dispute management, and makegoods. Integrates with Zuora (subscription billing), Wide Orbit (ad billing), and SAP S/4HANA (financial posting).' .

ind:Partner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:MediaBroadcasting ;
    rdfs:label 'Partner' ;
    rdfs:comment 'Manages relationships, contracts, and negotiations with studios, syndicators, content providers, MVPDs, and third-party distribution partners. Tracks partner agreements, content acquisition deals, co-production arrangements, and affiliate relationships that feed into rights, distribution, and finance domains.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:MediaBroadcasting ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Manages enterprise financial reporting, general ledger, cost centers, production budgets, EBITDA tracking, and financial reconciliation across all revenue streams (advertising, subscription, carriage fees, syndication). Integrates with SAP S/4HANA (FI/CO modules) for chart of accounts, period-end close, intercompany eliminations, and SOX-compliant financial controls. Provides the authoritative financial data layer for revenue assurance and corporate reporting.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:MediaBroadcasting ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Governs regulatory compliance obligations across broadcast licensing (FCC, Ofcom), content standards (MPA ratings, COPPA childrens content), data privacy (GDPR, CCPA), financial reporting (SOX), accessibility mandates, and technical standards (ATSC, DVB). Manages regulatory filings, license renewals, public inspection files, content clearance records, closed captioning compliance, consent management, and audit trails required by governing bodies.' .

# --- Data Product Classes (Tables) ---
ind:NielsenRating rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Audience ;
    rdfs:label 'Nielsen Rating' ;
    rdfs:comment 'Authoritative audience measurement record capturing program-level ratings data including household rating, share, HUT/PUT levels, GRP, TRP, average audience (AA), total audience (TA), cume audience, and demographic breakdowns (A18-49, A25-54, W18-49, M18-49, K2-11, etc.) for a specific program airing on a specific channel, market, and daypart. Sourced from Nielsen Media Research Platform. Includes universe estimates used as denominators for percentage calculations. The SSOT for all ratings intelligence consumed by ad sales, programming, and regulatory reporting. Supports both national and local market measurement.' .

ind:DemographicSegment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Audience ;
    rdfs:label 'Demographic Segment' ;
    rdfs:comment 'Reference master for standardized audience demographic segments used across Nielsen ratings, ad sales, and programming decisions. Defines age/gender cells (A18-49, W25-54, M18-34, K2-11, etc.), psychographic segments, income quintiles, and ethnicity classifications aligned with Nielsen and IAB standards. Used as the authoritative classification for all audience targeting and measurement reporting.' .

ind:Panel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Audience ;
    rdfs:label 'Panel' ;
    rdfs:comment 'Master record representing a Nielsen or proprietary audience measurement panel — a statistically representative sample of households or individuals used to project viewership to the total population. Captures panel type (Nielsen National People Meter, Nielsen Local People Meter, PPM, Diary, Return Path Data), panel size, geographic coverage (national or DMA-specific), demographic composition, panel vintage, recruitment methodology, weighting factors, and MRC accreditation status. Foundation for all projected audience estimates and the basis for measurement credibility.' .

ind:ViewershipRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Audience ;
    rdfs:label 'Viewership Record' ;
    rdfs:comment 'Granular transactional record of audience viewing activity for a specific content airing or stream session, capturing tuning start/end timestamps, channel or platform, device type, household or individual viewer identifier (anonymized/hashed per GDPR/CCPA), duration viewed, and completion rate. Aggregated from set-top box data, ACR (Automatic Content Recognition), and streaming platform telemetry via Adobe Experience Platform integration.' .

ind:ReachFrequencyReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Audience ;
    rdfs:label 'Reach Frequency Report' ;
    rdfs:comment 'Transactional record capturing computed reach (unduplicated audience count), frequency (average exposures per unique viewer), and effective reach (viewers exposed N+ times) for a defined campaign flight, programming block, or daypart window across a specified demographic segment, market, and measurement period. Sourced from Nielsen Media Research Platform. Used by ad sales for post-campaign delivery validation, makegoods calculation, upfront guarantee reconciliation, and scatter market pricing justification.' .

ind:MarketCoverage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Audience ;
    rdfs:label 'Market Coverage' ;
    rdfs:comment 'Master record defining a Designated Market Area (DMA) or television market — the geographic unit used for local audience measurement. Captures DMA rank, DMA code, market name, TV household universe estimate, population universe, geographic boundaries, and applicable measurement methodology (PPM vs. diary). Aligns with Nielsen DMA definitions and FCC market designations for must-carry and retransmission consent compliance.' .

ind:EngagementEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Audience ;
    rdfs:label 'Engagement Event' ;
    rdfs:comment 'Transactional record capturing a discrete digital audience engagement action on OTT/streaming platforms — including play, pause, seek, rewind, share, like, comment, and content completion events. Sourced from Adobe Experience Platform. Captures event type, content identifier, viewer session identifier (anonymized), platform, device, timestamp, and engagement depth score. Enables non-linear audience behavior analysis for programming and ad targeting.' .

ind:Guarantee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Audience ;
    rdfs:label 'Guarantee' ;
    rdfs:comment 'Master record of the audience delivery guarantee committed to an advertiser for a specific campaign or upfront deal — specifying the guaranteed GRP/TRP level, target demographic, measurement period, tolerance threshold, and makegood trigger conditions. Links to ad sales contracts and is reconciled against actual GRP delivery records. Central to revenue assurance and advertiser relationship management.' .

ind:AudienceProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Audience ;
    rdfs:label 'Audience Profile' ;
    rdfs:comment 'Anonymized/pseudonymized master record representing a unique audience member or household identity constructed from first-party data (subscriber records, app registrations, set-top box data) and third-party enrichment (Nielsen, Adobe AEP, data clean rooms). Captures hashed identity, device graph linkage, inferred demographic attributes, content affinity scores, platform preferences, viewing recency/frequency, and consent/privacy flags per GDPR, CCPA, and COPPA. Distinct from the subscriber SSOT in the subscriber domain — this is the audience intelligence and behavioral record, not the billing or subscription identity.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Audience ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Master record for a defined, reusable audience segment built from demographic, behavioral, and psychographic criteria for use in ad targeting, programming strategy, and content personalization. Captures segment name, definition logic, estimated size, demographic composition, platform applicability, activation status, and data source (Nielsen, Adobe AEP, first-party). Distinct from demographic_segment (which is a reference classification) — this is an operationally managed, business-owned targeting segment.' .

ind:Channel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Scheduling ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Master record for each linear broadcast channel — capturing network identity, call sign, transmission standard (ATSC, DVB-T/T2, QAM), logical channel number, language, resolution profile (SD/HD/UHD), and playout automation linkage to Ericsson MediaFirst. Serves as the SSOT for channel identity referenced by program schedules, EPG entries, playout events, and simulcast configurations within this domain.' .

ind:Daypart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Scheduling ;
    rdfs:label 'Daypart' ;
    rdfs:comment 'Reference definition of named broadcast time segments (e.g., Early Morning, Morning Drive, Daytime, Prime Time, Late Fringe, Overnight) used to govern ad pricing, content scheduling, and audience targeting. Captures daypart code, start/end time boundaries, day-of-week applicability, audience demographic profile, and rate multiplier. Aligns with Nielsen daypart taxonomy and Wide Orbit traffic system.' .

ind:ProgramSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Scheduling ;
    rdfs:label 'Program Schedule' ;
    rdfs:comment 'The authoritative linear channel grid (EPG backbone) representing the planned broadcast schedule for a channel on a given broadcast date. Captures schedule version, channel, broadcast date, schedule status (draft, approved, transmitted, as-run), total runtime, blackout flags, must-carry compliance status, and the Ericsson MediaFirst automation rundown reference. One record per channel per broadcast day per schedule version.' .

ind:ScheduleSlot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Scheduling ;
    rdfs:label 'Schedule Slot' ;
    rdfs:comment 'Individual time slot within a program schedule representing a single content event or break event on a linear channel. Captures slot sequence number, planned start time, planned duration, actual start time (as-run), actual duration, slot type (program, promo, commercial break, filler, PSA, EAS), content reference, daypart assignment, and live/tape flag. The atomic unit of the EPG rundown managed in Ericsson MediaFirst.' .

ind:EpgEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Scheduling ;
    rdfs:label 'Epg Entry' ;
    rdfs:comment 'Published Electronic Program Guide record distributed to MVPDs, vMVPDs, set-top boxes, and digital platforms for viewer-facing program discovery. Captures program title, episode title, series name, genre, content rating (MPA), short and long synopsis, start/end time, channel, language, closed-caption flag, HDR/resolution flag, ISAN/EIDR identifier, and distribution window. Derived from approved schedule slots and enriched with content metadata for consumer-facing EPG feeds.' .

ind:AdBreak rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Scheduling ;
    rdfs:label 'Ad Break' ;
    rdfs:comment 'Commercial break (ad pod) within a schedule slot — capturing break position (pre-roll, mid-roll, post-roll), sequence number, planned and maximum pod duration, break type (local avail, network avail, promotional), SCTE-35 cue-in/cue-out marker references, DAI eligibility flag, and Wide Orbit traffic system break ID. The structural container for sellable ad inventory within the linear schedule, linking scheduling to advertising sales fulfillment.' .

ind:SimulcastConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Scheduling ;
    rdfs:label 'Simulcast Config' ;
    rdfs:comment 'Configuration record defining a simulcast relationship where a single program or schedule is broadcast simultaneously across multiple channels or platforms (e.g., linear + OTT, HD + SD, primary + secondary feed). Captures source channel, target channel or platform, simulcast type (full-feed, partial, time-shifted), offset in seconds, audio/video profile mapping, and active date range. Drives Ericsson MediaFirst multi-feed automation.' .

ind:PlayoutEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Scheduling ;
    rdfs:label 'Playout Event' ;
    rdfs:comment 'As-run log record from Ericsson MediaFirst capturing actual transmission of each schedule slot as broadcast. Records actual start/end time, duration, content ID, channel, playout status (aired, skipped, substituted, failed), automation mode (auto, manual, override), operator ID, and deviation from planned schedule in seconds. The authoritative as-run record serving as the evidentiary basis for affidavit generation, rights usage reporting, advertiser billing reconciliation, and regulatory proof-of-performance.' .

ind:ProgramRundown rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Scheduling ;
    rdfs:label 'Program Rundown' ;
    rdfs:comment 'Detailed production rundown for a live or studio program defining the internal segment structure — news blocks, interview segments, commercial breaks, toss segments, and closing credits. Captures program title, episode reference, total runtime, segment count, live/tape flag, rundown status, and the ordered list of rundown items with planned durations. Used by Ericsson MediaFirst automation for live show playout control and by production teams for show preparation.' .

ind:RundownItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Scheduling ;
    rdfs:label 'Rundown Item' ;
    rdfs:comment 'Individual segment or item within a program rundown, representing a discrete production element (story package, live shot, interview, commercial break, graphic, music bed, or filler). Captures item sequence, item type, planned duration, actual duration, content asset reference, presenter/anchor assignment, cue text, backtime flag, and item status (ready, on-air, completed, skipped). The atomic unit of live show production control.' .

ind:SchedulingAvailabilityWindow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Scheduling ;
    rdfs:label 'Scheduling Availability Window' ;
    rdfs:comment 'Defines the on-demand programming window configuration for VOD, SVOD, AVOD, and TVOD platforms — specifying when a content title becomes available and when it expires on each platform or service tier. Captures content reference, platform type (SVOD, AVOD, TVOD, FAST), window open datetime, window close datetime, holdback flag, geographic territory, and windowing strategy (day-and-date, staggered, exclusive). Complements rights windows from the rights domain with operational scheduling parameters.' .

ind:Project rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Project' ;
    rdfs:comment 'Master record for a content production project — the greenlit initiative that drives all production activity. Captures the project title, type (scripted series, feature film, documentary, live event, news segment), greenlight status, production phase (development, pre-production, principal photography, post-production, delivery), approved budget, actual spend, production company, showrunner or executive producer, target delivery date, ISAN identifier, and integration reference to Dalet Galaxy workflow. This is the top-level anchor entity for the entire production domain.' .

ind:ShootSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Shoot Schedule' ;
    rdfs:comment 'Day-by-day principal photography schedule for a production project. Tracks shoot dates, call times, wrap times, location or studio facility, scene numbers, unit (main unit, second unit, splinter unit), director, first assistant director, estimated vs actual shoot hours, weather contingency flags, and schedule revision version. Integrates with facility booking and crew assignment to coordinate all on-set resources. Distinct from the EPG scheduling domain which governs broadcast playout.' .

ind:Budget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Budget' ;
    rdfs:comment 'Detailed production budget record aligned to the SAP S/4HANA CO (Controlling) module. Captures above-the-line and below-the-line cost categories, approved budget amounts by cost category, revised budget amounts, actual costs to date, purchase order commitments, variance amounts, currency, budget version, and approval status. Serves as the financial control baseline for a production project. Links to SAP cost centers and WBS elements for financial reconciliation.' .

ind:BudgetLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Budget Line' ;
    rdfs:comment 'Individual line-item within a production budget, representing a specific cost category or account code (e.g., cast fees, location fees, equipment rental, VFX, music licensing, post-production labor). Captures account code, cost category, sub-category, vendor or payee, budgeted amount, committed amount, actual amount, episode or segment allocation, and SAP G/L account reference. Enables granular cost tracking and variance analysis at the line-item level.' .

ind:CrewAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Crew Assignment' ;
    rdfs:comment 'Assignment of a crew member to a specific production project in a defined role and department. Captures crew role (director, DP, gaffer, script supervisor, editor, colorist, VFX supervisor, sound mixer), department (camera, grip, electric, art, wardrobe, hair/makeup, post-production), start date, end date, deal type (daily, weekly, flat), contracted rate, union or guild affiliation (DGA, IATSE, SAG-AFTRA), overtime eligibility, work permit status, and assignment status. References the talent domain for the crew members master record. Tracks the full below-the-line crew roster for a production.' .

ind:FacilityBooking rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Facility Booking' ;
    rdfs:comment 'Reservation and usage record for a production facility — soundstage, editing suite, dubbing stage, color grading suite, ADR studio, screening room, or post-production bay. Captures facility name, facility type, location, booking start datetime, booking end datetime, booked production project, booked episode or segment, booking status (tentative, confirmed, cancelled), rate per hour or day, total cost, and technical specifications of the facility. Enables resource conflict detection and cost allocation.' .

ind:EquipmentAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Equipment Allocation' ;
    rdfs:comment 'Allocation record tracking the assignment of production equipment (cameras, lenses, lighting rigs, sound packages, jibs, drones, editing workstations, encoding hardware) to a production project or shoot day. Captures equipment item, equipment category, serial number, rental vendor or owned asset flag, allocation start date, allocation end date, daily or weekly rental rate, insurance value, condition at checkout, condition at return, and responsible crew member. Supports equipment cost tracking and loss/damage management.' .

ind:ProductionEpisode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Production Episode' ;
    rdfs:comment 'Master record for an individual episode, segment, or installment within a production project (series, mini-series, anthology, or episodic documentary). Captures episode number, episode title, season number, running time target, production status, writer, director, script lock date, picture lock date, audio mix completion date, delivery date, and ISAN episode identifier. Acts as the granular production unit below the project level for episodic content.' .

ind:Script rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Script' ;
    rdfs:comment 'Master record for a production script or screenplay associated with a production project or episode. Captures script title, version number, draft type (outline, first draft, revised draft, shooting script, post-production script), writer credits, WGA registration number, page count, script lock status, lock date, language, and Dalet Galaxy document reference. Tracks the full script revision history and serves as the authoritative script record for production and rights purposes.' .

ind:PostProductionTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Post Production Task' ;
    rdfs:comment 'Individual post-production work task within the Dalet Galaxy workflow orchestration pipeline. Captures task type (offline edit, online conform, VFX composite, color grade, audio mix, ADR record, subtitle burn-in, QC review, transcode, archive ingest), assigned operator or vendor, task status (queued, in-progress, review, approved, rejected, complete), priority, due date, actual completion date, parent episode or deliverable, and Dalet Galaxy workflow task ID. Enables end-to-end post-production workflow tracking.' .

ind:Deliverable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Deliverable' ;
    rdfs:comment 'Contractually or operationally required output deliverable from a production project — the specific media asset or document that must be produced and handed off. Captures deliverable name, deliverable type (broadcast master, streaming master, promo cut, trailer, EPK, closed caption file, audio description track, subtitles, M&E track, textless version, compliance certificate), target format, target platform or recipient, due date, actual delivery date, delivery status, and QC pass/fail flag. Links to the digital asset management domain upon delivery.' .

ind:QcReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Qc Review' ;
    rdfs:comment 'Quality control review record for a production deliverable or post-production output. Captures QC type (technical QC, editorial QC, compliance QC, accessibility QC, loudness QC), QC operator, review date, pass/fail/conditional result, error count by severity (P1 critical, P2 major, P3 minor), specific error codes per EBU R128/ATSC A/85 loudness standards and ITU-R BT.1788 video quality standards, remediation required flag, re-QC date, and final approval status. Ensures all deliverables meet broadcast and platform technical specifications before distribution. Feeds the deliverable acceptance workflow.' .

ind:Milestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Milestone' ;
    rdfs:comment 'Key milestone event in the production lifecycle for a project or episode. Captures milestone type (greenlight, pre-production start, first day of photography, picture lock, audio mix complete, VFX complete, final QC pass, delivery to broadcaster, archive complete), planned date, actual date, milestone status (upcoming, at-risk, achieved, missed), responsible owner, and any associated approval or sign-off requirement. Enables production schedule tracking and stakeholder reporting against key delivery gates.' .

ind:Location rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Location' ;
    rdfs:comment 'Master record for a physical production location — an on-location shoot site used for principal photography or second unit work. Captures location name, address, GPS coordinates, country, region, location type (practical interior, practical exterior, backlot, remote, international), location scout approval status, permit status, permit authority, permit expiry date, location fee, safety assessment status, noise assessment, sunrise/sunset data relevance, parking and base camp capacity, and contact details for the location owner or manager. Distinct from facility_booking which covers controlled studio and post-production facilities.' .

ind:FormatSpec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Format Spec' ;
    rdfs:comment 'Reference record defining the technical production format specification for a project or deliverable — the agreed capture and delivery format standard. Captures format name, frame rate (23.976, 25, 29.97, 50, 59.94), resolution (HD 1080i, HD 1080p, UHD 4K, 8K), aspect ratio, color space (Rec.709, Rec.2020, P3), HDR standard (HDR10, Dolby Vision, HLG), audio configuration (5.1, 7.1, Atmos), codec, container format, and applicable broadcast standard (ATSC, DVB). Serves as the technical specification baseline for all production and post-production work.' .

ind:OttPlatform rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Ott Platform' ;
    rdfs:comment 'Master registry of all OTT service platforms operated by Media Broadcasting — web, mobile, connected TV (CTV), and set-top box (STB). Captures platform identity, service tier (SVOD, AVOD, TVOD, FAST), launch date, supported protocols (HLS, MPEG-DASH), DRM system bindings, CDN provider assignments, geographic availability, regulatory jurisdiction, brand identity, and operational status. This is the SSOT anchor for the entire platform domain — all other platform products reference back to this entity.' .

ind:DeviceType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Reference catalog of all device categories and models supported across OTT platforms — smart TVs, mobile phones, tablets, desktop browsers, streaming sticks, gaming consoles, and STBs. Captures device category, manufacturer, OS family, OS version range, screen resolution class, HDR capability, DRM compatibility (Widevine, PlayReady, FairPlay), ABR profile support, and certification status. Used for device-specific playback configuration and QoS segmentation.' .

ind:StreamingEndpoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Streaming Endpoint' ;
    rdfs:comment 'Master record of all streaming origin and edge endpoints managed across the CDN infrastructure (Akamai CDN). Captures endpoint URL, CDN provider, PoP (Point of Presence) region, protocol (HLS, MPEG-DASH), ABR ladder configuration reference, DRM license server URL, token authentication scheme, geo-restriction rules, failover endpoint reference, SLA tier, and operational status. SSOT for the technical delivery address of each stream.' .

ind:AbrProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Abr Profile' ;
    rdfs:comment 'Defines Adaptive Bitrate (ABR) encoding ladder profiles used for multi-platform streaming delivery. Captures profile name, codec (H.264, H.265/HEVC, AV1, VP9), container format (fMP4, TS), rendition count, per-rendition bitrate/resolution/frame-rate specifications, audio codec and channel configuration, HDR/SDR flag, MPEG-DASH or HLS manifest template reference, and target device class. Governs the encoding farm (transcode) output specifications.' .

ind:PlaybackSession rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Playback Session' ;
    rdfs:comment 'Transactional record of each individual viewer playback session initiated on the OTT platform. Captures session ID, subscriber/device reference, content asset reference, session start and end timestamps, platform and app version, device type, streaming endpoint used, ABR profile, DRM policy applied, initial buffering duration, average bitrate, rebuffering events count, total watch duration, exit reason (user-initiated, error, completion), CDN PoP served, and geographic location. Primary operational event for QoS monitoring and audience measurement.' .

ind:DaiConfiguration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Dai Configuration' ;
    rdfs:comment 'Configuration records for Dynamic Ad Insertion (DAI) on the OTT platform — defining ad pod placement rules, SCTE-35 signal handling, ad decision server (ADS) endpoints, fill-rate fallback logic, ad stitching mode (server-side vs client-side), blackout override rules, and frequency cap enforcement. Captures DAI config name, applicable content type (VOD, live), ad server URL, timeout thresholds, and effective date. Bridges the platform domain with the advertising domain\'s campaign delivery.' .

ind:DistributionPartner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Distribution Partner' ;
    rdfs:comment 'Master record for all distribution partners including MVPDs (cable, satellite, telco), vMVPDs, OTT platform operators, FAST aggregators, and syndication outlets. Captures partner identity, tier classification, distribution footprint (geographic markets served), carriage capacity, technical delivery capabilities (DVB, ATSC, HLS, MPEG-DASH), and commercial relationship status. SSOT for distribution partner identity within the distribution domain — distinct from the enterprise partner domain which owns broader commercial relationships.' .

ind:CarriageAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Carriage Agreement' ;
    rdfs:comment 'Contractual record governing the terms under which a channel or content package is carried by an MVPD, vMVPD, or OTT platform. Covers both retransmission consent agreements (FCC-regulated authorization for MVPDs to rebroadcast OTA signals) and standard carriage contracts. Captures agreement type (retransmission consent, must-carry, voluntary carriage), retransmission consent terms, must-carry election status, carriage fee rates, channel positioning tiers, geographic coverage (authorized DMAs), exclusivity windows, holdback restrictions, compensation terms (cash, channel carriage, promotional commitments), contract effective/expiry dates, and negotiation history. Links to distribution partner and channel master. Distinct from rights licensing contracts owned by the rights domain.' .

ind:CarriageFeeInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Carriage Fee Invoice' ;
    rdfs:comment 'Transactional billing record for carriage fees owed by or to distribution partners under active carriage agreements. Captures invoice period, fee amount, fee basis (per-subscriber, flat-rate, tiered), currency, payment due date, payment status, and reconciliation flags. Supports revenue assurance and financial reconciliation processes. Distinct from subscriber invoices (owned by billing domain) and advertising invoices (owned by advertising domain).' .

ind:DeliveryChannel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'Master definition of a logical distribution channel — a named, configured delivery pathway through which content is transmitted to audiences. Covers linear broadcast channels (DVB-T, DVB-S, ATSC, QAM), OTT streaming channels, FAST channels (Pluto TV, Tubi, Samsung TV Plus, Roku Channel), and simulcast feeds. Captures channel name, call sign, channel number, channel type (linear, OTT, FAST, simulcast), delivery technology standard, resolution/format, language, target market, EPG linkage, operational status, and FAST-specific attributes where applicable (aggregator platform, playlist type, ad insertion method, content refresh cadence, monetization model). SSOT for channel identity within the distribution domain.' .

ind:DrmPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Drm Policy' ;
    rdfs:comment 'Reference master defining Digital Rights Management packaging and enforcement policies applied to content streams. Captures DRM system (Widevine, PlayReady, FairPlay), license server endpoint, key rotation interval, output control rules (HDCP level, analog sunset), geo-restriction enforcement flag, offline download permissions, concurrent stream limits, and token expiry settings. Governs how content is protected during OTT and MVPD delivery.' .

ind:CdnConfiguration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Cdn Configuration' ;
    rdfs:comment 'Master configuration record for CDN (Akamai) delivery properties assigned to a delivery channel or OTT service. Captures CDN provider, property hostname, origin pull URL, caching rules (TTL, cache-control headers), token authentication settings, geo-blocking rules, failover origin configuration, SSL certificate reference, and SLA tier. Enables operations teams to manage Akamai CDN settings per channel and delivery endpoint.' .

ind:SignalRoute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Signal Route' ;
    rdfs:comment 'Master record defining the end-to-end signal routing path for a broadcast or streaming feed — from playout origin through satellite uplink, terrestrial transmission, CDN origin, or IP interconnect to the distribution endpoint. Captures source playout system (Ericsson MediaFirst), transport protocol (HLS, MPEG-DASH, UDP/TS, DVB-S2), uplink/downlink transponder details, IRD configuration, primary and backup path definitions, and failover priority. Critical for linear broadcast operations.' .

ind:ReleaseWindow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Release Window' ;
    rdfs:comment 'Master record defining the sequential release windowing strategy for a content title across distribution platforms and channels. Captures window type (theatrical, SVOD, AVOD, TVOD, linear, FAST, syndication), platform or channel assignment, window open date, window close date, holdback period, exclusivity flag, and territory scope. Implements the windowing strategy derived from rights agreements and commercial distribution deals. Complements the rights domain\'s window records by focusing on operational delivery scheduling.' .

ind:DeliveryEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Delivery Event' ;
    rdfs:comment 'Transactional record capturing each discrete content delivery event — including stream session initiations, linear broadcast transmissions, VOD asset deliveries, FAST channel playout events, and dynamic ad insertion (DAI) sessions. Captures event timestamp, event type (stream_start, vod_delivery, broadcast_tx, dai_insertion), delivery channel, content asset reference, delivery technology (HLS, MPEG-DASH, DVB, ATSC), CDN node, geographic region, stream quality (bitrate, resolution), delivery status (success, failure, degraded), error codes, and DAI-specific attributes (ad pod position, SCTE-35 signal, fill rate) where applicable. Feeds delivery SLA monitoring, CDN performance reporting, and AVOD/FAST monetization reconciliation.' .

ind:Title rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Title' ;
    rdfs:comment 'Master catalog record for every content asset across the enterprise — films, series, episodes, clips, music tracks, news segments, and live events. Serves as the authoritative SSOT for content identity, carrying EIDR, ISAN, and ISRC identifiers, MPA content rating, genre classification, original language, country of origin, production year, content type discriminator (film/series/episode/clip/music/news/live), runtime in seconds, content status (active/archived/restricted), parental advisory flags, COPPA child-directed flag, and lifecycle timestamps. Acts as the universal join point referenced by scheduling, distribution, rights, digital asset, and advertising domains. Format-level technical specifications are managed by the version and digital asset domains.' .

ind:Series rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Series' ;
    rdfs:comment 'Master record for a serialized content franchise or show brand — the parent container above seasons and episodes. Captures series title, franchise identifier, series type (scripted/unscripted/documentary/news/sports/reality), total season count, original network/platform, premiere date, finale date, series status (ongoing/ended/cancelled/hiatus), genre taxonomy, target demographic, content rating band, and brand metadata. Enables hierarchical content navigation from series → season → episode and supports scheduling, rights windowing, and syndication deal structures.' .

ind:Season rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Season' ;
    rdfs:comment 'Master record representing a discrete production cycle of a series, grouping episodes into an ordered season. Tracks season number, season title, episode count (ordered and total), production year, original air year, season status (in-production/completed/archived), season-level content rating, season-level synopsis, and promotional artwork references. Bridges the series-to-episode hierarchy and supports season-level rights licensing, scheduling blocks, and VOD packaging.' .

ind:ContentEpisode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Content Episode' ;
    rdfs:comment 'Master record for an individual episode within a series season. Captures episode number, episode title, production code, original broadcast date, runtime, episode type (standard/special/pilot/finale/recap), episode synopsis, content rating, EIDR episode identifier, closed-caption availability flag, audio description flag, and episode status. Supports EPG scheduling, VOD availability windows, rights clearance at episode level, and residuals calculation for talent reuse payments.' .

ind:Version rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Version' ;
    rdfs:comment 'Tracks every distinct version of a title — including edits, cuts, localized dubs, censored versions, broadcast-safe edits, theatrical vs. extended cuts, and format variants (SD/HD/4K). Each version record carries version type (theatrical/broadcast/director/unrated/censored/dubbed/subtitled), version label, target territory, target platform, runtime delta from master, language track configuration, subtitle language list, aspect ratio override, and version status. Enables multi-platform distribution where different versions are delivered to different windows and territories.' .

ind:Genre rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Genre' ;
    rdfs:comment 'Enterprise reference taxonomy for content genre and sub-genre classification. Captures genre code, genre name, parent genre reference (enabling hierarchical sub-genres like Drama > Legal Drama), genre tier (primary/secondary), applicable content types, IAB content category mapping for ad targeting, and active status. Standardizes genre labeling across EPG systems, streaming platform metadata feeds, and advertising contextual targeting to ensure consistent audience segmentation and content discovery.' .

ind:Rating rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Rating' ;
    rdfs:comment 'Reference table for MPA, TV Parental Guidelines, and international content rating classifications applied to titles. Captures rating code (G/PG/PG-13/R/NC-17/TV-Y/TV-G/TV-PG/TV-14/TV-MA and international equivalents), rating system (MPA/TVPG/BBFC/FSK/etc.), rating body, applicable territory, minimum age indicator, content descriptor codes (violence/language/nudity/drug-use), and regulatory mandate flags. Supports FCC compliance, COPPA enforcement, and parental control features across linear and OTT platforms.' .

ind:Localization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Localization' ;
    rdfs:comment 'Tracks the localization work product for a specific title version in a target language and territory — covering dubbing, subtitling, metadata translation, and compliance adaptation. Captures localization type (dub/subtitle/metadata/forced-narrative), target language, target territory, localization vendor, delivery date, localization status (ordered/in-progress/delivered/approved/rejected), QC pass flag, subtitle format (SRT/TTML/WebVTT), and dubbing studio reference. Supports multi-territory distribution and regulatory compliance for local-language requirements.' .

ind:TalentCredit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Talent Credit' ;
    rdfs:comment 'Association entity linking talent identities (owned by the talent domain) to specific titles and episodes with their credited role, billing position, character name, credit type (on-screen/off-screen), and credit display order. Captures SAG-AFTRA/WGA/DGA union affiliation flag, residuals eligibility flag, and credit approval status. Serves as the content domain\'s authoritative credit roll for EPG metadata delivery, streaming platform cast display, and residuals calculation triggers. Does not duplicate the talent master record — references it via FK to the talent domain.' .

ind:Acquisition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Acquisition' ;
    rdfs:comment 'Transactional record capturing the business event of acquiring content from an external source — studio, independent producer, syndicator, or distributor. Tracks acquisition type (purchase/license/co-production/commission), acquisition date, source party, acquisition cost, currency, content window acquired, territory scope, exclusivity flag, holdback period, acquisition status (negotiating/committed/delivered/cancelled), and originating deal reference. Serves as the financial and operational anchor for content entering the enterprise catalog from external sources.' .

ind:WindowingPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Windowing Plan' ;
    rdfs:comment 'Defines the content-side release sequencing strategy for a title across distribution channels — theatrical, SVOD, AVOD, TVOD, linear broadcast, home video, and syndication. Each record captures window type, platform/channel, territory, planned open date, planned close date, holdback duration, exclusivity tier, and window status. Represents the content team\'s intended release plan that feeds into the rights domain for contractual enforcement and the distribution domain for operational execution. Distinct from rights windows (which are contractual) — this is the editorial/commercial planning artifact.' .

ind:MetadataProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Metadata Profile' ;
    rdfs:comment 'Stores the full descriptive metadata set for a title as delivered to a specific platform or metadata standard — EPG, streaming platform, MVPD, search index, or press/publicity. Captures metadata standard (EIDR/Dublin Core/EBUCore/TVAnytime/schema.org), target platform, long synopsis, short synopsis, keyword tags, cast summary, director credit, production company, distributor, promotional tagline, metadata language, delivery date, and validation status. Enables platform-specific metadata packaging without polluting the core title master record.' .

ind:Artwork rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Artwork' ;
    rdfs:comment 'Master catalog of promotional and editorial artwork assets associated with a title — key art, thumbnail images, banner graphics, poster images, and logo treatments. Captures artwork type (key-art/thumbnail/banner/poster/logo/still), image dimensions, aspect ratio, file format, color profile, territory applicability, language overlay flag, approved-for-use flag, approval date, expiry date, and source system reference (Dalet Galaxy DAM). Supports EPG display, streaming platform UI, press kits, and advertising creative without duplicating the binary asset record owned by the digital asset domain.' .

ind:Tag rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Tag' ;
    rdfs:comment 'Flexible editorial and operational tagging of titles with controlled vocabulary terms beyond genre — mood, theme, setting, era, franchise, universe, content warning, editorial collection, and campaign tag. Each record captures tag type, tag value, tag source (editorial/algorithmic/partner), confidence score for algorithmic tags, applied date, and active status. Powers content discovery, recommendation engines, advertising contextual targeting, and editorial curation across OTT and linear platforms.' .

ind:Package rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Package' ;
    rdfs:comment 'Defines a curated bundle of titles assembled for a specific commercial or distribution purpose — a syndication package, SVOD library deal, MVPD carriage bundle, or FAST channel lineup. Captures package name, package type (syndication/svod-library/avod-catalog/fast-channel/educational/international), package status, effective date, expiry date, territory scope, exclusivity flag, and the commercial context it was assembled for. Acts as the content-side counterpart to distribution and rights deal structures.' .

ind:BroadcastLicense rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Broadcast License' ;
    rdfs:comment 'Master record for all broadcast licenses and spectrum authorizations issued by regulatory bodies (FCC, Ofcom, ACMA, CRTC) held by the organization. Tracks license type (AM, FM, TV full-power, TV low-power, satellite, cable franchise, IPTV), call sign, facility ID, frequency band, channel number, power output (ERP), coverage area (contour), community of license, license class, grant date, expiration date, renewal status, modification history, and the governing regulatory authority. Serves as the authoritative registry of all spectrum and broadcast operating authorities and the anchor entity for per-station compliance obligations.' .

ind:LicenseRenewal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'License Renewal' ;
    rdfs:comment 'Tracks the lifecycle of broadcast license renewal applications submitted to the FCC, Ofcom, or other regulatory bodies. Captures renewal cycle, filing deadline, submission date, application status, renewal fee, public notice period, petitions to deny, and final disposition. Ensures no license lapses due to missed renewal windows.' .

ind:RegulatoryFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Filing' ;
    rdfs:comment 'Authoritative record of all regulatory filings submitted to governing bodies including FCC, Ofcom, MPA, IAB, and others. Captures filing type (EEO report, ownership report, political file, children\'s programming report, annual report), form number, filing date, due date, submission method, filing status, confirmation number, and the responsible regulatory body. Supports SOX, FCC, and Ofcom compliance obligations.' .

ind:PublicInspectionFile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Public Inspection File' ;
    rdfs:comment 'Manages the FCC-mandated public inspection file (OPIF) for each licensed broadcast station. Tracks document categories (political file, EEO reports, ownership disclosures, children\'s programming reports, issues/programs lists, contour maps), document upload status, retention period, public access status, and FCC OPIF portal sync status. Required for all FCC-licensed stations under 47 CFR §73.3526 and §73.3527.' .

ind:ContentRating rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Content Rating' ;
    rdfs:comment 'Master registry of content ratings assigned to programming assets per MPA, TV Parental Guidelines, and international rating systems (BBFC, FSK, etc.). Captures rating system, rating value (G, PG, PG-13, R, NC-17; TV-Y, TV-Y7, TV-G, TV-PG, TV-14, TV-MA), content descriptors (violence, language, sexual content, drug use), rating authority, rating date, and applicability by territory. Links to content assets in the content domain.' .

ind:PrivacyRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Privacy Request' ;
    rdfs:comment 'Tracks data subject rights requests submitted under GDPR (right to access, erasure, portability, rectification, restriction) and CCPA (right to know, delete, opt-out of sale). Captures request type, requestor identity, submission channel, verification status, assigned handler, regulatory deadline (30-day GDPR / 45-day CCPA), fulfillment status, and response date. Ensures timely compliance with data subject rights obligations.' .

ind:ClosedCaptionRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Closed Caption Record' ;
    rdfs:comment 'Compliance record for closed captioning obligations under FCC rules (47 CFR §79.1) and Ofcom requirements. Tracks program title, air date, channel, caption file format (SRT, SCC, TTML, WebVTT), caption accuracy score, caption latency (for live programming), caption completeness percentage, complaint reference, remediation status, and exemption basis if applicable. Supports FCC caption quality standards and complaint response workflows.' .

ind:AccessibilityObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Accessibility Obligation' ;
    rdfs:comment 'Master record of accessibility compliance obligations applicable to the organization\'s content and platforms, including closed captioning, audio description (AD), video description, emergency alert accessibility, and online video player accessibility under CVAA, ADA, and Ofcom accessibility codes. Captures obligation type, applicable regulation, scope (linear, VOD, OTT), compliance deadline, responsible team, and current compliance status.' .

ind:EasLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Eas Log' ;
    rdfs:comment 'Operational log of Emergency Alert System (EAS) activations and tests for FCC-licensed broadcast stations. Captures alert type (national, state, local), alert originator (FEMA IPAWS, NWS, state/local authority), activation timestamp, relay chain, transmission status, duration, required monthly/weekly test compliance, and any missed alert incidents. Required under FCC 47 CFR Part 11 for all EAS participants.' .

ind:PoliticalAdRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Political Ad Record' ;
    rdfs:comment 'Compliance record for political advertising under FCC political broadcasting rules (47 CFR §73.1940, §73.1941, §73.1942). Tracks candidate or issue advertiser, federal/state/local race, lowest unit charge (LUC) rate applied, equal opportunities requests, reasonable access requests, sponsorship identification, air date and time, and public file disclosure. Mandatory for all FCC-licensed stations during election periods.' .

ind:RegulatoryObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Obligation' ;
    rdfs:comment 'Master catalog of all regulatory obligations applicable to the organization, mapped to specific regulations, governing bodies, and business units. Captures obligation type, regulation name, regulatory body, jurisdiction, obligation description, applicability scope (linear TV, OTT, radio, digital), compliance frequency (ongoing, annual, quarterly, event-driven), responsible owner, and current compliance status. Serves as the compliance obligation register.' .

ind:TalentProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Talent ;
    rdfs:label 'Talent Profile' ;
    rdfs:comment 'Master identity record for all on-screen and off-screen talent — actors, directors, writers, producers, hosts, correspondents, crew, and voice artists. Stores legal name, stage name, date of birth, nationality, gender identity, primary language, union membership references, talent tier classification, representation agency references, IMDb/ISNI identifiers, biometric consent flags, data privacy status (GDPR/CCPA), clearance status, and active/inactive lifecycle state. Serves as the authoritative SSOT for talent identity referenced by production, rights, royalty, and scheduling workflows across the enterprise.' .

ind:GuildAffiliation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Talent ;
    rdfs:label 'Guild Affiliation' ;
    rdfs:comment 'Tracks each talent\'s formal membership and standing within entertainment industry guilds and unions — SAG-AFTRA, WGA (Writers Guild of America), DGA (Directors Guild of America), IATSE, AFM (American Federation of Musicians), and international equivalents (BECTU, ACTRA). Records membership number, guild code, membership tier (full member, fi-core, apprentice), join date, current standing (good standing, suspended, resigned), dues payment status, and applicable collective bargaining agreement (CBA) version. Critical for residual eligibility determination and production compliance.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Talent ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Authoritative record of each talent engagement from initial deal memo through executed long-form contract — covering series regular deals, episodic guest agreements, overall deals, first-look deals, and crew contracts. Captures contract lifecycle stage (deal memo, countersigned, long-form executed), compensation structure (base fee, guarantees, backend participation, step-ups, pay-or-play), exclusivity and holdback restrictions, option periods with exercise status, amendment history, billing credit position, governing CBA, and document references. Source of truth for all commercial terms, obligations, and contractual modifications throughout the talent engagement lifecycle.' .

ind:CompensationStructure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Talent ;
    rdfs:label 'Compensation Structure' ;
    rdfs:comment 'Defines the detailed compensation terms attached to a talent contract — including base episode fee, weekly guarantee, daily rate, overtime multipliers, pension and health (P&H) contribution rates, residual base formula, backend gross participation percentage, deferred compensation schedule, and currency. Supports both union scale (SAG-AFTRA scale, DGA scale) and over-scale deals. Tracks step-up triggers (e.g., series pickup escalators), bonus thresholds, and pay-or-play provisions. Used by payroll and royalty workflows to calculate gross compensation and residual bases.' .

ind:AppearanceSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Talent ;
    rdfs:label 'Appearance Schedule' ;
    rdfs:comment 'Operational schedule of talent time allocation — covering confirmed bookings, holds (first/second/third), first refusals, availability windows, and personal unavailability alongside specific call times for principal photography, ADR sessions, promotional appearances, press junkets, and live broadcast slots. Records production reference, call date/time, wrap time, location, appearance type, hold level, confirmation status, and release tracking. Integrates with production scheduling and playout systems to ensure talent availability aligns with broadcast calendars.' .

ind:ResidualPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Talent ;
    rdfs:label 'Residual Payment' ;
    rdfs:comment 'Transactional record of each residual payment issued to talent for reuse of content across broadcast, home video, streaming (SVOD, AVOD, TVOD), FAST, and foreign distribution windows. Captures payment cycle, content asset reference, use type, distribution window, gross residual amount, P&H contribution amount, withholding tax amount, net payment amount, payment method, payment date, check or ACH reference, and remittance advice sent flag. Reconciles against Rightsline royalty calculations and SAP S/4HANA AP postings. Supports SAG-AFTRA and WGA audit requirements.' .

ind:DealMemo rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Talent ;
    rdfs:label 'Deal Memo' ;
    rdfs:comment 'Pre-contract deal memo capturing the agreed commercial terms for a talent engagement before the formal long-form contract is executed — including deal date, production title, role or function, episode count, start date, compensation summary, credit position, exclusivity summary, option terms, and deal memo status (draft, countersigned, superseded by long-form). Serves as the binding interim agreement used by production and legal teams during the gap between verbal deal and executed contract. Sourced from Salesforce Media Cloud opportunity and proposal records.' .

ind:Role rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Talent ;
    rdfs:label 'Role' ;
    rdfs:comment 'Defines the specific role or function a talent is engaged to perform within a production or content asset — capturing role name, character name (for on-screen talent), role category (series regular, recurring, guest star, day player, featured extra, host, correspondent, narrator, voice artist, director, writer, showrunner, executive producer, line producer, DP, editor), above-the-line or below-the-line classification, episode or segment scope, and role status. Provides the granular link between talent identity and their specific creative contribution to each content asset.' .

ind:TalentAgency rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Talent ;
    rdfs:label 'Talent Agency' ;
    rdfs:comment 'Master record for talent representation agencies and management companies — capturing agency legal name, agency type (talent agency, literary agency, management company, law firm), primary contact, address, phone, email, franchise status (SAG-AFTRA franchised agency flag), commission rate standard, and active/inactive status. Serves as the reference for routing deal negotiations, contract correspondence, and residual remittances to the correct representative. Distinct from the partner domain which manages distribution and content partners.' .

ind:RepresentationAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Talent ;
    rdfs:label 'Representation Agreement' ;
    rdfs:comment 'Records the formal representation relationship between a talent and their agency or management company — capturing representation type (exclusive agent, co-agent, manager, entertainment attorney), territory scope, commission percentage, agreement start and end dates, exclusivity flag, termination notice period, and current status. Tracks historical representation changes to support residual routing and deal negotiation audit trails. A talent may have multiple concurrent representation agreements across different territories or function types.' .

ind:Availability rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Talent ;
    rdfs:label 'Availability' ;
    rdfs:comment 'Operational record of a talent\'s confirmed availability or unavailability for production bookings — capturing availability window start and end dates, availability type (available, hold, first refusal, confirmed booking, personal unavailability, conflicting production), hold level (first hold, second hold, third hold), requesting production, and release date if hold is dropped. Supports production scheduling, casting decisions, and conflict resolution across concurrent productions. Integrates with appearance_schedule and Dalet Galaxy workflow orchestration.' .

ind:CbaRateCard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Talent ;
    rdfs:label 'Cba Rate Card' ;
    rdfs:comment 'Reference table of minimum scale rates and contribution percentages defined by each Collective Bargaining Agreement (CBA) applicable to Media Broadcasting — covering SAG-AFTRA Codified Basic Agreement, SAG-AFTRA Television Agreement, DGA Basic Agreement, WGA Minimum Basic Agreement, and IATSE Basic Agreement. Captures rate type (day rate, weekly rate, episodic rate, theatrical rate), performer category, effective date, expiration date, P&H contribution rate, and overtime multiplier. Used by compensation_structure and residual_eligibility to validate scale compliance.' .

ind:Partner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Partner Partner' ;
    rdfs:comment 'Master record for all external business partners including studios, syndicators, content providers, MVPDs, vMVPDs, FAST channel operators, and third-party distribution partners. Serves as the SSOT for partner identity, classification, legal entity details, and relationship status. Tracks partner type (studio, syndicator, MVPD, OTT aggregator, co-production house), corporate hierarchy, domicile jurisdiction, and onboarding lifecycle stage.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Individual contacts associated with a partner organization — executives, legal representatives, business development leads, technical liaisons, and finance contacts. Tracks name, title, role type, communication preferences, and relationship owner within Media Broadcasting. Supports negotiation workflows and partner relationship management.' .

ind:AcquisitionDeal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Acquisition Deal' ;
    rdfs:comment 'Master record for content acquisition deals negotiated with studios, syndicators, and independent content providers. Captures deal structure (flat fee, revenue share, MG/minimum guarantee), content package scope, exclusivity terms, territory coverage, windowing strategy (SVOD, AVOD, TVOD, linear), and deal status through the full negotiation-to-execution lifecycle. Source of truth for content acquisition commitments feeding into the rights and finance domains.' .

ind:AcquisitionDealLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Acquisition Deal Line' ;
    rdfs:comment 'Individual line items within a content acquisition deal, each representing a specific title, episode, season, or content package with its own financial terms, window schedule, territory rights, and delivery obligations. Enables granular tracking of per-title economics within a multi-title deal and feeds rights windowing and royalty calculation processes.' .

ind:DistributionAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Distribution Agreement' ;
    rdfs:comment 'Formal distribution agreements with MVPDs, vMVPDs, cable operators, satellite providers, and OTT aggregators governing carriage of Media Broadcasting channels and content. Tracks carriage fee structures, must-carry obligations, retransmission consent terms, blackout restrictions, channel positioning commitments, and SLA obligations. Distinct from content acquisition deals — this governs outbound distribution rather than inbound content.' .

ind:SyndicationAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Syndication Agreement' ;
    rdfs:comment 'Agreements governing the syndication of Media Broadcasting content to third-party broadcasters, regional stations, and international networks. Captures syndication fee structure, exclusivity windows, holdback periods, territory grants, episode count, run limitations, and clearance obligations. Feeds the scheduling and rights domains for cleared content availability.' .

ind:CoproductionAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Coproduction Agreement' ;
    rdfs:comment 'Co-production arrangements with studios, production houses, and international broadcasters for jointly financed and produced content. Tracks co-production budget splits, creative control provisions, IP ownership percentages, territorial distribution rights allocation, credit obligations, and residuals sharing. Bridges the partner, production, and rights domains.' .

ind:AffiliateAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Affiliate Agreement' ;
    rdfs:comment 'Affiliate relationship agreements with local broadcast stations, regional affiliates, and network affiliate groups. Tracks affiliation fees, network compensation, programming obligations, local insertion rights, must-air requirements, and affiliate performance standards. Distinct from MVPD distribution agreements — affiliates are broadcast station partners, not pay-TV distributors.' .

ind:DeliveryObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Delivery Obligation' ;
    rdfs:comment 'Tracks specific content delivery obligations owed to or from partners under acquisition, syndication, and co-production agreements. Captures required delivery format (HLS, MPEG-DASH, ISAN-tagged mezzanine), delivery deadline, technical specification compliance (ATSC, DVB), delivery status, and acceptance confirmation. Bridges partner agreements with the digital asset and distribution domains.' .

ind:CarriageFeeSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Carriage Fee Schedule' ;
    rdfs:comment 'Fee schedule governing carriage payments from MVPDs and vMVPDs for distribution of Media Broadcasting channels. Defines per-subscriber fee tiers, escalation clauses, most-favored-nation (MFN) provisions, volume discount thresholds, and payment frequency. Reference entity used to calculate carriage fee invoices in the billing domain.' .

ind:MinimumGuarantee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Minimum Guarantee' ;
    rdfs:comment 'Minimum guarantee (MG) commitments within content acquisition deals — the floor payment owed to a content provider regardless of actual viewership or revenue performance. Tracks MG amount, recoupment schedule, earned-against-MG balance, recoupment waterfall, and overage terms. Critical for financial reconciliation and royalty management in the finance and rights domains.' .

ind:PaymentTerm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Payment Term' ;
    rdfs:comment 'Payment terms and schedules agreed with partners for acquisition fees, carriage fees, syndication fees, and co-production cost contributions. Captures payment milestones, due dates, currency, payment method, late payment penalty clauses, and withholding tax obligations by jurisdiction. Used by the billing domain to generate partner-facing invoices and payment schedules.' .

ind:TerritoryGrant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Territory Grant' ;
    rdfs:comment 'Specific territorial rights grants within partner agreements — defining the geographic scope (country, region, DMA, blackout zone) for which content rights are licensed or distribution is authorized. Tracks grant type (exclusive, non-exclusive), platform scope (linear, SVOD, AVOD, TVOD), holdback restrictions, and effective window. Feeds the rights domain for clearance and blackout enforcement.' .

ind:PartnerContentWindow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Partner Content Window' ;
    rdfs:comment 'Defines the sequential release windows (theatrical, SVOD, AVOD, TVOD, linear, syndication) granted to or from partners for specific content titles under acquisition, distribution, or syndication agreements. Tracks window type, platform exclusivity, start and end dates, holdback periods, and window sequencing order. Authoritative source for windowing strategy within the partner domain, complementing the rights domain\'s rights window records.' .

ind:ChartOfAccounts rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'SAP S/4HANA FI-authoritative chart of accounts defining the complete hierarchy of general ledger account codes used across all Media Broadcasting entities. Captures account number, account type (P&L, balance sheet), account group, functional area, cost element category, currency, consolidation account mapping, and SOX control classification. Serves as the foundational reference for all financial postings, period-end close, and intercompany eliminations.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'SAP CO-authoritative cost center master data representing organizational units responsible for incurring costs across Media Broadcasting — including production studios, broadcast operations, digital platforms, sales regions, and corporate functions. Tracks cost center code, hierarchy node, responsible manager, controlling area, profit center assignment, currency, validity period, and budget allocation reference. Enables granular cost tracking for EBITDA reporting and departmental P&L.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'SAP CO-authoritative profit center master representing autonomous business units within Media Broadcasting that are evaluated on profitability — such as SVOD platform, linear broadcast network, advertising sales division, and syndication unit. Captures profit center code, hierarchy, controlling area, responsible manager, currency, and segment classification. Underpins segment reporting, EBITDA tracking, and management accounting.' .

ind:GeneralLedger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'General Ledger' ;
    rdfs:comment 'SAP FI general ledger representing period-level account balances and individual line items for all Media Broadcasting legal entities. Each record captures a GL account balance within a company code, fiscal year, and posting period — storing debit/credit totals, functional and transaction currency amounts, document type references, and SOX control indicators. Serves as the authoritative source for trial balance generation, statutory financial statements, and period-end close validation. Distinguished from journal_entry (which holds individual postings) by representing the aggregated account state.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Individual accounting document posted to the SAP S/4HANA general ledger capturing all financial transactions across Media Broadcasting — including revenue recognition postings, accruals, prepayments, intercompany charges, and period-end adjustments. Records document number, company code, posting date, document date, document type, reference, reversal indicator, posting user, and SOX approval workflow status. The atomic unit of financial record-keeping.' .

ind:ProductionBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Production Budget' ;
    rdfs:comment 'Financial budget allocated to individual content production projects — covering scripted series, films, live events, news programming, and digital originals. Tracks approved budget amount by cost category (above-the-line talent, below-the-line crew, facilities, post-production, VFX, music licensing), budget version, fiscal year, production project reference, cost center, currency, approval status, and variance-to-actual tracking. Integrates with SAP CO internal orders for production cost control.' .

ind:RevenueStream rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Revenue Stream' ;
    rdfs:comment 'Master classification of all revenue-generating streams across Media Broadcasting — advertising (upfront, scatter, DAI), subscription (SVOD, AVOD, TVOD), carriage fees, syndication license fees, content licensing, and ancillary revenues. Defines stream code, stream name, revenue category, recognition method (ASC 606 / IFRS 15), associated profit center, tax treatment, and reporting segment. Serves as the authoritative revenue taxonomy for financial reconciliation and EBITDA reporting.' .

ind:RevenueRecognitionEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Revenue Recognition Event' ;
    rdfs:comment 'Transactional record of each revenue recognition event posted in SAP S/4HANA for Media Broadcasting revenue streams — capturing the point-in-time or over-time recognition of advertising revenue, subscription fees, carriage fees, and content licensing income. Stores recognition date, recognized amount, deferred amount, performance obligation reference, contract modification flag, revenue stream, GL account, company code, and ASC 606 / IFRS 15 compliance indicators.' .

ind:AccountsReceivable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Accounts Receivable' ;
    rdfs:comment 'SAP FI-AR authoritative record of outstanding receivables owed to Media Broadcasting from advertisers, MVPDs, syndication partners, and content licensees. Captures customer account, invoice reference, due date, open amount, currency, payment terms, dunning level, clearing status, aging bucket, and dispute flag. Supports cash flow forecasting, revenue assurance, and period-end close reconciliation.' .

ind:AccountsPayable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Accounts Payable' ;
    rdfs:comment 'SAP FI-AP authoritative record of outstanding payables owed by Media Broadcasting to talent agencies, production vendors, content licensors, technology providers, and distribution partners. Captures vendor account, invoice reference, due date, open amount, currency, payment terms, payment block status, withholding tax indicator, and clearing status. Supports cash management, vendor payment runs, and period-end close.' .

ind:LegalEntity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Legal Entity' ;
    rdfs:comment 'Master record of each legal entity, company code, and reporting unit within the Media Broadcasting corporate structure — including broadcast networks, streaming platforms, production studios, and holding companies. Captures company code, legal entity name, country of incorporation, functional currency, fiscal year variant, chart of accounts assignment, consolidation group, tax registration numbers, and regulatory reporting obligations (SOX, IFRS, GAAP). The organizational anchor for all financial postings.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Master billing document representing a formal demand for payment issued to a subscriber, advertiser, MVPD partner, or syndication licensee. Captures invoice number, billing period, total amount due, currency, tax amounts, invoice status (draft, issued, paid, disputed, void), due date, payment terms, revenue category (subscription, advertising, carriage, syndication), ASC 606 revenue recognition period, and source system reference (Zuora, Wide Orbit, SAP S/4HANA). Supports stream-specific extended attributes: subscription plan/proration for SVOD billing, Wide Orbit order ID/ISCI codes for ad billing, MVPD subscriber count basis for carriage fees, and license window/installment schedule for syndication. Serves as the SSOT for all billing documents across all revenue streams.' .

ind:InvoiceLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice Line' ;
    rdfs:comment 'Individual line-item detail within a billing invoice, representing a discrete charge for a specific service, ad spot, carriage fee period, or license fee installment. Captures line number, charge description, quantity, unit rate, extended amount, revenue category (subscription, advertising, carriage, syndication), performance obligation identifier per ASC 606, tax code, and discount applied. Enables granular revenue recognition and dispute resolution at the charge level.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Record of a payment transaction received or applied against an outstanding invoice or account balance. Captures payment date, amount, currency, payment method type (credit card, ACH, wire, check), payment status (pending, cleared, failed, reversed), PCI DSS tokenized card reference, bank transaction reference, settlement date, and applied invoice linkage. Integrates with Zuora for subscriber payments and SAP S/4HANA for financial posting. SSOT for all inbound monetary receipts.' .

ind:PaymentMethod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Stored and tokenized payment instrument registered by a subscriber or advertiser for recurring or one-time billing. Captures payment method type (credit card, debit card, ACH, SEPA, wire), PCI DSS-compliant token (never raw PAN), card brand, last four digits, expiry month/year, billing address, bank routing number (masked), mandate reference for direct debit, is_default flag, verification status, and expiry alert date. Managed in Zuora for subscriber billing.' .

ind:BillingAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Account' ;
    rdfs:comment 'Billing-domain representation of a billable entity — a subscriber household, an advertising agency account, an MVPD operator, or a syndication licensee. Distinct from the subscriber or advertiser master record in their respective domains; this entity owns the financial relationship: billing address, billing currency, payment terms, credit limit, account balance, billing cycle assignment, tax exemption status, dunning level, and SAP customer account number. SSOT for the financial account identity within billing.' .

ind:Cycle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Cycle' ;
    rdfs:comment 'Defines the recurring billing schedule configuration for a billing account or product plan — monthly, quarterly, annual, or custom. Captures cycle name, frequency, cycle start day, billing run date, proration rules, advance vs. arrears billing flag, next bill date, and last bill date. Used by Zuora subscription billing engine to trigger invoice generation. Reference entity that governs when invoices are produced for each account.' .

ind:CreditMemo rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Credit Memo' ;
    rdfs:comment 'Formal credit or write-off document issued to reduce, reverse, or write off a previously billed amount — covering makegoods for under-delivered ad campaigns, billing error corrections, subscriber service credits, carriage fee adjustments, and bad debt write-offs for uncollectable balances. Captures credit memo number, reason code (makegood, billing error, service outage, goodwill, bad_debt_write_off), original invoice reference, credit amount, currency, approval status, applied date, collection agency referral flag, recovery amount if subsequently collected, and SAP credit/bad-debt posting reference. SSOT for all billing credits, adjustments, and write-offs.' .

ind:Dispute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Dispute' ;
    rdfs:comment 'Formal billing dispute record raised by a subscriber, advertiser, MVPD, or licensee contesting an invoice or charge. Captures dispute reference number, dispute type (amount error, service not received, makegood claim, duplicate charge, rate discrepancy), disputed amount, dispute open date, resolution deadline, assigned resolver, resolution status (open, under review, resolved, escalated), resolution outcome, credit memo issued flag, and root cause category. Drives the dispute management workflow.' .

ind:Refund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Refund' ;
    rdfs:comment 'Record of a monetary refund issued back to a subscriber or billing account following an overpayment, cancellation, or resolved dispute. Captures refund amount, currency, refund method (original payment method, check, account credit), refund reason, originating payment reference, approval status, processing date, settlement date, and SAP financial posting reference. Distinct from credit memos (which reduce invoice balances) — refunds represent actual cash outflows.' .

ind:RevenueRecognitionSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Revenue Recognition Schedule' ;
    rdfs:comment 'ASC 606 revenue recognition schedule defining how and when deferred revenue from multi-period contracts (subscriptions, syndication licenses, upfront ad deals) is recognized into earned revenue. Captures contract reference, total contract value, recognition start date, recognition end date, recognition method (straight-line, milestone, usage-based), monthly recognized amount, cumulative recognized amount, deferred balance, and SAP revenue account posting reference. Integrates with SAP S/4HANA revenue accounting module.' .

ind:Subscriber rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subscriber ;
    rdfs:label 'Subscriber' ;
    rdfs:comment 'Master identity record for every subscriber across SVOD, AVOD, TVOD, and bundled service tiers. Serves as the SSOT for subscriber identity, capturing registration source, registration timestamp, account status, service tier, demographic attributes, ARPU, LTV, churn risk score, GDPR/CCPA/COPPA consent flags, and integration keys to Zuora (billing) and Adobe Experience Platform (personalization). Each subscriber has a unique identity independent of household or device.' .

ind:Household rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subscriber ;
    rdfs:label 'Household' ;
    rdfs:comment 'Represents a logical household grouping of one or more subscribers sharing a service plan. Tracks household-level attributes including address, geographic market (DMA), household size, primary account holder reference, parental control settings, simultaneous stream limits, and household verification status. Supports MVPD household-based entitlement models, family plan billing, and account sharing enforcement.' .

ind:SubscriptionPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subscriber ;
    rdfs:label 'Subscription Plan' ;
    rdfs:comment 'Catalog of all available subscription plans and service tiers offered to subscribers — SVOD, AVOD, TVOD, FAST, bundled, and add-on plans. Captures plan name, tier classification, billing frequency, base price, trial eligibility, concurrent stream limit, download allowance, ad-supported flag, and plan lifecycle status. Managed in Zuora as the product catalog.' .

ind:Subscription rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subscriber ;
    rdfs:label 'Subscription' ;
    rdfs:comment 'Active or historical enrollment of a subscriber to a specific subscription plan. Represents the contractual service relationship — capturing plan enrollment date, renewal date, billing cycle, current status (active, suspended, cancelled, trialing), auto-renew flag, promotional rate, and Zuora subscription ID. One subscriber may have multiple subscriptions (e.g., base SVOD + premium add-on).' .

ind:DeviceRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subscriber ;
    rdfs:label 'Device Registration' ;
    rdfs:comment 'Records every device registered by a subscriber for authenticated playback. Captures device type (smart TV, mobile, tablet, set-top box, web browser, gaming console), device fingerprint, manufacturer, model, OS platform and version, registration timestamp, last active timestamp, device nickname, device status (active, deregistered, blocked), and DRM device certificate reference. Enforces per-account device limits and supports device management workflows including remote deregistration.' .

ind:Entitlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subscriber ;
    rdfs:label 'Entitlement' ;
    rdfs:comment 'Defines the specific content access rights granted to a subscriber based on their active subscription plan(s). Maps subscriber to entitled content windows, channel packages, VOD libraries, and premium add-ons. Captures entitlement source (plan, promotional grant, MVPD carriage), effective date, expiry date, and entitlement status. Drives playback authorization decisions at the CDN/DRM layer.' .

ind:ParentalControl rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subscriber ;
    rdfs:label 'Parental Control' ;
    rdfs:comment 'Stores parental control configurations set by the account holder for a household or individual profile. Captures content rating thresholds (MPA ratings: G, PG, PG-13, R, NC-17), PIN protection settings, COPPA child profile flag, blocked content categories, purchase lock, and time-of-day viewing restrictions. Enforces COPPA compliance for profiles identified as under-13.' .

ind:ViewerProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subscriber ;
    rdfs:label 'Viewer Profile' ;
    rdfs:comment 'Individual viewing profile within a subscriber account or household — supporting multi-profile accounts (e.g., up to 5 profiles per account). Captures profile name, avatar, language preference, content genre preferences, maturity rating level, is_kids_profile flag, and Adobe Experience Platform segment IDs for personalization. Distinct from the subscriber master record — one subscriber may have multiple viewer profiles.' .

ind:ChurnEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subscriber ;
    rdfs:label 'Churn Event' ;
    rdfs:comment 'Operational record of a subscriber cancellation or lapse event. Captures cancellation timestamp, cancellation channel (self-service, customer care, payment failure, MVPD drop), stated cancellation reason, win-back offer presented flag, win-back offer accepted flag, and reactivation eligibility date. Supports churn rate reporting and retention campaign targeting. Distinct from analytics — this is the operational event record.' .

ind:SubscriptionChange rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subscriber ;
    rdfs:label 'Subscription Change' ;
    rdfs:comment 'Audit trail of all plan changes, upgrades, downgrades, pauses, reinstatements, and promotional offer redemptions on a subscriber\'s subscription. Captures previous plan, new plan, change type (upgrade, downgrade, pause, reactivate, add-on attach, add-on detach, offer redemption), effective date, change channel, proration amount, applied discount, offer reference, redemption status, and Zuora amendment reference. Enables subscription lifecycle analysis, promotion effectiveness tracking, and revenue reconciliation.' .

ind:PaymentInstrument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subscriber ;
    rdfs:label 'Payment Instrument' ;
    rdfs:comment 'Subscriber\'s stored payment instruments used for subscription billing. Captures payment method type (credit card, debit card, PayPal, direct debit, gift card, MVPD billing), masked card/account number, card brand, expiry date, billing address, is_default flag, and PCI DSS tokenization reference. Managed in Zuora as the payment method entity. Distinct from actual payment transactions owned by the billing domain.' .

ind:OfferRedemption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subscriber ;
    rdfs:label 'Offer Redemption' ;
    rdfs:comment 'Transactional record of a subscriber redeeming a promotional offer or discount code. Captures subscriber reference, offer reference, redemption timestamp, redemption channel, applied discount amount, resulting subscription plan, and redemption status (applied, expired, reversed). Enables promotion effectiveness tracking and revenue impact reconciliation.' .

ind:AdOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Ad Order' ;
    rdfs:comment 'Master record for an advertising sales order (also called a broadcast order or traffic order) placed by an advertiser or agency. Captures the commercial agreement for a campaign buy including order number, advertiser, agency, account executive, total contracted value, currency, order status (pending, confirmed, cancelled, invoiced), order type (upfront, scatter, direct, programmatic), market, daypart mix, flight dates, billing instructions, Wide Orbit order reference, and Salesforce opportunity linkage. SSOT for the advertising order lifecycle.' .

ind:Campaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Campaign' ;
    rdfs:comment 'Advertising campaign master record representing the strategic grouping of ad orders and flights for a single advertiser objective. Tracks campaign name, advertiser, product/brand being advertised, campaign type (brand awareness, direct response, political, sponsorship), total budget, contracted reach and frequency targets, GRP/TRP goals, SOV targets, campaign status, start and end dates, and Salesforce Media Cloud campaign reference. Parent entity above ad orders and flights.' .

ind:Advertiser rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Advertiser' ;
    rdfs:comment 'Master record for an advertising client (brand or direct advertiser) purchasing airtime or digital inventory. Captures advertiser legal name, trade name, industry category (IAB taxonomy), parent company, billing address, credit limit, credit status, payment terms, tax ID, Salesforce account reference, Wide Orbit advertiser code, and account manager assignment. Distinct from the agency that places buys on behalf of the advertiser. SSOT for advertiser identity within the advertising domain.' .

ind:SalesAgency rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Sales Agency' ;
    rdfs:comment 'Master record for an advertising agency or media buying firm that places ad orders on behalf of advertisers. Captures agency name, agency type (full-service, media buying, digital, programmatic), holding company group, commission rate, billing model (gross/net), contact details, Wide Orbit agency code, Salesforce account reference, and accreditation status. Tracks the agency-advertiser relationship for commission calculation and billing split.' .

ind:AdSpot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Ad Spot' ;
    rdfs:comment 'Individual scheduled advertisement placement (spot) within a broadcast or digital break. Represents the atomic unit of ad delivery — a single commercial airing with ISCI code, spot length (seconds), scheduled air date and time, channel/network, program, daypart, pod position, actual air time (from affidavit), preemption flag, makegoood flag, DAI flag, and Wide Orbit traffic log reference. Links to the ad order line that booked it and the creative (isci) that aired.' .

ind:Makegood rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Makegood' ;
    rdfs:comment 'Compensatory ad spot record issued when a contracted spot fails to air as scheduled (due to preemption, technical failure, or audience underdelivery). Captures makegood ID, original ad spot reference, reason code (preemption, technical, ratings shortfall), proposed replacement spot details (channel, date, time, daypart, program), advertiser/agency approval status, approval date, and resolution status. Tracks the full makegood negotiation and fulfillment lifecycle.' .

ind:Proposal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Proposal' ;
    rdfs:comment 'Pre-sale advertising proposal submitted to an advertiser or agency in response to an RFP or upfront/scatter negotiation. Captures proposal number, advertiser, agency, account executive, proposal date, expiry date, total proposed value, proposed GRP/TRP/impression delivery, channel mix, daypart mix, spot length mix, CPM/CPRP, audience demographic targets, proposal status (draft, submitted, negotiating, accepted, rejected), and Salesforce opportunity reference. Precedes the formal ad order.' .

ind:UpfrontDeal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Upfront Deal' ;
    rdfs:comment 'Master record for an advertising deal negotiation and commitment — covering the full lifecycle from initial proposal/RFP response through negotiation rounds to final commitment. Encompasses upfront bulk buys negotiated during the annual upfront sales event as well as significant scatter and direct deals requiring formal proposal stages. Captures deal ID, advertiser, agency, account executive, deal year, proposal date, total proposed/committed spend, audience guarantee (GRP/TRP/impression), audience demographic, channel/daypart mix, cancellation option windows, scatter conversion rights, pricing basis (CPM or CPRP), deal status (draft, submitted, negotiating, committed, executed, cancelled), option exercise deadlines, and Salesforce opportunity reference. SSOT for the pre-order deal negotiation lifecycle.' .

ind:AdvertisingAudienceGuarantee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Advertising Audience Guarantee' ;
    rdfs:comment 'Audience delivery guarantee record associated with an ad order or upfront deal, specifying the contracted GRP/TRP/impression target and tracking actual delivery against that target. Captures guarantee ID, order or deal reference, audience demographic (age/gender cell), contracted GRP, delivered GRP, delivery variance, delivery percentage, underdelivery threshold, guarantee period, Nielsen measurement source, and guarantee status (on-track, at-risk, underdelivered, fulfilled). Triggers makegood or credit processes on underdelivery.' .

ind:ImpressionDelivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Impression Delivery' ;
    rdfs:comment 'Digital and streaming advertising delivery record tracking served impressions and ad insertions across OTT, AVOD, FAST, and digital display campaigns. Covers both Dynamic Ad Insertion (DAI) events triggered by SCTE-35 cues in streaming and standard digital impression serving. Captures delivery date, channel/platform, campaign, ad order line, ISCI creative, insertion type (DAI/SCTE-35, server-side, client-side, display), targeting parameters applied (audience segment, geo, device type), total impressions served, viewable impressions, completed views, click-throughs, CPM realized, insertion status (inserted, fallback, no-fill), CDN delivery confirmation, impression tracking URL, stream session reference, and third-party verification source (IAS, DoubleVerify, Nielsen DAR). Feeds digital billing reconciliation, campaign pacing, and DAI platform reporting.' .

ind:Sponsorship rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Sponsorship' ;
    rdfs:comment 'Master record for a program or content sponsorship deal where an advertiser sponsors a specific program, segment, event, or content series. Captures sponsorship ID, advertiser, agency, sponsored program or event, sponsorship type (presenting sponsor, title sponsor, segment sponsor, branded content), sponsorship value, deliverables (billboards, opens/closes, product integration, logo placement), exclusivity terms, flight dates, and fulfillment status. Distinct from standard spot advertising — sponsorships carry integration and exclusivity obligations.' .

ind:MediaAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mediaasset ;
    rdfs:label 'Media Asset' ;
    rdfs:comment 'Core master record for every managed digital object in the MAM (Dalet Galaxy) — raw camera footage, mezzanine masters, graphics, music beds, and archived assets. Stores canonical asset identity, technical format metadata (codec, resolution, duration, bit-rate, aspect ratio, color space, audio channels, frame rate), asset class (raw/mezzanine/proxy/archive), storage tier (hot/warm/cold/deep-archive), lifecycle status (ingest/QC/approved/archived/purged), industry identifiers (ISAN/EIDR/ISRC/UMID), originating system reference, and content classification tags. Single source of truth for all digital object identities and their technical characteristics across the enterprise.' .

ind:AssetVersion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mediaasset ;
    rdfs:label 'Asset Version' ;
    rdfs:comment 'Tracks every distinct version, rendition, or derivative of a media asset — including mezzanine, proxy (low-res preview/edit proxy/thumbnail), HLS/DASH adaptive bitrate ladder rungs, watermarked forensic copies, and localized dubs. Each version captures version number, rendition purpose (playout/distribution/archive/preview/proxy/watermark), format specification reference, file size, checksum (MD5/SHA-256), storage URI, transcode job reference, watermark payload (if applicable), proxy expiry date (if applicable), and version status. Enables full version lineage from camera original through every derivative to final delivery rendition.' .

ind:IngestJob rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mediaasset ;
    rdfs:label 'Ingest Job' ;
    rdfs:comment 'Transactional record of every media ingest operation executed in Dalet Galaxy — capturing ingest source (tape, file transfer, satellite feed, cloud upload), ingest start/end timestamps, operator identity, source format, target storage location, ingest status (queued/running/completed/failed), bytes transferred, transfer rate, and any error codes encountered. Provides the chain-of-custody entry point for all assets entering the MAM. Links to the resulting media_asset record upon successful completion.' .

ind:TranscodeJob rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mediaasset ;
    rdfs:label 'Transcode Job' ;
    rdfs:comment 'Transactional record of every format conversion operation performed on a media asset — including standard transcodes (ABR ladder generation, proxy creation, delivery package preparation) and format migrations (obsolescence-driven conversions such as MPEG-2 to H.265, tape digitisation, analogue-to-digital). Captures source asset version, target format specification, codec parameters, bitrate ladder configuration, output storage URI, job type (transcode/migration), migration reason (if applicable: format obsolescence/storage optimisation/distribution requirement), job priority, queue entry time, processing start/end timestamps, transcoding engine used, output file size, checksum, quality validation result, and job status (queued/processing/completed/failed/retrying). Single source of truth for all format conversion operations in the MAM.' .

ind:QcInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mediaasset ;
    rdfs:label 'Qc Inspection' ;
    rdfs:comment 'Records the quality control inspection result for each media asset version — capturing QC type (automated/manual/hybrid), inspection timestamp, operator or automated QC tool identity, pass/fail status, loudness compliance result (EBU R128 / ATSC A/85), black frame detection, freeze frame detection, audio sync check, caption/subtitle validation, aspect ratio compliance, HDR metadata validation, and a structured list of detected defects with timecode references. Mandatory gate before asset is approved for playout or distribution.' .

ind:StorageLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mediaasset ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Master reference for all physical and logical storage locations in the MAM infrastructure — on-premise SAN/NAS arrays, nearline LTO tape libraries, cloud object storage (S3, Azure Blob, GCS), CDN origin stores, and deep-archive vaults. Captures location name, storage type, tier classification (hot/warm/cold/deep-archive), geographic region/data centre, total capacity, used capacity, storage vendor, access protocol (NFS/SMB/S3/SFTP), SLA tier (restore time objective), and operational status. Drives automated storage tiering policy enforcement, capacity planning, and cost allocation reporting.' .

ind:AssetStorageAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mediaasset ;
    rdfs:label 'Asset Storage Assignment' ;
    rdfs:comment 'Tracks the complete storage placement history for every media asset version — recording which file resides at which storage location, when it was placed there, and why it moved. Captures storage location reference, file path/URI, storage tier at time of assignment, assignment start date, end date (if migrated or purged), file size, checksum at placement, migration trigger (tiering policy/legal hold/cost optimisation/format migration/capacity rebalance), and verification status. Provides the authoritative chain-of-custody for physical file placement, drives storage capacity reporting, enables restore path resolution, and supports legal discovery by proving where a file was at any point in time.' .

ind:RetentionPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mediaasset ;
    rdfs:label 'Retention Policy' ;
    rdfs:comment 'Defines the business retention rules applied to media assets — capturing policy name, asset class scope (raw/mezzanine/proxy/archive), minimum retention period, maximum retention period, retention trigger (ingest date / broadcast date / contract expiry / legal hold), post-retention action (purge/migrate-to-deep-archive/notify-rights-owner), regulatory basis (FCC, Ofcom, GDPR, SOX, legal hold), policy owner, effective date, and expiry date. Drives automated lifecycle management and ensures regulatory compliance for asset archival and deletion.' .

ind:FormatSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mediaasset ;
    rdfs:label 'Format Specification' ;
    rdfs:comment 'Reference catalogue of all approved media format specifications used across the enterprise — capturing format name, container format (MXF, MP4, MOV, TS), video codec (H.264, H.265/HEVC, AV1, ProRes, DNxHD), audio codec (AAC, PCM, Dolby AC-3, Dolby Atmos), resolution class (SD/HD/UHD/4K/8K), frame rate, scan type (progressive/interlaced), HDR standard (HDR10, HLG, Dolby Vision), audio loudness spec, subtitle/caption format, intended use case (ingest/mezzanine/proxy/playout/OTT-delivery/archive), and governing standard reference (ATSC, DVB, HLS, MPEG-DASH). Drives transcode job configuration and QC compliance checks.' .

ind:AssetCollection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mediaasset ;
    rdfs:label 'Asset Collection' ;
    rdfs:comment 'Defines logical groupings of media assets for editorial, distribution, or archival purposes — such as a series package, film franchise bundle, news story package, sports event clip collection, or music album. Captures collection name, type (series/film/news-package/sports-event/music-album/campaign-creative), description, creation date, owner department, status, and an ordered member list with membership role (primary/supplemental/bonus/trailer/promo), sequence position, and inclusion dates. Enables bulk operations (bulk QC, bulk rights check, bulk archive) and supports content packaging for distribution deals.' .

ind:ArchiveRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mediaasset ;
    rdfs:label 'Archive Record' ;
    rdfs:comment 'Tracks the formal archival of media assets to long-term storage — capturing archive date, archive destination (LTO tape generation, cloud deep-archive vault, off-site facility), archive job reference, tape barcode or vault identifier, restore SLA tier, restore test date, restore test result, retention policy applied, archival operator, and archive status (archived/restore-requested/restored/purge-pending). Supports ISO 14721 OAIS compliance and provides the authoritative record for asset archival and retrieval operations.' .

ind:LicenseAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rights ;
    rdfs:label 'License Agreement' ;
    rdfs:comment 'Master record for all content licensing, acquisition, and syndication agreements managed in Rightsline. Captures the full contractual relationship between Media Broadcasting and rights grantors or licensees (studios, distributors, music publishers, talent guilds, syndication partners). Stores agreement type (acquisition, co-production, syndication, first-run syndication, off-network syndication, international syndication, music sync, output deal), licensor and licensee identities, effective and expiry dates, territory scope, exclusivity flags, total license fee, payment schedule with milestone detail (advances, minimum guarantees, per-episode fees, annual installments), run count limitations for syndication, governing law jurisdiction, and agreement status (draft, executed, expired, terminated). This is the SSOT for all rights-bearing contracts and the anchor entity for all downstream window, royalty, and clearance records.' .

ind:Grant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rights ;
    rdfs:label 'Grant' ;
    rdfs:comment 'Granular rights entitlement record derived from a license agreement. Each row represents a specific bundle of rights granted for a content asset — capturing right type (broadcast, SVOD, AVOD, TVOD, theatrical, home video, music sync, podcast), media type, territory or territory group, language version, exclusivity indicator, holdback applicability, and the grant period (start and end dates). Multiple grants can exist per agreement and per content asset. Feeds the availability engine in scheduling and distribution domains. Powered by Rightsline availabilities module.' .

ind:RightsContentWindow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rights ;
    rdfs:label 'Rights Content Window' ;
    rdfs:comment 'Defines the sequential release window strategy (windowing) for a specific content asset across exploitation platforms, and computes the net availability status. Each record captures the window type (theatrical, PVOD, TVOD, SVOD, AVOD, linear, FAST, home video, syndication), platform or channel scope, window open and close dates, holdback start and end dates, territory, exclusivity tier, and computed availability status (available, held-back, blacked-out, expired). Enforces the windowing hierarchy that prevents simultaneous exploitation across competing platforms. The net availability (considering holdbacks and blackouts) is refreshed whenever upstream rights or holdback records change. Directly consumed by scheduling and distribution domains to validate playout eligibility. Powered by Rightsline Windows module.' .

ind:Holdback rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rights ;
    rdfs:label 'Holdback' ;
    rdfs:comment 'Records exclusivity holdback restrictions that prevent a content asset from being exploited on a specific platform, territory, or channel during a defined period. Each holdback captures the restriction type (platform holdback, territory holdback, channel holdback, format holdback), the restricted platform or distributor, holdback start and end dates, the triggering window type and source window reference, the source license agreement, and enforcement status (active, expired, waived, overridden). Holdbacks are enforced by the clearance workflow before any scheduling or distribution action is approved. Critical for MVPD carriage negotiations, OTT windowing compliance, and theatrical-to-home-video sequencing. Links to rights_content_window and license_agreement.' .

ind:RightsTerritory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rights ;
    rdfs:label 'Rights Territory' ;
    rdfs:comment 'Reference master for geographic territories and territory groups used in rights grants, holdbacks, and royalty calculations. Each record defines a territory by ISO country code, territory name, territory group (e.g., EMEA, LATAM, North America, Worldwide), broadcast regulatory body (FCC, Ofcom, etc.), currency, and whether the territory is subject to blackout restrictions. Provides the standardized territory taxonomy consumed by all rights, scheduling, and distribution products.' .

ind:RoyaltyRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rights ;
    rdfs:label 'Royalty Rule' ;
    rdfs:comment 'Defines the royalty calculation rules and rate structures associated with a license agreement or rights grant. Captures royalty type (flat fee, revenue share percentage, per-stream rate, per-unit rate, residual formula), calculation basis (gross revenue, net revenue, subscriber count, stream count, GRP), applicable platform or exploitation type, rate tiers and thresholds, minimum guarantee amounts, and effective date range. Serves as the configuration engine for the royalty calculation process in Rightsline. Distinct from actual royalty payment transactions.' .

ind:RoyaltyStatement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rights ;
    rdfs:label 'Royalty Statement' ;
    rdfs:comment 'Periodic royalty statement generated for a rights holder (licensor, talent guild, music publisher, or syndication partner) covering a specific reporting period. Captures statement period (monthly, quarterly, semi-annual), total royalties due, breakdown by exploitation type and territory, advance recoupment amounts, minimum guarantee shortfall, currency, exchange rate applied, and statement status (draft, approved, disputed, paid). The SSOT for royalty obligations owed to external rights holders. Feeds the billing domain for payment processing.' .

ind:Residual rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rights ;
    rdfs:label 'Residual' ;
    rdfs:comment 'Tracks talent residual payment obligations arising from the reuse or re-exploitation of content under guild agreements (SAG-AFTRA, WGA, DGA, IATSE). Each record captures the guild or union, contract cycle, content asset, exploitation type triggering the residual (rerun, streaming, foreign broadcast, home video), residual formula type, calculated residual amount, payment due date, and payment status. Residuals are distinct from general royalties — they are talent-specific reuse payments governed by collective bargaining agreements. Feeds talent and billing domains.' .

ind:MusicSyncLicense rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rights ;
    rdfs:label 'Music Sync License' ;
    rdfs:comment 'Master record for music synchronization licenses that authorize the use of a specific musical composition or sound recording within a content asset. Captures the music work (composition title, ISRC, ISWC), rights holder (publisher, label, PRO), sync license type (master use, synchronization, blanket, per-title), licensed territory, licensed platforms, license fee, royalty rate, license period, and clearance status. Music sync licenses are a distinct rights category from content licenses and are required for every piece of music embedded in a broadcast or streaming asset.' .

ind:ClearanceRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rights ;
    rdfs:label 'Clearance Request' ;
    rdfs:comment 'Workflow record capturing a rights clearance request initiated before a content asset is scheduled for broadcast, streaming, or distribution. Tracks the requesting department (scheduling, distribution, production), content asset, intended exploitation type and platform, requested air or publish date, territory, clearance status (pending, cleared, conditionally cleared, blocked, escalated), blocking reason if applicable, assigned clearance analyst, and resolution date. Enforces the clearance gate that prevents unlicensed content from reaching playout or distribution systems. Integrates with Ericsson MediaFirst scheduling and Rightsline availabilities.' .

ind:RightsAvailabilityWindow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rights ;
    rdfs:label 'Rights Availability Window' ;
    rdfs:comment 'Computed availability record representing the net exploitable window for a content asset on a specific platform and territory, derived from the intersection of rights grants, holdbacks, and content windows. Captures asset reference, platform type (SVOD, AVOD, TVOD, linear, FAST, MVPD), territory, availability start and end dates, exclusivity flag, blackout indicator, and the source rights grant and window records. This is the actionable availability feed consumed by scheduling and distribution domains to determine what can be programmed or published. Refreshed whenever upstream rights or window records change.' .

ind:Holder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Rights ;
    rdfs:label 'Holder' ;
    rdfs:comment 'Master record for all external entities that hold intellectual property rights licensed to or from Media Broadcasting — including film studios, independent production companies, music publishers, performing rights organizations (PROs), talent guilds, record labels, news agencies, and individual creators. Captures rights holder name, entity type, ISAN or ISRC registrant identifier, primary contact, territory of incorporation, preferred currency, payment terms, and tax withholding classification. This is the SSOT for rights grantor and grantee identity within the rights domain, distinct from the partner domain which manages broader commercial relationships.' .

ind:SalesAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Sales Account' ;
    rdfs:comment 'Master record for advertising agencies, direct advertisers, content licensees, syndication buyers, and distribution partners that engage in commercial transactions with Media Broadcasting. Serves as the SSOT for all sales-facing organizational identities — capturing account type (agency, direct, MVPD, syndicator), holding company hierarchy, credit rating, payment terms, assigned sales rep, market territory, agency commission rate, blackout restrictions, preferred currency, and CRM source ID from Salesforce Media Cloud. This is the commercial counterpart to subscriber identity and is the anchor entity for all sales pipeline activity.' .

ind:Opportunity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Opportunity' ;
    rdfs:comment 'A qualified sales pursuit representing a potential advertising campaign, content licensing deal, syndication agreement, or distribution carriage negotiation. Tracks deal stage (prospecting, proposal, negotiation, closed-won, closed-lost), estimated deal value, deal type (upfront, scatter, direct, programmatic guaranteed, content license, syndication), target flight dates, assigned sales executive, probability of close, and competitive displacement notes. Sourced from Salesforce Media Cloud Opportunity object. The primary pipeline entity feeding revenue forecasting and upfront commitment tracking.' .

ind:Rep rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Rep' ;
    rdfs:comment 'The sales representative or account executive profile within the sales domain, capturing the commercial assignment and quota context for each seller. Tracks rep name, employee ID (FK to HR/workforce), territory assignment, account portfolio, deal type specialization (national TV, digital, syndication, licensing), annual quota, quota period, commission plan type, manager, and active status. This is the sales-domain view of the seller — not a duplicate of HR employee master — focused on commercial assignment, quota, and territory rather than HR attributes.' .

ind:SalesTerritory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Sales Territory' ;
    rdfs:comment 'Defines the geographic, account-based, or vertical market territory assigned to sales teams and individual reps. Captures territory name, territory type (geographic region, account segment, vertical — automotive, pharma, retail, entertainment), assigned sales rep or team, revenue target, account count, and effective date range. Supports territory management, quota allocation, and pipeline reporting by market segment. Managed within Salesforce Media Cloud territory management module.' .

ind:Avail rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Avail' ;
    rdfs:comment 'An inventory availability record representing a specific advertising slot, sponsorship position, or content window that is available for sale at a given point in time. Captures channel or platform, program or content title, daypart, air date or window, unit type (spot, sponsorship, integration, digital pre-roll), spot length, available impressions or GRPs, audience demographic projection, floor CPM, hold status (available, first hold, second hold, released, sold), holding account reference, hold expiry date, and source system (Wide Orbit, programmatic SSP). Avails are the sellable inventory units that sales reps present to buyers and that proposals are built from. Sourced from Wide Orbit inventory management and EPG scheduling. Updated in near-real-time as holds are placed and orders confirmed.' .

ind:TitleRelationship rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Title Relationship' ;
    rdfs:comment 'Defines typed relationships between content assets — remakes, sequels, prequels, spin-offs, compilations, clip-parent associations, franchise linkages, and cross-promotional pairings. Captures source title, target title, relationship type (sequel/prequel/remake/spin-off/compilation/clip-of/franchise-sibling/crossover), relationship direction, canonical order, effective date, and active status. Supports content discovery, recommendation engines, franchise management, and editorial curation across linear and OTT platforms.' .

ind:Forecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Forecast' ;
    rdfs:comment 'Revenue forecast record capturing projected bookings by sales rep, territory, account segment, deal type (upfront, scatter, licensing, syndication, carriage), and time period (quarter, broadcast year). Tracks forecast version, submission date, forecast category (commit, best case, pipeline, omitted), total forecasted revenue, weighted pipeline value, variance to quota, and manager override amount. Enables sales leadership to project revenue attainment against quota, identify pipeline gaps, and allocate resources. Updated weekly during active selling periods and daily during upfront season.' .

ind:Vendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Vendor' ;
    rdfs:comment 'Master reference table for vendor. Referenced by vendor_id.' .

ind:Agreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Agreement' ;
    rdfs:comment 'Master reference table for partner_agreement. Referenced by partner_agreement_id.' .

ind:EquipmentItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Equipment Item' ;
    rdfs:comment 'Master reference table for equipment_item. Referenced by equipment_item_id.' .

ind:Offer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subscriber ;
    rdfs:label 'Offer' ;
    rdfs:comment 'Master reference table for offer. Referenced by offer_id.' .

ind:CrewCall rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Crew Call' ;
    rdfs:comment 'This association product represents the day-specific assignment of a crew member to a shoot schedule day. It captures the operational reality of the Day Out of Days (DOOD) report and daily call sheet in film and television production. Each record links one crew assignment to one shoot schedule day with attributes that exist only in the context of that specific shoot day: individual call times, overtime triggers, meal penalty tracking, and turnaround compliance. This is a fundamental production management entity that cannot be modeled as attributes on either the crew assignment (which spans multiple shoot days) or the shoot schedule (which involves multiple crew members).. Existence Justification: In film and television production, crew assignments span multiple shoot days (e.g., a Director of Photography contracted for 45 shoot days), and each shoot day involves dozens of crew members across departments. The Day Out of Days (DOOD) report and daily call sheet are industry-standard production management documents that track the intersection of crew assignments and shoot schedule days. Each crew-day pairing has unique operational data: individual call times (hair/makeup called earlier than camera), overtime triggers, meal penalty tracking, and turnaround compliance—all of which cannot exist on either the crew assignment (which is multi-day) or the shoot schedule (which is multi-crew).' .

ind:CollectionMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mediaasset ;
    rdfs:label 'Collection Membership' ;
    rdfs:comment 'This association product represents the membership relationship between asset_collection and media_asset. It captures the inclusion of individual media assets within editorial collections, series packages, news story bundles, and distribution packages. Each record links one asset_collection to one media_asset with attributes that define the role, sequence, and lifecycle of that specific membership relationship. Editorial teams actively create, reorder, and manage these memberships as part of content packaging and distribution workflows.. Existence Justification: In media broadcasting operations, asset collections (series packages, news story bundles, film franchise collections, music albums) routinely contain multiple media assets, and individual assets frequently appear in multiple collections simultaneously—a raw interview clip may be part of a breaking news package, a documentary series collection, and an archival topic bundle. Editorial teams actively manage collection membership as a distinct operational activity, creating, reordering, and removing memberships with specific roles (primary/supplemental/bonus/trailer/promo), sequence positions, and inclusion dates. This is not an analytical correlation but a core content packaging workflow.' .

ind:PackageTitle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Package Title' ;
    rdfs:comment 'This association product represents the inclusion of a specific title within a content package. It captures the commercial and operational terms under which each title is bundled into a package for distribution or licensing. Each record links one package to one title with attributes that exist only in the context of this specific inclusion relationship, such as sequencing, pricing contribution, and inclusion status.. Existence Justification: In media broadcasting operations, content packages are explicitly curated bundles containing multiple titles (films, series, episodes), and individual titles routinely appear across multiple packages simultaneously (e.g., a blockbuster film may be included in a premium SVOD library package, a syndication package for international markets, and a FAST channel lineup). The business actively manages these inclusions as operational records, tracking which titles are in which packages with specific commercial terms, sequencing, and pricing contributions.' .

ind:SegmentMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Audience ;
    rdfs:label 'Segment Membership' ;
    rdfs:comment 'This association product represents the membership relationship between audience_profile and segment. It captures the operational assignment of individual audience profiles to targeting segments for ad delivery, content personalization, and campaign activation. Each record links one audience profile to one segment with membership lifecycle attributes, activation status, and scoring metadata that exist only in the context of this specific profile-segment assignment.. Existence Justification: In media broadcasting operations, audience segment membership is a core operational concept actively managed by audience intelligence and ad operations teams. A single audience profile simultaneously belongs to multiple segments (e.g., \'Sports Enthusiasts\', \'High Income HH\', \'Prime Time Viewers\'), and each segment contains thousands to millions of audience profiles. The business explicitly tracks membership lifecycle (when profiles enter/exit segments), membership scores (how strongly they match criteria), and activation status (whether the membership is available for ad targeting). This is evidenced by the aep_segment_membership attribute on audience_profile, which is a denormalized representation of this M:N relationship.' .

ind:PlatformDeviceCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Platform Device Certification' ;
    rdfs:comment 'This association product represents the certification relationship between OTT platforms and device types. It captures the formal certification process that validates device compatibility with platform requirements, including DRM capabilities, resolution support, codec compatibility, and certification lifecycle management. Each record links one OTT platform to one device type with certification-specific attributes that exist only in the context of this platform-device pairing.. Existence Justification: In the OTT streaming industry, platform-device certification is a formal, operationally-managed business process where each OTT platform must independently certify each device type for compatibility. A single device type (e.g., Samsung Galaxy S21) must be certified separately for each platform it supports (e.g., Netflix, Disney+, HBO Max), and each platform maintains certification records for hundreds of device types. The certification relationship carries platform-specific data including certification dates, expiry dates, supported DRM levels, and maximum resolution for each unique platform-device pairing.' .

# --- Attribute Properties ---
ind:nielsenRatingId rdf:type rdf:Property ;
    rdfs:label 'Nielsen Rating Id' ;
    rdfs:comment 'Unique surrogate identifier for each Nielsen audience measurement record in the Silver layer. Primary key for the nielsen_rating data product.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NielsenRating .

ind:broadcastLicenseId rdf:type rdf:Property ;
    rdfs:label 'Broadcast License Id' ;
    rdfs:comment 'Foreign key linking to compliance.broadcast_license. Business justification: Ratings measurement tied to specific licensed broadcast facilities for regulatory reporting. Nielsen data aggregated by license for FCC public interest demonstration and license renewal applications.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastLicense .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to advertising.campaign. Business justification: Nielsen ratings measure campaign delivery performance for billing reconciliation, makegood determination, and audience guarantee compliance. Essential for post-campaign analysis and advertiser reporti' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Reference to the broadcast channel or network on which the program aired and for which this rating was measured.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:complianceContentRatingId rdf:type rdf:Property ;
    rdfs:label 'Compliance Content Rating Id' ;
    rdfs:comment 'Foreign key linking to compliance.content_rating. Business justification: Nielsen ratings measurement requires content rating context for demographic targeting compliance (COPPA children\'s programming restrictions) and advertiser suitability verification. Essential for regu' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentRating .

ind:daypartId rdf:type rdf:Property ;
    rdfs:label 'Daypart Id' ;
    rdfs:comment 'Reference to the daypart (time segment of the broadcast day) during which the program aired, such as Prime Time, Late Night, or Early Morning. Daypart is a core dimension for ad sales and programming decisions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Daypart .

ind:deliveryChannelId rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel Id' ;
    rdfs:comment 'Foreign key linking to distribution.delivery_channel. Business justification: Nielsen ratings are reported per delivery channel (broadcast, cable, FAST, SVOD) for cross-platform audience measurement. Distribution and ad sales teams require delivery-channel-level Nielsen data fo' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryChannel .

ind:easLogId rdf:type rdf:Property ;
    rdfs:label 'Eas Log Id' ;
    rdfs:comment 'Foreign key linking to compliance.eas_log. Business justification: Nielsen measurement windows affected by EAS alert transmissions require correlation for accurate rating adjustments. EAS interruptions impact audience measurement; link enables rating correction and c' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EasLog .

ind:marketCoverageId rdf:type rdf:Property ;
    rdfs:label 'Market Coverage Id' ;
    rdfs:comment 'Reference to the geographic market (DMA or national) for which this rating measurement applies. Supports both national and local market measurement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketCoverage .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Foreign key linking to sales.opportunity. Business justification: Nielsen ratings directly inform ad sales opportunity valuation and pricing negotiations. Sales teams reference specific program ratings when building proposals and justifying CPM/CPRP rates to adverti' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:ottPlatformId rdf:type rdf:Property ;
    rdfs:label 'Ott Platform Id' ;
    rdfs:comment 'Foreign key linking to distribution.ott_platform. Business justification: Nielsen streaming measurement (SVOD/FAST ratings) attributes ratings to specific OTT platforms. Nielsen\'s Big Data + Panel methodology requires platform-level rating attribution for cross-platform aud' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OttPlatform .

ind:panelId rdf:type rdf:Property ;
    rdfs:label 'Panel Id' ;
    rdfs:comment 'Foreign key linking to audience.panel. Business justification: A Nielsen rating record is produced by a specific measurement panel. Adding panel_id to nielsen_rating establishes the authoritative link between the rating measurement and the panel that generated it' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Panel .

ind:partnerId rdf:type rdf:Property ;
    rdfs:label 'Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Nielsen ratings for syndicated content must track which distribution partner\'s broadcast generated the rating for syndication performance reporting and partner revenue reconciliation. Essential for pa' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:politicalAdRecordId rdf:type rdf:Property ;
    rdfs:label 'Political Ad Record Id' ;
    rdfs:comment 'Foreign key linking to compliance.political_ad_record. Business justification: Nielsen ratings used for political advertising rate calculations (lowest unit charge) and public file disclosure. FCC requires ratings documentation for political ad pricing verification and equal tim' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoliticalAdRecord .

ind:productionEpisodeId rdf:type rdf:Property ;
    rdfs:label 'Production Episode Id' ;
    rdfs:comment 'Foreign key linking to production.production_episode. Business justification: Episode-level Nielsen ratings are the primary measurement unit for episodic television. Required for per-episode performance analysis, makegood calculations, and syndication valuation. Standard indust' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionEpisode .

ind:productionProjectId rdf:type rdf:Property ;
    rdfs:label 'Production Project Id' ;
    rdfs:comment 'Foreign key linking to production.project. Business justification: Nielsen ratings reports measure performance of specific production projects/series. Essential for greenlight decisions, talent negotiations, and advertiser delivery verification. Standard operational ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Ratings directly measure profit center performance for network/channel business units. Quarterly profit center reviews and segment reporting for investors require tying advertising revenue and audienc' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:programScheduleId rdf:type rdf:Property ;
    rdfs:label 'Program Schedule Id' ;
    rdfs:comment 'Foreign key linking to scheduling.program_schedule. Business justification: Nielsen overnight ratings are reconciled against specific program schedules to validate GRP delivery and trigger makegood obligations. Ratings reconciliation and affidavit workflows require linking ea' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramSchedule .

ind:regulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Nielsen ratings used for regulatory filings (license renewals, public interest programming reports, sweeps validation) must reference the underlying obligations. Rating has regulatory_filing_id and sw' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:revenueStreamId rdf:type rdf:Property ;
    rdfs:label 'Revenue Stream Id' ;
    rdfs:comment 'Foreign key linking to finance.revenue_stream. Business justification: Nielsen ratings validate advertising revenue stream delivery against sold guarantees. Sales operations use ratings to reconcile revenue recognition with audience performance for makegood determination' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueStream .

ind:scheduleSlotId rdf:type rdf:Property ;
    rdfs:label 'Schedule Slot Id' ;
    rdfs:comment 'Foreign key linking to scheduling.schedule_slot. Business justification: Nielsen ratings are measured at the individual program airing (slot) level. Linking rating records to schedule_slot enables slot-level CPM validation, makegood triggering, and as-run log reconciliatio' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleSlot .

ind:titleId rdf:type rdf:Property ;
    rdfs:label 'Title Id' ;
    rdfs:comment 'Reference to the program entity for which this audience measurement record was captured. Links to the program master data product.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:airDate rdf:type rdf:Property ;
    rdfs:label 'Air Date' ;
    rdfs:comment 'The calendar date on which the program episode aired on the specified channel and market. Used as the principal business event date for this measurement record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airEndTime rdf:type rdf:Property ;
    rdfs:label 'Air End Time' ;
    rdfs:comment 'The precise date and time at which the program finished airing. Combined with air_start_time to derive program duration for audience measurement calculations.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:airStartTime rdf:type rdf:Property ;
    rdfs:label 'Air Start Time' ;
    rdfs:comment 'The precise date and time (including timezone offset) at which the program began airing. Used for exact scheduling alignment and daypart classification.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:audienceCompositionPct rdf:type rdf:Property ;
    rdfs:label 'Audience Composition Pct' ;
    rdfs:comment 'The percentage of the program\'s total audience represented by the primary target demographic (typically A18-49). Indicates how well the program indexes against its target audience and is used in ad sales proposals and programming strategy.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageAudience rdf:type rdf:Property ;
    rdfs:label 'Average Audience' ;
    rdfs:comment 'The average number of persons or households tuned to the program during an average minute of the telecast. Expressed in thousands (000s). AA is the primary audience volume metric used in GRP and CPM calculations for ad sales.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumeAudience rdf:type rdf:Property ;
    rdfs:label 'Cume Audience' ;
    rdfs:comment 'The unduplicated number of different persons or households that tuned to the program for at least one minute across all airings within a defined period. Expressed in thousands (000s). Cume measures total reach and is critical for frequency management in ad campaign planning.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoA1849Rating rdf:type rdf:Property ;
    rdfs:label 'Demo A18 49 Rating' ;
    rdfs:comment 'The percentage of Adults aged 18-49 in the measured universe who were tuned to this program. A18-49 is the most commercially valuable and widely traded demographic in US television advertising, serving as the primary currency for primetime ad sales.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoA2554Rating rdf:type rdf:Property ;
    rdfs:label 'Demo A25 54 Rating' ;
    rdfs:comment 'The percentage of Adults aged 25-54 in the measured universe who were tuned to this program. A25-54 is a key secondary demographic used in news programming, cable networks, and certain advertiser categories.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoK211Rating rdf:type rdf:Property ;
    rdfs:label 'Demo K2 11 Rating' ;
    rdfs:comment 'The percentage of Children aged 2-11 in the measured universe who were tuned to this program. K2-11 is the primary demographic for children\'s programming and toy/food advertisers. Subject to COPPA compliance requirements for data handling.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoM1849Rating rdf:type rdf:Property ;
    rdfs:label 'Demo M18 49 Rating' ;
    rdfs:comment 'The percentage of Men aged 18-49 in the measured universe who were tuned to this program. M18-49 is a primary demographic for sports, automotive, and technology advertisers.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoW1849Rating rdf:type rdf:Property ;
    rdfs:label 'Demo W18 49 Rating' ;
    rdfs:comment 'The percentage of Women aged 18-49 in the measured universe who were tuned to this program. W18-49 is a primary demographic for lifestyle, beauty, and household product advertisers.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'The average number of times a unique person or household was exposed to the program within the measurement period. Frequency = GRP / Reach. Used with reach for ad campaign effectiveness analysis and makegoods calculations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grp rdf:type rdf:Property ;
    rdfs:label 'Grp' ;
    rdfs:comment 'The sum of all ratings delivered by an advertising schedule or program, representing total audience delivery without deduplication. GRP = Reach × Frequency. A fundamental currency metric in ad sales negotiations, upfront deals, and scatter market transactions.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdRating rdf:type rdf:Property ;
    rdfs:label 'Household Rating' ;
    rdfs:comment 'The percentage of all television households in the measured universe that were tuned to this program during the measurement period. Expressed as a decimal percentage (e.g., 5.2 = 5.2%). The foundational Nielsen rating metric used for ad pricing and programming evaluation.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdShare rdf:type rdf:Property ;
    rdfs:label 'Household Share' ;
    rdfs:comment 'The percentage of households using television (HUT) that were tuned to this program. Share = (Program Audience / HUT) × 100. Measures competitive performance relative to active TV viewers at the same time.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hutLevel rdf:type rdf:Property ;
    rdfs:label 'Hut Level' ;
    rdfs:comment 'The percentage of all television households in the universe that had their television sets in use during the measurement period. HUT is the denominator for household share calculations and a key indicator of overall TV viewing activity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressions rdf:type rdf:Property ;
    rdfs:label 'Impressions' ;
    rdfs:comment 'The total number of person-level exposures to the program, calculated as average audience multiplied by the number of airings. Expressed in absolute numbers (not thousands). Impressions are the transactional currency for digital and cross-platform ad sales.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingested Timestamp' ;
    rdfs:comment 'The timestamp at which this Nielsen rating record was ingested into the Databricks Lakehouse Silver layer from the Nielsen Media Research Platform. Used for data freshness monitoring, SLA tracking, and audit trail.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The timestamp of the most recent update to this rating record in the Silver layer, reflecting revisions from Nielsen (e.g., preliminary to final, or restated ratings). Supports change tracking and downstream consumer notification.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nielsenProgramCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Program Code' ;
    rdfs:comment 'Nielsen Media Research Platform\'s proprietary alphanumeric code uniquely identifying the program title within the Nielsen measurement system. Used as the business identifier for cross-referencing ratings data with Nielsen deliverables.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenReportDate rdf:type rdf:Property ;
    rdfs:label 'Nielsen Report Date' ;
    rdfs:comment 'The date on which Nielsen Media Research officially published or delivered this rating record to the broadcaster. Distinguishes the measurement air date from the data delivery date, which is critical for tracking preliminary vs. final rating release cycles.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nielsenReportWeek rdf:type rdf:Property ;
    rdfs:label 'Nielsen Report Week' ;
    rdfs:comment 'The ISO 8601 week identifier (e.g., 2024-W23) of the Nielsen measurement week in which this rating was reported. Nielsen measurement weeks run Monday through Sunday. Used for weekly ratings aggregation and trend analysis.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putLevel rdf:type rdf:Property ;
    rdfs:label 'Put Level' ;
    rdfs:comment 'The percentage of all persons in the measured universe who were watching television during the measurement period. PUT is the denominator for persons share calculations and complements HUT for demographic audience analysis.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingStatus rdf:type rdf:Property ;
    rdfs:label 'Rating Status' ;
    rdfs:comment 'Lifecycle status of this Nielsen rating record indicating whether the data is preliminary (fast nationals), final, or has been revised. Ad sales and programming decisions must distinguish preliminary from final ratings. Preliminary ratings are typically released within 24 hours; final ratings follow within days.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reach rdf:type rdf:Property ;
    rdfs:label 'Reach' ;
    rdfs:comment 'The unduplicated number of unique persons or households exposed to the program at least once within the measurement period. Expressed in thousands (000s). Reach is a core metric for ad campaign planning and audience delivery reporting.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The native record identifier assigned by the Nielsen Media Research Platform for this rating record. Preserved in the Silver layer for data lineage, reconciliation, and re-ingestion traceability back to the authoritative source system.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepsPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Sweeps Period Flag' ;
    rdfs:comment 'Indicates whether this rating was measured during a Nielsen Sweeps period (February, May, July, November intensive measurement periods). Sweeps ratings carry elevated importance for affiliate compensation, ad rate setting, and programming strategy.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeSpentViewingMin rdf:type rdf:Property ;
    rdfs:label 'Time Spent Viewing Min' ;
    rdfs:comment 'The average number of minutes that viewers in the measured audience spent watching the program. A key engagement metric used in programming decisions and content performance analysis. Expressed in minutes.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAudience rdf:type rdf:Property ;
    rdfs:label 'Total Audience' ;
    rdfs:comment 'The total number of persons or households that tuned to the program for at least six consecutive minutes. Expressed in thousands (000s). TA provides a broader reach measure than AA and is used for program promotion and scheduling decisions.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trp rdf:type rdf:Property ;
    rdfs:label 'Trp' ;
    rdfs:comment 'Rating points delivered specifically to a defined target demographic audience (e.g., Adults 18-49). TRP = (Target Audience Impressions / Target Universe) × 100. Used by advertisers to evaluate efficiency of reaching their specific target demographic.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:universeEstimateHh rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Hh' ;
    rdfs:comment 'The total estimated number of television households in the measured market or national universe used as the denominator for household rating calculations. Expressed in thousands (000s). Nielsen updates universe estimates annually based on census data.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:universeEstimatePersons rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Persons' ;
    rdfs:comment 'The total estimated number of persons in the measured market or national universe used as the denominator for persons rating calculations. Expressed in thousands (000s). Segmented by demographic group for TRP calculations.' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demographicSegmentId rdf:type rdf:Property ;
    rdfs:label 'Demographic Segment Id' ;
    rdfs:comment 'Unique surrogate identifier for each demographic segment record in the audience measurement reference master. Primary key for the demographic_segment product. [_canonical_skip_reason: Role classified as REFERENCE_LOOKUP — this is a reference master for standardized audience demographic classification cells; per-role minimums are exempt, but MASTER_RESOURCE minimums are applied given the entity carries rich descriptive and lifecycle attributes beyond a simple code list.]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemographicSegment .

ind:adobeSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Adobe Segment Code' ;
    rdfs:comment 'The corresponding segment identifier in Adobe Experience Platform (AEP) for digital audience activation. Enables cross-system reconciliation between Nielsen linear audience measurement and AEP digital audience profiles for cross-platform campaign targeting and DAI (Dynamic Ad Insertion) on OTT/streaming platforms.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageRangeMax rdf:type rdf:Property ;
    rdfs:label 'Age Range Max' ;
    rdfs:comment 'Upper bound (inclusive) of the age range defining this demographic cell, expressed in years. For example, 49 for the A18-49 cell. A null value indicates an open-ended upper bound (e.g., Adults 55+). Null for non-age-based segments.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeMin rdf:type rdf:Property ;
    rdfs:label 'Age Range Min' ;
    rdfs:comment 'Lower bound (inclusive) of the age range defining this demographic cell, expressed in years. For example, 18 for the A18-49 cell. Null for non-age-based segments such as psychographic or income quintile segments.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpmIndex rdf:type rdf:Property ;
    rdfs:label 'Cpm Index' ;
    rdfs:comment 'Relative CPM (Cost Per Mille) pricing index for this demographic segment compared to the baseline segment (index = 100). Premium segments such as A18-49 or W25-54 carry higher indices reflecting advertiser demand. Used in Salesforce Media Cloud ad sales proposals and upfront/scatter market pricing negotiations. Confidential commercial pricing data.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The timestamp when this demographic segment record was first created in the Silver Layer data product. Provides audit trail for data governance and lineage tracking in the Databricks Lakehouse environment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daypartRelevance rdf:type rdf:Property ;
    rdfs:label 'Daypart Relevance' ;
    rdfs:comment 'Comma-separated list of broadcast dayparts (e.g., \'Prime Time, Late Fringe, Daytime\') for which this demographic segment has primary relevance in programming and ad sales strategy. Informs Ericsson MediaFirst scheduling decisions and Wide Orbit daypart-based ad pod targeting. Null if the segment applies across all dayparts.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'The date from which this demographic segment definition is valid and available for use in audience measurement, ad sales targeting, and programming decisions. Supports temporal versioning of segment definitions as Nielsen and IAB standards evolve.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'The date after which this demographic segment definition is no longer valid for new audience measurement or ad targeting use. Null for currently active segments with no planned expiry. Enables historical ratings data to reference the correct segment definition vintage.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethnicityClassification rdf:type rdf:Property ;
    rdfs:label 'Ethnicity Classification' ;
    rdfs:comment 'Standardized ethnicity classification label for ethnicity-based demographic segments (e.g., \'Hispanic/Latino\', \'African American\', \'Asian American\', \'Non-Hispanic White\'). Populated only for ethnicity segment types. Aligned with Nielsen multicultural audience measurement standards and used in targeted content programming and ad sales. [ENUM-REF-CANDIDATE: hispanic_latino|african_american|asian_american|non_hispanic_white|native_american|multiracial|other — promote to reference product]' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprSpecialCategory rdf:type rdf:Property ;
    rdfs:label 'Gdpr Special Category' ;
    rdfs:comment 'Indicates whether this demographic segment is based on GDPR Article 9 special category data (e.g., ethnicity, health status). When true, enhanced consent and data processing controls are required for EU audience data associated with this segment. Relevant for pan-European distribution platforms and Ofcom-regulated services.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderQualifier rdf:type rdf:Property ;
    rdfs:label 'Gender Qualifier' ;
    rdfs:comment 'Gender dimension of the demographic cell. \'All\' denotes combined-gender segments (e.g., Adults 18-49, Persons 2+). Aligns with Nielsen standard gender breakdowns used in GRP/TRP calculations and ad sales targeting.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic level at which this demographic segment definition is applied. National segments are used for network-level ratings and upfront sales; DMA (Designated Market Area) segments apply to local market measurement; local applies to individual station markets; international for global distribution platforms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Grp Weight Factor' ;
    rdfs:comment 'Weighting factor applied to this demographic segment when calculating Gross Rating Points (GRP) and Target Rating Points (TRP) in audience measurement reports. Reflects the relative population size and measurement panel representation of the segment. Sourced from the Nielsen Media Research Platform and used in Wide Orbit ad scheduling and campaign delivery calculations.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdComposition rdf:type rdf:Property ;
    rdfs:label 'Household Composition' ;
    rdfs:comment 'Classification of household structure for household-based demographic segments. Used in HUT (Homes Using Television) and PUT (Persons Using Television) audience measurement reporting and in family-oriented programming and advertising targeting strategies.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iabAudienceCode rdf:type rdf:Property ;
    rdfs:label 'Iab Audience Code' ;
    rdfs:comment 'The IAB Audience Taxonomy 2.0 standardized code corresponding to this demographic segment. Enables cross-platform audience targeting alignment between linear broadcast, OTT/AVOD/SVOD digital campaigns, and programmatic advertising systems. Used in Salesforce Media Cloud ad proposals and Adobe Experience Platform segment mapping.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeQuintile rdf:type rdf:Property ;
    rdfs:label 'Income Quintile' ;
    rdfs:comment 'Household income quintile ranking (1=lowest 20%, 5=highest 20%) for income-based demographic segments. Populated only for income quintile segment types. Used in premium CPM pricing tiers and upfront ad sales targeting for high-value audience packages.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isChildrenSegment rdf:type rdf:Property ;
    rdfs:label 'Is Children Segment' ;
    rdfs:comment 'Indicates whether this demographic segment includes individuals under 13 years of age (e.g., K2-11, K2-5). Triggers COPPA compliance controls on data collection, ad targeting restrictions, and content rating enforcement. Critical for regulatory compliance in digital and broadcast advertising.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKeyDemo rdf:type rdf:Property ;
    rdfs:label 'Is Key Demo' ;
    rdfs:comment 'Flags whether this segment is designated as a key demographic (key demo) for the organization\'s primary ad sales and programming strategy. Key demos (typically A18-49, W25-54) command premium CPM rates and are the primary currency in upfront and scatter market negotiations.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNielsenStandardCell rdf:type rdf:Property ;
    rdfs:label 'Is Nielsen Standard Cell' ;
    rdfs:comment 'Indicates whether this demographic segment corresponds to an official Nielsen standard demographic cell (e.g., A18-49, W25-54). True for Nielsen-defined cells used in GRP/TRP/HUT/PUT ratings calculations; False for custom or proprietary segments defined internally or via Adobe Experience Platform.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'The audience measurement methodology used to quantify this demographic segment. Panel-based measurement uses Nielsen People Meter panels; census-based uses set-top box or streaming data; hybrid combines both; modeled uses statistical projection. Determines data quality, confidence intervals, and applicability for regulatory reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenCellLabel rdf:type rdf:Property ;
    rdfs:label 'Nielsen Cell Label' ;
    rdfs:comment 'The exact Nielsen Media Research standard cell label for this demographic segment (e.g., \'A18-49\', \'W25-54\', \'M18-34\', \'K2-11\', \'P2+\'). Used as the authoritative cross-reference when ingesting Nielsen ratings data and reconciling audience measurement reports from the Nielsen Media Research Platform.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Segment Code' ;
    rdfs:comment 'The native segment identifier assigned by the Nielsen Media Research Platform for this demographic cell. Used for direct API integration with Nielsen ratings data feeds, ensuring accurate mapping of audience measurement data to internal segment definitions.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformApplicability rdf:type rdf:Property ;
    rdfs:label 'Platform Applicability' ;
    rdfs:comment 'Indicates the distribution platforms for which this demographic segment definition is applicable. Linear segments apply to traditional broadcast/cable measurement; digital applies to OTT/streaming (SVOD, AVOD, FAST); cross-platform spans both; all applies universally. Drives segment availability in Wide Orbit (linear) vs. Adobe Experience Platform (digital) targeting.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psychographicProfile rdf:type rdf:Property ;
    rdfs:label 'Psychographic Profile' ;
    rdfs:comment 'Descriptive label for psychographic segment classification (e.g., \'Early Adopters\', \'Value Seekers\', \'Sports Enthusiasts\', \'News Junkies\'). Populated only for psychographic segment types. Derived from Adobe Experience Platform audience profiling and used in premium ad sales targeting and programming strategy.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachPotentialPct rdf:type rdf:Property ;
    rdfs:label 'Reach Potential Pct' ;
    rdfs:comment 'Estimated maximum reach potential expressed as a percentage of the segment universe achievable across the organization\'s full distribution footprint. Used in media planning to set realistic reach targets for ad campaigns and programming strategies. Sourced from Nielsen reach and frequency models.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Restriction Flag' ;
    rdfs:comment 'Indicates whether this demographic segment is subject to regulatory restrictions on data collection, targeting, or advertising. True for segments including minors (COPPA), sensitive demographic categories under GDPR Article 9, or segments subject to FCC advertising restrictions. Triggers compliance workflow in Adobe Experience Platform and Wide Orbit.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the demographic segment, aligned with Nielsen and IAB standard cell codes (e.g., A18-49, W25-54, M18-34, K2-11, P2+). Used as the business-facing identifier in ad sales proposals, ratings reports, and audience targeting systems.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Full narrative description of the demographic segment\'s defining characteristics, measurement criteria, and intended use cases. Provides context for business users in ad sales, programming, and analytics teams on how to correctly apply and interpret the segment in audience measurement and targeting workflows.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable label for the demographic segment (e.g., \'Adults 18-49\', \'Women 25-54\', \'Men 18-34\', \'Kids 2-11\'). Used in reporting dashboards, ad sales presentations, and EPG audience targeting configurations.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle state of the demographic segment definition. Active segments are available for audience targeting, ad sales proposals, and ratings reporting. Deprecated segments are retained for historical continuity but no longer used in new campaigns or programming decisions.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segment by its primary defining dimension. Distinguishes age/gender cells (Nielsen standard cells such as A18-49) from psychographic profiles, income quintiles, ethnicity classifications, behavioral clusters, and household composition segments. Drives which measurement methodology and data source applies.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifies the originating operational system of record from which this demographic segment definition was sourced. Nielsen indicates the Nielsen Media Research Platform; adobe_aep indicates Adobe Experience Platform; internal indicates proprietary segment definitions; iab indicates IAB Taxonomy-derived segments. Supports data lineage and reconciliation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepsPriority rdf:type rdf:Property ;
    rdfs:label 'Sweeps Priority' ;
    rdfs:comment 'Indicates whether this demographic segment is a priority measurement target during Nielsen sweeps periods (February, May, July, November). Priority segments receive enhanced panel measurement and are the primary basis for affiliate compensation and ad rate card negotiations during sweeps.' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:universeEstimate rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate' ;
    rdfs:comment 'Total estimated population count (universe) for this demographic segment in the measurement geography, as defined by Nielsen. Used as the denominator in ratings calculations (rating = audience / universe × 100). Updated periodically from Nielsen universe estimates and used in GRP, TRP, reach, and frequency reporting.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:universeEstimateYear rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Year' ;
    rdfs:comment 'The calendar year for which the universe estimate is valid. Nielsen updates universe estimates annually; this field identifies the vintage of the estimate to ensure correct ratings calculations and year-over-year audience trend analysis.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'The timestamp when this demographic segment record was most recently modified. Used for incremental data pipeline processing, change data capture, and audit compliance in the Databricks Lakehouse Silver Layer.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Audience measurement panels incur operational costs (panelist recruitment, maintenance, data processing, quality control) that must be allocated to research and insights cost centers for budget tracki' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Panels are operated by specific legal entities for regulatory compliance. MRC accreditation and data privacy obligations are entity-specific, requiring direct link for regulatory reporting and audit.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:cooperationRate rdf:type rdf:Property ;
    rdfs:label 'Cooperation Rate' ;
    rdfs:comment 'Percentage of recruited panel households or individuals who are actively and consistently providing usable measurement data. A declining cooperation rate is an early indicator of panel quality degradation and may trigger MRC review. Expressed as a decimal (e.g., 0.8500 = 85%).' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code indicating the primary country of coverage for this panel (e.g., USA, GBR, AUS). Required for international panels and regulatory reporting to Ofcom and the European Audiovisual Observatory.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Technical mechanism used to collect viewing data from panel members. Electronic meters (people meters) require active button-pressing; set-top-box (STB) and smart TV ACR (Automatic Content Recognition) are passive; diary is self-reported. Determines the granularity and reliability of minute-by-minute audience data.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demographicComposition rdf:type rdf:Property ;
    rdfs:label 'Demographic Composition' ;
    rdfs:comment 'Narrative or structured description of the demographic breakdowns captured by this panel (e.g., \'Age 2+, Adults 18-49, Adults 25-54, Persons 2-17, Households by income quintile\'). Defines which demographic cuts are available for TRP (Target Rating Point) calculations and demographic audience guarantees in ad sales.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date on which this panel was retired or superseded by a newer panel vintage. Null for currently active panels. Used to scope historical ratings queries to the correct panel vintage and to manage panel transitions during sweeps periods.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date on which this panel became the active currency measurement source for audience projections. Marks the beginning of the period for which this panel\'s data is used in ratings reports, ad sales guarantees, and GRP/TRP delivery calculations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementCurrencyFlag rdf:type rdf:Property ;
    rdfs:label 'Measurement Currency Flag' ;
    rdfs:comment 'Indicates whether this panel is designated as the official currency measurement source for audience guarantees in advertising transactions. True = this panel\'s data is used as the contractual basis for GRP/TRP delivery and makegood calculations in upfront and scatter market deals. False = supplemental or research-only panel.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minReportableRating rdf:type rdf:Property ;
    rdfs:label 'Min Reportable Rating' ;
    rdfs:comment 'The lowest audience rating value (expressed as a decimal fraction of the universe) that this panel can reliably report without exceeding acceptable statistical error thresholds. Ratings below this threshold are suppressed or flagged as unreliable. Typically expressed as a percentage (e.g., 0.0010 = 0.1%). Governed by MRC minimum cell size requirements.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrcAccreditationDate rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Date' ;
    rdfs:comment 'Date on which the MRC most recently granted or renewed accreditation for this panel. Used to track accreditation currency and schedule renewal audits. Panels must maintain continuous accreditation to support upfront and scatter market ad sales guarantees.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrcAccreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Expiry Date' ;
    rdfs:comment 'Date on which the current MRC accreditation for this panel expires and must be renewed. Expiry triggers a mandatory re-audit process. Ad sales teams must be notified of impending expiry to manage risk on guaranteed audience delivery commitments.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrcAccreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Status' ;
    rdfs:comment 'Current accreditation status granted by the Media Rating Council (MRC) for this panel. MRC accreditation is the industry standard for currency-grade audience measurement. Accredited panels are required for guaranteed ad buys and upfront sales commitments. Non-accredited panels cannot be used as primary currency.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenPanelCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Panel Code' ;
    rdfs:comment 'Nielsen\'s proprietary internal identifier for this panel as maintained in the Nielsen Media Research Platform. Used for direct API integration, data feed reconciliation, and cross-referencing Nielsen ratings reports. Distinct from the internal audience_panel_id surrogate key.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for capturing operational notes, known data quality issues, methodology changes, or special considerations associated with this panel (e.g., \'Sample boosted in Q3 2023 for Hispanic demographic\', \'Methodology change effective Jan 2024 — includes streaming\'). Used by audience analytics and ad sales teams.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfHomeMeasurementFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Home Measurement Flag' ;
    rdfs:comment 'Indicates whether this panel captures out-of-home (OOH) viewing, such as viewing in bars, hotels, airports, and other public venues. OOH measurement is captured via Portable People Meter (PPM) technology. OOH-inclusive panels produce higher total audience estimates than in-home-only panels.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:panelCode rdf:type rdf:Property ;
    rdfs:label 'Panel Code' ;
    rdfs:comment 'Externally-known alphanumeric code assigned by the measurement provider (e.g., Nielsen) to uniquely identify this panel within their system. Used for cross-system reconciliation with the Nielsen Media Research Platform.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelName rdf:type rdf:Property ;
    rdfs:label 'Panel Name' ;
    rdfs:comment 'Human-readable name of the audience measurement panel (e.g., \'Nielsen National People Meter 2024\', \'Nielsen Local People Meter — New York DMA\'). Used in reporting, dashboards, and ad sales presentations.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelStatus rdf:type rdf:Property ;
    rdfs:label 'Panel Status' ;
    rdfs:comment 'Current lifecycle state of the audience panel. Active panels are used for currency-grade audience projections. Suspended panels are temporarily halted due to quality or compliance issues. Retired panels are decommissioned and replaced by newer vintages.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelType rdf:type rdf:Property ;
    rdfs:label 'Panel Type' ;
    rdfs:comment 'Classification of the audience measurement methodology used by this panel. National People Meter (NPM) and Local People Meter (LPM) are electronic metered panels; Portable People Meter (PPM) captures out-of-home exposure; Diary is self-reported; Return Path Data (RPD) is set-top-box passback data; Hybrid combines multiple methods.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruitmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Recruitment Methodology' ;
    rdfs:comment 'Statistical sampling approach used to recruit panel members. Probability-based sampling (address-based or random-digit-dial) is required for MRC-accredited currency panels. Opt-in panels are used for supplemental or proprietary measurement. Affects the projectability and accreditation status of the panel.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'Cadence at which panel membership is rotated or refreshed to prevent panel conditioning effects and maintain demographic representativeness. Annual and biennial refreshes are standard for people meter panels; continuous recruitment is used for large-scale return path data panels.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingGranularity rdf:type rdf:Property ;
    rdfs:label 'Reporting Granularity' ;
    rdfs:comment 'Finest time interval at which this panel can produce reliable audience estimates. Minute-by-minute granularity is available from electronic people meter panels and supports DAI (Dynamic Ad Insertion) optimization. Quarter-hour is standard for diary panels. Determines compatibility with EPG-based program-level ratings reporting.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingErrorPct rdf:type rdf:Property ;
    rdfs:label 'Sampling Error Pct' ;
    rdfs:comment 'Estimated margin of error (as a percentage) for audience projections derived from this panel at a 95% confidence interval. Smaller panels have higher sampling error. Used by ad sales teams to communicate measurement uncertainty to advertisers and to set makegood thresholds for audience delivery shortfalls.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeHouseholds rdf:type rdf:Property ;
    rdfs:label 'Size Households' ;
    rdfs:comment 'Total number of sample households actively participating in this panel at any given time. Drives the statistical reliability and margin of error of projected audience estimates. A larger panel size yields lower sampling error for low-rated programs.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sizeIndividuals rdf:type rdf:Property ;
    rdfs:label 'Size Individuals' ;
    rdfs:comment 'Total number of individual persons (panelists) actively measured within this panel. Distinct from household count because multiple individuals per household are measured for demographic breakdowns used in Target Rating Point (TRP) calculations.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:streamingMeasurementFlag rdf:type rdf:Property ;
    rdfs:label 'Streaming Measurement Flag' ;
    rdfs:comment 'Indicates whether this panel captures streaming and OTT (Over-The-Top) viewing in addition to linear broadcast. Streaming-enabled panels support cross-platform audience measurement combining linear TV, SVOD, AVOD, and FAST channel viewing for total audience reporting.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sweepsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Sweeps Eligible Flag' ;
    rdfs:comment 'Indicates whether this panel is used during Nielsen Sweeps periods (February, May, July, November) for local market ratings measurement. Sweeps data drives local ad rates and program scheduling decisions. Only MRC-accredited panels with sufficient local market sample sizes are sweeps-eligible.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:universeEstimateType rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Type' ;
    rdfs:comment 'Specifies whether the universe_estimate represents total households, total persons, or TV households (HUT-eligible). TV households are the standard denominator for HUT (Homes Using Television) calculations in broadcast ratings.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vintageYear rdf:type rdf:Property ;
    rdfs:label 'Vintage Year' ;
    rdfs:comment 'Calendar year in which this panel sample was designed and recruited. Panels are periodically refreshed to maintain demographic representativeness as the population changes. Vintage year is used to track panel age and schedule mandatory refreshes per MRC accreditation requirements.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightingFactor rdf:type rdf:Property ;
    rdfs:label 'Weighting Factor' ;
    rdfs:comment 'Numeric multiplier applied to this panel\'s raw viewing data to project sample observations to the total universe estimate. A weighting factor greater than 1.0 indicates the panel under-represents a demographic segment relative to the population. Used in GRP and TRP calculations.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightingMethodology rdf:type rdf:Property ;
    rdfs:label 'Weighting Methodology' ;
    rdfs:comment 'Description of the statistical weighting approach applied to panel data to correct for demographic imbalances and non-response bias (e.g., \'Iterative Proportional Fitting / Raking\', \'Post-stratification weighting by age/sex/race/income\'). Critical for ensuring projected audience estimates are representative of the total population.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewershipRecordId rdf:type rdf:Property ;
    rdfs:label 'Viewership Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each granular viewership record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adSpotId rdf:type rdf:Property ;
    rdfs:label 'Ad Spot Id' ;
    rdfs:comment 'Foreign key linking to sales.ad_spot. Business justification: Ad spot delivery verification requires matching viewership records (actual impressions served) to specific ad spots. Affidavit generation, billing reconciliation, impression audits, and discrepancy re' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdSpot .

ind:assetVersionId rdf:type rdf:Property ;
    rdfs:label 'Asset Version Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_version. Business justification: Viewership analytics require knowing which specific asset version (4K HDR, SD, dubbed language) was delivered to measure QoE by rendition. Streaming platforms routinely analyze completion rates and en' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:audienceProfileId rdf:type rdf:Property ;
    rdfs:label 'Audience Profile Id' ;
    rdfs:comment 'Foreign key linking to audience.audience_profile. Business justification: A viewership_record captures granular viewing activity for an audience member. audience_profile is the audience domain\'s anonymized/pseudonymized master record for a unique audience member or househol' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceProfile .

ind:contentVersionId rdf:type rdf:Property ;
    rdfs:label 'Content Version Id' ;
    rdfs:comment 'Foreign key linking to content.version. Business justification: Viewership records must identify the specific content version delivered (language dub, resolution, accessibility variant) for rights compliance reporting, territory-specific version performance analys' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:deliverableId rdf:type rdf:Property ;
    rdfs:label 'Deliverable Id' ;
    rdfs:comment 'Foreign key linking to production.deliverable. Business justification: OTT and linear viewership records are generated against a specific deliverable (the stream or broadcast file consumed). Streaming analytics pipelines require linking viewership data to the deliverable' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deliverable .

ind:deviceTypeId rdf:type rdf:Property ;
    rdfs:label 'Device Type Id' ;
    rdfs:comment 'Hashed device identifier (e.g., hashed advertising ID, set-top box serial hash, or streaming device fingerprint) from which the viewing session originated. Pseudonymized to prevent direct device tracking per GDPR and CCPA. Used for device-level reach and frequency analysis.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceType .

ind:epgEntryId rdf:type rdf:Property ;
    rdfs:label 'Epg Entry Id' ;
    rdfs:comment 'Foreign key linking to scheduling.epg_entry. Business justification: Streaming and MVPD viewership records are attributed to EPG entries to measure tune-in driven by program listings. EPG-based viewership attribution is a standard audience measurement workflow for on-d' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpgEntry .

ind:householdId rdf:type rdf:Property ;
    rdfs:label 'Household Id' ;
    rdfs:comment 'Hashed/anonymized identifier representing the household unit from which the viewing event originated, derived from set-top box or ACR data. Pseudonymized per GDPR Article 25 and CCPA Section 1798.100 to prevent direct re-identification. Used for Nielsen household-level ratings aggregation and HUT (Homes Using Television) calculations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:playbackSessionId rdf:type rdf:Property ;
    rdfs:label 'Playback Session Id' ;
    rdfs:comment 'External business identifier for the viewing session as assigned by the source system (Adobe Experience Platform, set-top box telemetry, or streaming platform). Used to correlate records across ingestion pipelines and deduplicate events from multiple sources.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlaybackSession .

ind:privacyRequestId rdf:type rdf:Property ;
    rdfs:label 'Privacy Request Id' ;
    rdfs:comment 'Foreign key linking to compliance.privacy_request. Business justification: Privacy requests (access, deletion, portability) require viewership record identification and processing. GDPR/CCPA compliance mandates linking requests to specific data records for fulfillment within' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyRequest .

ind:programRundownId rdf:type rdf:Property ;
    rdfs:label 'Program Rundown Id' ;
    rdfs:comment 'Foreign key linking to scheduling.program_rundown. Business justification: ACR and set-top-box viewership records are matched to program rundowns to attribute viewing to specific rundown segments for content performance analytics and ad pod attribution. Essential for live an' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramRundown .

ind:subscriberId rdf:type rdf:Property ;
    rdfs:label 'Subscriber Id' ;
    rdfs:comment 'Reference to the authenticated subscriber account from Zuora subscription billing, populated for SVOD and authenticated AVOD sessions. Null for anonymous linear broadcast or unauthenticated OTT viewing.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:viewerProfileId rdf:type rdf:Property ;
    rdfs:label 'Viewer Profile Id' ;
    rdfs:comment 'Hashed/anonymized identifier representing an individual viewer within a household, derived from Adobe Experience Platform profile resolution or subscriber login. Pseudonymized per GDPR and CCPA. Used for PUT (Persons Using Television) and individual-level demographic analytics.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ViewerProfile .

ind:acrSource rdf:type rdf:Property ;
    rdfs:label 'Acr Source' ;
    rdfs:comment 'The data collection methodology or source system that generated this viewership record. ACR = Automatic Content Recognition from smart TV; set_top_box = return-path data from cable/satellite STB; streaming_telemetry = OTT platform event stream via Adobe Experience Platform; panel = Nielsen People Meter panel; return_path = MVPD return-path data.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adBreakCount rdf:type rdf:Property ;
    rdfs:label 'Ad Break Count' ;
    rdfs:comment 'Number of ad breaks (ad pods) encountered by the viewer during this viewing session. Used for DAI (Dynamic Ad Insertion) reconciliation, Wide Orbit affidavit verification, and advertiser delivery reporting.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adsViewedCount rdf:type rdf:Property ;
    rdfs:label 'Ads Viewed Count' ;
    rdfs:comment 'Total number of individual advertisement spots viewed (not skipped) by the viewer during this session. Used for AVOD monetization reporting, CPM impression counting, and advertiser campaign delivery verification against Wide Orbit schedules.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audienceShare rdf:type rdf:Property ;
    rdfs:label 'Audience Share' ;
    rdfs:comment 'The percentage of HUT (Homes Using Television) or PUT (Persons Using Television) tuned to this channel/program at the time of viewing, as reported by Nielsen. Share differs from rating in that it measures the proportion of active viewers rather than the total universe. Used for competitive programming analysis.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutApplied rdf:type rdf:Property ;
    rdfs:label 'Blackout Applied' ;
    rdfs:comment 'Indicates whether a geographic blackout restriction was applied to this viewing session, preventing delivery of specific content in the viewer\'s DMA or region per rights agreements. Used for blackout compliance auditing and retransmission consent reporting.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastDate rdf:type rdf:Property ;
    rdfs:label 'Broadcast Date' ;
    rdfs:comment 'The calendar date (yyyy-MM-dd) of the broadcast or streaming session, in the local broadcast timezone. Used as the primary date dimension for daily ratings aggregation, sweeps period attribution, and Nielsen overnight ratings reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdnEdgeNode rdf:type rdf:Property ;
    rdfs:label 'Cdn Edge Node' ;
    rdfs:comment 'Identifier of the Akamai CDN edge node or point-of-presence (PoP) that served the streaming content for this session. Used for CDN performance analysis, SLA compliance monitoring, and geographic delivery optimization.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionRate rdf:type rdf:Property ;
    rdfs:label 'Completion Rate' ;
    rdfs:comment 'Proportion of the content asset viewed during this session, expressed as a decimal between 0.0000 and 1.0000 (e.g., 0.7500 = 75% viewed). Sourced directly from platform telemetry; not derived within this product. Used for engagement scoring, programming decisions, and advertiser reporting.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Content Duration Seconds' ;
    rdfs:comment 'Total runtime in seconds of the full content asset or scheduled airing being viewed. Used as the denominator for completion rate calculations and to determine whether a full viewing occurred.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this viewership record was ingested into the Silver Layer. Used for data lineage tracking, quality auditing, and source-system reconciliation.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypart rdf:type rdf:Property ;
    rdfs:label 'Daypart' ;
    rdfs:comment 'The broadcast daypart time segment during which the tune-in occurred, as defined by industry standard time blocks. Daypart is a fundamental dimension for advertising sales (CPM pricing, GRP/TRP calculations), programming strategy, and Nielsen ratings reporting. [ENUM-REF-CANDIDATE: early_morning|daytime|early_fringe|prime_access|primetime|late_news|late_fringe|overnight — promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Category of device used to consume the content. Used for device-level audience segmentation, ad targeting eligibility, and platform-specific reach reporting. [ENUM-REF-CANDIDATE: tv|set_top_box|mobile|tablet|desktop|smart_tv|streaming_stick|gaming_console|dvr — promote to reference product]' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmProtected rdf:type rdf:Property ;
    rdfs:label 'Drm Protected' ;
    rdfs:comment 'Indicates whether the content stream was delivered with DRM (Digital Rights Management) encryption active during this session. Used for rights compliance auditing, anti-piracy reporting to MPA, and content protection SLA verification.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationViewedSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Viewed Seconds' ;
    rdfs:comment 'Total number of seconds the viewer actively watched the content during this session, as reported by the source telemetry system. Accounts for pauses and buffering exclusions per platform telemetry rules. Used for TSR (Time Spent Reading/Viewing) calculations and completion rate derivation.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'The date and time when this viewership record was first loaded into the Databricks Silver Layer lakehouse. Used for data freshness monitoring, SLA compliance, and audit trail purposes. Distinct from tune_in_timestamp (business event time).' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAuthenticated rdf:type rdf:Property ;
    rdfs:label 'Is Authenticated' ;
    rdfs:comment 'Indicates whether the viewer was authenticated (logged in) at the time of viewing. Authenticated sessions enable individual-level audience measurement and subscriber-linked analytics. Unauthenticated sessions rely on household or device-level inference.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSweepsPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Sweeps Period' ;
    rdfs:comment 'Flag indicating whether this viewership record falls within a Nielsen sweeps measurement period (February, May, July, November). Sweeps data is used for setting advertising rates and programming decisions. Critical for isolating sweeps vs. non-sweeps audience behavior.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nielsenProgramRating rdf:type rdf:Property ;
    rdfs:label 'Nielsen Program Rating' ;
    rdfs:comment 'The Nielsen audience rating score associated with the program airing for this viewership record, representing the percentage of the total TV households or persons in the universe tuned to the program. Sourced from Nielsen Media Research Platform integration. Used for GRP/TRP calculations and ad rate setting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'The distribution platform category through which the content was delivered. Used for multi-platform audience aggregation, MVPD/vMVPD carriage reporting, and OTT vs. linear audience segmentation. [ENUM-REF-CANDIDATE: broadcast|cable|satellite|ott|mvpd|vmvpd|web|mobile|podcast|social — promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playbackPositionSeconds rdf:type rdf:Property ;
    rdfs:label 'Playback Position Seconds' ;
    rdfs:comment 'The content offset position in seconds at which the viewer stopped watching (tune-out position within the asset). For linear broadcast, this reflects the offset from the scheduled start of the program. Used for resume-point analytics and mid-roll ad delivery attribution.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:streamQuality rdf:type rdf:Property ;
    rdfs:label 'Stream Quality' ;
    rdfs:comment 'The video quality level at which the content was delivered during this session, as reported by the ABR (Adaptive Bitrate Streaming) player or CDN telemetry from Akamai. Used for quality-of-experience reporting, CDN SLA compliance, and premium content delivery analytics.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tuneInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tune In Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) when the viewer began watching the content or tuned to the channel. This is the principal business event timestamp for the viewership record. Used for daypart analysis, time-spent calculations, and sweeps period attribution.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tuneOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tune Out Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) when the viewer stopped watching, changed channel, or the session ended. Used in conjunction with tune_in_timestamp to calculate duration_viewed_seconds.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:viewingStatus rdf:type rdf:Property ;
    rdfs:label 'Viewing Status' ;
    rdfs:comment 'Current lifecycle status of the viewing session record. \'completed\' = viewer watched to end or tune-out cleanly; \'in_progress\' = session still active at ingestion time; \'abandoned\' = viewer left before 10% completion; \'interrupted\' = session ended due to technical failure; \'error\' = telemetry data quality issue flagged.' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachFrequencyReportId rdf:type rdf:Property ;
    rdfs:label 'Reach Frequency Report Id' ;
    rdfs:comment 'Unique surrogate identifier for each reach and frequency report record in the Silver Layer lakehouse. Primary key for this transactional entity.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReachFrequencyReport .

ind:advertiserId rdf:type rdf:Property ;
    rdfs:label 'Advertiser Id' ;
    rdfs:comment 'Foreign key linking to advertising.advertiser. Business justification: Reach/frequency reports are generated for specific advertisers to show campaign performance across their portfolio, including cross-campaign reach, frequency distribution, and GRP/TRP delivery. Essent' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Advertiser .

ind:advertisingAudienceGuaranteeId rdf:type rdf:Property ;
    rdfs:label 'Advertising Audience Guarantee Id' ;
    rdfs:comment 'Foreign key linking to sales.advertising_audience_guarantee. Business justification: Audience guarantees are validated against reach_frequency_reports. Guarantee reconciliation compares contracted reach/frequency/GRP to delivered metrics from reports. Determines makegood obligations a' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdvertisingAudienceGuarantee .

ind:proposalId rdf:type rdf:Property ;
    rdfs:label 'Proposal Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_proposal. Business justification: Sales proposals include projected reach/frequency estimates that must be validated post-campaign against actual reach_frequency_reports. Proposal performance reconciliation compares guaranteed vs deli' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Proposal .

ind:audienceSharePct rdf:type rdf:Property ;
    rdfs:label 'Audience Share Pct' ;
    rdfs:comment 'The percentage of the total viewing audience (persons using television) that was watching the specific network or program during the measurement period. Calculated as the program\'s audience divided by the total HUT/PUT audience. Used for competitive programming analysis and ad sales positioning.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageFrequency rdf:type rdf:Property ;
    rdfs:label 'Average Frequency' ;
    rdfs:comment 'The average number of times a unique viewer within the target demographic was exposed to the content or campaign during the measurement period. Calculated as total impressions divided by unduplicated reach. Core metric for evaluating campaign saturation and makegoods calculation.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpm rdf:type rdf:Property ;
    rdfs:label 'Cpm' ;
    rdfs:comment 'The cost per one thousand audience impressions for the campaign or programming block, expressed in USD. Used by ad sales for post-campaign delivery validation, scatter market pricing justification, and makegood valuation. Confidential as it reflects negotiated commercial pricing.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cprp rdf:type rdf:Property ;
    rdfs:label 'Cprp' ;
    rdfs:comment 'The cost per one rating point delivered against the target demographic segment, expressed in USD. The primary pricing metric for linear TV advertising transactions. Used for upfront guarantee reconciliation, makegood valuation, and scatter market pricing. Confidential as it reflects negotiated commercial pricing.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'The ISO 4217 three-letter currency code for all monetary values in this report (CPM, CPRP). Defaults to USD for domestic US markets. Required for international market reports and multi-currency financial reconciliation under SOX compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryVariancePct rdf:type rdf:Property ;
    rdfs:label 'Delivery Variance Pct' ;
    rdfs:comment 'The percentage difference between the guaranteed audience delivery (GRP or TRP) and the actual delivered audience for the campaign flight. A negative value indicates under-delivery triggering makegood obligations; a positive value indicates over-delivery. Used for upfront guarantee reconciliation and scatter market adjustments.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveReach1plus rdf:type rdf:Property ;
    rdfs:label 'Effective Reach 1plus' ;
    rdfs:comment 'The count of unique persons exposed to the content or campaign at least one time (1+) during the measurement period. Equivalent to reach_persons; included as an explicit effective reach threshold field for consistency with N+ reporting framework used in post-campaign analysis.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveReach3plus rdf:type rdf:Property ;
    rdfs:label 'Effective Reach 3plus' ;
    rdfs:comment 'The count of unique persons exposed to the content or campaign at least three times (3+) during the measurement period. The industry-standard effective reach threshold used to assess whether sufficient frequency was achieved for advertising message recall. Critical for makegoods determination and campaign effectiveness evaluation.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveReachNplus rdf:type rdf:Property ;
    rdfs:label 'Effective Reach Nplus' ;
    rdfs:comment 'The count of unique persons exposed to the content or campaign at least N times (as defined by effective_reach_threshold) during the measurement period. Provides a configurable effective reach metric for custom campaign guarantee structures and advanced frequency analysis.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveReachThreshold rdf:type rdf:Property ;
    rdfs:label 'Effective Reach Threshold' ;
    rdfs:comment 'The minimum number of exposures (N) used to define effective reach for this specific report. Configurable per campaign or client agreement (e.g., 3 for standard campaigns, 5 for high-frequency campaigns). Determines the N+ threshold applied in effective reach calculations beyond the standard 1+ and 3+ fields.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hutRating rdf:type rdf:Property ;
    rdfs:label 'Hut Rating' ;
    rdfs:comment 'The percentage of all television households in the market that had their television sets in use during the measurement period. Sourced from Nielsen Media Research Platform. Used as a contextual benchmark for evaluating audience share and competitive programming performance.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMakegoodRequired rdf:type rdf:Property ;
    rdfs:label 'Is Makegood Required' ;
    rdfs:comment 'Indicates whether this reach and frequency report has identified an audience delivery shortfall that requires a makegood (compensatory ad spot) to be issued to the advertiser. Triggers the makegood workflow in Wide Orbit and Salesforce Media Cloud when set to True.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'The last date of the measurement window for which reach and frequency metrics are computed. Defines the end boundary of the campaign flight, programming block, or sweeps period being analyzed.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'The first date of the measurement window for which reach and frequency metrics are computed. Defines the start boundary of the campaign flight, programming block, or sweeps period being analyzed. Used in conjunction with measurement_period_end_date to bound the audience measurement interval.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'Classifies the type of measurement window for which this report was generated. \'campaign_flight\' covers a defined ad campaign run; \'programming_block\' covers a scheduled content block; \'daypart_window\' covers a standard broadcast daypart; \'sweeps_period\' covers an intensive Nielsen ratings measurement period; \'custom_window\' covers an ad hoc analysis window.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenReportCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Report Code' ;
    rdfs:comment 'The native report identifier assigned by the Nielsen Media Research Platform for this reach and frequency dataset. Used for source system traceability, data lineage, and reconciliation between the lakehouse Silver Layer and the Nielsen source system.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putRating rdf:type rdf:Property ;
    rdfs:label 'Put Rating' ;
    rdfs:comment 'The percentage of all persons in the target demographic who were watching television during the measurement period. Sourced from Nielsen Media Research Platform. Used alongside HUT to assess total available audience and calculate audience share for programming decisions.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachPct rdf:type rdf:Property ;
    rdfs:label 'Reach Pct' ;
    rdfs:comment 'The percentage of the target demographic universe reached at least once during the measurement period, calculated as (reach_persons / universe_estimate) × 100. Expressed as a decimal percentage (e.g., 45.2500 = 45.25%). Used by ad sales for post-campaign delivery reporting and scatter market pricing justification.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachPersons rdf:type rdf:Property ;
    rdfs:label 'Reach Persons' ;
    rdfs:comment 'The unduplicated count of unique persons within the target demographic segment who were exposed to the content or campaign at least once during the measurement period. The primary reach metric sourced from Nielsen Media Research Platform. Used for post-campaign delivery validation and upfront guarantee reconciliation.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Generated Timestamp' ;
    rdfs:comment 'The principal real-world event timestamp when this reach and frequency report was generated and delivered by the Nielsen Media Research Platform. Represents the business event time, distinct from audit timestamps. Used to track Nielsen data delivery SLAs and post-campaign reporting timeliness.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known business identifier for this reach and frequency report, sourced from the Nielsen Media Research Platform. Used by ad sales teams to reference specific post-campaign delivery reports in client communications, makegoods negotiations, and upfront guarantee reconciliation.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle state of the reach and frequency report. \'draft\' indicates in-progress computation; \'preliminary\' indicates initial Nielsen delivery pending validation; \'final\' indicates validated and approved for client delivery; \'revised\' indicates a corrected reissue; \'superseded\' indicates replaced by a newer version; \'archived\' indicates retired from active use.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportVersion rdf:type rdf:Property ;
    rdfs:label 'Report Version' ;
    rdfs:comment 'The version number of this reach and frequency report, incremented each time a revised or corrected report is issued by Nielsen or reprocessed in the lakehouse. Version 1 represents the initial delivery; subsequent versions represent corrections or revisions. Used to ensure ad sales teams are working with the most current data.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalImpressions rdf:type rdf:Property ;
    rdfs:label 'Total Impressions' ;
    rdfs:comment 'The total number of audience exposures (duplicated) to the content or campaign during the measurement period. Equals reach_persons multiplied by average_frequency. Used as the gross delivery metric for CPM-based advertising transactions and campaign pacing analysis.' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_territory. Business justification: Sales territories are defined by geographic market boundaries (DMA codes). Territory planning, quota allocation, rep assignment, and market-based revenue forecasting all require knowing which market_c' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTerritory .

ind:blackoutRuleApplicable rdf:type rdf:Property ;
    rdfs:label 'Blackout Rule Applicable' ;
    rdfs:comment 'Indicates whether geographic broadcast blackout rules apply to this market for sports or syndication exclusivity purposes. True if blackout restrictions can be enforced in this DMA; False otherwise. Used by rights management (Rightsline) and CDN geo-restriction (Akamai) to enforce territorial exclusivity.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastStandard rdf:type rdf:Property ;
    rdfs:label 'Broadcast Standard' ;
    rdfs:comment 'Digital broadcast transmission standard applicable to this market. \'ATSC\' (Advanced Television Systems Committee) is the US standard; \'DVB\' (Digital Video Broadcasting) is the European standard; \'ISDB\' is the Japanese/Brazilian standard; \'DTMB\' is the Chinese standard. Determines technical playout and transmission requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cablePenetrationRate rdf:type rdf:Property ;
    rdfs:label 'Cable Penetration Rate' ;
    rdfs:comment 'Estimated percentage of television households in the DMA that subscribe to cable television (MVPD or vMVPD service). Expressed as a decimal (e.g., 0.6234 = 62.34%). Used for carriage fee negotiations, distribution planning, and ad sales reach projections.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daylightSavingObserved rdf:type rdf:Property ;
    rdfs:label 'Daylight Saving Observed' ;
    rdfs:comment 'Indicates whether the DMA observes Daylight Saving Time (DST). True if DST is observed; False if not (e.g., markets in Arizona). Affects daypart scheduling, playout timing, and EPG accuracy in broadcast automation systems.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmaCode rdf:type rdf:Property ;
    rdfs:label 'Dma Code' ;
    rdfs:comment 'Nielsen-assigned three-digit numeric code uniquely identifying the Designated Market Area (DMA). This is the externally-known business identifier used across ad sales, ratings reporting, and FCC filings. Sourced from Nielsen Media Research Platform.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmaRank rdf:type rdf:Property ;
    rdfs:label 'Dma Rank' ;
    rdfs:comment 'Nielsen-assigned national rank of the DMA by television household universe size, where rank 1 is the largest market (New York). Used for market prioritization in ad sales, upfront negotiations, and carriage fee calculations. Updated annually by Nielsen.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'The date from which this market coverage record became effective and the DMA definition was valid. Used for temporal versioning of DMA boundary and universe changes, ensuring historical ratings data is associated with the correct market definition.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'The date on which this market coverage record ceased to be effective, typically due to a DMA boundary redefinition, market merger, or discontinuation. Null for currently active market definitions. Supports slowly changing dimension (SCD) history tracking.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fccMarketCode rdf:type rdf:Property ;
    rdfs:label 'Fcc Market Code' ;
    rdfs:comment 'FCC-assigned market identifier used for must-carry and retransmission consent compliance filings. Maps the Nielsen DMA to the FCC\'s designated market definition for broadcast licensing, spectrum regulation, and MVPD carriage obligations. Required for regulatory reporting under FCC 47 CFR Part 76.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicBoundaryWkt rdf:type rdf:Property ;
    rdfs:label 'Geographic Boundary Wkt' ;
    rdfs:comment 'Well-Known Text (WKT) representation of the DMA\'s geographic boundary polygon. Used for spatial analysis, blackout rule enforcement, retransmission consent territory mapping, and OTT/streaming geo-restriction via CDN (Akamai). Conforms to OGC WKT standard.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hispanicTvHouseholdPct rdf:type rdf:Property ;
    rdfs:label 'Hispanic Tv Household Pct' ;
    rdfs:comment 'Estimated percentage of television households in the DMA that are Hispanic/Latino, as measured by Nielsen. Expressed as a decimal (e.g., 0.2341 = 23.41%). Used for Spanish-language content distribution decisions, targeted ad sales, and TRP (Target Rating Point) calculations for Hispanic demographic segments.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hutBaseEstimate rdf:type rdf:Property ;
    rdfs:label 'Hut Base Estimate' ;
    rdfs:comment 'Nielsen baseline estimate of the percentage of television households in the DMA that are using television during an average primetime daypart. Expressed as a decimal (e.g., 0.5823 = 58.23%). Used as a reference benchmark for HUT-based audience projections and ad sales planning.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketName rdf:type rdf:Property ;
    rdfs:label 'Market Name' ;
    rdfs:comment 'Official human-readable name of the Designated Market Area (DMA) or television market as defined by Nielsen (e.g., \'New York\', \'Los Angeles\', \'Chicago\'). Used in audience reports, ad sales proposals, and regulatory filings.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketStatus rdf:type rdf:Property ;
    rdfs:label 'Market Status' ;
    rdfs:comment 'Current lifecycle status of the market coverage record. \'active\' indicates the DMA is currently measured and used in audience reporting; \'inactive\' indicates it is no longer measured; \'pending\' indicates a newly defined market awaiting first measurement; \'discontinued\' indicates a market that has been merged or eliminated by Nielsen.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketType rdf:type rdf:Property ;
    rdfs:label 'Market Type' ;
    rdfs:comment 'Classification of the market scope. \'local\' indicates a single-city DMA; \'regional\' indicates a multi-city or multi-state DMA; \'national\' indicates a national aggregate market; \'international\' indicates a non-US market territory. Used for ad sales segmentation, carriage fee tiers, and programming distribution decisions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'Frequency at which Nielsen provides audience measurement data for this market. \'continuous\' indicates year-round metered measurement (PPM markets); \'sweeps_only\' indicates measurement only during sweeps periods (diary markets); \'quarterly\' or \'annual\' for smaller markets with less frequent measurement cycles.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medianHouseholdIncome rdf:type rdf:Property ;
    rdfs:label 'Median Household Income' ;
    rdfs:comment 'Median annual household income (in USD) for the DMA, sourced from U.S. Census Bureau data as incorporated into Nielsen demographic profiles. Used for audience demographic segmentation, CPM (Cost Per Mille) pricing tiers, and advertiser targeting qualification.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mustCarryApplicable rdf:type rdf:Property ;
    rdfs:label 'Must Carry Applicable' ;
    rdfs:comment 'Indicates whether FCC must-carry rules apply to broadcast stations in this market, requiring cable operators (MVPDs) to carry local broadcast signals. True if must-carry obligations exist; False otherwise. Critical for retransmission consent negotiations and MVPD carriage compliance.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nielsenSourceMarketCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Source Market Code' ;
    rdfs:comment 'The native market identifier as assigned and used within the Nielsen Media Research Platform source system. Used for data lineage, reconciliation between the lakehouse silver layer and the Nielsen source system, and audit of universe estimate ingestion.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenStationIndex rdf:type rdf:Property ;
    rdfs:label 'Nielsen Station Index' ;
    rdfs:comment 'Total number of television stations measured by Nielsen within this DMA. Indicates the competitive landscape of the local market and is used in share calculations and ad sales competitive analysis.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ottPenetrationRate rdf:type rdf:Property ;
    rdfs:label 'Ott Penetration Rate' ;
    rdfs:comment 'Estimated percentage of television households in the DMA that access video content via OTT (Over-The-Top) streaming services. Expressed as a decimal. Used for digital distribution planning, SVOD/AVOD audience projections, and DAI (Dynamic Ad Insertion) inventory estimation.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:populationUniverse rdf:type rdf:Property ;
    rdfs:label 'Population Universe' ;
    rdfs:comment 'Nielsen-estimated total population (persons 2+) residing within the DMA boundary. Used as the denominator for person-based ratings metrics including PUT (Persons Using Television) and TRP (Target Rating Point) calculations. Updated annually in the Nielsen universe estimates release.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'ISO 639-1 or ISO 639-2 language code representing the predominant language spoken in the DMA (e.g., \'en\' for English, \'es\' for Spanish). Used for content localization decisions, Spanish-language network distribution, and audience demographic targeting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalCity rdf:type rdf:Property ;
    rdfs:label 'Principal City' ;
    rdfs:comment 'Name of the primary city or metropolitan area that anchors and names the DMA (e.g., \'New York\', \'Los Angeles\', \'Chicago\'). Used in market identification, ad sales materials, and regulatory filings.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putBaseEstimate rdf:type rdf:Property ;
    rdfs:label 'Put Base Estimate' ;
    rdfs:comment 'Nielsen baseline estimate of the percentage of persons (2+) in the DMA who are using television during an average primetime daypart. Expressed as a decimal (e.g., 0.4612 = 46.12%). Used as a reference benchmark for PUT-based audience projections and TRP calculations.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this market coverage record was first created in the Databricks Lakehouse Silver Layer. Used for audit trail, data lineage tracking, and compliance with SOX financial reporting controls that require data provenance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this market coverage record was most recently updated in the Databricks Lakehouse Silver Layer. Used for change detection, incremental processing, and audit trail maintenance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Primary broadcast regulatory authority governing this market. \'FCC\' for US markets; \'Ofcom\' for UK markets; \'CRTC\' for Canadian markets; \'ACMA\' for Australian markets; \'other\' for all other jurisdictions. Determines applicable must-carry, retransmission consent, content standards, and licensing requirements.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentApplicable rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Applicable' ;
    rdfs:comment 'Indicates whether retransmission consent rules apply to broadcast stations in this market, allowing broadcasters to negotiate compensation from MVPDs for carriage of their signals. True if retransmission consent is applicable; False otherwise.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'ISO 3166-2 two-letter state or province code of the primary state in which the DMA\'s principal city is located (e.g., \'NY\', \'CA\', \'IL\'). Used for geographic segmentation, blackout rule enforcement, and retransmission consent jurisdiction determination.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepsParticipation rdf:type rdf:Property ;
    rdfs:label 'Sweeps Participation' ;
    rdfs:comment 'Indicates whether this market participates in Nielsen sweeps periods (intensive ratings measurement periods in February, May, July, and November). True if the market is measured during sweeps; False if it is a non-sweeps market. Affects programming scheduling strategy and ad sales pricing.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the primary time zone of the DMA (e.g., \'America/New_York\', \'America/Los_Angeles\'). Critical for daypart scheduling, playout automation in Ericsson MediaFirst, EPG (Electronic Program Guide) alignment, and ad scheduling in Wide Orbit Traffic system.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCounties rdf:type rdf:Property ;
    rdfs:label 'Total Counties' ;
    rdfs:comment 'Total number of counties or county-equivalents included within the DMA boundary. Nielsen defines DMA boundaries at the county level. Used for geographic coverage analysis, must-carry compliance, and retransmission consent territory verification.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tvHouseholdUniverse rdf:type rdf:Property ;
    rdfs:label 'Tv Household Universe' ;
    rdfs:comment 'Nielsen-estimated total number of television households within the DMA boundary. This is the principal quantitative measurement fact for the market and serves as the denominator for all local ratings calculations, GRP/TRP computations, and CPM-based ad pricing. Updated annually in the Nielsen universe estimates release.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:universeEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Universe Effective Date' ;
    rdfs:comment 'The date from which the current Nielsen universe estimates (TV household and population) became effective for this market. Used to track the currency of universe data and ensure ratings calculations use the correct denominator for the applicable measurement period.' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementEventId rdf:type rdf:Property ;
    rdfs:label 'Engagement Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each discrete digital audience engagement action captured on OTT/streaming platforms. Primary key for this product in the Databricks Silver Layer.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adBreakId rdf:type rdf:Property ;
    rdfs:label 'Ad Break Id' ;
    rdfs:comment 'Foreign key linking to scheduling.ad_break. Business justification: Ad engagement events (is_ad_event, ad_pod_position fields) must link to the specific ad_break for DAI attribution, ad verification, and campaign delivery reporting. Ad tech platforms require break-lev' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdBreak .

ind:adCampaignId rdf:type rdf:Property ;
    rdfs:label 'Ad Campaign Id' ;
    rdfs:comment 'Identifier for the advertising campaign associated with this engagement event, populated when the event is triggered within or adjacent to an ad pod. Supports DAI (Dynamic Ad Insertion) attribution and campaign performance measurement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to audience.audience_segment. Business justification: Engagement events are tagged with custom audience segments for behavioral targeting and activation. The audience_segment_code should be replaced with FK to audience_segment master for consistency and ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:adPodPosition rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Position' ;
    rdfs:comment 'Ordinal position of the advertisement within its ad pod (group of ads in a break) at the time of the engagement event. Populated only when is_ad_event is True. Used to analyse viewer drop-off rates by pod position and optimise ad pod sequencing for revenue assurance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appVersion rdf:type rdf:Property ;
    rdfs:label 'App Version' ;
    rdfs:comment 'Version string of the OTT/streaming application that captured the engagement event (e.g., 4.2.1). Used to correlate engagement behaviour with app release cycles and identify version-specific anomalies in audience interaction patterns.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Bitrate Kbps' ;
    rdfs:comment 'Actual bitrate in kilobits per second of the stream being delivered at the time of the engagement event. Sourced from Akamai CDN performance telemetry. Used alongside stream_quality to assess CDN delivery performance and its impact on audience engagement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bufferingDurationMs rdf:type rdf:Property ;
    rdfs:label 'Buffering Duration Ms' ;
    rdfs:comment 'Total duration of buffering experienced by the viewer immediately preceding or during this engagement event, in milliseconds. Sourced from Adobe Experience Platform quality-of-experience telemetry. Used to correlate buffering events with pause and abandonment engagement actions.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentDurationMs rdf:type rdf:Property ;
    rdfs:label 'Content Duration Ms' ;
    rdfs:comment 'Total duration of the content asset in milliseconds at the time of the engagement event. Used in conjunction with content_position_ms to compute completion percentage and engagement depth score. Sourced from Dalet Galaxy asset metadata.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentGenre rdf:type rdf:Property ;
    rdfs:label 'Content Genre' ;
    rdfs:comment 'Primary genre classification of the content asset associated with this engagement event (e.g., Drama, News, Sports, Comedy, Documentary). Sourced from Dalet Galaxy asset metadata. Used for genre-level audience behaviour analysis and programming acquisition decisions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentPositionMs rdf:type rdf:Property ;
    rdfs:label 'Content Position Ms' ;
    rdfs:comment 'Playback position within the content asset at the moment the engagement event was triggered, expressed in milliseconds from the start of the content. Core EVENT_PAYLOAD_OR_VALUE for this event log. Enables precise engagement depth analysis, completion rate calculation, and identification of drop-off points.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentRating rdf:type rdf:Property ;
    rdfs:label 'Content Rating' ;
    rdfs:comment 'Motion Picture Association (MPA) or TV Parental Guidelines content rating of the asset at the time of the engagement event. Used for COPPA compliance (children\'s content restrictions), audience demographic validation, and parental control enforcement. [ENUM-REF-CANDIDATE: G|PG|PG-13|R|NC-17|TV-Y|TV-Y7|TV-G|TV-PG|TV-14|TV-MA — promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyConsent rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Consent' ;
    rdfs:comment 'Viewer\'s data privacy consent status at the time of the engagement event, governing permissible use of this record for analytics, personalisation, and ad targeting. Sourced from Adobe Experience Platform consent management. Mandatory for GDPR Article 6 lawful basis determination and CCPA opt-out compliance.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceOs rdf:type rdf:Property ;
    rdfs:label 'Device Os' ;
    rdfs:comment 'Operating system of the device that generated the engagement event (e.g., iOS, Android, tvOS, Roku OS, Fire OS, Windows, macOS). Sourced from Adobe Experience Platform device context. Supports technical platform compatibility analysis and audience reach reporting.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmScheme rdf:type rdf:Property ;
    rdfs:label 'Drm Scheme' ;
    rdfs:comment 'DRM (Digital Rights Management) protection scheme active on the content stream at the time of the engagement event. Used for rights compliance verification and to ensure content is consumed within licensed windows and territories. Supports Rightsline rights enforcement reporting.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementDepthScore rdf:type rdf:Property ;
    rdfs:label 'Engagement Depth Score' ;
    rdfs:comment 'Normalised score (0.00–100.00) representing the depth of audience engagement at the time of the event, calculated by Adobe Experience Platform based on playback position relative to content duration, interaction frequency, and event type weighting. Key metric for non-linear audience behaviour analysis and ad targeting propensity modelling.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Processing lifecycle status of the engagement event record in the Silver Layer. \'valid\' indicates the event passed all quality checks; \'invalid\' indicates a data quality failure; \'duplicate\' indicates a repeated event suppressed from analytics; \'quarantined\' indicates the event is held pending investigation.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Precise UTC timestamp recording when the engagement action occurred on the viewer\'s device. Principal EVENT_TIMESTAMP for this event log entity. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX. Used for time-series audience behaviour analysis, daypart analytics, and sweeps period reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Categorical discriminator identifying the specific audience interaction captured: play (content start/resume), pause (playback halted), seek (position jump forward), rewind (position jump backward), share (social distribution action), like (positive sentiment signal), comment (text interaction), complete (full content consumption). Core EVENT_TYPE_OR_CHANNEL field for non-linear audience behaviour analysis. [ENUM-REF-CANDIDATE: play|pause|seek|rewind|share|like|comment|complete — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geo Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the viewer\'s geographic location at the time of the engagement event, derived from IP geolocation. Used for territorial rights compliance (blackout enforcement, holdback windows), audience reach reporting by geography, and regulatory jurisdiction determination.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geo Region Code' ;
    rdfs:comment 'ISO 3166-2 subdivision code (state, province, or region) of the viewer\'s location at the time of the engagement event. Used for sub-national blackout enforcement, regional audience measurement, and daypart-adjusted analytics.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdEvent rdf:type rdf:Property ;
    rdfs:label 'Is Ad Event' ;
    rdfs:comment 'Indicates whether this engagement event occurred during an advertisement (True) or during editorial content (False). Critical for separating content engagement metrics from ad engagement metrics in AVOD and DAI (Dynamic Ad Insertion) analytics.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConcurrentStream rdf:type rdf:Property ;
    rdfs:label 'Is Concurrent Stream' ;
    rdfs:comment 'Indicates whether this engagement event occurred on a stream that was running concurrently with another active stream on the same viewer account (True) or not (False). Used for concurrent stream limit enforcement per subscription terms and HUT (Homes Using Television) measurement.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isanCode rdf:type rdf:Property ;
    rdfs:label 'Isan Code' ;
    rdfs:comment 'ISAN (International Standard Audiovisual Number) of the content asset associated with this engagement event. Provides a globally unique, persistent identifier for the audiovisual work independent of platform or distribution channel. Supports rights management, royalty calculation, and regulatory reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'UTC timestamp when the engagement event was received and ingested by Adobe Experience Platform. Distinct from event_timestamp (client-side occurrence time). Used to measure event latency, detect clock skew, and support data quality auditing in the Silver Layer pipeline.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Channel or mechanism through which the viewer arrived at the content that triggered this engagement event. Used for audience acquisition attribution, marketing campaign effectiveness analysis, and content discovery optimisation. [ENUM-REF-CANDIDATE: direct|search|social|email|push_notification|in_app|external_link — promote to reference product]' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seekFromPositionMs rdf:type rdf:Property ;
    rdfs:label 'Seek From Position Ms' ;
    rdfs:comment 'Playback position in milliseconds from which the viewer initiated a seek or rewind action. Populated only when event_type is \'seek\' or \'rewind\'. Combined with content_position_ms (seek-to position) to measure skip behaviour and identify content segments that audiences skip or revisit.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemEventCode rdf:type rdf:Property ;
    rdfs:label 'Source System Event Code' ;
    rdfs:comment 'Original event identifier assigned by Adobe Experience Platform at the point of capture, before Silver Layer surrogate key assignment. Used for data lineage tracing, deduplication, and reconciliation between the Silver Layer and the Adobe Experience Platform source system.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionTier rdf:type rdf:Property ;
    rdfs:label 'Subscription Tier' ;
    rdfs:comment 'Subscription or access tier of the viewer at the time of the engagement event, reflecting the monetisation model under which content was consumed. Sourced from Zuora subscription billing. Used to segment engagement behaviour by revenue tier for ARPU analysis and churn prediction.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeId rdf:type rdf:Property ;
    rdfs:label 'Guarantee Id' ;
    rdfs:comment 'Unique surrogate identifier for the audience delivery guarantee record. Primary key for the audience_guarantee data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Foreign key linking to finance.chart_of_accounts. Business justification: Audience guarantees create financial liabilities tracked in specific GL accounts for accrual accounting. Finance requires direct GL account reference for makegood reserve calculations and financial st' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_contract. Business justification: Upfront sales negotiations frequently tie audience guarantees to specific talent participation (e.g., guaranteed GRPs for episodes featuring marquee talent). Sales teams negotiate rate premiums and de' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:generalLedgerId rdf:type rdf:Property ;
    rdfs:label 'General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: Each guarantee creates GL entries for revenue recognition and makegood liability accrual. Finance links guarantees to GL for audit trail, SOX compliance, and reconciliation of sold vs delivered audien' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:guaranteeChannelId rdf:type rdf:Property ;
    rdfs:label 'Guarantee Channel Id' ;
    rdfs:comment 'Foreign key linking to scheduling.channel. Business justification: Audience guarantees are often negotiated at the network/channel level for upfront deals. Direct channel link enables automated guarantee reconciliation, makegood issuance by channel, and channel-speci' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:guaranteeNetworkChannelId rdf:type rdf:Property ;
    rdfs:label 'Guarantee Network Channel Id' ;
    rdfs:comment 'Reference to the television network or channel on which the guaranteed audience delivery is to be achieved. Links to the network/channel master record used in scheduling and playout systems.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:salesforceOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Id' ;
    rdfs:comment 'The opportunity identifier in Salesforce Media Cloud CRM linked to this audience guarantee. Enables traceability from the sales pipeline through to audience delivery commitment and reconciliation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:schedulingDaypartId rdf:type rdf:Property ;
    rdfs:label 'Scheduling Daypart Id' ;
    rdfs:comment 'Foreign key linking to scheduling.daypart. Business justification: Upfront guarantees specify daypart-level GRP/TRP commitments (e.g., Prime 18-49 rating guarantee). Direct daypart link enables automated delivery tracking, makegood triggering, and daypart-specific re' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Daypart .

ind:actualGrpDelivered rdf:type rdf:Property ;
    rdfs:label 'Actual Grp Delivered' ;
    rdfs:comment 'The actual total GRP delivered against this guarantee as measured by the designated audience measurement source (e.g., Nielsen). Populated during and after the measurement period through reconciliation with actual delivery records. Used to determine whether the guarantee was met and whether makegoods are required.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualTrpDelivered rdf:type rdf:Property ;
    rdfs:label 'Actual Trp Delivered' ;
    rdfs:comment 'The actual total TRP delivered against this guarantee within the target demographic, as measured by the designated audience measurement source. Populated during reconciliation. Used alongside actual_grp_delivered to assess guarantee fulfillment for demographic-specific commitments.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The timestamp when this audience guarantee was formally approved and activated, transitioning from draft to active status. Represents the binding commitment date for revenue recognition and contractual obligation purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dealType rdf:type rdf:Property ;
    rdfs:label 'Deal Type' ;
    rdfs:comment 'Classification of the advertising deal under which this guarantee was established. Upfront refers to advance advertising sales events; scatter refers to last-minute ad inventory sales; direct, programmatic, and sponsorship represent other deal structures common in media broadcasting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryShortfallGrp rdf:type rdf:Property ;
    rdfs:label 'Delivery Shortfall Grp' ;
    rdfs:comment 'The calculated difference between the guaranteed GRP level and the actual GRP delivered (guaranteed_grp minus actual_grp_delivered). A positive value indicates under-delivery and potential makegood obligation. Populated during reconciliation.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteeNumber rdf:type rdf:Property ;
    rdfs:label 'Guarantee Number' ;
    rdfs:comment 'Externally-known business identifier for the audience guarantee, used in advertiser-facing documents, contracts, and reconciliation reports. Typically referenced in Wide Orbit sales orders and Salesforce Media Cloud opportunities.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeStatus rdf:type rdf:Property ;
    rdfs:label 'Guarantee Status' ;
    rdfs:comment 'Current lifecycle state of the audience guarantee. Draft indicates the guarantee is being negotiated; active indicates it is in-flight; at_risk indicates delivery is trending below threshold; breached indicates the guarantee was not met and makegoods are triggered; fulfilled indicates full delivery was achieved; cancelled indicates the guarantee was voided.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedFrequency rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Frequency' ;
    rdfs:comment 'The minimum average number of times a member of the target audience is exposed to the campaign (frequency) committed to the advertiser. Frequency is the average exposures per viewer. Used alongside reach guarantees for campaigns with specific exposure objectives.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedGrp rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Grp' ;
    rdfs:comment 'The total Gross Rating Point (GRP) level committed to the advertiser for delivery over the measurement period. GRP is the sum of ratings for all ad spots in the campaign, representing total audience exposure as a percentage of the target universe. This is the contractually obligated delivery level.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedReach rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Reach' ;
    rdfs:comment 'The minimum number of unique audience members (reach) committed to the advertiser over the measurement period. Reach is the count of distinct individuals exposed to the campaign at least once. Complements GRP/TRP guarantees for campaigns focused on unique audience coverage.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedTrp rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Trp' ;
    rdfs:comment 'The total Target Rating Point (TRP) level committed to the advertiser, measured specifically against the defined target demographic segment. TRP is the GRP filtered to the target audience. Used when the guarantee is demographic-specific rather than total audience.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Makegood Deadline Date' ;
    rdfs:comment 'The contractual deadline by which makegood spots must be aired to compensate for any audience delivery shortfall. Critical for revenue assurance and advertiser relationship management.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makegoodGrpIssued rdf:type rdf:Property ;
    rdfs:label 'Makegood Grp Issued' ;
    rdfs:comment 'The total GRP value of makegood (compensatory ad spots) issued to the advertiser to compensate for audience delivery shortfall. Tracked for revenue assurance and advertiser relationship management. Zero if no makegoods were required.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodTriggerCondition rdf:type rdf:Property ;
    rdfs:label 'Makegood Trigger Condition' ;
    rdfs:comment 'Textual description of the specific conditions under which makegood (compensatory ad spots) obligations are activated. Defines the contractual rules for when and how makegoods must be provided to the advertiser when guaranteed audience delivery is not met. Sourced from the advertising contract terms.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenOrderCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Order Code' ;
    rdfs:comment 'The external order or tracking identifier assigned by the Nielsen Media Research Platform for the audience measurement order associated with this guarantee. Used to cross-reference Nielsen ratings data and reconciliation reports.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingMetricType rdf:type rdf:Property ;
    rdfs:label 'Rating Metric Type' ;
    rdfs:comment 'Specifies the primary audience measurement metric on which this guarantee is based. GRP (Gross Rating Point) measures total audience exposure; TRP (Target Rating Point) measures exposure within the target demographic; HUT (Homes Using Television) and PUT (Persons Using Television) measure set usage; reach measures unique audience count; frequency measures average exposures per viewer.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Current status of the reconciliation process comparing guaranteed audience delivery against actual GRP/TRP delivery records. Pending indicates reconciliation has not started; in_progress indicates active comparison; reconciled indicates agreement reached; disputed indicates advertiser has contested the delivery figures; closed indicates the reconciliation cycle is complete.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold Pct' ;
    rdfs:comment 'The acceptable percentage shortfall below the guaranteed GRP/TRP level before a makegood obligation is triggered. For example, a value of 5.00 means delivery must be within 5% of the guaranteed level. Defined in the advertising contract and used in reconciliation against actual delivery records.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGuaranteeValue rdf:type rdf:Property ;
    rdfs:label 'Total Guarantee Value' ;
    rdfs:comment 'The total contracted monetary value of this audience guarantee, calculated as guaranteed GRP/TRP multiplied by CPRP. Represents the revenue at risk if the guarantee is not met and is central to revenue assurance and financial reconciliation.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wideOrbitOrderCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Order Code' ;
    rdfs:comment 'The sales order identifier in the Wide Orbit Traffic and Billing system associated with this audience guarantee. Used for cross-system reconciliation between audience delivery records and ad scheduling/invoicing.' ;
    rdfs:domain ind:Guarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenPanelId rdf:type rdf:Property ;
    rdfs:label 'Nielsen Panel Id' ;
    rdfs:comment 'Pseudonymized identifier assigned by Nielsen Media Research to link this audience profile to a Nielsen panel household or individual. Enables direct integration of Nielsen ratings, GRP/TRP, and demographic data. Null for non-panel profiles.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Panel .

ind:adReceptivityScore rdf:type rdf:Property ;
    rdfs:label 'Ad Receptivity Score' ;
    rdfs:comment 'Propensity score (0.00–100.00) indicating this audience member\'s likelihood to engage with advertising content, derived from behavioral signals in Adobe AEP and viewing pattern analysis. Used by ad sales teams for premium audience packaging and CPM pricing optimization.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aepProfileCode rdf:type rdf:Property ;
    rdfs:label 'Aep Profile Code' ;
    rdfs:comment 'Unique profile identifier from Adobe Experience Platform (AEP) used to link behavioral engagement data, segment memberships, and journey analytics to this audience profile. Enables personalization and digital engagement enrichment.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avgSessionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Avg Session Duration Minutes' ;
    rdfs:comment 'Average duration in minutes of a single viewing session for this audience member, derived from set-top box or streaming platform telemetry. Represents Time Spent Viewing (TSV) at the individual level. Used for engagement scoring and content performance analytics.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccpaOptOut rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out' ;
    rdfs:comment 'Indicates whether this California-resident audience member has exercised their CCPA right to opt out of the sale or sharing of their personal information. When TRUE, this profile must be excluded from data sharing with third-party ad networks and data clean rooms.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent change to any consent or privacy flag (GDPR consent status, CCPA opt-out, COPPA flag) for this audience profile. Critical for regulatory audit trails demonstrating timely consent management and data processing compliance.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contentAffinityGenre rdf:type rdf:Property ;
    rdfs:label 'Content Affinity Genre' ;
    rdfs:comment 'Top inferred content genre affinity for this audience member (e.g., \'news\', \'sports\', \'drama\', \'reality\', \'documentary\'), derived from viewing history and behavioral signals in Adobe AEP. Used for content recommendation, programming decisions, and audience-targeted ad sales. [ENUM-REF-CANDIDATE: news|sports|drama|comedy|reality|documentary|entertainment|kids|lifestyle|sci_fi — promote to reference product]' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaProtected rdf:type rdf:Property ;
    rdfs:label 'Coppa Protected' ;
    rdfs:comment 'Indicates whether this audience profile is subject to COPPA (Children\'s Online Privacy Protection Act) protections, meaning the inferred or declared age is under 13. When TRUE, ad targeting, data sharing, and behavioral tracking are strictly restricted per COPPA compliance requirements.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCleanRoomEligible rdf:type rdf:Property ;
    rdfs:label 'Data Clean Room Eligible' ;
    rdfs:comment 'Indicates whether this audience profile is eligible for inclusion in data clean room matching operations with advertising partners. Eligibility is determined by consent status, CCPA opt-out flag, COPPA protection status, and contractual data sharing agreements.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daypartPreference rdf:type rdf:Property ;
    rdfs:label 'Daypart Preference' ;
    rdfs:comment 'Preferred daypart (time segment of the broadcast day) during which this audience member most frequently views content. Dayparts are standard broadcast industry time segments used for ad scheduling, upfront sales, and audience guarantee reporting.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceGraphCode rdf:type rdf:Property ;
    rdfs:label 'Device Graph Code' ;
    rdfs:comment 'Cross-device graph linkage identifier that associates this audience profile with a cluster of known devices (smart TV, mobile, desktop, STB). Sourced from identity resolution providers or Adobe AEP device graph. Enables multi-screen reach and frequency measurement.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrichmentSourceVersion rdf:type rdf:Property ;
    rdfs:label 'Enrichment Source Version' ;
    rdfs:comment 'Version identifier of the third-party enrichment data package (e.g., Nielsen demographic file version, Adobe AEP segment refresh batch ID) used to populate inferred attributes on this profile. Enables data lineage tracing and reproducibility of audience segment definitions.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Status' ;
    rdfs:comment 'Current GDPR consent status for processing this audience member\'s personal data for audience measurement and advertising purposes. \'granted\' permits processing; \'denied\' or \'withdrawn\' restricts processing; \'not_applicable\' for non-EU audience members. Drives data processing eligibility.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdSize rdf:type rdf:Property ;
    rdfs:label 'Household Size' ;
    rdfs:comment 'Estimated number of persons in the audience household, derived from Nielsen panel data or set-top box signals. Used in HUT (Homes Using Television) and PUT (Persons Using Television) calculations for audience measurement reporting.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hutEligible rdf:type rdf:Property ;
    rdfs:label 'Hut Eligible' ;
    rdfs:comment 'Indicates whether this household-level audience profile is eligible to be counted in HUT (Homes Using Television) calculations. HUT measures the percentage of TV-equipped homes actively watching television during a given time period, a foundational metric for broadcast ratings.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identityConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Identity Confidence Score' ;
    rdfs:comment 'Confidence score (0.00–100.00) representing the reliability of the identity resolution that constructed this audience profile. Higher scores indicate stronger deterministic matching (e.g., authenticated login); lower scores indicate probabilistic device-graph inference. Used to qualify profiles for premium ad targeting.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identityHash rdf:type rdf:Property ;
    rdfs:label 'Identity Hash' ;
    rdfs:comment 'SHA-256 pseudonymized hash of the audience member\'s primary identity (e.g., email or subscriber ID) used for cross-platform identity resolution without exposing raw PII. Enables privacy-safe linkage across Nielsen, Adobe AEP, and first-party data sources.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identitySource rdf:type rdf:Property ;
    rdfs:label 'Identity Source' ;
    rdfs:comment 'Originating source of the audience identity construction: \'first_party\' (subscriber or app registration data), \'nielsen\' (Nielsen Media Research panel linkage), \'adobe_aep\' (Adobe Experience Platform profile), \'set_top_box\' (STB device-level data), \'clean_room\' (data clean room match), or \'modeled\' (probabilistic inference).' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBand rdf:type rdf:Property ;
    rdfs:label 'Income Band' ;
    rdfs:comment 'Inferred household income band derived from third-party demographic enrichment (Nielsen, data clean rooms). Used for premium audience segmentation in upfront and scatter market ad sales, enabling CPM pricing differentiation by audience affluence.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferredAgeBand rdf:type rdf:Property ;
    rdfs:label 'Inferred Age Band' ;
    rdfs:comment 'Inferred age demographic band for the audience member, derived from Nielsen panel data, set-top box signals, or modeled enrichment. Used for GRP/TRP demographic targeting and ad sales audience guarantees. Not directly collected from the individual.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferredGender rdf:type rdf:Property ;
    rdfs:label 'Inferred Gender' ;
    rdfs:comment 'Inferred gender of the audience member derived from panel data or modeled signals. Used for demographic audience targeting in ad sales (GRP/TRP calculations) and programming decisions. Not directly collected.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSeenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Seen Timestamp' ;
    rdfs:comment 'Timestamp of the most recent observed audience activity event (viewing session, app interaction, or platform login) for this profile. Used to determine audience recency, drive re-engagement campaigns, and calculate viewing recency metrics.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nielsenGrpIndex rdf:type rdf:Property ;
    rdfs:label 'Nielsen Grp Index' ;
    rdfs:comment 'Indexed GRP (Gross Rating Point) score for this audience profile relative to the total population, sourced from Nielsen Media Research. A GRP index above 100 indicates above-average exposure to rated content. Used in ad sales audience guarantees and upfront negotiations.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:panelWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Panel Weight Factor' ;
    rdfs:comment 'Statistical weighting factor assigned by Nielsen to this panel member profile to project panel observations to the total population. Applied in GRP, TRP, HUT, and PUT calculations. Null for non-panel (modeled or first-party only) profiles.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformPreference rdf:type rdf:Property ;
    rdfs:label 'Platform Preference' ;
    rdfs:comment 'Primary viewing platform preference inferred from behavioral signals: \'linear_tv\' (traditional scheduled broadcast), \'svod\' (Subscription Video On Demand), \'avod\' (Advertising-Supported VOD), \'tvod\' (Transactional VOD), \'fast\' (Free Ad-Supported Streaming TV), \'ott\' (Over-The-Top), \'mvpd\' (Multichannel Video Programming Distributor), or \'vmvpd\' (Virtual MVPD). Drives distribution strategy and ad product targeting. [ENUM-REF-CANDIDATE: linear_tv|svod|avod|tvod|fast|ott|mvpd|vmvpd — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDeviceType rdf:type rdf:Property ;
    rdfs:label 'Primary Device Type' ;
    rdfs:comment 'The primary device type through which this audience member most frequently consumes content, derived from device graph and behavioral data. Used for CDN delivery optimization, ad format targeting, and platform analytics.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle state of the audience profile. \'suppressed\' indicates a privacy opt-out or regulatory hold; \'pending_consent\' indicates consent collection is in progress; \'purged\' indicates the record has been anonymized per GDPR/CCPA erasure request.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileType rdf:type rdf:Property ;
    rdfs:label 'Profile Type' ;
    rdfs:comment 'Classification of the audience profile record: \'individual\' (single person identity), \'household\' (aggregated household unit), \'panel_member\' (Nielsen or equivalent panel participant), or \'modeled\' (synthetically constructed from behavioral signals without direct identity linkage).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trpIndex rdf:type rdf:Property ;
    rdfs:label 'Trp Index' ;
    rdfs:comment 'Indexed TRP (Target Rating Point) score representing this audience member\'s contribution to a specific demographic target group\'s rating. Distinct from GRP in that it measures reach within a defined target demographic. Used for demographic-specific ad campaign planning and post-campaign analysis.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewingRecencyDays rdf:type rdf:Property ;
    rdfs:label 'Viewing Recency Days' ;
    rdfs:comment 'Number of days since this audience member last engaged with any content on any tracked platform. Used for audience recency segmentation, churn prediction, and re-engagement campaign targeting. Lower values indicate more recently active audiences.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weeklyViewingFrequency rdf:type rdf:Property ;
    rdfs:label 'Weekly Viewing Frequency' ;
    rdfs:comment 'Average number of distinct viewing sessions per week for this audience member, calculated over a rolling 4-week window. Represents the Frequency dimension of audience measurement (average exposures per viewer). Used in reach and frequency reporting for ad campaign delivery.' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationStatus rdf:type rdf:Property ;
    rdfs:label 'Activation Status' ;
    rdfs:comment 'Current lifecycle state of the segment governing whether it is available for use in ad targeting, campaign activation, or content personalization. \'draft\' indicates under construction; \'pending_review\' awaits compliance or data governance approval; \'active\' is live and deployable; \'inactive\' is suspended; \'archived\' is retired.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aepSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Aep Segment Code' ;
    rdfs:comment 'The segment identifier as defined and managed within Adobe Experience Platform (AEP). Used for digital audience activation, personalization journeys, and cross-channel targeting. Enables synchronization between the internal audience_segment master record and the AEP segment definition for OTT and digital platforms.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the data governance or compliance approver who authorized this segment for activation, particularly for segments involving sensitive demographic data, COPPA-restricted audiences, or GDPR-regulated EU audiences. Supports audit trail requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentGenreAffinity rdf:type rdf:Property ;
    rdfs:label 'Content Genre Affinity' ;
    rdfs:comment 'Primary content genre(s) this segment shows strong viewership affinity toward, used for programming strategy alignment and contextual ad targeting (e.g., \'drama,sports,news\'). Sourced from Nielsen viewing behavior data or Adobe AEP content interaction signals. Informs content acquisition decisions and ad pod placement strategy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Identifies the primary data origin used to construct the segment. \'nielsen\' indicates Nielsen Media Research Platform ratings and demographic data; \'adobe_aep\' indicates Adobe Experience Platform behavioral profiles; \'first_party\' indicates proprietary subscriber or registration data; \'third_party\' indicates licensed external data; \'hybrid\' indicates a combination of multiple sources.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartApplicability rdf:type rdf:Property ;
    rdfs:label 'Daypart Applicability' ;
    rdfs:comment 'Broadcast daypart(s) for which this segment is most relevant or has been validated, expressed as a comma-delimited list of standard daypart labels (e.g., \'primetime,late_night\'). Daypart is a standard media-buying time segment of the broadcast day used in ad scheduling and upfront sales. [ENUM-REF-CANDIDATE: early_morning|daytime|early_fringe|primetime|late_news|late_night|overnight — promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionLogic rdf:type rdf:Property ;
    rdfs:label 'Definition Logic' ;
    rdfs:comment 'The rule-based or SQL/JSON expression that defines segment membership criteria as implemented in Adobe AEP or Nielsen. Captures the inclusion/exclusion logic (e.g., age range, viewing frequency thresholds, content genre affinity, platform usage) used to qualify audience members into this segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedReach rdf:type rdf:Property ;
    rdfs:label 'Estimated Reach' ;
    rdfs:comment 'Estimated number of unique individuals (persons or households) who qualify for this segment at the time of last refresh. Reach is a core Nielsen and IAB metric used in ad sales proposals, GRP/TRP calculations, and CPM pricing. Distinct from impressions — counts unique audience members, not exposures.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedReachUnit rdf:type rdf:Property ;
    rdfs:label 'Estimated Reach Unit' ;
    rdfs:comment 'Unit of measurement for the estimated_reach figure. \'persons\' aligns with Nielsen PUT (Persons Using Television) methodology; \'households\' aligns with HUT (Homes Using Television); \'devices\' applies to digital/OTT platform segments measured by device-level identity.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderTarget rdf:type rdf:Property ;
    rdfs:label 'Gender Target' ;
    rdfs:comment 'Gender composition target for the segment as defined in Nielsen demographic cells and ad sales targeting parameters. \'all\' indicates gender-neutral targeting. Used in GRP (Gross Rating Point) and TRP (Target Rating Point) calculations for ad campaign planning.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpIndex rdf:type rdf:Property ;
    rdfs:label 'Grp Index' ;
    rdfs:comment 'The GRP (Gross Rating Point) index value representing this segment\'s relative audience weight as a percentage of the total universe. GRP is a fundamental media planning metric equal to Reach × Frequency. Used in upfront and scatter market ad sales to price inventory and measure campaign delivery against this segment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hutPutBasis rdf:type rdf:Property ;
    rdfs:label 'Hut Put Basis' ;
    rdfs:comment 'Indicates whether the segment\'s reach and rating metrics are calculated on a HUT (Homes Using Television) or PUT (Persons Using Television) basis. HUT is household-level measurement; PUT is person-level. This distinction governs how GRP/TRP values are interpreted and how the segment is applied in Nielsen-based ad sales planning.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBracket rdf:type rdf:Property ;
    rdfs:label 'Income Bracket' ;
    rdfs:comment 'Household income tier associated with the segment\'s demographic composition, used in premium ad targeting and CPM (Cost Per Mille) pricing. Expressed as a standardized range label (e.g., \'$75K-$100K HHI\', \'$100K+ HHI\'). Sourced from Nielsen MRI-Simmons or first-party subscriber data. [ENUM-REF-CANDIDATE: under_25k|25k_50k|50k_75k|75k_100k|100k_150k|150k_plus — promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDaiEligible rdf:type rdf:Property ;
    rdfs:label 'Is Dai Eligible' ;
    rdfs:comment 'Indicates whether this segment is approved and technically configured for use in DAI (Dynamic Ad Insertion) workflows on OTT and streaming platforms. DAI-eligible segments can be activated in real-time ad decisioning systems integrated with Akamai CDN and programmatic ad servers for addressable advertising.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSweepsValidated rdf:type rdf:Property ;
    rdfs:label 'Is Sweeps Validated' ;
    rdfs:comment 'Indicates whether this segment\'s reach and demographic composition estimates have been validated using Nielsen Sweeps period data (the intensive ratings measurement periods in February, May, July, and November). Sweeps-validated segments carry higher confidence for upfront ad sales commitments and programming decisions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'The date and time when the segment membership, reach estimates, and demographic composition were last recalculated from source data. Used to assess data freshness for ad sales proposals and campaign activation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'The date and time when this audience segment record was last updated. Tracks changes to segment definition, status, reach estimates, or compliance flags. Used for change data capture (CDC) in the Databricks Silver Layer pipeline and audit trail maintenance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ownerTeam rdf:type rdf:Property ;
    rdfs:label 'Owner Team' ;
    rdfs:comment 'The business team or department that owns and is accountable for this segment\'s definition, quality, and lifecycle management (e.g., \'Ad Sales Research\', \'Audience Analytics\', \'Programming Strategy\', \'Digital Marketing\'). Used for data governance, access control, and segment portfolio management.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCategory rdf:type rdf:Property ;
    rdfs:label 'Segment Category' ;
    rdfs:comment 'Business-facing category grouping segments for portfolio management and reporting (e.g., \'Ad Targeting\', \'Programming Strategy\', \'Content Personalization\', \'Subscriber Retention\', \'Regulatory Reporting\'). Enables segment library organization in Salesforce Media Cloud and Adobe AEP. [ENUM-REF-CANDIDATE: ad_targeting|programming_strategy|content_personalization|subscriber_retention|regulatory_reporting|audience_research — promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Monotonically incrementing version counter for the segment definition. Incremented each time the segment\'s definition logic, demographic criteria, or platform applicability is materially changed. Enables segment versioning for historical campaign attribution — ad campaigns reference the segment version active at time of booking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Account Id' ;
    rdfs:comment 'Foreign key linking to billing.account. Business justification: Channels have associated billing accounts for carriage fees, retransmission consent payments, and affiliate revenue. Essential for MVPD/distribution billing, carriage agreement invoicing, and per-subs' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:formatSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Format Specification Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.format_specification. Business justification: Each channel has a mandated broadcast format specification (e.g., HD 1080i/50, UHD 4K HDR) governing all content aired. Scheduling and QC systems use this FK to auto-validate that scheduled asset vers' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormatSpecification .

ind:genreId rdf:type rdf:Property ;
    rdfs:label 'Genre Id' ;
    rdfs:comment 'Foreign key linking to content.genre. Business justification: Channels are programmed around a primary genre (sports, kids, news, drama). Linking to content.genre enables genre-based content acquisition planning, scheduling analytics, and ad targeting configurat' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Genre .

ind:adBreakDurationSec rdf:type rdf:Property ;
    rdfs:label 'Ad Break Duration Sec' ;
    rdfs:comment 'Default duration in seconds of a standard ad pod (ad break) for this channel. Used by Wide Orbit traffic system for ad scheduling, inventory management, and avail calculation. Typical values are 120 (2 minutes) or 180 (3 minutes).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affiliateNetworkCode rdf:type rdf:Property ;
    rdfs:label 'Affiliate Network Code' ;
    rdfs:comment 'Code identifying the parent broadcast network or affiliate group this channel belongs to (e.g., NBC, CBS, ABC, FOX). Used for network affiliation reporting, retransmission consent negotiations, and carriage fee calculations.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutEnabled rdf:type rdf:Property ;
    rdfs:label 'Blackout Enabled' ;
    rdfs:comment 'Indicates whether geographic broadcast blackout restrictions are applicable to this channel. When true, blackout rules must be enforced during playout and OTT delivery to restrict content in specific geographic markets per rights agreements.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastTimezone rdf:type rdf:Property ;
    rdfs:label 'Broadcast Timezone' ;
    rdfs:comment 'IANA timezone identifier for the channel\'s primary broadcast timezone (e.g., America/New_York, Europe/London). Governs daypart definitions, schedule generation, and EPG time display for the channel\'s primary market.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callSign rdf:type rdf:Property ;
    rdfs:label 'Call Sign' ;
    rdfs:comment 'Officially assigned broadcast call sign (e.g., WABC, KNBC) that uniquely identifies the station with the regulatory authority. Serves as the primary external business identifier for the channel as registered with the FCC or Ofcom.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Usd' ;
    rdfs:comment 'The per-subscriber monthly carriage fee in US dollars charged to MVPDs and vMVPDs for distributing this channel. Commercially sensitive financial data used in revenue assurance, financial reconciliation in SAP S/4HANA, and EBITDA reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdnOriginUrl rdf:type rdf:Property ;
    rdfs:label 'Cdn Origin Url' ;
    rdfs:comment 'The origin ingest URL configured in Akamai CDN for this channel\'s live stream delivery. Used for OTT/streaming distribution, ABR (Adaptive Bitrate Streaming) packaging, and CDN cache configuration.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational lifecycle state of the channel. Drives playout automation eligibility, EPG publication, and scheduling availability in Ericsson MediaFirst.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Classification of the channel by its distribution and scheduling model. Linear indicates traditional scheduled broadcast; simulcast indicates simultaneous multi-platform broadcast; pop-up indicates temporary event channel; FAST (Free Ad-Supported Streaming Television) indicates ad-supported streaming linear channel; VOD indicates on-demand programming window channel.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingSystem rdf:type rdf:Property ;
    rdfs:label 'Content Rating System' ;
    rdfs:comment 'Default content advisory rating applied to the channel\'s programming under the applicable rating system (e.g., US TV Parental Guidelines). Drives V-chip compliance, parental control enforcement, and COPPA-regulated children\'s content restrictions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code identifying the country where the channel is licensed and originates its broadcast signal (e.g., USA, GBR, DEU). Used for regulatory jurisdiction determination, rights windowing, and blackout rule enforcement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daiEnabled rdf:type rdf:Property ;
    rdfs:label 'Dai Enabled' ;
    rdfs:comment 'Indicates whether Dynamic Ad Insertion (DAI) is active for this channel, enabling server-side ad replacement for OTT/streaming delivery. Drives ad operations workflow in Wide Orbit and integration with DAI platforms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daletChannelCode rdf:type rdf:Property ;
    rdfs:label 'Dalet Channel Code' ;
    rdfs:comment 'The channel identifier as configured in Dalet Galaxy Media Asset Management system. Used to link this channel to content ingest workflows, metadata management, archive operations, and rundown generation in Dalet.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'The date on which this channel was or is scheduled to be permanently decommissioned and removed from broadcast. Nullable for active channels. Used for lifecycle management, licence surrender, and EPG removal planning.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drmEnabled rdf:type rdf:Property ;
    rdfs:label 'Drm Enabled' ;
    rdfs:comment 'Indicates whether Digital Rights Management (DRM) encryption is applied to this channel\'s content stream for OTT/streaming delivery. Drives content protection configuration in Akamai CDN and subscriber entitlement enforcement in Zuora.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epgEnabled rdf:type rdf:Property ;
    rdfs:label 'Epg Enabled' ;
    rdfs:comment 'Indicates whether this channel is published to the Electronic Program Guide (EPG) for audience-facing schedule display. Channels under testing or decommissioned may be excluded from EPG publication.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hlsStreamUrl rdf:type rdf:Property ;
    rdfs:label 'Hls Stream Url' ;
    rdfs:comment 'The HLS (HTTP Live Streaming) manifest URL for this channel\'s live stream, used for Apple device and browser-based OTT delivery via Akamai CDN. Supports ABR (Adaptive Bitrate Streaming) for adaptive quality delivery.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The date on which this channel first went live and began broadcasting. Used for channel lifecycle tracking, anniversary reporting, regulatory licence history, and audience growth analytics.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:logicalChannelNumber rdf:type rdf:Property ;
    rdfs:label 'Logical Channel Number' ;
    rdfs:comment 'The numeric channel position assigned to this channel in the Electronic Program Guide (EPG) and set-top box channel lineup. Used by MVPDs and vMVPDs for channel navigation and must-carry compliance reporting.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxAdLoadPct rdf:type rdf:Property ;
    rdfs:label 'Max Ad Load Pct' ;
    rdfs:comment 'Maximum percentage of total broadcast hour that may be allocated to advertising on this channel. Governs inventory capacity planning, FCC commercial limits compliance (children\'s programming), and upfront/scatter market sales commitments.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediafirstChannelCode rdf:type rdf:Property ;
    rdfs:label 'Mediafirst Channel Code' ;
    rdfs:comment 'The channel identifier as configured in the Ericsson MediaFirst playout automation system. Used to link this master channel record to the playout engine for schedule execution, automation triggers, graphics insertion, and failover configuration.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpegDashStreamUrl rdf:type rdf:Property ;
    rdfs:label 'Mpeg Dash Stream Url' ;
    rdfs:comment 'The MPEG-DASH (Dynamic Adaptive Streaming over HTTP) manifest URL for this channel\'s live stream, used for Android, Smart TV, and cross-platform OTT delivery via Akamai CDN.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryStatus rdf:type rdf:Property ;
    rdfs:label 'Must Carry Status' ;
    rdfs:comment 'Indicates whether this channel is subject to must-carry obligations requiring MVPDs to include it in their channel lineup. Drives compliance reporting and carriage fee negotiations.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkName rdf:type rdf:Property ;
    rdfs:label 'Network Name' ;
    rdfs:comment 'Human-readable name of the broadcast network or channel brand (e.g., CNN, BBC One, ESPN). Used as the primary identity label for display in EPG, scheduling tools, and audience-facing interfaces.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenStationCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Station Code' ;
    rdfs:comment 'The unique station identifier assigned by Nielsen Media Research for audience measurement, ratings reporting, and GRP/TRP calculations. Links this channel to Nielsen ratings data for advertising sales and audience analytics.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutAutomationEnabled rdf:type rdf:Property ;
    rdfs:label 'Playout Automation Enabled' ;
    rdfs:comment 'Indicates whether the channel is configured for automated playout via Ericsson MediaFirst. When true, schedule execution, ad insertion cues, and failover are handled automatically. When false, manual playout operation is required.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retransmissionConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Required' ;
    rdfs:comment 'Indicates whether this channel requires retransmission consent from MVPDs before rebroadcasting. Drives carriage fee negotiations and compliance with FCC retransmission consent rules.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scte35Enabled rdf:type rdf:Property ;
    rdfs:label 'Scte35 Enabled' ;
    rdfs:comment 'Indicates whether SCTE-35 digital program insertion cue markers are active on this channel for Dynamic Ad Insertion (DAI). SCTE-35 signals define ad pod boundaries and splice points used by Wide Orbit traffic system and DAI platforms.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transmissionStandard rdf:type rdf:Property ;
    rdfs:label 'Transmission Standard' ;
    rdfs:comment 'Technical broadcast transmission standard used to deliver the channel signal. ATSC and ATSC 3.0 apply to North American over-the-air broadcast; DVB-T/T2 and DVB-S/S2 apply to European terrestrial and satellite; QAM applies to cable distribution; IP applies to OTT/streaming delivery. [ENUM-REF-CANDIDATE: ATSC|ATSC3|DVB-T|DVB-T2|DVB-S|DVB-S2|QAM|IP — promote to reference product]' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitStationCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Station Code' ;
    rdfs:comment 'The station code as configured in the Wide Orbit traffic and billing system. Used to link this channel master record to ad scheduling, sales orders, affidavit generation, and invoicing workflows in Wide Orbit.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daiConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Dai Configuration Id' ;
    rdfs:comment 'Foreign key linking to distribution.dai_configuration. Business justification: Daypart-specific DAI rules enforce regulatory and business constraints (COPPA restrictions in children\'s dayparts, primetime ad load caps, scatter vs upfront eligibility). Technical operations configu' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DaiConfiguration .

ind:adPodMaxCount rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Max Count' ;
    rdfs:comment 'The maximum number of ad pods (commercial breaks) permitted per hour within this daypart. Used by Wide Orbit for ad scheduling capacity planning and by Ericsson MediaFirst for playout rundown validation. Supports FCC commercial time compliance monitoring.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adPodMaxDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Max Duration Seconds' ;
    rdfs:comment 'The maximum allowable total duration in seconds for an ad pod (group of ads in a break) within this daypart. Governs commercial break length limits enforced by Ericsson MediaFirst playout automation and Wide Orbit ad scheduling. Aligns with FCC commercial time limits for children\'s programming dayparts.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableDays rdf:type rdf:Property ;
    rdfs:label 'Applicable Days' ;
    rdfs:comment 'Pipe-delimited list of days of the week on which this daypart definition applies, using three-letter abbreviations (e.g., MON|TUE|WED|THU|FRI for weekday dayparts, SAT|SUN for weekend). Governs schedule generation in Ericsson MediaFirst and ad inventory availability in Wide Orbit. [ENUM-REF-CANDIDATE: MON|TUE|WED|THU|FRI|SAT|SUN — promote to reference product]' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avgAudience000 rdf:type rdf:Property ;
    rdfs:label 'Avg Audience 000' ;
    rdfs:comment 'The average audience size in thousands of viewers (000s) expected during this daypart, based on Nielsen Media Research Platform historical ratings data. Used as the principal quantitative measurement of daypart audience value for ad sales, GRP calculations, and content scheduling decisions.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCpmUsd rdf:type rdf:Property ;
    rdfs:label 'Base Cpm Usd' ;
    rdfs:comment 'The baseline CPM (Cost Per Mille) rate in US dollars for advertising inventory sold within this daypart, before application of the rate_multiplier or audience demographic adjustments. Represents the floor pricing reference used in Salesforce Media Cloud upfront and scatter market proposals.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutEligible rdf:type rdf:Property ;
    rdfs:label 'Blackout Eligible' ;
    rdfs:comment 'Indicates whether geographic broadcast blackout restrictions can be applied to content scheduled within this daypart. When True, blackout rules (e.g., sports rights geographic exclusivity) may be enforced by the distribution platform. Aligns with must-carry and retransmission consent obligations.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentRatingRestriction rdf:type rdf:Property ;
    rdfs:label 'Content Rating Restriction' ;
    rdfs:comment 'The maximum permissible TV content rating (per MPA/TV Parental Guidelines) for programming scheduled within this daypart. Enforces content appropriateness standards — e.g., Prime Time may allow up to TV-14, while Children\'s dayparts are restricted to TV-Y or TV-Y7. Used by Ericsson MediaFirst for schedule validation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaRestricted rdf:type rdf:Property ;
    rdfs:label 'Coppa Restricted' ;
    rdfs:comment 'Indicates whether this daypart is subject to COPPA (Children\'s Online Privacy Protection Act) restrictions due to programming directed at children under 13. When True, audience data collection, behavioral targeting, and ad pod duration limits are governed by COPPA compliance rules and FCC children\'s television regulations.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daiEligible rdf:type rdf:Property ;
    rdfs:label 'Dai Eligible' ;
    rdfs:comment 'Indicates whether this daypart is eligible for Dynamic Ad Insertion (DAI) on OTT and streaming platforms. When True, ad pods within this daypart can be dynamically replaced with targeted ads during streaming delivery through Akamai CDN, enabling addressable advertising revenue.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dayCategory rdf:type rdf:Property ;
    rdfs:label 'Day Category' ;
    rdfs:comment 'High-level classification of the day-of-week applicability for the daypart. \'weekday\' covers Monday–Friday, \'weekend\' covers Saturday–Sunday, \'all_week\' applies every day, and \'holiday\' applies on designated public holidays. Used for rate card segmentation and audience demographic profiling.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartCode rdf:type rdf:Property ;
    rdfs:label 'Daypart Code' ;
    rdfs:comment 'Short alphanumeric business identifier for the daypart, used as the externally-known reference key across Wide Orbit traffic system, Ericsson MediaFirst playout automation, and Salesforce Media Cloud ad sales. Examples: PRIME, EARLY_AM, DAYTIME, LATE_FRINGE, OVERNIGHT. Aligns with Nielsen daypart taxonomy codes.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartDescription rdf:type rdf:Property ;
    rdfs:label 'Daypart Description' ;
    rdfs:comment 'Free-text narrative description of the daypart, including its programming characteristics, audience profile, and scheduling context. Used for internal documentation, Salesforce Media Cloud proposal narratives, and EPG metadata. Example: \'Prime Time (8PM-11PM) — highest-rated evening programming block targeting Adults 18-49.\'' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartName rdf:type rdf:Property ;
    rdfs:label 'Daypart Name' ;
    rdfs:comment 'Human-readable label for the daypart segment as displayed in the Electronic Program Guide (EPG), ad sales proposals, and scheduling interfaces. Examples: Early Morning, Morning Drive, Daytime, Prime Time, Late Fringe, Overnight.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartStatus rdf:type rdf:Property ;
    rdfs:label 'Daypart Status' ;
    rdfs:comment 'Current lifecycle state of the daypart definition. \'active\' indicates the daypart is in operational use for scheduling and ad sales. \'inactive\' means temporarily suspended. \'draft\' means under review before activation. \'deprecated\' means retired from use but retained for historical reference.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartType rdf:type rdf:Property ;
    rdfs:label 'Daypart Type' ;
    rdfs:comment 'Classifies the daypart by broadcast delivery mode. \'linear\' applies to traditional scheduled broadcast, \'non_linear\' to on-demand programming windows, \'simulcast\' to simultaneous multi-platform broadcast segments, and \'vod_window\' to VOD availability windows governed by this daypart definition.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total duration of the daypart window expressed in minutes. Derived from start_time and end_time boundaries but stored explicitly for scheduling calculations, ad inventory capacity planning, and rate card generation in Wide Orbit.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'The clock time (HH:mm:ss, 24-hour or extended broadcast-day format) at which the daypart ends. Supports broadcast day overflow notation (e.g., 25:59:59 for content airing past midnight within the same broadcast day). Paired with start_time to define the daypart boundary.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:epgDisplayOrder rdf:type rdf:Property ;
    rdfs:label 'Epg Display Order' ;
    rdfs:comment 'The sequential display order of this daypart within the Electronic Program Guide (EPG) channel grid, used by Ericsson MediaFirst for schedule presentation and by digital EPG distribution systems. Lower values appear earlier in the broadcast day display.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:makegoodEligible rdf:type rdf:Property ;
    rdfs:label 'Makegood Eligible' ;
    rdfs:comment 'Indicates whether compensatory ad spots (makegoods) can be scheduled within this daypart to fulfill underdelivered audience guarantees from other dayparts. Governs Wide Orbit makegood scheduling logic and Salesforce Media Cloud campaign reconciliation workflows.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nielsenDaypartCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Daypart Code' ;
    rdfs:comment 'The standardized daypart code as defined by Nielsen Media Research taxonomy (e.g., PRIME, EARLY_NEWS, LATE_NEWS, DAYTIME, EARLY_FRINGE, LATE_FRINGE, OVERNIGHT). Used to align internal scheduling definitions with Nielsen audience measurement reports and ratings data ingested from the Nielsen Media Research Platform.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Rate Multiplier' ;
    rdfs:comment 'Pricing multiplier applied to the base CPM (Cost Per Mille) rate card for ad inventory sold within this daypart. A value of 1.0000 represents the base rate; Prime Time typically carries a multiplier greater than 1.0 (e.g., 2.5000), while Overnight may be below 1.0 (e.g., 0.3000). Used in Salesforce Media Cloud proposal generation and Wide Orbit billing.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scatterEligible rdf:type rdf:Property ;
    rdfs:label 'Scatter Eligible' ;
    rdfs:comment 'Indicates whether unsold ad inventory within this daypart is available for scatter market (last-minute) sales. Governs Wide Orbit inventory availability rules for short-notice ad placement and makegood scheduling.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scte35CueEnabled rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue Enabled' ;
    rdfs:comment 'Indicates whether SCTE-35 digital program insertion cue markers are enabled for ad break signaling within this daypart. When True, Ericsson MediaFirst playout automation inserts SCTE-35 splice_insert commands at ad pod boundaries, enabling Dynamic Ad Insertion (DAI) for OTT and streaming distribution via Akamai CDN.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:simulcastEligible rdf:type rdf:Property ;
    rdfs:label 'Simulcast Eligible' ;
    rdfs:comment 'Indicates whether content scheduled in this daypart is eligible for simultaneous multi-platform broadcast (simulcast) across linear, OTT, and digital channels. When True, Ericsson MediaFirst can trigger simulcast distribution workflows for this daypart\'s programming.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'The clock time (HH:mm:ss, 24-hour format) at which the daypart begins each applicable day. Used by Ericsson MediaFirst for automated playout boundary detection and by Wide Orbit for ad scheduling slot assignment. Stored as STRING to support broadcast day conventions (e.g., 25:00:00 for post-midnight).' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:timezoneCode rdf:type rdf:Property ;
    rdfs:label 'Timezone Code' ;
    rdfs:comment 'The IANA timezone identifier (e.g., America/New_York, America/Los_Angeles, Europe/London) governing the clock boundaries of this daypart. Critical for multi-market broadcast operations where the same daypart definition must be applied across different time zones for network affiliates and regional channels.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfrontEligible rdf:type rdf:Property ;
    rdfs:label 'Upfront Eligible' ;
    rdfs:comment 'Indicates whether ad inventory within this daypart is offered during the upfront advance advertising sales event. Prime Time and key dayparts are typically upfront-eligible. Drives Salesforce Media Cloud opportunity and proposal configuration for annual upfront sales cycles.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wideOrbitDaypartCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Daypart Code' ;
    rdfs:comment 'The corresponding daypart identifier as configured in the Wide Orbit traffic and billing system. Used to reconcile internal daypart definitions with ad scheduling, sales orders, and affidavit records in Wide Orbit. Enables cross-system traceability for revenue assurance.' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDealId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Deal Id' ;
    rdfs:comment 'Foreign key linking to partner.acquisition_deal. Business justification: Program schedules airing acquired content must reference the acquisition deal for rights clearance verification, holdback compliance, and run-allowance tracking. Rights management and traffic operatio' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcquisitionDeal .

ind:affiliateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Affiliate Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.affiliate_agreement. Business justification: Affiliate station program schedules must reference the affiliate agreement to track must-air programming hours, preemption rights, and network compensation calculations. Affiliate relations and networ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AffiliateAgreement .

ind:assetCollectionId rdf:type rdf:Property ;
    rdfs:label 'Asset Collection Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_collection. Business justification: Syndication and themed programming blocks (e.g., a sports package, holiday marathon) are built from pre-curated asset collections. Scheduling teams assign a collection to a program schedule block, ena' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetCollection .

ind:coproductionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Coproduction Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.coproduction_agreement. Business justification: Program schedules airing co-produced content must reference the co-production agreement for credit obligation display, distribution rights allocation verification, and residuals tracking. Co-productio' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoproductionAgreement .

ind:distributionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Distribution Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.distribution_agreement. Business justification: Program schedules distributed to MVPDs or affiliates must reference the governing distribution agreement for must-carry compliance verification, blackout restriction enforcement, and carriage obligati' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionAgreement .

ind:licenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'License Agreement Id' ;
    rdfs:comment 'Foreign key linking to rights.license_agreement. Business justification: Schedule approval workflows require confirming the license agreement is valid for the scheduled broadcast period, territory, and channel. Rights clearance status on program_schedule is meaningless wit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:productionBudgetId rdf:type rdf:Property ;
    rdfs:label 'Production Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.production_budget. Business justification: Program schedules are executed against approved production budgets; finance controllers reconcile scheduled programming costs against budget lines for variance reporting and period-close. A media-broa' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionBudget .

ind:syndicationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Syndication Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.syndication_agreement. Business justification: Program schedules carrying syndicated content must reference the governing syndication agreement for rights clearance status, run-count tracking, barter spot reconciliation, and clearance obligation v' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SyndicationAgreement .

ind:adPodCount rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Count' ;
    rdfs:comment 'Total number of ad pods (groups of ads in a break) planned in the schedule for this channel day. An ad pod is a contiguous block of commercial spots within a program break. Used for inventory planning and SCTE-35 cue marker validation.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:asRunConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'As Run Confirmed Timestamp' ;
    rdfs:comment 'Timestamp when the as-run log was confirmed and reconciled against the planned schedule. Marks the transition to \'as-run\' status. Used for Wide Orbit affidavit generation, Nielsen ratings reconciliation, and revenue assurance.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blackoutFlag rdf:type rdf:Property ;
    rdfs:label 'Blackout Flag' ;
    rdfs:comment 'Indicates whether any geographic broadcast blackout restriction applies to this schedule. True = one or more programs in this schedule are subject to blackout in specific markets (e.g., sports rights blackout). Triggers downstream blackout enforcement in distribution and CDN systems.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentRatingAdvisory rdf:type rdf:Property ;
    rdfs:label 'Content Rating Advisory' ;
    rdfs:comment 'The highest content rating advisory applicable to any program in this schedule for the broadcast day. Used for parental control systems, V-chip compliance, and FCC content standards reporting. Ratings follow the TV Parental Guidelines system mandated by the FCC.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletWorkflowCode rdf:type rdf:Property ;
    rdfs:label 'Dalet Workflow Code' ;
    rdfs:comment 'Reference identifier for the Dalet Galaxy media asset management workflow instance associated with this schedule\'s content preparation and ingest activities. Links the schedule to the MAM workflow for asset readiness validation prior to playout.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyAlertReady rdf:type rdf:Property ;
    rdfs:label 'Emergency Alert Ready' ;
    rdfs:comment 'Indicates whether the schedule has been configured with Emergency Alert System (EAS) interrupt capability for this broadcast date. True = EAS interrupt slots are provisioned in the Ericsson MediaFirst rundown. Required for FCC EAS compliance.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epgGridCode rdf:type rdf:Property ;
    rdfs:label 'Epg Grid Code' ;
    rdfs:comment 'External identifier assigned to this schedule in the Electronic Program Guide (EPG) distribution system. Used by downstream EPG aggregators, set-top box providers, and digital guide services to reference the channel day grid. Aligns with DVB SI/EIT table identifiers.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fccChildrenProgrammingCompliant rdf:type rdf:Property ;
    rdfs:label 'Fcc Children Programming Compliant' ;
    rdfs:comment 'Indicates whether this schedule meets FCC children\'s educational and informational (E/I) programming requirements for the broadcast date. True = minimum required hours of qualifying children\'s programming are scheduled. Required for FCC license renewal compliance reporting.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this program schedule record. Tracks the last update across any field change, version increment, or status transition. Used for change detection in downstream EPG distribution and playout systems.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mediafirstRundownCode rdf:type rdf:Property ;
    rdfs:label 'Mediafirst Rundown Code' ;
    rdfs:comment 'Reference identifier for the automation rundown object in Ericsson MediaFirst that corresponds to this program schedule. Used to reconcile the planned schedule with the playout automation system\'s rundown for failover and as-run log generation.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryCompliant rdf:type rdf:Property ;
    rdfs:label 'Must Carry Compliant' ;
    rdfs:comment 'Indicates whether this schedule satisfies must-carry obligations for the channel on this broadcast date. Must-carry is the mandatory channel inclusion requirement imposed on cable and satellite MVPDs by the FCC. True = compliant; False = compliance issue requiring resolution.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playoutFailoverMode rdf:type rdf:Property ;
    rdfs:label 'Playout Failover Mode' ;
    rdfs:comment 'Indicates the Ericsson MediaFirst playout failover configuration active for this schedule. \'primary\' = normal automated playout; \'backup\' = failover to backup playout server; \'manual_override\' = operator has taken manual control of playout. Used for SLA and incident reporting.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Clearance Status' ;
    rdfs:comment 'Aggregate rights clearance status for all programs in this schedule as verified against Rightsline rights management. \'cleared\' = all programs have confirmed broadcast rights for this date and territory; \'pending\' = clearance in progress; \'partial\' = some programs cleared; \'failed\' = one or more rights conflicts identified.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleEndTime rdf:type rdf:Property ;
    rdfs:label 'Schedule End Time' ;
    rdfs:comment 'The planned end timestamp of the broadcast schedule for this channel day, including timezone offset. Typically 23:59:59 local broadcast time but may extend past midnight for overnight programming blocks. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable label for the schedule, typically combining channel name and broadcast date (e.g., \'CNN-HD 2024-06-15 v2\'). Used by scheduling operations staff to identify and reference the schedule in Ericsson MediaFirst and Wide Orbit Traffic systems.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Schedule Notes' ;
    rdfs:comment 'Free-text operational notes entered by scheduling staff regarding special instructions, exceptions, or context for this schedule (e.g., \'Breaking news override applied to 8PM slot\', \'Live sports event extends prime block by 30 min\'). Not used for automated processing.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleSource rdf:type rdf:Property ;
    rdfs:label 'Schedule Source' ;
    rdfs:comment 'Indicates how this schedule was generated. \'manual\' = built by scheduling staff; \'automated\' = generated by Ericsson MediaFirst automated schedule engine; \'imported\' = ingested from an external programming supplier or network feed; \'template\' = derived from a recurring schedule template.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStartTime rdf:type rdf:Property ;
    rdfs:label 'Schedule Start Time' ;
    rdfs:comment 'The planned start timestamp of the broadcast schedule for this channel day, including timezone offset. Typically 00:00:00 local broadcast time but may differ for overnight schedules that begin at a non-midnight boundary. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle state of the program schedule. \'draft\' = initial build in progress; \'approved\' = signed off by programming team; \'transmitted\' = sent to Ericsson MediaFirst playout automation; \'as-run\' = actual broadcast log confirmed; \'cancelled\' = schedule voided and replaced.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the schedule by programming strategy type. \'standard\' = regular broadcast day; \'special_event\' = live event or breaking news override; \'holiday\' = holiday programming grid; \'sweeps\' = Nielsen sweeps period intensive ratings schedule; \'upfront_preview\' = advance advertising sales event programming.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Monotonically incrementing version number for the schedule on a given channel and broadcast date. Enables tracking of schedule revisions from initial draft through final as-run. Version 1 is the initial draft; each approved revision increments the version.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scte35CueCount rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue Count' ;
    rdfs:comment 'Total number of SCTE-35 digital program insertion cue markers embedded in the schedule for this channel day. SCTE-35 cues signal ad break opportunities for Dynamic Ad Insertion (DAI) in both linear and OTT streams. Used to validate DAI readiness.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:simulcastFlag rdf:type rdf:Property ;
    rdfs:label 'Simulcast Flag' ;
    rdfs:comment 'Indicates whether this schedule is configured for simultaneous multi-platform broadcast (simulcast). True = the schedule is transmitted concurrently across linear broadcast and one or more OTT/streaming platforms. Drives Ericsson MediaFirst simulcast automation configuration.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:simulcastPlatformCount rdf:type rdf:Property ;
    rdfs:label 'Simulcast Platform Count' ;
    rdfs:comment 'Number of platforms on which this schedule is simultaneously broadcast when simulcast_flag is True. Used for multi-platform distribution planning and rights compliance verification across linear, OTT, and vMVPD delivery channels.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for the broadcast timezone in which this schedule\'s times are expressed (e.g., \'America/New_York\', \'Europe/London\'). Critical for accurate EPG display, daypart classification, and regulatory compliance reporting across markets.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAdTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Ad Time Seconds' ;
    rdfs:comment 'Total planned advertising airtime in seconds across all ad pods in the schedule for this channel day. Used for commercial inventory management, FCC commercial limits compliance, and revenue forecasting against Wide Orbit traffic orders.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalProgramTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Program Time Seconds' ;
    rdfs:comment 'Total planned programming (non-commercial) airtime in seconds for this channel day schedule. Equals total_runtime_seconds minus total_ad_time_seconds. Used for content utilization reporting and rights compliance verification.' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRuntimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Runtime Seconds' ;
    rdfs:comment 'Total planned runtime of all program items in the schedule, expressed in seconds. Used to validate that the schedule fills the full broadcast day (86,400 seconds for a 24-hour schedule) and to detect gaps or overlaps in the rundown.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionType rdf:type rdf:Property ;
    rdfs:label 'Transmission Type' ;
    rdfs:comment 'Indicates the primary mode of content delivery for this schedule. \'linear\' = traditional scheduled broadcast; \'vod_window\' = on-demand programming window; \'fast_channel\' = Free Ad-Supported Streaming Television (FAST) channel; \'simulcast\' = simultaneous multi-platform broadcast.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmitted Timestamp' ;
    rdfs:comment 'Timestamp when the approved schedule was transmitted to the Ericsson MediaFirst playout automation system. Marks the transition from \'approved\' to \'transmitted\' status. Used for playout readiness SLA monitoring and failover preparation.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wideOrbitLogCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Log Code' ;
    rdfs:comment 'Reference identifier for the corresponding traffic log in Wide Orbit Traffic and Billing system. Links the program schedule to the ad scheduling and affidavit records for commercial break reconciliation and proof-of-broadcast (affidavit) generation.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentEpisodeId rdf:type rdf:Property ;
    rdfs:label 'Content Episode Id' ;
    rdfs:comment 'Foreign key linking to content.content_episode. Business justification: For episodic programming, schedulers link slots to specific episodes for episode sequencing, repeat/rerun tracking (rerun_flag exists on schedule_slot), and EPG accuracy. Episode-level slot assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentEpisode .

ind:drmPolicyId rdf:type rdf:Property ;
    rdfs:label 'Drm Policy Id' ;
    rdfs:comment 'Foreign key linking to distribution.drm_policy. Business justification: Schedule slots for streaming/OTT delivery require a DRM policy assignment for rights enforcement and geo-restriction. Content protection compliance reporting and automated DRM enforcement during sched' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrmPolicy .

ind:grantId rdf:type rdf:Property ;
    rdfs:label 'Grant Id' ;
    rdfs:comment 'Foreign key linking to rights.grant. Business justification: Royalty calculation and rights exploitation reporting require knowing which specific grant (right type, territory, media type) authorizes each scheduled slot. Grants determine royalty rates and residu' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grant .

ind:mediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Schedule slots must reference the specific media file for playout automation systems (MediaFirst, WideOrbit) to execute. Critical for broadcast operations - automation pulls the actual file URI from t' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:schedulingAvailabilityWindowId rdf:type rdf:Property ;
    rdfs:label 'Scheduling Availability Window Id' ;
    rdfs:comment 'Reference to the active rights window in Rightsline that authorizes the broadcast of the content in this slot. Validates that the airing falls within the licensed holdback and windowing period for the territory and platform.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchedulingAvailabilityWindow .

ind:talentProfileId rdf:type rdf:Property ;
    rdfs:label 'Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: On-air talent (hosts, anchors, guests) are scheduled in broadcast slots. Scheduling systems track which talent appears in which slot for call sheets, union reporting, rights clearance verification, an' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:triggeringHoldbackId rdf:type rdf:Property ;
    rdfs:label 'Triggering Holdback Id' ;
    rdfs:comment 'Foreign key linking to rights.holdback. Business justification: Blackout enforcement on schedule slots is driven by holdback records. Linking slot to the triggering holdback enables blackout dispute resolution, holdback compliance reporting, and automated enforcem' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holdback .

ind:versionId rdf:type rdf:Property ;
    rdfs:label 'Version Id' ;
    rdfs:comment 'Foreign key linking to content.version. Business justification: Scheduling a specific version (dubbed, HD, SDR edit) is a core broadcast traffic operation. Traffic systems must record which version is scheduled per slot for playout automation handoff, rights compl' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:actualDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Seconds' ;
    rdfs:comment 'Real-world duration of the slot in seconds as recorded in the as-run log. Compared against planned_duration_seconds to identify overruns, underruns, and schedule compliance deviations. Used in affidavit reconciliation and makegoods processing.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Real-world start time of the slot as recorded in the as-run log by Ericsson MediaFirst playout automation. May differ from planned_start_time due to live events, technical delays, or schedule overruns. Critical for affidavit generation in Wide Orbit and Nielsen audience measurement reconciliation.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aspectRatio rdf:type rdf:Property ;
    rdfs:label 'Aspect Ratio' ;
    rdfs:comment 'Video aspect ratio of the content assigned to this slot. Drives playout automation letterboxing/pillarboxing decisions in Ericsson MediaFirst and ensures compliance with broadcast technical standards.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioFormat rdf:type rdf:Property ;
    rdfs:label 'Audio Format' ;
    rdfs:comment 'Audio encoding format for the content in this slot (e.g., stereo, Dolby 5.1, Dolby Atmos, mono). Required for playout automation configuration in Ericsson MediaFirst and compliance with broadcast audio loudness standards.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationEventCode rdf:type rdf:Property ;
    rdfs:label 'Automation Event Code' ;
    rdfs:comment 'Ericsson MediaFirst playout automation system event identifier for this slot. The native key from the MediaFirst rundown used for as-run reconciliation, failover event tracking, and technical operations audit.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionFlag rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Flag' ;
    rdfs:comment 'Indicates whether closed captioning is present and enabled for this slot (True). Mandatory for FCC compliance under the Twenty-First Century Communications and Video Accessibility Act (CVAA) for applicable programming.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:easAlertType rdf:type rdf:Property ;
    rdfs:label 'Eas Alert Type' ;
    rdfs:comment 'Type of Emergency Alert System (EAS) message associated with this slot when slot_type is \'eas\' (e.g., EAN — Emergency Action Notification, NPT — National Periodic Test, RWT — Required Weekly Test). Null for non-EAS slots. Mandatory for FCC EAS compliance logging. [ENUM-REF-CANDIDATE: EAN|NPT|RWT|SVR|TOR|FFW|HUW|WSW — promote to reference product]' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeNumber rdf:type rdf:Property ;
    rdfs:label 'Episode Number' ;
    rdfs:comment 'Episode identifier for serialized program content in this slot (e.g., S02E05 for Season 2, Episode 5). Used for rights window tracking in Rightsline, repeat detection, and EPG metadata publication.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlackout rdf:type rdf:Property ;
    rdfs:label 'Is Blackout' ;
    rdfs:comment 'Indicates whether a geographic broadcast restriction (blackout) applies to this slot (True). Blackout rules are enforced at the distribution layer and must be flagged at the slot level for rights compliance and audience measurement exclusion.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLive rdf:type rdf:Property ;
    rdfs:label 'Is Live' ;
    rdfs:comment 'Indicates whether this slot carries a live broadcast event (True) or pre-recorded/taped content (False). Live slots require different playout automation handling, DAI configuration, and rights clearance verification in Rightsline.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeat rdf:type rdf:Property ;
    rdfs:label 'Is Repeat' ;
    rdfs:comment 'Indicates whether this slot is a repeat airing of previously broadcast content (True) rather than a first-run premiere (False). Affects talent residuals calculations in Rightsline and Nielsen audience measurement weighting.' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSimulcast rdf:type rdf:Property ;
    rdfs:label 'Is Simulcast' ;
    rdfs:comment 'Indicates whether this slot is simultaneously broadcast across multiple platforms or channels (True). Simulcast slots require coordinated playout across linear and OTT/streaming distribution paths and may trigger additional rights obligations.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isciCode rdf:type rdf:Property ;
    rdfs:label 'Isci Code' ;
    rdfs:comment 'Industry Standard Commercial Identification (ISCI) code for the commercial spot airing in this slot. An 8-character alphanumeric code used by Wide Orbit and ad agencies to uniquely identify a specific commercial creative. Null for non-commercial slot types.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryFlag rdf:type rdf:Property ;
    rdfs:label 'Must Carry Flag' ;
    rdfs:comment 'Indicates whether this slot is subject to must-carry obligations requiring MVPDs to include this channel/content in their basic tier (True). Flags slots that cannot be blacked out or substituted under FCC must-carry rules.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Seconds' ;
    rdfs:comment 'Intended duration of the slot in seconds as scheduled in the EPG rundown. Used for schedule integrity validation, ad pod capacity planning, and compliance with broadcast standards for minimum program duration.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'Scheduled end date and time for this slot as defined in the EPG rundown. Derived from planned_start_time plus planned_duration_seconds but stored explicitly to support EPG grid queries and boundary validation.' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'Scheduled start date and time for this slot as defined in the EPG rundown prior to broadcast. Expressed in ISO 8601 format with timezone offset. Used for EPG publication, audience measurement alignment, and ad trafficking in Wide Orbit.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:programTitle rdf:type rdf:Property ;
    rdfs:label 'Program Title' ;
    rdfs:comment 'Human-readable title of the program or content event airing in this slot as it appears in the published EPG. Used for audience-facing program guides, Nielsen ratings matching, and schedule reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolution rdf:type rdf:Property ;
    rdfs:label 'Resolution' ;
    rdfs:comment 'Video resolution classification of the content in this slot (SD, HD, UHD, 4K). Determines the playout chain and CDN delivery profile used by Akamai and affects carriage fee agreements with MVPDs.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scte35CueInTime rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue In Time' ;
    rdfs:comment 'Timestamp of the SCTE-35 splice_insert cue-in signal marking the return to primary program content after an ad break. Paired with scte35_cue_out_time to define the exact ad avail window for DAI and Wide Orbit ad scheduling.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scte35CueOutTime rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue Out Time' ;
    rdfs:comment 'Timestamp of the SCTE-35 splice_insert cue-out signal marking the start of an ad break or content interruption within this slot. Used by Dynamic Ad Insertion (DAI) systems and downstream distribution platforms to trigger ad replacement. Null for non-break slot types.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Slot Sequence Number' ;
    rdfs:comment 'Ordinal position of this slot within the daily rundown for the channel. Determines the playout order in Ericsson MediaFirst automation. Sequence numbers are contiguous integers starting at 1 for each broadcast day.' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slotStatus rdf:type rdf:Property ;
    rdfs:label 'Slot Status' ;
    rdfs:comment 'Current lifecycle state of the schedule slot within the EPG workflow. Values: scheduled (initial EPG entry), confirmed (locked for playout), on_air (currently broadcasting), completed (as-run recorded), cancelled (removed from schedule), replaced (substituted with alternate content). Drives Ericsson MediaFirst automation state machine.' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotType rdf:type rdf:Property ;
    rdfs:label 'Slot Type' ;
    rdfs:comment 'Classification of the schedule slot by content category. Values: program (primary editorial content), promo (promotional spot), commercial_break (paid advertising break), filler (interstitial padding content), psa (Public Service Announcement), eas (Emergency Alert System message). Drives playout automation logic and ad insertion rules in Ericsson MediaFirst.' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Traffic Order Number' ;
    rdfs:comment 'Wide Orbit traffic system order number associated with this slot when it carries a commercial or promotional spot. Links the EPG slot to the ad sales order for affidavit generation, billing reconciliation, and makegood processing.' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsAvailabilityWindowId rdf:type rdf:Property ;
    rdfs:label 'Rights Availability Window Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_availability_window. Business justification: EPG publication workflow requires real-time validation that content is within its rights availability window before displaying to viewers. Prevents publishing unavailable content and supports automate' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsAvailabilityWindow .

ind:seriesId rdf:type rdf:Property ;
    rdfs:label 'Series Id' ;
    rdfs:comment 'Foreign key linking to content.series. Business justification: Series-level EPG reporting (e.g., all episodes of a series airing this week, series completion tracking for VOD catch-up) requires linking EPG entries to content.series. EPG aggregators use series gro' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Series .

ind:blackoutRegionCodes rdf:type rdf:Property ;
    rdfs:label 'Blackout Region Codes' ;
    rdfs:comment 'Comma-separated list of geographic region or market codes where this program is subject to broadcast blackout restrictions. Used by distribution systems to suppress EPG entry delivery in restricted markets. Populated only when is_blackout is True.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionWindow rdf:type rdf:Property ;
    rdfs:label 'Distribution Window' ;
    rdfs:comment 'The distribution window or release strategy under which this EPG entry is being broadcast, reflecting the windowing strategy for sequential content release. Determines rights availability and platform eligibility per Rightsline contract terms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'The total scheduled duration of the program in seconds, derived from the difference between scheduled start and end times. Used for EPG display, ad pod planning, and playout automation validation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eidr rdf:type rdf:Property ;
    rdfs:label 'Eidr' ;
    rdfs:comment 'The Entertainment Identifier Registry (EIDR) identifier for this content, providing a universal content identifier used across the media supply chain for content tracking, rights management, and EPG data exchange with MVPDs and vMVPDs.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'The current lifecycle status of this EPG entry within the scheduling workflow. \'draft\' indicates pending review; \'approved\' indicates cleared for distribution; \'published\' indicates actively distributed to EPG feeds; \'cancelled\' indicates removed from schedule; \'expired\' indicates the broadcast window has passed.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgEntryCode rdf:type rdf:Property ;
    rdfs:label 'Epg Entry Code' ;
    rdfs:comment 'Externally distributed business identifier for this EPG entry, used in feeds delivered to MVPDs, vMVPDs, set-top boxes, and digital platforms for program discovery. Format: EPG-{CHANNEL}-{YYYYMMDD}-{HHMMSS}.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgFeedVersion rdf:type rdf:Property ;
    rdfs:label 'Epg Feed Version' ;
    rdfs:comment 'The version number of this EPG entry record as distributed in the EPG feed. Incremented each time the entry is updated and redistributed to MVPDs, vMVPDs, and digital platforms. Enables downstream systems to detect and apply updates.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeTitle rdf:type rdf:Property ;
    rdfs:label 'Episode Title' ;
    rdfs:comment 'The title of the specific episode within a series, as displayed in the EPG. Null for non-episodic content such as feature films or standalone specials.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genrePrimary rdf:type rdf:Property ;
    rdfs:label 'Genre Primary' ;
    rdfs:comment 'The primary content genre classification for this EPG entry as distributed in the EPG feed (e.g., Drama, Comedy, News, Sports, Documentary, Reality). Used for viewer discovery, content filtering, and audience analytics. [ENUM-REF-CANDIDATE: drama|comedy|news|sports|documentary|reality|entertainment|children|film|music — promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreSecondary rdf:type rdf:Property ;
    rdfs:label 'Genre Secondary' ;
    rdfs:comment 'An optional secondary genre sub-classification providing more granular content categorization for EPG discovery and audience targeting (e.g., Crime Drama, Political Comedy, Investigative Documentary).' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isClosedCaption rdf:type rdf:Property ;
    rdfs:label 'Is Closed Caption' ;
    rdfs:comment 'Indicates whether closed captioning (CC) is available for this program (True). Distributed in EPG feeds for accessibility compliance and viewer information. Required for FCC closed captioning regulatory compliance.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHdr rdf:type rdf:Property ;
    rdfs:label 'Is Hdr' ;
    rdfs:comment 'Indicates whether this program is available in High Dynamic Range (HDR) format (True). Distributed in EPG feeds to inform viewers and set-top boxes of enhanced picture quality availability.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNewEpisode rdf:type rdf:Property ;
    rdfs:label 'Is New Episode' ;
    rdfs:comment 'Indicates whether this EPG entry represents a new, first-run episode (True) or a repeat/rerun broadcast (False). Distributed in EPG feeds for viewer-facing \'NEW\' indicators and drives audience measurement prioritization.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isan rdf:type rdf:Property ;
    rdfs:label 'Isan' ;
    rdfs:comment 'The International Standard Audiovisual Number (ISAN) uniquely identifying this audiovisual work globally. Used for rights management, content identification across platforms, and interoperability with Rightsline and international content registries.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'The primary audio language of the program, expressed as a three-letter ISO 639-2 language code (e.g., \'eng\' for English, \'spa\' for Spanish). Used in EPG feeds for language filtering and accessibility compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'The date and time when this EPG entry was first published and distributed to external EPG feeds (MVPDs, vMVPDs, set-top boxes, digital platforms). Serves as the record audit created timestamp for this data product.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rightsWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Rights Window End' ;
    rdfs:comment 'The end date of the broadcast rights window during which this content is cleared for transmission on this channel. After this date, the content enters a holdback period and cannot be broadcast without rights renewal in Rightsline.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsWindowStart rdf:type rdf:Property ;
    rdfs:label 'Rights Window Start' ;
    rdfs:comment 'The start date of the broadcast rights window during which this content is cleared for transmission on this channel. Derived from Rightsline contract availabilities and used to validate schedule compliance.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'The precise date and time at which this program is scheduled to end broadcast on the channel. Used to calculate program duration and to sequence adjacent EPG entries in the linear channel grid.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'The precise date and time at which this program is scheduled to begin broadcast on the channel, expressed in ISO 8601 format with timezone offset. This is the principal business event timestamp for the EPG entry and drives all downstream playout automation in Ericsson MediaFirst.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:seasonNumber rdf:type rdf:Property ;
    rdfs:label 'Season Number' ;
    rdfs:comment 'The season number within the series for this episode. Used for EPG display and content navigation. Null for non-episodic or non-seasonal content.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:synopsisLong rdf:type rdf:Property ;
    rdfs:label 'Synopsis Long' ;
    rdfs:comment 'A detailed program description (typically up to 500 characters) distributed in EPG feeds for display on digital platforms, OTT apps, and web-based program guides. Sourced from Dalet Galaxy content metadata.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synopsisShort rdf:type rdf:Property ;
    rdfs:label 'Synopsis Short' ;
    rdfs:comment 'A brief program description (typically up to 100 characters) distributed in EPG feeds for display on set-top boxes and digital platforms with limited screen real estate. Sourced from Dalet Galaxy content metadata.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAdBreakDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Ad Break Duration Seconds' ;
    rdfs:comment 'The total cumulative duration in seconds of all scheduled ad breaks within this program. Used for advertising inventory management, compliance with ad load regulations, and Wide Orbit traffic scheduling.' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:videoResolution rdf:type rdf:Property ;
    rdfs:label 'Video Resolution' ;
    rdfs:comment 'The video resolution format of this program as distributed in the EPG feed (e.g., SD, HD, FHD, UHD/4K). Used for viewer-facing display in EPG interfaces and for platform compatibility routing.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affidavitGenerated rdf:type rdf:Property ;
    rdfs:label 'Affidavit Generated' ;
    rdfs:comment 'Indicates whether a proof-of-broadcast affidavit has been generated for this ad break in the Wide Orbit traffic system following confirmed playout. Affidavits are required for advertiser billing reconciliation and regulatory compliance.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availCount rdf:type rdf:Property ;
    rdfs:label 'Avail Count' ;
    rdfs:comment 'The total number of individual advertising avail slots (unit positions) within this ad break pod. Each avail represents a discrete sellable unit (e.g., a 30-second spot position). Used for inventory capacity planning and traffic scheduling.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutRestricted rdf:type rdf:Property ;
    rdfs:label 'Blackout Restricted' ;
    rdfs:comment 'Indicates whether this ad break is subject to geographic blackout restrictions that prevent its broadcast or streaming in specific markets or regions. When true, downstream distribution systems must apply blackout logic per rights and regulatory obligations.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakPosition rdf:type rdf:Property ;
    rdfs:label 'Break Position' ;
    rdfs:comment 'Positional classification of the ad break relative to the surrounding program content. \'pre-roll\' = before program content begins; \'mid-roll\' = within program content; \'post-roll\' = after program content ends; \'interstitial\' = between programs in the schedule grid.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakStatus rdf:type rdf:Property ;
    rdfs:label 'Break Status' ;
    rdfs:comment 'Current lifecycle status of the ad break within the scheduling and playout workflow. \'scheduled\' = planned but not yet confirmed; \'confirmed\' = traffic-confirmed with sold inventory; \'aired\' = playout completed and affidavit-eligible; \'cancelled\' = removed from schedule; \'hold\' = temporarily suspended pending resolution.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakType rdf:type rdf:Property ;
    rdfs:label 'Break Type' ;
    rdfs:comment 'Classification of the ad break by inventory ownership and commercial purpose. \'local_avail\' = inventory sold by local affiliate; \'network_avail\' = inventory sold by the network; \'promotional\' = house promotional content; \'public_service\' = public service announcements; \'emergency\' = emergency alert system override. Drives revenue attribution and traffic scheduling rules.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Content Restriction Code' ;
    rdfs:comment 'A code indicating any content category restrictions applicable to advertising within this break (e.g., no alcohol ads during children\'s programming, no competitor ads). Enforced by the traffic system during ad assignment. [ENUM-REF-CANDIDATE: NO_ALCOHOL|NO_GAMBLING|NO_PHARMA|NO_COMPETITOR|CHILDREN_SAFE|NONE — promote to reference product]' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgBreakLabel rdf:type rdf:Property ;
    rdfs:label 'Epg Break Label' ;
    rdfs:comment 'The human-readable label or descriptor for this ad break as it appears in the Electronic Program Guide (EPG) and scheduling rundown. Used by traffic coordinators and scheduling operators to identify breaks in the EPG interface.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpTarget rdf:type rdf:Property ;
    rdfs:label 'Grp Target' ;
    rdfs:comment 'The target Gross Rating Point (GRP) value for this ad break, representing the expected total audience delivery as a percentage of the total target population. Used for audience guarantee tracking and campaign delivery reporting against Nielsen ratings.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodRequired rdf:type rdf:Property ;
    rdfs:label 'Makegood Required' ;
    rdfs:comment 'Indicates whether a makegood (compensatory ad spot) is required for this break due to a failure to air as contracted — for example, due to preemption, technical failure, or underdelivery. Triggers makegood workflow in Wide Orbit.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Max Duration Seconds' ;
    rdfs:comment 'The maximum allowable duration of the ad break in seconds, representing the hard ceiling for total ad content that may be inserted. Exceeding this value would cause schedule overrun. May differ from planned duration when flex time is permitted.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:podNumber rdf:type rdf:Property ;
    rdfs:label 'Pod Number' ;
    rdfs:comment 'The pod number identifying this ad break within the broadcast day for the channel. Distinct from sequence_number (which is relative to the program); pod_number is the channel-day-level ordinal used in traffic scheduling and affidavit reporting.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preemptionReason rdf:type rdf:Property ;
    rdfs:label 'Preemption Reason' ;
    rdfs:comment 'The reason code explaining why this ad break was preempted or cancelled if it did not air as scheduled. Used for makegood processing, revenue assurance, and operational reporting. \'none\' when the break aired as planned.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardCpm rdf:type rdf:Property ;
    rdfs:label 'Rate Card Cpm' ;
    rdfs:comment 'The published rate card CPM (Cost Per Mille — cost per 1,000 audience impressions) for this ad break, expressed in the local currency. Represents the base pricing for inventory in this break before negotiated discounts. Used for revenue forecasting and yield management.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordinal position of this ad break within the parent schedule slot or program. Used to order multiple breaks within a single program (e.g., break 1, break 2, break 3) for traffic scheduling and playout automation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soldAvailCount rdf:type rdf:Property ;
    rdfs:label 'Sold Avail Count' ;
    rdfs:comment 'The number of individual avail slots within this break that have been sold and assigned to advertiser spots in the Wide Orbit traffic system. Used with avail_count to compute sellout rate and unsold inventory.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soldDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Sold Duration Seconds' ;
    rdfs:comment 'The total duration in seconds of ad inventory within this break that has been sold to advertisers via the Wide Orbit traffic system. Used to calculate unsold (remnant) inventory and sellout rate for revenue assurance reporting.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wideOrbitBreakCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Break Code' ;
    rdfs:comment 'The externally-known break identifier assigned by the Wide Orbit traffic and billing system. Used to reconcile ad break inventory between the scheduling domain and the ad sales/traffic fulfillment workflow. This is the BUSINESS_IDENTIFIER for the break as known to the traffic system.' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simulcastConfigId rdf:type rdf:Property ;
    rdfs:label 'Simulcast Config Id' ;
    rdfs:comment 'Unique surrogate identifier for the simulcast configuration record. Primary key for this entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SimulcastConfig .

ind:abrProfileId rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Id' ;
    rdfs:comment 'Reference to the Adaptive Bitrate (ABR) streaming profile applied to the target simulcast feed for OTT delivery. Defines the bitrate ladder (HLS or MPEG-DASH renditions) used by Akamai CDN for adaptive streaming to end-user devices.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbrProfile .

ind:accessibilityObligationId rdf:type rdf:Property ;
    rdfs:label 'Accessibility Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.accessibility_obligation. Business justification: Simulcast configurations carry audio_description_passthrough and closed_caption_passthrough settings that must comply with specific accessibility obligations (CVAA, FCC closed captioning rules for IP-' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessibilityObligation .

ind:primarySimulcastBackupSourceChannelId rdf:type rdf:Property ;
    rdfs:label 'Primary Simulcast Backup Source Channel Id' ;
    rdfs:comment 'Reference to the backup or secondary source channel used by Ericsson MediaFirst failover automation when the primary source channel becomes unavailable. Supports broadcast continuity and SLA compliance.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:rightsTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Rights Territory Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_territory. Business justification: simulcast_config.rights_territory_code is a denormalized reference to rights_territory. Simulcast configurations are territory-specific; the rights_territory record defines regulatory parameters, blac' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsTerritory .

ind:simulcastPartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Simulcast Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Simulcast distribution agreements are with specific partners (cable operators, streaming platforms, syndication partners). Critical for multi-platform distribution tracking, partner SLA compliance, an' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:sourceChannelId rdf:type rdf:Property ;
    rdfs:label 'Source Channel Id' ;
    rdfs:comment 'Reference to the originating linear broadcast channel whose feed is being simulcast to one or more target channels or platforms. Drives Ericsson MediaFirst multi-feed automation as the master playout source.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:streamingEndpointId rdf:type rdf:Property ;
    rdfs:label 'Streaming Endpoint Id' ;
    rdfs:comment 'Foreign key linking to distribution.streaming_endpoint. Business justification: Simulcast configurations map linear channels to specific OTT delivery endpoints for live streaming workflows. Operations teams configure CDN routing, failover paths, and geo-restrictions per simulcast' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StreamingEndpoint .

ind:subscriptionPlanId rdf:type rdf:Property ;
    rdfs:label 'Subscription Plan Id' ;
    rdfs:comment 'Foreign key linking to subscriber.subscription_plan. Business justification: Simulcast configurations (e.g., 4K HDR streams, multi-audio) are gated to specific subscription plan tiers in OTT operations. This FK enables the distribution system to enforce plan-level simulcast el' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubscriptionPlan .

ind:targetChannelId rdf:type rdf:Property ;
    rdfs:label 'Target Channel Id' ;
    rdfs:comment 'Reference to the destination channel or platform that receives the simulcast feed from the source channel. May represent a linear channel, OTT platform feed, HD/SD variant, or secondary distribution outlet.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:adPodSubstitution rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Substitution' ;
    rdfs:comment 'Indicates whether the ad pods (groups of ads in a break) from the source linear feed are substituted with alternative ad content on the target simulcast feed. Distinct from DAI — covers cases where static alternate ad content replaces source pods without dynamic targeting.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioDescriptionPassthrough rdf:type rdf:Property ;
    rdfs:label 'Audio Description Passthrough' ;
    rdfs:comment 'Indicates whether the audio description (video description) secondary audio track is passed through from the source to the target simulcast feed. Required for FCC accessibility compliance for visually impaired audiences on qualifying broadcast and MVPD platforms.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutEnforced rdf:type rdf:Property ;
    rdfs:label 'Blackout Enforced' ;
    rdfs:comment 'Indicates whether geographic broadcast blackout restrictions are enforced on the target simulcast feed. When true, blackout rules (e.g., sports rights geographic restrictions) are applied to suppress content in restricted territories on the target platform.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdnOriginPath rdf:type rdf:Property ;
    rdfs:label 'Cdn Origin Path' ;
    rdfs:comment 'The Akamai CDN origin ingest path or stream key for the target simulcast feed. Used to route the encoded simulcast stream from Ericsson MediaFirst playout to the CDN origin for OTT and digital distribution.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionPassthrough rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Passthrough' ;
    rdfs:comment 'Indicates whether closed caption data from the source channel feed is passed through to the target simulcast feed. Required for FCC accessibility compliance on all broadcast and MVPD distribution platforms.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configCode rdf:type rdf:Property ;
    rdfs:label 'Config Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this simulcast configuration, used in Ericsson MediaFirst automation rules, runsheets, and operational documentation. Unique across all active configurations.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configDescription rdf:type rdf:Property ;
    rdfs:label 'Config Description' ;
    rdfs:comment 'Free-text operational description of the simulcast configuration, including business rationale, special handling instructions, and notes for scheduling and playout operations teams.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configName rdf:type rdf:Property ;
    rdfs:label 'Config Name' ;
    rdfs:comment 'Human-readable descriptive name for the simulcast configuration (e.g., \'CNN HD to CNN SD Full-Feed\', \'Linear to OTT Time-Shifted +1hr\'). Used in EPG management and scheduling operations.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPlatform rdf:type rdf:Property ;
    rdfs:label 'Distribution Platform' ;
    rdfs:comment 'The delivery platform type of the target channel or feed. Distinguishes linear broadcast from OTT (Over-The-Top), MVPD (Multichannel Video Programming Distributor), vMVPD (Virtual MVPD), FAST (Free Ad-Supported Streaming Television), cable, satellite, IPTV, or web delivery. [ENUM-REF-CANDIDATE: linear|ott|mvpd|vmvpd|fast|cable|satellite|iptv|web — promote to reference product]' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgSyncEnabled rdf:type rdf:Property ;
    rdfs:label 'Epg Sync Enabled' ;
    rdfs:comment 'Indicates whether the Electronic Program Guide (EPG) metadata from the source channel schedule is automatically synchronized to the target simulcast channel\'s EPG. When true, program titles, descriptions, and ratings are mirrored to the target channel grid.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failoverMode rdf:type rdf:Property ;
    rdfs:label 'Failover Mode' ;
    rdfs:comment 'Defines the failover behavior for the simulcast target feed in Ericsson MediaFirst when the source channel signal is lost or degraded. Automatic triggers immediate failover to backup source; manual requires operator intervention; disabled means no failover is configured.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:graphicsPassthrough rdf:type rdf:Property ;
    rdfs:label 'Graphics Passthrough' ;
    rdfs:comment 'Indicates whether on-screen graphics, lower-thirds, and channel branding overlays from the source channel are passed through to the target simulcast feed. When false, the target feed may apply its own branding or suppress source graphics.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediafirstConfigRef rdf:type rdf:Property ;
    rdfs:label 'Mediafirst Config Ref' ;
    rdfs:comment 'The external configuration reference identifier assigned by Ericsson MediaFirst playout automation system to this simulcast configuration. Used for reconciliation between the data lakehouse Silver Layer and the operational playout system.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric priority ranking for this simulcast configuration when multiple configurations apply to the same source channel simultaneously. Lower values indicate higher priority. Used by Ericsson MediaFirst to resolve conflicts in multi-feed automation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scte35CuePassthrough rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue Passthrough' ;
    rdfs:comment 'Indicates whether SCTE-35 digital program insertion cue markers from the source channel are passed through to the target simulcast feed. When true, ad break triggers and blackout signals are propagated to the target. Critical for DAI (Dynamic Ad Insertion) on OTT platforms.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:simulcastConfigStatus rdf:type rdf:Property ;
    rdfs:label 'Simulcast Config Status' ;
    rdfs:comment 'Current lifecycle state of the simulcast configuration record. Active configurations are processed by Ericsson MediaFirst automation. Suspended configurations are temporarily halted (e.g., rights blackout). Draft configurations are under review prior to activation.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simulcastType rdf:type rdf:Property ;
    rdfs:label 'Simulcast Type' ;
    rdfs:comment 'Classification of the simulcast relationship: full_feed (identical content and timing), partial (selected programs only), time_shifted (offset delay applied), simulcast_only (live events only), ad_substituted (DAI replaces linear ad pods on target). Drives automation logic in Ericsson MediaFirst.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeOffsetSeconds rdf:type rdf:Property ;
    rdfs:label 'Time Offset Seconds' ;
    rdfs:comment 'The delay in seconds applied to the target feed relative to the source channel. Zero for true simultaneous simulcast. Positive values indicate a time-shifted delay (e.g., +3600 for a +1 hour catch-up feed). Used by Ericsson MediaFirst to schedule playout offset.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:watermarkEnabled rdf:type rdf:Property ;
    rdfs:label 'Watermark Enabled' ;
    rdfs:comment 'Indicates whether a forensic or visible watermark is applied to the target simulcast feed for content protection, piracy detection, and rights enforcement tracking. Supports MPA anti-piracy compliance.' ;
    rdfs:domain ind:SimulcastConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playoutEventId rdf:type rdf:Property ;
    rdfs:label 'Playout Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each as-run playout event record in the Ericsson MediaFirst as-run log. Serves as the primary key for this table.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appearanceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Appearance Schedule Id' ;
    rdfs:comment 'Foreign key linking to talent.appearance_schedule. Business justification: appearance_schedule explicitly tracks playout_system_sync_status and playout_system_sync_timestamp, confirming this sync relationship is a real operational process. Playout operations teams reconcile ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AppearanceSchedule .

ind:clearanceRequestId rdf:type rdf:Property ;
    rdfs:label 'Clearance Request Id' ;
    rdfs:comment 'Foreign key linking to rights.clearance_request. Business justification: As-run affidavit generation and post-broadcast rights compliance reporting require linking each playout event to the clearance request that authorized it. Enables clearance SLA measurement and post-ai' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClearanceRequest .

ind:closedCaptionRecordId rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Record Id' ;
    rdfs:comment 'Foreign key linking to compliance.closed_caption_record. Business justification: Each playout event must have corresponding closed caption compliance record for FCC CVAA accessibility reporting. Required for quarterly closed captioning quality reports and complaint response. Links' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClosedCaptionRecord .

ind:primaryPlayoutTitleId rdf:type rdf:Property ;
    rdfs:label 'Primary Playout Title Id' ;
    rdfs:comment 'Reference to the content asset (programme, advertisement, interstitial, or filler) that was transmitted in this playout event. Links to the content master in the Digital Asset Management system.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:roleId rdf:type rdf:Property ;
    rdfs:label 'Role Id' ;
    rdfs:comment 'Foreign key linking to talent.role. Business justification: Guild residual formulas differ by role category (above-the-line vs. below-the-line). The as-run playout log must reference the specific role to calculate correct residual amounts per SAG-AFTRA/WGA agr' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Role .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual transmission end time as recorded in the Ericsson MediaFirst as-run log. Used with actual_start_time to confirm full transmission and calculate actual duration.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:automationMode rdf:type rdf:Property ;
    rdfs:label 'Automation Mode' ;
    rdfs:comment 'Operational mode of the Ericsson MediaFirst playout automation at the time of this event. \'auto\' = fully automated playout; \'manual\' = operator-controlled; \'override\' = scheduled automation overridden by operator; \'failover\' = backup/failover system active.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletAssetCode rdf:type rdf:Property ;
    rdfs:label 'Dalet Asset Code' ;
    rdfs:comment 'Asset identifier in the Dalet Galaxy Media Asset Management system for the content transmitted in this playout event. Used for digital asset reconciliation and archive linkage.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failoverActivated rdf:type rdf:Property ;
    rdfs:label 'Failover Activated' ;
    rdfs:comment 'Indicates whether the Ericsson MediaFirst failover/backup playout system was active during this event. When true, the primary playout chain was unavailable and the backup system handled transmission.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediafirstEventCode rdf:type rdf:Property ;
    rdfs:label 'Mediafirst Event Code' ;
    rdfs:comment 'Native event identifier assigned by Ericsson MediaFirst automation system for this as-run log entry. Used for reconciliation with the source playout system.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutStatus rdf:type rdf:Property ;
    rdfs:label 'Playout Status' ;
    rdfs:comment 'Outcome status of the playout event as recorded in the Ericsson MediaFirst as-run log. \'aired\' = transmitted as planned; \'skipped\' = omitted from transmission; \'substituted\' = replaced with alternate content; \'failed\' = transmission error; \'partial\' = incomplete transmission; \'delayed\' = transmitted late.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Scheduled Duration Seconds' ;
    rdfs:comment 'Planned duration of the playout event in seconds as defined in the program schedule rundown. Used as the baseline for duration deviation analysis.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:startDeviationSeconds rdf:type rdf:Property ;
    rdfs:label 'Start Deviation Seconds' ;
    rdfs:comment 'Difference in seconds between actual_start_time and scheduled_start_time. Positive values indicate late start; negative values indicate early start. Key metric for schedule adherence and SLA reporting.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substitutionReason rdf:type rdf:Property ;
    rdfs:label 'Substitution Reason' ;
    rdfs:comment 'Reason code explaining why the originally scheduled content was substituted with alternate content. Populated only when playout_status is \'substituted\'. Used for rights compliance and editorial audit trails.' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletStoryCode rdf:type rdf:Property ;
    rdfs:label 'Dalet Story Code' ;
    rdfs:comment 'The story or rundown identifier in Dalet Galaxy Media Asset Management system. Enables traceability from the Silver Layer back to the MAM workflow for metadata, archive, and ingest operations.' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liveFlag rdf:type rdf:Property ;
    rdfs:label 'Live Flag' ;
    rdfs:comment 'Indicates whether the program is transmitted live (True) or is a pre-recorded/tape playback (False). Drives Ericsson MediaFirst live playout mode and affects DAI eligibility and failover configuration.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionFormat rdf:type rdf:Property ;
    rdfs:label 'Production Format' ;
    rdfs:comment 'Describes the production origination format of the program. \'studio\' = produced in-house studio; \'remote\' = outside broadcast; \'hybrid\' = mixed studio and remote; \'tape\' = pre-recorded playback; \'simulcast\' = simultaneous multi-platform broadcast.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programContentSeconds rdf:type rdf:Property ;
    rdfs:label 'Program Content Seconds' ;
    rdfs:comment 'Total planned duration of editorial/program content segments in seconds, excluding commercial breaks and credits. Used for content-to-ad ratio compliance reporting.' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rundownCode rdf:type rdf:Property ;
    rdfs:label 'Rundown Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the rundown, used by production teams and Ericsson MediaFirst automation to reference the show rundown. Unique within a broadcast date and channel.' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rundownNotes rdf:type rdf:Property ;
    rdfs:label 'Rundown Notes' ;
    rdfs:comment 'Free-text production notes associated with the rundown, capturing special instructions, last-minute changes, talent notes, or technical advisories for the production and playout teams.' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rundownStatus rdf:type rdf:Property ;
    rdfs:label 'Rundown Status' ;
    rdfs:comment 'Current lifecycle state of the rundown. \'draft\' = in preparation; \'approved\' = signed off by producer; \'locked\' = no further edits permitted; \'transmitted\' = playout completed; \'archived\' = retained for compliance.' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rundownType rdf:type rdf:Property ;
    rdfs:label 'Rundown Type' ;
    rdfs:comment 'Classification of the program rundown by genre or production format. Drives template selection in Ericsson MediaFirst and informs segment structure expectations. [ENUM-REF-CANDIDATE: news|sports|entertainment|talk_show|documentary|magazine|special — promote to reference product]' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rundownVersion rdf:type rdf:Property ;
    rdfs:label 'Rundown Version' ;
    rdfs:comment 'Incremental version number of the rundown, incremented each time the rundown is revised. Enables version tracking and rollback for production teams and playout automation.' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentCount rdf:type rdf:Property ;
    rdfs:label 'Segment Count' ;
    rdfs:comment 'Total number of rundown items (segments) defined in this rundown, including news blocks, interviews, commercial breaks, tosses, and credits. Used for production planning and playout validation.' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rundownItemId rdf:type rdf:Property ;
    rdfs:label 'Rundown Item Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual segment or item within a program rundown. Primary key for the rundown_item entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:musicSyncLicenseId rdf:type rdf:Property ;
    rdfs:label 'Music Sync License Id' ;
    rdfs:comment 'Foreign key linking to rights.music_sync_license. Business justification: Cue sheet generation for music royalty reporting (ASCAP/BMI/SESAC) requires linking each rundown item containing music to its music sync license. Broadcasters are legally required to report music usag' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MusicSyncLicense .

ind:adPodDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Duration Seconds' ;
    rdfs:comment 'Total allocated duration in seconds for the ad pod break associated with this rundown item. Populated only when ad_pod_flag is true. Used for ad load compliance and Wide Orbit traffic scheduling.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adPodFlag rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Flag' ;
    rdfs:comment 'Indicates whether this rundown item represents an Ad Pod (a group of commercial spots within a break). When true, triggers SCTE-35 cue marker insertion and Dynamic Ad Insertion (DAI) eligibility checks.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adPodSpotCount rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Spot Count' ;
    rdfs:comment 'Number of individual commercial spots scheduled within this ad pod break. Used for ad load monitoring, Wide Orbit traffic log validation, and FCC children\'s programming ad limit compliance.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backtimeFlag rdf:type rdf:Property ;
    rdfs:label 'Backtime Flag' ;
    rdfs:comment 'Indicates whether this rundown item is backtimed — i.e., its start time is calculated backwards from a fixed end point (e.g., top-of-hour news break or programme end). Critical for live show timing control in Ericsson MediaFirst.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cueText rdf:type rdf:Property ;
    rdfs:label 'Cue Text' ;
    rdfs:comment 'Editorial cue or introduction text read by the presenter or director to introduce this rundown item. Stored as the production script reference for live show execution and post-broadcast archive.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationVarianceSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Variance Seconds' ;
    rdfs:comment 'Difference in seconds between actual_duration_seconds and planned_duration_seconds (actual minus planned). Positive values indicate overrun; negative values indicate underrun. Used for show timing analysis and rundown optimisation.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eomTimecode rdf:type rdf:Property ;
    rdfs:label 'Eom Timecode' ;
    rdfs:comment 'SMPTE timecode marking the End of Message (EOM) — the precise out-point of the media asset for this rundown item. Used alongside som_timecode for frame-accurate duration calculation and playout control.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgDescription rdf:type rdf:Property ;
    rdfs:label 'Epg Description' ;
    rdfs:comment 'Short editorial description of this rundown item for display in the Electronic Program Guide (EPG). Populated for story packages and feature segments; used by EPG aggregators and on-screen guide systems.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:graphicsTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Graphics Template Code' ;
    rdfs:comment 'Identifier for the graphics or lower-third template to be rendered by the Ericsson MediaFirst graphics engine for this rundown item. Applicable for graphic and lower_third segment formats.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current production lifecycle state of the rundown item as managed in the live show production control system. Drives automation decisions in Ericsson MediaFirst and Dalet Galaxy workflow.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemTitle rdf:type rdf:Property ;
    rdfs:label 'Item Title' ;
    rdfs:comment 'Human-readable editorial title or slug for the rundown item as displayed in the production control system and Electronic Program Guide (EPG). Used by producers and directors during live show execution.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemType rdf:type rdf:Property ;
    rdfs:label 'Item Type' ;
    rdfs:comment 'Classification of the discrete production element represented by this rundown item. Determines playout behaviour, automation triggers, and ad pod eligibility. [ENUM-REF-CANDIDATE: story_package|live_shot|interview|commercial_break|graphic|music_bed|filler|open|close — promote to reference product]' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediafirstItemCode rdf:type rdf:Property ;
    rdfs:label 'Mediafirst Item Code' ;
    rdfs:comment 'Native item identifier assigned by the Ericsson MediaFirst playout automation system for this rundown element. Used for reconciliation between the Silver Layer data product and the operational playout system.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentFormat rdf:type rdf:Property ;
    rdfs:label 'Segment Format' ;
    rdfs:comment 'Production format classification of the rundown item using broadcast newsroom terminology. Determines the technical playout configuration and graphics overlay requirements in Ericsson MediaFirst. [ENUM-REF-CANDIDATE: pkg|vo|vosot|sot|live|standup|anchor_read|graphic_full|lower_third — promote to reference product]' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skipReason rdf:type rdf:Property ;
    rdfs:label 'Skip Reason' ;
    rdfs:comment 'Reason code explaining why this rundown item was skipped during playout. Populated only when item_status = skipped. Used for post-broadcast editorial review and rights compliance audit.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:somTimecode rdf:type rdf:Property ;
    rdfs:label 'Som Timecode' ;
    rdfs:comment 'SMPTE timecode marking the Start of Message (SOM) — the precise in-point of the media asset to be played for this rundown item. Used by Ericsson MediaFirst for frame-accurate playout cueing.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeNumber rdf:type rdf:Property ;
    rdfs:label 'Tape Number' ;
    rdfs:comment 'Physical or virtual media identifier (tape ID, clip ID, or server ID) for the pre-recorded asset associated with this rundown item in the Dalet Galaxy MAM system. Used for media retrieval and playout server cueing.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitSpotCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Spot Code' ;
    rdfs:comment 'Identifier from the Wide Orbit Traffic and Billing system for commercial spots or ad pod items within this rundown. Populated only for item_type = commercial_break; used for affidavit generation and billing reconciliation.' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adBreakMaxDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Ad Break Max Duration Seconds' ;
    rdfs:comment 'The maximum allowable duration in seconds for a single ad break (ad pod) within the content during this availability window. Used to enforce ad load limits and viewer experience standards on AVOD and FAST platforms.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:akamaiStreamUrl rdf:type rdf:Property ;
    rdfs:label 'Akamai Stream Url' ;
    rdfs:comment 'The Akamai CDN origin stream URL for delivering the content during this availability window. Specifies the endpoint used for HLS or MPEG-DASH adaptive bitrate streaming to end-user devices.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmRequired rdf:type rdf:Property ;
    rdfs:label 'Drm Required' ;
    rdfs:comment 'Indicates whether Digital Rights Management (DRM) protection must be enforced for content delivery during this availability window. When True, the Akamai CDN and streaming infrastructure must apply DRM encryption before delivery.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eidrCode rdf:type rdf:Property ;
    rdfs:label 'Eidr Code' ;
    rdfs:comment 'The Entertainment Identifier Registry (EIDR) persistent identifier for the content title associated with this window. Enables interoperability with industry partners, distributors, and rights management systems for content identification.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusive Flag' ;
    rdfs:comment 'Indicates whether this availability window grants exclusive rights to the platform for the specified territory and window period. When True, the content must not be made available on any competing platform during this window.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdbackFlag rdf:type rdf:Property ;
    rdfs:label 'Holdback Flag' ;
    rdfs:comment 'Indicates whether this window represents a holdback period during which the content is explicitly withheld from the platform or service tier. When True, the content must not be made available regardless of other scheduling parameters.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightslineWindowRef rdf:type rdf:Property ;
    rdfs:label 'Rightsline Window Ref' ;
    rdfs:comment 'The native window reference identifier from the Rightsline Rights and Royalties Management system. Used for cross-system reconciliation between the scheduling domain and the rights domain to ensure operational parameters align with contractual rights.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staggerOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Stagger Offset Days' ;
    rdfs:comment 'For staggered windowing strategy, the number of days this platform\'s availability window is offset relative to the primary release platform or theatrical/linear premiere date. Zero indicates simultaneous release; positive values indicate delayed release.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:streamingProtocol rdf:type rdf:Property ;
    rdfs:label 'Streaming Protocol' ;
    rdfs:comment 'The adaptive bitrate (ABR) streaming protocol used to deliver the content during this availability window. HLS = HTTP Live Streaming; MPEG-DASH = Dynamic Adaptive Streaming over HTTP; SMOOTH = Microsoft Smooth Streaming; PROGRESSIVE = progressive download.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code identifying the geographic territory in which this availability window applies. Used to enforce blackout obligations, retransmission consent, and territorial rights restrictions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryScope rdf:type rdf:Property ;
    rdfs:label 'Territory Scope' ;
    rdfs:comment 'Broad geographic scope classification for the availability window. \'worldwide\' means no territorial restriction; \'regional\' means a multi-country region; \'national\' means a single country; \'local\' means a sub-national market; \'excluded\' means the territory is explicitly excluded from availability.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowCloseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Window Close Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone offset) at which the content title expires and is no longer available on the specified platform. Null indicates an open-ended window with no defined expiry.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:windowCode rdf:type rdf:Property ;
    rdfs:label 'Window Code' ;
    rdfs:comment 'Externally-known business identifier code for this availability window, used in operational systems such as Rightsline and Dalet Galaxy for cross-system reference and reconciliation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowDurationDays rdf:type rdf:Property ;
    rdfs:label 'Window Duration Days' ;
    rdfs:comment 'The total duration of the availability window in days, calculated as the difference between window_close_timestamp and window_open_timestamp. Stored as an operational field for scheduling and reporting purposes. Null for open-ended windows.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowNotes rdf:type rdf:Property ;
    rdfs:label 'Window Notes' ;
    rdfs:comment 'Free-text operational notes or comments associated with this availability window, capturing scheduling rationale, rights exceptions, platform-specific instructions, or escalation context for scheduling operations teams.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Window Open Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone offset) at which the content title becomes available on the specified platform. This is the principal business event timestamp for the availability window lifecycle.' ;
    rdfs:domain ind:SchedulingAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:windowStatus rdf:type rdf:Property ;
    rdfs:label 'Window Status' ;
    rdfs:comment 'Current lifecycle state of the availability window. \'draft\' indicates configuration in progress; \'scheduled\' means approved but not yet open; \'active\' means currently available to audiences; \'expired\' means the window close datetime has passed; \'cancelled\' means removed before activation; \'suspended\' means temporarily withheld.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowingStrategy rdf:type rdf:Property ;
    rdfs:label 'Windowing Strategy' ;
    rdfs:comment 'The sequential release strategy applied to this availability window. \'day_and_date\' means simultaneous release across all platforms; \'staggered\' means delayed release relative to another platform; \'exclusive\' means available only on this platform for the window duration; \'holdback\' means content is withheld from this platform during the window; \'rolling\' means a continuously refreshed window; \'simultaneous\' means released at the same time as theatrical or linear broadcast.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Primary key for project' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_agreement. Business justification: Master agreement governance: business affairs teams track which master partner agreement governs a production project\'s commercial terms (IP ownership, revenue share, creative control). Required for c' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:commissioningDistributionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Commissioning Distribution Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.distribution_agreement. Business justification: Greenlight/commissioning workflow: a broadcaster or distributor commissions a production project under a distribution agreement that defines funding, delivery specs, and territory. Business affairs te' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionAgreement .

ind:distributionPartnerId rdf:type rdf:Property ;
    rdfs:label 'Distribution Partner Id' ;
    rdfs:comment 'Foreign key linking to distribution.distribution_partner. Business justification: Production projects are commissioned by or produced for specific distribution partners (e.g., a cable operator orders an original series). This is a fundamental media-broadcasting output deal process.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaBroadcasting .

ind:masterLicenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Master License Agreement Id' ;
    rdfs:comment 'Foreign key linking to rights.license_agreement. Business justification: Projects often have master license agreements governing distribution rights (co-production deals, pre-sales, output deals). Real business need: tracking which license agreements fund or govern a produ' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:productionCompanyPartnerId rdf:type rdf:Property ;
    rdfs:label 'Production Company Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Production projects are executed by or with external production companies (partners). Linking enables contract management, payment processing, co-production tracking, and rights negotiation. The `prod' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:targetOttPlatformId rdf:type rdf:Property ;
    rdfs:label 'Target Ott Platform Id' ;
    rdfs:comment 'Foreign key linking to distribution.ott_platform. Business justification: Productions are commissioned for specific streaming platforms (Netflix Originals, HBO Max Exclusives). Platform determines technical specs, content ratings, delivery windows. Real business process: pl' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OttPlatform .

ind:upfrontDealId rdf:type rdf:Property ;
    rdfs:label 'Upfront Deal Id' ;
    rdfs:comment 'Foreign key linking to sales.upfront_deal. Business justification: Upfront deals commit advertisers to specific programming volumes; production projects are greenlighted to fulfill those content commitments. Production planning, greenlight approvals, and budget autho' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UpfrontDeal .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Date on which the final deliverable was actually delivered to the distribution or broadcast platform. Compared against target_delivery_date to measure on-time delivery performance and SLA compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Usd' ;
    rdfs:comment 'Cumulative actual expenditure incurred against this production project to date, denominated in US Dollars. Sourced from SAP S/4HANA cost postings. Compared against approved_budget_usd for variance and financial reconciliation reporting.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Usd' ;
    rdfs:comment 'Total production budget formally approved at greenlight, denominated in US Dollars. Represents the authorized spend ceiling for the project. Used for financial controlling, variance analysis, and EBITDA reporting in SAP S/4HANA.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coProductionFlag rdf:type rdf:Property ;
    rdfs:label 'Co Production Flag' ;
    rdfs:comment 'Indicates whether this production project is a co-production involving one or more external production partners. Triggers co-production agreement workflows, shared rights structures, and split budget reporting in SAP S/4HANA.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coppaApplicable rdf:type rdf:Property ;
    rdfs:label 'Coppa Applicable' ;
    rdfs:comment 'Indicates whether this production is directed at children under 13 and therefore subject to COPPA compliance requirements. Affects data collection practices, advertising eligibility, and platform distribution restrictions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daletWorkflowReference rdf:type rdf:Property ;
    rdfs:label 'Dalet Workflow Reference' ;
    rdfs:comment 'Integration reference identifier linking this production project to its corresponding workflow instance in Dalet Galaxy Media Asset Management and Workflow Orchestration system. Enables cross-system traceability for ingest, metadata, archive, and workflow operations.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeCount rdf:type rdf:Property ;
    rdfs:label 'Episode Count' ;
    rdfs:comment 'Total number of episodes commissioned for this production project. Applicable to scripted and unscripted series. Used for budget modeling, scheduling, and rights licensing calculations. Null for single-title formats such as feature films.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fccLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Fcc License Required' ;
    rdfs:comment 'Indicates whether this production requires FCC broadcast licensing compliance review prior to linear broadcast distribution. Applicable to content intended for over-the-air or cable transmission in the United States.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:greenlightDate rdf:type rdf:Property ;
    rdfs:label 'Greenlight Date' ;
    rdfs:comment 'Calendar date on which the production project received formal executive greenlight approval. Marks the official start of the production lifecycle and triggers budget release and resource mobilization.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:greenlightStatus rdf:type rdf:Property ;
    rdfs:label 'Greenlight Status' ;
    rdfs:comment 'Executive approval status of the production project. Indicates whether the project has received formal greenlight authorization to proceed, is pending approval, is on hold, or has been cancelled. Controls budget release and resource mobilization.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalIpFlag rdf:type rdf:Property ;
    rdfs:label 'Original Ip Flag' ;
    rdfs:comment 'Indicates whether this production is based on original intellectual property owned by the organization, as opposed to licensed or adapted IP. Affects rights ownership, residuals obligations, and long-term asset valuation.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postProductionStartDate rdf:type rdf:Property ;
    rdfs:label 'Post Production Start Date' ;
    rdfs:comment 'Scheduled or actual date on which post-production activities commenced, including editing, VFX, color grading, audio mixing, and transcoding. Used for facility booking and deliverable milestone planning.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preProductionStartDate rdf:type rdf:Property ;
    rdfs:label 'Pre Production Start Date' ;
    rdfs:comment 'Scheduled or actual date on which pre-production activities commenced, including casting, location scouting, script breakdown, and crew hiring. Used for production planning and milestone tracking.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:principalPhotographyEndDate rdf:type rdf:Property ;
    rdfs:label 'Principal Photography End Date' ;
    rdfs:comment 'Scheduled or actual date on which principal photography concluded (picture wrap). Triggers transition to post-production phase and initiates post-production resource scheduling.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:principalPhotographyStartDate rdf:type rdf:Property ;
    rdfs:label 'Principal Photography Start Date' ;
    rdfs:comment 'Scheduled or actual date on which principal photography (primary filming) commenced. A key production milestone used for crew scheduling, facility booking, and insurance activation.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionCountry rdf:type rdf:Property ;
    rdfs:label 'Production Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the primary country in which the production is being executed. Determines applicable regulatory frameworks, tax incentive eligibility, and co-production treaty benefits.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionPhase rdf:type rdf:Property ;
    rdfs:label 'Production Phase' ;
    rdfs:comment 'Current phase of the content production lifecycle. Tracks the project\'s progression from development through delivery. Used to gate workflow steps, resource allocation, and financial milestone releases.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the content production project by format and genre category. Drives production workflow templates, budget models, rights structures, and scheduling logic. [ENUM-REF-CANDIDATE: scripted_series|feature_film|documentary|live_event|news_segment|unscripted_series|short_form — promote to reference product]' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'SAP S/4HANA Work Breakdown Structure element code that maps this production project to the enterprise financial controlling hierarchy for budget tracking, cost allocation, and financial reconciliation.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synopsis rdf:type rdf:Property ;
    rdfs:label 'Synopsis' ;
    rdfs:comment 'Short narrative description of the content production project\'s story, subject matter, or editorial concept. Used for internal greenlight documentation, sales pitches, EPG metadata, and Dalet Galaxy asset metadata.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Target Delivery Date' ;
    rdfs:comment 'Contractually committed or internally planned date by which the finished content must be delivered to distribution, broadcast, or streaming platforms. Drives post-production scheduling, windowing strategy, and SLA compliance.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalRuntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Runtime Minutes' ;
    rdfs:comment 'Total planned or delivered runtime of the production in minutes. For series, this is the aggregate runtime across all episodes. Used for scheduling, licensing, and royalty calculations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shootScheduleId rdf:type rdf:Property ;
    rdfs:label 'Shoot Schedule Id' ;
    rdfs:comment 'Unique surrogate identifier for a shoot schedule record in the production domain. Primary key for the shoot_schedule data product.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShootSchedule .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Foreign key linking to production.location. Business justification: Normalization opportunity. Shoot schedule currently has location_name (STRING). FK to location table provides referential integrity and enables retrieving full location details (address, permits, safe' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:scriptId rdf:type rdf:Property ;
    rdfs:label 'Script Id' ;
    rdfs:comment 'Foreign key linking to production.script. Business justification: shoot_schedule has scene_numbers as a text field referencing specific script scenes being shot on a given day. Adding script_id creates a proper FK to the script being filmed on that shoot day, enabli' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Script .

ind:seasonId rdf:type rdf:Property ;
    rdfs:label 'Season Id' ;
    rdfs:comment 'Foreign key linking to content.season. Business justification: Block shooting across multiple episodes of a season is standard in episodic TV. Production coordinators plan shoot schedules at the season level for resource allocation and season delivery reporting. ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Season .

ind:actualExtrasCount rdf:type rdf:Property ;
    rdfs:label 'Actual Extras Count' ;
    rdfs:comment 'The actual number of background performers (extras) who worked on this shoot day. Used for payroll reconciliation, SAG-AFTRA reporting, and production cost tracking.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualShootHours rdf:type rdf:Property ;
    rdfs:label 'Actual Shoot Hours' ;
    rdfs:comment 'The actual number of hours spent in principal photography for the day. Used for budget reconciliation, overtime calculation, and production efficiency analysis.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualWrapTime rdf:type rdf:Property ;
    rdfs:label 'Actual Wrap Time' ;
    rdfs:comment 'The actual time at which principal photography concluded for the day. Compared against scheduled wrap time to calculate overtime and assess schedule adherence.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callTime rdf:type rdf:Property ;
    rdfs:label 'Call Time' ;
    rdfs:comment 'The scheduled time at which cast and crew are required to report to set. Used for crew coordination, transport logistics, and facility readiness planning.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coverSetDescription rdf:type rdf:Property ;
    rdfs:label 'Cover Set Description' ;
    rdfs:comment 'Description of the alternate interior or cover set designated for use if weather or other conditions prevent the primary shoot. Only applicable when weather_contingency_flag is True.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayOutOfDaysType rdf:type rdf:Property ;
    rdfs:label 'Day Out Of Days Type' ;
    rdfs:comment 'Industry-standard Day Out of Days (DOOD) designation indicating the cast/crew work status for this shoot day. SW=Start Work, W=Work, WF=Work Finish, F=Finish, H=Hold, D=Drop, SWF=Start Work Finish. Used for talent scheduling, residuals calculation, and SAG-AFTRA compliance. [ENUM-REF-CANDIDATE: SW|W|WF|F|H|D|SWF — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedExtrasCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Extras Count' ;
    rdfs:comment 'The planned number of background performers (extras) required for this shoot day. Used for casting coordination, catering planning, and SAG-AFTRA background performer compliance.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedShootHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Shoot Hours' ;
    rdfs:comment 'The planned number of shooting hours for the day, used for budget forecasting, crew scheduling, and facility booking. Expressed in decimal hours (e.g., 10.50 = 10 hours 30 minutes).' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstShotTime rdf:type rdf:Property ;
    rdfs:label 'First Shot Time' ;
    rdfs:comment 'The scheduled or actual time at which the first camera roll of the day begins. A key production efficiency metric used to assess set readiness and pre-production effectiveness.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isOvertimeDay rdf:type rdf:Property ;
    rdfs:label 'Is Overtime Day' ;
    rdfs:comment 'Indicates whether this shoot day resulted in overtime hours for cast or crew, triggering additional compensation obligations under union agreements (SAG-AFTRA, DGA, IATSE). Derived operationally but stored for compliance and payroll audit purposes.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mealPenaltyFlag rdf:type rdf:Property ;
    rdfs:label 'Meal Penalty Flag' ;
    rdfs:comment 'Indicates whether a meal penalty was incurred on this shoot day due to failure to provide a meal break within the union-mandated interval (typically 6 hours). Triggers additional compensation obligations under SAG-AFTRA and IATSE agreements.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'The number of script pages scheduled for photography on this shoot day, expressed in eighths of a page per industry convention (e.g., 4.625 = 4 and 5/8 pages). A standard production efficiency metric used to assess daily output against industry benchmarks.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionNotes rdf:type rdf:Property ;
    rdfs:label 'Production Notes' ;
    rdfs:comment 'Free-text field capturing significant events, issues, or observations from the shoot day, including equipment failures, weather delays, cast illness, or creative changes. Sourced from the daily production report.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionUnit rdf:type rdf:Property ;
    rdfs:label 'Production Unit' ;
    rdfs:comment 'Identifies the filming unit responsible for this shoot day. Main unit is led by the principal director; second unit handles action sequences or supplemental footage; splinter unit shoots simultaneously with main unit on a separate set; insert unit captures close-up or detail shots.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'The date on which the current revision of this shoot schedule was issued. Used to track the cadence of schedule changes and identify the most current approved version.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionVersion rdf:type rdf:Property ;
    rdfs:label 'Revision Version' ;
    rdfs:comment 'The version identifier of this shoot schedule revision (e.g., \'v1\', \'v3-BLUE\', \'Rev-7\'). Production schedules are revised frequently; tracking version enables audit of changes and comparison of planned vs. actual across revisions.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sceneNumbers rdf:type rdf:Property ;
    rdfs:label 'Scene Numbers' ;
    rdfs:comment 'Comma-separated list of scene numbers from the production script scheduled for photography on this shoot day (e.g., \'12, 13A, 14, 15B\'). Derived from the stripboard and used for script supervisor tracking and editorial planning.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this shoot schedule record, used in production paperwork, call sheets, and cross-system references (e.g., SS-2024-0042).' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledWrapTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Wrap Time' ;
    rdfs:comment 'The planned time at which principal photography is expected to conclude for the day. Used for facility booking, crew scheduling, and overtime cost estimation.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shootDate rdf:type rdf:Property ;
    rdfs:label 'Shoot Date' ;
    rdfs:comment 'The calendar date on which principal photography is scheduled or was executed. The primary business event date for this schedule record.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shootDayNumber rdf:type rdf:Property ;
    rdfs:label 'Shoot Day Number' ;
    rdfs:comment 'Sequential shoot day number within the production (e.g., Day 1, Day 15, Day 42). Used to track production progress against the total approved shoot days and for budget burn-rate analysis.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shootType rdf:type rdf:Property ;
    rdfs:label 'Shoot Type' ;
    rdfs:comment 'Classifies the nature of the shoot day environment. Distinguishes between controlled studio environments and on-location shoots, which have different logistical, permitting, and cost implications.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalApprovedShootDays rdf:type rdf:Property ;
    rdfs:label 'Total Approved Shoot Days' ;
    rdfs:comment 'The total number of principal photography days approved in the production greenlight. Used to calculate schedule completion percentage and identify overages requiring executive approval.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Hours' ;
    rdfs:comment 'The minimum rest period in hours between the wrap of the previous shoot day and the call time of this shoot day. Union agreements (SAG-AFTRA, DGA, IATSE) mandate minimum turnaround periods; violations trigger penalty payments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherContingencyFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Contingency Flag' ;
    rdfs:comment 'Indicates whether this shoot day has a weather contingency plan in place. When True, an alternate interior or cover set is designated in case outdoor conditions prevent the primary shoot. Critical for location shoots and insurance risk management.' ;
    rdfs:domain ind:ShootSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Primary key for budget' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Cumulative actual costs incurred to date for this cost category, sourced from SAP S/4HANA FI/CO actual postings. Represents real expenditure against the approved budget.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current workflow approval status of this budget record. DRAFT = in preparation; PENDING_APPROVAL = submitted for sign-off; APPROVED = formally authorized; REJECTED = returned for revision; LOCKED = frozen for actuals comparison; CLOSED = production complete.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'The formally approved budget amount for this cost category and version, representing the financial control baseline authorized by the production greenlight committee.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this budget record within the production finance system. Used for cross-system reference and reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Free-text narrative explaining the business justification for a budget revision (e.g., \'Schedule extension due to weather delays\', \'Additional VFX shots approved by director\'). Mandatory for revised versions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRequestReference rdf:type rdf:Property ;
    rdfs:label 'Change Request Reference' ;
    rdfs:comment 'Reference number of the formal budget change request (BCR) document that authorized a revision to this budget line, traceable in the production finance approval workflow.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Total value of open purchase order commitments (obligations) for this cost category that have been raised but not yet invoiced. Represents encumbered funds in the SAP MM/CO commitment ledger.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Amount' ;
    rdfs:comment 'The absolute monetary value of the contingency reserve allocated for this cost category, derived from the contingency percentage applied to the approved budget amount.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Contingency Percentage' ;
    rdfs:comment 'The percentage of the approved budget allocated as contingency reserve for this cost category, representing the risk buffer approved by the production finance committee.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Cost Category Code' ;
    rdfs:comment 'SAP cost element or cost category code classifying the type of production expenditure (e.g., ATL-TALENT, BTL-CREW, BTL-EQUIPMENT, POST-VFX, POST-AUDIO). [ENUM-REF-CANDIDATE: ATL-TALENT|ATL-RIGHTS|BTL-CREW|BTL-EQUIPMENT|BTL-FACILITIES|BTL-TRAVEL|POST-VFX|POST-AUDIO|POST-COLOR|CONTINGENCY — promote to reference product]' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCategoryName rdf:type rdf:Property ;
    rdfs:label 'Cost Category Name' ;
    rdfs:comment 'Human-readable name of the production cost category (e.g., \'Above-the-Line Talent\', \'Below-the-Line Crew\', \'Visual Effects\', \'Audio Post-Production\').' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costLineType rdf:type rdf:Property ;
    rdfs:label 'Cost Line Type' ;
    rdfs:comment 'High-level classification of the cost line distinguishing above-the-line (ATL) creative costs (writers, directors, producers, talent) from below-the-line (BTL) technical and crew costs, post-production, contingency, and overhead.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate applied to convert this budget record\'s currency to the production\'s reporting currency at the time of budget approval or revision.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month number 1–12 or 1–16 for special periods) within the fiscal year to which this budget line is assigned in SAP CO.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The four-digit fiscal year to which this budget record belongs in the SAP S/4HANA CO controlling area, used for annual financial planning and SOX reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastAmount rdf:type rdf:Property ;
    rdfs:label 'Forecast Amount' ;
    rdfs:comment 'Latest estimate of the total cost expected to be incurred for this cost category by production completion, incorporating actuals to date and projected remaining spend.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGreenlightBudget rdf:type rdf:Property ;
    rdfs:label 'Is Greenlight Budget' ;
    rdfs:comment 'Indicates whether this budget record represents the original greenlight-approved budget for the production, as distinct from subsequent revisions. The greenlight budget is the primary financial authorization baseline.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether this budget version has been locked and is no longer open for modification. A locked budget serves as the immutable financial baseline for variance reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The end date of the fiscal or production period covered by this budget record. Defines the temporal boundary for cost accumulation and variance measurement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The start date of the fiscal or production period covered by this budget record, aligning to the SAP fiscal year/period structure.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the group reporting currency to which all amounts are translated for consolidated financial reporting (e.g., USD for a US-headquartered broadcaster).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Amount' ;
    rdfs:comment 'The most recently revised budget amount for this cost category following a formal budget change request. Null if no revision has been approved since the original budget.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapCostObjectCode rdf:type rdf:Property ;
    rdfs:label 'Sap Cost Object Code' ;
    rdfs:comment 'The SAP S/4HANA CO cost object identifier (Internal Order number or WBS Element ID) that anchors this budget record to the controlling module for financial reconciliation.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The difference between the approved (or revised) budget amount and the sum of actual costs plus commitments. A negative value indicates an over-budget condition; positive indicates underspend.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version label of this budget record, distinguishing the original greenlight budget from subsequent revisions and the locked final version. Supports budget version history tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual budget line item within a production budget. Primary key for this entity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetLine .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: When production costs are incurred, journal entries are posted against budget lines for accrual accounting and cost commitment tracking. Production accountants reconcile budget lines against journal e' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:royaltyRuleId rdf:type rdf:Property ;
    rdfs:label 'Royalty Rule Id' ;
    rdfs:comment 'Foreign key linking to rights.royalty_rule. Business justification: Production accountants budget royalty and residual obligations per budget line using specific royalty rules. This link enables accurate royalty accrual forecasting during production budgeting. No exis' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyRule .

ind:accountCode rdf:type rdf:Property ;
    rdfs:label 'Account Code' ;
    rdfs:comment 'Industry-standard production account code identifying the cost category within the budget (e.g., 1100 for Above-the-Line Talent, 2200 for Camera Equipment). Follows standard production accounting chart of accounts (e.g., AICP, Producers Guild).' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accruedAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Amount' ;
    rdfs:comment 'Costs accrued for work performed or services received but not yet invoiced or formally committed. Supports period-end financial close and accurate cost-to-complete reporting.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'Total actual costs incurred and posted against this budget line to date, sourced from SAP FI invoice postings and payroll actuals. Used for variance analysis against budgeted and committed amounts.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedAmount rdf:type rdf:Property ;
    rdfs:label 'Budgeted Amount' ;
    rdfs:comment 'Original approved budget amount for this line item as established at greenlight or budget approval. Represents the planned cost baseline against which actuals and commitments are measured.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyPct rdf:type rdf:Property ;
    rdfs:label 'Contingency Pct' ;
    rdfs:comment 'Contingency percentage applied to this budget line to cover unforeseen cost overruns. Typically 5–15% for production lines. Contributes to the overall production contingency reserve.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'High-level cost category classifying the budget line within the production budget structure. Above-the-line covers creative talent (writers, directors, producers, cast); below-the-line covers crew, equipment, locations, and production services. [ENUM-REF-CANDIDATE: above_the_line|below_the_line|post_production|music_licensing|vfx|marketing|overhead|contingency|insurance|legal — promote to reference product]' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSubCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Sub Category' ;
    rdfs:comment 'Granular sub-classification within the cost category (e.g., \'Cast Fees\', \'Location Fees\', \'Equipment Rental\', \'VFX Compositing\', \'Music Synchronization License\', \'Post-Production Labor\'). Enables detailed variance analysis at the sub-category level.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fringeRatePct rdf:type rdf:Property ;
    rdfs:label 'Fringe Rate Pct' ;
    rdfs:comment 'Percentage applied to labor costs on this line to account for employer fringe benefits (payroll taxes, pension contributions, health insurance, residuals). Standard production accounting practice for above-the-line and below-the-line labor lines.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAboveTheLine rdf:type rdf:Property ;
    rdfs:label 'Is Above The Line' ;
    rdfs:comment 'Flag indicating whether this budget line is classified as above-the-line (ATL) cost, covering creative talent such as writers, directors, producers, and principal cast. False indicates below-the-line (BTL) cost.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnionLabor rdf:type rdf:Property ;
    rdfs:label 'Is Union Labor' ;
    rdfs:comment 'Flag indicating whether this budget line involves union or guild labor subject to collective bargaining agreements (DGA, SAG-AFTRA, WGA, IATSE). Drives fringe rate calculations and residuals obligations.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Free-text description of the specific cost item represented by this budget line (e.g., \'Lead Actor Day Rate — Week 3\', \'Steadicam Rental — Principal Photography\', \'Dolby Atmos Mix — Episode 4\').' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the parent budget document, used for ordering and referencing individual line items in budget reports and purchase orders.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle status of the budget line item, tracking its progression from initial draft through approval, commitment, invoicing, and payment. Drives workflow routing and financial reporting. [ENUM-REF-CANDIDATE: draft|approved|committed|invoiced|paid|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'SAP purchase order number raised against this budget line for vendor commitments. Links the budget line to the formal procurement document and enables three-way matching (PO, goods receipt, invoice).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of units associated with this budget line (e.g., number of shoot days, number of crew members, number of VFX shots, hours of post-production labor). Combined with unit_rate to derive budgeted amount.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedBudgetedAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Budgeted Amount' ;
    rdfs:comment 'Most recent approved revision to the budgeted amount, reflecting approved change orders, scope changes, or budget transfers. Null if no revision has been approved since original budget.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCreditEligible rdf:type rdf:Property ;
    rdfs:label 'Tax Credit Eligible' ;
    rdfs:comment 'Flag indicating whether this budget line qualifies for production tax credits or incentives (e.g., UK High-End TV Tax Relief, US state film tax credits). Enables automated calculation of eligible spend for tax credit claims.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the quantity field (e.g., day, hour, week, flat_fee, shot, reel, license). Defines how the quantity is counted for rate-based cost calculations. [ENUM-REF-CANDIDATE: day|hour|week|flat_fee|shot|reel|license|unit — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'Rate per unit of measure for this budget line (e.g., daily rate for a crew member, hourly rate for facility hire, per-shot rate for VFX). Multiplied by quantity to derive the budgeted amount.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'SAP Work Breakdown Structure element code that hierarchically positions this budget line within the production project plan (e.g., PRD-2024-001.3.2.1 for a specific post-production task).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Crew Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for a crew assignment record in the production domain. Primary key for the crew_assignment data product.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrewAssignment .

ind:cbaRateCardId rdf:type rdf:Property ;
    rdfs:label 'Cba Rate Card Id' ;
    rdfs:comment 'Foreign key linking to talent.cba_rate_card. Business justification: Union crew assignments must reference the applicable CBA rate card to calculate correct scale rates, overtime multipliers, meal penalties, and turnaround compliance. Production payroll systems require' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CbaRateCard .

ind:guildAffiliationId rdf:type rdf:Property ;
    rdfs:label 'Guild Affiliation Id' ;
    rdfs:comment 'Foreign key linking to talent.guild_affiliation. Business justification: Crew assignments for guild members require the specific guild_affiliation record to calculate pension/health contributions, file guild reports, and verify membership status. The existing union_guild_a' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuildAffiliation .

ind:loanOutPartnerId rdf:type rdf:Property ;
    rdfs:label 'Loan Out Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Crew members often work through loan-out companies or talent agencies (partners). Linking enables tracking all crew supplied by that partner, payment processing to the loan-out entity, union/guild com' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Externally-known business identifier for this crew assignment, used in deal memos, call sheets, and payroll processing. Format: CA-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle state of the crew assignment. Drives payroll eligibility, call sheet inclusion, and production roster reporting. Values: pending (offer extended, not yet accepted), confirmed (deal memo signed), active (currently on set/in production), on_hold (temporarily suspended), completed (assignment concluded), cancelled (assignment terminated before start).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Status of the crew member\'s background check for this production assignment. Required for productions involving minors (COPPA compliance) or access to secure facilities. Values: not_required, pending, cleared, failed, expired.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boxRentalRate rdf:type rdf:Property ;
    rdfs:label 'Box Rental Rate' ;
    rdfs:comment 'Daily or weekly rate paid to the crew member for the rental of their personal tool box or specialized equipment package (e.g., makeup artist\'s kit, wardrobe supervisor\'s supplies). Distinct from kit_rental_rate which covers technical equipment.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedRate rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate' ;
    rdfs:comment 'The agreed compensation rate for this crew assignment, expressed in the applicable deal_type unit (per day, per week, or flat total). Stored in the production\'s base currency. Used for budget tracking and payroll processing in SAP S/4HANA.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditName rdf:type rdf:Property ;
    rdfs:label 'Credit Name' ;
    rdfs:comment 'The name as it should appear in the production\'s end credits, which may differ from the crew member\'s legal name (e.g., stage name, preferred professional name). Sourced from the deal memo credit clause.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditPosition rdf:type rdf:Property ;
    rdfs:label 'Credit Position' ;
    rdfs:comment 'Specifies where the crew member\'s credit appears in the production: main_title (opening credits), end_title (closing credits), both, or none (no contractual credit obligation). Drives post-production credit sequence assembly.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'The production department to which the crew member belongs for this assignment (e.g., camera, grip, electric, art, wardrobe, hair/makeup, post-production, sound, VFX). Drives crew call sheet grouping and budget cost center allocation. [ENUM-REF-CANDIDATE: camera|grip|electric|art|wardrobe|hair_makeup|post_production|sound|vfx|production — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The contractually agreed last day of work for this crew assignment. Nullable for open-ended or rolling assignments. Used for wrap scheduling and final payroll processing.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteedDays rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Days' ;
    rdfs:comment 'The minimum number of work days guaranteed to the crew member under this assignment deal, regardless of actual production schedule. Relevant for weekly and episodic deal types. Used for take-or-pay liability calculation.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kitRentalRate rdf:type rdf:Property ;
    rdfs:label 'Kit Rental Rate' ;
    rdfs:comment 'Daily or weekly rate paid to the crew member for the rental of their personal professional equipment (kit) used on the production (e.g., camera operator\'s lens kit, sound mixer\'s equipment package). Common in below-the-line crew deals.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mealPenaltyEligible rdf:type rdf:Property ;
    rdfs:label 'Meal Penalty Eligible' ;
    rdfs:comment 'Indicates whether this crew member is entitled to meal penalty payments if the production fails to provide a meal break within the contractually required interval (typically 6 hours under IATSE/DGA agreements). Drives production scheduling compliance.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeEligible rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible' ;
    rdfs:comment 'Indicates whether this crew member is eligible for overtime pay under their union/guild agreement or applicable labor law. True = eligible for overtime; False = flat deal or exempt classification. Drives payroll calculation logic.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Rate Multiplier' ;
    rdfs:comment 'The multiplier applied to the base contracted_rate for overtime hours (e.g., 1.5 for time-and-a-half, 2.0 for double-time). Applicable only when overtime_eligible is True. Sourced from the applicable union/guild agreement.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perDiemRate rdf:type rdf:Property ;
    rdfs:label 'Per Diem Rate' ;
    rdfs:comment 'Daily allowance paid to the crew member for meals and incidental expenses when working away from their home base location. Rate varies by filming location and union agreement. Used for production cost budgeting.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionCompany rdf:type rdf:Property ;
    rdfs:label 'Production Company' ;
    rdfs:comment 'The legal name of the production company or entity that is the employer of record for this crew assignment. Relevant for co-productions where multiple entities may employ different crew members. Used for payroll and tax reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualsEligible rdf:type rdf:Property ;
    rdfs:label 'Residuals Eligible' ;
    rdfs:comment 'Indicates whether this crew member is entitled to residual payments when the production is reused, syndicated, or distributed on additional platforms (e.g., streaming, international broadcast). Residuals are governed by DGA, IATSE, and SAG-AFTRA agreements.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleTitle rdf:type rdf:Property ;
    rdfs:label 'Role Title' ;
    rdfs:comment 'The specific production role or job title assigned to the crew member (e.g., Director, Director of Photography, Gaffer, Script Supervisor, Editor, Colorist, VFX Supervisor, Sound Mixer, Key Grip, Best Boy). [ENUM-REF-CANDIDATE: director|director_of_photography|gaffer|script_supervisor|editor|colorist|vfx_supervisor|sound_mixer|key_grip|best_boy|production_designer|costume_designer — promote to reference product]' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyTrainingCertified rdf:type rdf:Property ;
    rdfs:label 'Safety Training Certified' ;
    rdfs:comment 'Indicates whether the crew member has completed the required on-set safety training certification for this production (e.g., OSHA safety, COVID-19 protocols, stunt safety). Required for insurance compliance and production liability management.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapPersonnelActionCode rdf:type rdf:Property ;
    rdfs:label 'Sap Personnel Action Code' ;
    rdfs:comment 'The personnel action number in SAP S/4HANA HR that corresponds to this crew assignment. Used for payroll processing, benefits enrollment, and HR compliance reporting. Enables reconciliation between the production data product and the ERP system of record.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDays rdf:type rdf:Property ;
    rdfs:label 'Scheduled Days' ;
    rdfs:comment 'The total number of work days currently scheduled for this crew member on the production, as reflected in the current production schedule. May differ from guaranteed_days if the schedule changes.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The contractually agreed first day of work for this crew assignment. Used for payroll calculation, permit verification, and production schedule alignment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:travelAllowance rdf:type rdf:Property ;
    rdfs:label 'Travel Allowance' ;
    rdfs:comment 'Fixed or estimated travel reimbursement amount for this crew assignment, covering transportation costs to and from the filming location. Distinct from per_diem_rate which covers daily living expenses.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workPermitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Work Permit Expiry Date' ;
    rdfs:comment 'The expiration date of the crew member\'s work permit or visa authorization. Used to trigger renewal alerts and ensure continuous legal work authorization throughout the assignment period.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Work Permit Number' ;
    rdfs:comment 'The official government-issued work permit or visa authorization number for the crew member in the production jurisdiction. Nullable when work_permit_required is False. Required for compliance audits and production insurance.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPermitRequired rdf:type rdf:Property ;
    rdfs:label 'Work Permit Required' ;
    rdfs:comment 'Indicates whether a work permit or visa authorization is required for this crew member to legally work on this production in the filming jurisdiction. True = permit required; False = no permit required (domestic/citizen crew). Triggers compliance workflow in HR.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityBookingId rdf:type rdf:Property ;
    rdfs:label 'Facility Booking Id' ;
    rdfs:comment 'Unique surrogate identifier for each facility booking record in the production domain. Primary key for the facility_booking data product.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FacilityBooking .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'The final invoiced or accrued cost of the facility booking after actual usage is confirmed. Includes any overtime charges or adjustments. Reconciled against estimated_cost for budget variance reporting in SAP S/4HANA CO.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEnd rdf:type rdf:Property ;
    rdfs:label 'Actual End' ;
    rdfs:comment 'The actual date and time the facility usage concluded, as recorded by the facility operator or production coordinator. Used for overtime calculation, billing reconciliation, and schedule variance reporting.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStart rdf:type rdf:Property ;
    rdfs:label 'Actual Start' ;
    rdfs:comment 'The actual date and time the facility usage commenced, as recorded by the facility operator or production coordinator. May differ from booking_start due to delays or early starts. Used for variance analysis and billing reconciliation.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingEnd rdf:type rdf:Property ;
    rdfs:label 'Booking End' ;
    rdfs:comment 'The scheduled date and time at which the facility booking period ends. Combined with booking_start to compute duration and detect scheduling conflicts across productions.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingReference rdf:type rdf:Property ;
    rdfs:label 'Booking Reference' ;
    rdfs:comment 'Externally visible alphanumeric reference code assigned to this booking, used in communications with facility operators, vendors, and production coordinators. Corresponds to the booking order number in SAP S/4HANA MM module.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingStart rdf:type rdf:Property ;
    rdfs:label 'Booking Start' ;
    rdfs:comment 'The scheduled date and time at which the facility booking period begins. Used for conflict detection, crew scheduling, and playout coordination. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Status' ;
    rdfs:comment 'Current lifecycle state of the facility booking. \'tentative\' indicates a provisional hold pending confirmation; \'confirmed\' indicates a firm reservation; \'cancelled\' indicates the booking was withdrawn; \'completed\' indicates the facility usage has concluded; \'on_hold\' indicates a temporary pause pending decision.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date on which the facility booking was formally cancelled. Used to determine whether cancellation fees apply per the vendor contract terms and for financial accrual reversal in SAP S/4HANA.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationFee rdf:type rdf:Property ;
    rdfs:label 'Cancellation Fee' ;
    rdfs:comment 'Monetary penalty charged by the facility vendor when a confirmed booking is cancelled within the contractual notice period. Recorded for financial reconciliation and budget variance reporting.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text explanation for why the booking was cancelled. Populated only when booking_status is \'cancelled\'. Used for production post-mortem analysis and vendor dispute resolution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPersons rdf:type rdf:Property ;
    rdfs:label 'Capacity Persons' ;
    rdfs:comment 'Maximum number of persons the facility can accommodate during the booking period. Used for crew planning, health and safety compliance, and resource allocation decisions.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'The projected total cost of the facility booking at the time of reservation, calculated from rate_amount and the planned booking duration. Used for production budget planning and greenlight approvals.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the production facility being booked. Drives resource conflict detection logic and cost allocation rules. [ENUM-REF-CANDIDATE: soundstage|editing_suite|dubbing_stage|color_grading_suite|adr_studio|screening_room|post_production_bay — promote to reference product]' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Indicates whether this booking grants exclusive use of the facility for the booked period, preventing any concurrent bookings by other productions. When False, the facility may be shared with other productions subject to capacity constraints.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Number of hours the facility was used beyond the originally booked end time. Drives overtime rate calculations and is a key input to actual_cost reconciliation and production schedule variance analysis.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Amount' ;
    rdfs:comment 'The contracted rate charged for the facility per the applicable rate_type unit (e.g., cost per hour or cost per day). Sourced from the facility rate card or negotiated contract. Used for budget estimation and cost allocation.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'The billing rate structure applied to this facility booking. Determines how the total cost is calculated — per hour, per day, half-day block, weekly block, or a negotiated flat fee.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSpecs rdf:type rdf:Property ;
    rdfs:label 'Technical Specs' ;
    rdfs:comment 'Free-text description of the technical capabilities and equipment configuration of the facility at the time of booking (e.g., \'Dolby Atmos 7.1.4 mixing console, Pro Tools HDX, 4K DI suite\'). Sourced from Dalet Galaxy facility metadata.' ;
    rdfs:domain ind:FacilityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Equipment Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each equipment allocation record. Primary key for the equipment_allocation data product in the production domain.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentItemId rdf:type rdf:Property ;
    rdfs:label 'Equipment Item Id' ;
    rdfs:comment 'Reference to the master equipment item record (camera body, lens, lighting rig, sound package, jib, drone, editing workstation, encoding hardware) being allocated.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentItem .

ind:allocationEndDate rdf:type rdf:Property ;
    rdfs:label 'Allocation End Date' ;
    rdfs:comment 'The date on which the equipment allocation ends — i.e., the last day the equipment is assigned to the production. Used for rental cost calculation and return scheduling.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Externally-known business identifier for the allocation record, used in production paperwork, crew call sheets, and facility booking confirmations. Format: EQALLOC-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStartDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Start Date' ;
    rdfs:comment 'The date on which the equipment allocation begins — i.e., the first day the equipment is available to the production. Used for rental rate calculation and scheduling conflict detection.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle state of the equipment allocation. Drives workflow routing in Dalet Galaxy and cost accrual in SAP S/4HANA. [ENUM-REF-CANDIDATE: requested|confirmed|checked_out|in_use|checked_in|cancelled|lost|damaged — promote to reference product]' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagCode rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Code' ;
    rdfs:comment 'Internal asset tag or barcode label affixed to owned equipment for physical inventory tracking. Format: {CC}-{NNNNNN} where CC is category code. Null for rented equipment.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutCondition rdf:type rdf:Property ;
    rdfs:label 'Checkout Condition' ;
    rdfs:comment 'Assessed physical condition of the equipment at the time of checkout. Establishes the baseline condition for damage assessment upon return. Recorded by the equipment manager.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checkout Timestamp' ;
    rdfs:comment 'Exact date and time the equipment was physically checked out from the equipment room or rental house. Serves as the principal business event timestamp for the allocation lifecycle.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:damageClaimAmount rdf:type rdf:Property ;
    rdfs:label 'Damage Claim Amount' ;
    rdfs:comment 'Monetary value of the damage or loss claim raised against this allocation, in the currency specified by currency_code. Null when no damage claim exists. Used for financial reconciliation and insurance recovery.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Free-text description of any damage, loss, or malfunction identified at return. Null when equipment is returned in acceptable condition. Used to support insurance claims and vendor dispute resolution.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Category' ;
    rdfs:comment 'High-level classification of the equipment type being allocated. Drives cost centre coding, insurance grouping, and crew department assignment. [ENUM-REF-CANDIDATE: camera|lens|lighting|sound|grip|drone|editing_workstation|encoding_hardware|other — promote to reference product]' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentName rdf:type rdf:Property ;
    rdfs:label 'Equipment Name' ;
    rdfs:comment 'Human-readable name or model designation of the equipment item (e.g., ARRI ALEXA Mini LF, Cooke S4/i 32mm, Litepanels Astra 6X). Supports crew call sheets and production reports.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Reference number of the insurance policy covering this equipment allocation. Used for claims processing and compliance with production insurance requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceValue rdf:type rdf:Property ;
    rdfs:label 'Insurance Value' ;
    rdfs:comment 'Declared replacement value of the equipment for insurance purposes, in the currency specified by currency_code. Used to calculate insurance premiums and process loss/damage claims.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isInsuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Is Insurance Required' ;
    rdfs:comment 'Indicates whether specific insurance coverage must be arranged for this equipment allocation (True) or whether it falls under the production\'s blanket policy (False). Relevant for high-value or specialist equipment.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOwnedAsset rdf:type rdf:Property ;
    rdfs:label 'Is Owned Asset' ;
    rdfs:comment 'Indicates whether the equipment is owned by the production company (True) or rented from an external vendor (False). Drives depreciation accounting vs. rental cost booking in SAP S/4HANA FI.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionDepartment rdf:type rdf:Property ;
    rdfs:label 'Production Department' ;
    rdfs:comment 'The production department responsible for the equipment allocation (e.g., camera, lighting, grip, sound). Used for departmental budget tracking and cost centre allocation in SAP S/4HANA CO. [ENUM-REF-CANDIDATE: camera|lighting|grip|sound|art|vfx|post_production|production_office|other — promote to reference product]' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rentalRateAmount rdf:type rdf:Property ;
    rdfs:label 'Rental Rate Amount' ;
    rdfs:comment 'The agreed rental rate per day or per week (per rental_rate_type) for the equipment, in the production\'s base currency. Used for production budget tracking and vendor cost reconciliation in SAP S/4HANA.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentalRateType rdf:type rdf:Property ;
    rdfs:label 'Rental Rate Type' ;
    rdfs:comment 'Indicates whether the rental rate is charged on a daily, weekly, or flat-fee basis. Determines how the total rental cost is computed for budget tracking and vendor invoice reconciliation.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnCondition rdf:type rdf:Property ;
    rdfs:label 'Return Condition' ;
    rdfs:comment 'Assessed physical condition of the equipment at the time of return. Compared against checkout_condition to identify damage or deterioration. Triggers damage claim workflow if degraded. [ENUM-REF-CANDIDATE: new|excellent|good|fair|poor|damaged|lost — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Timestamp' ;
    rdfs:comment 'Exact date and time the equipment was physically returned to the equipment room or rental house. Null until the equipment is returned. Used to calculate actual rental duration and late return penalties.' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the specific equipment unit allocated. Used for asset tracking, insurance claims, and loss/damage investigations. Classified confidential as it identifies a specific high-value asset.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'SAP S/4HANA Work Breakdown Structure (WBS) element code identifying the specific production phase or deliverable to which this equipment cost is attributed (e.g., pre-production, principal photography, post-production).' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipId rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Id' ;
    rdfs:comment 'Foreign key linking to sales.sponsorship. Business justification: Individual episodes are sponsored (e.g., \'Episode presented by Brand X\'). Production must track which sponsorship is attached to each episode for branded content compliance, sponsor approval workflows' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sponsorship .

ind:syndicationLicenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Syndication License Agreement Id' ;
    rdfs:comment 'Foreign key linking to rights.license_agreement. Business justification: Individual episodes may have separate syndication or international license agreements distinct from the series-level agreement. Real business need: episode-level rights tracking for syndication deals,' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:actualCostUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Usd' ;
    rdfs:comment 'Total actual production cost incurred for this episode in US dollars, as recorded in SAP S/4HANA. Used for budget variance analysis, EBITDA reporting, and production cost per minute calculations.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualRunningTimeSec rdf:type rdf:Property ;
    rdfs:label 'Actual Running Time Sec' ;
    rdfs:comment 'Final delivered running time of the episode in seconds as measured from the completed master file. May differ from target due to editorial decisions made during post-production. Used for playout scheduling reconciliation and delivery compliance verification.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Audio Language Code' ;
    rdfs:comment 'ISO 639-2 three-letter language code for the primary audio track of this episode. Used for distribution rights matching, subtitle/dubbing workflow triggering, and EPG metadata population.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioMixCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Audio Mix Completion Date' ;
    rdfs:comment 'Date on which the final audio mix (including dialogue, music, and effects) was completed and approved. Prerequisite for final mastering and delivery. Tracked as a post-production milestone in Dalet Galaxy.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedCaptioningCompliant rdf:type rdf:Property ;
    rdfs:label 'Closed Captioning Compliant' ;
    rdfs:comment 'Indicates whether this episode meets FCC closed captioning requirements (47 CFR Part 79) and Ofcom subtitling standards. Required for broadcast clearance and regulatory compliance reporting.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:colorGradeCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Color Grade Completion Date' ;
    rdfs:comment 'Date on which color grading (digital color correction and finishing) was completed and approved. Required before final mastering and transcode for delivery. Tracked as a post-production milestone in Dalet Galaxy.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contentType rdf:type rdf:Property ;
    rdfs:label 'Content Type' ;
    rdfs:comment 'Broad classification of the episode content format. Determines applicable production workflows, rights frameworks, talent residual calculations, and compliance requirements (e.g., COPPA for children\'s content). [ENUM-REF-CANDIDATE: scripted|unscripted|documentary|news|sports|animation|live_event — promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Contractually committed or operationally planned date by which the completed episode master must be delivered to the distributor, broadcaster, or platform. Used for SLA tracking and rights window activation in Rightsline.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:directorName rdf:type rdf:Property ;
    rdfs:label 'Director Name' ;
    rdfs:comment 'Full name of the credited director for this episode. Used for DGA residuals calculation, talent contract compliance, and creative attribution in production records.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeCode rdf:type rdf:Property ;
    rdfs:label 'Episode Code' ;
    rdfs:comment 'Internal production code assigned by the production team to uniquely identify this episode within the production management system (e.g., Dalet Galaxy asset code). Used for workflow routing, asset tagging, and facility booking references.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstAirDate rdf:type rdf:Property ;
    rdfs:label 'First Air Date' ;
    rdfs:comment 'Date on which this episode first aired or was made available to audiences on any platform (linear broadcast, VOD, OTT). Marks the start of the content windowing lifecycle and triggers residuals calculation in Rightsline.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:masterFormat rdf:type rdf:Property ;
    rdfs:label 'Master Format' ;
    rdfs:comment 'Technical format specification of the delivered episode master file (e.g., UHD HDR, HD 1080p). Determines transcode profiles required for multi-platform distribution and CDN delivery via Akamai.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pictureLockDate rdf:type rdf:Property ;
    rdfs:label 'Picture Lock Date' ;
    rdfs:comment 'Date on which the final edited picture was locked, freezing all visual edits. Triggers downstream post-production workflows including VFX, color grading, and audio mixing. Critical milestone for delivery scheduling.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionStatus rdf:type rdf:Property ;
    rdfs:label 'Production Status' ;
    rdfs:comment 'Current lifecycle stage of the episode within the end-to-end production workflow. Drives workflow routing in Dalet Galaxy and milestone reporting to production management. [ENUM-REF-CANDIDATE: development|pre_production|principal_photography|post_production|picture_lock|delivered|archived — promote to reference product]' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scriptLockDate rdf:type rdf:Property ;
    rdfs:label 'Script Lock Date' ;
    rdfs:comment 'Date on which the final shooting script was locked, freezing all creative changes. Triggers pre-production scheduling, crew assignments, and facility bookings. Key milestone for production planning.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shootCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shoot Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the primary country where principal photography was conducted. Used for production tax credit eligibility, co-production treaty compliance, and content origin classification.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shootEndDate rdf:type rdf:Property ;
    rdfs:label 'Shoot End Date' ;
    rdfs:comment 'Scheduled or actual end date of principal photography (picture wrap) for this episode. Used to confirm transition to post-production and trigger post-production workflow initiation in Dalet Galaxy.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shootLocation rdf:type rdf:Property ;
    rdfs:label 'Shoot Location' ;
    rdfs:comment 'Primary geographic location where principal photography for this episode was conducted. Used for production tax credit eligibility, location permit compliance, and production logistics reporting.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shootStartDate rdf:type rdf:Property ;
    rdfs:label 'Shoot Start Date' ;
    rdfs:comment 'Scheduled or actual start date of principal photography for this episode. Used for crew scheduling, facility booking, and production budget burn-rate tracking in SAP S/4HANA.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:showrunnerName rdf:type rdf:Property ;
    rdfs:label 'Showrunner Name' ;
    rdfs:comment 'Full name of the showrunner (executive producer with creative oversight) responsible for this episode. Key accountability reference for production governance and editorial decisions.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleLanguages rdf:type rdf:Property ;
    rdfs:label 'Subtitle Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639-2 three-letter language codes for subtitle tracks available in the delivered master. Used for accessibility compliance (FCC closed captioning rules), distribution rights, and EPG metadata.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRunningTimeSec rdf:type rdf:Property ;
    rdfs:label 'Target Running Time Sec' ;
    rdfs:comment 'Planned editorial running time of the episode in seconds, excluding commercial breaks. Used for scheduling slot allocation, playout automation configuration in Ericsson MediaFirst, and delivery specification compliance.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vfxCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Vfx Completion Date' ;
    rdfs:comment 'Date on which all visual effects shots were completed and approved for integration into the picture lock. Tracked as a post-production milestone. Null if the episode contains no VFX work.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writerName rdf:type rdf:Property ;
    rdfs:label 'Writer Name' ;
    rdfs:comment 'Full name of the credited writer(s) for this episode. Used for residuals calculation, WGA/guild compliance reporting, and rights attribution in Rightsline.' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingId rdf:type rdf:Property ;
    rdfs:label 'Content Rating Id' ;
    rdfs:comment 'Foreign key linking to compliance.content_rating. Business justification: Pre-production content classification: scripts are submitted for content rating review before greenlight in many jurisdictions. Linking script to content_rating supports the pre-production compliance ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaBroadcasting .

ind:underlyingRightsHolderId rdf:type rdf:Property ;
    rdfs:label 'Underlying Rights Holder Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_holder. Business justification: Scripts are often based on underlying IP owned by rights holders (novels, plays, life rights, true stories, existing franchises). Real business need: tracking the rights holder of the underlying IP be' ;
    rdfs:domain ind:Script ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which the script was officially approved for production.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'The confidentiality classification of the script document (public, internal, confidential, restricted).' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copyrightHolder rdf:type rdf:Property ;
    rdfs:label 'Copyright Holder' ;
    rdfs:comment 'The legal entity or individual who holds the copyright to the script.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copyrightYear rdf:type rdf:Property ;
    rdfs:label 'Copyright Year' ;
    rdfs:comment 'The year in which the script copyright was established or registered.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daletDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Dalet Document Reference' ;
    rdfs:comment 'The unique document identifier or reference in the Dalet Galaxy Media Asset Management (MAM) system linking this script record to the digital script file.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionRestriction rdf:type rdf:Property ;
    rdfs:label 'Distribution Restriction' ;
    rdfs:comment 'Any restrictions or limitations on the distribution or sharing of the script (e.g., internal use only, NDA required).' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftType rdf:type rdf:Property ;
    rdfs:label 'Draft Type' ;
    rdfs:comment 'The classification of the script draft stage (outline, first draft, revised draft, shooting script, post-production script, final draft).' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRuntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Runtime Minutes' ;
    rdfs:comment 'The estimated runtime of the production in minutes based on the script length and pacing.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'The digital file format of the script document (PDF, DOCX, FDX, FOUNTAIN, TXT).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'The size of the script file in megabytes.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'The production format for which the script is intended (feature film, television episode, miniseries, web series, documentary, commercial, short film). [ENUM-REF-CANDIDATE: feature film|television episode|miniseries|web series|documentary|commercial|short film — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genre rdf:type rdf:Property ;
    rdfs:label 'Genre' ;
    rdfs:comment 'The genre or category of the script (e.g., drama, comedy, thriller, documentary).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'The primary language in which the script is written (e.g., English, Spanish, French).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockDate rdf:type rdf:Property ;
    rdfs:label 'Lock Date' ;
    rdfs:comment 'The date on which the script was locked and finalized for production.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockStatus rdf:type rdf:Property ;
    rdfs:label 'Lock Status' ;
    rdfs:comment 'Indicates whether the script is locked for production (true) or still open for revisions (false).' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisionNotes rdf:type rdf:Property ;
    rdfs:label 'Revision Notes' ;
    rdfs:comment 'Notes or comments describing the changes made in the current revision of the script.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sceneCount rdf:type rdf:Property ;
    rdfs:label 'Scene Count' ;
    rdfs:comment 'The total number of scenes defined in the script.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scriptNumber rdf:type rdf:Property ;
    rdfs:label 'Script Number' ;
    rdfs:comment 'The externally-known unique identifier or code assigned to this script for production tracking and reference purposes.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scriptStatus rdf:type rdf:Property ;
    rdfs:label 'Script Status' ;
    rdfs:comment 'Current lifecycle status of the script (draft, in review, approved, locked, archived, rejected).' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wgaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Wga Registration Number' ;
    rdfs:comment 'The WGA registration number assigned to this script for copyright and intellectual property protection.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writerCredits rdf:type rdf:Property ;
    rdfs:label 'Writer Credits' ;
    rdfs:comment 'The names and credits of the writer(s) who authored or contributed to the script.' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postProductionTaskId rdf:type rdf:Property ;
    rdfs:label 'Post Production Task Id' ;
    rdfs:comment 'Unique identifier for the post-production task within the Dalet Galaxy workflow orchestration pipeline.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PostProductionTask .

ind:deliveryObligationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Obligation Id' ;
    rdfs:comment 'Foreign key linking to partner.delivery_obligation. Business justification: Obligation-driven post-production workflow: post-production supervisors assign tasks (dubbing, subtitling, QC, localization) directly to fulfill specific contractual delivery obligations. Direct link ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryObligation .

ind:formatSpecId rdf:type rdf:Property ;
    rdfs:label 'Format Spec Id' ;
    rdfs:comment 'Foreign key linking to production.format_spec. Business justification: post_production_task has technical_specification as a free-text field. Adding format_spec_id normalizes this to a proper FK to the format_spec reference table, which contains authoritative technical f' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormatSpec .

ind:ingestJobId rdf:type rdf:Property ;
    rdfs:label 'Ingest Job Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.ingest_job. Business justification: Post-production ingest tasks (camera card ingest, rushes ingest, final delivery ingest) directly correspond to MAM ingest jobs. Linking enables end-to-end production pipeline traceability from task as' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IngestJob .

ind:parentTaskPostProductionTaskId rdf:type rdf:Property ;
    rdfs:label 'Parent Task Post Production Task Id' ;
    rdfs:comment 'Reference to the parent post-production task if this task is a sub-task or dependent task in a hierarchical workflow.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PostProductionTask .

ind:targetScheduleSlotId rdf:type rdf:Property ;
    rdfs:label 'Target Schedule Slot Id' ;
    rdfs:comment 'Foreign key linking to scheduling.schedule_slot. Business justification: Post-production task deadlines are driven by the air date of the target schedule slot. Post coordinators and traffic teams use this link to prioritize QC, mastering, and delivery tasks against specifi' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleSlot .

ind:transcodeJobId rdf:type rdf:Property ;
    rdfs:label 'Transcode Job Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.transcode_job. Business justification: Post-production tasks (conform, encode, package) directly trigger MAM transcode jobs. Linking enables production pipeline monitoring against MAM processing jobs — essential for SLA reporting, cost att' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TranscodeJob .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Actual date and time when the post-production task was completed and submitted for review or approval.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDurationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Hours' ;
    rdfs:comment 'Actual number of hours spent completing the post-production task, used for cost tracking and performance analysis.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when work on the post-production task commenced.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daletWorkflowTaskReference rdf:type rdf:Property ;
    rdfs:label 'Dalet Workflow Task Reference' ;
    rdfs:comment 'External system identifier from Dalet Galaxy workflow orchestration system for this specific task instance.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyType rdf:type rdf:Property ;
    rdfs:label 'Dependency Type' ;
    rdfs:comment 'Type of scheduling dependency relationship this task has with its predecessor tasks in the workflow.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Amount' ;
    rdfs:comment 'Budgeted cost for completing this post-production task, including labor, equipment, and vendor fees.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Planned number of hours required to complete the post-production task, used for resource planning and scheduling.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputMediaPath rdf:type rdf:Property ;
    rdfs:label 'Output Media Path' ;
    rdfs:comment 'File system path or MAM location where the completed output files or deliverables from this task are stored.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority level assigned to the task, determining scheduling and resource allocation urgency.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcPassFlag rdf:type rdf:Property ;
    rdfs:label 'Qc Pass Flag' ;
    rdfs:comment 'Indicator of whether the task output passed quality control review on first submission without requiring revisions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation of why the task output was rejected during review, requiring rework or revision.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Feedback, comments, or change requests provided by reviewers or approvers during the quality control or approval process.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Version number indicating how many times this task has been revised or reworked due to feedback or quality issues.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledDueDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Due Date' ;
    rdfs:comment 'Target completion date for the post-production task as defined in the production schedule.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date when the post-production task is scheduled to begin.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceMediaPath rdf:type rdf:Property ;
    rdfs:label 'Source Media Path' ;
    rdfs:comment 'File system path or Media Asset Management (MAM) location of the source media files or assets for this task.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskNotes rdf:type rdf:Property ;
    rdfs:label 'Task Notes' ;
    rdfs:comment 'General operational notes, instructions, or context information related to the execution of this post-production task.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Human-readable business identifier for the post-production task, often used for tracking and communication purposes.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the post-production task within the workflow pipeline. [ENUM-REF-CANDIDATE: queued|in_progress|review|approved|rejected|complete|on_hold|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the post-production work task indicating the specific type of creative or technical operation being performed. [ENUM-REF-CANDIDATE: offline_edit|online_conform|vfx_composite|color_grade|audio_mix|adr_record|subtitle_burn_in|qc_review|transcode|archive_ingest|foley_record|sound_design|title_graphics|versioning — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workstationCode rdf:type rdf:Property ;
    rdfs:label 'Workstation Code' ;
    rdfs:comment 'Identifier of the specific editing suite, color grading bay, or audio mixing console assigned for this task.' ;
    rdfs:domain ind:PostProductionTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adOrderId rdf:type rdf:Property ;
    rdfs:label 'Ad Order Id' ;
    rdfs:comment 'Foreign key linking to sales.ad_order. Business justification: Ad spots and custom creative deliverables are produced to fulfill contracted ad orders. Traffic and production coordinators reconcile deliverable completion against ad order commitments for billing an' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdOrder .

ind:distributionDrmPolicyId rdf:type rdf:Property ;
    rdfs:label 'Distribution Drm Policy Id' ;
    rdfs:comment 'Foreign key linking to distribution.drm_policy. Business justification: Deliverables require specific DRM protection policies based on content rights and platform requirements. Real business process: content protection enforcement, rights management, and secure delivery c' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrmPolicy .

ind:partnerContentWindowId rdf:type rdf:Property ;
    rdfs:label 'Partner Content Window Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_content_window. Business justification: Content windowing fulfillment: distribution operations teams produce deliverables to meet the technical and rights requirements of specific partner content windows (SVOD, TVOD, linear). Direct link en' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerContentWindow .

ind:recipientPartnerId rdf:type rdf:Property ;
    rdfs:label 'Recipient Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Deliverables are sent to distribution partners, broadcasters, streaming platforms, and licensees. Linking enables delivery obligation tracking, SLA compliance monitoring, acceptance workflow managemen' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:releaseWindowId rdf:type rdf:Property ;
    rdfs:label 'Release Window Id' ;
    rdfs:comment 'Foreign key linking to distribution.release_window. Business justification: A deliverable is produced to fulfill a specific release window obligation (territory, window type, exclusivity). This is a fundamental media-broadcasting contractual process — deliverables are tracked' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReleaseWindow .

ind:territoryGrantId rdf:type rdf:Property ;
    rdfs:label 'Territory Grant Id' ;
    rdfs:comment 'Foreign key linking to partner.territory_grant. Business justification: Territory-compliant delivery: rights and distribution teams ensure each deliverable (e.g., dubbed version, localized cut) is produced and delivered within the scope of a specific territory grant. Enab' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerritoryGrant .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Actual date and time when the deliverable was successfully delivered or handed off.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:audioChannels rdf:type rdf:Property ;
    rdfs:label 'Audio Channels' ;
    rdfs:comment 'Audio channel configuration for the deliverable (e.g., \'Stereo\', \'5.1 Surround\', \'7.1 Surround\', \'Mono\', \'Dolby Atmos\'). Null for non-audio deliverables.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioDescriptionFlag rdf:type rdf:Property ;
    rdfs:label 'Audio Description Flag' ;
    rdfs:comment 'Indicates whether an audio description track for visually impaired viewers is included. True = audio description present; False = no audio description.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checksumMd5 rdf:type rdf:Property ;
    rdfs:label 'Checksum Md5' ;
    rdfs:comment 'MD5 hash of the deliverable file for integrity verification during transfer and storage.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificateFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certificate Flag' ;
    rdfs:comment 'Indicates whether a regulatory compliance certificate (e.g., FCC, Ofcom, content rating) accompanies this deliverable. True = certificate included; False = no certificate.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference number or identifier of the contract or agreement that mandates this deliverable.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred to produce this deliverable, including labor, equipment, facilities, and post-production services.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverableName rdf:type rdf:Property ;
    rdfs:label 'Deliverable Name' ;
    rdfs:comment 'Human-readable name or title of the deliverable (e.g., \'Broadcast Master HD\', \'Promo Cut 30s\', \'Closed Caption SRT File\').' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableType rdf:type rdf:Property ;
    rdfs:label 'Deliverable Type' ;
    rdfs:comment 'Category of deliverable output. Broadcast master = final linear transmission file; streaming master = OTT/VOD optimized file; promo cut = promotional excerpt; trailer = marketing preview; EPK = Electronic Press Kit; closed caption file = accessibility text; audio description track = visually impaired narration; subtitle file = translation text; M&E track = Music and Effects (no dialogue); textless version = graphics-free master; compliance certificate = regulatory approval document; QC report = Quality Control validation; as-run log = actual playout record. [ENUM-REF-CANDIDATE: broadcast_master|streaming_master|promo_cut|trailer|epk|closed_caption_file|audio_description_track|subtitle_file|me_track|textless_version|compliance_certificate|qc_report|as_run_log|other — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Physical address, URL, FTP path, or cloud storage location where the deliverable was sent or made available.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method or protocol used to deliver the deliverable to the recipient. Physical media = hard drive/tape shipment; FTP = File Transfer Protocol; Aspera = high-speed file transfer; Signiant = media transfer platform; AWS S3 = Amazon cloud storage; Akamai NetStorage = CDN storage; Google Drive/Dropbox = cloud file sharing. [ENUM-REF-CANDIDATE: physical_media|ftp|aspera|signiant|aws_s3|akamai_netstorage|google_drive|dropbox|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle state of the deliverable. Not started = work has not begun; in progress = actively being produced; QC pending = awaiting quality control review; QC failed = did not pass quality checks; QC passed = approved for delivery; ready for delivery = prepared and awaiting handoff; delivered = sent to recipient; accepted = recipient confirmed receipt and approval; rejected = recipient declined or returned; cancelled = deliverable no longer required. [ENUM-REF-CANDIDATE: not_started|in_progress|qc_pending|qc_failed|qc_passed|ready_for_delivery|delivered|accepted|rejected|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Contractually or operationally required date by which this deliverable must be completed and handed off.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Total file size of the deliverable in bytes. Used for storage planning, transfer time estimation, and CDN capacity management.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcNotes rdf:type rdf:Property ;
    rdfs:label 'Qc Notes' ;
    rdfs:comment 'Detailed notes from the quality control review, including any issues found, corrective actions taken, or validation comments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcOperatorName rdf:type rdf:Property ;
    rdfs:label 'Qc Operator Name' ;
    rdfs:comment 'Name of the quality control technician or automated system that performed the QC validation.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcPerformedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Performed Timestamp' ;
    rdfs:comment 'Date and time when quality control validation was completed for this deliverable.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Timestamp' ;
    rdfs:comment 'Planned date and time for delivery of this deliverable to the recipient or platform.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qcReviewId rdf:type rdf:Property ;
    rdfs:label 'Qc Review Id' ;
    rdfs:comment 'Unique identifier for the quality control review record. Primary key.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcInspectionId rdf:type rdf:Property ;
    rdfs:label 'Qc Inspection Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.qc_inspection. Business justification: Production QC reviews (editorial/compliance) and MAM qc_inspections (technical/format) are complementary processes on the same asset. Broadcasters and OTT platforms require a unified QC audit trail li' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QcInspection .

ind:targetAbrProfileId rdf:type rdf:Property ;
    rdfs:label 'Target Abr Profile Id' ;
    rdfs:comment 'Foreign key linking to distribution.abr_profile. Business justification: QC reviews validate deliverables against target ABR profile specifications for distribution readiness. Real business process: quality assurance for streaming assets, technical compliance validation, a' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbrProfile .

ind:audioChannelConfiguration rdf:type rdf:Property ;
    rdfs:label 'Audio Channel Configuration' ;
    rdfs:comment 'Audio channel layout (e.g., stereo, 5.1 surround, 7.1 surround, mono).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioCodec rdf:type rdf:Property ;
    rdfs:label 'Audio Codec' ;
    rdfs:comment 'Audio codec used in the deliverable (e.g., AAC, Dolby Digital, PCM).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioDescriptionComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Audio Description Compliance Flag' ;
    rdfs:comment 'Indicates whether audio description track meets accessibility standards. True if compliant, False if missing or non-compliant.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedCaptionComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Compliance Flag' ;
    rdfs:comment 'Indicates whether closed captions meet accessibility and regulatory standards (FCC, CVAA). True if compliant, False if violations detected.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:errorCodes rdf:type rdf:Property ;
    rdfs:label 'Error Codes' ;
    rdfs:comment 'Comma-separated list of specific error codes identified during the review, aligned with EBU R128, ATSC A/85, and ITU-R BT.1788 standards (e.g., V001 for video freeze, A002 for loudness violation, C003 for closed caption sync error).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Final Approval Date' ;
    rdfs:comment 'Date when the deliverable received final approval for distribution. Null if not yet approved.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Final Approval Status' ;
    rdfs:comment 'Final approval status of the deliverable after QC review and any remediation: approved (ready for distribution), rejected (does not meet standards), pending approval (awaiting sign-off), or conditional approval (approved with minor caveats).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loudnessComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Loudness Compliance Flag' ;
    rdfs:comment 'Indicates whether the deliverable meets loudness standards (EBU R128 or ATSC A/85). True if compliant, False if violations detected.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loudnessLufs rdf:type rdf:Property ;
    rdfs:label 'Loudness Lufs' ;
    rdfs:comment 'Measured integrated loudness level in LUFS (Loudness Units relative to Full Scale) per EBU R128 or ATSC A/85 standards. Target is typically -23 LUFS for broadcast.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:p1CriticalErrorCount rdf:type rdf:Property ;
    rdfs:label 'P1 Critical Error Count' ;
    rdfs:comment 'Number of P1 critical errors that prevent broadcast or distribution (e.g., audio dropout, video corruption, missing segments).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:p2MajorErrorCount rdf:type rdf:Property ;
    rdfs:label 'P2 Major Error Count' ;
    rdfs:comment 'Number of P2 major errors that significantly impact quality but may not prevent distribution (e.g., color grading inconsistencies, audio sync issues).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:p3MinorErrorCount rdf:type rdf:Property ;
    rdfs:label 'P3 Minor Error Count' ;
    rdfs:comment 'Number of P3 minor errors that have minimal impact on viewer experience (e.g., minor subtitle timing issues, cosmetic artifacts).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcPlatform rdf:type rdf:Property ;
    rdfs:label 'Qc Platform' ;
    rdfs:comment 'Name of the QC platform or tool used to perform the review (e.g., Dalet Galaxy QC module, Tektronix Sentry, Interra Baton).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcResult rdf:type rdf:Property ;
    rdfs:label 'Qc Result' ;
    rdfs:comment 'Overall result of the QC review: pass (no issues), fail (critical issues preventing distribution), conditional pass (minor issues requiring remediation), or pending review (awaiting final approval).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcType rdf:type rdf:Property ;
    rdfs:label 'Qc Type' ;
    rdfs:comment 'Type of quality control review performed: technical QC (video/audio quality), editorial QC (content accuracy), compliance QC (regulatory standards), accessibility QC (closed captions, audio description), loudness QC (EBU R128/ATSC A/85), or format QC (file format and codec validation).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reQcDate rdf:type rdf:Property ;
    rdfs:label 'Re Qc Date' ;
    rdfs:comment 'Date when the deliverable was re-reviewed after remediation. Null if no re-QC has been performed.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationNotes rdf:type rdf:Property ;
    rdfs:label 'Remediation Notes' ;
    rdfs:comment 'Detailed notes describing the remediation actions required to address identified errors and bring the deliverable into compliance.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Flag' ;
    rdfs:comment 'Indicates whether the deliverable requires remediation or correction before final approval. True if remediation needed, False if no action required.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date when the QC review was performed.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Review Duration Minutes' ;
    rdfs:comment 'Total duration of the QC review session in minutes.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review End Timestamp' ;
    rdfs:comment 'Timestamp when the QC operator completed the review session.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Business identifier for the QC review, typically formatted as a human-readable reference code.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Start Timestamp' ;
    rdfs:comment 'Timestamp when the QC operator began the review session.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle status of the QC review process.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalErrorCount rdf:type rdf:Property ;
    rdfs:label 'Total Error Count' ;
    rdfs:comment 'Total number of errors identified across all severity levels during the QC review.' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:videoCodec rdf:type rdf:Property ;
    rdfs:label 'Video Codec' ;
    rdfs:comment 'Video codec used in the deliverable (e.g., H.264, H.265/HEVC, ProRes, MPEG-2).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoFrameRate rdf:type rdf:Property ;
    rdfs:label 'Video Frame Rate' ;
    rdfs:comment 'Measured video frame rate (e.g., 23.976, 25, 29.97, 50, 59.94 fps).' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Primary key for milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predecessorMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Milestone Id' ;
    rdfs:comment 'Reference to another milestone that must be completed before this milestone can begin or be achieved.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Milestone .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'The date on which the milestone was actually achieved or completed. Null if milestone has not yet been reached.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or role of the individual or committee authorized to approve this milestone (e.g., Executive Producer, Network Executive, Showrunner).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether formal approval or sign-off is required before this milestone can be marked as achieved.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Approved baseline date for the milestone after initial project approval, used for variance tracking and performance measurement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Usd' ;
    rdfs:comment 'Estimated financial impact or cost associated with achieving this milestone, or cost of delay if milestone is missed.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Flag' ;
    rdfs:comment 'Indicates whether this milestone is on the critical path of the production schedule, meaning any delay directly impacts final delivery date.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dependencyCount rdf:type rdf:Property ;
    rdfs:label 'Dependency Count' ;
    rdfs:comment 'Number of other milestones or tasks that are dependent on the completion of this milestone.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'Current projected or estimated date for milestone completion based on latest production progress and risk assessment.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Human-readable name or title of the milestone event (e.g., Greenlight Approval, Picture Lock, Final Delivery).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current lifecycle status of the milestone indicating whether it is pending, on track, delayed, completed, or no longer applicable.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Categorical classification of the milestone within the production lifecycle. Defines the phase or gate this milestone represents. [ENUM-REF-CANDIDATE: greenlight|pre_production_start|principal_photography_start|principal_photography_end|picture_lock|audio_mix_complete|vfx_complete|color_grading_complete|final_qc_pass|delivery_to_broadcaster|archive_complete|post_production_start|rough_cut_complete|final_cut_complete|mastering_complete — promote to reference product]' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Mitigation Plan' ;
    rdfs:comment 'Description of actions or contingency plans in place to address identified risks and ensure milestone is achieved.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'Originally scheduled or target date for achieving this milestone as defined during production planning.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'The production department or functional area responsible for delivering this milestone. [ENUM-REF-CANDIDATE: production|post_production|vfx|audio|editorial|color|qc|delivery|archive|legal|finance — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed explanation of identified risks, issues, or blockers that may prevent timely achievement of this milestone.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessment of the risk that this milestone will not be achieved on time, based on current production status and known issues.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Notification Flag' ;
    rdfs:comment 'Indicates whether stakeholders (network executives, distributors, talent) must be notified when this milestone is achieved or at risk.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceDays rdf:type rdf:Property ;
    rdfs:label 'Variance Days' ;
    rdfs:comment 'Number of days difference between planned date and actual date (positive indicates delay, negative indicates early completion). Calculated field for reporting purposes.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Owner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Location owners and management companies are partners who lease filming locations. Linking enables tracking all locations managed by that partner, payment processing for location fees, permit coordina' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the production location including street number and name.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information such as suite, building, or unit number.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCampCapacity rdf:type rdf:Property ;
    rdfs:label 'Base Camp Capacity' ;
    rdfs:comment 'Number of trailers or mobile units that can be accommodated at the base camp area near the location for cast, crew, wardrobe, makeup, and catering.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the location is situated.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Total fee paid to the location owner or manager for the right to film at this location. Excludes additional costs such as permits, insurance, or restoration.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the location fee (e.g., USD, CAD, GBP, EUR).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Indicates whether the location owner requires specific production insurance coverage or certificates of insurance before filming can commence.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the location in decimal degrees format, used for mapping, navigation, and sunrise/sunset calculations.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Business identifier code for the location used in production schedules and call sheets. Typically assigned by the location manager or production coordinator.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name or title of the production location (e.g., \'Downtown Warehouse District\', \'Malibu Beach House\', \'Historic City Hall\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current lifecycle status of the location: scouted (identified by location scout), approved (approved for use by director/producer), contracted (agreement signed with owner), active (currently in use for shooting), wrapped (shooting completed), rejected (not suitable for production).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the location based on its physical characteristics and usage: practical interior (real indoor space), practical exterior (real outdoor space), backlot (studio-controlled outdoor set), remote (distant or hard-to-access site), international (foreign location), studio exterior (controlled outdoor studio space).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the location in decimal degrees format, used for mapping, navigation, and logistics planning.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerNotes rdf:type rdf:Property ;
    rdfs:label 'Manager Notes' ;
    rdfs:comment 'Free-text notes and observations from the location manager regarding access, restrictions, special requirements, or other relevant production considerations.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiseAssessment rdf:type rdf:Property ;
    rdfs:label 'Noise Assessment' ;
    rdfs:comment 'Assessment of ambient noise levels at the location: quiet (minimal background noise, suitable for dialogue recording), moderate (some noise, may require sound treatment), noisy (significant noise, requires ADR or sound mitigation), unacceptable (excessive noise, unsuitable for production).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Contact Email' ;
    rdfs:comment 'Primary email address for the location owner or authorized representative for contract and coordination communications.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Owner Contact Phone' ;
    rdfs:comment 'Primary phone number for the location owner or authorized representative for coordination and emergency contact during production.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingCapacity rdf:type rdf:Property ;
    rdfs:label 'Parking Capacity' ;
    rdfs:comment 'Number of vehicle parking spaces available at or near the location for crew, cast, and equipment trucks.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitAuthority rdf:type rdf:Property ;
    rdfs:label 'Permit Authority' ;
    rdfs:comment 'Name of the governmental or regulatory authority responsible for issuing filming permits for this location (e.g., \'Los Angeles Film Office\', \'NYC Mayor Office of Media and Entertainment\').' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Permit Expiry Date' ;
    rdfs:comment 'Date when the filming permit expires and is no longer valid for production use.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitIssueDate rdf:type rdf:Property ;
    rdfs:label 'Permit Issue Date' ;
    rdfs:comment 'Date when the filming permit was officially issued by the permitting authority.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'Official permit or authorization number issued by the permitting authority for filming at this location.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current status of filming permits required for this location: not required (no permit needed), pending (application submitted), approved (permit granted), denied (permit rejected), expired (permit validity lapsed).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the location address.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerAvailability rdf:type rdf:Property ;
    rdfs:label 'Power Availability' ;
    rdfs:comment 'Assessment of electrical power availability at the location: grid (connected to utility power), generator required (no grid power, generators needed), limited (some power available but insufficient for full production), none (no power infrastructure).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Broader geographic region or area classification (e.g., \'Southern California\', \'Pacific Northwest\', \'New England\') used for production planning and logistics.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restorationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Restoration Required Flag' ;
    rdfs:comment 'Indicates whether the production is contractually obligated to restore the location to its original condition after filming concludes.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restroomFacilities rdf:type rdf:Property ;
    rdfs:label 'Restroom Facilities' ;
    rdfs:comment 'Assessment of restroom availability: on site (permanent facilities available), portable required (portable restrooms must be brought in), nearby (facilities within walking distance), none (no facilities available).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Safety Assessment Date' ;
    rdfs:comment 'Date when the safety assessment was conducted by the production safety officer or third-party assessor.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Assessment Status' ;
    rdfs:comment 'Status of the safety and risk assessment conducted for this location: not assessed (no evaluation performed), in progress (assessment underway), passed (meets safety requirements), failed (does not meet safety standards), conditional (approved with specific safety measures required).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoutApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Scout Approval Status' ;
    rdfs:comment 'Approval status from the location scout assessment: pending (awaiting review), approved (meets production requirements), rejected (does not meet requirements), conditional (approved with specific conditions or modifications).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region of the location.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterAvailability rdf:type rdf:Property ;
    rdfs:label 'Water Availability' ;
    rdfs:comment 'Assessment of water access at the location: available (connected to water supply), limited (some water but insufficient for full crew), trucked in required (no water infrastructure, must be transported), none (no water access).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abrProfile rdf:type rdf:Property ;
    rdfs:label 'Abr Profile' ;
    rdfs:comment 'The adaptive bitrate streaming profile or ladder configuration associated with this format specification.' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioBitDepth rdf:type rdf:Property ;
    rdfs:label 'Audio Bit Depth' ;
    rdfs:comment 'The number of bits used to represent each audio sample (e.g., 16, 24, 32).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioConfiguration rdf:type rdf:Property ;
    rdfs:label 'Audio Configuration' ;
    rdfs:comment 'The audio channel layout and configuration for this format specification.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioSampleRateKhz rdf:type rdf:Property ;
    rdfs:label 'Audio Sample Rate Khz' ;
    rdfs:comment 'The audio sampling frequency in kilohertz (e.g., 48, 96, 192).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bitDepth rdf:type rdf:Property ;
    rdfs:label 'Bit Depth' ;
    rdfs:comment 'The number of bits used to represent color information per channel (e.g., 8, 10, 12, 16).' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chromaSubsampling rdf:type rdf:Property ;
    rdfs:label 'Chroma Subsampling' ;
    rdfs:comment 'The chroma subsampling scheme defining color resolution relative to luminance (e.g., 4:2:0, 4:2:2, 4:4:4).' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionStandard rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Standard' ;
    rdfs:comment 'The closed captioning or subtitle standard supported by this format (e.g., CEA-608, CEA-708, DVB Subtitles, TTML).' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorSpace rdf:type rdf:Property ;
    rdfs:label 'Color Space' ;
    rdfs:comment 'The color space standard defining the range and representation of colors in the video signal.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'List of regulatory or industry compliance requirements that this format specification satisfies (e.g., FCC broadcast standards, ATSC 3.0, DVB-T2).' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerFormat rdf:type rdf:Property ;
    rdfs:label 'Container Format' ;
    rdfs:comment 'The file container or wrapper format used to package video, audio, and metadata streams (e.g., MXF, MOV, MP4, TS).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletFormatProfileReference rdf:type rdf:Property ;
    rdfs:label 'Dalet Format Profile Reference' ;
    rdfs:comment 'The corresponding format profile identifier in Dalet Galaxy MAM system used for workflow orchestration and transcoding.' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmCompatibility rdf:type rdf:Property ;
    rdfs:label 'Drm Compatibility' ;
    rdfs:comment 'The DRM systems or encryption standards compatible with this format specification (e.g., Widevine, PlayReady, FairPlay).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeGb rdf:type rdf:Property ;
    rdfs:label 'File Size Gb' ;
    rdfs:comment 'The estimated or typical file size in gigabytes for content encoded in this format specification for a standard duration.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formatCode rdf:type rdf:Property ;
    rdfs:label 'Format Code' ;
    rdfs:comment 'Short alphanumeric code or identifier used to reference this format specification in production systems and workflows.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatName rdf:type rdf:Property ;
    rdfs:label 'Format Name' ;
    rdfs:comment 'Business name or label for this format specification (e.g., \'UHD 4K HDR10 Theatrical\', \'HD 1080p Broadcast Standard\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatStatus rdf:type rdf:Property ;
    rdfs:label 'Format Status' ;
    rdfs:comment 'The current lifecycle status of this format specification within the production environment.' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'Classification of the format specification by its intended use in the production workflow.' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameRate rdf:type rdf:Property ;
    rdfs:label 'Frame Rate' ;
    rdfs:comment 'The number of frames per second for this format specification (e.g., 23.976, 24, 25, 29.97, 30, 50, 59.94, 60).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hdrStandard rdf:type rdf:Property ;
    rdfs:label 'Hdr Standard' ;
    rdfs:comment 'The HDR standard applied to this format specification, or SDR if standard dynamic range.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultFormat rdf:type rdf:Property ;
    rdfs:label 'Is Default Format' ;
    rdfs:comment 'Boolean flag indicating whether this format specification is the default or recommended format for its type and resolution class.' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalNotes rdf:type rdf:Property ;
    rdfs:label 'Technical Notes' ;
    rdfs:comment 'Additional technical notes, specifications, or guidance for production teams using this format specification.' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timecodeFormat rdf:type rdf:Property ;
    rdfs:label 'Timecode Format' ;
    rdfs:comment 'The timecode standard and format used for frame-accurate synchronization and editing.' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoBitrateMbps rdf:type rdf:Property ;
    rdfs:label 'Video Bitrate Mbps' ;
    rdfs:comment 'The target or maximum video bitrate in megabits per second for this format specification.' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdnConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Cdn Configuration Id' ;
    rdfs:comment 'Foreign key linking to distribution.cdn_configuration. Business justification: An OTT platform is served by a primary CDN configuration that governs its content delivery infrastructure. The cdn_origin_url and cdn_provider STRING fields on ott_platform are denormalized CDN refere' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CdnConfiguration .

ind:licenseeSalesAccountId rdf:type rdf:Property ;
    rdfs:label 'Licensee Sales Account Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_account. Business justification: OTT platforms are licensed to enterprise customers and distribution partners tracked as sales accounts. Supports B2B platform licensing deals, white-label OTT agreements, and enterprise streaming serv' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesAccount .

ind:primarySegmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Segment Id' ;
    rdfs:comment 'Foreign key linking to audience.segment. Business justification: OTT platforms configure a primary audience activation segment for DAI targeting and personalization. The segment.is_dai_eligible flag is designed for this. Ad operations teams assign platform-level se' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:adobePropertyCode rdf:type rdf:Property ;
    rdfs:label 'Adobe Property Code' ;
    rdfs:comment 'The unique property identifier assigned to this OTT platform within Adobe Experience Platform (AEP) for audience data collection, segmentation, and personalization. Used to link platform-level engagement events to subscriber profiles and Nielsen cross-platform measurement.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arpu rdf:type rdf:Property ;
    rdfs:label 'Arpu' ;
    rdfs:comment 'Average monthly revenue generated per active subscriber on this platform, expressed in the platform\'s billing currency. Calculated at the platform level for strategic pricing and investor reporting. Confidential as a key financial performance indicator. Sourced from Zuora revenue recognition data.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseSubscriptionPrice rdf:type rdf:Property ;
    rdfs:label 'Base Subscription Price' ;
    rdfs:comment 'The standard monthly subscription price for this platform in the billing currency. Applicable for SVOD and HYBRID tiers. Null for AVOD and FAST platforms with no subscription fee. Used in Zuora plan configuration and financial forecasting in SAP S/4HANA.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrency rdf:type rdf:Property ;
    rdfs:label 'Billing Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the primary billing currency used on this platform (e.g., \'USD\', \'GBP\', \'EUR\'). Governs Zuora subscription plan pricing, SAP S/4HANA financial reconciliation, and multi-currency revenue reporting.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaCompliant rdf:type rdf:Property ;
    rdfs:label 'Coppa Compliant' ;
    rdfs:comment 'Indicates whether this platform is designated as COPPA-compliant, meaning it is directed at children under 13 and adheres to COPPA data collection restrictions. True = COPPA-compliant children\'s platform; False = general audience platform. Drives data collection policies in Adobe Experience Platform and ad targeting restrictions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daiProvider rdf:type rdf:Property ;
    rdfs:label 'Dai Provider' ;
    rdfs:comment 'The technology vendor or platform providing DAI services for this OTT platform (e.g., \'Google DAI\', \'FreeWheel\', \'Yospace\', \'Brightcove SSAI\'). Null if DAI is not enabled. Used for vendor management, SLA tracking, and ad revenue reconciliation.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgFeedUrl rdf:type rdf:Property ;
    rdfs:label 'Epg Feed Url' ;
    rdfs:comment 'The URL of the Electronic Program Guide data feed for this platform, used by third-party EPG aggregators, smart TV manufacturers, and vMVPD partners to display scheduling information. Null for pure VOD platforms without a linear schedule. Sourced from Ericsson MediaFirst playout system.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastChannelEnabled rdf:type rdf:Property ;
    rdfs:label 'Fast Channel Enabled' ;
    rdfs:comment 'Indicates whether this platform operates or hosts FAST channels — linear-style, ad-supported free streaming channels. True = FAST channel delivery active; False = no FAST channel. Relevant for FAST syndication partnerships and Wide Orbit ad scheduling.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeTrialDays rdf:type rdf:Property ;
    rdfs:label 'Free Trial Days' ;
    rdfs:comment 'Number of days in the free trial period offered to new subscribers on this platform. Zero or null if no free trial is offered. Configured in Zuora subscription plans and used in churn rate and LTV analysis.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether GDPR data protection obligations apply to this platform based on its geographic availability and subscriber base. True = GDPR applies (EU/EEA territories served); False = GDPR not applicable. Governs consent management, data subject rights workflows, and Adobe Experience Platform profile handling.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdrSupported rdf:type rdf:Property ;
    rdfs:label 'Hdr Supported' ;
    rdfs:comment 'Indicates whether the platform supports High Dynamic Range video delivery (HDR10, Dolby Vision, or HLG). True = HDR delivery supported; False = SDR only. Relevant for premium content licensing negotiations and CTV device compatibility.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxConcurrentStreams rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Streams' ;
    rdfs:comment 'The maximum number of simultaneous streams permitted per subscriber account on this platform. Enforced at the entitlement layer to prevent credential sharing and manage CDN bandwidth capacity. A key parameter in Zuora subscription plan configuration.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxDownloadDevices rdf:type rdf:Property ;
    rdfs:label 'Max Download Devices' ;
    rdfs:comment 'The maximum number of devices on which a subscriber may store downloaded content for offline viewing on this platform. Null if offline downloads are not supported. Governed by DRM policy and Rightsline windowing rules.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxVideoResolution rdf:type rdf:Property ;
    rdfs:label 'Max Video Resolution' ;
    rdfs:comment 'The highest video resolution tier supported for streaming on this platform. SD = Standard Definition (480p); HD = High Definition (720p); FHD = Full HD (1080p); 4K = Ultra HD (2160p); 8K = Super Hi-Vision (4320p). Drives ABR profile configuration, CDN bandwidth planning, and content ingest specifications in Dalet Galaxy.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvpdCarriageEligible rdf:type rdf:Property ;
    rdfs:label 'Mvpd Carriage Eligible' ;
    rdfs:comment 'Indicates whether this OTT platform\'s content or channels are eligible for carriage by MVPD or vMVPD partners (cable, satellite, virtual pay-TV operators). True = eligible for carriage agreements; False = direct-to-consumer only. Governs retransmission consent and must-carry negotiations.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentBrand rdf:type rdf:Property ;
    rdfs:label 'Parent Brand' ;
    rdfs:comment 'The overarching corporate or media brand under which this OTT platform operates (e.g., \'Media Broadcasting Group\', \'MB Sports Network\'). Supports brand hierarchy reporting, consolidated audience measurement, and multi-brand advertising sales in Salesforce Media Cloud.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformCode rdf:type rdf:Property ;
    rdfs:label 'Platform Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to the OTT platform (e.g., \'MB_SVOD_WEB\', \'MB_AVOD_CTV\'). Used in operational systems, contracts, and partner integrations as the canonical platform identifier. Maps to the platform identifier used in Zuora subscription plans and Akamai CDN configuration.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformDescription rdf:type rdf:Property ;
    rdfs:label 'Platform Description' ;
    rdfs:comment 'Detailed narrative description of the platform\'s content offering, target audience, and service proposition. Used in partner onboarding documentation, regulatory filings, and internal product catalogues.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Official commercial brand name of the OTT platform as presented to subscribers and partners (e.g., \'MediaBroadcast+\', \'MB Sports Live\'). Used in marketing materials, EPG listings, and subscriber-facing interfaces.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformStatus rdf:type rdf:Property ;
    rdfs:label 'Platform Status' ;
    rdfs:comment 'Current lifecycle state of the OTT platform. \'active\' = live and serving audiences; \'beta\' = limited release for testing; \'sunset\' = scheduled for decommission; \'suspended\' = temporarily offline; \'inactive\' = decommissioned. Governs whether the platform is eligible for new subscriber acquisition, ad campaign targeting, and CDN resource allocation.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryStreamingProtocol rdf:type rdf:Property ;
    rdfs:label 'Primary Streaming Protocol' ;
    rdfs:comment 'The primary adaptive bitrate streaming protocol used for content delivery on this platform. HLS = HTTP Live Streaming (Apple standard, widely supported); MPEG-DASH = Dynamic Adaptive Streaming over HTTP (ISO 23009 standard); RTMP = Real-Time Messaging Protocol (legacy live); SRT = Secure Reliable Transport (low-latency live). Drives CDN configuration in Akamai and player SDK selection.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTier rdf:type rdf:Property ;
    rdfs:label 'Service Tier' ;
    rdfs:comment 'Business model classification of the OTT platform. SVOD = Subscription Video On Demand (recurring fee, no ads); AVOD = Advertising-Supported Video On Demand (free with ads); TVOD = Transactional Video On Demand (pay-per-view); FAST = Free Ad-Supported Streaming Television (linear-style free channel); HYBRID = combination of tiers. Drives revenue recognition logic in Zuora and ad inventory management in Wide Orbit.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaUptimeTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Target Pct' ;
    rdfs:comment 'The contractually committed platform availability target expressed as a percentage (e.g., 99.95). Governs CDN SLA enforcement with Akamai, incident escalation thresholds, and operational reporting. Distinct from actual measured uptime.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriberCount rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count' ;
    rdfs:comment 'Current count of active paying or registered subscribers on this platform as of the last reconciliation cycle. A key operational metric for ARPU calculation, churn rate monitoring, and Zuora revenue reporting. Confidential as it represents commercially sensitive business performance data.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sunsetDate rdf:type rdf:Property ;
    rdfs:label 'Sunset Date' ;
    rdfs:comment 'Planned or actual date on which the OTT platform will be or was decommissioned. Null if the platform has no scheduled end-of-life. Used for subscriber migration planning, contract wind-down, and CDN resource deallocation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportedDeviceClasses rdf:type rdf:Property ;
    rdfs:label 'Supported Device Classes' ;
    rdfs:comment 'Comma-separated list of device categories supported by this platform (e.g., \'web,mobile,ctv,stb,gaming_console\'). Drives device compatibility testing, app store distribution, and audience reach reporting. [ENUM-REF-CANDIDATE: web|mobile|ctv|stb|gaming_console|smart_tv|tablet — promote to reference product]' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zuoraProductCode rdf:type rdf:Property ;
    rdfs:label 'Zuora Product Code' ;
    rdfs:comment 'The product identifier in Zuora\'s subscription billing platform corresponding to this OTT platform\'s subscription offering. Used for revenue recognition, invoice generation, and subscription lifecycle management. Links the platform master record to Zuora\'s billing product catalogue.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abrProfileDash rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Dash' ;
    rdfs:comment 'Indicates whether the device supports MPEG-DASH (Dynamic Adaptive Streaming over HTTP) adaptive bitrate streaming protocol.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:abrProfileHls rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Hls' ;
    rdfs:comment 'Indicates whether the device supports HLS (HTTP Live Streaming) adaptive bitrate streaming protocol.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:abrProfileSmooth rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Smooth' ;
    rdfs:comment 'Indicates whether the device supports Microsoft Smooth Streaming adaptive bitrate protocol.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activeInstallBase rdf:type rdf:Property ;
    rdfs:label 'Active Install Base' ;
    rdfs:comment 'Estimated number of active devices of this type currently accessing the OTT platform, used for capacity planning and analytics.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date when the device successfully completed OTT platform certification testing.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the device certification expires and requires re-certification for continued platform support.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current certification status of the device for OTT platform compatibility (certified, pending, failed, not_tested).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codecAudioSupport rdf:type rdf:Property ;
    rdfs:label 'Codec Audio Support' ;
    rdfs:comment 'List of audio codecs supported by the device (e.g., AAC, Dolby Digital, Dolby Atmos, DTS). Pipe-separated list.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codecVideoSupport rdf:type rdf:Property ;
    rdfs:label 'Codec Video Support' ;
    rdfs:comment 'List of video codecs supported by the device (e.g., H.264, H.265/HEVC, VP9, AV1). Pipe-separated list.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daiSupported rdf:type rdf:Property ;
    rdfs:label 'Dai Supported' ;
    rdfs:comment 'Indicates whether the device supports DAI (Dynamic Ad Insertion) for server-side ad stitching in streaming content.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceCategory rdf:type rdf:Property ;
    rdfs:label 'Device Category' ;
    rdfs:comment 'High-level classification of the device type (e.g., smart TV, mobile phone, tablet, desktop browser, streaming stick, gaming console, set-top box). [ENUM-REF-CANDIDATE: smart_tv|mobile_phone|tablet|desktop_browser|streaming_stick|gaming_console|set_top_box — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmFairplaySupported rdf:type rdf:Property ;
    rdfs:label 'Drm Fairplay Supported' ;
    rdfs:comment 'Indicates whether the device supports Apple FairPlay DRM for content protection.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmPlayreadySupported rdf:type rdf:Property ;
    rdfs:label 'Drm Playready Supported' ;
    rdfs:comment 'Indicates whether the device supports Microsoft PlayReady DRM for content protection.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmWidevineLevel rdf:type rdf:Property ;
    rdfs:label 'Drm Widevine Level' ;
    rdfs:comment 'Google Widevine DRM security level supported (L1 = hardware-backed, L2 = software-backed, L3 = software only, not_supported).' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formFactor rdf:type rdf:Property ;
    rdfs:label 'Form Factor' ;
    rdfs:comment 'Physical form factor of the device (handheld, television, desktop, wearable, embedded).' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdrCapable rdf:type rdf:Property ;
    rdfs:label 'Hdr Capable' ;
    rdfs:comment 'Indicates whether the device supports HDR (High Dynamic Range) video playback for enhanced color and contrast.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdrFormat rdf:type rdf:Property ;
    rdfs:label 'Hdr Format' ;
    rdfs:comment 'Specific HDR formats supported by the device (e.g., HDR10, HDR10+, Dolby Vision, HLG). Pipe-separated list if multiple formats are supported.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputMethod rdf:type rdf:Property ;
    rdfs:label 'Input Method' ;
    rdfs:comment 'Primary input method(s) supported by the device (e.g., touchscreen, remote_control, keyboard_mouse, voice, gamepad). Pipe-separated list if multiple.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this device type is currently active and supported for OTT platform streaming.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the device manufacturer or brand (e.g., Samsung, Apple, Roku, Amazon, LG, Sony).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBitrateMbps rdf:type rdf:Property ;
    rdfs:label 'Max Bitrate Mbps' ;
    rdfs:comment 'Maximum streaming bitrate supported by the device in megabits per second (Mbps), used for ABR profile selection and QoS (Quality of Service) optimization.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Specific model name or identifier assigned by the manufacturer (e.g., Galaxy S21, iPhone 13 Pro, Fire TV Stick 4K).' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Technical model number or SKU (Stock Keeping Unit) used for precise device identification and inventory tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCapability rdf:type rdf:Property ;
    rdfs:label 'Network Capability' ;
    rdfs:comment 'Network connectivity capabilities of the device (e.g., wifi, ethernet, cellular_4g, cellular_5g). Pipe-separated list if multiple.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osFamily rdf:type rdf:Property ;
    rdfs:label 'Os Family' ;
    rdfs:comment 'Operating system family running on the device (e.g., Android, iOS, tvOS, webOS, Tizen, Roku OS, Fire OS, Windows, macOS, Linux, PlayStation, Xbox). [ENUM-REF-CANDIDATE: android|ios|tvos|webos|tizen|roku_os|fire_os|windows|macos|linux|playstation|xbox — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osVersionMax rdf:type rdf:Property ;
    rdfs:label 'Os Version Max' ;
    rdfs:comment 'Maximum OS version tested and certified for compatibility. Null indicates no upper bound.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osVersionMin rdf:type rdf:Property ;
    rdfs:label 'Os Version Min' ;
    rdfs:comment 'Minimum OS version required for OTT (Over-The-Top) platform compatibility and playback support.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosTier rdf:type rdf:Property ;
    rdfs:label 'Qos Tier' ;
    rdfs:comment 'QoS tier assigned to the device type for streaming quality segmentation and CDN (Content Delivery Network) routing (premium, standard, basic).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenResolutionClass rdf:type rdf:Property ;
    rdfs:label 'Screen Resolution Class' ;
    rdfs:comment 'Display resolution category supported by the device (SD, HD, Full HD, 4K UHD (Ultra High Definition), 8K UHD).' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportEndDate rdf:type rdf:Property ;
    rdfs:label 'Support End Date' ;
    rdfs:comment 'Date when platform support for this device type will be discontinued, after which playback may no longer be guaranteed.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:userAgentString rdf:type rdf:Property ;
    rdfs:label 'User Agent String' ;
    rdfs:comment 'Standard HTTP user agent string reported by the device, used for device detection and analytics.' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failoverEndpointId rdf:type rdf:Property ;
    rdfs:label 'Failover Endpoint Id' ;
    rdfs:comment 'Reference to the backup streaming endpoint that should be used if this endpoint becomes unavailable. Supports high availability and disaster recovery.' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StreamingEndpoint .

ind:activatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activated Timestamp' ;
    rdfs:comment 'The date and time when this endpoint was first activated and began serving live traffic.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bandwidthLimitGbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Limit Gbps' ;
    rdfs:comment 'Maximum aggregate bandwidth capacity in gigabits per second allocated to this endpoint. Used for capacity planning and cost management.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cacheTtlSeconds rdf:type rdf:Property ;
    rdfs:label 'Cache Ttl Seconds' ;
    rdfs:comment 'The duration in seconds that content should be cached at edge locations before refreshing from origin. Balances freshness with CDN efficiency.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPerGb rdf:type rdf:Property ;
    rdfs:label 'Cost Per Gb' ;
    rdfs:comment 'The CDN provider\'s charge per gigabyte of data transferred through this endpoint. Used for cost allocation and financial forecasting.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deactivatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivated Timestamp' ;
    rdfs:comment 'The date and time when this endpoint was deactivated or taken out of service. Null if currently active.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:drmLicenseServerUrl rdf:type rdf:Property ;
    rdfs:label 'Drm License Server Url' ;
    rdfs:comment 'URL of the DRM license server that provides decryption keys and enforces content protection policies for this endpoint. Critical for securing premium content.' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointName rdf:type rdf:Property ;
    rdfs:label 'Endpoint Name' ;
    rdfs:comment 'Human-readable name or label for the streaming endpoint, used for identification and operational reference.' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointType rdf:type rdf:Property ;
    rdfs:label 'Endpoint Type' ;
    rdfs:comment 'Classification of the endpoint role within the CDN architecture. Origin endpoints serve as the source, edge endpoints serve end users, and backup endpoints provide failover capability.' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointUrl rdf:type rdf:Property ;
    rdfs:label 'Endpoint Url' ;
    rdfs:comment 'The full URL address of the streaming endpoint, including protocol, domain, and path. This is the technical delivery address for the stream.' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRestrictionMode rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Mode' ;
    rdfs:comment 'Defines whether geo_restriction_rules represent an allow list (whitelist) or deny list (blacklist) for content delivery.' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRestrictionRules rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Rules' ;
    rdfs:comment 'Comma-separated list of ISO country codes or regions where content delivery is allowed or blocked. Enforces territorial licensing and rights management requirements.' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthCheckIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Health Check Interval Seconds' ;
    rdfs:comment 'Frequency in seconds at which automated health checks are performed against this endpoint.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:healthCheckUrl rdf:type rdf:Property ;
    rdfs:label 'Health Check Url' ;
    rdfs:comment 'URL endpoint used for automated health monitoring and availability checks. Returns status codes indicating endpoint health.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipv6Enabled rdf:type rdf:Property ;
    rdfs:label 'Ipv6 Enabled' ;
    rdfs:comment 'Indicates whether this endpoint supports IPv6 addressing in addition to IPv4, enabling delivery to modern network infrastructures.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastHealthCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Health Check Timestamp' ;
    rdfs:comment 'The date and time of the most recent successful health check performed on this endpoint.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manifestFormat rdf:type rdf:Property ;
    rdfs:label 'Manifest Format' ;
    rdfs:comment 'The streaming manifest file format used by this endpoint. m3u8 for HLS, mpd for MPEG-DASH, ism for Smooth Streaming, f4m for Adobe HDS.' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the streaming endpoint. Active endpoints are serving traffic; inactive endpoints are provisioned but not in use; maintenance indicates scheduled downtime.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionedDate rdf:type rdf:Property ;
    rdfs:label 'Provisioned Date' ;
    rdfs:comment 'The date when this streaming endpoint was initially provisioned and configured in the CDN infrastructure.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaUptimeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Target Percent' ;
    rdfs:comment 'The contractual uptime percentage target for this endpoint (e.g., 99.99%). Used for SLA compliance monitoring and vendor accountability.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sslCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Ssl Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the SSL/TLS certificate securing this endpoint. Critical for maintaining secure HTTPS delivery and avoiding service disruptions.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportedDevices rdf:type rdf:Property ;
    rdfs:label 'Supported Devices' ;
    rdfs:comment 'Comma-separated list of device types or platforms that this endpoint is optimized to serve (e.g., iOS, Android, Smart TV, Web Browser, Set-Top Box).' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenAuthenticationScheme rdf:type rdf:Property ;
    rdfs:label 'Token Authentication Scheme' ;
    rdfs:comment 'The authentication mechanism used to secure access to the endpoint. Prevents unauthorized access and hotlinking through cryptographic token validation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Audio Bitrate Kbps' ;
    rdfs:comment 'Audio bitrate in kilobits per second (e.g., 128, 192, 256). Defines audio quality.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioChannelConfig rdf:type rdf:Property ;
    rdfs:label 'Audio Channel Config' ;
    rdfs:comment 'Audio channel layout (mono, stereo, 5.1 surround, 7.1 surround, Dolby Atmos). Defines spatial audio configuration.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnOptimizationFlag rdf:type rdf:Property ;
    rdfs:label 'Cdn Optimization Flag' ;
    rdfs:comment 'Indicates whether the profile is optimized for CDN delivery with caching-friendly segment naming and structure. True if CDN-optimized; false otherwise.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Drm Support Flag' ;
    rdfs:comment 'Indicates whether the profile supports DRM encryption. True if DRM is enabled; false otherwise.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmSystem rdf:type rdf:Property ;
    rdfs:label 'Drm System' ;
    rdfs:comment 'DRM system(s) supported by this profile (Widevine, PlayReady, FairPlay Streaming, Multi-DRM). Null if DRM is not enabled.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date when the ABR profile became active and available for use in production encoding workflows.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:encodingPreset rdf:type rdf:Property ;
    rdfs:label 'Encoding Preset' ;
    rdfs:comment 'Encoder speed/quality preset (fast, medium, slow, veryslow). Slower presets yield better compression but require more processing time.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date when the ABR profile is scheduled to be deprecated or retired. Null for profiles with no planned end date.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hdrSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Hdr Support Flag' ;
    rdfs:comment 'Indicates whether the profile supports HDR (High Dynamic Range) video. True if HDR is enabled; false for SDR (Standard Dynamic Range) only.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyframeIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Keyframe Interval Seconds' ;
    rdfs:comment 'Interval between keyframes (I-frames) in seconds. Aligns with segment duration for seamless ABR switching.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manifestTemplateReference rdf:type rdf:Property ;
    rdfs:label 'Manifest Template Reference' ;
    rdfs:comment 'Reference to the MPEG-DASH MPD or HLS M3U8 manifest template used for this profile. Defines playlist structure and metadata.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Max Bitrate Kbps' ;
    rdfs:comment 'Highest video bitrate in kilobits per second across all renditions in the ladder. Used for high-quality streaming on fast connections.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxResolution rdf:type rdf:Property ;
    rdfs:label 'Max Resolution' ;
    rdfs:comment 'Highest video resolution in the ladder (e.g., \'1920x1080\', \'3840x2160\'). Defines the top quality tier.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Min Bitrate Kbps' ;
    rdfs:comment 'Lowest video bitrate in kilobits per second across all renditions in the ladder. Used for low-bandwidth scenarios.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minResolution rdf:type rdf:Property ;
    rdfs:label 'Min Resolution' ;
    rdfs:comment 'Lowest video resolution in the ladder (e.g., \'320x180\', \'640x360\'). Typically used for mobile or constrained bandwidth.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Unique business identifier code for the ABR profile used in transcode job requests and CDN configuration.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileDescription rdf:type rdf:Property ;
    rdfs:label 'Profile Description' ;
    rdfs:comment 'Detailed description of the ABR profile, including use cases, target audience, and technical notes.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable name of the ABR profile (e.g., \'Premium 4K HDR\', \'Standard HD\', \'Mobile Optimized\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renditionCount rdf:type rdf:Property ;
    rdfs:label 'Rendition Count' ;
    rdfs:comment 'Total number of video renditions (bitrate/resolution variants) in the ABR ladder. Typical range is 3-10 renditions.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Segment Duration Seconds' ;
    rdfs:comment 'Duration of each media segment in seconds (e.g., 2, 4, 6, 10). Shorter segments enable faster ABR switching but increase overhead.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetDeviceClass rdf:type rdf:Property ;
    rdfs:label 'Target Device Class' ;
    rdfs:comment 'Primary device class this profile is optimized for (mobile, tablet, desktop, smart TV, set-top box, gaming console). Influences resolution and bitrate choices.' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Foreign key linking to billing.payment. Business justification: TVOD and PPV playback sessions are authorized by a specific payment. Customer service and fraud operations require direct session-to-payment linkage to verify purchase authorization, process refunds f' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:primaryPlaybackDeviceDeviceTypeId rdf:type rdf:Property ;
    rdfs:label 'Primary Playback Device Device Type Id' ;
    rdfs:comment 'Reference to the device used for this playback session. Enables device-level analytics and QoS (Quality of Service) monitoring.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceType .

ind:revenueRecognitionEventId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Event Id' ;
    rdfs:comment 'Foreign key linking to finance.revenue_recognition_event. Business justification: TVOD and PVOD playback sessions trigger individual revenue recognition events under ASC 606. Finance requires session-to-recognition-event traceability for transactional revenue recognition, audit com' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognitionEvent .

ind:rightsContentWindowId rdf:type rdf:Property ;
    rdfs:label 'Rights Content Window Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_content_window. Business justification: Playback sessions occur within specific rights content windows. This FK enables usage cap enforcement (rights_content_window.usage_cap_units), royalty calculation per window, and rights compliance rep' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsContentWindow .

ind:adBreaksServedCount rdf:type rdf:Property ;
    rdfs:label 'Ad Breaks Served Count' ;
    rdfs:comment 'Number of ad breaks (ad pods) served during this playback session. Used for advertising inventory management and revenue reconciliation.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioLanguage rdf:type rdf:Property ;
    rdfs:label 'Audio Language' ;
    rdfs:comment 'ISO 639 language code for the audio track selected by the viewer. Supports multi-language content analytics and localization strategy.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Average Bitrate Kbps' ;
    rdfs:comment 'Average streaming bitrate in kilobits per second during the session. Indicates video quality delivered and network performance.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdnPopLocation rdf:type rdf:Property ;
    rdfs:label 'Cdn Pop Location' ;
    rdfs:comment 'Geographic location identifier of the CDN point of presence that served this session. Critical for CDN performance optimization and SLA monitoring.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionsEnabled rdf:type rdf:Property ;
    rdfs:label 'Closed Captions Enabled' ;
    rdfs:comment 'Indicates whether closed captions were enabled during the session. Critical for accessibility compliance reporting and user preference analysis.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of content watched relative to total content duration. Key engagement metric for content performance and recommendation algorithms.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Technical error code if the session ended due to an error. Enables root cause analysis and platform stability monitoring.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitReason rdf:type rdf:Property ;
    rdfs:label 'Exit Reason' ;
    rdfs:comment 'The reason the playback session ended. Critical for distinguishing intentional exits from technical failures and optimizing viewer experience.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCity rdf:type rdf:Property ;
    rdfs:label 'Geographic City' ;
    rdfs:comment 'City where the viewer is located during playback. Enables hyper-local audience analytics and targeted advertising campaigns.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicPostalCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Postal Code' ;
    rdfs:comment 'Postal code derived from viewer location. Used for demographic overlay and targeted advertising. Subject to privacy regulations.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialBufferingDurationMs rdf:type rdf:Property ;
    rdfs:label 'Initial Buffering Duration Ms' ;
    rdfs:comment 'Time in milliseconds from session start until playback began. Key QoS metric for measuring time-to-first-frame and viewer experience.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playbackMode rdf:type rdf:Property ;
    rdfs:label 'Playback Mode' ;
    rdfs:comment 'The mode of content consumption: live linear broadcast, VOD (Video On Demand), DVR (time-shifted), or restart. Critical for audience measurement methodology and rights management.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebufferingEventsCount rdf:type rdf:Property ;
    rdfs:label 'Rebuffering Events Count' ;
    rdfs:comment 'Number of rebuffering (stalling) events that occurred during the session. Critical QoS metric for viewer experience and churn prediction.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Created Timestamp' ;
    rdfs:comment 'Timestamp when this playback session record was created in the system. Used for data lineage and operational monitoring.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session End Timestamp' ;
    rdfs:comment 'Precise timestamp when the playback session ended. Used to calculate total watch duration and session completion metrics.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the viewer initiated the playback session. Critical for audience measurement, daypart analysis, and concurrent viewer calculations.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Updated Timestamp' ;
    rdfs:comment 'Timestamp when this playback session record was last updated. Supports audit trail and data quality monitoring.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subtitleLanguage rdf:type rdf:Property ;
    rdfs:label 'Subtitle Language' ;
    rdfs:comment 'ISO 639 language code for subtitles displayed during the session. Null if no subtitles were enabled. Supports accessibility and localization analytics.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAdDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Ad Duration Seconds' ;
    rdfs:comment 'Cumulative duration of all advertisements served during the session. Essential for advertising billing and viewer experience analysis.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRebufferingDurationMs rdf:type rdf:Property ;
    rdfs:label 'Total Rebuffering Duration Ms' ;
    rdfs:comment 'Cumulative time in milliseconds spent in rebuffering state during the session. Complements rebuffering count for comprehensive QoS analysis.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalWatchDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Watch Duration Seconds' ;
    rdfs:comment 'Total time in seconds the viewer actively watched content during this session. Primary metric for audience measurement and content engagement analysis.' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:viewerIpAddress rdf:type rdf:Property ;
    rdfs:label 'Viewer Ip Address' ;
    rdfs:comment 'IP address of the viewer during the playback session. Used for geographic analysis, fraud detection, and blackout enforcement. Subject to GDPR and CCPA privacy regulations.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abrProfileCompatibility rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Compatibility' ;
    rdfs:comment 'Comma-separated list of ABR streaming profiles this DAI configuration is compatible with (e.g., HLS, MPEG-DASH, Smooth Streaming).' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adDecisionServerUrl rdf:type rdf:Property ;
    rdfs:label 'Ad Decision Server Url' ;
    rdfs:comment 'Endpoint URL for the Ad Decision Server that determines which ads to serve based on targeting criteria and inventory availability.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adFormatSupport rdf:type rdf:Property ;
    rdfs:label 'Ad Format Support' ;
    rdfs:comment 'Comma-separated list of supported ad formats for this configuration (e.g., VAST, VMAP, VPAID, SIMID).' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adPodPlacementRules rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Placement Rules' ;
    rdfs:comment 'Business rules defining where ad pods (groups of ads in a break) can be inserted within the content, including pre-roll, mid-roll, and post-roll positions.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adServerTimeoutMilliseconds rdf:type rdf:Property ;
    rdfs:label 'Ad Server Timeout Milliseconds' ;
    rdfs:comment 'Maximum time in milliseconds to wait for a response from the ad decision server before triggering fallback logic.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backupAdServerUrl rdf:type rdf:Property ;
    rdfs:label 'Backup Ad Server Url' ;
    rdfs:comment 'Failover endpoint URL for ad decision requests when the primary ad server is unavailable or times out.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutOverrideEnabled rdf:type rdf:Property ;
    rdfs:label 'Blackout Override Enabled' ;
    rdfs:comment 'Indicates whether this DAI configuration can override geographic blackout restrictions for ad insertion purposes.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdnIntegrationMode rdf:type rdf:Property ;
    rdfs:label 'Cdn Integration Mode' ;
    rdfs:comment 'How the DAI system integrates with the CDN: direct (CDN serves pre-stitched streams), proxied (DAI proxies through CDN), or edge decisioning (ad decisions at CDN edge).' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companionAdsEnabled rdf:type rdf:Property ;
    rdfs:label 'Companion Ads Enabled' ;
    rdfs:comment 'Indicates whether companion banner ads are displayed alongside video ads to enhance engagement and click-through rates.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configurationCode rdf:type rdf:Property ;
    rdfs:label 'Configuration Code' ;
    rdfs:comment 'Unique alphanumeric code identifying this DAI configuration across systems and platforms.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationName rdf:type rdf:Property ;
    rdfs:label 'Configuration Name' ;
    rdfs:comment 'Human-readable name for this DAI configuration, used for identification and reference by operations teams.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Current lifecycle status of this DAI configuration: active (in production use), inactive (not in use), testing (under validation), or deprecated (scheduled for removal).' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationVersion rdf:type rdf:Property ;
    rdfs:label 'Configuration Version' ;
    rdfs:comment 'Version number of this configuration, incremented with each modification to support change tracking and rollback capabilities.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceTargetingEnabled rdf:type rdf:Property ;
    rdfs:label 'Device Targeting Enabled' ;
    rdfs:comment 'Indicates whether device-specific targeting is enabled to serve ads optimized for the viewers device type (mobile, tablet, TV, desktop).' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmEnforcementMode rdf:type rdf:Property ;
    rdfs:label 'Drm Enforcement Mode' ;
    rdfs:comment 'Level of DRM enforcement applied to ad content: strict (full encryption), lenient (selective protection), or disabled (no DRM on ads).' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackCreativeStrategy rdf:type rdf:Property ;
    rdfs:label 'Fallback Creative Strategy' ;
    rdfs:comment 'Strategy for handling unfilled ad inventory: display house ads, show slate/filler, continue content, or repeat the last served ad.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRateTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Target Percentage' ;
    rdfs:comment 'Target percentage of available ad inventory that should be filled with paid advertisements, used to measure monetization effectiveness.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyCapEnabled rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Enabled' ;
    rdfs:comment 'Indicates whether frequency capping is enforced to limit the number of times a viewer sees the same ad within a session or time period.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geoTargetingEnabled rdf:type rdf:Property ;
    rdfs:label 'Geo Targeting Enabled' ;
    rdfs:comment 'Indicates whether geographic targeting is enabled to serve location-specific ads based on viewer IP address or device location.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxAdPodDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Max Ad Pod Duration Seconds' ;
    rdfs:comment 'Maximum allowed duration in seconds for a single ad pod insertion, ensuring viewer experience and regulatory compliance.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxImpressionsPerHour rdf:type rdf:Property ;
    rdfs:label 'Max Impressions Per Hour' ;
    rdfs:comment 'Maximum number of times the same ad creative can be shown to a viewer within a one-hour period when frequency capping is enabled.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxImpressionsPerSession rdf:type rdf:Property ;
    rdfs:label 'Max Impressions Per Session' ;
    rdfs:comment 'Maximum number of times the same ad creative can be shown to a viewer within a single viewing session when frequency capping is enabled.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minAdPodDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Min Ad Pod Duration Seconds' ;
    rdfs:comment 'Minimum required duration in seconds for an ad pod to be considered valid for insertion.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the user who last modified this DAI configuration record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Numeric priority level used to resolve conflicts when multiple DAI configurations could apply to the same content. Higher values indicate higher priority.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scte35SignalHandling rdf:type rdf:Property ;
    rdfs:label 'Scte35 Signal Handling' ;
    rdfs:comment 'How SCTE-35 cue markers embedded in the content stream are processed: enabled (parse and act), disabled (ignore), or passthrough (forward without processing).' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stitchingMode rdf:type rdf:Property ;
    rdfs:label 'Stitching Mode' ;
    rdfs:comment 'Method used to insert ads into the content stream: server-side stitching (SSAI), client-side stitching (CSAI), or hybrid approach combining both.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingEventsEnabled rdf:type rdf:Property ;
    rdfs:label 'Tracking Events Enabled' ;
    rdfs:comment 'Indicates whether ad tracking events (impressions, quartiles, completions, clicks) are captured and reported to measurement systems.' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountManagerRepId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: Each distribution partner (MVPD, vMVPD, OTT aggregator) has an assigned account manager/sales rep responsible for the commercial relationship. Role-prefixed \'account_manager_rep_id\' distinguishes from' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:assignedSalesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_territory. Business justification: Distribution partners (MVPDs, cable operators, streaming aggregators) are assigned to sales territories for account management. Supports territory-based partner relationship management, quota allocati' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTerritory .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: MVPDs and distribution partners must file retransmission consent elections and must-carry notifications with the FCC. Linking distribution_partner to its governing regulatory_filing is essential for r' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:salesAccountId rdf:type rdf:Property ;
    rdfs:label 'Sales Account Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_account. Business justification: Distribution partners (MVPDs, vMVPDs, OTT aggregators) are managed as sales accounts in CRM. Linking enables account-level revenue attribution, credit management, and unified commercial relationship t' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesAccount .

ind:abrProfileSupport rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Support' ;
    rdfs:comment 'Description of Adaptive Bitrate streaming profiles and quality tiers supported by the distribution partner for OTT and streaming delivery. Includes resolution ranges, bitrate ladders, and codec support.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Blackout Capability Flag' ;
    rdfs:comment 'Indicates whether the distribution partner has technical capability to enforce geographic broadcast restrictions and content blackouts based on licensing and rights windows.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageCapacityChannels rdf:type rdf:Property ;
    rdfs:label 'Carriage Capacity Channels' ;
    rdfs:comment 'Number of linear channels or content streams that the distribution partner has capacity to carry simultaneously. Relevant for MVPD, vMVPD, and cable operators.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carriageFeeModel rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Model' ;
    rdfs:comment 'Commercial model for carriage fees paid by or to the distribution partner. Per Subscriber indicates fees based on subscriber count, Flat Rate indicates fixed periodic payment, Revenue Share indicates percentage of advertising or subscription revenue, Hybrid indicates combination of models.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnProvider rdf:type rdf:Property ;
    rdfs:label 'Cdn Provider' ;
    rdfs:comment 'Name of the Content Delivery Network provider used by the distribution partner for content streaming and delivery. May include Akamai, Cloudflare, AWS CloudFront, or partner-owned CDN infrastructure.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Date when the current distribution agreement with the partner expires or is scheduled for renewal. Null indicates open-ended or evergreen agreement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractRenewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Notice Days' ;
    rdfs:comment 'Number of days advance notice required for contract renewal or termination as specified in the distribution agreement.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Date when the current distribution agreement with the partner became effective.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daiSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Dai Support Flag' ;
    rdfs:comment 'Indicates whether the distribution partner supports Dynamic Ad Insertion technology for server-side ad stitching in streaming content.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmCapability rdf:type rdf:Property ;
    rdfs:label 'Drm Capability' ;
    rdfs:comment 'Digital Rights Management systems and encryption standards supported by the distribution partner. May include Widevine, FairPlay, PlayReady, and other DRM technologies.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Physical address of the distribution partner\'s corporate headquarters or primary business location.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the distribution partner\'s headquarters is located.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the country where the distribution partner\'s headquarters is located.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the distribution partner\'s headquarters location.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State, province, or administrative region where the distribution partner\'s headquarters is located.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Must Carry Obligation Flag' ;
    rdfs:comment 'Indicates whether the distribution partner has a must-carry obligation requiring mandatory inclusion of certain broadcast channels under FCC regulations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerTier rdf:type rdf:Property ;
    rdfs:label 'Partner Tier' ;
    rdfs:comment 'Strategic classification of the partner based on reach, revenue contribution, and business importance. Tier 1 represents largest national/international partners, Tier 2 represents regional significant partners, Tier 3 represents local or niche partners.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the distribution partner based on delivery model. MVPD (Multichannel Video Programming Distributor) includes traditional cable, satellite, and telco providers. vMVPD (Virtual MVPD) includes internet-based multichannel services. OTT Platform includes direct-to-consumer streaming services. FAST Aggregator includes Free Ad-Supported Streaming Television channel aggregators. Syndication Outlet includes broadcast stations and regional networks.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Standard payment terms in days for invoices related to carriage fees, revenue share, or other financial transactions with the distribution partner.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portalUrl rdf:type rdf:Property ;
    rdfs:label 'Portal Url' ;
    rdfs:comment 'Web URL for the distribution partner\'s business portal, technical documentation, or partner management system.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for financial transactions and reporting with this distribution partner.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary business contact for distribution operations, technical coordination, and business communications.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the distribution partner organization for operational coordination and escalation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary telephone number for reaching the distribution partner contact for urgent operational matters and coordination.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosMonitoringEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Qos Monitoring Enabled Flag' ;
    rdfs:comment 'Indicates whether active Quality of Service monitoring and reporting is enabled for content delivery through this distribution partner.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current state of the commercial relationship and content distribution agreement with the partner.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Status' ;
    rdfs:comment 'Status of retransmission consent authorization allowing the distribution partner to rebroadcast content. Relevant for MVPD and cable operators under FCC regulations.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaLatencyTargetMs rdf:type rdf:Property ;
    rdfs:label 'Sla Latency Target Ms' ;
    rdfs:comment 'Maximum acceptable latency in milliseconds for content delivery as defined in the distribution Service Level Agreement. Critical for live streaming and low-latency applications.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriberReachEstimate rdf:type rdf:Property ;
    rdfs:label 'Subscriber Reach Estimate' ;
    rdfs:comment 'Estimated number of subscribers, households, or unique users that can access content through this distribution partner. Used for reach analysis and revenue forecasting.' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carriageAgreementId rdf:type rdf:Property ;
    rdfs:label 'Carriage Agreement Id' ;
    rdfs:comment 'Unique identifier for the carriage agreement record. Primary key.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarriageAgreement .

ind:assignedSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: Carriage agreements are managed by assigned sales reps who negotiate terms and maintain partner relationships. Critical for rep commission calculation on carriage fees, account ownership tracking, and' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:billingCycleId rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Id' ;
    rdfs:comment 'Foreign key linking to billing.cycle. Business justification: Carriage agreements specify billing frequency (monthly, quarterly) for carriage fees. Linking to billing.cycle enables automated billing run scheduling and proration calculations. Media distribution f' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cycle .

ind:holdbackId rdf:type rdf:Property ;
    rdfs:label 'Holdback Id' ;
    rdfs:comment 'Foreign key linking to rights.holdback. Business justification: Carriage agreements must respect holdback restrictions that may block specific content from being carried. Direct FK enables automated holdback enforcement during carriage agreement activation and pro' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holdback .

ind:packageId rdf:type rdf:Property ;
    rdfs:label 'Package Id' ;
    rdfs:comment 'Foreign key linking to content.package. Business justification: Carriage agreements carry content packages (bundles of channels/titles) to distribution partners. carriage_agreement has channel_id but no package_id; package_id links a carriage deal to the content p' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the carriage agreement: draft (being prepared), active (in force), suspended (temporarily paused), expired (term ended), terminated (cancelled before expiry), or under negotiation (renewal or amendment in progress).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the carriage agreement: retransmission consent (FCC-regulated authorization for MVPDs to rebroadcast OTA signals), must-carry (mandatory carriage under FCC rules), voluntary carriage (negotiated carriage without must-carry obligation), or platform carriage (OTT/vMVPD distribution agreement).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the agreement automatically renews at the end of the term unless either party provides termination notice.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutProvisions rdf:type rdf:Property ;
    rdfs:label 'Blackout Provisions' ;
    rdfs:comment 'Geographic or temporal restrictions on content availability, such as sports blackout rules, local market exclusions, or event-specific restrictions required by rights holders or league rules.' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Amount' ;
    rdfs:comment 'Monetary compensation paid by the distribution partner to the content provider for the right to carry the channel or content package. May be per-subscriber, flat fee, or tiered based on subscriber count.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carriageFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the carriage fee amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeStructure rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Structure' ;
    rdfs:comment 'Pricing model for the carriage fee: per-subscriber (fee per active subscriber), flat monthly (fixed monthly payment), tiered (rate varies by subscriber volume), revenue share (percentage of ad or subscription revenue), or barter (non-cash compensation such as promotional commitments or channel positioning).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelNumberAssignment rdf:type rdf:Property ;
    rdfs:label 'Channel Number Assignment' ;
    rdfs:comment 'The channel number or dial position assigned to the channel on the distribution platform. May vary by market or headend.' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPositioningTier rdf:type rdf:Property ;
    rdfs:label 'Channel Positioning Tier' ;
    rdfs:comment 'The service tier or package in which the channel is positioned (e.g., basic, expanded basic, premium, sports tier). Affects channel visibility and subscriber reach.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationTerms rdf:type rdf:Property ;
    rdfs:label 'Compensation Terms' ;
    rdfs:comment 'Detailed description of all compensation provided under the agreement, including cash payments, barter arrangements (e.g., promotional commitments, ad inventory exchange), channel carriage reciprocity, or other non-monetary considerations.' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Agreed method for resolving disputes arising under the agreement: arbitration (binding third-party decision), mediation (facilitated negotiation), litigation (court proceedings), or negotiation (direct party-to-party resolution).' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmRequirements rdf:type rdf:Property ;
    rdfs:label 'Drm Requirements' ;
    rdfs:comment 'DRM and content protection requirements mandated under the agreement, such as encryption standards, conditional access systems, watermarking, and anti-piracy measures.' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityWindow rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Window' ;
    rdfs:comment 'Period during which the distribution partner has exclusive carriage rights within a defined geographic territory or platform category (e.g., exclusive MVPD rights in a DMA, exclusive vMVPD rights nationally).' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction and governing law applicable to the agreement (e.g., State of New York, England and Wales). Determines which courts and laws apply in case of dispute.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackRestrictions rdf:type rdf:Property ;
    rdfs:label 'Holdback Restrictions' ;
    rdfs:comment 'Restrictions on when or where content may be made available on other platforms or windows. Protects the distribution partners investment by limiting competing distribution during the agreement term.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or modification to the carriage agreement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumSubscriberGuarantee rdf:type rdf:Property ;
    rdfs:label 'Minimum Subscriber Guarantee' ;
    rdfs:comment 'Minimum number of subscribers the distribution partner guarantees to deliver for the channel. Used in per-subscriber fee calculations and performance commitments.' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mustCarryElection rdf:type rdf:Property ;
    rdfs:label 'Must Carry Election' ;
    rdfs:comment 'Indicates whether the broadcaster has elected must-carry status under FCC rules, requiring the MVPD to carry the signal without negotiation. Applicable to qualified broadcast stations.' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiationHistory rdf:type rdf:Property ;
    rdfs:label 'Negotiation History' ;
    rdfs:comment 'Summary of key negotiation milestones, amendments, and material changes to the agreement over its lifecycle. Provides context for current terms and future renegotiations.' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalCommitment rdf:type rdf:Property ;
    rdfs:label 'Promotional Commitment' ;
    rdfs:comment 'Marketing and promotional obligations agreed by either party, such as on-air promotion, co-marketing campaigns, EPG placement guarantees, or cross-platform promotion.' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Conditions and terms governing agreement renewal, including renewal period length, rate adjustments, renegotiation triggers, and notice requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentGranted rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Granted' ;
    rdfs:comment 'Indicates whether retransmission consent has been granted under FCC regulations, authorizing the MVPD to rebroadcast over-the-air signals. Applicable only to retransmission consent agreement types.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'Performance commitments and service quality standards, including uptime guarantees, signal quality metrics, fault resolution times, and penalties for non-compliance.' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalDeliveryRequirements rdf:type rdf:Property ;
    rdfs:label 'Technical Delivery Requirements' ;
    rdfs:comment 'Technical specifications for content delivery, including signal format (HD, 4K, HDR), encoding standards (MPEG-2, MPEG-4, HEVC), delivery method (satellite, fiber, IP), and quality parameters (bitrate, resolution, audio channels).' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the agreement. Protects both parties from abrupt service disruption.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carriageFeeInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Invoice Id' ;
    rdfs:comment 'Unique identifier for the carriage fee invoice record. Primary key for this transactional billing entity.' ;
    rdfs:domain ind:CarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountsReceivableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Receivable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_receivable. Business justification: Carriage fee invoices create A/R entries when billed to distribution partners. Monthly A/R aging reports include outstanding carriage fee invoices for cash flow management and collections tracking in ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsReceivable .

ind:billingInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Billing Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Distribution-domain carriage fee invoices must reconcile against the master billing system invoice for AR integration and financial close. Media broadcasters require this link to match distribution-ge' ;
    rdfs:domain ind:CarriageFeeInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:responsibleSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Responsible Sales Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: Carriage fee invoices are tracked by responsible sales rep for commission calculation and dispute resolution. Essential for rep compensation on recurring carriage revenue, account health monitoring, a' ;
    rdfs:domain ind:CarriageFeeInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Total adjustments applied to the base fee, including discounts, credits, penalties, or promotional adjustments. May be positive or negative.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Base Fee Amount' ;
    rdfs:comment 'The base carriage fee amount before any adjustments, discounts, or taxes. Represents the core contractual fee for the billing period.' ;
    rdfs:domain ind:CarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'The last date of the period for which carriage fees are being billed. Defines the end of the service or subscription window covered by this invoice.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'The first date of the period for which carriage fees are being billed. Defines the beginning of the service or subscription window covered by this invoice.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'The username or identifier of the user or system process that created this invoice record. Used for audit and accountability.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The date on which the dispute was formally raised by the distribution partner. Null if the invoice has never been disputed.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Boolean indicator of whether the invoice is currently under dispute by the distribution partner. True if disputed, false otherwise.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text description of the reason for the dispute, if the invoice is disputed. Captures the distribution partners objection or concern.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeBasis rdf:type rdf:Property ;
    rdfs:label 'Fee Basis' ;
    rdfs:comment 'The pricing model or calculation method used to determine the carriage fee amount. Defines whether the fee is per-subscriber, flat-rate, tiered by volume, revenue-share, or a hybrid structure.' ;
    rdfs:domain ind:CarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalLedgerAccountCode rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account Code' ;
    rdfs:comment 'The GL account code to which this carriage fee invoice is posted in the financial system. Used for financial reporting and revenue recognition.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date on which the invoice was officially issued to the distribution partner. This is the principal business event timestamp for the invoice transaction.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally-visible unique invoice number used for billing correspondence, payment reconciliation, and financial reporting. Typically follows a sequential or structured numbering scheme.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the carriage fee invoice. Tracks progression from draft through issuance, acknowledgment, payment, and potential dispute or cancellation. [ENUM-REF-CANDIDATE: draft|issued|sent|acknowledged|paid|partially_paid|overdue|disputed|cancelled|void — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The payment instrument or mechanism used or expected for settling this invoice (e.g., wire transfer, ACH, check).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'The date on which payment was received and applied to this invoice. Null if the invoice has not been paid.' ;
    rdfs:domain ind:CarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External reference number or transaction identifier provided by the payer or payment processor. Used for payment reconciliation and traceability.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current payment status of the invoice. Tracks whether the invoice has been paid in full, partially paid, remains unpaid, or is overdue or disputed.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Contractual payment terms for this invoice, such as Net 30, Net 60, or custom terms. Defines the expected payment timeline and conditions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'The date on which the invoice was successfully reconciled against subscriber data, payments, and contractual obligations. Null if reconciliation is pending or failed.' ;
    rdfs:domain ind:CarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax amount applied to the invoice, including sales tax, VAT, or other applicable taxes based on jurisdiction and tax rules.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'The final total amount due on the invoice, calculated as base fee plus adjustments plus taxes. This is the amount the distribution partner must pay.' ;
    rdfs:domain ind:CarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'The username or identifier of the user or system process that last modified this invoice record. Used for audit and accountability.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutRulesEnabled rdf:type rdf:Property ;
    rdfs:label 'Blackout Rules Enabled' ;
    rdfs:comment 'Indicates whether geographic or rights-based blackout restrictions are enforced for this channel (true) or not (false).' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'The official brand name of the delivery channel as presented to audiences (e.g., \'HBO Max\', \'NBC Sports\', \'Pluto TV Comedy\').' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelNumber rdf:type rdf:Property ;
    rdfs:label 'Channel Number' ;
    rdfs:comment 'Logical channel number or position in the Electronic Program Guide (EPG) lineup (e.g., \'7.1\', \'502\', \'virtual 12\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRefreshCadence rdf:type rdf:Property ;
    rdfs:label 'Content Refresh Cadence' ;
    rdfs:comment 'Frequency at which the channel programming lineup or content library is updated with new material.' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTechnology rdf:type rdf:Property ;
    rdfs:label 'Delivery Technology' ;
    rdfs:comment 'The technical transmission standard used for content delivery. DVB (Digital Video Broadcasting) variants for European broadcast, ATSC (Advanced Television Systems Committee) for North American broadcast, QAM (Quadrature Amplitude Modulation) for cable, HLS (HTTP Live Streaming) and MPEG-DASH for adaptive bitrate streaming. [ENUM-REF-CANDIDATE: dvb-t|dvb-s|dvb-c|atsc|qam|hls|mpeg-dash|smooth-streaming|rtmp|webrtc — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgSourceCode rdf:type rdf:Property ;
    rdfs:label 'Epg Source Code' ;
    rdfs:comment 'External identifier linking this channel to its Electronic Program Guide (EPG) metadata feed provider (e.g., Gracenote, Tribune Media Services).' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastAggregatorPlatform rdf:type rdf:Property ;
    rdfs:label 'Fast Aggregator Platform' ;
    rdfs:comment 'Name of the FAST platform aggregator hosting the channel (e.g., \'Pluto TV\', \'Tubi\', \'Samsung TV Plus\', \'Roku Channel\', \'Xumo\'). Applicable only to FAST channel types.' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastPlaylistType rdf:type rdf:Property ;
    rdfs:label 'Fast Playlist Type' ;
    rdfs:comment 'Content scheduling model for FAST channels: linear-loop (repeating content block), scheduled (traditional time-based EPG), dynamic (algorithm-driven), or hybrid. Applicable only to FAST channel types.' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetizationModel rdf:type rdf:Property ;
    rdfs:label 'Monetization Model' ;
    rdfs:comment 'Revenue model for the channel: AVOD (Advertising-Supported Video On Demand), SVOD (Subscription Video On Demand), TVOD (Transactional Video On Demand), hybrid (multiple models), or free (no monetization).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalControlRating rdf:type rdf:Property ;
    rdfs:label 'Parental Control Rating' ;
    rdfs:comment 'TV Parental Guidelines rating assigned to the channel for content filtering and parental control systems.' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionFormat rdf:type rdf:Property ;
    rdfs:label 'Resolution Format' ;
    rdfs:comment 'Video resolution tier supported by the channel: SD (standard definition 480p), HD (720p), Full HD (1080p), 4K UHD (2160p), 8K UHD (4320p).' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when the channel ceased operations or was decommissioned. Null for active channels.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaUptimePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percent' ;
    rdfs:comment 'Contractual uptime guarantee for the channel expressed as a percentage (e.g., 99.95 for \'four nines\' availability).' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:streamingEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Streaming Endpoint Url' ;
    rdfs:comment 'Primary streaming endpoint URL or manifest URL for OTT and FAST channels. Confidential operational data.' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airplayEnabled rdf:type rdf:Property ;
    rdfs:label 'Airplay Enabled' ;
    rdfs:comment 'Flag indicating whether Apple AirPlay streaming to external devices is permitted.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowedCountries rdf:type rdf:Property ;
    rdfs:label 'Allowed Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where content playback is permitted.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analogOutputControl rdf:type rdf:Property ;
    rdfs:label 'Analog Output Control' ;
    rdfs:comment 'Policy governing analog video output (allowed, restricted with downscaling, or completely blocked).' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analogSunsetEnabled rdf:type rdf:Property ;
    rdfs:label 'Analog Sunset Enabled' ;
    rdfs:comment 'Flag indicating whether analog output is progressively restricted or disabled (analog sunset policy).' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedCountries rdf:type rdf:Property ;
    rdfs:label 'Blocked Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where content playback is explicitly blocked.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chromecastEnabled rdf:type rdf:Property ;
    rdfs:label 'Chromecast Enabled' ;
    rdfs:comment 'Flag indicating whether Google Chromecast streaming to external devices is permitted.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concurrentStreamLimit rdf:type rdf:Property ;
    rdfs:label 'Concurrent Stream Limit' ;
    rdfs:comment 'The maximum number of simultaneous streams allowed per user account or license.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentKeyReference rdf:type rdf:Property ;
    rdfs:label 'Content Key Reference' ;
    rdfs:comment 'The unique identifier for the encryption key used to protect the content.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceBindingEnabled rdf:type rdf:Property ;
    rdfs:label 'Device Binding Enabled' ;
    rdfs:comment 'Flag indicating whether licenses are bound to specific devices to prevent unauthorized sharing.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmVendor rdf:type rdf:Property ;
    rdfs:label 'Drm Vendor' ;
    rdfs:comment 'The vendor or provider of the DRM solution (e.g., Google, Microsoft, Apple, Adobe).' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionScheme rdf:type rdf:Property ;
    rdfs:label 'Encryption Scheme' ;
    rdfs:comment 'The encryption scheme used for content protection (CENC, CBC1, CENS, CBCS) as defined by Common Encryption standards.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRestrictionEnabled rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Enabled' ;
    rdfs:comment 'Flag indicating whether geographic restrictions are enforced for content delivery based on viewer location.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdcpLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Hdcp Level Required' ;
    rdfs:comment 'The minimum HDCP version required for output protection to prevent unauthorized digital copying. [ENUM-REF-CANDIDATE: none|hdcp_1_0|hdcp_1_1|hdcp_1_2|hdcp_1_3|hdcp_1_4|hdcp_2_0|hdcp_2_1|hdcp_2_2|hdcp_2_3 — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyRotationIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Key Rotation Interval Hours' ;
    rdfs:comment 'The frequency in hours at which encryption keys are rotated for enhanced security.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'License Duration Seconds' ;
    rdfs:comment 'The validity period in seconds for a DRM license before it must be renewed.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseServerEndpoint rdf:type rdf:Property ;
    rdfs:label 'License Server Endpoint' ;
    rdfs:comment 'The URL endpoint of the DRM license server that issues decryption keys to authorized clients.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDeviceRegistrations rdf:type rdf:Property ;
    rdfs:label 'Max Device Registrations' ;
    rdfs:comment 'The maximum number of devices that can be registered for content playback per user account.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offlineLicenseDurationHours rdf:type rdf:Property ;
    rdfs:label 'Offline License Duration Hours' ;
    rdfs:comment 'The maximum duration in hours that offline downloaded content remains playable before license expiration.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offlinePlaybackEnabled rdf:type rdf:Property ;
    rdfs:label 'Offline Playback Enabled' ;
    rdfs:comment 'Flag indicating whether content can be downloaded and played offline without an active internet connection.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offlinePlaybackWindowHours rdf:type rdf:Property ;
    rdfs:label 'Offline Playback Window Hours' ;
    rdfs:comment 'The time window in hours during which offline content must be played once playback begins.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:persistentLicenseEnabled rdf:type rdf:Property ;
    rdfs:label 'Persistent License Enabled' ;
    rdfs:comment 'Flag indicating whether licenses can be stored persistently on the device for offline or repeated playback.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playbackDurationHours rdf:type rdf:Property ;
    rdfs:label 'Playback Duration Hours' ;
    rdfs:comment 'The time window in hours during which content must be consumed once playback begins for rental content.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Unique business code or identifier for the DRM policy used across systems and platforms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name of the DRM policy for identification and reference purposes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyPriority rdf:type rdf:Property ;
    rdfs:label 'Policy Priority' ;
    rdfs:comment 'The priority ranking of this policy when multiple policies could apply. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'The current lifecycle status of the DRM policy (draft, active, suspended, deprecated, retired).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rentalDurationHours rdf:type rdf:Property ;
    rdfs:label 'Rental Duration Hours' ;
    rdfs:comment 'The total rental period in hours during which content is accessible for Transactional Video On Demand (TVOD) rentals.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:screenCaptureBlocked rdf:type rdf:Property ;
    rdfs:label 'Screen Capture Blocked' ;
    rdfs:comment 'Flag indicating whether screen capture and recording are blocked during content playback.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'The security level required for DRM implementation (software or hardware-based cryptography and decoding).' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenExpirySeconds rdf:type rdf:Property ;
    rdfs:label 'Token Expiry Seconds' ;
    rdfs:comment 'The expiration time in seconds for authentication tokens used in DRM license acquisition.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:widevineSecurityLevel rdf:type rdf:Property ;
    rdfs:label 'Widevine Security Level' ;
    rdfs:comment 'The Widevine-specific security level (L1 hardware-backed, L2 software-backed, L3 software only).' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'The user or system identifier that created this DRM policy record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cacheControlHeader rdf:type rdf:Property ;
    rdfs:label 'Cache Control Header' ;
    rdfs:comment 'HTTP Cache-Control header directives applied to CDN responses, controlling caching behavior at edge and client levels.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionEnabled rdf:type rdf:Property ;
    rdfs:label 'Compression Enabled' ;
    rdfs:comment 'Indicates whether content compression (gzip, brotli) is enabled at the CDN edge to reduce bandwidth consumption and improve delivery performance.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failoverOriginUrl rdf:type rdf:Property ;
    rdfs:label 'Failover Origin Url' ;
    rdfs:comment 'Secondary origin server URL used for redundancy and failover when the primary origin is unavailable.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoBlockingEnabled rdf:type rdf:Property ;
    rdfs:label 'Geo Blocking Enabled' ;
    rdfs:comment 'Indicates whether geographic content restrictions are enforced at the CDN edge based on viewer location.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geoBlockingMode rdf:type rdf:Property ;
    rdfs:label 'Geo Blocking Mode' ;
    rdfs:comment 'Specifies whether the geo-blocking rules operate as an allow-list (whitelist) or deny-list (blacklist) of countries.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:http2Enabled rdf:type rdf:Property ;
    rdfs:label 'Http2 Enabled' ;
    rdfs:comment 'Indicates whether HTTP/2 protocol is enabled for this CDN configuration to improve streaming performance through multiplexing and header compression.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originPullUrl rdf:type rdf:Property ;
    rdfs:label 'Origin Pull Url' ;
    rdfs:comment 'The origin server URL from which the CDN pulls content when not cached. Typically points to the media asset management system or playout server.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prefetchEnabled rdf:type rdf:Property ;
    rdfs:label 'Prefetch Enabled' ;
    rdfs:comment 'Indicates whether content prefetching is enabled to proactively cache content at edge locations before viewer requests.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:propertyHostname rdf:type rdf:Property ;
    rdfs:label 'Property Hostname' ;
    rdfs:comment 'The fully qualified domain name (FQDN) of the CDN property or edge hostname used for content delivery.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryStringCachingMode rdf:type rdf:Property ;
    rdfs:label 'Query String Caching Mode' ;
    rdfs:comment 'Defines how URL query string parameters are handled in cache key generation. Controls cache efficiency and personalization support.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'The contracted service level tier for this CDN configuration, determining uptime guarantees, support response times, and performance commitments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sslCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Ssl Certificate Reference' ;
    rdfs:comment 'Reference identifier or serial number of the SSL/TLS certificate deployed on the CDN property for secure HTTPS delivery.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenAuthenticationEnabled rdf:type rdf:Property ;
    rdfs:label 'Token Authentication Enabled' ;
    rdfs:comment 'Indicates whether token-based authentication is enabled for this CDN configuration to prevent unauthorized access to content.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tokenSecretKey rdf:type rdf:Property ;
    rdfs:label 'Token Secret Key' ;
    rdfs:comment 'The cryptographic secret key used to generate and validate authentication tokens. Must be kept confidential and rotated regularly.' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalRouteId rdf:type rdf:Property ;
    rdfs:label 'Signal Route Id' ;
    rdfs:comment 'Unique identifier for the signal routing path. Primary key for the signal route entity.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playoutChannelId rdf:type rdf:Property ;
    rdfs:label 'Playout Channel Id' ;
    rdfs:comment 'Identifier of the specific playout channel within the playout system that originates the signal for this route.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:backupPathDescription rdf:type rdf:Property ;
    rdfs:label 'Backup Path Description' ;
    rdfs:comment 'Detailed description of the backup or redundant signal routing path used for failover in case of primary path failure.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Mbps' ;
    rdfs:comment 'Allocated bandwidth capacity for this signal route in megabits per second (Mbps), defining the maximum throughput for signal transmission.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Destination Endpoint Url' ;
    rdfs:comment 'Uniform Resource Locator (URL) of the destination endpoint where the signal is delivered (CDN origin, distribution partner, or broadcast facility).' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downlinkFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Downlink Frequency Mhz' ;
    rdfs:comment 'Downlink reception frequency in megahertz (MHz) for satellite signal routes.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:encryptionAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Encryption Algorithm' ;
    rdfs:comment 'Cryptographic algorithm used for signal encryption (e.g., AES-128, AES-256).' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled' ;
    rdfs:comment 'Boolean flag indicating whether signal encryption is enabled for this route to protect content during transmission.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failoverPriority rdf:type rdf:Property ;
    rdfs:label 'Failover Priority' ;
    rdfs:comment 'Numeric priority ranking determining the order in which this route is selected during failover scenarios (lower number indicates higher priority).' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failoverThresholdSeconds rdf:type rdf:Property ;
    rdfs:label 'Failover Threshold Seconds' ;
    rdfs:comment 'Maximum allowable signal interruption duration in seconds before automatic failover to backup path is triggered.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:irdModel rdf:type rdf:Property ;
    rdfs:label 'Ird Model' ;
    rdfs:comment 'Model name and identifier of the Integrated Receiver Decoder (IRD) equipment used to receive and decode the satellite or terrestrial signal.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irdSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Ird Serial Number' ;
    rdfs:comment 'Serial number of the IRD equipment deployed for this signal route, used for asset tracking and maintenance.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latencyTargetMs rdf:type rdf:Property ;
    rdfs:label 'Latency Target Ms' ;
    rdfs:comment 'Target end-to-end latency in milliseconds for signal delivery from origin to destination, critical for live broadcast and low-latency streaming.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playoutSystemCode rdf:type rdf:Property ;
    rdfs:label 'Playout System Code' ;
    rdfs:comment 'Identifier of the playout automation system serving as the origin source for this signal route (e.g., Ericsson MediaFirst instance).' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:polarization rdf:type rdf:Property ;
    rdfs:label 'Polarization' ;
    rdfs:comment 'Polarization mode of the satellite signal transmission (horizontal, vertical, left circular, right circular).' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPathDescription rdf:type rdf:Property ;
    rdfs:label 'Primary Path Description' ;
    rdfs:comment 'Detailed description of the primary signal routing path, including intermediate hops, network segments, and infrastructure components.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the signal route in operational systems and documentation.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Human-readable name identifying the signal routing path, typically describing the source-to-destination flow (e.g., \'Studio-A-to-East-Coast-Uplink\').' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the signal routing path based on delivery technology and infrastructure (linear broadcast, OTT streaming, hybrid, satellite uplink, terrestrial transmission, IP interconnect).' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportProtocol rdf:type rdf:Property ;
    rdfs:label 'Transport Protocol' ;
    rdfs:comment 'Technical protocol used for signal transport and delivery across the routing path. Includes HTTP Live Streaming (HLS), MPEG Dynamic Adaptive Streaming over HTTP (MPEG-DASH), User Datagram Protocol/Transport Stream (UDP/TS), Digital Video Broadcasting Satellite Second Generation (DVB-S2), and others. [ENUM-REF-CANDIDATE: HLS|MPEG-DASH|UDP/TS|DVB-S2|DVB-T2|ATSC|RTP|RTMP|SRT — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uplinkFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Uplink Frequency Mhz' ;
    rdfs:comment 'Uplink transmission frequency in megahertz (MHz) for satellite signal routes.' ;
    rdfs:domain ind:SignalRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licensingInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Licensing Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Release windows (theatrical, home video, SVOD, AVOD) have associated platform licensing fees that generate invoices. Real business process: windowing revenue recognition, platform licensing billing, m' ;
    rdfs:domain ind:ReleaseWindow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:sourceOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Source Opportunity Id' ;
    rdfs:comment 'Foreign key linking to sales.opportunity. Business justification: Distribution windows are negotiated as part of content licensing opportunities. Links windowing strategy (theatrical, SVOD, AVOD, linear) to original sales deal structure. Critical for rights manageme' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:adInsertionEnabled rdf:type rdf:Property ;
    rdfs:label 'Ad Insertion Enabled' ;
    rdfs:comment 'Indicates whether Dynamic Ad Insertion (DAI) is enabled for this distribution window, allowing targeted advertising within the content stream.' ;
    rdfs:domain ind:ReleaseWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adLoadMinutes rdf:type rdf:Property ;
    rdfs:label 'Ad Load Minutes' ;
    rdfs:comment 'Total minutes of advertising permitted per hour of content in this distribution window. Applicable for AVOD, linear, and FAST windows.' ;
    rdfs:domain ind:ReleaseWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audioDescriptionRequired rdf:type rdf:Property ;
    rdfs:label 'Audio Description Required' ;
    rdfs:comment 'Indicates whether audio description track is required for visually impaired accessibility in this distribution window.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutRules rdf:type rdf:Property ;
    rdfs:label 'Blackout Rules' ;
    rdfs:comment 'Geographic or temporal blackout restrictions applied to this distribution window, preventing broadcast in specific regions or time periods (e.g., sports blackout rules).' ;
    rdfs:domain ind:ReleaseWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionRequired rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Required' ;
    rdfs:comment 'Indicates whether closed captioning is required for accessibility compliance in this distribution window.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dubbingLanguages rdf:type rdf:Property ;
    rdfs:label 'Dubbing Languages' ;
    rdfs:comment 'Comma-separated list of dubbing/audio track languages available for this distribution window (ISO 639-1 codes).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'Precise timestamp when this distribution window record became effective and operational for scheduling and delivery systems.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this distribution window grants exclusive rights to the platform, preventing simultaneous distribution on competing platforms during the window period.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'Precise timestamp when this distribution window record expires and is no longer valid for operational use. Nullable for indefinite windows.' ;
    rdfs:domain ind:ReleaseWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hdrEnabled rdf:type rdf:Property ;
    rdfs:label 'Hdr Enabled' ;
    rdfs:comment 'Indicates whether High Dynamic Range video format is enabled for this distribution window, providing enhanced color and contrast.' ;
    rdfs:domain ind:ReleaseWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdbackPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Holdback Period Days' ;
    rdfs:comment 'Number of days between the close of the previous window and the open of this window, enforcing exclusivity periods per rights agreements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageVersion rdf:type rdf:Property ;
    rdfs:label 'Language Version' ;
    rdfs:comment 'Primary language version of the content distributed in this window (e.g., English, Spanish, French). ISO 639-1 two-letter language codes preferred.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Amount' ;
    rdfs:comment 'Minimum guaranteed payment amount from the distributor or platform for this distribution window, regardless of actual performance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Revenue model for this distribution window. Subscription = SVOD flat fee; Transactional = TVOD pay-per-view or rental; Advertising = AVOD ad-supported; Free = no charge to viewer; Hybrid = combination of models.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasePrice rdf:type rdf:Property ;
    rdfs:label 'Purchase Price' ;
    rdfs:comment 'Price charged to viewers for permanent purchase/download during this window (EST model). Nullable if not applicable.' ;
    rdfs:domain ind:ReleaseWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentalPrice rdf:type rdf:Property ;
    rdfs:label 'Rental Price' ;
    rdfs:comment 'Price charged to viewers for transactional rental access during this window (TVOD model). Nullable if not applicable.' ;
    rdfs:domain ind:ReleaseWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueSharePercent rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percent' ;
    rdfs:comment 'Percentage of revenue shared with the platform or distributor for this window, per the commercial distribution agreement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windowCloseDate rdf:type rdf:Property ;
    rdfs:label 'Window Close Date' ;
    rdfs:comment 'Date when the distribution window closes and content is no longer available on the specified platform or channel. Nullable for open-ended windows.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windowOpenDate rdf:type rdf:Property ;
    rdfs:label 'Window Open Date' ;
    rdfs:comment 'Date when the distribution window opens and content becomes available on the specified platform or channel.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windowPriority rdf:type rdf:Property ;
    rdfs:label 'Window Priority' ;
    rdfs:comment 'Numeric priority ranking of this window in the overall release strategy, where 1 = highest priority (typically theatrical), incrementing for subsequent windows.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowType rdf:type rdf:Property ;
    rdfs:label 'Window Type' ;
    rdfs:comment 'Type of distribution window defining the release strategy. Theatrical = cinema release; SVOD = Subscription Video On Demand; AVOD = Advertising-Supported Video On Demand; TVOD = Transactional Video On Demand; Linear = traditional broadcast; FAST = Free Ad-Supported Streaming Television; Syndication = content resale to multiple outlets; PPV = Pay-Per-View; EST = Electronic Sell-Through. [ENUM-REF-CANDIDATE: theatrical|svod|avod|tvod|linear|fast|syndication|vod|ppv|est — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryEventId rdf:type rdf:Property ;
    rdfs:label 'Delivery Event Id' ;
    rdfs:comment 'Unique identifier for the delivery event record. Primary key.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adFillRatePercent rdf:type rdf:Property ;
    rdfs:label 'Ad Fill Rate Percent' ;
    rdfs:comment 'Percentage of available ad inventory that was successfully filled during this DAI event (0.00 to 100.00).' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bytesDelivered rdf:type rdf:Property ;
    rdfs:label 'Bytes Delivered' ;
    rdfs:comment 'Total number of bytes delivered to the viewer during this event.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdnCacheStatus rdf:type rdf:Property ;
    rdfs:label 'Cdn Cache Status' ;
    rdfs:comment 'CDN cache status for this delivery (hit, miss, stale, bypass).' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnNodeCode rdf:type rdf:Property ;
    rdfs:label 'Cdn Node Code' ;
    rdfs:comment 'Identifier of the CDN edge node that served the content for this delivery event.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Human-readable error message describing the delivery failure or issue.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the delivery occurred (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region where the content was delivered (e.g., North America, EMEA, APAC, or specific country/state codes).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Network Latency Ms' ;
    rdfs:comment 'Network latency measured in milliseconds between CDN edge and viewer device.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originServerResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Origin Server Response Time Ms' ;
    rdfs:comment 'Response time from origin server in milliseconds for cache-miss scenarios.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scte35SignalType rdf:type rdf:Property ;
    rdfs:label 'Scte35 Signal Type' ;
    rdfs:comment 'Type of SCTE-35 signal that triggered the DAI event (e.g., splice_insert, time_signal).' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Session Duration Seconds' ;
    rdfs:comment 'Total duration of the delivery session in seconds for streaming events.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'User agent string from the viewer device identifying browser/app and operating system.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Master Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Standalone films, documentaries, and short-form titles require a direct link to their master media asset for QC sign-off, rights clearance readiness, and distribution packaging. Every other content le' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:primaryRightsHolderId rdf:type rdf:Property ;
    rdfs:label 'Primary Rights Holder Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_holder. Business justification: Tracks who owns/controls rights to each title - essential for royalty payments, clearance workflows, and determining who must approve licensing deals. Rights holder is the starting point for all right' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date when the content rights were acquired by the organization. Used for rights lifecycle tracking, amortization calculations, and contract management.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:archiveDate rdf:type rdf:Property ;
    rdfs:label 'Archive Date' ;
    rdfs:comment 'Date when the content was moved to archived status. Used for content lifecycle management and digital asset retention policies.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:audioDescriptionAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Audio Description Available Flag' ;
    rdfs:comment 'Indicates whether audio description track is available for visually impaired audiences. Required for accessibility compliance and inclusive broadcasting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedCaptionAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Available Flag' ;
    rdfs:comment 'Indicates whether closed captioning is available for the content. Required for FCC compliance and accessibility standards.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:colorFormat rdf:type rdf:Property ;
    rdfs:label 'Color Format' ;
    rdfs:comment 'Indicates whether the content is in color, black and white, or has been colorized. Used for archival classification and presentation metadata.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentStatus rdf:type rdf:Property ;
    rdfs:label 'Content Status' ;
    rdfs:comment 'Current lifecycle status of the content asset. Determines availability for scheduling, distribution, and monetization. Active content is available for use; archived content is retained but not actively distributed; restricted content has legal or rights limitations.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaChildDirectedFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Child Directed Flag' ;
    rdfs:comment 'Indicates whether the content is directed to children under 13 years of age. Triggers COPPA compliance requirements for data collection, advertising restrictions, and privacy protections.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Hd Available Flag' ;
    rdfs:comment 'Indicates whether a high-definition version of the content is available. Used for channel playout decisions and quality-tier distribution strategies.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isrc rdf:type rdf:Property ;
    rdfs:label 'Isrc' ;
    rdfs:comment 'International standard code for uniquely identifying sound recordings and music video recordings. Used for music tracks and audio content royalty tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords and tags describing content themes, subjects, and topics. Used for search optimization, content discovery, and recommendation algorithms.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalLanguage rdf:type rdf:Property ;
    rdfs:label 'Original Language' ;
    rdfs:comment 'ISO 639-2 three-letter code representing the original language of the content production. Used for localization planning, dubbing, and subtitle workflows.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTitle rdf:type rdf:Property ;
    rdfs:label 'Original Title' ;
    rdfs:comment 'Original title name in the native language of production. Preserved for rights management, archival, and international distribution purposes.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalAdvisoryFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Advisory Flag' ;
    rdfs:comment 'Indicates whether the content carries a parental advisory warning for explicit content, violence, or mature themes. Used for compliance with broadcast standards and platform content policies.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:premiereFlag rdf:type rdf:Property ;
    rdfs:label 'Premiere Flag' ;
    rdfs:comment 'Indicates whether the content is a premiere or first-run broadcast. Used for promotional scheduling, advertising premium pricing, and audience measurement reporting.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionYear rdf:type rdf:Property ;
    rdfs:label 'Production Year' ;
    rdfs:comment 'Calendar year in which the content was originally produced or completed. Used for catalog organization, rights windowing calculations, and archival classification.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the content was first released to the public or premiered. Used for rights availability calculations, windowing strategies, and anniversary programming.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Status' ;
    rdfs:comment 'Current rights availability status indicating whether the content can be legally broadcast or distributed. Drives scheduling decisions and geographic blackout enforcement.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runtimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Runtime Seconds' ;
    rdfs:comment 'Total duration of the content in seconds. Used for program scheduling, ad pod allocation, playout automation, and Electronic Program Guide (EPG) generation.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subGenre rdf:type rdf:Property ;
    rdfs:label 'Sub Genre' ;
    rdfs:comment 'Secondary or more granular genre classification providing additional content categorization for advanced audience segmentation and personalization.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theatricalReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Theatrical Release Flag' ;
    rdfs:comment 'Indicates whether the content had a theatrical release. Used for windowing strategy, rights holdback periods, and marketing classification.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:titleName rdf:type rdf:Property ;
    rdfs:label 'Title Name' ;
    rdfs:comment 'Primary display name of the content title. The human-readable identifier used across all systems and customer-facing platforms.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uhd4kAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Uhd 4k Available Flag' ;
    rdfs:comment 'Indicates whether an Ultra HD 4K version of the content is available. Used for premium streaming tiers and next-generation broadcast services.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originatingChannelId rdf:type rdf:Property ;
    rdfs:label 'Originating Channel Id' ;
    rdfs:comment 'Foreign key linking to scheduling.channel. Business justification: Series are commissioned by or associated with a primary originating channel (original_network is plain text on series). Linking to channel.channel_id enables channel-level content library reports, acq' ;
    rdfs:domain ind:Series ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:archiveLocation rdf:type rdf:Property ;
    rdfs:label 'Archive Location' ;
    rdfs:comment 'Physical or logical location identifier where the series master content and metadata are archived. Used for Digital Asset Management (DAM) and Media Asset Management (MAM) retrieval.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioDescriptionAvailable rdf:type rdf:Property ;
    rdfs:label 'Audio Description Available' ;
    rdfs:comment 'Indicates whether audio description track is available for visually impaired viewers. Required for accessibility compliance in many jurisdictions.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedCaptionAvailable rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Available' ;
    rdfs:comment 'Indicates whether closed captioning is available for the series. Required for regulatory compliance under FCC accessibility rules and international broadcasting standards.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:episodeRuntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Episode Runtime Minutes' ;
    rdfs:comment 'Standard runtime duration in minutes for a typical episode of the series, excluding commercials. Used for scheduling, ad pod planning, and playout automation.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finaleDate rdf:type rdf:Property ;
    rdfs:label 'Finale Date' ;
    rdfs:comment 'Date when the final episode of the series aired or was released. Null for ongoing series. Used for syndication eligibility and rights holdback period calculations.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseName rdf:type rdf:Property ;
    rdfs:label 'Franchise Name' ;
    rdfs:comment 'Brand name of the content franchise or show brand. Used for grouping related series, spin-offs, and reboots under a common brand umbrella.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageOriginal rdf:type rdf:Property ;
    rdfs:label 'Language Original' ;
    rdfs:comment 'ISO 639-3 three-letter code for the original production language of the series. Used for localization planning and international distribution.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalNetwork rdf:type rdf:Property ;
    rdfs:label 'Original Network' ;
    rdfs:comment 'Name of the original broadcast network or streaming platform that first aired or released the series. Critical for rights management and syndication deals.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiereDate rdf:type rdf:Property ;
    rdfs:label 'Premiere Date' ;
    rdfs:comment 'Date when the first episode of the series originally aired or was released. Marks the beginning of the series lifecycle and is used for rights windowing calculations.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionStandard rdf:type rdf:Property ;
    rdfs:label 'Resolution Standard' ;
    rdfs:comment 'Standard video resolution for the series master content. Determines transcoding requirements and Adaptive Bitrate (ABR) streaming profile generation.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesStatus rdf:type rdf:Property ;
    rdfs:label 'Series Status' ;
    rdfs:comment 'Current lifecycle status of the series. Indicates whether the series is actively producing new content, has concluded, or is temporarily paused.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesType rdf:type rdf:Property ;
    rdfs:label 'Series Type' ;
    rdfs:comment 'Classification of the series format and production style. Determines scheduling strategy, audience targeting, and production workflow. [ENUM-REF-CANDIDATE: scripted|unscripted|documentary|news|sports|reality|talk_show|game_show|variety|animated|miniseries|anthology — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationEligible rdf:type rdf:Property ;
    rdfs:label 'Syndication Eligible' ;
    rdfs:comment 'Indicates whether the series meets the minimum episode threshold and rights clearance requirements for syndication to secondary markets and broadcast stations.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetDemographic rdf:type rdf:Property ;
    rdfs:label 'Target Demographic' ;
    rdfs:comment 'Primary audience demographic segment the series is designed to reach. Used for advertising sales, scheduling strategy, and Target Rating Point (TRP) calculations. [ENUM-REF-CANDIDATE: adults_18_49|adults_25_54|adults_18_34|children_2_11|teens_12_17|women_18_49|men_18_49|total_viewers — promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Official title of the series as registered and marketed. Primary human-readable identifier for the content franchise.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleOriginal rdf:type rdf:Property ;
    rdfs:label 'Title Original' ;
    rdfs:comment 'Original title of the series in its native language and market before localization or translation.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEpisodeCount rdf:type rdf:Property ;
    rdfs:label 'Total Episode Count' ;
    rdfs:comment 'Cumulative count of all episodes produced across all seasons. Includes specials and pilot episodes.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSeasonCount rdf:type rdf:Property ;
    rdfs:label 'Total Season Count' ;
    rdfs:comment 'Total number of seasons produced for the series to date. Updated as new seasons are commissioned and produced.' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardsNominated rdf:type rdf:Property ;
    rdfs:label 'Awards Nominated' ;
    rdfs:comment 'Comma-separated list of major award nominations received by the season. Supports promotional messaging and content valuation.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardsWon rdf:type rdf:Property ;
    rdfs:label 'Awards Won' ;
    rdfs:comment 'Comma-separated list of major awards won by the season (e.g., Emmy, Golden Globe). Used for marketing and promotional value enhancement.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bannerArtworkUrl rdf:type rdf:Property ;
    rdfs:label 'Banner Artwork Url' ;
    rdfs:comment 'URL reference to the season\'s banner or hero image for wide-format displays on streaming platforms and websites.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeCountAired rdf:type rdf:Property ;
    rdfs:label 'Episode Count Aired' ;
    rdfs:comment 'Number of episodes that have been broadcast or released to audiences. Used for tracking release progress.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeCountOrdered rdf:type rdf:Property ;
    rdfs:label 'Episode Count Ordered' ;
    rdfs:comment 'Number of episodes originally ordered or commissioned for this season by the network or platform.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeCountProduced rdf:type rdf:Property ;
    rdfs:label 'Episode Count Produced' ;
    rdfs:comment 'Actual number of episodes produced and delivered for this season. May differ from ordered count due to production changes.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkOriginal rdf:type rdf:Property ;
    rdfs:label 'Network Original' ;
    rdfs:comment 'Name of the network or platform that originally commissioned or first aired the season. Used for windowing and exclusivity tracking.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalAirDate rdf:type rdf:Property ;
    rdfs:label 'Original Air Date' ;
    rdfs:comment 'Date when the first episode of the season was originally broadcast or released. Key for windowing and rights calculations.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:posterArtworkUrl rdf:type rdf:Property ;
    rdfs:label 'Poster Artwork Url' ;
    rdfs:comment 'URL reference to the season\'s primary poster artwork stored in the Media Asset Management (MAM) system. Used for EPG, VOD, and promotional displays.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Rights Expiry Date' ;
    rdfs:comment 'Date when current distribution rights for the season expire. Triggers rights renewal workflows and availability restrictions.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsTerritory rdf:type rdf:Property ;
    rdfs:label 'Rights Territory' ;
    rdfs:comment 'Geographic territories where distribution rights are held, using ISO 3166-1 alpha-3 country codes or regional groupings. Critical for windowing and blackout enforcement.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonStatus rdf:type rdf:Property ;
    rdfs:label 'Season Status' ;
    rdfs:comment 'Current lifecycle status of the season. Tracks progression from development through archival or cancellation. [ENUM-REF-CANDIDATE: in-development|in-production|post-production|completed|airing|aired|archived|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentSeasonId rdf:type rdf:Property ;
    rdfs:label 'Content Season Id' ;
    rdfs:comment 'Reference to the specific season within the series to which this episode belongs. Enables season-level grouping and rights management.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Season .

ind:contentSeriesId rdf:type rdf:Property ;
    rdfs:label 'Content Series Id' ;
    rdfs:comment 'Reference to the parent series to which this episode belongs. Links episode to its series container.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Series .

ind:broadcastCount rdf:type rdf:Property ;
    rdfs:label 'Broadcast Count' ;
    rdfs:comment 'Total number of times this episode has been broadcast on linear television. Used for residuals calculation and syndication rights management.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentAdvisory rdf:type rdf:Property ;
    rdfs:label 'Content Advisory' ;
    rdfs:comment 'Specific content warnings or advisories for viewer guidance (e.g., violence, language, adult themes). Displayed in Electronic Program Guide (EPG) and Video On Demand (VOD) interfaces.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eidrIdentifier rdf:type rdf:Property ;
    rdfs:label 'Eidr Identifier' ;
    rdfs:comment 'Globally unique identifier for the episode registered with the Entertainment Identifier Registry. Enables universal content identification across distribution platforms and rights management systems.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeStatus rdf:type rdf:Property ;
    rdfs:label 'Episode Status' ;
    rdfs:comment 'Current lifecycle state of the episode. Determines availability for scheduling, playout automation, and distribution to Over-The-Top (OTT) platforms.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeType rdf:type rdf:Property ;
    rdfs:label 'Episode Type' ;
    rdfs:comment 'Classification of the episode format and purpose within the series. Affects scheduling strategy, promotional treatment, and rights valuation. [ENUM-REF-CANDIDATE: standard|special|pilot|finale|recap|bonus|behind_the_scenes — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicCueSheetSubmitted rdf:type rdf:Property ;
    rdfs:label 'Music Cue Sheet Submitted' ;
    rdfs:comment 'Indicates whether the music cue sheet has been submitted for royalty collection. Required for music rights compliance and royalty distribution.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionCode rdf:type rdf:Property ;
    rdfs:label 'Production Code' ;
    rdfs:comment 'Internal production identifier assigned during content creation. Used for tracking production workflow, post-production tasks, and archival reference.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rerunFlag rdf:type rdf:Property ;
    rdfs:label 'Rerun Flag' ;
    rdfs:comment 'Indicates whether this broadcast is a rerun. Affects advertising rates, Cost Per Rating Point (CPRP) calculations, and residuals payments to talent.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runtimeWithAdsSeconds rdf:type rdf:Property ;
    rdfs:label 'Runtime With Ads Seconds' ;
    rdfs:comment 'Total broadcast duration including commercial ad breaks. Used for linear scheduling and daypart planning.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subtitlesAvailable rdf:type rdf:Property ;
    rdfs:label 'Subtitles Available' ;
    rdfs:comment 'Indicates whether subtitle tracks are available for this episode. Supports international distribution and localization strategies.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vodAvailableFromDate rdf:type rdf:Property ;
    rdfs:label 'Vod Available From Date' ;
    rdfs:comment 'Date when the episode becomes available on Video On Demand (VOD) platforms. Part of windowing strategy and rights holdback management.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vodAvailableUntilDate rdf:type rdf:Property ;
    rdfs:label 'Vod Available Until Date' ;
    rdfs:comment 'Date when the episode is removed from Video On Demand (VOD) platforms. Enforces rights windows and exclusivity periods.' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:masterAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Master Asset Version Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_version. Business justification: A content version (editorial/rights construct) maps to a specific technical asset_version in the MAM. Distribution readiness reporting and platform delivery workflows require this link to confirm the ' ;
    rdfs:domain ind:Version ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'Timestamp when this version was moved to long-term archive storage.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:audioTrackConfiguration rdf:type rdf:Property ;
    rdfs:label 'Audio Track Configuration' ;
    rdfs:comment 'Comma-separated list of audio track languages and types available in this version (e.g., \'en:stereo,es:5.1,fr:stereo,en:descriptive\').' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastSafe rdf:type rdf:Property ;
    rdfs:label 'Broadcast Safe' ;
    rdfs:comment 'Indicates whether this version has been certified as broadcast-safe, meeting technical standards for linear transmission (audio levels, video levels, closed captioning).' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isrcCode rdf:type rdf:Property ;
    rdfs:label 'Isrc Code' ;
    rdfs:comment 'International Standard Recording Code for music or audio content versions, enabling tracking and royalty distribution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Human-readable label identifying this version (e.g., \'Theatrical Cut\', \'Director\'s Cut\', \'Broadcast Safe\', \'Spanish Dub\', \'UK Censored\').' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Primary Language Code' ;
    rdfs:comment 'ISO 639 two or three-letter code for the primary audio language of this version (e.g., \'en\', \'es\', \'fr\').' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Qc Completed Date' ;
    rdfs:comment 'Date when quality control review was completed for this version.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Status' ;
    rdfs:comment 'Quality control review status for this version, indicating whether it has passed technical and content quality checks.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runtimeDeltaSeconds rdf:type rdf:Property ;
    rdfs:label 'Runtime Delta Seconds' ;
    rdfs:comment 'Difference in runtime (in seconds) between this version and the master version. Positive values indicate longer runtime, negative indicate shorter.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical or logical storage location identifier where this version is archived (e.g., tape library ID, cloud bucket path, MAM archive reference).' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPlatform rdf:type rdf:Property ;
    rdfs:label 'Target Platform' ;
    rdfs:comment 'Distribution platform or window this version is optimized for (e.g., linear broadcast, SVOD, AVOD, theatrical). [ENUM-REF-CANDIDATE: linear_broadcast|svod|avod|tvod|theatrical|home_video|syndication|fast|mvpd|vmvpd — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTerritory rdf:type rdf:Property ;
    rdfs:label 'Target Territory' ;
    rdfs:comment 'Three-letter ISO country code indicating the primary geographic territory this version is intended for (e.g., USA, GBR, FRA).' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of the version indicating its readiness for distribution and playout. [ENUM-REF-CANDIDATE: draft|in_production|qc_pending|approved|active|archived|deprecated|rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionType rdf:type rdf:Property ;
    rdfs:label 'Version Type' ;
    rdfs:comment 'Classification of the version type indicating the nature of the edit or adaptation. [ENUM-REF-CANDIDATE: theatrical|broadcast|director|extended|unrated|censored|dubbed|subtitled|localized|preview|trailer — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentGenreId rdf:type rdf:Property ;
    rdfs:label 'Parent Genre Id' ;
    rdfs:comment 'Reference to the parent genre in the hierarchical taxonomy, enabling multi-level classification such as Drama > Legal Drama or Sports > Football. Null for top-level genres.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Genre .

ind:adPodCompatibility rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Compatibility' ;
    rdfs:comment 'Indicates whether content in this genre is compatible with Dynamic Ad Insertion (DAI) and ad pod placement. False for genres requiring uninterrupted viewing (e.g., live sports critical moments, news breaking coverage).' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableContentTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Content Types' ;
    rdfs:comment 'Comma-separated list of content types to which this genre applies (e.g., series, film, clip, live_event, news_segment, music_video). Enables content-type-specific genre filtering.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveRetentionPolicy rdf:type rdf:Property ;
    rdfs:label 'Archive Retention Policy' ;
    rdfs:comment 'Digital asset archival retention policy for content in this genre. Permanent retention for high-value evergreen genres; short-term for time-sensitive news and event content.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avodMonetizationPotential rdf:type rdf:Property ;
    rdfs:label 'Avod Monetization Potential' ;
    rdfs:comment 'Revenue generation potential for this genre on Advertising-Supported Video On Demand (AVOD) platforms, based on Cost Per Mille (CPM) rates and advertiser demand. High-potential genres command premium ad rates.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartAffinity rdf:type rdf:Property ;
    rdfs:label 'Daypart Affinity' ;
    rdfs:comment 'Comma-separated list of broadcast dayparts where this genre typically performs best (e.g., prime_time, late_night, early_morning, daytime, weekend). Informs program scheduling and playout automation strategies.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eidrGenreMapping rdf:type rdf:Property ;
    rdfs:label 'Eidr Genre Mapping' ;
    rdfs:comment 'Mapping to Entertainment Identifier Registry (EIDR) genre taxonomy for cross-industry content identification and rights management interoperability.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastChannelApplicability rdf:type rdf:Property ;
    rdfs:label 'Fast Channel Applicability' ;
    rdfs:comment 'Indicates whether this genre is suitable for Free Ad-Supported Streaming Television (FAST) linear channel programming. FAST channels require genres with deep catalog availability and consistent audience appeal.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genreCode rdf:type rdf:Property ;
    rdfs:label 'Genre Code' ;
    rdfs:comment 'Short alphanumeric code representing the genre for system integration and Electronic Program Guide (EPG) feeds. Used as a business key across scheduling, distribution, and metadata systems.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreDescription rdf:type rdf:Property ;
    rdfs:label 'Genre Description' ;
    rdfs:comment 'Detailed textual description of the genre, including defining characteristics, typical content examples, and audience expectations. Used for editorial guidance and content acquisition briefings.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreName rdf:type rdf:Property ;
    rdfs:label 'Genre Name' ;
    rdfs:comment 'Full display name of the genre as presented to audiences in Electronic Program Guides (EPG), streaming platform interfaces, and content discovery systems.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreTier rdf:type rdf:Property ;
    rdfs:label 'Genre Tier' ;
    rdfs:comment 'Hierarchical level of the genre within the taxonomy. Primary represents top-level genres, secondary represents sub-genres, and tertiary represents granular classifications.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestrictionApplicability rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction Applicability' ;
    rdfs:comment 'Indicates whether content in this genre is subject to geographic blackout restrictions or regional licensing constraints. Common for sports genres with territorial rights and retransmission consent agreements.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iabContentCategory rdf:type rdf:Property ;
    rdfs:label 'Iab Content Category' ;
    rdfs:comment 'Mapping to Interactive Advertising Bureau (IAB) content taxonomy for programmatic advertising and contextual ad targeting. Enables Share of Voice (SOV) optimization and Cost Per Mille (CPM) rate alignment.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linearBroadcastSuitability rdf:type rdf:Property ;
    rdfs:label 'Linear Broadcast Suitability' ;
    rdfs:comment 'Indicates whether this genre is suitable for traditional linear scheduled broadcasting. Some genres (e.g., interactive, choose-your-own-adventure) are non-linear only.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localizationPriority rdf:type rdf:Property ;
    rdfs:label 'Localization Priority' ;
    rdfs:comment 'Priority level for content localization (dubbing, subtitling, cultural adaptation) for this genre. High-priority genres justify investment in multi-language versions for international distribution.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataEnrichmentPriority rdf:type rdf:Property ;
    rdfs:label 'Metadata Enrichment Priority' ;
    rdfs:comment 'Priority level for metadata enrichment and tagging in Media Asset Management (MAM) systems. Critical genres require comprehensive metadata for content discovery and personalization.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpaRatingApplicability rdf:type rdf:Property ;
    rdfs:label 'Mpa Rating Applicability' ;
    rdfs:comment 'Comma-separated list of Motion Picture Association (MPA) ratings typically associated with this genre (e.g., G, PG, PG-13, R, NC-17). Used for content clearance and daypart scheduling compliance.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenGenreCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Genre Code' ;
    rdfs:comment 'Nielsen Media Research genre classification code used for audience measurement, ratings analysis, and Gross Rating Point (GRP) reporting alignment.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ottPlatformPriority rdf:type rdf:Property ;
    rdfs:label 'Ott Platform Priority' ;
    rdfs:comment 'Priority level for featuring this genre on Over-The-Top (OTT) streaming platforms and Video On Demand (VOD) services. High priority genres receive prominent placement in content discovery and recommendation engines.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalGuidanceFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Guidance Flag' ;
    rdfs:comment 'Indicates whether content in this genre typically requires parental guidance warnings or viewer discretion advisories. Used for compliance with Federal Communications Commission (FCC) broadcast standards and Children\'s Online Privacy Protection Act (COPPA) requirements.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:svodPerformanceTier rdf:type rdf:Property ;
    rdfs:label 'Svod Performance Tier' ;
    rdfs:comment 'Performance classification for this genre on Subscription Video On Demand (SVOD) platforms. Premium genres drive subscriber acquisition and reduce churn rate; catalog genres provide library depth.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationEligibility rdf:type rdf:Property ;
    rdfs:label 'Syndication Eligibility' ;
    rdfs:comment 'Indicates whether content in this genre is typically eligible for syndication to multiple outlets and resale. Used in rights and royalties management and windowing strategy planning.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Notes' ;
    rdfs:comment 'Internal notes and guidelines for content producers, schedulers, and metadata specialists on proper application of this genre classification. Includes edge cases and disambiguation rules.' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingId rdf:type rdf:Property ;
    rdfs:label 'Rating Id' ;
    rdfs:comment 'Primary key for rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'The current status of any appeal filed by the content producer or distributor to challenge or modify the assigned rating classification.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:body rdf:type rdf:Property ;
    rdfs:label 'Body' ;
    rdfs:comment 'The official name of the regulatory or industry body that issued the rating (e.g., Motion Picture Association, TV Parental Guidelines Monitoring Board, British Board of Film Classification, Freiwillige Selbstkontrolle der Filmwirtschaft).' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'The unique certificate or reference number issued by the rating body upon classification approval. Used for audit and compliance verification.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDescriptorDrugUse rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Drug Use' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for drug use or substance abuse.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorFear rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Fear' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for frightening or intense scenes that may be unsuitable for younger audiences.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorLanguage rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Language' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for strong or offensive language.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorNudity rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Nudity' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for nudity or sexual content.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorViolence rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Violence' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for violence or intense action.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumAge rdf:type rdf:Property ;
    rdfs:label 'Minimum Age' ;
    rdfs:comment 'The minimum recommended or legally mandated age (in years) for viewers of content with this rating. Null if no specific age restriction applies.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentalControlEnabled rdf:type rdf:Property ;
    rdfs:label 'Parental Control Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this rating is used to enforce parental control features on linear broadcast, OTT (Over-The-Top), or MVPD (Multichannel Video Programming Distributor) platforms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingCode rdf:type rdf:Property ;
    rdfs:label 'Rating Code' ;
    rdfs:comment 'The official rating classification code assigned to the content (e.g., G, PG, PG-13, R, NC-17 for MPA film ratings; TV-Y, TV-Y7, TV-G, TV-PG, TV-14, TV-MA for TV Parental Guidelines; or international equivalents such as BBFC, FSK, OFLC codes). [ENUM-REF-CANDIDATE: G|PG|PG-13|R|NC-17|TV-Y|TV-Y7|TV-G|TV-PG|TV-14|TV-MA — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingDescription rdf:type rdf:Property ;
    rdfs:label 'Rating Description' ;
    rdfs:comment 'Detailed textual description of the rating, including the rationale for the classification and any additional context provided by the rating body (e.g., \'Rated PG-13 for intense sequences of violence and action, some suggestive content, and brief strong language\').' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Boolean flag indicating whether the rating is legally mandated by a regulatory body (e.g., FCC, Ofcom) or is a voluntary industry classification.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The date on which the content was submitted to the rating body for classification review.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:system rdf:type rdf:Property ;
    rdfs:label 'System' ;
    rdfs:comment 'The rating system or classification framework under which the rating was assigned (e.g., MPA for Motion Picture Association, TVPG for TV Parental Guidelines, BBFC for British Board of Film Classification, FSK for Freiwillige Selbstkontrolle der Filmwirtschaft, OFLC for Australian Classification Board, CBFC for Central Board of Film Certification India).' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationId rdf:type rdf:Property ;
    rdfs:label 'Localization Id' ;
    rdfs:comment 'Unique identifier for the localization work product record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Localization .

ind:accountsPayableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Payable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_payable. Business justification: Localization vendors (dubbing studios, subtitle houses) are paid via accounts payable. localization has purchase_order_number as a plain attribute indicating AP linkage. Direct FK supports vendor paym' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsPayable .

ind:localizedAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Localized Asset Version Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_version. Business justification: A localization order produces a specific asset_version (dubbed or subtitled rendition). QC and platform delivery workflows require linking the localization record to the exact technical rendition for ' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:localizedMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Localized Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Localized audio tracks and subtitle files are delivered as media assets. Distribution workflows require linking localization records to their delivered asset files for QC, versioning, and platform del' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:titleVersionId rdf:type rdf:Property ;
    rdfs:label 'Title Version Id' ;
    rdfs:comment 'Reference to the specific title version being localized.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:voiceTalentProfileId rdf:type rdf:Property ;
    rdfs:label 'Voice Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: Dubbing and voice localization require tracking which talent performed the localized version for residual payments, credit attribution, and guild reporting. Essential for international content distrib' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:accessibilityStandardMet rdf:type rdf:Property ;
    rdfs:label 'Accessibility Standard Met' ;
    rdfs:comment 'Specific accessibility standard that the localization work product complies with (e.g., WCAG 2.1 AA, FCC CVAA).' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the localization work product received final approval for distribution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the individual or role who provided final approval for the localization work product.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetFilePath rdf:type rdf:Property ;
    rdfs:label 'Asset File Path' ;
    rdfs:comment 'Storage location or URI path to the delivered localization asset file in the Media Asset Management (MAM) system or Content Delivery Network (CDN).' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characterCount rdf:type rdf:Property ;
    rdfs:label 'Character Count' ;
    rdfs:comment 'Total number of characters in the subtitle or metadata translation work product, used for billing and capacity planning.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Flag' ;
    rdfs:comment 'Indicates whether the localization meets regulatory compliance requirements for the target territory (e.g., local content quotas, language laws, accessibility standards).' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localizationStatus rdf:type rdf:Property ;
    rdfs:label 'Localization Status' ;
    rdfs:comment 'Current workflow status of the localization work product. [ENUM-REF-CANDIDATE: ordered|in_progress|delivered|qc_review|approved|rejected|revision_required — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationType rdf:type rdf:Property ;
    rdfs:label 'Localization Type' ;
    rdfs:comment 'The type of localization work being performed on the content asset.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Date when the localization work was ordered from the vendor or internal team.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcReviewDate rdf:type rdf:Property ;
    rdfs:label 'Qc Review Date' ;
    rdfs:comment 'Date when quality control review of the localization work product was completed.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcReviewerName rdf:type rdf:Property ;
    rdfs:label 'Qc Reviewer Name' ;
    rdfs:comment 'Name of the individual or team who performed the quality control review.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Business reason or description for why a revision of the localization work product was required.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Contractually agreed or planned delivery date for the completed localization work product.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subtitleFormat rdf:type rdf:Property ;
    rdfs:label 'Subtitle Format' ;
    rdfs:comment 'Technical format specification for subtitle files (SRT, TTML, WebVTT, etc.). [ENUM-REF-CANDIDATE: SRT|TTML|WebVTT|EBU-STL|SMPTE-TT|SCC|DFXP — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Target Language Code' ;
    rdfs:comment 'ISO 639 language code for the target localization language (e.g., es-MX for Mexican Spanish, fr-CA for Canadian French).' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Target Territory Code' ;
    rdfs:comment 'ISO 3166 three-letter country code representing the target distribution territory for this localization.' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentCreditId rdf:type rdf:Property ;
    rdfs:label 'Talent Credit Id' ;
    rdfs:comment 'Unique identifier for the talent credit record. Primary key for the talent credit association entity.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingPosition rdf:type rdf:Property ;
    rdfs:label 'Billing Position' ;
    rdfs:comment 'The ordinal position of the talent in the credit sequence, determining the order in which credits are displayed. Lower numbers indicate higher prominence (e.g., 1 = top billing). Used for EPG display and contractual compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Credit Approval Date' ;
    rdfs:comment 'The date on which the credit was officially approved for publication. Used for audit trails and compliance with guild credit determination timelines.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Approval Status' ;
    rdfs:comment 'Current approval state of the credit. Pending indicates awaiting review; Approved indicates credit is finalized and ready for publication; Disputed indicates a challenge has been raised; Rejected indicates credit was not approved; Arbitration indicates the credit is under formal guild arbitration process.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCategory rdf:type rdf:Property ;
    rdfs:label 'Credit Category' ;
    rdfs:comment 'High-level categorization of the credit by functional area or department. Used for grouping credits in EPG displays, streaming platform interfaces, and analytics. [ENUM-REF-CANDIDATE: cast|director|producer|writer|cinematography|editing|music|sound|production_design|costume|makeup|visual_effects|executive|other — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditDisplayName rdf:type rdf:Property ;
    rdfs:label 'Credit Display Name' ;
    rdfs:comment 'The exact name as it should appear in credits, EPG metadata, and streaming platform displays. May differ from the talents legal name if a pseudonym or stage name is used. This is the authoritative display value for all public-facing credit presentations.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditDisplayOrder rdf:type rdf:Property ;
    rdfs:label 'Credit Display Order' ;
    rdfs:comment 'The sequence number for displaying this credit within its credit type or section (e.g., within the cast section or crew section). Used for rendering credits in EPG, streaming platforms, and promotional materials.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Credit End Timestamp' ;
    rdfs:comment 'The timestamp marking when this credit ceases to be effective or visible. Nullable for credits that remain active indefinitely. Used for managing credit corrections, disputes, or contractual credit windows.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditNotes rdf:type rdf:Property ;
    rdfs:label 'Credit Notes' ;
    rdfs:comment 'Free-text field for additional context, special credit requirements, contractual stipulations, or notes related to credit disputes, arbitration outcomes, or special billing arrangements.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Credit Start Timestamp' ;
    rdfs:comment 'The timestamp marking when this credit becomes effective or visible in EPG and streaming platform metadata. Used for managing credit changes over time and versioning.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditType rdf:type rdf:Property ;
    rdfs:label 'Credit Type' ;
    rdfs:comment 'Classification of the credit based on how the talent contribution is presented. On-screen credits appear in the visual content; off-screen credits appear in end titles or metadata only; voice credits are for voice-over or dubbing; stunt credits are for stunt performers; archive credits are for archival footage appearances.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pseudonymFlag rdf:type rdf:Property ;
    rdfs:label 'Pseudonym Flag' ;
    rdfs:comment 'Indicates whether the talent is credited under a pseudonym or stage name rather than their legal name. True if pseudonym is used; False if legal name is used. Relevant for guild compliance and contractual credit requirements.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualsEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Residuals Eligibility Flag' ;
    rdfs:comment 'Indicates whether this credit qualifies the talent for residual payments based on content reuse, syndication, or secondary distribution. True if eligible; False otherwise. Triggers residuals calculation workflows in the rights and royalties domain.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionAffiliationFlag rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation Flag' ;
    rdfs:comment 'Indicates whether the talent is affiliated with a recognized industry union (SAG-AFTRA, DGA, WGA, IATSE) for this credit. True if union-affiliated; False otherwise. Used for residuals eligibility determination and compliance reporting.' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acquisitionId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Id' ;
    rdfs:comment 'Primary key for acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Acquisition .

ind:acquiredMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Acquired Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Content acquisition workflows require reconciling the acquired deliverable (physical or digital) with its MAM record. Acquisition-to-asset traceability is mandatory for rights clearance audits, paymen' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:payableInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Payable Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Content acquisition deals generate payable invoices to rights holders. Accounts payable teams track which invoices correspond to acquisition agreements for payment scheduling, rights verification, cos' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:acquisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Acquisition Status' ;
    rdfs:comment 'Current lifecycle state of the acquisition. Negotiating = deal in discussion; Committed = contract signed but content not yet delivered; Delivered = content received and ingested; Active = content in use; Cancelled = deal terminated before delivery; Expired = license period ended.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionType rdf:type rdf:Property ;
    rdfs:label 'Acquisition Type' ;
    rdfs:comment 'Classification of the acquisition method. Purchase = outright ownership transfer; License = time-limited rights; Co-production = joint production investment; Commission = original content commissioned from producer; Barter = content exchanged for advertising inventory; Syndication = content licensed from syndicator for regional broadcast.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillaryRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Ancillary Rights Flag' ;
    rdfs:comment 'Indicates whether ancillary rights (merchandising, soundtrack, publishing, remake, sequel, spin-off, clip licensing) are included in the acquisition (True) or retained by the supplier (False).' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Status' ;
    rdfs:comment 'Rights verification status confirming that all necessary clearances (music rights, talent rights, third-party content, trademarks) have been obtained for broadcast or distribution. Pending = verification in progress; Cleared = all rights confirmed; Restricted = partial clearance with limitations; Failed = clearance issues prevent exploitation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentWindowType rdf:type rdf:Property ;
    rdfs:label 'Content Window Type' ;
    rdfs:comment 'The distribution window or rights category acquired. Windowing refers to the sequential release strategy where content is made available through different channels over time. Theatrical = cinema release; Home Video = physical/digital sell-through; SVOD = Subscription Video On Demand; AVOD = Advertising-Supported Video On Demand; TVOD = Transactional Video On Demand; Linear Broadcast = traditional scheduled TV; Syndication = resale to multiple outlets; All Rights = comprehensive rights across all windows. [ENUM-REF-CANDIDATE: theatrical|home_video|svod|avod|tvod|linear_broadcast|syndication|all_rights — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the acquisition cost amount (e.g., USD, GBP, EUR, JPY).' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFormat rdf:type rdf:Property ;
    rdfs:label 'Delivery Format' ;
    rdfs:comment 'The technical format and delivery method used by the supplier to provide the content. Examples: ProRes 422 HQ via FTP, IMF package via Aspera, DCP hard drive, MPEG-4 via CDN, tape (legacy).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatRights rdf:type rdf:Property ;
    rdfs:label 'Format Rights' ;
    rdfs:comment 'The technical formats or delivery specifications covered by the acquisition. May include SD, HD, 4K, HDR, theatrical DCP, broadcast master, streaming-optimized, etc. Defines the quality and format tiers the enterprise is authorized to distribute.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageRights rdf:type rdf:Property ;
    rdfs:label 'Language Rights' ;
    rdfs:comment 'The languages or language versions for which rights were acquired. May specify original language only, dubbed versions, subtitled versions, or all language adaptations. Examples: English, Spanish, French; All Languages; Original + Subtitles.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseEndDate rdf:type rdf:Property ;
    rdfs:label 'License End Date' ;
    rdfs:comment 'The date on which the acquired content rights expire and the enterprise must cease exploitation. Null for perpetual purchases. For time-limited licenses, this defines the end of the license term.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseStartDate rdf:type rdf:Property ;
    rdfs:label 'License Start Date' ;
    rdfs:comment 'The date from which the enterprise is authorized to begin exploiting the acquired content rights. For licenses, this is the effective start of the license term; for purchases, typically the acquisition date.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'External business identifier for this acquisition transaction. May be a purchase order number, deal reference, or contract line item identifier used in communications with the supplier.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualsObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Residuals Obligation Flag' ;
    rdfs:comment 'Indicates whether the enterprise has an obligation to pay residuals (talent reuse payments) to performers, writers, directors, or other rights holders each time the content is rebroadcast or redistributed (True) or if residuals are the supplier\'s responsibility (False).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percent' ;
    rdfs:comment 'The percentage of revenue or receipts that must be paid to the supplier as ongoing royalties under a revenue-sharing acquisition model. Null if the acquisition is a flat-fee structure with no revenue share.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runsAllowed rdf:type rdf:Property ;
    rdfs:label 'Runs Allowed' ;
    rdfs:comment 'The maximum number of times the content may be broadcast or streamed under the acquisition agreement. Common in linear broadcast licenses (e.g., 3 runs over 2 years). Null indicates unlimited runs within the license period.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runsConsumed rdf:type rdf:Property ;
    rdfs:label 'Runs Consumed' ;
    rdfs:comment 'The number of runs (broadcasts or streams) that have been executed to date against the runs_allowed limit. Tracked to ensure compliance with contractual run restrictions.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sublicensingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Allowed Flag' ;
    rdfs:comment 'Indicates whether the enterprise is permitted to sublicense the acquired content to third parties (True) or must exploit the content directly only (False). Sublicensing enables syndication and secondary distribution deals.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windowingPlanId rdf:type rdf:Property ;
    rdfs:label 'Windowing Plan Id' ;
    rdfs:comment 'Unique identifier for the windowing plan record. Primary key for the windowing plan entity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WindowingPlan .

ind:governingLicenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Governing License Agreement Id' ;
    rdfs:comment 'Foreign key linking to rights.license_agreement. Business justification: Windowing strategies must comply with license agreement terms (holdbacks, exclusivity windows, platform restrictions). Windowing plan validation and conflict detection require checking against the gov' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:marketingCampaignId rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Id' ;
    rdfs:comment 'Reference identifier for the marketing campaign associated with this window release. Links to promotional activities, advertising spend, and audience acquisition efforts.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:abrEnabled rdf:type rdf:Property ;
    rdfs:label 'Abr Enabled' ;
    rdfs:comment 'Indicates whether adaptive bitrate streaming is enabled for this window, allowing dynamic quality adjustment based on viewer bandwidth. True=ABR enabled, False=fixed bitrate.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutRestrictions rdf:type rdf:Property ;
    rdfs:label 'Blackout Restrictions' ;
    rdfs:comment 'Geographic or temporal blackout rules that restrict content availability in specific regions or time periods within the territory (e.g., sports blackouts, regional exclusions).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleEligibility rdf:type rdf:Property ;
    rdfs:label 'Bundle Eligibility' ;
    rdfs:comment 'Indicates whether this content is eligible for inclusion in subscription bundles or multi-title packages during this window. True=bundle eligible, False=standalone only.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concurrentStreamsLimit rdf:type rdf:Property ;
    rdfs:label 'Concurrent Streams Limit' ;
    rdfs:comment 'Maximum number of simultaneous streams allowed per subscriber account for this content in this window. Used for subscription service tier management.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentFormat rdf:type rdf:Property ;
    rdfs:label 'Content Format' ;
    rdfs:comment 'The technical format specification for content delivery in this window. SD=standard definition, HD=high definition 1080p, 4K=ultra high definition, 8K=8K resolution, HDR=high dynamic range, Dolby Vision=premium HDR format.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartRestriction rdf:type rdf:Property ;
    rdfs:label 'Daypart Restriction' ;
    rdfs:comment 'Time-of-day broadcast restrictions for linear windows, defining when content may air (e.g., prime time only, late night only, daytime safe). Applies primarily to linear broadcast and cable windows.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadToGoEnabled rdf:type rdf:Property ;
    rdfs:label 'Download To Go Enabled' ;
    rdfs:comment 'Indicates whether offline download capability is enabled for this window, allowing viewers to download content for offline viewing. True=downloads allowed, False=streaming only.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dubbingAvailability rdf:type rdf:Property ;
    rdfs:label 'Dubbing Availability' ;
    rdfs:comment 'Indicates whether dubbed audio tracks in alternate languages are available for this window release. True=dubbing provided, False=original language only.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityTier rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Tier' ;
    rdfs:comment 'The level of exclusivity granted to the platform during this window. Exclusive=sole distribution rights, Non-Exclusive=concurrent availability on multiple platforms, Shared Exclusive=limited to a defined group of platforms, First Run=premiere window, Second Run=subsequent availability.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackDurationDays rdf:type rdf:Property ;
    rdfs:label 'Holdback Duration Days' ;
    rdfs:comment 'The number of days between the close of the previous window and the open of this window, representing the exclusivity period or gap between release phases.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Planned Close Date' ;
    rdfs:comment 'The intended end date when the content will no longer be available on the specified platform/channel in the specified territory. Nullable for open-ended windows.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedOpenDate rdf:type rdf:Property ;
    rdfs:label 'Planned Open Date' ;
    rdfs:comment 'The intended start date when the content becomes available on the specified platform/channel in the specified territory. Represents the editorial/commercial release plan.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricePoint rdf:type rdf:Property ;
    rdfs:label 'Price Point' ;
    rdfs:comment 'The consumer-facing price for transactional windows (TVOD, EST, PPV) in the specified currency. Represents the retail price charged to end viewers.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Pricing Flag' ;
    rdfs:comment 'Indicates whether promotional or discounted pricing is applied for this window. True=promotional pricing active, False=standard pricing.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Model' ;
    rdfs:comment 'The monetization approach for this window. Subscription=SVOD model, Advertising=AVOD model, Transactional=TVOD/PPV/EST, Hybrid=combination of models, Free=no direct revenue.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleAvailability rdf:type rdf:Property ;
    rdfs:label 'Subtitle Availability' ;
    rdfs:comment 'Indicates whether subtitles or closed captions are available for this window release. True=subtitles provided, False=no subtitles.' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:viewingWindowHours rdf:type rdf:Property ;
    rdfs:label 'Viewing Window Hours' ;
    rdfs:comment 'For TVOD/rental windows, the number of hours a viewer has to complete watching the content after initiating playback (e.g., 48-hour rental window).' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Window Sequence Number' ;
    rdfs:comment 'Sequential ordering of this window within the overall release strategy for the content. Lower numbers indicate earlier windows (e.g., 1=theatrical, 2=SVOD, 3=AVOD).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metadataProfileId rdf:type rdf:Property ;
    rdfs:label 'Metadata Profile Id' ;
    rdfs:comment 'Unique identifier for the metadata profile record. Primary key.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Delivery Asset Version Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_version. Business justification: Platform-specific metadata profiles are validated against the specific asset_version being delivered to that platform. Platform delivery validation workflows require this link to confirm metadata comp' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:previewMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Preview Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Metadata packages for platform delivery often include preview clips or thumbnail assets. Distribution systems require linking metadata profiles to their associated preview/promo assets for bundled del' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:castSummary rdf:type rdf:Property ;
    rdfs:label 'Cast Summary' ;
    rdfs:comment 'Summarized list of principal cast members and their roles. Used for promotional materials and EPG (Electronic Program Guide) displays where full cast lists are impractical.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directorCredit rdf:type rdf:Property ;
    rdfs:label 'Director Credit' ;
    rdfs:comment 'Name(s) of the director(s) of the content. Used for attribution, promotional materials, and search/discovery.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributor rdf:type rdf:Property ;
    rdfs:label 'Distributor' ;
    rdfs:comment 'Name of the distributor responsible for delivering the content to platforms and audiences. Used for rights management and business intelligence.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keywordTags rdf:type rdf:Property ;
    rdfs:label 'Keyword Tags' ;
    rdfs:comment 'Comma-separated list of keyword tags for content discovery, search indexing, and recommendation engines. Includes themes, topics, moods, and contextual descriptors.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longSynopsis rdf:type rdf:Property ;
    rdfs:label 'Long Synopsis' ;
    rdfs:comment 'Extended narrative description of the content title. Typically 200-500 words, used for detailed program guides, press releases, and promotional materials.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataLanguage rdf:type rdf:Property ;
    rdfs:label 'Metadata Language' ;
    rdfs:comment 'ISO 639 language code (2 or 3 letters) with optional ISO 3166 country code for the language in which this metadata profile is written. Examples: en, en-US, fr, es-MX.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataStandard rdf:type rdf:Property ;
    rdfs:label 'Metadata Standard' ;
    rdfs:comment 'The metadata standard or schema used for this profile. Defines the structure and vocabulary of the metadata package.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User or system identifier of the person or process that last modified this metadata profile. Used for audit trails and accountability.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalGuidanceNotes rdf:type rdf:Property ;
    rdfs:label 'Parental Guidance Notes' ;
    rdfs:comment 'Detailed notes explaining the content rating, including specific content descriptors (violence, language, sexual content, etc.). Used for parental controls and compliance.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformSpecificCode rdf:type rdf:Property ;
    rdfs:label 'Platform Specific Code' ;
    rdfs:comment 'Unique identifier assigned by the target platform for this metadata profile. Used for cross-referencing and reconciliation with external systems.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posterUrl rdf:type rdf:Property ;
    rdfs:label 'Poster Url' ;
    rdfs:comment 'URL (Uniform Resource Locator) to the poster or cover art image associated with this metadata profile. Used for streaming platform UI, marketing, and promotional materials.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalTagline rdf:type rdf:Property ;
    rdfs:label 'Promotional Tagline' ;
    rdfs:comment 'Short, catchy promotional phrase or slogan used in marketing campaigns, social media, and advertising. Typically 10-30 words.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runtimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Runtime Minutes' ;
    rdfs:comment 'Total runtime of the content in minutes. Used for scheduling, EPG (Electronic Program Guide) display, and audience planning.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shortSynopsis rdf:type rdf:Property ;
    rdfs:label 'Short Synopsis' ;
    rdfs:comment 'Brief narrative description of the content title. Typically 50-150 words, used for EPG (Electronic Program Guide) listings, mobile apps, and quick reference.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'URL (Uniform Resource Locator) to the thumbnail image associated with this metadata profile. Used for EPG (Electronic Program Guide) display, streaming platform UI, and promotional materials.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerUrl rdf:type rdf:Property ;
    rdfs:label 'Trailer Url' ;
    rdfs:comment 'URL (Uniform Resource Locator) to the trailer or preview video associated with this content. Used for promotional campaigns and streaming platform previews.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrors rdf:type rdf:Property ;
    rdfs:label 'Validation Errors' ;
    rdfs:comment 'Detailed list of validation errors or warnings encountered during metadata quality checks. Used for troubleshooting and metadata remediation.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Result of automated or manual validation checks against the target metadata standard. Indicates whether the profile meets all required schema and business rules.' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artworkId rdf:type rdf:Property ;
    rdfs:label 'Artwork Id' ;
    rdfs:comment 'Unique identifier for the artwork asset record. Primary key for the artwork catalog.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedForUseFlag rdf:type rdf:Property ;
    rdfs:label 'Approved For Use Flag' ;
    rdfs:comment 'Boolean indicator of whether the artwork has passed legal, brand, and creative approval processes and is authorized for public distribution. True indicates approved and ready for use, False indicates pending approval or rejected.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:artworkType rdf:type rdf:Property ;
    rdfs:label 'Artwork Type' ;
    rdfs:comment 'Classification of the artwork asset by its intended use and format. Key-art is primary promotional image, thumbnail for Electronic Program Guide (EPG) and streaming UI, banner for web headers, poster for theatrical/retail, logo for branding, still for scene captures.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorProfile rdf:type rdf:Property ;
    rdfs:label 'Color Profile' ;
    rdfs:comment 'Color space standard applied to the artwork for accurate color reproduction across devices and platforms. sRGB for web/digital, Adobe RGB for professional photography, CMYK for print, Rec. 709 for HD broadcast, Rec. 2020 for Ultra HD (UHD) broadcast.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingDisplayedFlag rdf:type rdf:Property ;
    rdfs:label 'Content Rating Displayed Flag' ;
    rdfs:comment 'Boolean indicator of whether the artwork includes a visible Motion Picture Association (MPA) or equivalent content rating badge (G, PG, PG-13, R, NC-17, TV-Y, TV-PG, TV-14, TV-MA). True indicates rating is burned into the image, False indicates clean artwork without rating overlay.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which the artwork rights or usage authorization expires and the asset should no longer be used for promotional or distribution purposes. Supports rights management and holdback compliance. Nullable for perpetual-use artwork. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:heightPixels rdf:type rdf:Property ;
    rdfs:label 'Height Pixels' ;
    rdfs:comment 'Vertical dimension of the artwork image measured in pixels. Used to determine display suitability and resolution quality for various distribution channels.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageOverlayFlag rdf:type rdf:Property ;
    rdfs:label 'Language Overlay Flag' ;
    rdfs:comment 'Boolean indicator of whether the artwork contains burned-in text, titles, or language-specific graphic elements. True indicates localized artwork requiring territory-specific versions, False indicates language-neutral artwork suitable for all markets.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photographerCredit rdf:type rdf:Property ;
    rdfs:label 'Photographer Credit' ;
    rdfs:comment 'Name or attribution of the photographer, artist, or creative agency responsible for creating the artwork. Used for copyright attribution, residuals tracking, and legal compliance with talent agreements.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDpi rdf:type rdf:Property ;
    rdfs:label 'Resolution Dpi' ;
    rdfs:comment 'Image resolution measured in dots per inch. 72 DPI for web/screen display, 300 DPI for high-quality print, 150 DPI for standard print. Critical for determining print suitability and image quality.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Unique identifier or reference key for the artwork asset in the originating source system. Enables traceability and synchronization with upstream Digital Asset Management (DAM) or creative management platforms.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRights rdf:type rdf:Property ;
    rdfs:label 'Usage Rights' ;
    rdfs:comment 'Scope of authorized usage channels and media types for the artwork. All-media for unrestricted use, digital-only for Over-The-Top (OTT) and web, print-only for press kits and retail, broadcast-only for linear television, theatrical-only for cinema, promotional-only for advertising and marketing campaigns.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthPixels rdf:type rdf:Property ;
    rdfs:label 'Width Pixels' ;
    rdfs:comment 'Horizontal dimension of the artwork image measured in pixels. Used to determine display suitability and resolution quality for various distribution channels.' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tagId rdf:type rdf:Property ;
    rdfs:label 'Tag Id' ;
    rdfs:comment 'Primary key for tag' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentTagId rdf:type rdf:Property ;
    rdfs:label 'Parent Tag Id' ;
    rdfs:comment 'Reference to a parent tag in a hierarchical taxonomy structure. Enables multi-level tag classification (e.g., \'Action\' as parent, \'Car Chase\' as child). Null for top-level tags.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tag .

ind:advertiserSafe rdf:type rdf:Property ;
    rdfs:label 'Advertiser Safe' ;
    rdfs:comment 'Indicates whether content with this tag is suitable for advertising placement according to brand safety guidelines. False may indicate sensitive or controversial content that requires restricted ad inventory.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliedDate rdf:type rdf:Property ;
    rdfs:label 'Applied Date' ;
    rdfs:comment 'Date when the tag was first applied to the content asset. Tracks the temporal evolution of content metadata and editorial curation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Confidence level for algorithmically-generated tags, expressed as a decimal between 0.0000 and 1.0000. A score of 1.0000 indicates highest confidence. Null for manually-applied editorial tags.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Depth level of this tag within a hierarchical taxonomy structure. Level 1 represents top-level categories, with increasing numbers indicating deeper nesting. Supports faceted navigation and drill-down discovery.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDisplayable rdf:type rdf:Property ;
    rdfs:label 'Is Displayable' ;
    rdfs:comment 'Indicates whether this tag should be displayed to end users in content detail pages, Electronic Program Guides (EPG), or Over-The-Top (OTT) platform interfaces. Some tags are for backend analytics only.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSearchable rdf:type rdf:Property ;
    rdfs:label 'Is Searchable' ;
    rdfs:comment 'Indicates whether this tag should be indexed and surfaced in user-facing search interfaces. Some tags may be used for internal classification or algorithmic purposes only.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tagSource rdf:type rdf:Property ;
    rdfs:label 'Tag Source' ;
    rdfs:comment 'Origin of the tag assignment. Indicates whether the tag was applied by internal editorial staff, generated by machine learning algorithms, provided by a content partner or rights holder, contributed by users, or supplied by the production team.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagType rdf:type rdf:Property ;
    rdfs:label 'Tag Type' ;
    rdfs:comment 'Category of the tag applied to the content. Defines the semantic purpose of the tag (e.g., mood for emotional tone, theme for subject matter, setting for location context, era for time period, franchise for brand universe, content_warning for viewer advisories, editorial_collection for curated groupings, campaign for promotional initiatives). [ENUM-REF-CANDIDATE: mood|theme|setting|era|franchise|universe|content_warning|editorial_collection|campaign|keyword — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagValue rdf:type rdf:Property ;
    rdfs:label 'Tag Value' ;
    rdfs:comment 'The specific controlled vocabulary term or label applied to the content. Examples: \'suspenseful\', \'family-friendly\', \'urban\', \'1980s\', \'Marvel Cinematic Universe\', \'violence\', \'holiday-special\', \'summer-blockbuster\'.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxonomyVersion rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Version' ;
    rdfs:comment 'Version number of the external taxonomy or controlled vocabulary system referenced by taxonomy_id. Tracks schema evolution and ensures backward compatibility.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageContext rdf:type rdf:Property ;
    rdfs:label 'Usage Context' ;
    rdfs:comment 'Primary business context or application domain for which this tag is intended. Defines how the tag should be leveraged across the content lifecycle (e.g., recommendation engines, contextual advertising targeting, editorial curation, regulatory compliance reporting).' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weight rdf:type rdf:Property ;
    rdfs:label 'Weight' ;
    rdfs:comment 'Relative importance or prominence of this tag for the content asset, expressed as a decimal between 0.0000 and 1.0000. Higher weights indicate more central or defining characteristics. Used to prioritize tags in recommendation and discovery algorithms.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rightsHolderId rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Id' ;
    rdfs:comment 'Foreign key linking to rights.holder. Business justification: Packages have a rights holder governing royalty and clearance obligations. Package has rights_holder as a denormalized plain text attribute. Proper FK to holder master is required for royalty manageme' ;
    rdfs:domain ind:Package ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:commercialContext rdf:type rdf:Property ;
    rdfs:label 'Commercial Context' ;
    rdfs:comment 'Free-text description of the business purpose or deal context for which the package was assembled, such as upfront sales event, scatter market offering, MVPD (Multichannel Video Programming Distributor) carriage negotiation, or international syndication deal.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Drm Required Flag' ;
    rdfs:comment 'Indicates whether Digital Rights Management (DRM) protection is required for distribution of this package (True/False). Critical for rights enforcement and anti-piracy compliance.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePrimary rdf:type rdf:Property ;
    rdfs:label 'Language Primary' ;
    rdfs:comment 'The primary language of the content in the package, expressed as ISO 639-2 three-letter language code (e.g., eng, spa, fra). Critical for localization and international distribution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'The externally-known unique business identifier or code for the package used in contracts, invoicing, and distribution systems.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageDescription rdf:type rdf:Property ;
    rdfs:label 'Package Description' ;
    rdfs:comment 'A detailed narrative description of the package content, target audience, and commercial positioning. Used for marketing, sales proposals, and catalog listings.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageName rdf:type rdf:Property ;
    rdfs:label 'Package Name' ;
    rdfs:comment 'The business name or title of the content package as recognized in commercial agreements and distribution deals.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the package: draft (under construction), active (available for distribution), suspended (temporarily unavailable), expired (past effective period), terminated (cancelled before expiry), or archived (historical record).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'The classification of the package based on its commercial or distribution purpose: syndication (content resale to multiple outlets), SVOD (Subscription Video On Demand) library (subscription-based catalog), AVOD (Advertising-Supported Video On Demand) catalog (ad-supported offering), FAST (Free Ad-Supported Streaming Television) channel (linear streaming channel), educational (academic or training content bundle), or international (cross-border distribution bundle).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRuntimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Runtime Hours' ;
    rdfs:comment 'The aggregate runtime of all content in the package, expressed in hours. Used for programming and scheduling calculations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTitleCount rdf:type rdf:Property ;
    rdfs:label 'Total Title Count' ;
    rdfs:comment 'The total number of distinct titles (episodes, films, clips, or other content assets) included in the package. Used for inventory reporting and deal valuation.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valueUsd rdf:type rdf:Property ;
    rdfs:label 'Value Usd' ;
    rdfs:comment 'The estimated or contracted commercial value of the package in United States Dollars (USD). Used for revenue forecasting, deal valuation, and financial reporting.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'Annual regulatory fee assessed by the governing authority for maintaining this broadcast license.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:antennaHeightMeters rdf:type rdf:Property ;
    rdfs:label 'Antenna Height Meters' ;
    rdfs:comment 'Height of the transmitting antenna above average terrain, measured in meters. Critical factor in determining coverage area.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:broadcastLicenseStatus rdf:type rdf:Property ;
    rdfs:label 'Broadcast License Status' ;
    rdfs:comment 'Current lifecycle status of the broadcast license indicating its operational validity and regulatory standing. [ENUM-REF-CANDIDATE: Active|Pending|Suspended|Expired|Revoked|Cancelled|Under Renewal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptioningRequired rdf:type rdf:Property ;
    rdfs:label 'Closed Captioning Required' ;
    rdfs:comment 'Indicates whether this license requires closed captioning for accessibility compliance.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communityOfLicense rdf:type rdf:Property ;
    rdfs:label 'Community Of License' ;
    rdfs:comment 'City or community that the broadcast station is licensed to serve. Determines local content and public interest obligations.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligations rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligations' ;
    rdfs:comment 'Summary of specific regulatory compliance requirements attached to this license (e.g., closed captioning, EAS participation, local content quotas, children\'s programming).' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageAreaContour rdf:type rdf:Property ;
    rdfs:label 'Coverage Area Contour' ;
    rdfs:comment 'Geographic boundary of the licensed coverage area, typically defined by signal strength contours (e.g., 60 dBu for FM, Grade A/B for TV). May be expressed as coordinates or geographic description.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easParticipationRequired rdf:type rdf:Property ;
    rdfs:label 'Eas Participation Required' ;
    rdfs:comment 'Indicates whether this license requires participation in the Emergency Alert System for public safety broadcasts.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyBand rdf:type rdf:Property ;
    rdfs:label 'Frequency Band' ;
    rdfs:comment 'Spectrum frequency band allocated to this license (e.g., 88.1 MHz for FM, 470-608 MHz for UHF TV). Expressed in MHz or GHz.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantDate rdf:type rdf:Property ;
    rdfs:label 'Grant Date' ;
    rdfs:comment 'Date when the broadcast license was originally granted or issued by the regulatory authority.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jurisdictionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the jurisdiction where this license is valid (e.g., USA, GBR, AUS).' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent regulatory inspection or audit of the licensed facility and operations.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Modification Date' ;
    rdfs:comment 'Date of the most recent modification or amendment to the license terms, technical parameters, or ownership.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseClass rdf:type rdf:Property ;
    rdfs:label 'License Class' ;
    rdfs:comment 'Regulatory classification of the license indicating power level, coverage area, and operational constraints (e.g., Class A, Class B, Class C for FM; Full-Power, Low-Power for TV).' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Official license number or authorization code issued by the regulatory authority. This is the externally-known unique identifier for the broadcast license.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Classification of the broadcast license by service type and transmission technology. [ENUM-REF-CANDIDATE: AM Radio|FM Radio|TV Full-Power|TV Low-Power|TV Translator|Satellite|Cable Franchise|IPTV — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseeType rdf:type rdf:Property ;
    rdfs:label 'Licensee Type' ;
    rdfs:comment 'Legal structure of the licensee organization.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationType rdf:type rdf:Property ;
    rdfs:label 'Modification Type' ;
    rdfs:comment 'Nature of the most recent license modification (e.g., Technical Change, Ownership Transfer, Power Increase, Frequency Change).' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipAttribution rdf:type rdf:Property ;
    rdfs:label 'Ownership Attribution' ;
    rdfs:comment 'Details of attributable ownership interests in the licensee entity, required for regulatory ownership reporting and concentration limits.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerOutputErpWatts rdf:type rdf:Property ;
    rdfs:label 'Power Output Erp Watts' ;
    rdfs:comment 'Maximum authorized effective radiated power output for the transmitter, measured in watts. Determines the coverage area and signal strength.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicInspectionFileLocation rdf:type rdf:Property ;
    rdfs:label 'Public Inspection File Location' ;
    rdfs:comment 'Physical or online location where the stations public inspection file is maintained, as required by regulatory authorities.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Governing body that issued and oversees this broadcast license (e.g., FCC for United States, Ofcom for United Kingdom). [ENUM-REF-CANDIDATE: FCC|Ofcom|ACMA|CRTC|ANATEL|IFT|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Application Date' ;
    rdfs:comment 'Date when the license renewal application was filed with the regulatory authority.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current status of the license renewal process, tracking whether renewal application has been filed and its disposition.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Nature of the broadcast service provided under this license, indicating the operational and content obligations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmitterAddress rdf:type rdf:Property ;
    rdfs:label 'Transmitter Address' ;
    rdfs:comment 'Physical street address of the licensed transmitter facility. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmitterLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Transmitter Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the licensed transmitter site in decimal degrees.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmitterLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Transmitter Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the licensed transmitter site in decimal degrees.' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseRenewalId rdf:type rdf:Property ;
    rdfs:label 'License Renewal Id' ;
    rdfs:comment 'Unique identifier for the broadcast license renewal application record.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicInspectionFileId rdf:type rdf:Property ;
    rdfs:label 'Public Inspection File Id' ;
    rdfs:comment 'Foreign key linking to compliance.public_inspection_file. Business justification: license_renewal already has a public_inspection_file_updated BOOLEAN field indicating whether the public inspection file was updated as part of the renewal process. Replacing this boolean with a direc' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PublicInspectionFile .

ind:complianceCertificationSubmitted rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Submitted' ;
    rdfs:comment 'Indicates whether the required compliance certifications (EEO, children\'s programming, political file, etc.) were submitted as part of the renewal application.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionsImposed rdf:type rdf:Property ;
    rdfs:label 'Conditions Imposed' ;
    rdfs:comment 'Any special conditions, restrictions, or requirements imposed by the regulatory authority as part of the renewal grant (e.g., compliance reporting, technical upgrades, programming commitments).' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialDate rdf:type rdf:Property ;
    rdfs:label 'Denial Date' ;
    rdfs:comment 'The date the regulatory authority officially denied the license renewal application.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'The regulatory authority\'s stated reason for denying the license renewal (e.g., failure to meet public interest standard, character qualifications, technical violations).' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Date' ;
    rdfs:comment 'The date the renewal filing fee was paid to the regulatory authority.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feePaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Status' ;
    rdfs:comment 'The current status of the renewal fee payment obligation.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDeadline rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline' ;
    rdfs:comment 'The regulatory deadline by which the renewal application must be submitted to avoid license lapse (typically 4 months prior to expiration for FCC).' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalDisposition rdf:type rdf:Property ;
    rdfs:label 'Final Disposition' ;
    rdfs:comment 'The ultimate outcome of the license renewal application process.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newLicenseTermEndDate rdf:type rdf:Property ;
    rdfs:label 'New License Term End Date' ;
    rdfs:comment 'The expiration date of the renewed license term, establishing the next renewal cycle.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:newLicenseTermStartDate rdf:type rdf:Property ;
    rdfs:label 'New License Term Start Date' ;
    rdfs:comment 'The effective start date of the renewed license term following approval.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:petitionCount rdf:type rdf:Property ;
    rdfs:label 'Petition Count' ;
    rdfs:comment 'The total number of petitions to deny filed against this renewal application.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:petitionToDenyFiled rdf:type rdf:Property ;
    rdfs:label 'Petition To Deny Filed' ;
    rdfs:comment 'Indicates whether any party filed a formal petition to deny the license renewal during the public comment period.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicCommentDeadline rdf:type rdf:Property ;
    rdfs:label 'Public Comment Deadline' ;
    rdfs:comment 'The deadline by which the public may file comments or petitions to deny the renewal application.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Public Notice Date' ;
    rdfs:comment 'The date the regulatory body published public notice of the renewal application, opening the period for public comment and petitions to deny.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'The governing regulatory authority to which the renewal application is submitted (Federal Communications Commission, Office of Communications, etc.).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalCycleEndDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Cycle End Date' ;
    rdfs:comment 'The date marking the expiration of the current license term, triggering the renewal requirement.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalCycleStartDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Cycle Start Date' ;
    rdfs:comment 'The date marking the beginning of the current license term that is subject to renewal.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Amount' ;
    rdfs:comment 'The regulatory filing fee amount required for processing the license renewal application.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the renewal fee (e.g., USD, GBP, CAD).' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'The date the regulatory authority completed its review and issued a final decision on the renewal application.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'The date the regulatory authority formally commenced substantive review of the renewal application.' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalFilingRegulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Original Filing Regulatory Filing Id' ;
    rdfs:comment 'Reference to the original regulatory filing identifier if this submission is an amendment or correction, establishing the lineage of filing revisions.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:amendmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this filing is an amendment or correction to a previously submitted filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking this filing to detailed audit trail records capturing all preparation, review, approval, and submission activities for compliance verification.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaApplicable rdf:type rdf:Property ;
    rdfs:label 'Ccpa Applicable' ;
    rdfs:comment 'Boolean indicator specifying whether this filing is subject to California Consumer Privacy Act (CCPA) viewer data privacy requirements for California residents.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'The primary regulatory compliance domain or category that this filing addresses, such as broadcast licensing, content standards, data privacy, financial reporting, accessibility mandates, or technical standards.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'The unique confirmation or receipt number issued by the regulatory body upon successful submission of the filing, serving as proof of receipt.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'The Uniform Resource Locator (URL) or file path to the digital copy of the filed document stored in the Media Asset Management (MAM) system or document repository.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'The date on which the regulatory filing was officially submitted to the governing body. This is the principal business event timestamp for the filing.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Description' ;
    rdfs:comment 'A detailed textual description of the filing content, purpose, and scope, providing context for the regulatory submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Amount' ;
    rdfs:comment 'The monetary fee charged by the regulatory body for processing this filing, expressed in the broadcaster\'s reporting currency.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Currency' ;
    rdfs:comment 'The three-letter International Organization for Standardization (ISO) 4217 currency code for the filing fee amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Number' ;
    rdfs:comment 'The externally-known unique filing number or reference code assigned by the broadcaster or regulatory body for tracking and identification purposes.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory filing indicating its progress through the submission and approval workflow. [ENUM-REF-CANDIDATE: draft|submitted|accepted|rejected|under_review|pending_correction|completed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'The category or type of regulatory filing being submitted, such as Equal Employment Opportunity (EEO) report, ownership report, political file, children\'s programming report, annual report, license renewal application, or public inspection file entry. [ENUM-REF-CANDIDATE: eeo_report|ownership_report|political_file|childrens_programming_report|annual_report|license_renewal|public_inspection_file — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formNumber rdf:type rdf:Property ;
    rdfs:label 'Form Number' ;
    rdfs:comment 'The official form number or identifier designated by the regulatory body for this filing type (e.g., FCC Form 323, FCC Form 396, Ofcom Form 1).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketDesignation rdf:type rdf:Property ;
    rdfs:label 'Market Designation' ;
    rdfs:comment 'The designated market area or geographic market served by the broadcast facility, as defined by Nielsen or equivalent measurement authority.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFilingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Filing Due Date' ;
    rdfs:comment 'The anticipated due date for the next recurring filing of this type, supporting proactive compliance planning and calendar management.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Confirmation Number' ;
    rdfs:comment 'The confirmation or transaction number for the filing fee payment, linking the financial transaction to the regulatory submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Public Inspection Required' ;
    rdfs:comment 'Boolean indicator specifying whether this filing must be made available for public inspection as required by regulatory transparency mandates.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'The end date of the time period covered by this regulatory filing, defining the conclusion of the reporting window for compliance data.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'The start date of the time period covered by this regulatory filing, defining the beginning of the reporting window for compliance data.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxApplicable rdf:type rdf:Property ;
    rdfs:label 'Sox Applicable' ;
    rdfs:comment 'Boolean indicator specifying whether this filing is subject to Sarbanes-Oxley Act (SOX) financial reporting and internal control requirements.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'The channel or mechanism through which the filing was submitted to the regulatory body, such as online portal, email, postal mail, fax, electronic filing system, or Application Programming Interface (API).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalDocumentPublicInspectionFileId rdf:type rdf:Property ;
    rdfs:label 'Original Document Public Inspection File Id' ;
    rdfs:comment 'If this is an amendment, reference to the original public inspection file document being amended or corrected.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PublicInspectionFile .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'The FCC-mandated category of the public inspection file document. Categories include political file (advertising records), EEO reports (equal employment opportunity), ownership reports, issues/programs lists, children\'s programming reports, and contour maps.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDescription rdf:type rdf:Property ;
    rdfs:label 'Document Description' ;
    rdfs:comment 'Detailed description of the document content, purpose, and any relevant context for public inspection.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFileFormat rdf:type rdf:Property ;
    rdfs:label 'Document File Format' ;
    rdfs:comment 'The file format of the stored document (e.g., PDF, DOCX, XLSX). FCC typically requires PDF format for OPIF submissions.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFilePath rdf:type rdf:Property ;
    rdfs:label 'Document File Path' ;
    rdfs:comment 'The storage location or URI of the document file in the media asset management system or document repository.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Document File Size Bytes' ;
    rdfs:comment 'The size of the document file in bytes.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Document Period End Date' ;
    rdfs:comment 'The end date of the reporting period covered by this document.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Document Period Start Date' ;
    rdfs:comment 'The start date of the reporting period covered by this document (e.g., for quarterly EEO reports or issues/programs lists).' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'The descriptive title or name of the public inspection file document.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fccOpifSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Fcc Opif Sync Status' ;
    rdfs:comment 'Synchronization status with the FCC\'s Online Public Inspection File portal. Indicates whether the document has been successfully transmitted to and accepted by the FCC system.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fccOpifSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fcc Opif Sync Timestamp' ;
    rdfs:comment 'The date and time of the last successful synchronization with the FCC OPIF portal.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fccReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Fcc Reference Number' ;
    rdfs:comment 'The unique reference or confirmation number assigned by the FCC OPIF system upon successful document submission.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAmendment rdf:type rdf:Property ;
    rdfs:label 'Is Amendment' ;
    rdfs:comment 'Indicates whether this document is an amendment or correction to a previously filed public inspection file document.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:politicalAdvertiserName rdf:type rdf:Property ;
    rdfs:label 'Political Advertiser Name' ;
    rdfs:comment 'For political file documents, the name of the candidate, campaign, or political organization that purchased advertising time. Required for political file category documents.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:politicalOfficeSought rdf:type rdf:Property ;
    rdfs:label 'Political Office Sought' ;
    rdfs:comment 'For political file documents, the elected office being sought by the candidate (e.g., President, Senator, Governor, Mayor).' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicAccessStatus rdf:type rdf:Property ;
    rdfs:label 'Public Access Status' ;
    rdfs:comment 'Indicates whether the document is currently available for public inspection. Documents may be restricted during review or removed after retention period expiration.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiration Date' ;
    rdfs:comment 'The date when the regulatory retention period expires and the document may be removed from the public inspection file.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'The number of years this document must be retained in the public inspection file as mandated by FCC regulations. Varies by document category (e.g., 2 years for political files, 8 years for ownership reports).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uploadStatus rdf:type rdf:Property ;
    rdfs:label 'Upload Status' ;
    rdfs:comment 'Current status of the document upload to the FCC OPIF (Online Public Inspection File) portal. Tracks the lifecycle from pending submission through verification and archival.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upload Timestamp' ;
    rdfs:comment 'The date and time when the document was successfully uploaded to the FCC OPIF portal or internal public inspection file system.' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Internal verification status indicating whether the document has been reviewed for accuracy and compliance before public posting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'The date and time when the document was verified for compliance and accuracy by station staff.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contentTitleId rdf:type rdf:Property ;
    rdfs:label 'Content Title Id' ;
    rdfs:comment 'Reference to the content title asset that this rating applies to.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:accessibilityRatingNotes rdf:type rdf:Property ;
    rdfs:label 'Accessibility Rating Notes' ;
    rdfs:comment 'Notes regarding accessibility features relevant to the rating, such as closed captioning compliance, audio description availability, or photosensitive epilepsy warnings.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDescriptors rdf:type rdf:Property ;
    rdfs:label 'Content Descriptors' ;
    rdfs:comment 'Comma-separated list of content advisory descriptors that explain the reasons for the rating. Examples: violence, strong language, sexual content, drug use, nudity, adult themes, frightening scenes.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugUseDescriptor rdf:type rdf:Property ;
    rdfs:label 'Drug Use Descriptor' ;
    rdfs:comment 'Indicates whether the content contains drug use or substance abuse that contributed to the rating.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageDescriptor rdf:type rdf:Property ;
    rdfs:label 'Language Descriptor' ;
    rdfs:comment 'Indicates whether the content contains strong or offensive language that contributed to the rating.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalGuidanceRequired rdf:type rdf:Property ;
    rdfs:label 'Parental Guidance Required' ;
    rdfs:comment 'Indicates whether parental guidance is recommended or required for viewers under a certain age.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousRatingValue rdf:type rdf:Property ;
    rdfs:label 'Previous Rating Value' ;
    rdfs:comment 'The rating value that was assigned before the current rating, if the content was re-rated. Null for initial ratings.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingAuthority rdf:type rdf:Property ;
    rdfs:label 'Rating Authority' ;
    rdfs:comment 'The official organization or regulatory body that issued the rating. Examples: Motion Picture Association, TV Parental Guidelines Monitoring Board, British Board of Film Classification, Freiwillige Selbstkontrolle der Filmwirtschaft.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Rating Certificate Number' ;
    rdfs:comment 'The official certificate or registration number issued by the rating authority for this content rating.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingDate rdf:type rdf:Property ;
    rdfs:label 'Rating Date' ;
    rdfs:comment 'The date on which the rating was officially assigned to the content by the rating authority.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Rating Expiration Date' ;
    rdfs:comment 'The date on which the rating expires or requires renewal, if applicable. Null for ratings with no expiration.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Rating Fee Amount' ;
    rdfs:comment 'The fee charged by the rating authority for evaluating and assigning the rating to the content.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Rating Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the rating fee. Examples: USD, GBP, EUR, AUD, JPY.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingNotes rdf:type rdf:Property ;
    rdfs:label 'Rating Notes' ;
    rdfs:comment 'Additional notes or comments regarding the rating, including any special conditions, context, or clarifications provided by the rating authority or compliance team.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingReason rdf:type rdf:Property ;
    rdfs:label 'Rating Reason' ;
    rdfs:comment 'Detailed explanation provided by the rating authority describing the specific content elements that led to the assigned rating.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingReviewDate rdf:type rdf:Property ;
    rdfs:label 'Rating Review Date' ;
    rdfs:comment 'The date on which the rating was last reviewed or re-evaluated by the rating authority.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Rating Submission Date' ;
    rdfs:comment 'The date on which the content was submitted to the rating authority for evaluation.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingSystem rdf:type rdf:Property ;
    rdfs:label 'Rating System' ;
    rdfs:comment 'The rating authority or system that issued this rating. Examples: MPA (Motion Picture Association), TV Parental Guidelines, BBFC (British Board of Film Classification), FSK (Germany), ACB (Australia), EIRIN (Japan), KFCB (Kenya). [ENUM-REF-CANDIDATE: MPA|TV_PARENTAL_GUIDELINES|BBFC|FSK|ACB|EIRIN|KFCB — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingType rdf:type rdf:Property ;
    rdfs:label 'Rating Type' ;
    rdfs:comment 'The distribution context for which this rating was assigned. Different ratings may apply to theatrical release, television broadcast, home video, or streaming platforms.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingValue rdf:type rdf:Property ;
    rdfs:label 'Rating Value' ;
    rdfs:comment 'The specific rating classification assigned to the content. Examples: G, PG, PG-13, R, NC-17 (MPA); TV-Y, TV-Y7, TV-G, TV-PG, TV-14, TV-MA (TV Parental Guidelines); U, PG, 12A, 15, 18 (BBFC). [ENUM-REF-CANDIDATE: G|PG|PG-13|R|NC-17|TV-Y|TV-Y7|TV-G|TV-PG|TV-14|TV-MA|U|12A|15|18|FSK0|FSK6|FSK12|FSK16|FSK18 — promote to reference product]' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingVersion rdf:type rdf:Property ;
    rdfs:label 'Rating Version' ;
    rdfs:comment 'Version number of this rating record. Increments when the rating is re-evaluated or updated due to content changes or appeals.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sexualContentDescriptor rdf:type rdf:Property ;
    rdfs:label 'Sexual Content Descriptor' ;
    rdfs:comment 'Indicates whether the content contains sexual content or nudity that contributed to the rating.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violenceDescriptor rdf:type rdf:Property ;
    rdfs:label 'Violence Descriptor' ;
    rdfs:comment 'Indicates whether the content contains violence that contributed to the rating.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCategoriesInvolved rdf:type rdf:Property ;
    rdfs:label 'Data Categories Involved' ;
    rdfs:comment 'Comma-separated list of data categories involved in the request (e.g., subscriber profile, viewing history, payment data, device identifiers). Used for scope tracking and audit.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataVolumeProcessed rdf:type rdf:Property ;
    rdfs:label 'Data Volume Processed' ;
    rdfs:comment 'Total volume of data processed for this request in megabytes, used for operational metrics and resource planning.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedDeadline rdf:type rdf:Property ;
    rdfs:label 'Extended Deadline' ;
    rdfs:comment 'New deadline date if an extension was granted. GDPR allows up to 3 months total; CCPA allows up to 90 days total.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionGranted rdf:type rdf:Property ;
    rdfs:label 'Extension Granted' ;
    rdfs:comment 'Indicates whether a deadline extension was granted due to request complexity or volume. GDPR allows 2-month extension; CCPA allows 45-day extension.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionReason rdf:type rdf:Property ;
    rdfs:label 'Extension Reason' ;
    rdfs:comment 'Business justification for granting a deadline extension, such as request complexity, high volume of requests, or technical challenges.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Detailed status of request fulfillment workflow: not_started, data_collection (gathering data), data_review (validating), response_preparation (packaging), response_sent (delivered), closed (finalized).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingTimeHours rdf:type rdf:Property ;
    rdfs:label 'Processing Time Hours' ;
    rdfs:comment 'Total staff hours spent processing this request, used for cost tracking and efficiency analysis.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Deadline' ;
    rdfs:comment 'Calculated deadline for responding to the request based on regulatory requirements: 30 calendar days for GDPR, 45 calendar days for CCPA, from submission date.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Externally-visible unique identifier for the privacy request, used in communications with data subjects and regulators.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the privacy request: submitted (received), under_review (initial assessment), identity_verification (verifying requestor), in_progress (fulfilling), completed (closed successfully), rejected (denied with justification), withdrawn (cancelled by requestor). [ENUM-REF-CANDIDATE: submitted|under_review|identity_verification|in_progress|completed|rejected|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Type of data subject rights request: access (right to know), erasure (right to delete), portability (data export), rectification (correction), restriction (processing limitation), or opt_out_sale (CCPA opt-out).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorEmail rdf:type rdf:Property ;
    rdfs:label 'Requestor Email' ;
    rdfs:comment 'Primary email address of the data subject for request correspondence and response delivery.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Requestor Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the data subject\'s jurisdiction, used to determine applicable privacy law (e.g., DEU for Germany/GDPR, USA for US/CCPA).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full legal name of the data subject submitting the privacy request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorPhone rdf:type rdf:Property ;
    rdfs:label 'Requestor Phone' ;
    rdfs:comment 'Contact phone number of the data subject for identity verification and request follow-up.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'Date when the response was delivered to the data subject, marking completion of the request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseMethod rdf:type rdf:Property ;
    rdfs:label 'Response Method' ;
    rdfs:comment 'Method used to deliver the response to the data subject: email (encrypted), secure_portal (download link), mail (postal), phone (verbal), or in_person.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Channel through which the privacy request was submitted: web_form (online portal), email, phone (call center), mail (postal), mobile_app, or chat (live support).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when the privacy request was submitted by the data subject. Used to calculate regulatory deadline (30 days GDPR, 45 days CCPA).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:systemsAccessed rdf:type rdf:Property ;
    rdfs:label 'Systems Accessed' ;
    rdfs:comment 'Comma-separated list of internal systems queried to fulfill the request (e.g., Zuora, Adobe Experience Platform, Akamai CDN logs). Used for audit trail and completeness verification.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify the requestor\'s identity: email_confirmation, account_login, document_upload (ID scan), phone_verification, two_factor_auth, or manual_review.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captionVendorPartnerId rdf:type rdf:Property ;
    rdfs:label 'Caption Vendor Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Captioning vendor performance and FCC compliance is tracked by partner. Captioning accuracy failures, latency violations, and format errors may trigger vendor SLA breaches, disputes, or vendor substit' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:narratorTalentProfileId rdf:type rdf:Property ;
    rdfs:label 'Narrator Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: Closed caption records may reference talent for audio description, voice identification, or accessibility compliance when talent narrates or appears in content. Accessibility teams identify talent voi' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:airTime rdf:type rdf:Property ;
    rdfs:label 'Air Time' ;
    rdfs:comment 'The precise timestamp when the captioned content began airing or streaming.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:captionAccuracyScore rdf:type rdf:Property ;
    rdfs:label 'Caption Accuracy Score' ;
    rdfs:comment 'Percentage score representing the accuracy of the captions compared to the spoken audio, measured as a percentage from 0.00 to 100.00.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:captionCompletenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Caption Completeness Percentage' ;
    rdfs:comment 'Percentage of the program duration that was captioned, measured from 0.00 to 100.00.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:captionFileFormat rdf:type rdf:Property ;
    rdfs:label 'Caption File Format' ;
    rdfs:comment 'The technical format of the closed caption file used for this broadcast. [ENUM-REF-CANDIDATE: SRT|SCC|TTML|WebVTT|CEA-608|CEA-708|DFXP|STL — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captionLatencySeconds rdf:type rdf:Property ;
    rdfs:label 'Caption Latency Seconds' ;
    rdfs:comment 'The average delay in seconds between spoken audio and caption display, critical for live programming compliance.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:captionPlacementCompliance rdf:type rdf:Property ;
    rdfs:label 'Caption Placement Compliance' ;
    rdfs:comment 'Indicates whether caption placement on screen met regulatory standards for visibility and non-obstruction of critical content.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:captionQualityReviewDate rdf:type rdf:Property ;
    rdfs:label 'Caption Quality Review Date' ;
    rdfs:comment 'Date when the caption quality was formally reviewed for compliance assessment.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:captionSynchronizationCompliance rdf:type rdf:Property ;
    rdfs:label 'Caption Synchronization Compliance' ;
    rdfs:comment 'Indicates whether captions were properly synchronized with the audio and video content per regulatory requirements.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:captionType rdf:type rdf:Property ;
    rdfs:label 'Caption Type' ;
    rdfs:comment 'Indicates whether the captions were generated live during broadcast or pre-recorded offline.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captionedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Captioned Duration Minutes' ;
    rdfs:comment 'Total duration in minutes that was actually captioned within the program.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complaintReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Complaint Received Date' ;
    rdfs:comment 'Date when a viewer complaint regarding captioning was received by the broadcaster.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complaintReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Reference Number' ;
    rdfs:comment 'Reference number of any viewer complaint filed regarding caption quality or availability for this broadcast.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintType rdf:type rdf:Property ;
    rdfs:label 'Complaint Type' ;
    rdfs:comment 'Category of the captioning complaint filed by viewers or regulatory bodies.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of the closed captioning for this broadcast record.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionBasis rdf:type rdf:Property ;
    rdfs:label 'Exemption Basis' ;
    rdfs:comment 'Legal or regulatory basis for exemption from closed captioning requirements, if applicable.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionCategory rdf:type rdf:Property ;
    rdfs:label 'Exemption Category' ;
    rdfs:comment 'Category of exemption from captioning requirements as defined by regulatory frameworks. [ENUM-REF-CANDIDATE: primarily_textual|late_night|promotional|public_service_announcement|locally_produced|economic_burden|interstitial_material|secondary_audio — promote to reference product]' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Program Duration Minutes' ;
    rdfs:comment 'Total duration of the program in minutes for which captioning compliance is being tracked.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicInspectionFileIncluded rdf:type rdf:Property ;
    rdfs:label 'Public Inspection File Included' ;
    rdfs:comment 'Indicates whether this caption record has been included in the broadcasters public inspection file as required by FCC regulations.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Date' ;
    rdfs:comment 'Date when the caption compliance record was filed with the regulatory authority.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required' ;
    rdfs:comment 'Indicates whether this caption record requires formal filing with regulatory authorities such as FCC or Ofcom.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completed Date' ;
    rdfs:comment 'Date when remediation actions to correct captioning issues were completed.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationDescription rdf:type rdf:Property ;
    rdfs:label 'Remediation Description' ;
    rdfs:comment 'Detailed description of the remediation actions taken to address captioning compliance issues.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of remediation efforts to address captioning deficiencies or complaints.' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegulation rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulation' ;
    rdfs:comment 'Primary regulatory framework governing this obligation: CVAA (Twenty-First Century Communications and Video Accessibility Act), ADA (Americans with Disabilities Act), Ofcom Access Code, EU Audiovisual Media Services Directive, WCAG 2.1 (Web Content Accessibility Guidelines), or ATSC A/53 (Advanced Television Systems Committee standard for closed captioning).' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'Date by which the organization must achieve full compliance with this accessibility obligation.' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Percentage' ;
    rdfs:comment 'Percentage of content or platform features currently meeting this accessibility obligation (0.00 to 100.00), used for tracking progress toward full compliance.' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Content Type Applicability' ;
    rdfs:comment 'Types of content to which this obligation applies (e.g., all programming, news and emergency information, pre-recorded entertainment, live events, user-generated content exclusions).' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedComplianceCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Compliance Cost' ;
    rdfs:comment 'Estimated total cost in USD to achieve full compliance with this obligation, including technology implementation, content remediation, training, and ongoing operational costs.' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Explanation of why this obligation does not apply to the organization or why a waiver was granted (e.g., content category exemption, undue burden waiver, technical infeasibility).' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Geographic Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the jurisdiction where this obligation is enforceable (e.g., USA for FCC/CVAA, GBR for Ofcom, DEU for German regulations).' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'Date when the organization last conducted an internal review or audit of compliance with this accessibility obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Review Date' ;
    rdfs:comment 'Scheduled date for the next internal review or audit of compliance with this accessibility obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Business identifier code for the accessibility obligation, used for external reference and reporting.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'Human-readable name of the accessibility obligation (e.g., Closed Captioning for Linear Broadcast, Audio Description for VOD Content).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Category of accessibility requirement: closed captioning (CC), audio description (AD), video description, emergency alert accessibility, online video player accessibility, or keyboard navigation compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyForNonCompliance rdf:type rdf:Property ;
    rdfs:label 'Penalty For Non Compliance' ;
    rdfs:comment 'Description of regulatory penalties, fines, or sanctions that may be imposed for failure to meet this obligation (e.g., FCC forfeiture up to $100,000 per violation, Ofcom statutory sanctions, license suspension risk).' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationSection rdf:type rdf:Property ;
    rdfs:label 'Regulation Section' ;
    rdfs:comment 'Specific section, article, or clause of the regulation that mandates this obligation (e.g., 47 CFR 79.1, WCAG 2.1 Success Criterion 1.2.2).' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which compliance status for this obligation must be reported to the regulator: annual, quarterly, monthly, on-demand (upon request), or not required.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Team' ;
    rdfs:comment 'Name of the internal team, department, or business unit responsible for ensuring compliance with this obligation (e.g., Broadcast Operations, Digital Product, Legal Compliance, Content Production).' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'Distribution platform scope to which this obligation applies: linear broadcast, VOD (Video On Demand), SVOD (Subscription Video On Demand), AVOD (Advertising-Supported Video On Demand), TVOD (Transactional Video On Demand), OTT (Over-The-Top), FAST (Free Ad-Supported Streaming Television), MVPD (Multichannel Video Programming Distributor), vMVPD (Virtual Multichannel Video Programming Distributor), or all platforms. [ENUM-REF-CANDIDATE: linear|vod|svod|avod|tvod|ott|fast|mvpd|vmvpd|all_platforms — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Target Compliance Percentage' ;
    rdfs:comment 'Required percentage of content or platform features that must meet this accessibility obligation to achieve regulatory compliance (typically 100.00, but may be lower for phased implementation schedules).' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalStandard rdf:type rdf:Property ;
    rdfs:label 'Technical Standard' ;
    rdfs:comment 'Technical standard or specification that defines how this accessibility feature must be implemented (e.g., CEA-608 for closed captioning, TTML for web captions, WCAG 2.1 AA for player accessibility).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiration Date' ;
    rdfs:comment 'Date when a granted waiver or exemption expires and the obligation becomes enforceable again (null for permanent exemptions).' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:alertDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Alert Duration Seconds' ;
    rdfs:comment 'Duration of the EAS alert transmission in seconds, from start to end of the alert message.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertText rdf:type rdf:Property ;
    rdfs:label 'Alert Text' ;
    rdfs:comment 'Full text content of the EAS alert message that was transmitted or received, including any instructions to the public.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Timestamp' ;
    rdfs:comment 'Date and time when the EAS alert was activated or received by the station. This is the principal business event timestamp for the alert.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the EAS alert by geographic scope: national emergency, state emergency, local emergency, or test alert.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attentionSignalTransmitted rdf:type rdf:Property ;
    rdfs:label 'Attention Signal Transmitted' ;
    rdfs:comment 'Indicates whether the two-tone attention signal was transmitted as part of the EAS alert.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioMessageTransmitted rdf:type rdf:Property ;
    rdfs:label 'Audio Message Transmitted' ;
    rdfs:comment 'Indicates whether the audio message portion of the EAS alert was transmitted.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capMessageReceived rdf:type rdf:Property ;
    rdfs:label 'Cap Message Received' ;
    rdfs:comment 'Indicates whether the alert was received in Common Alerting Protocol (CAP) format via IPAWS or other digital alert system.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endOfMessageTransmitted rdf:type rdf:Property ;
    rdfs:label 'End Of Message Transmitted' ;
    rdfs:comment 'Indicates whether the End of Message (EOM) code was transmitted to signal completion of the EAS alert.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentUsed rdf:type rdf:Property ;
    rdfs:label 'Equipment Used' ;
    rdfs:comment 'Description or model identifier of the EAS equipment (encoder/decoder) used to process and transmit the alert.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Three-letter EAS event code identifying the nature of the emergency (e.g., EAN for Emergency Action Notification, RWT for Required Weekly Test, RMT for Required Monthly Test, TOR for Tornado Warning).' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Detailed explanation of why an EAS alert transmission failed or was missed, including technical or operational reasons.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipawsMessageCode rdf:type rdf:Property ;
    rdfs:label 'Ipaws Message Code' ;
    rdfs:comment 'Unique message identifier from FEMA IPAWS system for alerts originated through the national alert infrastructure.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatorCode rdf:type rdf:Property ;
    rdfs:label 'Originator Code' ;
    rdfs:comment 'Three-letter code identifying the entity that originated the alert (e.g., PEP for Primary Entry Point, CIV for Civil Authority, WXR for National Weather Service, EAS for EAS Participant).' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatorName rdf:type rdf:Property ;
    rdfs:label 'Originator Name' ;
    rdfs:comment 'Full name of the authority or organization that originated the EAS alert (e.g., FEMA IPAWS, National Weather Service, State Emergency Management Agency).' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicInspectionFileEntry rdf:type rdf:Property ;
    rdfs:label 'Public Inspection File Entry' ;
    rdfs:comment 'Indicates whether this EAS log entry has been included in the stations public inspection file as required by FCC regulations.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relayChainPosition rdf:type rdf:Property ;
    rdfs:label 'Relay Chain Position' ;
    rdfs:comment 'Position of this station in the EAS relay chain, indicating how many hops the alert has traveled from the originator (1 for direct receipt, 2+ for relayed).' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'Date when this EAS log record is eligible for deletion based on FCC retention requirements (minimum 2 years for EAS logs).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testComplianceType rdf:type rdf:Property ;
    rdfs:label 'Test Compliance Type' ;
    rdfs:comment 'Type of EAS test compliance this log entry satisfies: Required Weekly Test (RWT), Required Monthly Test (RMT), National Periodic Test, or none if not a test.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Test Scheduled Date' ;
    rdfs:comment 'Date when the EAS test was scheduled to occur, used for tracking compliance with required weekly and monthly test schedules.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Transmission Status' ;
    rdfs:comment 'Status of the EAS alert transmission indicating whether the station successfully transmitted, received, relayed, failed to transmit, or missed the alert.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upstreamSourceCallsign rdf:type rdf:Property ;
    rdfs:label 'Upstream Source Callsign' ;
    rdfs:comment 'Call sign of the upstream station or source from which this station received the EAS alert for relay.' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validTimePeriod rdf:type rdf:Property ;
    rdfs:label 'Valid Time Period' ;
    rdfs:comment 'Four-digit code indicating the valid time period for the alert in 15-minute increments (e.g., 0030 for 30 minutes, 0100 for 1 hour).' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advertiserType rdf:type rdf:Property ;
    rdfs:label 'Advertiser Type' ;
    rdfs:comment 'Classification of the political advertiser entity type for regulatory reporting and rate determination purposes.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affidavitIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Affidavit Issued Flag' ;
    rdfs:comment 'Indicates whether a broadcast affidavit (proof of performance) has been issued to the advertiser confirming that this political ad aired as scheduled.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:candidateName rdf:type rdf:Property ;
    rdfs:label 'Candidate Name' ;
    rdfs:comment 'Name of the political candidate featured or referenced in the advertisement, if applicable. Null for issue advocacy ads without candidate reference.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text field for documenting compliance issues, remediation actions, equal opportunities requests, reasonable access determinations, or other regulatory notes related to this political ad placement.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Sales contract or agreement number under which this political advertisement was purchased. Links to the traffic system sales order.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionDate rdf:type rdf:Property ;
    rdfs:label 'Election Date' ;
    rdfs:comment 'Scheduled date of the election to which this political advertisement relates. Critical for determining Lowest Unit Charge (LUC) period applicability (45 days before primary, 60 days before general election).' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:electionType rdf:type rdf:Property ;
    rdfs:label 'Election Type' ;
    rdfs:comment 'Type of election for which the political advertisement is being aired.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equalOpportunitiesRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Equal Opportunities Request Flag' ;
    rdfs:comment 'Indicates whether this ad placement was triggered by an equal opportunities request under Section 315 of the Communications Act, requiring equal treatment of opposing candidates.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'Governmental jurisdiction level of the race or ballot measure (federal, state, or local) for compliance categorization and public file organization.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lucPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Luc Period Flag' ;
    rdfs:comment 'Indicates whether this ad aired during the Lowest Unit Charge (LUC) period (45 days before primary or 60 days before general election) when special rate protections apply to candidate ads.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lucRate rdf:type rdf:Property ;
    rdfs:label 'Luc Rate' ;
    rdfs:comment 'The lowest unit charge rate applicable to this spot based on the rate class and daypart during the pre-election window (45 days before primary, 60 days before general election). Null if outside LUC period.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Flag' ;
    rdfs:comment 'Indicates whether this ad spot is a compensatory makegood placement provided due to a previous preemption or technical failure.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:officeSought rdf:type rdf:Property ;
    rdfs:label 'Office Sought' ;
    rdfs:comment 'The elected office or ballot measure that the political advertisement relates to (e.g., President, U.S. Senate, Governor, State Representative, Proposition 22).' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Preemption Flag' ;
    rdfs:comment 'Indicates whether this scheduled political ad spot was preempted and did not air as originally scheduled. Triggers makegood obligations.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Name of the television or radio program during which the political advertisement aired. Required for public file disclosure.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicFileDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Public File Disclosure Date' ;
    rdfs:comment 'Date when this political ad record was uploaded to the stations online public inspection file as required by FCC rules. Must occur immediately upon ad placement.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateCharged rdf:type rdf:Property ;
    rdfs:label 'Rate Charged' ;
    rdfs:comment 'Actual dollar amount charged to the political advertiser for this spot placement. Must comply with Lowest Unit Charge (LUC) requirements during pre-election windows.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateClass rdf:type rdf:Property ;
    rdfs:label 'Rate Class' ;
    rdfs:comment 'Commercial rate classification applied to this spot (e.g., Fixed, Preemptible-1, Preemptible-2, Run-of-Schedule). Determines Lowest Unit Charge (LUC) eligibility and comparison group.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonableAccessRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Reasonable Access Request Flag' ;
    rdfs:comment 'Indicates whether this ad placement was the result of a federal candidate reasonable access request under Section 312(a)(7) of the Communications Act, requiring broadcasters to provide reasonable access to federal candidates.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorAddress rdf:type rdf:Property ;
    rdfs:label 'Sponsor Address' ;
    rdfs:comment 'Mailing address of the political advertiser or sponsor. Required for public inspection file disclosure.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorContactName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Name' ;
    rdfs:comment 'Name of the individual or organization contact person responsible for the political advertisement purchase. Required for public file records.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorEmail rdf:type rdf:Property ;
    rdfs:label 'Sponsor Email' ;
    rdfs:comment 'Email address of the political advertiser or sponsor contact for correspondence and compliance communication.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorPhone rdf:type rdf:Property ;
    rdfs:label 'Sponsor Phone' ;
    rdfs:comment 'Contact telephone number for the political advertiser or sponsor. Required for public file records.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipIdentification rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Identification' ;
    rdfs:comment 'The on-air sponsorship disclosure statement identifying who paid for the advertisement (e.g., \'Paid for by Committee to Elect Jane Smith\'). Required by FCC sponsorship identification rules.' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Spot Length Seconds' ;
    rdfs:comment 'Duration of the political advertisement spot in seconds (e.g., 15, 30, 60, 120). Used for rate calculation and inventory management.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByObligationRegulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Obligation Regulatory Obligation Id' ;
    rdfs:comment 'Reference to the regulatory obligation that supersedes this one, if applicable. Null if not superseded.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Business units, platforms, or services to which this obligation applies (e.g., linear TV, OTT platforms, radio, digital publishers, SVOD services, AVOD platforms, FAST channels).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Indicates whether an audit trail of compliance activities and decisions must be maintained for this obligation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automationStatus rdf:type rdf:Property ;
    rdfs:label 'Automation Status' ;
    rdfs:comment 'Degree to which compliance monitoring and reporting for this obligation is automated: manual, partially automated, fully automated, or not applicable.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Frequency' ;
    rdfs:comment 'How often compliance with this obligation must be demonstrated or reported: ongoing (continuous), annual, quarterly, monthly, event-driven (triggered by specific events), or biennial.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequired rdf:type rdf:Property ;
    rdfs:label 'Documentation Required' ;
    rdfs:comment 'Indicates whether formal documentation, records, or evidence must be maintained to demonstrate compliance with this obligation.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Documentation Retention Years' ;
    rdfs:comment 'Number of years that compliance documentation must be retained, as mandated by the regulation or internal policy.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalReportingRequired rdf:type rdf:Property ;
    rdfs:label 'External Reporting Required' ;
    rdfs:comment 'Indicates whether compliance with this obligation requires formal reporting or filing to an external regulatory body.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingDeadlineDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Description' ;
    rdfs:comment 'Human-readable description of the filing deadline (e.g., \'April 1 annually\', \'10 days after broadcast\', \'within 30 days of license expiration\').' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDeadlineType rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Type' ;
    rdfs:comment 'Type of deadline for compliance filing or reporting: fixed date (specific calendar date), rolling (X days from event), event-based (triggered by business event), or not applicable.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Geographic jurisdiction where this obligation applies, using 3-letter ISO country code (e.g., USA, GBR, DEU) or regional code (e.g., EUR for EU-wide regulations).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Penalty Amount' ;
    rdfs:comment 'Maximum monetary penalty or fine amount that can be imposed for non-compliance, in the currency specified.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringSystem rdf:type rdf:Property ;
    rdfs:label 'Monitoring System' ;
    rdfs:comment 'Name of the system or tool used to monitor compliance with this obligation (e.g., GRC platform, compliance management system, manual tracking).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed description of the regulatory obligation, including what must be done, reported, or maintained to achieve compliance.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency' ;
    rdfs:comment 'Currency code for the penalty amount, using ISO 4217 3-letter code (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Description of penalties, fines, or sanctions that may be imposed for non-compliance with this obligation.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Required' ;
    rdfs:comment 'Indicates whether compliance information or related documents must be made publicly available (e.g., in FCC Online Public Inspection File).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulationName rdf:type rdf:Property ;
    rdfs:label 'Regulation Name' ;
    rdfs:comment 'Full name of the regulation, law, or standard that mandates this obligation (e.g., Communications Act Section 73, GDPR Article 30, SOX Section 404).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference Number' ;
    rdfs:comment 'Official citation or reference number of the regulation (e.g., 47 CFR 73.3526, GDPR Art. 30, SOX §404).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentAgencyId rdf:type rdf:Property ;
    rdfs:label 'Talent Agency Id' ;
    rdfs:comment 'FK to talent.talent_agency' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentAgency .

ind:biometricConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Consent Flag' ;
    rdfs:comment 'Indicates whether the talent has provided consent for collection and use of biometric data (facial recognition, voice prints) for digital effects, deepfake prevention, and AI training. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccpaOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Flag' ;
    rdfs:comment 'Indicates whether the talent has opted out of the sale or sharing of their personal information under CCPA. Required for California-based talent or productions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Expiration Date' ;
    rdfs:comment 'The date when the talent\'s current clearance status expires and requires renewal. Used for compliance tracking and production eligibility verification.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'The talent\'s date of birth. Required for age verification, child labor law compliance (COPPA), insurance underwriting, and residual payment calculations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'The primary email address for talent communication, contract delivery, and digital correspondence.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Clause Flag' ;
    rdfs:comment 'Indicates whether the talent is currently bound by an exclusivity clause that restricts their ability to work with competing networks, studios, or brands. Used for conflict checking during casting and booking.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderIdentity rdf:type rdf:Property ;
    rdfs:label 'Gender Identity' ;
    rdfs:comment 'The talent\'s self-identified gender. Used for diversity reporting, casting analytics, and compliance with equal opportunity regulations.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdbIdentifier rdf:type rdf:Property ;
    rdfs:label 'Imdb Identifier' ;
    rdfs:comment 'The talent\'s unique identifier in the Internet Movie Database (IMDb). Used for cross-referencing filmography, public profile linking, and industry data integration.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Flag' ;
    rdfs:comment 'Indicates whether the talent is currently covered by production insurance (liability, workers compensation, errors and omissions). Required for on-set work authorization.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isniCode rdf:type rdf:Property ;
    rdfs:label 'Isni Code' ;
    rdfs:comment 'The International Standard Name Identifier (ISNI) for the talent. A globally unique identifier for creators used in rights management and royalty distribution systems.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The full legal name of the talent as it appears on official documents and contracts. Used for contract execution, payroll, and legal compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'The talent\'s nationality represented as a 3-letter ISO country code. Used for work authorization, tax treaty eligibility, and international co-production compliance.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'The primary contact phone number for the talent. Used for production scheduling, emergency contact, and direct communication.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Eligibility Flag' ;
    rdfs:comment 'Indicates whether the talent is eligible to receive residual payments for reuse of their work in syndication, streaming, or international distribution. Determined by union status and contract terms.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stageName rdf:type rdf:Property ;
    rdfs:label 'Stage Name' ;
    rdfs:comment 'The professional or stage name used by the talent for public appearances, credits, and marketing materials. May differ from legal name.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentTier rdf:type rdf:Property ;
    rdfs:label 'Talent Tier' ;
    rdfs:comment 'The classification tier of the talent based on industry recognition, box office draw, and compensation level. Used for budgeting, marketing strategy, and billing rate determination.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentType rdf:type rdf:Property ;
    rdfs:label 'Talent Type' ;
    rdfs:comment 'The primary professional category or role type of the talent. Determines applicable guild rules, contract templates, and credit attribution standards. [ENUM-REF-CANDIDATE: actor|director|writer|producer|host|correspondent|crew|voice_artist|composer|cinematographer — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'The talent\'s tax identification number (SSN, EIN, or international equivalent). Required for payroll processing, tax withholding, and IRS 1099 reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionAffiliation rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation' ;
    rdfs:comment 'The primary labor union or guild affiliation of the talent. Determines contract terms, minimum compensation, residual eligibility, and working conditions.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMemberNumber rdf:type rdf:Property ;
    rdfs:label 'Union Member Number' ;
    rdfs:comment 'The talent\'s membership identifier within their primary union or guild. Required for residual payment processing and contract compliance verification.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Status' ;
    rdfs:comment 'The talent\'s current work authorization status in the primary production jurisdiction. Determines eligibility for employment and production participation.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workVisaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Work Visa Expiration Date' ;
    rdfs:comment 'The expiration date of the talent\'s work visa. Critical for production scheduling and compliance with immigration regulations.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workVisaType rdf:type rdf:Property ;
    rdfs:label 'Work Visa Type' ;
    rdfs:comment 'The specific type of work visa held by the talent (e.g., O-1, P-1, H-1B). Used for compliance tracking and production planning for international talent.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbaEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Cba Effective Date' ;
    rdfs:comment 'Date when the current collective bargaining agreement became effective for this membership.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cbaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Cba Expiration Date' ;
    rdfs:comment 'Date when the current collective bargaining agreement expires. Used to track contract renewal cycles and potential rate changes.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:duesPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Dues Payment Status' ;
    rdfs:comment 'Current status of membership dues payment obligations. Current (all dues paid up to date), overdue (payment past due but within grace period), delinquent (significantly past due, may affect standing), exempt (not required to pay dues), waived (dues forgiven by guild).' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildCode rdf:type rdf:Property ;
    rdfs:label 'Guild Code' ;
    rdfs:comment 'Standardized code identifying the entertainment industry guild or union. SAG-AFTRA (Screen Actors Guild - American Federation of Television and Radio Artists), WGA (Writers Guild of America), DGA (Directors Guild of America), IATSE (International Alliance of Theatrical Stage Employees), AFM (American Federation of Musicians), BECTU (Broadcasting Entertainment Communications and Theatre Union - UK), ACTRA (Alliance of Canadian Cinema Television and Radio Artists). [ENUM-REF-CANDIDATE: SAG-AFTRA|WGA|DGA|IATSE|AFM|BECTU|ACTRA|OTHER — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildName rdf:type rdf:Property ;
    rdfs:label 'Guild Name' ;
    rdfs:comment 'Full legal name of the guild or union organization.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthBenefitsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Health Benefits Eligible Flag' ;
    rdfs:comment 'Indicates whether the talent is eligible for guild-provided health insurance benefits based on this membership and earnings thresholds. True if eligible, false otherwise.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:joinDate rdf:type rdf:Property ;
    rdfs:label 'Join Date' ;
    rdfs:comment 'Date when the talent officially became a member of this guild. Used to determine seniority and eligibility for certain benefits.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDuesPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Dues Payment Date' ;
    rdfs:comment 'Date of the most recent membership dues payment received by the guild.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localChapter rdf:type rdf:Property ;
    rdfs:label 'Local Chapter' ;
    rdfs:comment 'Local chapter, branch, or regional division of the guild to which this membership is assigned. Used for regional governance and event coordination.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipNumber rdf:type rdf:Property ;
    rdfs:label 'Membership Number' ;
    rdfs:comment 'Unique membership identifier assigned by the guild to the talent member. Required for residual payment processing and production compliance verification.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current standing of the talent within the guild. Good standing (active member in compliance), suspended (temporarily barred due to dues or violations), resigned (voluntarily terminated membership), expelled (involuntarily removed), inactive (not currently active but not terminated), pending (application under review).' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipTier rdf:type rdf:Property ;
    rdfs:label 'Membership Tier' ;
    rdfs:comment 'Classification of membership level within the guild. Full member (standard active membership with full benefits), fi-core (financial core member with limited participation), apprentice (trainee or provisional member), honorary (recognition membership), lifetime (permanent membership status), emeritus (retired member with recognition).' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDuesPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Next Dues Payment Date' ;
    rdfs:comment 'Date when the next membership dues payment is due.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pensionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Pension Eligible Flag' ;
    rdfs:comment 'Indicates whether the talent is eligible for guild pension plan contributions and benefits. True if eligible, false otherwise.' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date when the guild membership ended, whether through resignation, expulsion, or other termination. Null for active memberships.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when the guild membership status was last verified with the guild organization. Used to ensure data accuracy for production compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:representationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Representation Agreement Id' ;
    rdfs:comment 'Foreign key linking to talent.representation_agreement. Business justification: contract contains denormalized fields talent_representative_agency (STRING) and talent_representative_name (STRING) that duplicate data captured on representation_agreement (agency legal name via tale' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RepresentationAgreement .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'The total number of formal amendments made to this contract since initial execution. Tracks contract modification history.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backendParticipationPercentage rdf:type rdf:Property ;
    rdfs:label 'Backend Participation Percentage' ;
    rdfs:comment 'The percentage of net profits, adjusted gross, or other revenue streams the talent is entitled to receive after recoupment of production costs. Common for above-the-line talent.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backendParticipationType rdf:type rdf:Property ;
    rdfs:label 'Backend Participation Type' ;
    rdfs:comment 'The revenue calculation basis for backend participation. Net profits are after all costs; adjusted gross is after specific deductions; gross receipts are from first dollar. None indicates no backend participation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Base Compensation Amount' ;
    rdfs:comment 'The guaranteed base fee or salary payable to the talent for services rendered under this contract, excluding bonuses, backend participation, and residuals.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCreditPosition rdf:type rdf:Property ;
    rdfs:label 'Billing Credit Position' ;
    rdfs:comment 'The contractually specified position and format of the talent\'s on-screen credit (e.g., \'First Position Main Title\', \'Shared Card\', \'Single Card\', \'Above the Title\'). Critical for talent reputation and guild compliance.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the base compensation amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationStructure rdf:type rdf:Property ;
    rdfs:label 'Compensation Structure' ;
    rdfs:comment 'The payment model for the base compensation. Flat fee is a single lump sum; per-episode is paid per episode produced; weekly/annual/day/hourly rates define periodic payment schedules.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current stage of the contract in its lifecycle. Deal memo represents initial short-form agreement; countersigned indicates mutual acceptance; long-form executed is the final detailed contract; amended reflects modifications; suspended indicates temporary hold; terminated is early cancellation; expired is natural end. [ENUM-REF-CANDIDATE: deal_memo|countersigned|long_form_executed|amended|suspended|terminated|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the talent engagement type. Series regular deals cover multi-episode commitments; episodic guest agreements are single or limited appearances; overall deals provide exclusive services across multiple projects; first-look deals grant priority rights to talent-developed content; crew contracts cover technical and production staff; talent holding deals reserve talent availability; development deals fund content creation. [ENUM-REF-CANDIDATE: series_regular|episodic_guest|overall_deal|first_look_deal|crew_contract|talent_holding_deal|development_deal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditPlacementRequirements rdf:type rdf:Property ;
    rdfs:label 'Credit Placement Requirements' ;
    rdfs:comment 'Detailed contractual requirements for credit placement, including main title vs end credits, paid advertising inclusion, promotional materials, and any special formatting or adjacency requirements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditSizePercentage rdf:type rdf:Property ;
    rdfs:label 'Credit Size Percentage' ;
    rdfs:comment 'The minimum size of the talent\'s on-screen credit as a percentage of the title or other reference credit size. Null if not contractually specified.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentReferenceUri rdf:type rdf:Property ;
    rdfs:label 'Document Reference Uri' ;
    rdfs:comment 'The storage location or document management system URI for the executed contract document and all amendments. Used for legal reference and audit.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementRole rdf:type rdf:Property ;
    rdfs:label 'Engagement Role' ;
    rdfs:comment 'The specific role or position the talent is contracted to perform (e.g., Lead Actor, Director, Showrunner, Writer, Executive Producer, Director of Photography, Host).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Detailed description of the exclusivity restrictions, including prohibited activities, competing platforms, genre restrictions, and geographic scope. Null if exclusivity_flag is false.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingCba rdf:type rdf:Property ;
    rdfs:label 'Governing Cba' ;
    rdfs:comment 'The specific collective bargaining agreement that governs this contract, including version and effective date (e.g., SAG-AFTRA Television Agreement 2020-2023). Defines minimum compensation, working conditions, and residual structures.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedEpisodes rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Episodes' ;
    rdfs:comment 'The minimum number of episodes for which the talent is guaranteed compensation, regardless of actual production. Common in series regular deals. Null for non-episodic contracts.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optionExerciseDeadline rdf:type rdf:Property ;
    rdfs:label 'Option Exercise Deadline' ;
    rdfs:comment 'The date by which the company must notify the talent of its decision to exercise or decline the next option period. Null if no active option exists.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionExerciseStatus rdf:type rdf:Property ;
    rdfs:label 'Option Exercise Status' ;
    rdfs:comment 'Current status of the most recent option period. Not applicable if no options exist; pending if decision deadline has not passed; exercised if company extended; declined if company chose not to extend; expired if deadline passed without action.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionPeriodsCount rdf:type rdf:Property ;
    rdfs:label 'Option Periods Count' ;
    rdfs:comment 'The number of option periods (typically annual) the company holds to extend the contract beyond the initial term. Common in series regular and overall deals.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payOrPlayFlag rdf:type rdf:Property ;
    rdfs:label 'Pay Or Play Flag' ;
    rdfs:comment 'Indicates whether the contract includes a pay-or-play provision, guaranteeing full compensation even if the talent services are not ultimately used or the production is cancelled.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepUpAmount rdf:type rdf:Property ;
    rdfs:label 'Step Up Amount' ;
    rdfs:comment 'The incremental increase in base compensation for each exercised option period or season renewal. Null if no step-up provision exists.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'The primary reason for early contract termination. Null if contract was not terminated early. [ENUM-REF-CANDIDATE: mutual_agreement|breach_of_contract|force_majeure|production_cancellation|talent_unavailability|company_convenience|talent_request|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationStructureId rdf:type rdf:Property ;
    rdfs:label 'Compensation Structure Id' ;
    rdfs:comment 'Unique identifier for the compensation structure record. Primary key.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompensationStructure .

ind:backendGrossParticipationPct rdf:type rdf:Property ;
    rdfs:label 'Backend Gross Participation Pct' ;
    rdfs:comment 'The percentage of adjusted gross receipts or backend profits the talent is entitled to receive (e.g., 0.05 for 5% backend participation). Null if no backend participation is granted.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseEpisodeFee rdf:type rdf:Property ;
    rdfs:label 'Base Episode Fee' ;
    rdfs:comment 'The guaranteed compensation amount per episode for episodic talent (actors, writers, directors). Expressed in the contract currency.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'The fixed or maximum bonus amount payable when the bonus threshold is met. Expressed in the contract currency. Null if no bonus provision exists.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusThresholdDescription rdf:type rdf:Property ;
    rdfs:label 'Bonus Threshold Description' ;
    rdfs:comment 'Textual description of the performance or milestone thresholds that trigger bonus payments (e.g., \'Nielsen rating above 2.0 in key demo\', \'box office exceeds $100M domestic\').' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationType rdf:type rdf:Property ;
    rdfs:label 'Compensation Type' ;
    rdfs:comment 'Classification of the compensation arrangement: union scale (SAG-AFTRA, WGA, DGA minimum), over-scale (above union minimum), flat fee, episodic rate, weekly guarantee, daily rate, backend gross participation, deferred compensation, or residual-only deal. [ENUM-REF-CANDIDATE: union_scale|over_scale|flat_fee|episodic|weekly|daily|backend_participation|deferred|residual_only — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyRate rdf:type rdf:Property ;
    rdfs:label 'Daily Rate' ;
    rdfs:comment 'The guaranteed daily compensation amount for talent engaged on a day-player or daily basis. Expressed in the contract currency.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Compensation Amount' ;
    rdfs:comment 'The total amount of compensation deferred to a future payment date or contingent event (e.g., series pickup, profitability milestone). Expressed in the contract currency.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredPaymentTrigger rdf:type rdf:Property ;
    rdfs:label 'Deferred Payment Trigger' ;
    rdfs:comment 'The business event or milestone that triggers payment of deferred compensation (e.g., \'series_pickup\', \'profitability_threshold_met\', \'syndication_sale\', \'specific_date\').' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Multiplier' ;
    rdfs:comment 'The multiplier applied to the base rate for overtime hours worked (e.g., 1.5 for time-and-a-half, 2.0 for double-time). Null if overtime is not applicable.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pensionHealthRate rdf:type rdf:Property ;
    rdfs:label 'Pension Health Rate' ;
    rdfs:comment 'The percentage rate of gross compensation contributed to the guild pension and health plan (e.g., 0.185 for 18.5% SAG-AFTRA P&H). Used to calculate employer contributions.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualBaseFormula rdf:type rdf:Property ;
    rdfs:label 'Residual Base Formula' ;
    rdfs:comment 'The formula or method used to calculate the residual base for reuse payments (e.g., \'initial_compensation\', \'applicable_minimum\', \'pro_rata_share\'). Defines how residuals are computed per guild rules.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepUpTrigger rdf:type rdf:Property ;
    rdfs:label 'Step Up Trigger' ;
    rdfs:comment 'The condition or event that triggers an automatic increase in compensation (e.g., \'season_2_pickup\', \'episode_13_renewal\', \'ratings_threshold\'). Null if no step-up provision exists.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureName rdf:type rdf:Property ;
    rdfs:label 'Structure Name' ;
    rdfs:comment 'Business-friendly name or label for this compensation structure (e.g., \'Series Regular Season 1\', \'Guest Star Rate Card\').' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureStatus rdf:type rdf:Property ;
    rdfs:label 'Structure Status' ;
    rdfs:comment 'Current lifecycle status of the compensation structure: draft (under negotiation), active (in force), amended (modified after execution), superseded (replaced by a newer structure), or terminated (no longer applicable).' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsScope rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Scope' ;
    rdfs:comment 'Description of the media usage rights covered by this compensation structure (e.g., \'initial broadcast only\', \'all media in perpetuity\', \'theatrical and SVOD\', \'domestic free television\'). Defines what exploitation is covered by the base compensation.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeklyGuarantee rdf:type rdf:Property ;
    rdfs:label 'Weekly Guarantee' ;
    rdfs:comment 'The guaranteed weekly compensation amount for talent engaged on a weekly basis (e.g., series regulars, production staff). Expressed in the contract currency.' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availabilityId rdf:type rdf:Property ;
    rdfs:label 'Availability Id' ;
    rdfs:comment 'Foreign key linking to talent.availability. Business justification: An appearance schedule (confirmed booking) is the downstream result of a confirmed availability record. Linking appearance_schedule back to the availability record that enabled the booking provides op' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Availability .

ind:rescheduledFromAppearanceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Rescheduled From Appearance Schedule Id' ;
    rdfs:comment 'Reference to the original appearance schedule record if this schedule is a rescheduled version of a previous booking.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AppearanceSchedule .

ind:resultingMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Resulting Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Links scheduled talent appearances (talk shows, live events, promotional shoots) to the resulting recorded media assets. Required for archival cross-reference, rights verification, and tracking which ' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:appearanceType rdf:type rdf:Property ;
    rdfs:label 'Appearance Type' ;
    rdfs:comment 'Classification of the type of appearance or activity scheduled for the talent. ADR (Automated Dialogue Replacement) refers to post-production voice recording sessions. [ENUM-REF-CANDIDATE: principal_photography|adr_session|promotional_appearance|press_junket|live_broadcast|table_read|rehearsal|wardrobe_fitting|makeup_test|screen_test — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Availability Window End' ;
    rdfs:comment 'The end date of the period during which the talent has indicated availability for scheduling.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availabilityWindowStart rdf:type rdf:Property ;
    rdfs:label 'Availability Window Start' ;
    rdfs:comment 'The start date of the period during which the talent has indicated availability for scheduling.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:callDate rdf:type rdf:Property ;
    rdfs:label 'Call Date' ;
    rdfs:comment 'The scheduled date on which the talent is required to appear for the activity. Follows yyyy-MM-dd format.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'The date and time when this appearance schedule was cancelled, if applicable.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Current lifecycle status of the appearance schedule indicating whether the booking is pending confirmation, confirmed, cancelled, rescheduled, completed, or resulted in a no-show.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityConflictFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Conflict Flag' ;
    rdfs:comment 'Boolean flag indicating whether this appearance schedule conflicts with any exclusivity clauses in the talent\'s contract.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guildNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Guild Notification Required' ;
    rdfs:comment 'Boolean flag indicating whether guild notification is required for this appearance per union agreements (SAG-AFTRA, WGA, DGA).' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guildNotificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Guild Notification Sent Timestamp' ;
    rdfs:comment 'The date and time when notification was sent to the relevant guild regarding this appearance schedule.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdLevel rdf:type rdf:Property ;
    rdfs:label 'Hold Level' ;
    rdfs:comment 'Priority level of the talent booking indicating the strength of the commitment. First hold is highest priority, second and third holds are lower priority backups, first refusal gives talent right to accept or decline before offering to others.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The username or identifier of the user who most recently modified this appearance schedule record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutSystemSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Playout System Sync Status' ;
    rdfs:comment 'Status indicating whether this appearance schedule has been synchronized with the playout and channel management system (Ericsson MediaFirst) for live broadcast coordination.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutSystemSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Playout System Sync Timestamp' ;
    rdfs:comment 'The date and time when this appearance schedule was last synchronized with the playout system.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseTrackingStatus rdf:type rdf:Property ;
    rdfs:label 'Release Tracking Status' ;
    rdfs:comment 'Status of obtaining necessary talent releases, waivers, or permissions required for the appearance, particularly for promotional and publicity activities.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingNotes rdf:type rdf:Property ;
    rdfs:label 'Scheduling Notes' ;
    rdfs:comment 'Free-text field for additional scheduling information, special requirements, or coordination notes relevant to this appearance.' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unavailabilityReason rdf:type rdf:Property ;
    rdfs:label 'Unavailability Reason' ;
    rdfs:comment 'Free-text explanation of why the talent is unavailable during certain periods, such as personal commitments, conflicting bookings, or contractual exclusivity.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wrapTime rdf:type rdf:Property ;
    rdfs:label 'Wrap Time' ;
    rdfs:comment 'The actual or estimated date and time when the talent completed their scheduled activity and was released from the set or location.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:residualPaymentId rdf:type rdf:Property ;
    rdfs:label 'Residual Payment Id' ;
    rdfs:comment 'Unique identifier for the residual payment transaction.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Residual payments are invoiced line items requiring invoice-level tracking for revenue recognition, audit compliance, guild reporting, and payment reconciliation. Completes payment-to-invoice chain fo' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:paymentCycleId rdf:type rdf:Property ;
    rdfs:label 'Payment Cycle Id' ;
    rdfs:comment 'Reference to the payment cycle or batch in which this residual was processed.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cycle .

ind:achTraceNumber rdf:type rdf:Property ;
    rdfs:label 'Ach Trace Number' ;
    rdfs:comment 'The ACH trace number if the payment method is ACH or direct deposit, used for reconciliation and audit.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Agent Commission Amount' ;
    rdfs:comment 'The agent or manager commission amount deducted from the residual payment, if applicable.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditReportDate rdf:type rdf:Property ;
    rdfs:label 'Audit Report Date' ;
    rdfs:comment 'The date on which this residual payment was included in a guild audit report.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditReportFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Report Flag' ;
    rdfs:comment 'Indicates whether this residual payment has been included in a guild audit report (SAG-AFTRA, WGA, DGA).' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'The check number if the payment method is check, used for reconciliation and audit.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exhibitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Exhibition End Date' ;
    rdfs:comment 'The end date of the exhibition period for which this residual is calculated.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exhibitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Exhibition Start Date' ;
    rdfs:comment 'The start date of the exhibition period for which this residual is calculated.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossResidualAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Residual Amount' ;
    rdfs:comment 'The gross residual amount calculated before deductions, in the payment currency.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'The net residual payment amount after all deductions, paid to the talent.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the residual payment (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date on which the residual payment was issued or disbursed to the talent.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentNotes rdf:type rdf:Property ;
    rdfs:label 'Payment Notes' ;
    rdfs:comment 'Free-text notes or comments related to this residual payment, including special circumstances, adjustments, or exceptions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pensionHealthAmount rdf:type rdf:Property ;
    rdfs:label 'Pension Health Amount' ;
    rdfs:comment 'The pension and health contribution amount deducted from the gross residual, as required by guild agreements.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceAdviceSentDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Sent Date' ;
    rdfs:comment 'The date on which the remittance advice was sent to the talent.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remittanceAdviceSentFlag rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Sent Flag' ;
    rdfs:comment 'Indicates whether a remittance advice document was sent to the talent for this payment.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyCalculationReference rdf:type rdf:Property ;
    rdfs:label 'Royalty Calculation Reference' ;
    rdfs:comment 'Reference to the Rightsline royalty calculation record that generated this residual payment.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:useType rdf:type rdf:Property ;
    rdfs:label 'Use Type' ;
    rdfs:comment 'The type of content reuse triggering the residual payment (broadcast, cable, SVOD, AVOD, TVOD, FAST, home video, foreign distribution, theatrical). [ENUM-REF-CANDIDATE: broadcast|cable|SVOD|AVOD|TVOD|FAST|home_video|foreign|theatrical — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Wire Reference Number' ;
    rdfs:comment 'The wire transfer reference number if the payment method is wire transfer, used for reconciliation and audit.' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The tax amount withheld from the residual payment for federal, state, or foreign tax obligations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealMemoId rdf:type rdf:Property ;
    rdfs:label 'Deal Memo Id' ;
    rdfs:comment 'Unique identifier for the talent deal memo record. Primary key.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:longFormContractId rdf:type rdf:Property ;
    rdfs:label 'Long Form Contract Id' ;
    rdfs:comment 'Reference to the executed long-form talent contract that supersedes this deal memo. Null if the long-form contract has not yet been executed.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:productionTitleId rdf:type rdf:Property ;
    rdfs:label 'Production Title Id' ;
    rdfs:comment 'Reference to the production title (series, episode, film, special) for which the talent is engaged.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:compensationAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount' ;
    rdfs:comment 'The primary monetary compensation amount agreed in the deal memo (e.g., total fee, per-episode rate, or guaranteed minimum).' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationSummary rdf:type rdf:Property ;
    rdfs:label 'Compensation Summary' ;
    rdfs:comment 'High-level summary of the compensation structure agreed in the deal memo (e.g., per-episode fee, flat fee, day rate, backend participation). Detailed breakdowns are captured in the long-form contract.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countersignedDate rdf:type rdf:Property ;
    rdfs:label 'Countersigned Date' ;
    rdfs:comment 'The date on which the deal memo was countersigned by both the talent (or agent) and the production company, making it a binding interim agreement. Null if not yet countersigned.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealDate rdf:type rdf:Property ;
    rdfs:label 'Deal Date' ;
    rdfs:comment 'The date on which the deal terms were verbally agreed or the deal memo was initially drafted.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Deal Memo Number' ;
    rdfs:comment 'Externally-known unique business identifier for the deal memo, typically generated by the CRM or legal system.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealMemoStatus rdf:type rdf:Property ;
    rdfs:label 'Deal Memo Status' ;
    rdfs:comment 'Current lifecycle status of the deal memo: draft (under negotiation), countersigned (binding interim agreement), superseded_by_long_form (replaced by executed contract), expired (lapsed without execution), cancelled (deal fell through).' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementEndDate rdf:type rdf:Property ;
    rdfs:label 'Engagement End Date' ;
    rdfs:comment 'The date on which the talent engagement is scheduled to end. Null for open-ended or option-based engagements.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementStartDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Date' ;
    rdfs:comment 'The date on which the talent engagement is scheduled to begin (first day of work, rehearsal, or availability).' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivitySummary rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Summary' ;
    rdfs:comment 'High-level summary of exclusivity terms (e.g., exclusive to network during production, non-exclusive, first-look, holdback period). Detailed clauses are in the long-form contract.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionTerms rdf:type rdf:Property ;
    rdfs:label 'Option Terms' ;
    rdfs:comment 'Summary of any option clauses (e.g., network option for additional seasons, talent option to extend, mutual option). Null if no options are included.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleFunction rdf:type rdf:Property ;
    rdfs:label 'Role Function' ;
    rdfs:comment 'The specific role or function the talent will perform (e.g., Lead Actor, Director, Writer, Executive Producer, Host, Correspondent, Camera Operator).' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededDate rdf:type rdf:Property ;
    rdfs:label 'Superseded Date' ;
    rdfs:comment 'The date on which the deal memo was superseded by the execution of a long-form contract. Null if not yet superseded.' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aboveTheLineFlag rdf:type rdf:Property ;
    rdfs:label 'Above The Line Flag' ;
    rdfs:comment 'Indicates whether this role is classified as above-the-line (creative principals: actors, directors, writers, producers) or below-the-line (technical crew and support staff). Impacts budget allocation and residual calculations.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appearanceCount rdf:type rdf:Property ;
    rdfs:label 'Appearance Count' ;
    rdfs:comment 'Total number of episodes, segments, or appearances in which this talent role is featured. Used for episodic and recurring roles.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:characterName rdf:type rdf:Property ;
    rdfs:label 'Character Name' ;
    rdfs:comment 'The name of the character portrayed by the talent for on-screen roles. Null for off-screen roles such as crew, directors, or producers.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditText rdf:type rdf:Property ;
    rdfs:label 'Credit Text' ;
    rdfs:comment 'The exact text of the credit as it appears on-screen or in marketing materials, including any special formatting or possessory credits (e.g., \'A Film By\', \'Created By\').' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeScopeEnd rdf:type rdf:Property ;
    rdfs:label 'Episode Scope End' ;
    rdfs:comment 'The last episode number in which this talent role appears. Null indicates ongoing engagement or single-episode appearance.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeScopeStart rdf:type rdf:Property ;
    rdfs:label 'Episode Scope Start' ;
    rdfs:comment 'The first episode number in which this talent role appears. Used for episodic content to define the scope of the talent\'s engagement.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Eligible Flag' ;
    rdfs:comment 'Indicates whether this role is eligible for residual payments based on subsequent distribution, reuse, or syndication of the content. Determined by guild agreements and contract terms.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleCategory rdf:type rdf:Property ;
    rdfs:label 'Role Category' ;
    rdfs:comment 'Classification of the role type indicating the nature and scope of the talent\'s engagement. Determines compensation structure, credit placement, and residual eligibility. [ENUM-REF-CANDIDATE: series_regular|recurring|guest_star|day_player|featured_extra|host|correspondent|narrator|voice_artist|director|writer|showrunner|executive_producer|line_producer|cinematographer|editor|composer|production_designer|costume_designer|makeup_artist|stunt_coordinator|other — promote to reference product]' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleName rdf:type rdf:Property ;
    rdfs:label 'Role Name' ;
    rdfs:comment 'The specific role or function the talent is engaged to perform (e.g., Lead Actor, Director, Executive Producer, Cinematographer, Script Supervisor).' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleStatus rdf:type rdf:Property ;
    rdfs:label 'Role Status' ;
    rdfs:comment 'Current lifecycle status of the talent role assignment indicating the stage of engagement from negotiation through completion. [ENUM-REF-CANDIDATE: confirmed|tentative|in_negotiation|contracted|active|completed|cancelled|suspended — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Screen Time Minutes' ;
    rdfs:comment 'Total on-screen time in minutes for this talent role across all appearances. Used for on-screen talent to measure prominence and for residual calculations.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stuntDoubleFlag rdf:type rdf:Property ;
    rdfs:label 'Stunt Double Flag' ;
    rdfs:comment 'Indicates whether this role involves stunt work or if a stunt double is used for this character. Impacts insurance, safety protocols, and credit attribution.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageRightsDurationYears rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Duration Years' ;
    rdfs:comment 'Number of years for which usage rights are granted. Null indicates perpetual rights.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageRightsMedia rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Media' ;
    rdfs:comment 'Media platforms and formats for which usage rights are granted (e.g., \'Theatrical, Home Video, Streaming, Broadcast TV\').' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsTerritory rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Territory' ;
    rdfs:comment 'Geographic territories in which the content featuring this talent role may be distributed and exploited (e.g., \'Worldwide\', \'North America\', \'USA and Canada\').' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voiceOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Voice Only Flag' ;
    rdfs:comment 'Indicates whether this is a voice-only role (voice-over, narration, animation, ADR) with no on-screen physical appearance by the talent.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the representation entity: talent agency (licensed to procure employment), literary agency (represents writers), management company (career guidance), law firm (legal representation), publicity firm (public relations), or hybrid (multiple services).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountName rdf:type rdf:Property ;
    rdfs:label 'Bank Account Name' ;
    rdfs:comment 'The name on the bank account used for commission and residual payments to the agency.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'The bank account number for electronic funds transfer of commissions and residuals to the agency.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'The bank routing number (ABA number in the US, sort code in UK, or equivalent) for electronic funds transfer of commissions and residuals.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'The trade name or doing-business-as name under which the agency operates, if different from the legal name.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'The date on which the talent agency was originally established or incorporated.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'The fax number for the agency, used for contract transmission and official correspondence in jurisdictions where fax is still required.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Effective Date' ;
    rdfs:comment 'The date on which the SAG-AFTRA franchise agreement became effective for this agency.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Expiration Date' ;
    rdfs:comment 'The date on which the current SAG-AFTRA franchise agreement expires and must be renewed.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseNumber rdf:type rdf:Property ;
    rdfs:label 'Franchise Number' ;
    rdfs:comment 'The unique franchise identification number issued by SAG-AFTRA to franchised talent agencies.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseStatus rdf:type rdf:Property ;
    rdfs:label 'Franchise Status' ;
    rdfs:comment 'Indicates whether the agency holds a valid SAG-AFTRA franchise agreement, which authorizes the agency to represent union talent. Franchised agencies agree to standard commission rates and contract terms.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'License Effective Date' ;
    rdfs:comment 'The date on which the state talent agency license became effective.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'License Expiration Date' ;
    rdfs:comment 'The date on which the state talent agency license expires and must be renewed.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseState rdf:type rdf:Property ;
    rdfs:label 'License State' ;
    rdfs:comment 'The state or province that issued the talent agency license. Use standard two-letter state/province codes.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'The job title or role of the primary contact person (e.g., President, Partner, Agent, Business Affairs Manager).' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'The primary email address for official correspondence, contract delivery, and residual payment notifications.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'The primary telephone number for the agency, including country and area codes.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterSize rdf:type rdf:Property ;
    rdfs:label 'Roster Size' ;
    rdfs:comment 'The approximate number of talent clients currently represented by the agency. Used for agency scale assessment and negotiation context.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialization rdf:type rdf:Property ;
    rdfs:label 'Specialization' ;
    rdfs:comment 'The primary area of talent specialization or focus for the agency (e.g., film and television actors, commercial talent, voice-over artists, writers, directors, below-the-line crew, music artists). Free-text field to accommodate multiple specializations.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Standard Commission Rate' ;
    rdfs:comment 'The standard commission rate percentage that the agency charges for talent representation, typically 10% for franchised agencies under SAG-AFTRA rules. Expressed as a percentage (e.g., 10.00 for 10%).' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Status Effective Date' ;
    rdfs:comment 'The date on which the current status became effective.' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:talentAgencyStatus rdf:type rdf:Property ;
    rdfs:label 'Talent Agency Status' ;
    rdfs:comment 'The current operational status of the talent agency: active (currently representing talent), inactive (not currently operating), suspended (temporarily not authorized), pending_verification (under review), or dissolved (permanently closed).' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'The tax identification number (EIN in the US, VAT number in EU) for the agency, used for tax reporting and residual payment processing.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'The primary website URL for the talent agency, used for public information and talent roster visibility.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentContactEmail rdf:type rdf:Property ;
    rdfs:label 'Agent Contact Email' ;
    rdfs:comment 'Primary email address for the agent or representative, used for deal negotiation and residual routing communications.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentContactPhone rdf:type rdf:Property ;
    rdfs:label 'Agent Contact Phone' ;
    rdfs:comment 'Primary phone number for the agent or representative.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentName rdf:type rdf:Property ;
    rdfs:label 'Agent Name' ;
    rdfs:comment 'Full name of the individual agent, manager, or attorney assigned as primary contact for this representation.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for this representation agreement, used for contract reference and audit trails.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionCapAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Cap Amount' ;
    rdfs:comment 'Maximum commission amount per engagement or per year, if a cap is specified in the agreement. Null if no cap applies.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionPercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Percentage' ;
    rdfs:comment 'Percentage of talent earnings paid to the representative as commission (typically 10% for agents, 15% for managers per industry standards).' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDocumentUri rdf:type rdf:Property ;
    rdfs:label 'Contract Document Uri' ;
    rdfs:comment 'URI or file path to the signed representation agreement contract document stored in the Media Asset Management (MAM) system or document repository.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildFranchiseFlag rdf:type rdf:Property ;
    rdfs:label 'Guild Franchise Flag' ;
    rdfs:comment 'Indicates whether the agency or representative is franchised by a talent guild (SAG-AFTRA, WGA, DGA). Franchised agents must comply with guild-mandated commission caps and contract terms.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the agreement includes an automatic renewal option or requires explicit renegotiation at expiration.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:representationAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Representation Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the representation agreement: active (in force), expired (end date reached), terminated (ended early by either party), suspended (temporarily inactive), or pending (signed but not yet effective).' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representationType rdf:type rdf:Property ;
    rdfs:label 'Representation Type' ;
    rdfs:comment 'Classification of the representation relationship: exclusive agent (sole representation), co-agent (shared representation), manager (career management), entertainment attorney (legal counsel), business manager (financial management), or publicist (public relations).' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRoutingFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Routing Flag' ;
    rdfs:comment 'Indicates whether residual payments for work performed during this representation period should be routed through this representative for commission deduction.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeOfServices rdf:type rdf:Property ;
    rdfs:label 'Scope Of Services' ;
    rdfs:comment 'Detailed description of services the representative will provide: deal negotiation, career guidance, audition scheduling, contract review, brand partnerships, etc.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingDate rdf:type rdf:Property ;
    rdfs:label 'Signing Date' ;
    rdfs:comment 'Date when the representation agreement was signed by both parties.' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the representation agreement (commonly 30, 60, or 90 days).' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityType rdf:type rdf:Property ;
    rdfs:label 'Availability Type' ;
    rdfs:comment 'Classification of the availability status: available (talent is free), hold (production has placed a hold), first_refusal (talent has granted first right to book), confirmed_booking (talent is booked), personal_unavailability (talent is unavailable for personal reasons), conflicting_production (talent is committed to another production).' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingConfirmedDate rdf:type rdf:Property ;
    rdfs:label 'Booking Confirmed Date' ;
    rdfs:comment 'The date when the booking was confirmed and the talent was officially committed to the production. Null if not yet confirmed.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictProductionNetwork rdf:type rdf:Property ;
    rdfs:label 'Conflict Production Network' ;
    rdfs:comment 'Network or studio associated with the conflicting production. Used to identify potential exclusivity clause violations.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictProductionTitle rdf:type rdf:Property ;
    rdfs:label 'Conflict Production Title' ;
    rdfs:comment 'Title of the conflicting production when availability_type is conflicting_production. Null if not applicable.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Guild Notification Date' ;
    rdfs:comment 'The date when the guild was notified of this booking. Null if notification not yet sent or not required.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guildNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Guild Notification Required Flag' ;
    rdfs:comment 'Indicates whether guild notification is required for this booking per collective bargaining agreement rules (SAG-AFTRA, WGA, DGA). True if notification required, False otherwise.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Hold Expiration Date' ;
    rdfs:comment 'The date by which the production must confirm the booking or the hold will expire. Null if not applicable.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdPlacedDate rdf:type rdf:Property ;
    rdfs:label 'Hold Placed Date' ;
    rdfs:comment 'The date when the hold was initially placed on the talent. Null if availability_type is not hold or first_refusal.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdReleasedDate rdf:type rdf:Property ;
    rdfs:label 'Hold Released Date' ;
    rdfs:comment 'The date when the hold was released or dropped by the requesting production. Null if hold was not released.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Requesting Contact Email' ;
    rdfs:comment 'Email address of the production contact who placed the availability request.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Requesting Contact Phone' ;
    rdfs:comment 'Phone number of the production contact who placed the availability request.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingDepartment rdf:type rdf:Property ;
    rdfs:label 'Requesting Department' ;
    rdfs:comment 'The department or business unit that requested the availability hold or booking (e.g., Drama Production, News, Sports, Documentary Unit).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingProducerName rdf:type rdf:Property ;
    rdfs:label 'Requesting Producer Name' ;
    rdfs:comment 'Name of the producer or production manager who requested the availability hold or booking.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByRateCardCbaRateCardId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Card Cba Rate Card Id' ;
    rdfs:comment 'Reference to the newer CBA rate card entry that replaces this one, if applicable.' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CbaRateCard .

ind:budgetTier rdf:type rdf:Property ;
    rdfs:label 'Budget Tier' ;
    rdfs:comment 'Production budget classification that determines applicable rates (e.g., high budget, low budget, ultra-low budget, modified low budget).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbaCode rdf:type rdf:Property ;
    rdfs:label 'Cba Code' ;
    rdfs:comment 'Standardized code identifying the specific collective bargaining agreement (e.g., SAG_AFTRA_TV, DGA_BASIC, WGA_MBA, IATSE_BASIC).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbaName rdf:type rdf:Property ;
    rdfs:label 'Cba Name' ;
    rdfs:comment 'Full legal name of the collective bargaining agreement (e.g., SAG-AFTRA Television Agreement, DGA Basic Agreement, WGA Minimum Basic Agreement).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbaRatificationDate rdf:type rdf:Property ;
    rdfs:label 'Cba Ratification Date' ;
    rdfs:comment 'Date when the CBA was ratified by the guild membership.' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cbaVersion rdf:type rdf:Property ;
    rdfs:label 'Cba Version' ;
    rdfs:comment 'Version identifier of the CBA document (e.g., 2023-2026, v4.2).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forcedCallPenaltyMultiplier rdf:type rdf:Property ;
    rdfs:label 'Forced Call Penalty Multiplier' ;
    rdfs:comment 'Multiplier applied when talent is called back to work before the minimum turnaround period has elapsed.' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goldenTimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Golden Time Multiplier' ;
    rdfs:comment 'Multiplier applied to base rate for hours worked beyond double-time threshold (e.g., 3.0 for triple-time), applicable in certain guild agreements.' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobClassification rdf:type rdf:Property ;
    rdfs:label 'Job Classification' ;
    rdfs:comment 'Specific job title or classification within the performer category (e.g., Series Regular, Guest Star, Co-Star, Director of Photography, Script Supervisor).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mealPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Meal Penalty Amount' ;
    rdfs:comment 'Penalty payment owed to talent when meal breaks are not provided within the CBA-mandated timeframe.' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumScaleRate rdf:type rdf:Property ;
    rdfs:label 'Minimum Scale Rate' ;
    rdfs:comment 'Minimum compensation amount defined by the CBA for this rate type and performer category.' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Threshold Hours' ;
    rdfs:comment 'Number of hours worked before overtime rates apply (e.g., 8.0 for daily overtime, 40.0 for weekly overtime).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pensionHealthContributionRate rdf:type rdf:Property ;
    rdfs:label 'Pension Health Contribution Rate' ;
    rdfs:comment 'Percentage of gross compensation that the employer must contribute to pension and health funds as mandated by the CBA (e.g., 0.1850 for 18.5%).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performerCategory rdf:type rdf:Property ;
    rdfs:label 'Performer Category' ;
    rdfs:comment 'Classification of the talent role covered by this rate (e.g., principal performer, day player, stunt performer, background actor, director, writer, producer, crew member).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionType rdf:type rdf:Property ;
    rdfs:label 'Production Type' ;
    rdfs:comment 'Type of production this rate applies to (e.g., theatrical motion picture, television series, television movie, new media, commercial, industrial).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of this rate card entry (active, expired, superseded, pending, draft).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualFormulaCode rdf:type rdf:Property ;
    rdfs:label 'Residual Formula Code' ;
    rdfs:comment 'Code identifying the residual calculation formula applicable to this rate (e.g., NETWORK_PRIME, BASIC_CABLE, SVOD_HIGH_BUDGET).' ;
    rdfs:domain ind:CbaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPartnerId rdf:type rdf:Property ;
    rdfs:label 'Parent Partner Id' ;
    rdfs:comment 'Reference to the parent partner entity in cases where this partner is a subsidiary or division of a larger corporate entity. Enables tracking of corporate hierarchies and consolidated relationships. Null for top-level parent entities.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:primaryRegulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Partners (distributors, affiliates, content licensors, co-producers) must meet specific regulatory obligations (content standards, closed captioning, political advertising rules, children\'s programmin' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:annualContentVolumeHours rdf:type rdf:Property ;
    rdfs:label 'Annual Content Volume Hours' ;
    rdfs:comment 'Estimated or actual annual volume of content hours acquired from or distributed through this partner. Used for capacity planning, content pipeline forecasting, and partner performance evaluation.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenueContributionUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Contribution Usd' ;
    rdfs:comment 'Estimated or actual annual revenue contribution from this partner relationship in USD. Includes content licensing fees, distribution revenue share, advertising revenue, or other monetization streams. Used for partner valuation and ROI analysis.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentSpecialization rdf:type rdf:Property ;
    rdfs:label 'Content Specialization' ;
    rdfs:comment 'Primary content genres, formats, or categories that the partner specializes in producing or distributing. Examples include scripted drama, unscripted reality, sports, news, children\'s programming, documentary, or multi-genre. Supports content acquisition strategy and partner matching.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Date' ;
    rdfs:comment 'Next scheduled date for master agreement renewal or renegotiation with this partner. Used for relationship management planning, contract pipeline tracking, and ensuring continuity of content supply or distribution.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:corporateHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Corporate Hierarchy Level' ;
    rdfs:comment 'Numeric level in the corporate hierarchy tree where 1 represents the ultimate parent entity and higher numbers represent deeper subsidiary levels. Used for roll-up reporting and consolidated analytics.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'External credit rating assigned by rating agencies such as Moody\'s, S&P, or Fitch. Used for financial risk assessment, contract negotiation, and determining payment terms or guarantees required.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionTerritories rdf:type rdf:Property ;
    rdfs:label 'Distribution Territories' ;
    rdfs:comment 'Geographic territories or markets where the partner operates or holds distribution rights. Stored as comma-separated list of country codes or region identifiers. Critical for rights management and windowing strategy.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domicileCountryCode rdf:type rdf:Property ;
    rdfs:label 'Domicile Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the legal domicile jurisdiction where the partner entity is incorporated or registered. Determines applicable regulatory frameworks and tax treaties.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit unique identifier assigned by Dun & Bradstreet to identify business entities globally. Used for credit assessment, vendor management, and corporate hierarchy tracking.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'First line of the physical headquarters address including street number and street name. Used for legal correspondence, contract execution, and regulatory filings.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line2' ;
    rdfs:comment 'Second line of the physical headquarters address for suite, floor, building name, or other secondary address details.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User identifier or system account that performed the most recent modification to this partner record. Used for audit trail and accountability.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStage rdf:type rdf:Property ;
    rdfs:label 'Onboarding Stage' ;
    rdfs:comment 'Current stage in the partner onboarding workflow. Tracks progression from initial prospect through due diligence, contract negotiation, legal review, approval, and final onboarding completion.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCode rdf:type rdf:Property ;
    rdfs:label 'Partner Code' ;
    rdfs:comment 'Externally-known unique business identifier for the partner used in operational systems, contracts, and inter-company communications. Typically assigned during onboarding.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'The full legal name of the partner organization as registered with governing authorities. Used for contracts, invoicing, and legal documentation.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPaymentTerms rdf:type rdf:Property ;
    rdfs:label 'Preferred Payment Terms' ;
    rdfs:comment 'Standard payment terms negotiated with the partner for content licensing, royalties, or service fees. Examples include Net 30, Net 60, advance against royalties, or milestone-based payments. Feeds into accounts payable and cash flow planning.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date when the business relationship with this partner was formally terminated or is scheduled to end. Null for active ongoing relationships. Used for historical analysis and transition planning.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date when the business relationship with this partner was formally established, typically corresponding to the first executed agreement or onboarding completion. Used for relationship tenure analysis and anniversary tracking.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Internal risk classification based on financial stability, contract compliance history, operational reliability, and strategic importance. Used for relationship management prioritization and escalation protocols.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Tier' ;
    rdfs:comment 'Classification of the partner\'s strategic importance to the business. Tier 1 represents critical strategic partners with significant content volume or distribution reach, Tier 2 represents important but not critical partners, Tier 3 represents transactional relationships, and emerging represents new partners under evaluation.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Secondary classification providing additional granularity within the partner type. Examples include major studio vs independent studio, first-run syndicator vs off-network syndicator, FAST channel operator, co-production house, or affiliate network.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique identifier for the partner contact record. Primary key.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assistantEmail rdf:type rdf:Property ;
    rdfs:label 'Assistant Email' ;
    rdfs:comment 'The email address of the contacts executive assistant, used for meeting coordination and scheduling.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantName rdf:type rdf:Property ;
    rdfs:label 'Assistant Name' ;
    rdfs:comment 'The name of the contacts executive assistant or administrative support person, if applicable. Used for scheduling and coordination.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantPhone rdf:type rdf:Property ;
    rdfs:label 'Assistant Phone' ;
    rdfs:comment 'The phone number of the contacts executive assistant, used for urgent scheduling needs and coordination.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationLanguage rdf:type rdf:Property ;
    rdfs:label 'Communication Language' ;
    rdfs:comment 'The preferred language for business communications with this contact, specified using ISO 639-1 two-letter language codes (e.g., EN, ES, FR).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the partner contact. Indicates whether the contact is actively engaged, temporarily unavailable, or no longer with the partner organization.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractSignatory rdf:type rdf:Property ;
    rdfs:label 'Contract Signatory' ;
    rdfs:comment 'Boolean flag indicating whether this contact has legal authority to sign contracts and binding agreements on behalf of the partner organization.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionMakingAuthority rdf:type rdf:Property ;
    rdfs:label 'Decision Making Authority' ;
    rdfs:comment 'The level of decision-making authority the contact has within their organization for partnership matters, contract negotiations, and business agreements.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'The first name or given name of the partner contact individual.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'The complete formatted name of the partner contact, typically combining first, middle, and last names.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Boolean flag indicating whether this contact is the primary or main point of contact for the partner organization.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'The official job title or position of the contact within the partner organization (e.g., Vice President of Content Acquisition, Director of Business Development, Legal Counsel).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'The date of the most recent business interaction or communication with this partner contact. Used for relationship health tracking.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'The last name or family name of the partner contact individual.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'The URL to the contacts professional LinkedIn profile, used for professional networking and background verification.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile or cell phone number for the partner contact, used for urgent communications and on-the-go accessibility.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaSignedDate rdf:type rdf:Property ;
    rdfs:label 'Nda Signed Date' ;
    rdfs:comment 'The date when the contact signed a non-disclosure agreement with Media Broadcasting, if applicable. Used to track confidentiality obligations.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledContactDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Contact Date' ;
    rdfs:comment 'The planned date for the next scheduled interaction or follow-up with this partner contact. Supports proactive relationship management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'The physical office location or city where the contact is based within the partner organization.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Method' ;
    rdfs:comment 'The contacts preferred method of communication for business interactions and negotiations.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'The functional role category of the contact within the partnership context. Defines the primary area of responsibility and engagement. [ENUM-REF-CANDIDATE: executive|legal|business_development|technical|finance|operations|marketing — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'The user identifier or name of the person who last modified this partner contact record.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDeliveryFormat rdf:type rdf:Property ;
    rdfs:label 'Content Delivery Format' ;
    rdfs:comment 'Technical specifications for content delivery including file formats, resolution standards, and delivery methods (e.g., HD 1080p ProRes, 4K HEVC, physical media, digital file transfer).' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentPackageScope rdf:type rdf:Property ;
    rdfs:label 'Content Package Scope' ;
    rdfs:comment 'Detailed description of the content included in this acquisition deal, including series titles, episode counts, seasons, or film packages.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the executed contract document stored in the document management system.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Contract Execution Date' ;
    rdfs:comment 'Date when the acquisition deal contract was formally signed and executed by all parties, marking the transition from negotiation to binding agreement.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Deal Effective Date' ;
    rdfs:comment 'Date when the acquisition deal terms become effective and rights begin to accrue, which may differ from execution date.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Deal Expiration Date' ;
    rdfs:comment 'Date when the acquisition deal expires and rights revert to the content provider, marking the end of the license period.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealNumber rdf:type rdf:Property ;
    rdfs:label 'Deal Number' ;
    rdfs:comment 'Externally-known business identifier for the acquisition deal, typically formatted with prefix and sequential number for tracking and reference in contracts and communications.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealStatus rdf:type rdf:Property ;
    rdfs:label 'Deal Status' ;
    rdfs:comment 'Current lifecycle status of the acquisition deal from initial draft through negotiation, execution, and eventual expiration or termination. [ENUM-REF-CANDIDATE: draft|negotiation|legal_review|approved|executed|active|expired|terminated|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealTitle rdf:type rdf:Property ;
    rdfs:label 'Deal Title' ;
    rdfs:comment 'Human-readable name or title of the acquisition deal, typically reflecting the content package or series being acquired.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealValueAmount rdf:type rdf:Property ;
    rdfs:label 'Deal Value Amount' ;
    rdfs:comment 'Total monetary value of the acquisition deal in the specified currency, representing the gross commitment before adjustments.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionRights rdf:type rdf:Property ;
    rdfs:label 'Distribution Rights' ;
    rdfs:comment 'Comma-separated list of distribution platforms and methods covered by this deal (e.g., linear, SVOD, AVOD, TVOD, FAST, syndication, VOD).' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseTermMonths rdf:type rdf:Property ;
    rdfs:label 'License Term Months' ;
    rdfs:comment 'Duration of the content license in months, representing the period during which the broadcaster has rights to exploit the acquired content.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketingMaterialsIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Materials Included Flag' ;
    rdfs:comment 'Indicates whether the deal includes delivery of marketing and promotional materials such as trailers, key art, press kits, and promotional clips.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metadataRequirements rdf:type rdf:Property ;
    rdfs:label 'Metadata Requirements' ;
    rdfs:comment 'Specifications for content metadata to be delivered with the content package, including descriptive, technical, and rights metadata standards.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationStartDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Start Date' ;
    rdfs:comment 'Date when formal negotiations for this acquisition deal commenced.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentSchedule rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule' ;
    rdfs:comment 'Detailed schedule of payment milestones and amounts, including upfront payments, delivery payments, and ongoing royalty schedules.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceGuarantees rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantees' ;
    rdfs:comment 'Contractual performance commitments such as minimum broadcast hours, promotional support, or audience delivery guarantees required by the content provider.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percentage' ;
    rdfs:comment 'Percentage of revenue shared with the content provider for revenue share and hybrid deal structures, typically applied after minimum guarantee recoupment.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sublicensingTerms rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Terms' ;
    rdfs:comment 'Detailed terms and restrictions governing sublicensing rights, including revenue sharing with original content provider and territorial limitations.' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCoverage rdf:type rdf:Property ;
    rdfs:label 'Territory Coverage' ;
    rdfs:comment 'Geographic territories or markets covered by this acquisition deal, specified as comma-separated ISO 3166-1 alpha-3 country codes or regional designations (e.g., USA, CAN, GBR, or NORTH_AMERICA).' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDealLineId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Deal Line Id' ;
    rdfs:comment 'Unique identifier for the acquisition deal line item. Primary key for this entity.' ;
    rdfs:domain ind:AcquisitionDealLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryDueDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Due Date' ;
    rdfs:comment 'The date by which the content provider must deliver the content asset for this line item. Critical for production scheduling and playout planning.' ;
    rdfs:domain ind:AcquisitionDealLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseDurationMonths rdf:type rdf:Property ;
    rdfs:label 'License Duration Months' ;
    rdfs:comment 'Total duration of the license term expressed in months. Calculated from start and end dates for reporting and windowing analysis.' ;
    rdfs:domain ind:AcquisitionDealLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'License Fee Amount' ;
    rdfs:comment 'The base license fee amount for this specific content line item. Represents the core acquisition cost before adjustments.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseTermEndDate rdf:type rdf:Property ;
    rdfs:label 'License Term End Date' ;
    rdfs:comment 'The date when the license rights for this content line item expire. Marks the end of the rights window.' ;
    rdfs:domain ind:AcquisitionDealLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseTermStartDate rdf:type rdf:Property ;
    rdfs:label 'License Term Start Date' ;
    rdfs:comment 'The date when the license rights for this content line item become effective. Marks the beginning of the rights window.' ;
    rdfs:domain ind:AcquisitionDealLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Contracting Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Distribution agreements are executed by specific legal entities for proper revenue recognition, tax jurisdiction determination, and SOX compliance. Essential for carriage fee revenue allocation and in' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:auditRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Included' ;
    rdfs:comment 'Indicates whether Media Broadcasting retains the right to audit the distributors subscriber counts, revenue reports, and compliance with agreement terms.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelsIncluded rdf:type rdf:Property ;
    rdfs:label 'Channels Included' ;
    rdfs:comment 'List or description of Media Broadcasting channels covered by this distribution agreement (e.g., primary network, secondary channels, HD feeds, regional variants).' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'URL or file path to the signed distribution agreement contract document stored in the document management system.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryObligation rdf:type rdf:Property ;
    rdfs:label 'Must Carry Obligation' ;
    rdfs:comment 'Indicates whether this agreement includes must-carry obligations under FCC regulations requiring the distributor to carry the broadcast signal.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiatedBy rdf:type rdf:Property ;
    rdfs:label 'Negotiated By' ;
    rdfs:comment 'Name or identifier of the Media Broadcasting executive or team responsible for negotiating this distribution agreement.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Hours' ;
    rdfs:comment 'Maximum response time in hours for addressing service disruptions or technical issues under the SLA.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percentage' ;
    rdfs:comment 'Minimum uptime percentage guaranteed under the Service Level Agreement (SLA) for signal delivery and availability.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:streamingRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Streaming Rights Included' ;
    rdfs:comment 'Indicates whether the agreement includes rights for the distributor to offer live streaming or simulcast of Media Broadcasting channels via OTT platforms.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:svodRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Svod Rights Included' ;
    rdfs:comment 'Indicates whether the agreement includes rights for the distributor to offer Subscription Video On Demand (SVOD) access as part of a subscription package.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territory rdf:type rdf:Property ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Geographic territory or market covered by this distribution agreement. May include country codes, DMA codes, or regional descriptors.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tvodRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Tvod Rights Included' ;
    rdfs:comment 'Indicates whether the agreement includes rights for the distributor to offer Transactional Video On Demand (TVOD) access where viewers pay per transaction.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vodRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Vod Rights Included' ;
    rdfs:comment 'Indicates whether the agreement includes rights for the distributor to offer Video On Demand (VOD) access to Media Broadcasting content.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vodWindowDays rdf:type rdf:Property ;
    rdfs:label 'Vod Window Days' ;
    rdfs:comment 'Number of days that content remains available in the distributors VOD library after initial broadcast, if VOD rights are included.' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:syndicationPartnerId rdf:type rdf:Property ;
    rdfs:label 'Syndication Partner Id' ;
    rdfs:comment 'Reference to the third-party broadcaster, regional station, or international network acquiring syndication rights.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:auditRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Flag' ;
    rdfs:comment 'Indicates whether Media Broadcasting retains the right to audit the syndication partner\'s broadcast logs and financial records.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:barterSpotCount rdf:type rdf:Property ;
    rdfs:label 'Barter Spot Count' ;
    rdfs:comment 'Number of advertising spots retained by Media Broadcasting per episode in barter syndication arrangements.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearanceObligation rdf:type rdf:Property ;
    rdfs:label 'Clearance Obligation' ;
    rdfs:comment 'Party responsible for obtaining broadcast clearances and rights verification in the syndication territory.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Window End Date' ;
    rdfs:comment 'End date of the exclusivity period. Nullable if exclusivity_flag is false.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Window Start Date' ;
    rdfs:comment 'Start date of the exclusivity period during which no other syndication partner may broadcast the content in the granted territory. Nullable if exclusivity_flag is false.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flatFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Fee Amount' ;
    rdfs:comment 'Total flat fee amount for the entire syndication agreement. Applicable when syndication_fee_structure is flat_fee or hybrid.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perEpisodeFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Per Episode Fee Amount' ;
    rdfs:comment 'Fee amount charged per episode. Applicable when syndication_fee_structure is per_episode or hybrid.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceGuarantee rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee' ;
    rdfs:comment 'Minimum performance commitments required from the syndication partner, such as minimum broadcast frequency or audience reach targets.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days prior to expiration that the syndication partner must provide notice to exercise renewal option.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runLimit rdf:type rdf:Property ;
    rdfs:label 'Run Limit' ;
    rdfs:comment 'Maximum number of times each episode may be broadcast by the syndication partner during the agreement term.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when the syndication agreement was executed by all parties.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:syndicationFeeStructure rdf:type rdf:Property ;
    rdfs:label 'Syndication Fee Structure' ;
    rdfs:comment 'Compensation model governing how the syndication partner pays for content rights.' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Conditions and procedures under which either party may terminate the agreement prior to the effective end date.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryGrant rdf:type rdf:Property ;
    rdfs:label 'Territory Grant' ;
    rdfs:comment 'Geographic territories where the syndication partner is granted broadcast rights. Pipe-separated list of ISO 3166-1 alpha-3 country codes or regional designations. [ENUM-REF-CANDIDATE: USA|CAN|GBR|AUS|DEU|FRA|JPN|BRA|MEX|IND|CHN — promote to reference product]' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadPartnerId rdf:type rdf:Property ;
    rdfs:label 'Lead Partner Id' ;
    rdfs:comment 'Reference to the primary partner organization responsible for managing the co-production.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:leadTalentProfileId rdf:type rdf:Property ;
    rdfs:label 'Lead Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: Co-production agreements frequently specify lead talent (star, showrunner, director) as part of the deal structure—attached talent drives financing approval and production greenlight decisions. Critic' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:targetDemographicSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Demographic Segment Id' ;
    rdfs:comment 'Foreign key linking to audience.demographic_segment. Business justification: Coproduction partnerships target specific audience demographics to justify investment allocation and distribution strategy. Partners negotiate budget share and territory rights based on expected audie' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemographicSegment .

ind:auditRights rdf:type rdf:Property ;
    rdfs:label 'Audit Rights' ;
    rdfs:comment 'Provisions allowing partners to audit financial records and production accounts related to the co-production.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the total budget amount.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityTerms rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Terms' ;
    rdfs:comment 'Non-disclosure obligations and confidentiality requirements binding all co-production partners.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeControlLevel rdf:type rdf:Property ;
    rdfs:label 'Creative Control Level' ;
    rdfs:comment 'Degree of creative decision-making authority held by our organization in the production process.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditObligation rdf:type rdf:Property ;
    rdfs:label 'Credit Obligation' ;
    rdfs:comment 'Contractual requirements for on-screen and promotional credits for each co-production partner.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Agreed-upon mechanism for resolving disputes between co-production partners.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionRightsAllocation rdf:type rdf:Property ;
    rdfs:label 'Distribution Rights Allocation' ;
    rdfs:comment 'Description of how distribution rights are divided among co-production partners by territory and platform.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureProvision rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Provision' ;
    rdfs:comment 'Contractual terms addressing obligations and liabilities in the event of unforeseeable circumstances preventing performance.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Mandatory insurance coverage types and amounts required for the co-production.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ourInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Our Investment Amount' ;
    rdfs:comment 'Financial contribution amount committed by our organization to the co-production.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ourInvestmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Our Investment Percentage' ;
    rdfs:comment 'Percentage of total production budget contributed by our organization.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ourIpOwnershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Our Ip Ownership Percentage' ;
    rdfs:comment 'Percentage of intellectual property rights owned by our organization in the co-produced content.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ourPrimaryTerritory rdf:type rdf:Property ;
    rdfs:label 'Our Primary Territory' ;
    rdfs:comment 'Geographic territory or territories where our organization holds primary distribution rights.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionEndDate rdf:type rdf:Property ;
    rdfs:label 'Production End Date' ;
    rdfs:comment 'Scheduled or actual date when principal photography or production activities are completed.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionStartDate rdf:type rdf:Property ;
    rdfs:label 'Production Start Date' ;
    rdfs:comment 'Scheduled or actual date when principal photography or production activities commence.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residualsSharingFormula rdf:type rdf:Property ;
    rdfs:label 'Residuals Sharing Formula' ;
    rdfs:comment 'Formula or methodology for distributing residual payments to talent among co-production partners.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharingModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Sharing Model' ;
    rdfs:comment 'Methodology for distributing revenues generated from the co-produced content among partners.' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'Total production budget for the co-produced content across all partners.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affiliateStationPartnerId rdf:type rdf:Property ;
    rdfs:label 'Affiliate Station Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: affiliate_agreement.affiliate_station_id represents the affiliate station partner. Renaming to affiliate_station_partner_id for clarity (ends with partner_partner_partner_id pattern). Links to partner' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:measurementPanelId rdf:type rdf:Property ;
    rdfs:label 'Measurement Panel Id' ;
    rdfs:comment 'Foreign key linking to audience.panel. Business justification: Affiliate agreements contractually specify which Nielsen panel (or other measurement panel) is the official source for performance verification and compensation calculations. Agreements reference spec' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Panel .

ind:networkLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Network Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Affiliate agreements generate intercompany transactions requiring legal entity tracking for network compensation accounting, retransmission revenue split allocation, and consolidation elimination. Cri' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryAffiliateStationChannelId rdf:type rdf:Property ;
    rdfs:label 'Primary Affiliate Station Channel Id' ;
    rdfs:comment 'Reference to the local broadcast station or regional affiliate partner that is party to this agreement.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:tertiaryAffiliateNetworkChannelId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Affiliate Network Channel Id' ;
    rdfs:comment 'Reference to the parent network or broadcast network entity that is the counterparty to this affiliate agreement.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:affiliationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Affiliation Fee Amount' ;
    rdfs:comment 'Monthly or annual fee paid by the network to the affiliate station for carrying network programming, or reverse compensation paid by affiliate to network. Negative values indicate reverse compensation.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affiliationFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Affiliation Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the affiliation fee amount (e.g., USD, CAD, GBP).' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliationFeeFrequency rdf:type rdf:Property ;
    rdfs:label 'Affiliation Fee Frequency' ;
    rdfs:comment 'Frequency at which affiliation fees are calculated and paid between network and affiliate.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalRightsIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Rights Included Flag' ;
    rdfs:comment 'Indicates whether the affiliate agreement includes rights to distribute network content via digital platforms, streaming services, and Over-The-Top (OTT) channels.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityTerritory rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Territory' ;
    rdfs:comment 'Geographic territory within which the affiliate has exclusive rights to broadcast network programming, typically defined by DMA boundaries, county lists, or signal contours.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localAdAvailsMinutesPerHour rdf:type rdf:Property ;
    rdfs:label 'Local Ad Avails Minutes Per Hour' ;
    rdfs:comment 'Number of minutes per hour of network programming that the affiliate may use for local advertising insertion, typically 2-4 minutes per hour.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localInsertionRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Local Insertion Rights Flag' ;
    rdfs:comment 'Indicates whether the affiliate has the right to insert local advertising spots during designated network programming breaks (ad pods).' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumClearancePercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Clearance Percentage' ;
    rdfs:comment 'Minimum percentage of network programming hours that the affiliate is contractually obligated to broadcast, typically 85-95% for primary affiliates. Expressed as percentage (e.g., 90.00 for 90%).' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mustAirProgrammingHours rdf:type rdf:Property ;
    rdfs:label 'Must Air Programming Hours' ;
    rdfs:comment 'Minimum number of weekly hours of network programming that the affiliate must broadcast without preemption, including prime-time, news, and sports.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkCompensationModel rdf:type rdf:Property ;
    rdfs:label 'Network Compensation Model' ;
    rdfs:comment 'Economic model governing compensation flow between network and affiliate: fixed fee paid to affiliate, revenue share from advertising, audience-based payments, hybrid model, or reverse compensation where affiliate pays network.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMeasurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Performance Measurement Methodology' ;
    rdfs:comment 'Audience measurement methodology used to assess affiliate performance against contractual standards (Nielsen ratings, Comscore, proprietary measurement, or multi-source approach).' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceStandardGrpMinimum rdf:type rdf:Property ;
    rdfs:label 'Performance Standard Grp Minimum' ;
    rdfs:comment 'Minimum Gross Rating Points (GRP) that the affiliate must deliver for network programming to meet performance standards and avoid penalties or compensation adjustments.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preemptionNoticeHours rdf:type rdf:Property ;
    rdfs:label 'Preemption Notice Hours' ;
    rdfs:comment 'Minimum number of hours advance notice the affiliate must provide to the network before preempting scheduled programming, typically 24-72 hours except for breaking news.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preemptionRights rdf:type rdf:Property ;
    rdfs:label 'Preemption Rights' ;
    rdfs:comment 'Extent to which the affiliate may preempt scheduled network programming for local content, special events, or breaking news. Preemption typically requires advance notice and makegoods.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Included Flag' ;
    rdfs:comment 'Indicates whether the affiliate agreement includes provisions for retransmission consent negotiations with Multichannel Video Programming Distributors (MVPDs) and virtual MVPDs (vMVPDs).' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retransmissionRevenueSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Retransmission Revenue Split Percentage' ;
    rdfs:comment 'Percentage of retransmission consent fees collected from MVPDs that the affiliate must share with the network. Expressed as percentage (e.g., 30.00 for 30% to network).' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:simulcastRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Simulcast Requirement Flag' ;
    rdfs:comment 'Indicates whether the affiliate is required to simulcast network programming simultaneously across multiple platforms (linear broadcast, digital streaming, mobile apps).' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termLengthMonths rdf:type rdf:Property ;
    rdfs:label 'Term Length Months' ;
    rdfs:comment 'Duration of the affiliate agreement term expressed in months, typically ranging from 12 to 60 months for broadcast affiliations.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationForCauseProvisions rdf:type rdf:Property ;
    rdfs:label 'Termination For Cause Provisions' ;
    rdfs:comment 'Description of conditions under which either party may terminate the agreement for cause, including breach of clearance obligations, payment defaults, license revocation, or material violations of broadcast standards.' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Delivered Asset Version Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_version. Business justification: Delivery obligations specify exact version/format requirements (HD vs 4K, dubbed vs subtitled). Tracks which specific version satisfies contractual delivery for acceptance sign-off, QC validation, and' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the partner formally accepted the delivered content as meeting technical and contractual specifications.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:audioTrackLanguages rdf:type rdf:Property ;
    rdfs:label 'Audio Track Languages' ;
    rdfs:comment 'Comma-separated list of audio track languages that must be included in the delivery, using ISO 639 codes.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDeadline rdf:type rdf:Property ;
    rdfs:label 'Delivery Deadline' ;
    rdfs:comment 'Contractually agreed date by which the content must be delivered to the partner.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drmRequirement rdf:type rdf:Property ;
    rdfs:label 'Drm Requirement' ;
    rdfs:comment 'Digital rights management protection required for the delivered content to prevent unauthorized access and distribution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isanIdentifier rdf:type rdf:Property ;
    rdfs:label 'Isan Identifier' ;
    rdfs:comment 'International Standard Audiovisual Number uniquely identifying the audiovisual work being delivered.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Number' ;
    rdfs:comment 'Business identifier for the delivery obligation, typically referenced in contracts and communications.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Financial penalty amount incurred for late delivery or non-compliance with delivery specifications, in the contract currency.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Qc Completion Date' ;
    rdfs:comment 'Date on which quality control review was completed and content was approved for delivery.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Control Status' ;
    rdfs:comment 'Status of quality control review process for the content before delivery to ensure technical compliance.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redeliveryRequired rdf:type rdf:Property ;
    rdfs:label 'Redelivery Required' ;
    rdfs:comment 'Indicates whether the content must be redelivered due to rejection or technical issues with the initial delivery.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredBitrateMbps rdf:type rdf:Property ;
    rdfs:label 'Required Bitrate Mbps' ;
    rdfs:comment 'Minimum or target bitrate in megabits per second required for the delivered content to meet quality standards.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredCodec rdf:type rdf:Property ;
    rdfs:label 'Required Codec' ;
    rdfs:comment 'Video and audio codec specifications required for the delivery, such as H.264, H.265, AAC, or Dolby Digital.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredFormat rdf:type rdf:Property ;
    rdfs:label 'Required Format' ;
    rdfs:comment 'Technical delivery format required by the partner, such as HLS (HTTP Live Streaming), MPEG-DASH (Dynamic Adaptive Streaming over HTTP), or mezzanine file format.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredResolution rdf:type rdf:Property ;
    rdfs:label 'Required Resolution' ;
    rdfs:comment 'Video resolution specification required for delivery, ranging from standard definition to ultra-high definition.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCompliance rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance' ;
    rdfs:comment 'Indicates whether the delivery was completed within the service level agreement timeframe specified in the partner contract.' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Schedule Id' ;
    rdfs:comment 'Unique identifier for the carriage fee schedule. Primary key for this entity.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseFeePerSubscriber rdf:type rdf:Property ;
    rdfs:label 'Base Fee Per Subscriber' ;
    rdfs:comment 'The baseline carriage fee amount charged per subscriber per month. This is the foundational rate before any escalations, discounts, or adjustments are applied.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationFrequency rdf:type rdf:Property ;
    rdfs:label 'Escalation Frequency' ;
    rdfs:comment 'Frequency at which fee escalations are applied. Defines how often the base fee is adjusted according to the escalation type and rate.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Escalation Rate Percentage' ;
    rdfs:comment 'Annual percentage rate by which the base fee per subscriber increases, if escalation type is fixed percentage. Expressed as a percentage (e.g., 3.00 for 3% annual increase).' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationType rdf:type rdf:Property ;
    rdfs:label 'Escalation Type' ;
    rdfs:comment 'Method by which carriage fees increase over time. Options include no escalation, fixed annual percentage increase, Consumer Price Index (CPI) indexing, negotiated increases at specified intervals, or tiered increases based on subscriber growth.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeType rdf:type rdf:Property ;
    rdfs:label 'Fee Type' ;
    rdfs:comment 'Classification of the fee structure. Indicates whether fees are charged per subscriber, as a flat monthly rate, in tiers based on subscriber count, volume-based with discounts, a hybrid model, or as a percentage of revenue share.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latePaymentPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Rate' ;
    rdfs:comment 'Percentage rate applied as a penalty for late payment of carriage fees beyond the payment terms. Expressed as an annual percentage rate or per-period rate.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumFeeCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Fee Cap' ;
    rdfs:comment 'The maximum total carriage fee amount per billing period, regardless of subscriber count. Protects the distributor from excessive fees in high-subscriber scenarios.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mfnProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Mfn Provision Flag' ;
    rdfs:comment 'Boolean indicator of whether this schedule includes a Most-Favored-Nation clause. If true, the distributor is entitled to the most favorable carriage fee terms that Media Broadcasting offers to any comparable distributor.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mfnScope rdf:type rdf:Property ;
    rdfs:label 'Mfn Scope' ;
    rdfs:comment 'Defines the scope and conditions under which the MFN provision applies, including comparable distributor criteria, geographic limitations, and exclusions.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteedFee rdf:type rdf:Property ;
    rdfs:label 'Minimum Guaranteed Fee' ;
    rdfs:comment 'The minimum total carriage fee amount guaranteed per billing period, regardless of subscriber count. Protects Media Broadcasting revenue in low-subscriber scenarios.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Frequency at which carriage fees are invoiced and paid by the distributor. Defines the billing cycle for this fee schedule.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberCountSource rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count Source' ;
    rdfs:comment 'Source of subscriber count data used to calculate carriage fees. Options include distributor self-reporting, third-party audit, Nielsen measurement, or Media Broadcasting internal estimates.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeDiscountTier1Rate rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 1 Rate' ;
    rdfs:comment 'Discounted per-subscriber fee rate applicable when subscriber count exceeds the Tier 1 threshold.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountTier1Threshold rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 1 Threshold' ;
    rdfs:comment 'Subscriber count threshold at which the first volume discount tier is triggered. Distributors exceeding this subscriber count qualify for a reduced per-subscriber fee.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeDiscountTier2Rate rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 2 Rate' ;
    rdfs:comment 'Discounted per-subscriber fee rate applicable when subscriber count exceeds the Tier 2 threshold.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountTier2Threshold rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 2 Threshold' ;
    rdfs:comment 'Subscriber count threshold at which the second volume discount tier is triggered, offering further per-subscriber fee reduction.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeDiscountTier3Rate rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 3 Rate' ;
    rdfs:comment 'Discounted per-subscriber fee rate applicable when subscriber count exceeds the Tier 3 threshold.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountTier3Threshold rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 3 Threshold' ;
    rdfs:comment 'Subscriber count threshold at which the third volume discount tier is triggered, offering the deepest per-subscriber fee reduction.' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumGuaranteeId rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Id' ;
    rdfs:comment 'Unique identifier for the minimum guarantee commitment within a content acquisition deal.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoupmentInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Recoupment Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: MG recoupment tracking requires linking actual invoiced revenue (syndication fees, royalty statements) back to the guarantee for overage calculation, royalty true-ups, and partner financial reporting.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:accountingTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Accounting Treatment Code' ;
    rdfs:comment 'The financial accounting classification for the minimum guarantee: asset (capitalized content cost), expense (immediate P&L impact), deferred expense (amortized over time), prepaid (advance payment), or liability (obligation to provider).' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amortizationMethod rdf:type rdf:Property ;
    rdfs:label 'Amortization Method' ;
    rdfs:comment 'The method used to amortize the minimum guarantee cost over its useful life: straight-line (equal periods), usage-based (viewership-driven), revenue-based (proportional to earnings), accelerated (front-loaded), or none (expensed immediately).' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'The master contract or agreement number that governs this minimum guarantee commitment. Links to the legal contract document for audit and compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Final Payment Date' ;
    rdfs:comment 'The date when the last scheduled minimum guarantee payment was made or is due. Relevant for installment or milestone-based payment structures.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstPaymentDate rdf:type rdf:Property ;
    rdfs:label 'First Payment Date' ;
    rdfs:comment 'The date when the initial minimum guarantee payment was made or is scheduled to be made to the content provider.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fullyRecoupedDate rdf:type rdf:Property ;
    rdfs:label 'Fully Recouped Date' ;
    rdfs:comment 'The date when the minimum guarantee was fully recouped and the outstanding balance reached zero. After this date, overage royalty terms apply to additional revenue.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCrossCollateralized rdf:type rdf:Property ;
    rdfs:label 'Is Cross Collateralized' ;
    rdfs:comment 'Indicates whether this minimum guarantee can be recouped from revenue generated by other content titles or deals with the same provider (true) or is isolated to this specific deal (false).' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecoupable rdf:type rdf:Property ;
    rdfs:label 'Is Recoupable' ;
    rdfs:comment 'Indicates whether the minimum guarantee can be recouped from revenue (true) or is a non-recoupable floor payment (false). Non-recoupable MGs are paid regardless of performance with no offset.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRecoupmentCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Last Recoupment Calculation Date' ;
    rdfs:comment 'The date when the most recent recoupment calculation was performed, updating the recouped to date and outstanding balance amounts.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mgAmount rdf:type rdf:Property ;
    rdfs:label 'Mg Amount' ;
    rdfs:comment 'The floor payment amount owed to the content provider regardless of actual viewership or revenue performance. This is the baseline financial commitment.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mgNumber rdf:type rdf:Property ;
    rdfs:label 'Mg Number' ;
    rdfs:comment 'Business identifier for the minimum guarantee commitment, used in contracts and financial reconciliation.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mgStatus rdf:type rdf:Property ;
    rdfs:label 'Mg Status' ;
    rdfs:comment 'Current lifecycle state of the minimum guarantee: draft (under negotiation), active (in effect), partially recouped (some revenue applied), fully recouped (MG threshold met), overage (revenue exceeds MG), expired (term ended), or terminated (contract cancelled). [ENUM-REF-CANDIDATE: draft|active|partially_recouped|fully_recouped|overage|expired|terminated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mgType rdf:type rdf:Property ;
    rdfs:label 'Mg Type' ;
    rdfs:comment 'Classification of the minimum guarantee structure: flat (single fixed payment), tiered (stepped payments based on milestones), performance-based (adjusted by viewership), hybrid (combination), recoupable (can be offset by revenue share), or non-recoupable (floor payment regardless of performance).' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRecoupmentCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Next Recoupment Calculation Date' ;
    rdfs:comment 'The scheduled date for the next recoupment calculation cycle. Typically aligned with monthly, quarterly, or annual reporting periods.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outstandingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance Amount' ;
    rdfs:comment 'Remaining minimum guarantee amount not yet recouped. Calculated as MG amount minus recouped to date amount. When zero, the MG is fully recouped.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageAmount rdf:type rdf:Property ;
    rdfs:label 'Overage Amount' ;
    rdfs:comment 'Revenue earned beyond the minimum guarantee threshold. Once the MG is fully recouped, additional revenue share payments are calculated on this overage amount per the contract terms.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageRoyaltyRate rdf:type rdf:Property ;
    rdfs:label 'Overage Royalty Rate' ;
    rdfs:comment 'The percentage rate applied to overage revenue to calculate additional royalty payments owed to the content provider after the minimum guarantee is fully recouped. Typically ranges from 0.00 to 100.00 percent.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentScheduleType rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule Type' ;
    rdfs:comment 'The timing structure for minimum guarantee payments: upfront (single payment at signing), milestone (tied to delivery/broadcast events), installment (fixed periodic payments), quarterly, annual, upon delivery (when content is delivered), or upon broadcast (when content airs). [ENUM-REF-CANDIDATE: upfront|milestone|installment|quarterly|annual|upon_delivery|upon_broadcast — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Description' ;
    rdfs:comment 'Detailed narrative of the payment schedule, milestones, and conditions governing the minimum guarantee disbursement. Includes specific dates, amounts, and triggering events.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoupedToDateAmount rdf:type rdf:Property ;
    rdfs:label 'Recouped To Date Amount' ;
    rdfs:comment 'Cumulative revenue amount that has been applied against the minimum guarantee as of the current reporting period. Tracks progress toward full recoupment.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoupmentBasis rdf:type rdf:Property ;
    rdfs:label 'Recoupment Basis' ;
    rdfs:comment 'The revenue or performance metric against which the minimum guarantee is recouped: gross revenue (total), net revenue (after costs), advertising revenue (CPM/GRP-based), subscription revenue (SVOD/ARPU), combined revenue (multi-stream), or viewership metric (Nielsen ratings, reach).' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoupmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Recoupment Percentage' ;
    rdfs:comment 'The percentage of revenue (based on recoupment basis) that is applied toward recouping the minimum guarantee. Typically ranges from 0.00 to 100.00 percent.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoupmentPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Recoupment Period Months' ;
    rdfs:comment 'The duration in months over which the minimum guarantee can be recouped from revenue. Common periods are 12, 24, 36, or 60 months depending on content type and windowing strategy.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoupmentWaterfallDescription rdf:type rdf:Property ;
    rdfs:label 'Recoupment Waterfall Description' ;
    rdfs:comment 'Detailed explanation of the revenue allocation sequence and priority order for recouping the minimum guarantee. Defines which revenue streams are applied first and how costs are deducted before recoupment.' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermId rdf:type rdf:Property ;
    rdfs:label 'Payment Term Id' ;
    rdfs:comment 'Unique identifier for the partner payment term record. Primary key.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Invoice Required Flag' ;
    rdfs:comment 'Indicates whether the partner must submit an invoice before payment can be processed. True if invoice is required, False if payment is automatic or self-billed.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latePaymentGracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Late Payment Grace Period Days' ;
    rdfs:comment 'Number of days after the payment due date during which no late payment penalty is assessed, allowing the payer time to remit without financial consequence.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The gross monetary value of the payment obligation before any adjustments, taxes, or withholdings. Expressed in the currency specified in the currency_code field.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Approval Required Flag' ;
    rdfs:comment 'Indicates whether internal approval is required before payment can be released. True if approval workflow must be completed, False if payment is automatic upon due date.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentBankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Bank Account Number' ;
    rdfs:comment 'Reference to the partner\'s bank account record where payment should be remitted. Used for wire transfer and ACH payments.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which the payment must be made to the partner to avoid late payment penalties or interest charges.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMilestone rdf:type rdf:Property ;
    rdfs:label 'Payment Milestone' ;
    rdfs:comment 'Business event or condition that triggers this payment obligation (e.g., \'Upon Delivery\', \'First Broadcast\', \'Quarterly Arrears\', \'Upon Execution\', \'Net 30 Days from Invoice\').' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRemittanceEmail rdf:type rdf:Property ;
    rdfs:label 'Payment Remittance Email' ;
    rdfs:comment 'Email address to which payment remittance advice and confirmation should be sent. May differ from the partner\'s primary contact email.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termNumber rdf:type rdf:Property ;
    rdfs:label 'Term Number' ;
    rdfs:comment 'Business identifier for this payment term, often used in invoicing and reconciliation. May follow partner-specific or internal numbering conventions.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termType rdf:type rdf:Property ;
    rdfs:label 'Term Type' ;
    rdfs:comment 'Classification of the payment term based on the nature of the financial obligation: acquisition fee (content licensing), carriage fee (distribution payment), syndication fee (content resale), co-production contribution (shared production cost), royalty (usage-based payment), or residual (talent reuse payment).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Jurisdiction' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the jurisdiction whose tax laws govern the withholding obligation (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'Percentage of the payment amount that must be withheld for tax purposes based on the partner\'s jurisdiction and applicable tax treaties. Expressed as a percentage (e.g., 15.00 for 15%).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avodRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Avod Rights Flag' ;
    rdfs:comment 'Indicates whether Advertising-Supported Video On Demand distribution rights are included in this grant.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutZoneIndicator rdf:type rdf:Property ;
    rdfs:label 'Blackout Zone Indicator' ;
    rdfs:comment 'Flag indicating whether this grant defines a blackout zone where distribution is explicitly prohibited rather than authorized.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageFeeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Applicable Flag' ;
    rdfs:comment 'Indicates whether a carriage fee (distribution payment) is required for this territorial grant.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Verification Date' ;
    rdfs:comment 'Date when rights clearance was last verified for this territorial grant.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Grant Reference Code' ;
    rdfs:comment 'Business identifier for the territory grant, used in contracts and rights clearance documentation.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantType rdf:type rdf:Property ;
    rdfs:label 'Grant Type' ;
    rdfs:comment 'Type of territorial grant indicating exclusivity level. Exclusive grants prohibit other licensees in the territory; non-exclusive allows multiple licensees; co-exclusive allows a limited number of licensees; holdback restricts distribution during a specific window; reserved indicates rights retained by licensor.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackRestriction rdf:type rdf:Property ;
    rdfs:label 'Holdback Restriction' ;
    rdfs:comment 'Description of any holdback period or exclusivity restrictions that limit distribution during specific windows or in relation to other platforms. For example, a 90-day theatrical holdback before SVOD release.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageRestriction rdf:type rdf:Property ;
    rdfs:label 'Language Restriction' ;
    rdfs:comment 'Comma-separated list of ISO 639-2 language codes specifying which language versions are covered by this grant. Null if all language versions are included.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linearRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Linear Rights Flag' ;
    rdfs:comment 'Indicates whether traditional scheduled broadcast (linear) distribution rights are included in this grant.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaFormatRestriction rdf:type rdf:Property ;
    rdfs:label 'Media Format Restriction' ;
    rdfs:comment 'Restrictions on media formats or technical specifications (e.g., HD only, 4K excluded, standard definition only). Null if no format restrictions apply.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformScope rdf:type rdf:Property ;
    rdfs:label 'Platform Scope' ;
    rdfs:comment 'Comma-separated list of distribution platforms covered by this grant. May include: linear (traditional broadcast), SVOD (Subscription Video On Demand), AVOD (Advertising-Supported Video On Demand), TVOD (Transactional Video On Demand), OTT (Over-The-Top), theatrical, home video, FAST (Free Ad-Supported Streaming Television), MVPD (Multichannel Video Programming Distributor), vMVPD (Virtual Multichannel Video Programming Distributor).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Named region for multi-country grants (e.g., North America, European Union, Asia-Pacific, Latin America). Used when grant covers multiple countries as a group.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Required Flag' ;
    rdfs:comment 'Indicates whether retransmission consent (rebroadcast authorization) is required for this territorial grant under FCC regulations.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sublicensePermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Sublicense Permitted Flag' ;
    rdfs:comment 'Indicates whether the licensee is authorized to sublicense the territorial rights to third parties.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:svodRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Svod Rights Flag' ;
    rdfs:comment 'Indicates whether Subscription Video On Demand distribution rights are included in this grant.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tvodRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Tvod Rights Flag' ;
    rdfs:comment 'Indicates whether Transactional Video On Demand (pay-per-view, rental, electronic sell-through) distribution rights are included in this grant.' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'The actual date on which the content was made available on the platform, which may differ from the planned window_start_date due to operational delays or early releases.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'The actual date on which the content was removed from the platform, which may differ from the planned window_end_date due to early termination or extensions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:languageAvailability rdf:type rdf:Property ;
    rdfs:label 'Language Availability' ;
    rdfs:comment 'Languages in which the content must be made available during this window (e.g., English, Spanish, French). Comma-separated list of ISO 639-1 language codes.' ;
    rdfs:domain ind:PartnerContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingRightsIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Rights Included Flag' ;
    rdfs:comment 'Indicates whether the platform has rights to use promotional materials, trailers, and marketing assets for this window (True) or must obtain separate clearance (False).' ;
    rdfs:domain ind:PartnerContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceGuaranteeDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Description' ;
    rdfs:comment 'Free-text description of any performance commitments tied to this window (e.g., minimum viewership targets, promotional spend requirements, platform placement guarantees).' ;
    rdfs:domain ind:PartnerContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleRequirement rdf:type rdf:Property ;
    rdfs:label 'Subtitle Requirement' ;
    rdfs:comment 'Specifies subtitle languages required for this window to meet accessibility and localization obligations. Comma-separated list of ISO 639-1 language codes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowEndDate rdf:type rdf:Property ;
    rdfs:label 'Window End Date' ;
    rdfs:comment 'The date on which this distribution window expires and the content must be removed from the platform or the rights revert. Nullable for perpetual windows.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windowStartDate rdf:type rdf:Property ;
    rdfs:label 'Window Start Date' ;
    rdfs:comment 'The date on which this distribution window becomes active and the content may be released on the specified platform.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:companyLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Company Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: GL accounts are defined per legal entity in SAP S/4HANA. The company_code is a business key reference to legal_entity. FK enables proper chart of accounts management per legal entity.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:accountCurrency rdf:type rdf:Property ;
    rdfs:label 'Account Currency' ;
    rdfs:comment 'The primary currency in which this account is maintained, using ISO 4217 three-letter currency codes (e.g., \'USD\', \'EUR\', \'GBP\'). Determines the currency for postings and balance reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'SAP account group classification that controls field status, number range assignment, and screen layout for the account. Groups accounts with similar characteristics and processing rules (e.g., \'REVENUE\', \'COGS\', \'OPEX\', \'CAPEX\').' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The full descriptive name of the general ledger account, providing clear business context for the account\'s purpose (e.g., \'Advertising Revenue - Linear TV\', \'Content Production Costs\', \'Subscription Revenue - SVOD\').' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNotes rdf:type rdf:Property ;
    rdfs:label 'Account Notes' ;
    rdfs:comment 'Free-text field for additional notes, usage guidelines, or special instructions related to this account. Used to document account-specific policies, restrictions, or business context.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountShortText rdf:type rdf:Property ;
    rdfs:label 'Account Short Text' ;
    rdfs:comment 'Abbreviated name or short description of the account used in reports and transaction displays where space is limited.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the account: active (available for posting), inactive (not available for new postings but retains history), blocked (temporarily suspended), or pending_approval (awaiting activation approval).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'High-level classification of the account into fundamental accounting categories: asset (balance sheet), liability (balance sheet), equity (balance sheet), revenue (P&L), or expense (P&L). Determines which financial statement the account appears on.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'An alternative or legacy account number used for mapping to previous chart of accounts structures, external reporting systems, or consolidation systems. Supports migration and integration scenarios.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'For balance sheet accounts, specifies whether the account is classified as current asset, non-current asset, current liability, non-current liability, or equity. Not applicable for P&L accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'The chart of accounts identifier to which this account belongs. Media Broadcasting may maintain multiple charts of accounts for different regions or business units (e.g., \'USGA\' for US GAAP, \'IFRS\' for international operations).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'The SAP company code (legal entity) to which this chart of accounts entry applies. Supports multi-entity environments where different legal entities may have entity-specific account configurations.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccount rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account' ;
    rdfs:comment 'The consolidation account code used for corporate consolidation and intercompany eliminations. Maps local entity accounts to group-level chart of accounts for consolidated financial reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterRequired rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required' ;
    rdfs:comment 'Indicates whether a cost center must be specified when posting to this account. True for expense accounts requiring cost center assignment; false for balance sheet and revenue accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Classification of the account as a cost element for controlling purposes: primary (direct posting from FI), secondary (internal allocations/assessments), revenue (revenue postings), or none (not a cost element). Links financial accounting to management accounting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Item' ;
    rdfs:comment 'The line item code on the financial statement (balance sheet or income statement) where this account\'s balance is reported. Used for financial statement generation and external reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'SAP functional area classification used for segment reporting and cost-of-sales accounting. Represents business functions such as \'Content Production\', \'Distribution\', \'Sales & Marketing\', \'Technology\', \'Corporate\'. Enables P&L reporting by business function per IFRS requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Account Number' ;
    rdfs:comment 'The unique account code used to identify this general ledger account across all financial postings. This is the authoritative account identifier used in SAP S/4HANA FI module for all financial transactions.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplayAllowed rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Allowed' ;
    rdfs:comment 'Indicates whether individual line items (transaction details) can be displayed for this account. True enables drill-down to transaction level; false shows only account balance. Typically true for balance sheet accounts, false for P&L accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialityThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Materiality Threshold Amount' ;
    rdfs:comment 'The monetary threshold above which transactions or balances in this account are considered material for audit and control purposes. Used to determine testing scope and control frequency for SOX compliance.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Indicates whether this account uses open item management, tracking individual postings until they are cleared (e.g., for receivables, payables, clearing accounts). True enables clearing transactions; false for standard balance accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plStatementClassification rdf:type rdf:Property ;
    rdfs:label 'Pl Statement Classification' ;
    rdfs:comment 'For P&L accounts, specifies the detailed classification within the income statement (e.g., \'Operating Revenue\', \'Cost of Sales\', \'Operating Expenses\', \'Depreciation\', \'Interest Expense\', \'Tax Expense\'). Not applicable for balance sheet accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'The planning level or budget category assigned to this account for financial planning and budgeting purposes. Links the account to budget planning hierarchies and enables budget vs. actual reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingBlocked rdf:type rdf:Property ;
    rdfs:label 'Posting Blocked' ;
    rdfs:comment 'Indicates whether direct postings to this account are currently blocked. True prevents new transactions; false allows normal posting. Used to freeze accounts during period-end close or for inactive accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterRequired rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required' ;
    rdfs:comment 'Indicates whether a profit center must be specified when posting to this account. True for accounts requiring segment profitability tracking; false otherwise.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Type' ;
    rdfs:comment 'Identifies if this is a reconciliation account (subledger control account) and its type: customer (accounts receivable), vendor (accounts payable), asset (fixed assets), or none (standard GL account). Reconciliation accounts are automatically posted from subledgers.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlClassification rdf:type rdf:Property ;
    rdfs:label 'Sox Control Classification' ;
    rdfs:comment 'Classification of the account for SOX compliance purposes: key_control (critical accounts requiring enhanced controls and testing), supporting_control (accounts with standard controls), or not_in_scope (accounts outside SOX scope). Drives audit testing requirements.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'The tax category classification for this account, determining how tax is calculated and posted (e.g., \'Input Tax\', \'Output Tax\', \'Non-Taxable\', \'Tax Exempt\'). Used for VAT/GST/sales tax processing.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerRequired rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Required' ;
    rdfs:comment 'Indicates whether a trading partner (intercompany entity) must be specified when posting to this account. True for intercompany accounts requiring elimination tracking; false for standard accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this account becomes active and available for posting. Supports time-dependent chart of accounts changes and new account activation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date until which this account remains active. After this date, the account is no longer available for posting. Null indicates the account is currently active with no planned end date.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Reference to the parent cost center in the organizational hierarchy, enabling hierarchical cost roll-ups and departmental P&L aggregation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'The primary activity type or service provided by this cost center for internal cost allocation purposes (e.g., Studio Hours, Editing Hours, Transmission Hours).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'The total annual budget allocated to this cost center for the current fiscal year, in the cost center\'s currency.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAllocationReference rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Reference' ;
    rdfs:comment 'Reference identifier to the annual or periodic budget allocation document for this cost center, used for budget vs. actual variance analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'The business area or division within Media Broadcasting to which this cost center belongs (e.g., Linear Broadcasting, Streaming Platforms, News Division, Sports Division).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'The SAP Controlling Area code to which this cost center belongs. Controlling area represents the organizational unit for cost accounting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'The method used to allocate costs from this cost center to other cost objects (e.g., direct assignment, activity-based costing, percentage allocation, driver-based).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Classification of the cost center by cost behavior: direct costs attributable to specific content/programs, indirect costs supporting operations, overhead, or capital expenditure.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The business identifier code for the cost center as defined in SAP Controlling (CO) module. Used for financial reporting and budget tracking.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Detailed description of the cost center\'s purpose, scope, and responsibilities within the organization.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The full descriptive name of the cost center (e.g., \'Digital Platform Operations\', \'News Production Studio A\', \'Ad Sales Northeast Region\').' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center indicating whether it is operational and available for cost posting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by functional area within the media broadcasting business. [ENUM-REF-CANDIDATE: production|operations|sales|distribution|corporate|technology|content_acquisition — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group' ;
    rdfs:comment 'The primary cost element group or category that this cost center typically incurs (e.g., Personnel Costs, Production Costs, Technology Costs, Rights & Licensing).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'The department code within the organizational structure to which this cost center is assigned.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaReportingSegment rdf:type rdf:Property ;
    rdfs:label 'Ebitda Reporting Segment' ;
    rdfs:comment 'The EBITDA reporting segment to which this cost center\'s costs are allocated for executive and investor reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyNode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node' ;
    rdfs:comment 'The position of this cost center within the organizational cost center hierarchy, used for roll-up reporting and consolidation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Indicates whether this cost center participates in intercompany transactions requiring elimination entries during consolidation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRevenueGenerating rdf:type rdf:Property ;
    rdfs:label 'Is Revenue Generating' ;
    rdfs:comment 'Flag indicating whether this cost center directly generates revenue (e.g., Ad Sales regions) or is purely a cost-incurring unit.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Indicates whether this cost center is subject to SOX financial controls and requires enhanced audit trail and approval workflows.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Method' ;
    rdfs:comment 'The methodology used for allocating budgets to this profit center. Top-down allocates from corporate targets; bottom-up aggregates from operational plans; zero-based requires justification of all expenses; incremental adjusts prior year budgets.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'The higher-level business unit or division to which this profit center belongs. Used for hierarchical rollup in management reporting. Examples: Digital Media, Broadcast Networks, Content Production.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'The date on which this profit center was closed and ceased operations. Null for active profit centers. Used for historical reporting and archival.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'The controlling area to which this profit center is assigned. Controlling area is the organizational unit in SAP CO that represents a closed system for cost accounting purposes.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterAssignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Center Assignment Flag' ;
    rdfs:comment 'Indicates whether cost centers can be directly assigned to this profit center for cost allocation and internal charging purposes.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ebitdaReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Ebitda Reporting Flag' ;
    rdfs:comment 'Indicates whether this profit center is included in EBITDA segment reporting for management and investor communications. EBITDA is a key profitability metric in media broadcasting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyEliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Flag' ;
    rdfs:comment 'Indicates whether transactions involving this profit center require intercompany elimination adjustments during financial consolidation. Used in multi-entity corporate structures.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Code' ;
    rdfs:comment 'The code of the parent profit center in the organizational hierarchy, if this profit center rolls up to another. Enables hierarchical consolidation for segment EBITDA and management reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'The externally-known unique alphanumeric code identifying the profit center within the controlling area. Used in SAP CO for segment reporting and management accounting. Examples: SVOD-US, LINEAR-UK, ADSALES-NA.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Detailed textual description of the profit centers business purpose, scope of operations, and strategic role within the enterprise. Used for documentation and onboarding.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'The full business name of the profit center. Human-readable label used in financial reports and management dashboards.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center. Active profit centers are operational and accept postings; inactive are temporarily suspended; planned are future entities; closed are historical and no longer accept transactions.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center based on its accountability model. Revenue centers are responsible for revenue generation; cost centers for cost control; investment centers for return on invested capital; service centers provide internal services.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenuePostingFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Posting Flag' ;
    rdfs:comment 'Indicates whether revenue transactions can be posted directly to this profit center. Used to control which profit centers participate in revenue recognition workflows.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name or acronym for the profit center, used in condensed reports and system displays where space is limited.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Scope Flag' ;
    rdfs:comment 'Indicates whether this profit center is within the scope of SOX financial controls and requires enhanced audit trails and segregation of duties for financial postings.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'The method used for pricing internal transactions between this profit center and other organizational units. Examples: cost-plus, market-based, negotiated. Critical for accurate profit center performance measurement.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmountFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Amount Functional Currency' ;
    rdfs:comment 'Budgeted amount allocated to the general ledger account for the fiscal period, expressed in functional currency. Used for budget vs. actual variance analysis and financial planning. Particularly relevant for production budgets, content acquisition costs, and operational expense management.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingBalanceFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Closing Balance Functional Currency' ;
    rdfs:comment 'Closing balance of the general ledger account at the end of the fiscal period, expressed in functional currency. Calculated as opening balance plus net period activity. Represents the ending position for trial balance and financial statement generation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consolidationUnit rdf:type rdf:Property ;
    rdfs:label 'Consolidation Unit' ;
    rdfs:comment 'Consolidation unit code representing the entity for group consolidation and statutory reporting. Used for multi-entity financial consolidation, intercompany eliminations, and corporate-level financial statement preparation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmountFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Amount Functional Currency' ;
    rdfs:comment 'Total credit amount posted to the general ledger account for the period, expressed in the functional currency of the company code. Represents increases to liability, equity, and revenue accounts or decreases to asset and expense accounts.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditAmountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Amount Transaction Currency' ;
    rdfs:comment 'Total credit amount posted to the general ledger account for the period, expressed in the original transaction currency. Maintained for audit trail and foreign exchange reconciliation purposes.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmountFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Debit Amount Functional Currency' ;
    rdfs:comment 'Total debit amount posted to the general ledger account for the period, expressed in the functional currency of the company code. Represents increases to asset and expense accounts or decreases to liability, equity, and revenue accounts.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Debit Amount Transaction Currency' ;
    rdfs:comment 'Total debit amount posted to the general ledger account for the period, expressed in the original transaction currency. Maintained for audit trail and foreign exchange reconciliation purposes.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Two-character code representing the type of accounting document that generated the general ledger entry (e.g., SA for G/L account document, DR for customer invoice, KR for vendor invoice, DZ for payment). Used for document classification and posting control.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaIndicator rdf:type rdf:Property ;
    rdfs:label 'Ebitda Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the general ledger account is included in EBITDA calculation for management reporting and investor disclosures. True if the account contributes to EBITDA (operating revenues and expenses), false if excluded (interest, taxes, depreciation, amortization).' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the functional currency of the company code (e.g., USD, GBP, EUR). The functional currency is the primary currency in which the legal entity conducts business and prepares financial statements.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger account number from the chart of accounts. Represents the specific account classification (asset, liability, equity, revenue, expense) for financial transactions. Structured according to the enterprise chart of accounts hierarchy.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPostingDate rdf:type rdf:Property ;
    rdfs:label 'Last Posting Date' ;
    rdfs:comment 'Date of the most recent transaction posted to this general ledger account within the fiscal period. Used for audit trail and period-end reconciliation validation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'Ledger group code representing the accounting principle or reporting standard (e.g., 0L for leading ledger, 2L for IFRS, 3L for US GAAP). Enables parallel accounting for multiple reporting frameworks within a single system.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBalanceFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Net Balance Functional Currency' ;
    rdfs:comment 'Net balance of the general ledger account for the period, calculated as debit amount minus credit amount (or vice versa depending on account type), expressed in the functional currency. Represents the aggregated account state for trial balance and financial statement generation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingBalanceFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Opening Balance Functional Currency' ;
    rdfs:comment 'Opening balance of the general ledger account at the beginning of the fiscal period, expressed in functional currency. Represents the carried-forward balance from the previous period for balance sheet accounts.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodLockStatus rdf:type rdf:Property ;
    rdfs:label 'Period Lock Status' ;
    rdfs:comment 'Status of the posting period indicating whether the period is open for new postings, closed for regular postings but open for adjustments, or locked for all postings. Used for period-end close control and financial statement finalization.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit numeric code that controls the posting behavior and determines whether the entry is a debit or credit (e.g., 40 for debit, 50 for credit). Used for transaction validation and account determination logic.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriod rdf:type rdf:Property ;
    rdfs:label 'Posting Period' ;
    rdfs:comment 'Numeric posting period within the fiscal year (typically 1-12 for monthly periods, with additional special periods 13-16 for year-end adjustments). Represents the accounting period for transaction posting and period-end close.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconciliationAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the general ledger account is a reconciliation account (subledger control account) that must reconcile with subsidiary ledgers such as accounts receivable, accounts payable, or fixed assets. True if reconciliation account, false otherwise.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueStreamCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Stream Category' ;
    rdfs:comment 'Classification of revenue accounts by primary revenue stream type for Media Broadcasting business. Categories include advertising (linear and digital ad sales), subscription (SVOD/AVOD), carriage fees (MVPD/vMVPD distribution), syndication (content resale), licensing (rights monetization), transactional (TVOD), and other. Used for revenue assurance and segment reporting. [ENUM-REF-CANDIDATE: advertising|subscription|carriage_fees|syndication|licensing|transactional|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Segment code for external segment reporting as required by IFRS 8 and US GAAP. Represents reportable business segments for statutory financial reporting and investor disclosures (e.g., content production, advertising, subscription services).' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Sox Control Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the general ledger account is subject to Sarbanes-Oxley Act internal control requirements and audit procedures. True if SOX-controlled account requiring enhanced documentation and approval workflows, false otherwise.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradingPartner rdf:type rdf:Property ;
    rdfs:label 'Trading Partner' ;
    rdfs:comment 'Trading partner code identifying the intercompany counterparty for intercompany transactions. Used for intercompany eliminations and consolidated financial statement preparation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the original transaction currency if different from functional currency. Used for multi-currency transactions requiring foreign exchange conversion and revaluation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmountFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Variance Amount Functional Currency' ;
    rdfs:comment 'Variance between actual net balance and budgeted amount for the fiscal period, expressed in functional currency. Calculated as actual minus budget. Positive variance indicates over-budget for expense accounts or under-budget for revenue accounts.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accrualReversalDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Reversal Date' ;
    rdfs:comment 'The future posting date on which this accrual entry will automatically reverse. Populated only when accrual_reversal_indicator is True.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualReversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Accrual Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is an automatic accrual reversal. True if this entry will automatically reverse in the subsequent period.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the journal entry by its accounting purpose: standard operational posting, period-end accrual, prepayment amortization, account reclassification, intercompany elimination, or error correction.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchInputSession rdf:type rdf:Property ;
    rdfs:label 'Batch Input Session' ;
    rdfs:comment 'The name of the batch input session if this journal entry was posted via batch processing rather than manual entry. Empty for manually posted entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date of the original source document (invoice, receipt, contract) that gave rise to this journal entry. May differ from posting date when entries are posted retrospectively.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentHeaderText rdf:type rdf:Property ;
    rdfs:label 'Document Header Text' ;
    rdfs:comment 'Descriptive text at the document header level providing context or explanation for the journal entry, such as the business purpose, transaction description, or special instructions.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The externally-known SAP document number assigned to this journal entry at posting time. This is the business identifier used across financial reporting and audit trails.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The calendar date when the journal entry was physically entered into the SAP system by the user, which may differ from both document date and posting date.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryTime rdf:type rdf:Property ;
    rdfs:label 'Entry Time' ;
    rdfs:comment 'The precise date and time when the journal entry was created in the SAP system. Provides audit trail for record creation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Single-character code indicating the type of exchange rate used (e.g., M=Average Rate, B=Bank Buying Rate, G=Bank Selling Rate). Determines which rate table is consulted for currency conversion.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry represents an intercompany transaction between different legal entities within Media Broadcasting. True for intercompany entries requiring elimination in consolidated reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the local currency of the company code. Used for parallel accounting and statutory reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkedIndicator rdf:type rdf:Property ;
    rdfs:label 'Parked Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is in parked status (saved but not yet posted). True if parked, False if fully posted.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the journal entry was posted to the general ledger. This is the accounting date that determines the fiscal period and is used for financial statement reporting. Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recurringEntryIndicator rdf:type rdf:Property ;
    rdfs:label 'Recurring Entry Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is part of a recurring entry template (e.g., monthly depreciation, rent accruals). True if generated from a recurring template.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is a reversal of a previously posted document. True if this entry reverses another entry, False otherwise.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Two-digit code indicating the business reason for reversing the original document (e.g., 01=Error Correction, 02=Accrual Reversal, 03=Period-End Adjustment). Populated only when reversal_indicator is True.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the original journal entry that this entry reverses. Populated only when reversal_indicator is True.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'The company code of the intercompany trading partner for intercompany transactions. Populated only when intercompany_indicator is True. Used for intercompany reconciliation and consolidation eliminations.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Code' ;
    rdfs:comment 'The SAP transaction code (T-Code) used to post this journal entry (e.g., FB01, FB50, F-02). Indicates the posting interface and provides context for the entry method.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Status' ;
    rdfs:comment 'Current status of the journal entry within the SOX-compliant approval workflow. Tracks the document through draft, approval, posting, and potential reversal stages.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aboveTheLineAmount rdf:type rdf:Property ;
    rdfs:label 'Above The Line Amount' ;
    rdfs:comment 'Budget allocated to above-the-line costs including key creative talent (writers, directors, producers, lead actors). These are typically negotiated individually and represent significant budget items.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSpendToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Spend To Date' ;
    rdfs:comment 'Cumulative actual expenditure against this budget as of the last financial update. Used for variance tracking and budget performance monitoring.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:belowTheLineAmount rdf:type rdf:Property ;
    rdfs:label 'Below The Line Amount' ;
    rdfs:comment 'Budget allocated to below-the-line costs including crew, equipment, facilities, and production support. These are standard production costs not tied to key creative talent.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Budget Effective Date' ;
    rdfs:comment 'The date from which this budget version becomes effective and spending authorization begins.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Budget Expiry Date' ;
    rdfs:comment 'The date on which this budget version expires or is superseded by a new version. Null for open-ended budgets.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetNotes rdf:type rdf:Property ;
    rdfs:label 'Budget Notes' ;
    rdfs:comment 'Free-text notes and comments regarding this budget version, including justification for revisions, special conditions, or approval stipulations.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Externally-known unique identifier for the production budget, used for tracking and reference in financial systems and production workflows.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the production budget. Tracks progression from draft through approval to active spending and final closure. [ENUM-REF-CANDIDATE: draft|submitted|approved|active|revised|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the production budget by content type. Different content types have different cost structures and budget approval workflows. [ENUM-REF-CANDIDATE: scripted_series|film|live_event|news_programming|digital_original|documentary|sports|reality|animation — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Version number of the budget. Budgets are revised throughout the production lifecycle; this field tracks the iteration (e.g., 1 for initial, 2 for first revision).' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitiesAmount rdf:type rdf:Property ;
    rdfs:label 'Facilities Amount' ;
    rdfs:comment 'Budget allocated to production facilities including studio rental, location fees, set construction, and production office space.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'SAP CO internal order number used for production cost control and tracking actual expenditures against this budget.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicLicensingAmount rdf:type rdf:Property ;
    rdfs:label 'Music Licensing Amount' ;
    rdfs:comment 'Budget allocated to music licensing, original score composition, and music rights clearance for the production.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postProductionAmount rdf:type rdf:Property ;
    rdfs:label 'Post Production Amount' ;
    rdfs:comment 'Budget allocated to post-production activities including editing, color correction, sound design, mixing, and final mastering.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalApprovedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Approved Amount' ;
    rdfs:comment 'Total approved budget amount for the production project across all cost categories. This is the authorized spending limit.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Variance expressed as a percentage of the approved budget. Used for budget performance dashboards and exception reporting.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vfxAmount rdf:type rdf:Property ;
    rdfs:label 'Vfx Amount' ;
    rdfs:comment 'Budget allocated to visual effects production. VFX is often a significant cost category for scripted series, films, and high-production-value content.' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'The accounting standard governing revenue recognition for this stream (ASC 606 for US GAAP, IFRS 15 for international, or local GAAP variants).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceMeasurementSource rdf:type rdf:Property ;
    rdfs:label 'Audience Measurement Source' ;
    rdfs:comment 'Primary audience measurement provider used for revenue validation and guarantees (e.g., Nielsen, Comscore, Adobe Analytics). Critical for advertising revenue streams with audience guarantees.' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percent' ;
    rdfs:comment 'Standard commission rate percentage paid to sales representatives or agencies for revenue generated through this stream.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General ledger account code in the chart of accounts where revenue from this stream is posted.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeferred rdf:type rdf:Property ;
    rdfs:label 'Is Deferred' ;
    rdfs:comment 'Indicates whether revenue from this stream is initially recorded as deferred revenue and recognized over time (True for advance payments, subscriptions; False for immediate recognition).' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this revenue stream generates recurring revenue (True for subscriptions, carriage fees; False for one-time transactions, spot advertising).' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:makegoodsPolicy rdf:type rdf:Property ;
    rdfs:label 'Makegoods Policy' ;
    rdfs:comment 'Policy for providing makegoods (compensatory ad spots) when delivery guarantees are not met: automatic, negotiated, none, audience-based, or technical failure only.' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceObligation rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation' ;
    rdfs:comment 'Description of the performance obligation that must be satisfied for revenue recognition per ASC 606 / IFRS 15 (e.g., delivery of ad impressions, provision of streaming access, content licensing rights transfer).' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'Method by which revenue is recognized per accounting standards: point in time (transactional), over time (subscription), usage-based (consumption), or milestone-based (licensing).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSegment rdf:type rdf:Property ;
    rdfs:label 'Reporting Segment' ;
    rdfs:comment 'Corporate reporting segment for external financial reporting (e.g., Linear Broadcasting, Streaming Services, Content Licensing). Used for segment disclosure per ASC 280 / IFRS 8.' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'High-level classification of revenue type: advertising (upfront, scatter, DAI), subscription (SVOD, AVOD, TVOD), carriage fees, syndication, content licensing, ancillary, or transactional. [ENUM-REF-CANDIDATE: advertising|subscription|carriage|syndication|licensing|ancillary|transactional — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueStreamStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Stream Status' ;
    rdfs:comment 'Current lifecycle status of the revenue stream: active (currently generating revenue), inactive (not in use), suspended (temporarily halted), pending approval (awaiting finance approval), or deprecated (phased out).' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSubcategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Subcategory' ;
    rdfs:comment 'Detailed sub-classification within the revenue category (e.g., Upfront, Scatter, Programmatic for advertising; SVOD, AVOD, TVOD for subscription; Linear Carriage, OTT Carriage for carriage fees).' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamCode rdf:type rdf:Property ;
    rdfs:label 'Stream Code' ;
    rdfs:comment 'Business identifier code for the revenue stream (e.g., ADV-UPFRONT, SVOD-PREM, CARRIAGE-FEE). Used across financial systems and reporting.' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamName rdf:type rdf:Property ;
    rdfs:label 'Stream Name' ;
    rdfs:comment 'Full descriptive name of the revenue stream (e.g., Upfront Advertising Sales, Premium SVOD Subscription, Syndication License Fees).' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'Primary tax jurisdiction for this revenue stream using ISO 3166-1 alpha-2 or alpha-3 country codes (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatment rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment' ;
    rdfs:comment 'Tax treatment classification for this revenue stream: taxable (subject to VAT/GST/sales tax), exempt, zero-rated, or out of scope.' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalRecognitionEventRevenueRecognitionEventId rdf:type rdf:Property ;
    rdfs:label 'Original Recognition Event Revenue Recognition Event Id' ;
    rdfs:comment 'Reference to the original revenue recognition event ID if this record represents a reversal or adjustment. Enables full audit trail of revenue corrections.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognitionEvent .

ind:accountingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Accounting Document Number' ;
    rdfs:comment 'The SAP S/4HANA accounting document number (FI document) that records this revenue recognition event. Provides full audit trail and drill-back capability to source transactions.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asc606CompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Asc 606 Compliant Flag' ;
    rdfs:comment 'Boolean indicator (True/False) confirming that this revenue recognition event was processed in accordance with ASC 606 (US GAAP) revenue recognition standards.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractModificationFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Modification Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this revenue recognition event resulted from a contract modification. ASC 606 requires specific accounting treatment for modified contracts.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deferredAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Amount' ;
    rdfs:comment 'The monetary amount of revenue deferred (not yet recognized) as of this event. Represents unearned revenue that will be recognized in future periods as performance obligations are satisfied.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ifrs15CompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs 15 Compliant Flag' ;
    rdfs:comment 'Boolean indicator (True/False) confirming that this revenue recognition event was processed in accordance with IFRS 15 (International Financial Reporting Standards) revenue recognition standards.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The accounting date on which this revenue was recognized in the general ledger. This is the principal business event timestamp for financial reporting and period-end close.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current lifecycle status of this revenue recognition event: recognized (fully posted to GL), deferred (not yet earned), partially_recognized (over-time recognition in progress), reversed (corrected or cancelled), or adjusted (modified post-recognition).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Amount' ;
    rdfs:comment 'The monetary amount of revenue recognized in this event and posted to the general ledger. Represents the earned portion of the transaction price allocated to the performance obligation.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueAssuranceStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Assurance Status' ;
    rdfs:comment 'Status of revenue assurance validation for this recognition event: verified (passed all controls), pending_verification (awaiting reconciliation), discrepancy_identified (variance detected), or reconciled (discrepancy resolved).' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The original business transaction date (e.g., ad spot air date, subscription activation date, content delivery date) that triggered the revenue recognition event. May differ from recognition_date for deferred or over-time recognition scenarios.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoId rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Id' ;
    rdfs:comment 'Foreign key linking to billing.credit_memo. Business justification: AR records must link to credit memos that adjust them, required for dispute resolution tracking, bad debt analysis, and financial close. Advertising billing frequently involves makegoods and credits t' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditMemo .

ind:refundId rdf:type rdf:Property ;
    rdfs:label 'Refund Id' ;
    rdfs:comment 'Foreign key linking to billing.refund. Business justification: AR records must link to refunds that reverse them, required for churn analysis, revenue reversal tracking, and cash flow reporting. Subscription businesses need to track which AR line items were rever' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Refund .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'The aging category of the receivable based on days past due (current, 1-30 days, 31-60 days, 61-90 days, over 90 days).' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'Free-text assignment field used for additional sorting, grouping, or reconciliation purposes in SAP FI-AR.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date when the receivable was fully cleared through payment or other settlement mechanism. Null if still open.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Current clearing status of the receivable indicating whether it is open, partially cleared, fully cleared, disputed, or written off.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysPastDue rdf:type rdf:Property ;
    rdfs:label 'Days Past Due' ;
    rdfs:comment 'The number of days the receivable is overdue, calculated as the difference between current date and due date. Zero or negative if not yet due.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentCurrency rdf:type rdf:Property ;
    rdfs:label 'Document Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the receivable was originally denominated (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'The date when the most recent dunning notice was sent to the customer for this receivable.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'The current dunning level indicating the escalation stage of collection efforts (0 = no dunning, 1-9 = escalating levels).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localCurrency rdf:type rdf:Property ;
    rdfs:label 'Local Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code of the company\'s local reporting currency.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'The receivable amount converted to the company\'s local reporting currency for consolidation and financial reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openAmount rdf:type rdf:Property ;
    rdfs:label 'Open Amount' ;
    rdfs:comment 'The current outstanding amount still owed by the customer in document currency after partial payments or adjustments.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalAmount rdf:type rdf:Property ;
    rdfs:label 'Original Amount' ;
    rdfs:comment 'The original gross amount of the receivable in document currency when first posted.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDocument rdf:type rdf:Property ;
    rdfs:label 'Reference Document' ;
    rdfs:comment 'External reference document number such as customer purchase order number, contract number, or other business reference.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textDescription rdf:type rdf:Property ;
    rdfs:label 'Text Description' ;
    rdfs:comment 'Free-text description or memo field providing additional context about this receivable entry.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Identifier of the vendor to whom payment is owed. Links to talent agencies, production vendors, content licensors, technology providers, and distribution partners.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:assignmentReference rdf:type rdf:Property ;
    rdfs:label 'Assignment Reference' ;
    rdfs:comment 'Free-text reference field for additional assignment information (e.g., production code, content title, project ID). Used for detailed cost tracking.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'SAP FI document number of the payment document that cleared this payable. Null if not yet cleared.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Potential cash discount amount available if payment is made by the discount due date, in document currency.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'Date by which payment must be made to qualify for early payment discount. Null if no discount terms apply.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total invoice amount before any deductions, in document currency. Represents the full amount billed by the vendor.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReference rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference' ;
    rdfs:comment 'Vendor-provided invoice number or reference identifier. Used for vendor reconciliation and payment matching.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net amount payable to vendor after all deductions (discounts, withholding tax), in document currency. This is the amount that will be paid.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlock rdf:type rdf:Property ;
    rdfs:label 'Payment Block' ;
    rdfs:comment 'Single-character code indicating if payment is blocked (e.g., A=Blocked for Payment, R=Blocked for Review, blank=Not Blocked). Prevents automatic payment until resolved.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Free-text explanation for why payment is blocked (e.g., pending approval, invoice dispute, missing documentation). Null if not blocked.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxIndicator rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Indicator' ;
    rdfs:comment 'Boolean flag indicating whether withholding tax applies to this payable. True if withholding tax is calculated and deducted.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Legal Entity Id' ;
    rdfs:comment 'Reference to the parent legal entity in the corporate hierarchy. Used to establish organizational structure and consolidation relationships. Null for the ultimate parent entity.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:broadcastLicenseHolderFlag rdf:type rdf:Property ;
    rdfs:label 'Broadcast License Holder Flag' ;
    rdfs:comment 'Indicates whether this legal entity holds one or more broadcast licenses issued by the FCC or equivalent regulatory authority. True if the entity is a licensed broadcaster.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Four-character code identifying the chart of accounts assigned to this legal entity in SAP S/4HANA. Defines the structure of general ledger accounts used for financial postings.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'Identifier for the consolidation group or reporting unit to which this legal entity belongs. Used for corporate consolidation, intercompany eliminations, and segment reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Country Of Incorporation' ;
    rdfs:comment 'Three-letter ISO country code representing the country where the legal entity is incorporated and registered. Determines primary legal jurisdiction and regulatory framework.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'Four-character code identifying the credit control area assigned to this legal entity in SAP S/4HANA. Used for credit management and accounts receivable monitoring.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'Current operational status of the legal entity. Active indicates the entity is conducting business; inactive indicates temporary suspension; dormant indicates no current operations but entity remains registered; liquidation indicates entity is being wound down; dissolved indicates entity has been formally closed.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the legal entity based on its primary business function within the Media Broadcasting corporate structure. Determines the operational model and reporting requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Two-character code defining the fiscal year structure for this legal entity, including the number of periods, period start and end dates, and year-end closing rules. Used for period-based financial reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Functional Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the primary currency in which the entity conducts its business and maintains its books of account. Used for financial statement preparation and consolidation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the legal entity was officially incorporated or registered with the governing authority.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyEliminationGroup rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Group' ;
    rdfs:comment 'Code identifying the group of entities for which intercompany transactions must be eliminated during consolidation. Used to ensure accurate consolidated financial statements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Full legal name of the entity as registered with the governing authority. This is the official name used in all legal documents, contracts, regulatory filings, and financial statements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalForm rdf:type rdf:Property ;
    rdfs:label 'Legal Form' ;
    rdfs:comment 'The legal structure or incorporation type of the entity (e.g., Corporation, Limited Liability Company, Partnership, Public Limited Company). Determines liability, taxation, and regulatory obligations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of equity ownership held by the parent entity. Used for consolidation calculations and minority interest determination. Range: 0.00 to 100.00.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the official registered address of the legal entity as filed with the incorporation authority. Used for legal correspondence and regulatory filings.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Second line of the official registered address (suite, floor, building name). Optional field for additional address details.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'City or municipality of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountry rdf:type rdf:Property ;
    rdfs:label 'Registered Country' ;
    rdfs:comment 'Three-letter ISO country code for the registered address. Typically matches the country of incorporation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredStateProvince rdf:type rdf:Property ;
    rdfs:label 'Registered State Province' ;
    rdfs:comment 'State, province, or region of the registered address. Uses standard postal abbreviations where applicable.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official registration or incorporation number assigned by the government authority in the country of incorporation. Used for legal identification and regulatory compliance.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingObligations rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Obligations' ;
    rdfs:comment 'Comma-separated list of regulatory reporting frameworks and obligations applicable to this legal entity (e.g., SEC 10-K, FCC Form 323, Ofcom Annual Return). Determines mandatory filings and disclosure requirements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the currency used for external financial reporting and consolidation at the corporate level.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Scope Flag' ;
    rdfs:comment 'Indicates whether this legal entity is within the scope of SOX compliance and internal control testing. True if the entity is material to consolidated financial statements and subject to SOX Section 404 requirements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Primary tax identification number assigned by the tax authority in the country of incorporation. Used for all tax filings, withholding, and revenue reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'VAT or GST registration number for entities operating in jurisdictions requiring VAT registration. Used for VAT reporting and cross-border transactions.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyStatementId rdf:type rdf:Property ;
    rdfs:label 'Royalty Statement Id' ;
    rdfs:comment 'Foreign key linking to rights.royalty_statement. Business justification: Royalty statements are invoiced to licensees or paid to rights holders in media broadcasting. The accounts receivable/payable reconciliation process requires linking the invoice generated for a royalt' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyStatement .

ind:salesAgencyId rdf:type rdf:Property ;
    rdfs:label 'Sales Agency Id' ;
    rdfs:comment 'Foreign key linking to advertising.agency. Business justification: Agency-billed invoices require agency reference for consolidated billing, commission calculation, agency credit limit management, and agency-level AR reporting in advertising operations.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesAgency .

ind:subscriptionId rdf:type rdf:Property ;
    rdfs:label 'Subscription Id' ;
    rdfs:comment 'Foreign key linking to subscriber.subscription. Business justification: Invoice-to-subscription lifecycle management: invoices must reference the subscription they bill for dunning, renewal triggering, and subscription status updates on payment. invoice has subscriber_id ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscription .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'Total amount paid against this invoice to date. Used to calculate outstanding balance.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installmentNumber rdf:type rdf:Property ;
    rdfs:label 'Installment Number' ;
    rdfs:comment 'Installment sequence number for syndication license fees paid over multiple periods. Null for single-payment invoices.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isciCodes rdf:type rdf:Property ;
    rdfs:label 'Isci Codes' ;
    rdfs:comment 'Comma-separated list of ISCI codes for ad spots included in this advertising invoice. Used for affidavit matching and proof of broadcast.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvpdSubscriberCount rdf:type rdf:Property ;
    rdfs:label 'Mvpd Subscriber Count' ;
    rdfs:comment 'Number of subscribers reported by the MVPD partner as the basis for carriage fee calculation. Relevant for carriage fee invoices.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid balance on this invoice. Calculated as total_amount_due minus amount_paid.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidDate rdf:type rdf:Property ;
    rdfs:label 'Paid Date' ;
    rdfs:comment 'Date the invoice was fully paid. Null if not yet paid or only partially paid.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prorationFlag rdf:type rdf:Property ;
    rdfs:label 'Proration Flag' ;
    rdfs:comment 'Indicates whether this subscription invoice includes prorated charges due to mid-cycle changes. Relevant for SVOD billing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition End Date' ;
    rdfs:comment 'End date of the period over which revenue from this invoice should be recognized per ASC 606 guidelines.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Start Date' ;
    rdfs:comment 'Start date of the period over which revenue from this invoice should be recognized per ASC 606 guidelines.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemInvoiceReference rdf:type rdf:Property ;
    rdfs:label 'Source System Invoice Reference' ;
    rdfs:comment 'Original invoice identifier from the source billing system. Used for reconciliation and audit trail.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Total amount before taxes, fees, and adjustments. Sum of all line item amounts.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmountDue rdf:type rdf:Property ;
    rdfs:label 'Total Amount Due' ;
    rdfs:comment 'Final total amount due after all taxes, discounts, and adjustments. This is the amount the customer must pay.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'Reason this invoice was voided or cancelled. Populated when invoice_status is void or cancelled.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitOrderReference rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Order Reference' ;
    rdfs:comment 'Reference to the Wide Orbit sales order for advertising billing invoices. Null for non-advertising revenue categories.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Unique identifier for the invoice line item. Primary key for the invoice_line product.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:advertisingMakegoodId rdf:type rdf:Property ;
    rdfs:label 'Advertising Makegood Id' ;
    rdfs:comment 'Foreign key linking to advertising.makegood. Business justification: Makegood spot billing requires direct makegood reference for revenue recognition, fulfillment tracking, and advertiser reporting of makegood delivery in broadcast advertising operations.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Makegood .

ind:contentPackageId rdf:type rdf:Property ;
    rdfs:label 'Content Package Id' ;
    rdfs:comment 'Foreign key linking to content.package. Business justification: Content packages (title bundles) are sold as a unit and billed via invoice lines referencing the package. Package-level billing is standard in content distribution; this link supports package revenue ' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:originalInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Line Id' ;
    rdfs:comment 'Reference to the original invoice line that this line is adjusting, crediting, or replacing. Used for tracking billing corrections, credits, and makegoods.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:chargeDescription rdf:type rdf:Property ;
    rdfs:label 'Charge Description' ;
    rdfs:comment 'Detailed description of the charge appearing on the invoice line, explaining the service, ad spot, carriage fee period, or license fee installment being billed.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center or business unit responsible for this revenue line, used for internal financial reporting and profitability analysis.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpmRate rdf:type rdf:Property ;
    rdfs:label 'Cpm Rate' ;
    rdfs:comment 'Cost per thousand impressions rate for advertising line items, the standard pricing metric for ad inventory sales in broadcasting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountCode rdf:type rdf:Property ;
    rdfs:label 'Discount Code' ;
    rdfs:comment 'Code or identifier for the discount program or promotion applied to this line, used for tracking discount effectiveness and revenue impact.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current status of any billing dispute associated with this line item, tracking customer challenges and resolution workflow.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedAmount rdf:type rdf:Property ;
    rdfs:label 'Extended Amount' ;
    rdfs:comment 'Total amount for this line item including all charges, discounts, and taxes. This is the final billable amount for the line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grpDelivered rdf:type rdf:Property ;
    rdfs:label 'Grp Delivered' ;
    rdfs:comment 'Gross Rating Points delivered for this advertising line item, measuring the total audience reach and frequency achieved for the campaign.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Business-facing line item identifier displayed on customer invoices and billing statements for reference and dispute resolution.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionRule rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Rule' ;
    rdfs:comment 'Rule or method for recognizing revenue from this line item, such as point-in-time (ad spot delivery), over-time (subscription period), or milestone-based (license installment).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Service Period End Date' ;
    rdfs:comment 'End date of the service period covered by this line item charge. For subscriptions this is the billing cycle end; for ad campaigns this is the flight end date.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Period Start Date' ;
    rdfs:comment 'Start date of the service period covered by this line item charge. For subscriptions this is the billing cycle start; for ad campaigns this is the flight start date.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spotCount rdf:type rdf:Property ;
    rdfs:label 'Spot Count' ;
    rdfs:comment 'Number of ad spots delivered for this line item, used in advertising billing to verify delivery against the sales order commitment.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax classification code that determines the tax treatment for this line item, used for tax calculation and compliance reporting.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Payment Method Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_method. Business justification: Payment is made using ONE payment method (stored payment instrument). Currently duplicates card and bank account details; need FK to the stored payment_method record for single source of truth. Remove' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The monetary amount of the payment transaction in the specified currency. Gross payment value before any adjustments.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'The portion of the payment amount that has been applied against outstanding invoices or account balances. May differ from payment_amount if partial application or overpayment.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Authorization code returned by the payment processor or card issuer confirming approval of the transaction.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Bank Transaction Reference' ;
    rdfs:comment 'Reference number provided by the bank for wire transfers, ACH transactions, or check deposits. Used for bank reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The channel or interface through which the payment was submitted (web portal, mobile app, IVR, mail, in-person, API, batch import). [ENUM-REF-CANDIDATE: web_portal|mobile_app|ivr|mail|in_person|api|batch_import — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateway rdf:type rdf:Property ;
    rdfs:label 'Gateway' ;
    rdfs:comment 'Name of the payment gateway or processor used to handle the transaction (e.g., Stripe, Authorize.Net, PayPal, Adyen).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the payment gateway or processor. Used for reconciliation and dispute resolution.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date when the payment was posted to the general ledger in the financial system. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAutopay rdf:type rdf:Property ;
    rdfs:label 'Is Autopay' ;
    rdfs:comment 'Indicates whether this payment was processed automatically through a recurring payment or autopay setup. True if autopay, false if manual.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Indicates whether this payment is currently under dispute or chargeback. True if disputed, false otherwise.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodType rdf:type rdf:Property ;
    rdfs:label 'Method Type' ;
    rdfs:comment 'The type of payment instrument used for the transaction. Indicates the financial mechanism (credit card, ACH, wire, check, etc.). [ENUM-REF-CANDIDATE: credit_card|debit_card|ach|wire_transfer|check|cash|paypal|direct_debit — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Externally visible unique payment transaction number used for customer communication and reconciliation. Format: PAY-XXXXXXXX.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentSource rdf:type rdf:Property ;
    rdfs:label 'Payment Source' ;
    rdfs:comment 'Type of business relationship generating the payment (subscriber, advertiser, distributor, syndicator, licensee, other).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Timestamp' ;
    rdfs:comment 'The precise date and time when the payment transaction was processed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Amount refunded to the customer if payment status is refunded. May be partial or full refund.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundDate rdf:type rdf:Property ;
    rdfs:label 'Refund Date' ;
    rdfs:comment 'Date when the refund was processed and issued to the customer. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Reason for payment reversal if status is reversed. Includes chargeback reason codes and dispute details.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date when the payment funds were settled and cleared in the business bank account. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'The portion of the payment amount that remains unapplied and is held as credit on the account. Calculated as payment_amount minus applied_amount.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountNumberLastFour rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number Last Four' ;
    rdfs:comment 'The last four digits of the bank account number. Used for customer identification without exposing full account details. Applicable for ACH, SEPA, and wire transfer methods.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'The primary street address line associated with the payment method. Used for Address Verification Service (AVS) checks and fraud prevention.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Secondary address line for apartment, suite, or unit number. Optional field for complete billing address capture.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'The city or municipality of the billing address. Used for AVS verification and tax jurisdiction determination.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the billing address. Used for international payment processing and regulatory compliance (e.g., GDPR, PCI DSS regional requirements).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the billing address. Critical for AVS verification and accurate sales tax calculation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'The state, province, or region of the billing address. Used for AVS verification and regional tax compliance.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardBrand rdf:type rdf:Property ;
    rdfs:label 'Card Brand' ;
    rdfs:comment 'The brand or network of the payment card (e.g., Visa, Mastercard, American Express). Applicable only when payment method type is credit or debit card. [ENUM-REF-CANDIDATE: visa|mastercard|amex|discover|jcb|diners_club|unionpay — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'The name of the individual or entity as it appears on the payment card. Used for billing verification and fraud prevention.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'The reason why the payment method was deactivated. Used for churn analysis and process improvement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryAlertDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Alert Date' ;
    rdfs:comment 'The date when the system should trigger an alert to the subscriber about upcoming payment method expiration. Typically set 30-60 days before card expiry to enable proactive customer outreach and reduce involuntary churn.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryMonth rdf:type rdf:Property ;
    rdfs:label 'Expiry Month' ;
    rdfs:comment 'The month (1-12) when the payment card expires. Used to validate card validity and trigger expiry alerts for subscription renewals.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryYear rdf:type rdf:Property ;
    rdfs:label 'Expiry Year' ;
    rdfs:comment 'The four-digit year when the payment card expires. Used in conjunction with expiry_month to determine card validity and schedule proactive customer outreach.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failedTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Failed Transaction Count' ;
    rdfs:comment 'The cumulative count of failed transaction attempts using this payment method. Used to identify problematic payment methods and trigger dunning workflows.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gatewayCustomerProfileReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Customer Profile Reference' ;
    rdfs:comment 'The unique customer profile identifier in the payment gateway system. Used to link this payment method to the gateway\'s customer vault for secure transaction processing.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayPaymentMethodReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Payment Method Reference' ;
    rdfs:comment 'The unique payment method identifier assigned by the payment gateway. Used for transaction processing and reconciliation with gateway records.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Boolean flag indicating whether this is the default payment method for the subscriber. Used to determine which payment method to charge for recurring subscriptions and invoices.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastFailureDate rdf:type rdf:Property ;
    rdfs:label 'Last Failure Date' ;
    rdfs:comment 'The date of the most recent failed transaction attempt. Used in conjunction with failed_transaction_count to manage retry logic and customer communication.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastFailureReason rdf:type rdf:Property ;
    rdfs:label 'Last Failure Reason' ;
    rdfs:comment 'The reason code or message returned by the payment gateway for the most recent failed transaction. Used for troubleshooting and customer support.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Last Four Digits' ;
    rdfs:comment 'The last four digits of the payment card number. Used for customer identification and verification without exposing full card details. PCI DSS permits storage of last four digits.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Amount' ;
    rdfs:comment 'The amount of the most recent successful transaction in the subscriber\'s billing currency. Used for fraud detection and transaction pattern analysis.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'The date of the most recent successful transaction using this payment method. Used for payment method activity tracking and dormancy analysis.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandateReference rdf:type rdf:Property ;
    rdfs:label 'Mandate Reference' ;
    rdfs:comment 'The unique reference identifier for the direct debit mandate authorizing recurring payments. Required for SEPA Direct Debit and other regulated direct debit schemes.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandateSignedDate rdf:type rdf:Property ;
    rdfs:label 'Mandate Signed Date' ;
    rdfs:comment 'The date when the customer signed the direct debit mandate. Required for regulatory compliance and dispute resolution in direct debit transactions.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentGateway rdf:type rdf:Property ;
    rdfs:label 'Payment Gateway' ;
    rdfs:comment 'The payment gateway or processor used to tokenize and process transactions for this payment method (e.g., Stripe, Adyen, Braintree, Authorize.Net). Used for routing transactions and reconciliation.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Method Status' ;
    rdfs:comment 'The current lifecycle status of the payment method. Determines whether the payment method can be used for new transactions. Inactive or expired methods require customer action to reactivate.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'The type of payment instrument registered. Indicates the payment mechanism used for billing transactions. [ENUM-REF-CANDIDATE: credit_card|debit_card|ach|sepa|wire_transfer|paypal|apple_pay — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:token rdf:type rdf:Property ;
    rdfs:label 'Token' ;
    rdfs:comment 'PCI DSS-compliant tokenized representation of the payment instrument. Never stores raw Primary Account Number (PAN). Used for secure payment processing without exposing sensitive cardholder data.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-visible unique account number assigned to the billing account. Used on invoices, statements, and customer correspondence.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPayEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic payment processing is enabled for this account. When true, invoices are automatically charged to the default payment method on the due date.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code in which this account is billed (e.g., USD, GBP, EUR). All invoices and payments for this account are denominated in this currency.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycleDay rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Day' ;
    rdfs:comment 'Day of the month (1-31) on which recurring invoices are generated for monthly billing cycles. Null for non-monthly cycles.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date on which this billing account was permanently closed. Null for active and suspended accounts.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum outstanding balance allowed for this account before credit hold is applied. Null indicates no credit limit (cash-in-advance or unlimited credit).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Current Balance Amount' ;
    rdfs:comment 'Current outstanding balance on the account, calculated as sum of unpaid invoices minus unapplied credits and payments. Positive values indicate amounts owed to the business; negative values indicate credit balances owed to the customer.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'Preferred method for delivering invoices to this account. Email sends PDF invoices; postal mail sends printed invoices; electronic portal makes invoices available for download in customer self-service portal; EDI transmits invoices via Electronic Data Interchange (X12 810 or EDIFACT INVOIC).' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date of the most recent dunning notice or collections contact sent to this account.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Invoice Date' ;
    rdfs:comment 'Date of the most recent invoice generated for this account. Used for billing cycle tracking and account activity monitoring.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Amount of the most recent payment received. Used for payment pattern analysis.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment received and applied to this account. Used for payment behavior analysis and credit risk assessment.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date on which this billing account was first established and activated.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapCustomerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Account Number' ;
    rdfs:comment 'Customer master record number in SAP S/4HANA Financial Accounting (FI) module. Used for GL posting, accounts receivable management, and financial reconciliation. This is the authoritative financial system identifier.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether this account is exempt from sales tax, VAT, or other consumption taxes. True for tax-exempt organizations (e.g., non-profits, government entities, resellers with valid exemption certificates); false for standard taxable accounts.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'Government-issued certificate or registration number authorizing tax exemption. Required for audit trail when tax_exempt_flag is true.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Expiry Date' ;
    rdfs:comment 'Date on which the tax exemption certificate expires and must be renewed. Null for permanent exemptions.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wideorbitAccountReference rdf:type rdf:Property ;
    rdfs:label 'Wideorbit Account Reference' ;
    rdfs:comment 'Account identifier in WideOrbit traffic and billing system. Used for advertising sales order management, spot scheduling, and ad billing for advertiser and agency accounts.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zuoraAccountReference rdf:type rdf:Property ;
    rdfs:label 'Zuora Account Reference' ;
    rdfs:comment 'Account identifier in Zuora subscription billing platform. Used for subscription lifecycle management, recurring billing, and revenue recognition for SVOD/AVOD subscriber accounts.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleId rdf:type rdf:Property ;
    rdfs:label 'Cycle Id' ;
    rdfs:comment 'Primary key for cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenewEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Enabled' ;
    rdfs:comment 'Indicates whether subscriptions on this billing cycle automatically renew at the end of the term. True enables automatic renewal in Zuora subscription management.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingPeriodEndDay rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Day' ;
    rdfs:comment 'Day of the month (1-31) when the service period covered by the invoice ends. Used to calculate service period duration for revenue recognition. Null for non-monthly frequencies.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingPeriodStartDay rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Day' ;
    rdfs:comment 'Day of the month (1-31) when the service period covered by the invoice begins. May differ from cycle_day for advance billing scenarios. Null for non-monthly frequencies.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingRunDayOffset rdf:type rdf:Property ;
    rdfs:label 'Billing Run Day Offset' ;
    rdfs:comment 'Number of days before or after the cycle day when the billing run executes. Positive values indicate days after cycle day; negative values indicate days before. Used to schedule invoice generation in advance of service period.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingTiming rdf:type rdf:Property ;
    rdfs:label 'Billing Timing' ;
    rdfs:comment 'Indicates whether billing occurs in advance (invoice before service period) or in arrears (invoice after service period). Critical for revenue recognition under ASC 606.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Business identifier code for the billing cycle (e.g., MONTHLY_01, QUARTERLY_Q1, ANNUAL_FY). Used in Zuora subscription billing engine for cycle identification.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleDescription rdf:type rdf:Property ;
    rdfs:label 'Cycle Description' ;
    rdfs:comment 'Detailed description of the billing cycle configuration, including business rules, special handling instructions, and usage notes for billing operations team.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Human-readable name of the billing cycle (e.g., Monthly Standard, Quarterly Advance, Annual Arrears).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'Current lifecycle status of the billing cycle configuration. Active cycles are available for new subscriptions; inactive cycles are closed to new assignments but continue for existing subscribers; deprecated cycles are phased out; pending cycles are configured but not yet live.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'Classification of the billing cycle by revenue stream: subscription (SVOD/AVOD subscriber billing), advertising (ad campaign billing via Wide Orbit), carriage (MVPD/vMVPD distribution fees), syndication (content licensing fees), usage (pay-per-view/TVOD), or custom (non-standard arrangements).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:day rdf:type rdf:Property ;
    rdfs:label 'Day' ;
    rdfs:comment 'Day of the month (1-31) when the billing cycle starts or billing run executes. For monthly cycles, this is the anchor date. Null for non-monthly frequencies.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days after payment due date before late fees or service suspension actions are triggered. Provides customer buffer for payment processing delays.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceGenerationDay rdf:type rdf:Property ;
    rdfs:label 'Invoice Generation Day' ;
    rdfs:comment 'Specific day of the month (1-31) when invoices are generated for this cycle. Calculated from cycle_day and billing_run_day_offset. Null for non-monthly frequencies.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastBillingDate rdf:type rdf:Property ;
    rdfs:label 'Last Billing Date' ;
    rdfs:comment 'Most recent date when a billing run was successfully completed for this cycle. Null if no billing run has occurred yet.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextBillingDate rdf:type rdf:Property ;
    rdfs:label 'Next Billing Date' ;
    rdfs:comment 'Next date when a billing run will execute for accounts assigned to this cycle. Updated after each billing run completion. Used by Zuora billing engine for scheduling.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDueDays rdf:type rdf:Property ;
    rdfs:label 'Payment Due Days' ;
    rdfs:comment 'Number of days after invoice generation when payment is due. Used to calculate invoice due date. Standard terms are Net 30, Net 15, or immediate (0 days).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prorationEnabled rdf:type rdf:Property ;
    rdfs:label 'Proration Enabled' ;
    rdfs:comment 'Indicates whether partial-period charges are prorated when subscription starts/ends mid-cycle. True enables proration calculation in Zuora.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prorationMethod rdf:type rdf:Property ;
    rdfs:label 'Proration Method' ;
    rdfs:comment 'Method for calculating prorated charges: daily (per-day calculation), monthly (per-month calculation), or none (no proration). Used when proration_enabled is true.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCalculationEnabled rdf:type rdf:Property ;
    rdfs:label 'Tax Calculation Enabled' ;
    rdfs:comment 'Indicates whether automatic tax calculation is enabled for invoices generated under this cycle. True triggers tax engine integration (e.g., Avalara, Vertex) during invoice generation.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalAdSpotId rdf:type rdf:Property ;
    rdfs:label 'Original Ad Spot Id' ;
    rdfs:comment 'Foreign key linking to advertising.ad_spot. Business justification: Spot-level credits for technical failures, preemptions, or affidavit discrepancies require direct ad_spot reference for precise credit calculation and makegood tracking in broadcast advertising operat' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdSpot .

ind:originalInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Id' ;
    rdfs:comment 'Reference to the original invoice being credited, adjusted, or written off. Null for credits not tied to a specific invoice.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:badDebtWriteOffFlag rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Write Off Flag' ;
    rdfs:comment 'Indicates whether this credit memo represents a bad debt write-off for an uncollectable balance. True for write-offs, false for other credit types.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionAgencyName rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Name' ;
    rdfs:comment 'Name of the third-party collection agency to which the debt was referred, if applicable.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAgencyReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Referral Flag' ;
    rdfs:comment 'Indicates whether the original debt was referred to a collection agency before write-off. Used for tracking recovery potential.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Monetary value of the credit being issued, always positive. Represents the amount to be deducted from customer balance or written off.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Externally-visible business identifier for the credit memo, used in customer communications and financial reporting. Typically follows format CM-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Status' ;
    rdfs:comment 'Current lifecycle status of the credit memo in the approval and application workflow.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date the credit memo was formally issued and became effective for accounting purposes.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makegoodSpotsQuantity rdf:type rdf:Property ;
    rdfs:label 'Makegood Spots Quantity' ;
    rdfs:comment 'Number of compensatory advertising spots to be provided as makegood for under-delivered campaigns. Null for non-makegood credits.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Net Credit Amount' ;
    rdfs:comment 'Net credit amount after tax adjustments. Equals credit_amount minus tax_amount.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Business reason category for issuing the credit memo. Makegood refers to compensatory ad spots for under-delivered campaigns; billing_error for invoice corrections; service_outage for subscriber service credits; goodwill for customer retention; bad_debt_write_off for uncollectable balances.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of why the credit memo was issued, including specific circumstances, campaign details, or error descriptions.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'Amount subsequently recovered from a written-off debt through collection efforts or customer payment. Null if no recovery occurred.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Date' ;
    rdfs:comment 'Date on which a previously written-off amount was recovered. Null if no recovery occurred.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionImpact rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Impact' ;
    rdfs:comment 'Accounting period impact classification for revenue recognition under ASC 606. Indicates whether the credit affects current, prior, or future period revenue.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'SAP S/4HANA financial document number for the credit memo posting, used for reconciliation and audit trail.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPostingDate rdf:type rdf:Property ;
    rdfs:label 'Sap Posting Date' ;
    rdfs:comment 'Date the credit memo was posted to SAP S/4HANA general ledger for financial reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Id' ;
    rdfs:comment 'Unique identifier for the billing dispute record. Primary key.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dispute .

ind:assignedResolverName rdf:type rdf:Property ;
    rdfs:label 'Assigned Resolver Name' ;
    rdfs:comment 'Name of the employee or team assigned to resolve the dispute, for operational tracking.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address of the primary contact person for the disputing party, used for dispute correspondence.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact person for the disputing party, used for dispute resolution communication.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Issued Flag' ;
    rdfs:comment 'Indicates whether a credit memo was issued as part of the dispute resolution (True) or not (False).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Detailed narrative explanation of the dispute as provided by the disputing party, capturing the specific issue and context.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Classification of the dispute reason: amount_error (billing calculation error), service_not_received (content or service not delivered), makegood_claim (compensatory ad spot request), duplicate_charge (same charge billed twice), rate_discrepancy (incorrect pricing applied), contract_dispute (terms interpretation disagreement).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The monetary amount being contested by the disputing party, in the invoice currency.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputingPartyName rdf:type rdf:Property ;
    rdfs:label 'Disputing Party Name' ;
    rdfs:comment 'Name of the organization or individual who raised the dispute, for reporting and communication purposes.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputingPartyType rdf:type rdf:Property ;
    rdfs:label 'Disputing Party Type' ;
    rdfs:comment 'Category of the entity raising the dispute: subscriber (end consumer), advertiser (ad campaign buyer), MVPD (Multichannel Video Programming Distributor), licensee (content license holder), distributor (content distribution partner).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Numeric indicator of how many times the dispute has been escalated (0 = no escalation, 1 = first escalation to supervisor, 2 = second escalation to manager, etc.).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Explanation of why the dispute was escalated beyond the initial resolver, capturing complexity or policy exception requirements.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCaseNumber rdf:type rdf:Property ;
    rdfs:label 'External Case Number' ;
    rdfs:comment 'Reference number from an external system (e.g., CRM case ID, legal case number) if the dispute is tracked in multiple systems.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'The date the dispute was formally raised and entered into the dispute management system.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openTimestamp rdf:type rdf:Property ;
    rdfs:label 'Open Timestamp' ;
    rdfs:comment 'Precise timestamp when the dispute was created in the system, used for SLA tracking and audit trail.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date the dispute was formally closed with a final outcome.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Deadline Date' ;
    rdfs:comment 'Target date by which the dispute must be resolved per Service Level Agreement (SLA) or contractual terms.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Internal notes documenting the investigation findings, resolution rationale, and actions taken by the resolver.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome of the dispute resolution: full_credit (entire disputed amount credited), partial_credit (portion credited), no_adjustment (dispute rejected, no change), makegood_issued (compensatory ad spot provided), contract_amendment (terms renegotiated), escalated_unresolved (sent to legal or executive review).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Precise timestamp when the dispute was resolved, used for SLA compliance measurement.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Classification of the underlying cause of the dispute for process improvement and trend analysis: billing_system_error (system calculation bug), data_entry_error (manual input mistake), rate_card_error (incorrect pricing configuration), service_delivery_failure (content or ad not delivered), contract_misinterpretation (terms unclear or misread), customer_misunderstanding (customer expectation mismatch).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the dispute resolution exceeded the contractual SLA deadline (True) or was resolved within SLA (False).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Expected Settlement Date' ;
    rdfs:comment 'Projected date when the refund is expected to be settled and funds returned to the subscriber. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fee rdf:type rdf:Property ;
    rdfs:label 'Fee' ;
    rdfs:comment 'Any processing fee deducted from the refund amount, if applicable (e.g., payment gateway fees, administrative charges).' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isChargebackRelated rdf:type rdf:Property ;
    rdfs:label 'Is Chargeback Related' ;
    rdfs:comment 'Boolean flag indicating whether this refund is related to a payment chargeback or dispute initiated by the subscriber through their financial institution.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialRefund rdf:type rdf:Property ;
    rdfs:label 'Is Partial Refund' ;
    rdfs:comment 'Boolean flag indicating whether this is a partial refund (true) or a full refund (false) of the original payment amount.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Net Refund Amount' ;
    rdfs:comment 'Net monetary amount actually returned to the subscriber or account after deducting any processing fees (refund_amount - refund_fee).' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingDate rdf:type rdf:Property ;
    rdfs:label 'Processing Date' ;
    rdfs:comment 'Date when the refund was submitted for payment processing. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'The method by which the refund is being returned to the subscriber: back to original payment instrument, check, account credit, wire transfer, or other mechanism. [ENUM-REF-CANDIDATE: original_payment_method|credit_card|bank_transfer|check|account_credit|wire_transfer|paypal|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Number' ;
    rdfs:comment 'Externally-visible business identifier for the refund, used in customer communications and financial reconciliation. Format: RFD-XXXXXXXXXX.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Current lifecycle status of the refund transaction in the processing workflow. [ENUM-REF-CANDIDATE: pending_approval|approved|processing|completed|failed|cancelled|reversed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundType rdf:type rdf:Property ;
    rdfs:label 'Refund Type' ;
    rdfs:comment 'Classification of the refund based on the revenue stream being reversed: subscription billing, advertising billing, carriage fee, syndication license fee, overpayment, or other.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date when the refund was originally requested by the subscriber or initiated by the system. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wideorbitRefundReference rdf:type rdf:Property ;
    rdfs:label 'Wideorbit Refund Reference' ;
    rdfs:comment 'External identifier from Wide Orbit traffic and billing system for refunds originating from advertising revenue, used for system integration and reconciliation.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zuoraRefundReference rdf:type rdf:Property ;
    rdfs:label 'Zuora Refund Reference' ;
    rdfs:comment 'External identifier from Zuora subscription billing system for refunds originating from subscription revenue, used for system integration and reconciliation.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Schedule Id' ;
    rdfs:comment 'Unique identifier for the revenue recognition schedule entry. Primary key for ASC 606 revenue recognition tracking.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Business justification for any modification to the original recognition schedule (e.g., \'Contract amendment - extended term by 6 months\', \'Makegood issued for underdelivered GRPs\', \'Early termination - subscriber cancellation\', \'Price adjustment - volume discount applied\'). Required for audit trail and SOX compliance.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeRecognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Recognized Amount' ;
    rdfs:comment 'Total revenue recognized to date from contract inception through the current reporting period. Increases each period as revenue is earned. Used for deferred revenue balance calculation and revenue assurance reconciliation.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentPeriodRecognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Current Period Recognized Amount' ;
    rdfs:comment 'Revenue amount recognized in the current accounting period (month or quarter). Posted to the SAP revenue account. May differ from monthly recognized amount for usage-based or milestone-based contracts.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredRevenueBalance rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Balance' ;
    rdfs:comment 'Remaining unearned revenue balance on the contract. Calculated as total contract value minus cumulative recognized amount. Represents the liability on the balance sheet under ASC 606. Decreases as revenue is recognized over time.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Last Recognition Date' ;
    rdfs:comment 'Date of the most recent revenue recognition posting. Used to track recognition progress and identify schedules requiring current-period processing.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monthlyRecognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Recognized Amount' ;
    rdfs:comment 'Standard monthly revenue amount to be recognized under straight-line method. Calculated as total contract value divided by recognition period months. May vary for usage-based or milestone-based contracts.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Next Recognition Date' ;
    rdfs:comment 'Scheduled date for the next revenue recognition posting. Used by automated revenue recognition jobs to process monthly or quarterly recognition batches.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceObligationDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Description' ;
    rdfs:comment 'Narrative description of the performance obligation under ASC 606 (e.g., \'Provide streaming access to content library for 12 months\', \'Deliver 52 episodes of syndicated series\', \'Deliver 1000 GRPs in Q4 upfront commitment\'). Documents the basis for revenue recognition timing.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Recognition End Date' ;
    rdfs:comment 'Date when revenue recognition is scheduled to complete. Corresponds to the contract expiration date or end of the performance obligation period. Null for evergreen contracts until termination notice.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Recognition Period Months' ;
    rdfs:comment 'Total number of months over which revenue will be recognized. Calculated from recognition start date to end date. Used for straight-line recognition calculations and forecasting.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recognitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Start Date' ;
    rdfs:comment 'Date when revenue recognition begins. Corresponds to the contract effective date or service commencement date under ASC 606. Marks the beginning of the performance obligation period.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapDeferredRevenueAccountCode rdf:type rdf:Property ;
    rdfs:label 'Sap Deferred Revenue Account Code' ;
    rdfs:comment 'General Ledger (GL) liability account code in SAP S/4HANA where deferred revenue balance is maintained. Decreases as revenue is recognized and transferred to the revenue account.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapRevenueAccountCode rdf:type rdf:Property ;
    rdfs:label 'Sap Revenue Account Code' ;
    rdfs:comment 'General Ledger (GL) account code in SAP S/4HANA where recognized revenue is posted. Maps to the appropriate revenue account based on contract type and business unit (e.g., subscription revenue, advertising revenue, licensing revenue).' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemContractReference rdf:type rdf:Property ;
    rdfs:label 'Source System Contract Reference' ;
    rdfs:comment 'Native contract identifier in the source system (e.g., Zuora subscription ID, Wide Orbit order number, Rightsline license agreement ID). Used for data lineage and reconciliation back to operational systems.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Total monetary value of the contract to be recognized over the performance period. Represents the transaction price under ASC 606. Denominated in the contract currency.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adobeProfileReference rdf:type rdf:Property ;
    rdfs:label 'Adobe Profile Reference' ;
    rdfs:comment 'External identifier linking this subscriber to their unified profile in Adobe Experience Platform. Used for personalization, segmentation, and journey orchestration.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency of subscription billing. Monthly, quarterly, and annual are recurring; lifetime is one-time payment; pay-per-view is transactional.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Timestamp' ;
    rdfs:comment 'Date and time when CCPA opt-out was recorded. Required for audit trail and compliance reporting.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:churnRiskScore rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score' ;
    rdfs:comment 'Predictive score (0.0000 to 1.0000) indicating likelihood of subscriber cancellation within next billing cycle. Generated by machine learning model based on engagement, payment history, and behavioral signals.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coppaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Compliant Flag' ;
    rdfs:comment 'Indicates whether this subscriber account is subject to COPPA restrictions (under 13 years old). When true, data collection and advertising are restricted.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External business identifier for the subscriber, typically used for integration with Zuora billing and Adobe Experience Platform. May be customer-facing account number or external system key.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether subscriber has provided explicit consent for data processing under GDPR. Required for EU subscribers.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprConsentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Timestamp' ;
    rdfs:comment 'Date and time when GDPR consent was obtained. Required for audit trail and consent management.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Subscriber\'s self-identified gender. Used for demographic analytics and content personalization. Optional field respecting subscriber privacy preferences.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Login Timestamp' ;
    rdfs:comment 'Date and time of subscriber\'s most recent authentication. Used for engagement tracking and churn prediction.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastViewingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Viewing Timestamp' ;
    rdfs:comment 'Date and time of subscriber\'s most recent content viewing session. Used for engagement analysis and retention modeling.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ltv rdf:type rdf:Property ;
    rdfs:label 'Ltv' ;
    rdfs:comment 'Predicted total revenue this subscriber will generate over their entire relationship with the service. Used for acquisition cost justification and retention prioritization.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether subscriber has consented to receive marketing communications. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxRegisteredDevices rdf:type rdf:Property ;
    rdfs:label 'Max Registered Devices' ;
    rdfs:comment 'Maximum number of devices that can be registered to this subscriber account. Used for device management and anti-piracy enforcement.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentalControlPin rdf:type rdf:Property ;
    rdfs:label 'Parental Control Pin' ;
    rdfs:comment 'Encrypted PIN code required to access age-restricted content when parental controls are enabled. Stored in hashed format for security.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Two-letter ISO language code representing subscriber\'s preferred interface and content language. Used for UI localization and content recommendations.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationSource rdf:type rdf:Property ;
    rdfs:label 'Registration Source' ;
    rdfs:comment 'Channel through which the subscriber originally registered. Used for acquisition analytics and channel effectiveness measurement.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Timestamp' ;
    rdfs:comment 'Date and time when the subscriber account was first created. Used for cohort analysis, LTV calculation, and subscriber lifecycle tracking.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subscriptionEndDate rdf:type rdf:Property ;
    rdfs:label 'Subscription End Date' ;
    rdfs:comment 'Date when the current subscription is scheduled to end or renew. Null for active recurring subscriptions. Used for churn prediction and retention campaigns.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionStartDate rdf:type rdf:Property ;
    rdfs:label 'Subscription Start Date' ;
    rdfs:comment 'Date when the current subscription tier became effective. Used for billing cycle calculation and tenure analysis.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalViewingHours rdf:type rdf:Property ;
    rdfs:label 'Total Viewing Hours' ;
    rdfs:comment 'Cumulative hours of content viewed by this subscriber since registration. Key engagement metric for LTV calculation and content recommendation.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxContentRatingId rdf:type rdf:Property ;
    rdfs:label 'Max Content Rating Id' ;
    rdfs:comment 'Foreign key linking to content.rating. Business justification: Household-level content filtering enforces a maximum rating ceiling for all profiles in the household. The max_content_rating plain column is a denormalized rating reference; a FK to content.rating.ra' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaBroadcasting .

ind:accountCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Account Created Date' ;
    rdfs:comment 'Date when the household account was first created in the system. Used for tenure analysis and customer lifetime value (LTV) calculations.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:averageRevenuePerUser rdf:type rdf:Property ;
    rdfs:label 'Average Revenue Per User' ;
    rdfs:comment 'Average monthly revenue generated by this household, calculated as total revenue divided by number of active months. Key metric for household value assessment.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the household has consented to sharing their viewing data with third parties for analytics and advertising purposes. Required for privacy compliance.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:householdName rdf:type rdf:Property ;
    rdfs:label 'Household Name' ;
    rdfs:comment 'Human-readable name or label for the household, typically derived from the primary account holder\'s name or a custom household designation.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdStatus rdf:type rdf:Property ;
    rdfs:label 'Household Status' ;
    rdfs:comment 'Current lifecycle status of the household account. Determines access rights and billing state.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdType rdf:type rdf:Property ;
    rdfs:label 'Household Type' ;
    rdfs:comment 'Classification of the household based on its composition and purpose. Determines applicable service tier rules and entitlement models.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO 639-1 language code representing the household\'s preferred content and interface language. Used for content recommendations and UI localization.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifetimeValue rdf:type rdf:Property ;
    rdfs:label 'Lifetime Value' ;
    rdfs:comment 'Total revenue generated by this household since account creation, including subscription fees, transactional purchases (TVOD), and advertising revenue attribution. Used for customer segmentation and retention investment decisions.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primarySubscriberCode rdf:type rdf:Property ;
    rdfs:label 'Primary Subscriber Code' ;
    rdfs:comment 'Reference to the primary account holder or subscriber who owns this household account. This subscriber has administrative privileges for the household.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Number of registered members or subscribers within this household. Used for family plan eligibility and simultaneous stream limit enforcement.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adSupported rdf:type rdf:Property ;
    rdfs:label 'Ad Supported' ;
    rdfs:comment 'Indicates whether this subscription plan includes advertising (AVOD/FAST model) or is ad-free (SVOD model).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addonEligible rdf:type rdf:Property ;
    rdfs:label 'Addon Eligible' ;
    rdfs:comment 'Indicates whether this plan can be purchased as an add-on to another base subscription plan (e.g., premium sports channel add-on).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioQualityMax rdf:type rdf:Property ;
    rdfs:label 'Audio Quality Max' ;
    rdfs:comment 'Maximum audio quality format available under this subscription plan (e.g., stereo, surround 5.1, Dolby Atmos, DTS:X).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether subscriptions under this plan automatically renew at the end of each billing period by default.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'Standard recurring price for the subscription plan before any discounts, promotions, or taxes. Expressed in the default currency.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Frequency at which subscribers are billed for this plan (e.g., monthly, quarterly, annual, biannual, one-time, usage-based).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundledPlan rdf:type rdf:Property ;
    rdfs:label 'Bundled Plan' ;
    rdfs:comment 'Indicates whether this is a bundled subscription plan that combines multiple services or content packages (e.g., streaming + live TV + music).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationPolicy rdf:type rdf:Property ;
    rdfs:label 'Cancellation Policy' ;
    rdfs:comment 'Policy governing subscriber cancellation: anytime (immediate), end of billing period, no refund, or prorated refund.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:churnRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Category' ;
    rdfs:comment 'Assessed churn risk category for subscribers on this plan based on historical churn rate analysis (low, medium, high).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Minimum contract commitment period in months for this subscription plan. Null indicates month-to-month with no minimum commitment.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceRegistrationLimit rdf:type rdf:Property ;
    rdfs:label 'Device Registration Limit' ;
    rdfs:comment 'Maximum number of devices that can be registered to a subscriber account under this plan. Null indicates unlimited device registrations.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downloadEnabled rdf:type rdf:Property ;
    rdfs:label 'Download Enabled' ;
    rdfs:comment 'Indicates whether offline download of content is permitted under this subscription plan.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downloadLimit rdf:type rdf:Property ;
    rdfs:label 'Download Limit' ;
    rdfs:comment 'Maximum number of titles that can be downloaded for offline viewing at any given time. Null if download_enabled is false or unlimited.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyTerminationFee rdf:type rdf:Property ;
    rdfs:label 'Early Termination Fee' ;
    rdfs:comment 'Fee charged to subscribers who cancel before the end of the contract term. Null if no early termination fee applies.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicAvailability rdf:type rdf:Property ;
    rdfs:label 'Geographic Availability' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this subscription plan is available for purchase (e.g., USA,CAN,GBR,AUS). Empty indicates global availability.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known unique business identifier for the subscription plan used in billing systems and customer communications. Managed in Zuora product catalog.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the subscription plan features, benefits, and included content for subscriber-facing materials and internal reference.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable marketing name of the subscription plan displayed to subscribers (e.g., Premium Plus, Family Bundle, Sports Add-On).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the subscription plan: active (available for new subscriptions), inactive (temporarily unavailable), deprecated (no longer offered but existing subscriptions continue), sunset (being phased out), coming soon (announced but not yet available).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Business model classification: SVOD (Subscription Video On Demand), AVOD (Advertising-Supported Video On Demand), TVOD (Transactional Video On Demand), FAST (Free Ad-Supported Streaming Television), hybrid, or add-on plan.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalPlan rdf:type rdf:Property ;
    rdfs:label 'Promotional Plan' ;
    rdfs:comment 'Indicates whether this is a limited-time promotional subscription plan offered at a special price or with enhanced features.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetArpu rdf:type rdf:Property ;
    rdfs:label 'Target Arpu' ;
    rdfs:comment 'Target average revenue per user (ARPU) metric for financial planning and performance tracking of this subscription plan.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLtv rdf:type rdf:Property ;
    rdfs:label 'Target Ltv' ;
    rdfs:comment 'Target lifetime value (LTV) metric representing the projected total revenue from a subscriber over the duration of their subscription to this plan.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trialDurationDays rdf:type rdf:Property ;
    rdfs:label 'Trial Duration Days' ;
    rdfs:comment 'Number of days for the free trial period if trial_eligible is true. Null if no trial is offered.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trialEligible rdf:type rdf:Property ;
    rdfs:label 'Trial Eligible' ;
    rdfs:comment 'Indicates whether this subscription plan is eligible for a free trial period for new subscribers.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:videoQualityMax rdf:type rdf:Property ;
    rdfs:label 'Video Quality Max' ;
    rdfs:comment 'Maximum video resolution quality available under this subscription plan (e.g., SD, HD, Full HD, 4K, 8K).' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Payment Instrument Id' ;
    rdfs:comment 'Foreign key linking to subscriber.payment_instrument. Business justification: A subscription is billed using a subscriber\'s stored payment instrument. While subscription.payment_method_id already references billing.payment_method (cross-domain), adding payment_instrument_id cre' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentInstrument .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'Marketing channel or source through which the subscriber acquired this subscription (e.g., web, mobile app, partner referral, promotional campaign).' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether the subscription will automatically renew at the end of the current term. True = auto-renew enabled, False = manual renewal required.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rate Amount' ;
    rdfs:comment 'The standard subscription rate amount per billing cycle, in the billing currency, before any discounts or promotions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Marketing campaign identifier associated with the subscription acquisition, used for campaign performance tracking and attribution.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationInitiatedBy rdf:type rdf:Property ;
    rdfs:label 'Cancellation Initiated By' ;
    rdfs:comment 'Entity that initiated the cancellation: subscriber (voluntary), system (automated), admin (manual intervention), payment_failure (billing issue), fraud_detection (security). Null for active subscriptions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentTermEndDate rdf:type rdf:Property ;
    rdfs:label 'Current Term End Date' ;
    rdfs:comment 'End date of the current billing term or subscription period. Represents the next renewal or expiration date.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentTermStartDate rdf:type rdf:Property ;
    rdfs:label 'Current Term Start Date' ;
    rdfs:comment 'Start date of the current billing term or subscription period.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date when the subscriber first enrolled in this subscription plan. Represents the start of the contractual relationship.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gracePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Grace Period End Date' ;
    rdfs:comment 'Date when the grace period ends after a payment failure or cancellation, after which access is fully revoked. Null if no grace period applies.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotional End Date' ;
    rdfs:comment 'Date when the promotional rate expires and standard pricing resumes. Null if no promotion is active.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalRateAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Rate Amount' ;
    rdfs:comment 'The discounted subscription rate amount during the promotional period, in the billing currency. Null if no promotion is active.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalRateFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Rate Flag' ;
    rdfs:comment 'Indicates whether the subscription is currently on a promotional or discounted rate. True = promotional pricing active, False = standard pricing.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Date when the subscription is scheduled to renew for the next billing cycle.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Subscription Number' ;
    rdfs:comment 'Human-readable business identifier for the subscription, displayed to subscribers and customer service representatives.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle state of the subscription: active (in service), suspended (temporarily paused), cancelled (terminated by subscriber or system), expired (end date reached), trialing (in trial period), pending (awaiting activation).' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionType rdf:type rdf:Property ;
    rdfs:label 'Subscription Type' ;
    rdfs:comment 'Classification of subscription model: SVOD (Subscription Video On Demand), AVOD (Advertising-Supported Video On Demand), TVOD (Transactional Video On Demand), bundle, premium add-on, or trial.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Free-text explanation for why the subscription was suspended (e.g., payment failure, subscriber request, fraud investigation). Null for non-suspended subscriptions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialEndDate rdf:type rdf:Property ;
    rdfs:label 'Trial End Date' ;
    rdfs:comment 'Date when the trial period ends and billing begins, if applicable. Null for non-trial subscriptions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialStartDate rdf:type rdf:Property ;
    rdfs:label 'Trial Start Date' ;
    rdfs:comment 'Date when the trial period began, if applicable. Null for non-trial subscriptions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:zuoraSubscriptionReference rdf:type rdf:Property ;
    rdfs:label 'Zuora Subscription Reference' ;
    rdfs:comment 'External subscription identifier from Zuora billing system for revenue recognition and invoicing integration.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Device Registration Id' ;
    rdfs:comment 'Unique identifier for the device registration record. Primary key.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceRegistration .

ind:adTrackingConsent rdf:type rdf:Property ;
    rdfs:label 'Ad Tracking Consent' ;
    rdfs:comment 'Indicates whether the user has consented to advertising tracking on this device. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:advertisingDeviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Advertising Device Identifier' ;
    rdfs:comment 'Device advertising identifier (IDFA for iOS, AAID for Android). Used for targeted advertising and attribution tracking. Subject to user consent per GDPR and CCPA.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioCodecSupport rdf:type rdf:Property ;
    rdfs:label 'Audio Codec Support' ;
    rdfs:comment 'Comma-separated list of audio codecs supported by the device (e.g., AAC, Dolby Digital, Dolby Atmos, DTS). Determines audio track selection.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deregistrationReason rdf:type rdf:Property ;
    rdfs:label 'Deregistration Reason' ;
    rdfs:comment 'Reason why the device was deregistered. Used for churn analysis and fraud investigation. [ENUM-REF-CANDIDATE: user_initiated|account_closure|fraud_detected|device_limit_exceeded|inactivity|admin_action|device_lost_stolen — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deregistrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deregistration Timestamp' ;
    rdfs:comment 'Date and time when the device was deregistered or removed from the subscriber account. Null if device is still registered.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviceFingerprint rdf:type rdf:Property ;
    rdfs:label 'Device Fingerprint' ;
    rdfs:comment 'Unique cryptographic hash or identifier that uniquely identifies the physical device. Used for device authentication and fraud prevention.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceLimitEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Device Limit Enforcement Flag' ;
    rdfs:comment 'Indicates whether this device counts toward the subscribers per-account device limit. Used to exempt customer service test devices or promotional devices.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceNickname rdf:type rdf:Property ;
    rdfs:label 'Device Nickname' ;
    rdfs:comment 'User-assigned friendly name for the device (e.g., Living Room TV, Johns iPhone). Improves device management user experience.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Drm Certificate Reference' ;
    rdfs:comment 'Reference to the DRM device certificate used for secure content decryption. Required for protected content playback.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmSecurityLevel rdf:type rdf:Property ;
    rdfs:label 'Drm Security Level' ;
    rdfs:comment 'Security level of the DRM implementation on the device. Determines maximum content quality and protection level (e.g., Widevine L1 for HD, L3 for SD).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Calculated fraud risk score for this device registration (0.00 to 100.00). Higher scores indicate higher likelihood of fraudulent activity.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicLocation rdf:type rdf:Property ;
    rdfs:label 'Geographic Location' ;
    rdfs:comment 'Geographic location derived from IP address or device GPS (country, region, city). Used for content windowing and blackout restrictions.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdrSupport rdf:type rdf:Property ;
    rdfs:label 'Hdr Support' ;
    rdfs:comment 'Indicates whether the device supports HDR video playback (HDR10, Dolby Vision, HLG). Enables premium content delivery.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address from which the device was registered. Used for geolocation, fraud detection, and blackout enforcement.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Active Timestamp' ;
    rdfs:comment 'Date and time of the most recent authenticated activity from this device. Used to identify inactive devices and enforce inactivity policies.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxDownloadCount rdf:type rdf:Property ;
    rdfs:label 'Max Download Count' ;
    rdfs:comment 'Maximum number of titles that can be downloaded for offline viewing on this device. Enforced per subscription plan terms.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxResolutionSupported rdf:type rdf:Property ;
    rdfs:label 'Max Resolution Supported' ;
    rdfs:comment 'Highest video resolution the device can decode and display. Used for adaptive bitrate streaming (ABR) profile selection.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offlineDownloadEnabled rdf:type rdf:Property ;
    rdfs:label 'Offline Download Enabled' ;
    rdfs:comment 'Indicates whether this device is authorized for offline content downloads. Subject to plan entitlements and DRM restrictions.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalControlPinHash rdf:type rdf:Property ;
    rdfs:label 'Parental Control Pin Hash' ;
    rdfs:comment 'Cryptographic hash of the parental control PIN. Used to authenticate access to restricted content without storing the PIN in plaintext.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationToken rdf:type rdf:Property ;
    rdfs:label 'Push Notification Token' ;
    rdfs:comment 'Device-specific token for sending push notifications (APNS for iOS, FCM for Android). Used for engagement campaigns and service alerts.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the device registration. Determines whether the device is authorized for playback.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementId rdf:type rdf:Property ;
    rdfs:label 'Entitlement Id' ;
    rdfs:comment 'Unique identifier for the entitlement record. Primary key.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelPackageId rdf:type rdf:Property ;
    rdfs:label 'Channel Package Id' ;
    rdfs:comment 'Reference to the channel package or bundle that this entitlement provides access to.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:restrictingHoldbackId rdf:type rdf:Property ;
    rdfs:label 'Restricting Holdback Id' ;
    rdfs:comment 'Foreign key linking to rights.holdback. Business justification: Entitlement blackout_exempt flag requires knowing which holdback is restricting access. When a holdback is active for a media asset in a territory, the entitlement system must reference the specific h' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holdback .

ind:accessLevel rdf:type rdf:Property ;
    rdfs:label 'Access Level' ;
    rdfs:comment 'Degree of access granted by this entitlement: full (complete access), preview (sample or trailer only), limited (restricted features or duration), or premium (enhanced quality or early access).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adFree rdf:type rdf:Property ;
    rdfs:label 'Ad Free' ;
    rdfs:comment 'Indicates whether this entitlement provides ad-free viewing experience. False indicates AVOD (Advertising-Supported Video On Demand) model applies.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationCount rdf:type rdf:Property ;
    rdfs:label 'Authorization Count' ;
    rdfs:comment 'Total number of playback authorization requests processed for this entitlement since activation.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenew rdf:type rdf:Property ;
    rdfs:label 'Auto Renew' ;
    rdfs:comment 'Indicates whether this entitlement will automatically renew upon expiration based on the underlying subscription plan.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutExempt rdf:type rdf:Property ;
    rdfs:label 'Blackout Exempt' ;
    rdfs:comment 'Indicates whether this entitlement is exempt from geographic blackout restrictions typically applied to live sports or regional content.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFlags rdf:type rdf:Property ;
    rdfs:label 'Compliance Flags' ;
    rdfs:comment 'Comma-separated list of compliance requirements applicable to this entitlement (e.g., \'GDPR\', \'CCPA\', \'COPPA\'). Used to enforce data privacy and regulatory obligations.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceLimit rdf:type rdf:Property ;
    rdfs:label 'Device Limit' ;
    rdfs:comment 'Maximum number of concurrent devices that can use this entitlement. Null indicates no device limit.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyAccessEnabled rdf:type rdf:Property ;
    rdfs:label 'Early Access Enabled' ;
    rdfs:comment 'Indicates whether this entitlement grants early access to content before general release.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Entitlement Status' ;
    rdfs:comment 'Current lifecycle status of the entitlement: active (currently valid), suspended (temporarily disabled), expired (past end date), revoked (administratively cancelled), or pending (awaiting activation).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementType rdf:type rdf:Property ;
    rdfs:label 'Entitlement Type' ;
    rdfs:comment 'Classification of the entitlement based on how it was granted: subscription (standard plan), promotional (marketing grant), bundle (package deal), addon (premium add-on), mvpd_carriage (Multichannel Video Programming Distributor carriage agreement), or trial (free trial period).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalEntitlementReference rdf:type rdf:Property ;
    rdfs:label 'External Entitlement Reference' ;
    rdfs:comment 'Unique identifier for this entitlement in the originating external system (e.g., Zuora subscription ID, MVPD authorization token).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this entitlement is valid. Empty indicates no geographic restriction.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantReason rdf:type rdf:Property ;
    rdfs:label 'Grant Reason' ;
    rdfs:comment 'Business justification or reason code for why this entitlement was granted (e.g., \'Annual Subscription\', \'Promotional Campaign Q4-2024\', \'Customer Retention Offer\', \'MVPD Carriage Agreement\').' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuthorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Authorization Timestamp' ;
    rdfs:comment 'Timestamp of the most recent playback authorization request that validated this entitlement at the CDN/DRM layer.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parentalControlLevel rdf:type rdf:Property ;
    rdfs:label 'Parental Control Level' ;
    rdfs:comment 'Maximum content rating level accessible under this entitlement based on parental control settings. Follows Motion Picture Association (MPA) and TV Parental Guidelines ratings. [ENUM-REF-CANDIDATE: none|g|pg|pg13|r|nc17|tv_y|tv_y7|tv_g|tv_pg|tv_14|tv_ma — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Reason why the entitlement was revoked or suspended, if applicable (e.g., \'Payment Failure\', \'Terms of Service Violation\', \'Subscriber Request\', \'Rights Expiration\').' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revokedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Revoked Timestamp' ;
    rdfs:comment 'Timestamp when the entitlement was permanently revoked, if applicable.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:suspendedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Suspended Timestamp' ;
    rdfs:comment 'Timestamp when the entitlement was suspended, if applicable.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trialEntitlement rdf:type rdf:Property ;
    rdfs:label 'Trial Entitlement' ;
    rdfs:comment 'Indicates whether this is a trial entitlement granted as part of a free trial period.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalControlId rdf:type rdf:Property ;
    rdfs:label 'Parental Control Id' ;
    rdfs:comment 'Unique identifier for the parental control configuration record. Primary key.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allowedViewingEndTime rdf:type rdf:Property ;
    rdfs:label 'Allowed Viewing End Time' ;
    rdfs:comment 'End time of the daily viewing window in HH:MM format (24-hour clock). Content access is blocked after this time. Null if viewing_time_restriction_enabled is False.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allowedViewingStartTime rdf:type rdf:Property ;
    rdfs:label 'Allowed Viewing Start Time' ;
    rdfs:comment 'Start time of the daily viewing window in HH:MM format (24-hour clock). Content access is permitted starting at this time. Null if viewing_time_restriction_enabled is False.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoplayEnabled rdf:type rdf:Property ;
    rdfs:label 'Autoplay Enabled' ;
    rdfs:comment 'Indicates whether automatic playback of next episode or recommended content is enabled for this profile. True if autoplay is on, False if disabled (often disabled for child profiles to limit binge-watching).' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedContentCategories rdf:type rdf:Property ;
    rdfs:label 'Blocked Content Categories' ;
    rdfs:comment 'Comma-separated list of content genre or category codes that are explicitly blocked for this profile (e.g., \'horror\', \'violence\', \'adult\'). Provides granular control beyond rating thresholds.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentLanguageRestriction rdf:type rdf:Property ;
    rdfs:label 'Content Language Restriction' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 language codes (e.g., \'en\', \'es\', \'fr\') to which content access is restricted. Null if no language restrictions apply. Used to limit content to specific languages for child profiles.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaChildProfileFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Child Profile Flag' ;
    rdfs:comment 'Indicates whether this profile is designated as belonging to a child under 13 years of age, triggering COPPA compliance requirements. True if the profile is for a child under 13, False otherwise.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceRestrictionEnabled rdf:type rdf:Property ;
    rdfs:label 'Device Restriction Enabled' ;
    rdfs:comment 'Indicates whether this parental control configuration restricts viewing to specific registered devices. True if device restrictions are enforced, False if profile can be accessed from any device.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maturityLevelOverride rdf:type rdf:Property ;
    rdfs:label 'Maturity Level Override' ;
    rdfs:comment 'Custom maturity level designation that overrides standard rating thresholds for specific content. Used for granular exceptions (e.g., allowing a specific R-rated film for educational purposes). Null if no override is set.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDailyViewingMinutes rdf:type rdf:Property ;
    rdfs:label 'Max Daily Viewing Minutes' ;
    rdfs:comment 'Maximum number of minutes of content viewing allowed per day for this profile. Null if no daily limit is set. Used to enforce screen time limits for child profiles.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationEmail rdf:type rdf:Property ;
    rdfs:label 'Notification Email' ;
    rdfs:comment 'Email address to which parental control alerts and notifications are sent (e.g., when a child attempts to access restricted content). Null if notifications are disabled.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalControlStatus rdf:type rdf:Property ;
    rdfs:label 'Parental Control Status' ;
    rdfs:comment 'Current lifecycle status of this parental control configuration. Active indicates the configuration is enforced; Inactive indicates it is saved but not enforced; Suspended indicates temporary deactivation by system or admin.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinCodeHash rdf:type rdf:Property ;
    rdfs:label 'Pin Code Hash' ;
    rdfs:comment 'Cryptographic hash of the parental control PIN. Stored as a one-way hash for security. Never stored in plaintext. Used to authenticate access to restricted content or settings changes.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinProtectionEnabled rdf:type rdf:Property ;
    rdfs:label 'Pin Protection Enabled' ;
    rdfs:comment 'Indicates whether a PIN is required to access content above the rating threshold or to modify parental control settings. True if PIN protection is active, False otherwise.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchaseLockEnabled rdf:type rdf:Property ;
    rdfs:label 'Purchase Lock Enabled' ;
    rdfs:comment 'Indicates whether transactional purchases (TVOD - Transactional Video On Demand) are blocked for this profile. True if purchase lock is active (preventing rentals/purchases), False if purchases are allowed.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:searchRestrictionEnabled rdf:type rdf:Property ;
    rdfs:label 'Search Restriction Enabled' ;
    rdfs:comment 'Indicates whether search functionality is restricted to only show age-appropriate content. True if search results are filtered by parental controls, False if unrestricted search is allowed.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:viewingTimeRestrictionEnabled rdf:type rdf:Property ;
    rdfs:label 'Viewing Time Restriction Enabled' ;
    rdfs:comment 'Indicates whether time-of-day viewing restrictions are enforced for this profile. True if time restrictions are active, False otherwise.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:favoriteGenreId rdf:type rdf:Property ;
    rdfs:label 'Favorite Genre Id' ;
    rdfs:comment 'Foreign key linking to content.genre. Business justification: Personalization and recommendation engines require explicit genre preferences. Drives content discovery, homepage curation, and email marketing. Complements behavioral signals with declared preference' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Genre .

ind:aepSegmentIds rdf:type rdf:Property ;
    rdfs:label 'Aep Segment Ids' ;
    rdfs:comment 'Comma-separated list of Adobe Experience Platform segment IDs that this viewer profile belongs to. Used for personalized content recommendations, targeted advertising, and dynamic user experience customization.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoplayPreviewsEnabled rdf:type rdf:Property ;
    rdfs:label 'Autoplay Previews Enabled' ;
    rdfs:comment 'Boolean flag indicating whether automatic preview playback is enabled when browsing content. True enables preview autoplay; false disables previews.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:avatarUrl rdf:type rdf:Property ;
    rdfs:label 'Avatar Url' ;
    rdfs:comment 'URL reference to the profile avatar image stored in the Media Asset Management (MAM) system or Content Delivery Network (CDN). Used for visual identification in profile selection interfaces.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSaverMode rdf:type rdf:Property ;
    rdfs:label 'Data Saver Mode' ;
    rdfs:comment 'Boolean flag indicating whether data saver mode is enabled to reduce bandwidth consumption. True limits video quality and disables high-bandwidth features; false allows full quality streaming.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genrePreferences rdf:type rdf:Property ;
    rdfs:label 'Genre Preferences' ;
    rdfs:comment 'Comma-separated list of preferred content genre identifiers for personalization and recommendation algorithms. Derived from viewing history and explicit user selections. Used by Adobe Experience Platform for segment targeting.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultProfile rdf:type rdf:Property ;
    rdfs:label 'Is Default Profile' ;
    rdfs:comment 'Boolean flag indicating whether this is the default profile that is automatically selected when the subscriber logs in. True for default profile; false for secondary profiles. Only one profile per subscriber should be marked as default.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKidsProfile rdf:type rdf:Property ;
    rdfs:label 'Is Kids Profile' ;
    rdfs:comment 'Boolean flag indicating whether this is a dedicated kids profile with enhanced parental controls, age-appropriate content filtering, and COPPA (Children\'s Online Privacy Protection Act) compliance enforcement. True for kids profiles; false for adult/general profiles.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAccessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Access Timestamp' ;
    rdfs:comment 'Timestamp when the viewer profile was last accessed or used for content viewing. Used for engagement analytics, churn prediction, and inactive profile identification. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastPlatform rdf:type rdf:Property ;
    rdfs:label 'Last Platform' ;
    rdfs:comment 'Platform type of the last device used to access this viewer profile. Used for platform-specific analytics and Over-The-Top (OTT) distribution tracking. [ENUM-REF-CANDIDATE: web|mobile_ios|mobile_android|smart_tv|roku|fire_tv|apple_tv|chromecast|gaming_console — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingConsent rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent' ;
    rdfs:comment 'Boolean flag indicating whether the viewer profile has consented to receive marketing communications and promotional content. True allows marketing; false opts out. Required for GDPR (General Data Protection Regulation) and CCPA (California Consumer Privacy Act) compliance.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maturityRatingLevel rdf:type rdf:Property ;
    rdfs:label 'Maturity Rating Level' ;
    rdfs:comment 'Maximum content maturity rating level allowed for this viewer profile. Enforces parental controls and content filtering based on Motion Picture Association (MPA) film ratings and TV Parental Guidelines. Content exceeding this rating is blocked from playback. [ENUM-REF-CANDIDATE: G|PG|PG-13|R|NC-17|TV-Y|TV-Y7|TV-G|TV-PG|TV-14|TV-MA — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDownloads rdf:type rdf:Property ;
    rdfs:label 'Max Downloads' ;
    rdfs:comment 'Maximum number of content titles that can be downloaded for offline viewing on this profile. Enforces subscription tier limits and storage management policies.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personalizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Personalization Enabled' ;
    rdfs:comment 'Boolean flag indicating whether personalized content recommendations and user experience customization are enabled for this profile. True enables Adobe Experience Platform personalization; false provides generic content discovery. Impacts GDPR (General Data Protection Regulation) and CCPA (California Consumer Privacy Act) consent requirements.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pinEnabled rdf:type rdf:Property ;
    rdfs:label 'Pin Enabled' ;
    rdfs:comment 'Boolean flag indicating whether PIN protection is enabled for this profile. True requires PIN entry for profile access; false allows unrestricted access.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profileSortOrder rdf:type rdf:Property ;
    rdfs:label 'Profile Sort Order' ;
    rdfs:comment 'Integer value determining the display order of this profile in the profile selection interface. Lower values appear first. Used for user experience optimization.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subtitlePreference rdf:type rdf:Property ;
    rdfs:label 'Subtitle Preference' ;
    rdfs:comment 'Default subtitle display preference for this viewer profile. Off disables subtitles; on always displays subtitles; auto displays subtitles based on content language and user language mismatch.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewingHistoryEnabled rdf:type rdf:Property ;
    rdfs:label 'Viewing History Enabled' ;
    rdfs:comment 'Boolean flag indicating whether viewing history is tracked and stored for this profile. True enables history tracking for recommendations and resume playback; false disables tracking for privacy. Impacts GDPR (General Data Protection Regulation) and CCPA (California Consumer Privacy Act) compliance.' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:churnEventId rdf:type rdf:Property ;
    rdfs:label 'Churn Event Id' ;
    rdfs:comment 'Unique identifier for the subscriber churn event record.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationCreditMemoId rdf:type rdf:Property ;
    rdfs:label 'Cancellation Credit Memo Id' ;
    rdfs:comment 'Foreign key linking to billing.credit_memo. Business justification: Cancellation proration credit issuance: when subscribers cancel mid-billing-period, a credit memo is issued for unused days. Linking churn_event to the resulting credit_memo supports cancellation fina' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditMemo .

ind:cancellationRefundId rdf:type rdf:Property ;
    rdfs:label 'Cancellation Refund Id' ;
    rdfs:comment 'Foreign key linking to billing.refund. Business justification: Churn-triggered refund reconciliation: annual or prepaid subscription cancellations generate refunds that must be linked to the churn event for cancellation financial close-out, win-back offer cost ac' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Refund .

ind:finalInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Final Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Cancellation final invoice reconciliation: churn events trigger final prorated invoices or zero-balance invoices at cancellation. Finance teams require churn_event → invoice linkage for churn revenue ' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:lastViewedChannelId rdf:type rdf:Property ;
    rdfs:label 'Last Viewed Channel Id' ;
    rdfs:comment 'Foreign key linking to scheduling.channel. Business justification: Churn analysis requires identifying which channel a subscriber was last watching before cancellation — a standard retention analytics and content investment decision process. This FK enables channel-l' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:lastViewedTitleId rdf:type rdf:Property ;
    rdfs:label 'Last Viewed Title Id' ;
    rdfs:comment 'Foreign key linking to content.title. Business justification: Churn analysis tracks last content engagement to identify content gaps and inform win-back campaigns. Critical for retention analytics, content investment decisions, and personalized re-engagement off' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:autoRenewDisabledDate rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Disabled Date' ;
    rdfs:comment 'The date when the subscriber disabled auto-renewal for their subscription. Null if auto-renewal was never disabled. Used to identify planned churn versus reactive churn.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationChannel rdf:type rdf:Property ;
    rdfs:label 'Cancellation Channel' ;
    rdfs:comment 'The interface or channel through which the cancellation was initiated. Supports analysis of churn patterns by customer touchpoint. [ENUM-REF-CANDIDATE: web_self_service|mobile_app|customer_care|email|chat|ivr|mvpd_drop|system_automated — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Standardized code representing the stated reason for cancellation. Used for churn analytics and product improvement initiatives. Empty value_regex indicates reference to external reason code lookup table with more than 6 values.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Description' ;
    rdfs:comment 'Free-text description or additional details provided by the subscriber explaining the reason for cancellation. Supports qualitative churn analysis.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:churnPredictionScore rdf:type rdf:Property ;
    rdfs:label 'Churn Prediction Score' ;
    rdfs:comment 'The machine learning model-generated churn risk score that was assigned to the subscriber prior to the churn event. Range 0.0000 to 1.0000, where higher values indicate higher churn risk. Used for model validation and predictive accuracy assessment.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:churnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Churn Timestamp' ;
    rdfs:comment 'The exact date and time when the subscriber cancellation or lapse event occurred. This is the business event timestamp representing when the subscriber relationship ended.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:churnType rdf:type rdf:Property ;
    rdfs:label 'Churn Type' ;
    rdfs:comment 'Classification of the churn event based on the nature of cancellation. Voluntary indicates subscriber-initiated cancellation, involuntary indicates business-initiated termination, payment failure indicates cancellation due to billing issues.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorServiceMentionedFlag rdf:type rdf:Property ;
    rdfs:label 'Competitor Service Mentioned Flag' ;
    rdfs:comment 'Boolean indicator of whether the subscriber mentioned switching to a competitor service during the cancellation process. Used for competitive intelligence and market positioning analysis.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerCareContactCount rdf:type rdf:Property ;
    rdfs:label 'Customer Care Contact Count' ;
    rdfs:comment 'The number of customer care interactions the subscriber had in the 30 days prior to churn. Used to identify service quality issues and early warning signals.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysSinceLastViewing rdf:type rdf:Property ;
    rdfs:label 'Days Since Last Viewing' ;
    rdfs:comment 'The number of days between the last viewing activity and the churn event. Used for engagement-based churn prediction models.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceCountAtChurn rdf:type rdf:Property ;
    rdfs:label 'Device Count At Churn' ;
    rdfs:comment 'The number of registered devices associated with the subscriber at the time of churn. Used for multi-device engagement analysis.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalAccessDate rdf:type rdf:Property ;
    rdfs:label 'Final Access Date' ;
    rdfs:comment 'The last date the subscriber had active access to content and services. May differ from churn_timestamp due to grace periods or paid-through dates.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprDataDeletionRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Deletion Requested Flag' ;
    rdfs:comment 'Boolean indicator of whether the subscriber requested deletion of their personal data under GDPR right to erasure at the time of churn. Used for privacy compliance tracking.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastViewingDate rdf:type rdf:Property ;
    rdfs:label 'Last Viewing Date' ;
    rdfs:comment 'The date of the subscribers last content viewing activity before churn. Used to identify engagement drop-off patterns and at-risk subscriber signals.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentalControlEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Control Enabled Flag' ;
    rdfs:comment 'Boolean indicator of whether parental controls were enabled on the subscription at the time of churn. Used for family-oriented subscriber segmentation and churn analysis.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentFailureCount rdf:type rdf:Property ;
    rdfs:label 'Payment Failure Count' ;
    rdfs:comment 'The number of consecutive payment failures that occurred before the churn event. Used to identify involuntary churn patterns and dunning effectiveness.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalDiscountActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Discount Active Flag' ;
    rdfs:comment 'Boolean indicator of whether the subscriber had an active promotional discount at the time of churn. Used to analyze price sensitivity and promotional effectiveness.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reactivationEligibilityDate rdf:type rdf:Property ;
    rdfs:label 'Reactivation Eligibility Date' ;
    rdfs:comment 'The date when the churned subscriber becomes eligible for reactivation campaigns or promotional offers. Used for win-back campaign targeting and timing.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionTenureMonths rdf:type rdf:Property ;
    rdfs:label 'Subscription Tenure Months' ;
    rdfs:comment 'The total number of months the subscriber maintained an active subscription before churning. Used for cohort analysis and LTV (Lifetime Value) calculations.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLifetimeRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Lifetime Revenue' ;
    rdfs:comment 'The cumulative revenue generated from this subscriber across their entire subscription tenure. Used for LTV (Lifetime Value) analysis and churn impact assessment.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:winBackOfferAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Win Back Offer Accepted Flag' ;
    rdfs:comment 'Boolean indicator of whether the subscriber accepted the win-back offer. True indicates acceptance and retention, False indicates rejection and churn completion. Null if no offer was presented.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:winBackOfferPresentedFlag rdf:type rdf:Property ;
    rdfs:label 'Win Back Offer Presented Flag' ;
    rdfs:comment 'Boolean indicator of whether a retention or win-back offer was presented to the subscriber during the cancellation process. True indicates an offer was made, False indicates no offer was presented.' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subscriptionChangeId rdf:type rdf:Property ;
    rdfs:label 'Subscription Change Id' ;
    rdfs:comment 'Unique identifier for the subscription change event. Primary key.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerId rdf:type rdf:Property ;
    rdfs:label 'Offer Id' ;
    rdfs:comment 'Reference to the promotional offer or retention campaign that was redeemed during this subscription change. Null if no offer was applied.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offer .

ind:offerRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Offer Redemption Id' ;
    rdfs:comment 'Foreign key linking to subscriber.offer_redemption. Business justification: A subscription change is frequently triggered by a promotional offer redemption (e.g., a subscriber redeems a discount code that causes a plan upgrade or downgrade). Adding offer_redemption_id as a FK' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OfferRedemption .

ind:primarySubscriptionPlanId rdf:type rdf:Property ;
    rdfs:label 'Primary Subscription Plan Id' ;
    rdfs:comment 'Reference to the subscription plan that was active before this change. Null for new subscriptions or add-on attach events.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubscriptionPlan .

ind:prorationCreditMemoId rdf:type rdf:Property ;
    rdfs:label 'Proration Credit Memo Id' ;
    rdfs:comment 'Foreign key linking to billing.credit_memo. Business justification: Downgrade proration credit memo tracking: subscription downgrades generate prorated credit memos for the billing period difference. subscription_change already links to the invoice via zuora_invoice_i' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditMemo .

ind:zuoraInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Zuora Invoice Id' ;
    rdfs:comment 'The unique identifier of the Zuora invoice generated for this subscription change. Links the change event to billing and revenue recognition processes.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:appliedDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Discount Amount' ;
    rdfs:comment 'The total discount amount applied to the new plan as part of this change. Includes promotional offers, retention discounts, and loyalty rewards.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Applied Discount Percentage' ;
    rdfs:comment 'The percentage discount applied to the new plan subscription fee. Used for promotion effectiveness analysis and revenue impact modeling.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeChannel rdf:type rdf:Property ;
    rdfs:label 'Change Channel' ;
    rdfs:comment 'The channel through which the subscription change was initiated. Enables channel effectiveness analysis and self-service adoption tracking. [ENUM-REF-CANDIDATE: web|mobile app|call center|chat|email|api|admin portal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Change Effective Date' ;
    rdfs:comment 'The date when the subscription change became effective and billing adjustments were applied. Critical for revenue recognition and proration calculations.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:changeNotes rdf:type rdf:Property ;
    rdfs:label 'Change Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the agent or system during the change process. Captures context, customer feedback, and special handling instructions.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Change Processed Timestamp' ;
    rdfs:comment 'The exact date and time when the system completed processing the change and updated the subscription state. Used for operational efficiency metrics.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Change Request Timestamp' ;
    rdfs:comment 'The exact date and time when the subscriber or agent initiated the change request. Used for time-to-fulfillment analysis and customer experience tracking.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'The type of change applied to the subscription. Categorizes the nature of the modification for lifecycle analysis and revenue impact assessment.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentEntitlementChange rdf:type rdf:Property ;
    rdfs:label 'Content Entitlement Change' ;
    rdfs:comment 'Describes changes to content library access, premium channel entitlements, or windowing rights resulting from this subscription change. Critical for content licensing and rights management.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceLimitNew rdf:type rdf:Property ;
    rdfs:label 'Device Limit New' ;
    rdfs:comment 'The maximum number of concurrent devices allowed under the new subscription plan. Enables analysis of device limit impact on upgrade and downgrade decisions.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceLimitPrevious rdf:type rdf:Property ;
    rdfs:label 'Device Limit Previous' ;
    rdfs:comment 'The maximum number of concurrent devices allowed under the previous subscription plan. Used to track device entitlement changes and household sharing patterns.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrrImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Mrr Impact Amount' ;
    rdfs:comment 'The net change in monthly recurring revenue resulting from this subscription change. Positive for upgrades, negative for downgrades. Calculated as new_monthly_recurring_revenue minus previous_monthly_recurring_revenue.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newBillingPeriod rdf:type rdf:Property ;
    rdfs:label 'New Billing Period' ;
    rdfs:comment 'The billing frequency of the new subscription plan. Enables analysis of billing period changes and their impact on cash flow and retention.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newMonthlyRecurringRevenue rdf:type rdf:Property ;
    rdfs:label 'New Monthly Recurring Revenue' ;
    rdfs:comment 'The monthly recurring revenue amount from the new plan after this change. Used to calculate MRR expansion, contraction, and net revenue retention metrics.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousBillingPeriod rdf:type rdf:Property ;
    rdfs:label 'Previous Billing Period' ;
    rdfs:comment 'The billing frequency of the previous subscription plan. Used to analyze billing period migration patterns and payment preference trends.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousMonthlyRecurringRevenue rdf:type rdf:Property ;
    rdfs:label 'Previous Monthly Recurring Revenue' ;
    rdfs:comment 'The monthly recurring revenue amount from the previous plan before this change. Critical for MRR movement analysis and revenue waterfall reporting.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prorationAmount rdf:type rdf:Property ;
    rdfs:label 'Proration Amount' ;
    rdfs:comment 'The prorated credit or charge amount applied to the subscriber account due to mid-cycle plan changes. Positive values represent charges, negative values represent credits.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prorationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Proration Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the proration amount. Supports multi-currency subscription operations.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTierChange rdf:type rdf:Property ;
    rdfs:label 'Service Tier Change' ;
    rdfs:comment 'Describes the service tier transition for this subscription change. Specific to media streaming business models including AVOD (Advertising-Supported Video On Demand), SVOD (Subscription Video On Demand), and tiered SVOD offerings.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zuoraAmendmentReference rdf:type rdf:Property ;
    rdfs:label 'Zuora Amendment Reference' ;
    rdfs:comment 'The unique identifier of the Zuora subscription amendment record that represents this change. Enables reconciliation with the billing system of record.' ;
    rdfs:domain ind:SubscriptionChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zuoraPaymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Zuora Payment Method Id' ;
    rdfs:comment 'External identifier for this payment method in the Zuora subscription billing system. Used for system integration and reconciliation.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:bankAccountType rdf:type rdf:Property ;
    rdfs:label 'Bank Account Type' ;
    rdfs:comment 'Type of bank account for direct debit or ACH payment methods. Null for card-based payment methods.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Gateway Reference Code' ;
    rdfs:comment 'External reference identifier assigned by the payment gateway for this payment instrument. Used for gateway-specific operations and reconciliation.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftCardBalance rdf:type rdf:Property ;
    rdfs:label 'Gift Card Balance' ;
    rdfs:comment 'Remaining balance on the gift card or prepaid card. Updated after each transaction. Null for non-gift-card payment methods.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftCardCode rdf:type rdf:Property ;
    rdfs:label 'Gift Card Code' ;
    rdfs:comment 'Masked gift card or prepaid card code. Full code is tokenized per PCI DSS requirements.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandateAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Mandate Acceptance Date' ;
    rdfs:comment 'Date when the subscriber accepted the direct debit mandate. Required for regulatory compliance and dispute resolution.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maskedAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Masked Account Number' ;
    rdfs:comment 'Masked representation of the card or account number showing only the last 4 digits (e.g., ****1234). Full number is tokenized and stored securely per PCI DSS requirements.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentInstrumentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Instrument Status' ;
    rdfs:comment 'Current lifecycle status of the payment instrument. Active instruments can be charged; expired or suspended instruments require update or replacement.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentToken rdf:type rdf:Property ;
    rdfs:label 'Payment Token' ;
    rdfs:comment 'PCI DSS compliant tokenization reference for the actual payment instrument details. Used to process transactions without exposing sensitive cardholder data.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paypalEmail rdf:type rdf:Property ;
    rdfs:label 'Paypal Email' ;
    rdfs:comment 'Email address associated with the PayPal account. Used for PayPal payment method identification and processing.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paypalPayerReference rdf:type rdf:Property ;
    rdfs:label 'Paypal Payer Reference' ;
    rdfs:comment 'Unique PayPal payer identifier for the linked PayPal account. Used for PayPal billing agreement reference.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingTitleId rdf:type rdf:Property ;
    rdfs:label 'Qualifying Title Id' ;
    rdfs:comment 'Foreign key linking to content.title. Business justification: Promotional offers often require viewing or purchasing specific titles (e.g., "watch premiere to unlock discount"). Supports campaign attribution, content-driven acquisition, and partnership promotion' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:resultingSubscriptionPlanId rdf:type rdf:Property ;
    rdfs:label 'Resulting Subscription Plan Id' ;
    rdfs:comment 'Reference to the subscription plan that the subscriber enrolled in or upgraded to as a result of this offer redemption. Links to the subscription plan master record.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubscriptionPlan .

ind:attributionSource rdf:type rdf:Property ;
    rdfs:label 'Attribution Source' ;
    rdfs:comment 'The marketing source or touchpoint that led to this offer redemption. Examples include email campaign, social media ad, affiliate link, or organic search. Used for marketing attribution analysis.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Discount Duration Months' ;
    rdfs:comment 'The number of months for which the discount will be applied to the subscription. Null for one-time discounts or permanent pricing changes.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'The percentage discount applied when discount_type is percentage. Null for non-percentage discount types. Expressed as a decimal (e.g., 25.00 for 25% off).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'The type of discount mechanism applied through this offer redemption. Determines how the discount value is calculated and applied to the subscription.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityFailureReason rdf:type rdf:Property ;
    rdfs:label 'Eligibility Failure Reason' ;
    rdfs:comment 'Detailed explanation of why the redemption was rejected or marked ineligible. Null if redemption was successful. Used for customer service and offer optimization.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verified Flag' ;
    rdfs:comment 'Indicates whether the subscribers eligibility for the offer was verified at the time of redemption. True if eligibility checks passed, False otherwise.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstTimeSubscriberFlag rdf:type rdf:Property ;
    rdfs:label 'First Time Subscriber Flag' ;
    rdfs:comment 'Indicates whether this redemption resulted in a new subscriber acquisition (True) or was redeemed by an existing subscriber (False). Critical for Customer Acquisition Cost (CAC) and Lifetime Value (LTV) analysis.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offerExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Offer Expiration Date' ;
    rdfs:comment 'The date on which the promotional offer expires and can no longer be redeemed. Used to validate redemption eligibility and track expired redemption attempts.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redemptionChannel rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel' ;
    rdfs:comment 'The platform or channel through which the subscriber redeemed the offer. Enables channel effectiveness analysis for promotional campaigns.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCode rdf:type rdf:Property ;
    rdfs:label 'Redemption Code' ;
    rdfs:comment 'The unique promotional code or voucher code entered by the subscriber at the time of redemption. Used for tracking and validation.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionDeviceType rdf:type rdf:Property ;
    rdfs:label 'Redemption Device Type' ;
    rdfs:comment 'The type of device used by the subscriber to redeem the offer. Supports device-specific campaign optimization and user experience analysis.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionIpAddress rdf:type rdf:Property ;
    rdfs:label 'Redemption Ip Address' ;
    rdfs:comment 'The IP address from which the redemption request originated. Used for fraud detection and geographic analysis. May be considered Personally Identifiable Information (PII) under General Data Protection Regulation (GDPR).' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current lifecycle status of the offer redemption. Tracks whether the redemption was successfully applied, expired before use, reversed due to policy violation, or rejected due to eligibility failure.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'The exact date and time when the subscriber successfully redeemed the promotional offer. Represents the business event time of redemption.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Amount' ;
    rdfs:comment 'The estimated impact on revenue resulting from this offer redemption. Negative values represent revenue reduction due to discounts; positive values may represent incremental revenue from new subscriptions or upgrades.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'The date and time when the offer redemption was reversed or cancelled. Null if the redemption remains active. Used for chargeback and refund reconciliation.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:termsAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted Flag' ;
    rdfs:comment 'Indicates whether the subscriber explicitly accepted the terms and conditions associated with the promotional offer at the time of redemption. Required for compliance and dispute resolution.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms Version' ;
    rdfs:comment 'The version identifier of the offer terms and conditions that the subscriber agreed to at redemption. Format: v1.0, v2.1, etc. Used for legal audit trails.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zuoraSubscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Zuora Subscription Number' ;
    rdfs:comment 'The subscription identifier in the Zuora billing system that was created or modified as a result of this offer redemption. Used for billing reconciliation and revenue recognition.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affidavitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Affidavit Required Flag' ;
    rdfs:comment 'Indicates whether proof of broadcast affidavits must be provided to the advertiser. True = affidavits required; False = not required. Affidavits document actual air times and are often required for political advertising.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Agency commission rate as a percentage of gross order value. Standard industry rate is 15%. Applied to calculate net revenue.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the advertising order was confirmed by the advertiser or agency. Marks transition from pending to confirmed status.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contractedCpm rdf:type rdf:Property ;
    rdfs:label 'Contracted Cpm' ;
    rdfs:comment 'Contracted Cost Per Mille (cost per thousand impressions) for this advertising order. Key pricing metric for media buying.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedCprp rdf:type rdf:Property ;
    rdfs:label 'Contracted Cprp' ;
    rdfs:comment 'Contracted Cost Per Rating Point. Pricing metric calculated as total cost divided by GRP. Used for market efficiency comparison.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daypartMix rdf:type rdf:Property ;
    rdfs:label 'Daypart Mix' ;
    rdfs:comment 'Distribution of advertising spots across broadcast dayparts (time segments of broadcast day). Examples: Prime (8pm-11pm), Early Morning (6am-9am), Late Night (11pm-2am). Stored as comma-separated daypart allocations.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightEndDate rdf:type rdf:Property ;
    rdfs:label 'Flight End Date' ;
    rdfs:comment 'Last date the advertising campaign is scheduled to air. End of the contracted broadcast period.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flightStartDate rdf:type rdf:Property ;
    rdfs:label 'Flight Start Date' ;
    rdfs:comment 'First date the advertising campaign is scheduled to air. Beginning of the contracted broadcast period.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makegoodPolicy rdf:type rdf:Property ;
    rdfs:label 'Makegood Policy' ;
    rdfs:comment 'Policy for providing compensatory ad spots (makegoods) if contracted delivery is not met. Standard = industry-standard makegood terms; Guaranteed = full delivery guarantee; No Makegood = no compensation; Custom = special negotiated terms.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Net revenue value after agency commissions, discounts, and adjustments. Amount recognized for revenue reporting.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text notes and special instructions for this advertising order. May include trafficking instructions, creative specifications, or client preferences.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business identifier for the advertising order. Externally-known unique order number used in Wide Orbit traffic system and client communications. Also called broadcast order number or traffic order number.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the advertising order. Draft = initial entry; Pending = awaiting approval; Confirmed = accepted by advertiser; Active = currently running; Completed = flight finished; Cancelled = terminated; Invoiced = billed. [ENUM-REF-CANDIDATE: draft|pending|confirmed|active|completed|cancelled|invoiced — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the advertising order based on sales method. Upfront = advance advertising sales event; Scatter = last-minute ad inventory sales; Direct = direct advertiser purchase; Programmatic = automated bidding; Sponsorship = integrated brand partnership; Barter = trade arrangement.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:politicalAdFlag rdf:type rdf:Property ;
    rdfs:label 'Political Ad Flag' ;
    rdfs:comment 'Indicates whether this order contains political advertising content. True = political advertising; False = commercial advertising. Political ads have special FCC disclosure and equal-time requirements.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'Industry classification of the advertised product or service (e.g., automotive, pharmaceutical, retail, financial services). Used for content clearance and regulatory compliance.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGrp rdf:type rdf:Property ;
    rdfs:label 'Target Grp' ;
    rdfs:comment 'Target Gross Rating Points contracted for this order. GRP = Reach × Frequency, measuring total audience delivery weight. Used for campaign performance evaluation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTrp rdf:type rdf:Property ;
    rdfs:label 'Target Trp' ;
    rdfs:comment 'Target Rating Points for specific demographic audience. TRP measures delivery against a defined target audience segment rather than total audience.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalContractedValue rdf:type rdf:Property ;
    rdfs:label 'Total Contracted Value' ;
    rdfs:comment 'Total monetary value of the advertising order across all spots and placements. Gross revenue before agency commissions and discounts.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSpotCount rdf:type rdf:Property ;
    rdfs:label 'Total Spot Count' ;
    rdfs:comment 'Total number of advertising spots (commercial airings) contracted in this order across all placements and dayparts.' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Business name of the advertising campaign used for identification and reporting.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the advertising campaign. [ENUM-REF-CANDIDATE: draft|proposed|approved|active|paused|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign objective and strategy.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makegoodEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Eligible Flag' ;
    rdfs:comment 'Indicates whether this campaign is eligible for makegood compensatory ad spots if contracted delivery targets are not met.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productBrand rdf:type rdf:Property ;
    rdfs:label 'Product Brand' ;
    rdfs:comment 'The product, service, or brand being advertised in this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'The sales channel through which the campaign was sold (upfront advance sales, scatter last-minute, programmatic automated, direct negotiated, or sponsorship).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceCampaignReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Campaign Reference' ;
    rdfs:comment 'External reference identifier linking to the campaign record in Salesforce Media Cloud CRM system.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCpm rdf:type rdf:Property ;
    rdfs:label 'Target Cpm' ;
    rdfs:comment 'Contracted target Cost Per Mille representing the cost per thousand impressions.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCprp rdf:type rdf:Property ;
    rdfs:label 'Target Cprp' ;
    rdfs:comment 'Contracted target Cost Per Rating Point representing the cost to achieve one rating point.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetFrequency rdf:type rdf:Property ;
    rdfs:label 'Target Frequency' ;
    rdfs:comment 'Contracted average number of times each unique audience member should be exposed to the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetImpressions rdf:type rdf:Property ;
    rdfs:label 'Target Impressions' ;
    rdfs:comment 'Contracted total number of ad impressions to be delivered across the campaign.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetReachPercent rdf:type rdf:Property ;
    rdfs:label 'Target Reach Percent' ;
    rdfs:comment 'Contracted percentage of unique audience members to be reached by the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSovPercent rdf:type rdf:Property ;
    rdfs:label 'Target Sov Percent' ;
    rdfs:comment 'Contracted target Share of Voice representing the percentage of total advertising impressions in the category or daypart.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualSpendTier rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Tier' ;
    rdfs:comment 'The classification tier based on annual advertising spend volume, used for pricing, service level, and upfront negotiation priority.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'The credit approval status indicating whether the advertiser is authorized to purchase advertising on credit terms.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryCategory rdf:type rdf:Property ;
    rdfs:label 'Industry Category' ;
    rdfs:comment 'The Interactive Advertising Bureau (IAB) taxonomy category classifying the advertiser\'s primary business vertical (e.g., Automotive, Financial Services, Consumer Packaged Goods).' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPoliticalAdvertiser rdf:type rdf:Property ;
    rdfs:label 'Is Political Advertiser' ;
    rdfs:comment 'Boolean flag indicating whether this advertiser is a political candidate, party, or issue advocacy group subject to FCC political advertising disclosure requirements.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentCompanyName rdf:type rdf:Property ;
    rdfs:label 'Parent Company Name' ;
    rdfs:comment 'The name of the parent or holding company if the advertiser is a subsidiary or brand within a larger corporate structure.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAdClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Ad Clearance' ;
    rdfs:comment 'Boolean flag indicating whether this advertiser\'s creative content requires pre-broadcast clearance review due to industry category (e.g., pharmaceuticals, alcohol, financial services).' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'The doing-business-as (DBA) or brand name used in advertising campaigns and public-facing materials.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitAdvertiserCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Advertiser Code' ;
    rdfs:comment 'The unique advertiser identifier in the Wide Orbit traffic and billing system, used for ad scheduling, sales orders, and invoicing.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Date' ;
    rdfs:comment 'Date when the agency was granted accreditation status by the broadcaster or industry body.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiry Date' ;
    rdfs:comment 'Date when the current accreditation status expires and requires renewal. Nullable for indefinite accreditation.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Current accreditation status of the agency with industry bodies or the broadcaster, indicating creditworthiness and eligibility for commission-based billing.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingModel rdf:type rdf:Property ;
    rdfs:label 'Billing Model' ;
    rdfs:comment 'Billing methodology used for this agency. Gross: agency bills advertiser full amount and remits net to broadcaster. Net: broadcaster bills agency net amount. Hybrid: mixed approach.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum credit amount (in base currency) extended to the agency for outstanding ad orders before payment is required. Used for credit risk management.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingCompanyGroup rdf:type rdf:Property ;
    rdfs:label 'Holding Company Group' ;
    rdfs:comment 'Name of the parent holding company or agency network to which this agency belongs (e.g., WPP, Omnicom, Publicis, IPG, Dentsu). Null if independent.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date when the agency was first onboarded and approved to place advertising orders with the broadcaster.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesAgencyName rdf:type rdf:Property ;
    rdfs:label 'Sales Agency Name' ;
    rdfs:comment 'Full legal or trade name of the advertising agency or media buying firm.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesAgencyStatus rdf:type rdf:Property ;
    rdfs:label 'Sales Agency Status' ;
    rdfs:comment 'Current operational status of the agency relationship. Active agencies can place orders; inactive/suspended/terminated agencies cannot.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusReason rdf:type rdf:Property ;
    rdfs:label 'Status Reason' ;
    rdfs:comment 'Explanation or business reason for the current status, particularly for inactive, suspended, or terminated statuses (e.g., credit issues, contract expiration, voluntary closure).' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Agency Code' ;
    rdfs:comment 'Unique agency identifier code used in the Wide Orbit traffic and billing system for ad scheduling, sales orders, and invoicing.' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalSpotAdSpotId rdf:type rdf:Property ;
    rdfs:label 'Original Spot Ad Spot Id' ;
    rdfs:comment 'Reference to the original ad spot that this makegood spot is compensating for. Populated only when makegood_flag is true.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdSpot .

ind:actualAirTime rdf:type rdf:Property ;
    rdfs:label 'Actual Air Time' ;
    rdfs:comment 'The actual date and time when this ad spot aired, as recorded in the broadcast affidavit. Used for proof of performance and billing reconciliation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affidavitReference rdf:type rdf:Property ;
    rdfs:label 'Affidavit Reference' ;
    rdfs:comment 'Reference to the broadcast affidavit (proof of performance document) that certifies this spot aired as scheduled. Required for billing and advertiser verification.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current billing status of this spot. Tracks the spot through the billing lifecycle from unbilled through payment or dispute resolution.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusSpotFlag rdf:type rdf:Property ;
    rdfs:label 'Bonus Spot Flag' ;
    rdfs:comment 'Indicates whether this spot was provided as a bonus (added value) to the advertiser at no additional charge. Used for revenue recognition and campaign value calculation.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Code identifying the broadcast channel or network where the spot aired (e.g., ABC, NBC, ESPN). Links to channel master data.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpmAmount rdf:type rdf:Property ;
    rdfs:label 'Cpm Amount' ;
    rdfs:comment 'Cost per thousand impressions for this spot. Key pricing metric in advertising sales used to compare efficiency across different placements.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daiFlag rdf:type rdf:Property ;
    rdfs:label 'Dai Flag' ;
    rdfs:comment 'Indicates whether this spot was delivered via Dynamic Ad Insertion technology, allowing personalized ad delivery to different viewers or platforms.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grpValue rdf:type rdf:Property ;
    rdfs:label 'Grp Value' ;
    rdfs:comment 'Gross Rating Point value delivered by this spot. Measures the size of the audience reached relative to the total market population. Sum of all rating points across the campaign.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Impressions Delivered' ;
    rdfs:comment 'Total number of impressions (views) delivered by this spot. Used for performance measurement and billing reconciliation.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'Designated Market Area (DMA) or geographic market code where the spot aired. Used for regional campaign tracking and market-specific pricing.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preemptedFlag rdf:type rdf:Property ;
    rdfs:label 'Preempted Flag' ;
    rdfs:comment 'Indicates whether this spot was preempted (bumped from its scheduled time slot). Preempted spots typically require makegood compensation.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rotationPattern rdf:type rdf:Property ;
    rdfs:label 'Rotation Pattern' ;
    rdfs:comment 'Describes the rotation or sequencing pattern for this spot within the campaign (e.g., ROS - Run of Schedule, fixed position, alternating). Used for inventory management and fulfillment.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledAirDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Air Date' ;
    rdfs:comment 'The date on which this ad spot was scheduled to air. Used for planning and inventory management.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledAirTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Air Time' ;
    rdfs:comment 'The precise date and time when this ad spot was scheduled to air. Includes timezone information for accurate cross-platform scheduling.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:separationRequirement rdf:type rdf:Property ;
    rdfs:label 'Separation Requirement' ;
    rdfs:comment 'Specifies any separation rules for this spot (e.g., competitive separation, minimum time between airings). Ensures advertiser requirements are met.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotRateAmount rdf:type rdf:Property ;
    rdfs:label 'Spot Rate Amount' ;
    rdfs:comment 'The rate charged for this individual spot placement. May differ from the order line rate due to daypart, program, or inventory adjustments.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spotRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Spot Rate Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the spot rate amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotStatus rdf:type rdf:Property ;
    rdfs:label 'Spot Status' ;
    rdfs:comment 'Current lifecycle status of the ad spot. Tracks whether the spot was scheduled, successfully aired, preempted, cancelled, or requires makegood processing.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficLogReference rdf:type rdf:Property ;
    rdfs:label 'Traffic Log Reference' ;
    rdfs:comment 'Reference identifier to the Wide Orbit traffic log entry that scheduled and tracked this spot. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trpValue rdf:type rdf:Property ;
    rdfs:label 'Trp Value' ;
    rdfs:comment 'Target Rating Point value delivered by this spot. Measures audience reach within a specific demographic target segment, more precise than GRP.' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodId rdf:type rdf:Property ;
    rdfs:label 'Makegood Id' ;
    rdfs:comment 'Primary key for makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:makegoodOriginalChannelId rdf:type rdf:Property ;
    rdfs:label 'Makegood Original Channel Id' ;
    rdfs:comment 'Reference to the channel on which the original ad spot was scheduled to air.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:makegoodProposedChannelId rdf:type rdf:Property ;
    rdfs:label 'Makegood Proposed Channel Id' ;
    rdfs:comment 'Reference to the channel on which the makegood replacement spot is proposed to air.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:proposedScheduleSlotId rdf:type rdf:Property ;
    rdfs:label 'Proposed Schedule Slot Id' ;
    rdfs:comment 'Foreign key linking to scheduling.schedule_slot. Business justification: Makegood resolution requires reserving a specific replacement schedule slot. Traffic systems must link the proposed makegood to an actual slot to confirm availability and prevent double-booking. Role ' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleSlot .

ind:actualAirDate rdf:type rdf:Property ;
    rdfs:label 'Actual Air Date' ;
    rdfs:comment 'The date on which the makegood replacement spot actually aired, confirming fulfillment.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affidavitDate rdf:type rdf:Property ;
    rdfs:label 'Affidavit Date' ;
    rdfs:comment 'The date on which the affidavit for the makegood spot was generated and issued.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affidavitGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Affidavit Generated Flag' ;
    rdfs:comment 'Indicates whether a proof-of-broadcast affidavit has been generated for the aired makegood spot.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:makegoodNumber rdf:type rdf:Property ;
    rdfs:label 'Makegood Number' ;
    rdfs:comment 'Business identifier for the makegood record, used in external communications and affidavits.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalActualGrp rdf:type rdf:Property ;
    rdfs:label 'Original Actual Grp' ;
    rdfs:comment 'The actual GRP delivered by the original spot if it aired but underperformed, triggering a ratings shortfall makegood.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalContractedGrp rdf:type rdf:Property ;
    rdfs:label 'Original Contracted Grp' ;
    rdfs:comment 'The GRP value that was contracted for the original ad spot, used to assess audience underdelivery.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalDaypart rdf:type rdf:Property ;
    rdfs:label 'Original Daypart' ;
    rdfs:comment 'The broadcast daypart (time segment) in which the original spot was scheduled, such as Prime, Early Fringe, Late Night.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Original Scheduled Date' ;
    rdfs:comment 'The date on which the original ad spot was scheduled to air before the failure occurred.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalScheduledTime rdf:type rdf:Property ;
    rdfs:label 'Original Scheduled Time' ;
    rdfs:comment 'The precise timestamp at which the original ad spot was scheduled to air.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalSpotLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Original Spot Length Seconds' ;
    rdfs:comment 'The duration in seconds of the original ad spot that failed to air.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalSpotRate rdf:type rdf:Property ;
    rdfs:label 'Original Spot Rate' ;
    rdfs:comment 'The contracted rate (in USD) for the original ad spot that failed to air.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedDaypart rdf:type rdf:Property ;
    rdfs:label 'Proposed Daypart' ;
    rdfs:comment 'The broadcast daypart proposed for the makegood replacement spot.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedEstimatedGrp rdf:type rdf:Property ;
    rdfs:label 'Proposed Estimated Grp' ;
    rdfs:comment 'The estimated GRP that the proposed makegood replacement spot is expected to deliver.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedReplacementDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Replacement Date' ;
    rdfs:comment 'The date proposed by the broadcaster for airing the makegood replacement spot.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedReplacementTime rdf:type rdf:Property ;
    rdfs:label 'Proposed Replacement Time' ;
    rdfs:comment 'The precise timestamp proposed for airing the makegood replacement spot.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proposedSpotLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Proposed Spot Length Seconds' ;
    rdfs:comment 'The duration in seconds of the proposed makegood replacement spot.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current lifecycle status of the makegood record, tracking whether it has been fulfilled or remains outstanding.' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySalesRepId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Rep Id' ;
    rdfs:comment 'Reference to the sales account executive responsible for this proposal and the advertiser relationship.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:acceptedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Accepted Timestamp' ;
    rdfs:comment 'Timestamp when the proposal was accepted by the advertiser or agency. Null if not yet accepted or if rejected.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:agencyCommissionPercentage rdf:type rdf:Property ;
    rdfs:label 'Agency Commission Percentage' ;
    rdfs:comment 'Agency commission percentage to be paid to the agency from the gross proposal value. Typically 15% in the industry. Null if direct advertiser buy.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audienceGuaranteeFlag rdf:type rdf:Property ;
    rdfs:label 'Audience Guarantee Flag' ;
    rdfs:comment 'Indicates whether the proposal includes an audience delivery guarantee with makegood provisions if targets are not met.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:campaignEndDate rdf:type rdf:Property ;
    rdfs:label 'Campaign End Date' ;
    rdfs:comment 'Proposed end date for the advertising campaign covered by this proposal.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignStartDate rdf:type rdf:Property ;
    rdfs:label 'Campaign Start Date' ;
    rdfs:comment 'Proposed start date for the advertising campaign covered by this proposal.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationTerms rdf:type rdf:Property ;
    rdfs:label 'Cancellation Terms' ;
    rdfs:comment 'Terms and conditions for cancellation of the proposal or resulting order, including notice periods and penalties.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelMixSummary rdf:type rdf:Property ;
    rdfs:label 'Channel Mix Summary' ;
    rdfs:comment 'High-level summary of the proposed channel distribution (e.g., 60% Linear TV, 30% OTT, 10% Digital). Detailed channel breakdown is in proposal line items.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveSituation rdf:type rdf:Property ;
    rdfs:label 'Competitive Situation' ;
    rdfs:comment 'Internal notes on competitive dynamics, other bidders, and strategic positioning for this proposal.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentAdjacencyPreferences rdf:type rdf:Property ;
    rdfs:label 'Content Adjacency Preferences' ;
    rdfs:comment 'Client-specified preferences or restrictions for content types adjacent to ad placements (e.g., sports, news, drama, avoid violent content).' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartMixSummary rdf:type rdf:Property ;
    rdfs:label 'Daypart Mix Summary' ;
    rdfs:comment 'High-level summary of the proposed daypart distribution (e.g., 40% Prime, 30% Early Fringe, 20% Late Night, 10% Weekend). Detailed daypart breakdown is in proposal line items.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demographicTarget rdf:type rdf:Property ;
    rdfs:label 'Demographic Target' ;
    rdfs:comment 'Primary audience demographic segment targeted by this proposal, expressed in standard Nielsen notation (e.g., Adults 25-54, Women 18-49).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedImpressions rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Impressions' ;
    rdfs:comment 'Minimum number of impressions contractually guaranteed to be delivered, triggering makegood obligations if underdelivered.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netProposedValue rdf:type rdf:Property ;
    rdfs:label 'Net Proposed Value' ;
    rdfs:comment 'Net revenue value of the proposal after discounts and agency commissions. This is the expected revenue to the broadcaster.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposalDate rdf:type rdf:Property ;
    rdfs:label 'Proposal Date' ;
    rdfs:comment 'Date when the proposal was created and issued to the advertiser or agency.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposalDescription rdf:type rdf:Property ;
    rdfs:label 'Proposal Description' ;
    rdfs:comment 'Detailed narrative description of the proposal, including campaign objectives, creative strategy, and value proposition.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalName rdf:type rdf:Property ;
    rdfs:label 'Proposal Name' ;
    rdfs:comment 'Descriptive name or title of the proposal, typically reflecting the campaign or client name.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalNumber rdf:type rdf:Property ;
    rdfs:label 'Proposal Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the proposal, used in client communications and internal tracking.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalSource rdf:type rdf:Property ;
    rdfs:label 'Proposal Source' ;
    rdfs:comment 'Origin or trigger for this proposal: response to RFP (request for proposal), proactive sales pitch, contract renewal, upsell to existing client, or cross-sell of additional services.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalStatus rdf:type rdf:Property ;
    rdfs:label 'Proposal Status' ;
    rdfs:comment 'Current lifecycle status of the advertising proposal in the sales workflow.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalType rdf:type rdf:Property ;
    rdfs:label 'Proposal Type' ;
    rdfs:comment 'Category of commercial offer: advertising (spot sales), content licensing (rights acquisition), syndication (content resale), distribution (carriage agreements), sponsorship (branded integration), or upfront (advance commitment).' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedFrequency rdf:type rdf:Property ;
    rdfs:label 'Proposed Frequency' ;
    rdfs:comment 'Proposed average frequency (number of times) that each reached individual in the target audience will be exposed to the campaign. Frequency = GRP / Reach.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedGrp rdf:type rdf:Property ;
    rdfs:label 'Proposed Grp' ;
    rdfs:comment 'Total Gross Rating Points (GRP) proposed to be delivered across all dayparts and channels. GRP measures the total exposure weight of the campaign.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedImpressions rdf:type rdf:Property ;
    rdfs:label 'Proposed Impressions' ;
    rdfs:comment 'Total number of impressions (ad views) proposed to be delivered across all channels and platforms in this campaign.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedReach rdf:type rdf:Property ;
    rdfs:label 'Proposed Reach' ;
    rdfs:comment 'Proposed reach as a percentage of the target audience that will be exposed to the campaign at least once. Reach measures unique audience coverage.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedTrp rdf:type rdf:Property ;
    rdfs:label 'Proposed Trp' ;
    rdfs:comment 'Total Target Rating Points (TRP) proposed to be delivered to the specific demographic target audience. TRP measures exposure within the target demo only.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejected Timestamp' ;
    rdfs:comment 'Timestamp when the proposal was rejected by the advertiser or agency. Null if not rejected.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Requested or required date by which the client should provide a decision or response to the proposal.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spotLengthMixSummary rdf:type rdf:Property ;
    rdfs:label 'Spot Length Mix Summary' ;
    rdfs:comment 'High-level summary of the proposed spot length distribution (e.g., 80% :30s, 15% :15s, 5% :60s). Detailed spot length breakdown is in proposal line items.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'Date when the proposal was formally submitted to the client or agency for review.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Timestamp when the proposal was formally submitted to the advertiser or agency. Null if still in draft status.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Legal and commercial terms governing the proposal, including payment terms, cancellation policies, makegood provisions, and liability clauses.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalProposedValue rdf:type rdf:Property ;
    rdfs:label 'Total Proposed Value' ;
    rdfs:comment 'Total gross revenue value of the proposal in the base currency, before any discounts or agency commissions. Sum of all proposed line items.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:winProbabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Win Probability Percent' ;
    rdfs:comment 'Sales team estimated probability of winning this proposal, expressed as a percentage (0-100).' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audienceGuaranteeGrp rdf:type rdf:Property ;
    rdfs:label 'Audience Guarantee Grp' ;
    rdfs:comment 'Total Gross Rating Points (GRP) guaranteed to the advertiser across all flights and dayparts in this deal. GRP = Reach × Frequency, representing the total audience delivery commitment.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audienceGuaranteeImpressions rdf:type rdf:Property ;
    rdfs:label 'Audience Guarantee Impressions' ;
    rdfs:comment 'Total number of ad impressions guaranteed to the advertiser. Alternative or complementary metric to GRP, especially for digital and cross-platform deals.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationOptionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Cancellation Option Window Days' ;
    rdfs:comment 'Number of days before flight start date within which the advertiser may cancel or reduce the commitment without penalty. Common in upfront deals to provide flexibility.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelMix rdf:type rdf:Property ;
    rdfs:label 'Channel Mix' ;
    rdfs:comment 'Comma-separated list or description of broadcast channels, networks, or platforms included in this deal (e.g., Network Prime, Cable Bundle, OTT Streaming). Defines the inventory scope.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Date' ;
    rdfs:comment 'Date when the advertiser or agency verbally or formally committed to the deal terms. Nullable until commitment is secured.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cprpRate rdf:type rdf:Property ;
    rdfs:label 'Cprp Rate' ;
    rdfs:comment 'Cost per rating point for CPRP-based deals. Nullable if pricing basis is not CPRP. Represents the unit price per GRP delivered.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealYear rdf:type rdf:Property ;
    rdfs:label 'Deal Year' ;
    rdfs:comment 'Broadcast year for which this upfront deal applies, typically representing the September-to-August broadcast season (e.g., 2024 for 2024-2025 season). Critical for upfront planning and inventory allocation.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date when the deal contract was fully executed (signed by all parties). Nullable until contract is finalized.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makegoodProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Provision Flag' ;
    rdfs:comment 'Indicates whether the deal includes makegood provisions for audience delivery shortfalls. True = makegoods required if guaranteed audience is not delivered; False = no makegood obligation.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiationRoundCount rdf:type rdf:Property ;
    rdfs:label 'Negotiation Round Count' ;
    rdfs:comment 'Number of formal negotiation rounds or proposal revisions submitted during the deal lifecycle. Tracks negotiation complexity and sales effort.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingBasis rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis' ;
    rdfs:comment 'Pricing model used for this deal. CPM (Cost Per Mille) = cost per thousand impressions; CPRP (Cost Per Rating Point) = cost per GRP point; Flat Rate = fixed fee regardless of delivery; Performance = outcome-based pricing.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceOpportunityReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Reference' ;
    rdfs:comment 'External reference to the corresponding Salesforce Media Cloud Opportunity record. Enables cross-system traceability between the deal negotiation (Salesforce) and trafficking/billing (Wide Orbit).' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scatterConversionRights rdf:type rdf:Property ;
    rdfs:label 'Scatter Conversion Rights' ;
    rdfs:comment 'Indicates whether the advertiser has the right to convert unused upfront commitment into scatter market inventory at preferential rates. True = conversion allowed; False = no conversion rights.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCommittedSpend rdf:type rdf:Property ;
    rdfs:label 'Total Committed Spend' ;
    rdfs:comment 'Total dollar value of advertising spend committed by the advertiser after negotiation. Nullable until commitment is secured. This is the final agreed revenue amount.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProposedSpend rdf:type rdf:Property ;
    rdfs:label 'Total Proposed Spend' ;
    rdfs:comment 'Total dollar value of advertising spend proposed in the initial deal submission. Represents the gross revenue opportunity before negotiation adjustments.' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedGrp rdf:type rdf:Property ;
    rdfs:label 'Contracted Grp' ;
    rdfs:comment 'The guaranteed Gross Rating Point (GRP) delivery target contractually committed to the advertiser for the specified demographic.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedImpressions rdf:type rdf:Property ;
    rdfs:label 'Contracted Impressions' ;
    rdfs:comment 'The guaranteed number of impressions committed to the advertiser for the campaign period.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedTrp rdf:type rdf:Property ;
    rdfs:label 'Contracted Trp' ;
    rdfs:comment 'The guaranteed Target Rating Point (TRP) delivery target for the specific demographic audience segment.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredGrp rdf:type rdf:Property ;
    rdfs:label 'Delivered Grp' ;
    rdfs:comment 'The actual Gross Rating Point (GRP) delivered to date as measured by Nielsen or other audience measurement provider.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredImpressions rdf:type rdf:Property ;
    rdfs:label 'Delivered Impressions' ;
    rdfs:comment 'The actual number of impressions delivered to date as measured by the audience measurement system.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveredTrp rdf:type rdf:Property ;
    rdfs:label 'Delivered Trp' ;
    rdfs:comment 'The actual Target Rating Point (TRP) delivered to date for the specified demographic segment.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryPercentage rdf:type rdf:Property ;
    rdfs:label 'Delivery Percentage' ;
    rdfs:comment 'The percentage of the contracted guarantee that has been delivered, calculated as (delivered / contracted) * 100.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryVarianceGrp rdf:type rdf:Property ;
    rdfs:label 'Delivery Variance Grp' ;
    rdfs:comment 'The difference between contracted and delivered GRP, calculated as delivered minus contracted (negative indicates underdelivery).' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Guarantee Period End Date' ;
    rdfs:comment 'The end date of the period during which the audience guarantee applies.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Guarantee Period Start Date' ;
    rdfs:comment 'The start date of the period during which the audience guarantee applies.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMeasurementDate rdf:type rdf:Property ;
    rdfs:label 'Last Measurement Date' ;
    rdfs:comment 'The date of the most recent audience measurement update used to calculate delivery performance.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makegoodGrpOwed rdf:type rdf:Property ;
    rdfs:label 'Makegood Grp Owed' ;
    rdfs:comment 'The amount of GRP that must be delivered through makegood spots to fulfill the guarantee obligation.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Required Flag' ;
    rdfs:comment 'Indicates whether makegood spots are required due to underdelivery against the guarantee.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'The audience measurement provider or system used to track delivery against the guarantee (e.g., Nielsen, Comscore).' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkStationCode rdf:type rdf:Property ;
    rdfs:label 'Network Station Code' ;
    rdfs:comment 'The broadcast network or station identifier where the guaranteed audience delivery is measured.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextEvaluationDate rdf:type rdf:Property ;
    rdfs:label 'Next Evaluation Date' ;
    rdfs:comment 'The scheduled date for the next evaluation of guarantee delivery performance.' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:underdeliveryThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Underdelivery Threshold Percentage' ;
    rdfs:comment 'The contractual threshold percentage below which underdelivery triggers makegood or credit obligations (e.g., 95% means delivery below 95% triggers makegoods).' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressionDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Impression Delivery Id' ;
    rdfs:comment 'Unique identifier for the digital or streaming advertising impression delivery record.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:browserType rdf:type rdf:Property ;
    rdfs:label 'Browser Type' ;
    rdfs:comment 'Web browser used to view the impression, if applicable.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnDeliveryConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Cdn Delivery Confirmed Flag' ;
    rdfs:comment 'Boolean flag indicating whether the CDN confirmed successful delivery of the impression.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdnNodeReference rdf:type rdf:Property ;
    rdfs:label 'Cdn Node Reference' ;
    rdfs:comment 'Identifier of the CDN edge node that delivered the impression.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickThroughRatePercent rdf:type rdf:Property ;
    rdfs:label 'Click Through Rate Percent' ;
    rdfs:comment 'Percentage of impressions that resulted in a click-through, calculated as click-throughs divided by total impressions served.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clickThroughs rdf:type rdf:Property ;
    rdfs:label 'Click Throughs' ;
    rdfs:comment 'Number of times viewers clicked on the ad to visit the advertiser\'s destination.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completedViews rdf:type rdf:Property ;
    rdfs:label 'Completed Views' ;
    rdfs:comment 'Number of impressions where the viewer watched the ad to completion.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Completion Rate Percent' ;
    rdfs:comment 'Percentage of impressions that were viewed to completion, calculated as completed views divided by total impressions served.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpmRealized rdf:type rdf:Property ;
    rdfs:label 'Cpm Realized' ;
    rdfs:comment 'Actual cost per thousand impressions realized for this delivery event.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Exact date and time when the impression was delivered to the viewer.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geoTargetCode rdf:type rdf:Property ;
    rdfs:label 'Geo Target Code' ;
    rdfs:comment 'ISO country or region code representing the geographic targeting applied to this impression.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionTrackingUrl rdf:type rdf:Property ;
    rdfs:label 'Impression Tracking Url' ;
    rdfs:comment 'URL used to track and verify the impression delivery event.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insertionStatus rdf:type rdf:Property ;
    rdfs:label 'Insertion Status' ;
    rdfs:comment 'Status indicating whether the ad was successfully inserted, a fallback was used, or no ad was available.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insertionType rdf:type rdf:Property ;
    rdfs:label 'Insertion Type' ;
    rdfs:comment 'Technical method used to insert the ad into the content stream or page. [ENUM-REF-CANDIDATE: DAI|SCTE-35|Server-Side|Client-Side|Display|Pre-Roll|Mid-Roll|Post-Roll — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'Operating system of the device that received the impression.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Amount' ;
    rdfs:comment 'Total revenue generated from this impression delivery event.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thirdPartyVerificationSource rdf:type rdf:Property ;
    rdfs:label 'Third Party Verification Source' ;
    rdfs:comment 'Name of the third-party verification service that validated this impression delivery.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalImpressionsServed rdf:type rdf:Property ;
    rdfs:label 'Total Impressions Served' ;
    rdfs:comment 'Total number of impressions delivered in this event.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:viewabilityRatePercent rdf:type rdf:Property ;
    rdfs:label 'Viewability Rate Percent' ;
    rdfs:comment 'Percentage of impressions that met viewability standards, calculated as viewable impressions divided by total impressions served.' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewableImpressions rdf:type rdf:Property ;
    rdfs:label 'Viewable Impressions' ;
    rdfs:comment 'Number of impressions that met the IAB viewability standard (50% of pixels in view for 2+ seconds for display, 50% for 2+ seconds for video).' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentPartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Content Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Sponsorships require tracking the content partner (network, producer, syndicator) delivering the sponsored property, distinct from the agency. Real business process: sponsorship fulfillment verificati' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:billboardCount rdf:type rdf:Property ;
    rdfs:label 'Billboard Count' ;
    rdfs:comment 'Number of billboard mentions or placements included in the sponsorship package.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryExclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Category Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the sponsor has category exclusivity rights for the sponsored content.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliverablesDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverables Description' ;
    rdfs:comment 'Detailed description of sponsorship deliverables including billboards, opens/closes, product integration, logo placement, mentions, and other sponsor benefits.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveCategory rdf:type rdf:Property ;
    rdfs:label 'Exclusive Category' ;
    rdfs:comment 'Product or service category for which the sponsor holds exclusivity rights (e.g., automotive, telecommunications, financial services).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityTerms rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Terms' ;
    rdfs:comment 'Description of category exclusivity provisions preventing competing sponsors within the same product or service category.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Percentage' ;
    rdfs:comment 'Percentage of sponsorship deliverables that have been completed and delivered to the sponsor.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:logoPlacementFlag rdf:type rdf:Property ;
    rdfs:label 'Logo Placement Flag' ;
    rdfs:comment 'Indicates whether sponsor logo placement is included in the deliverables.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Product Integration Flag' ;
    rdfs:comment 'Indicates whether product integration within content is part of the sponsorship agreement.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsoredContentType rdf:type rdf:Property ;
    rdfs:label 'Sponsored Content Type' ;
    rdfs:comment 'Type of content being sponsored (program, series, event, segment, etc.).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipCode rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Code' ;
    rdfs:comment 'Business identifier or code for the sponsorship deal used in trafficking and billing systems.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipName rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Name' ;
    rdfs:comment 'Descriptive name of the sponsorship deal for business reference and reporting.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipStatus rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Status' ;
    rdfs:comment 'Current lifecycle status of the sponsorship deal. [ENUM-REF-CANDIDATE: draft|proposed|negotiating|approved|active|fulfilled|cancelled|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipType rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Type' ;
    rdfs:comment 'Classification of the sponsorship arrangement indicating the level and nature of sponsor integration.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueAmount rdf:type rdf:Property ;
    rdfs:label 'Value Amount' ;
    rdfs:comment 'Total monetary value of the sponsorship deal.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionPolicyId rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.retention_policy. Business justification: media_asset.retention_policy_code is a denormalized STRING code referencing the retention_policy table. Each media asset is governed by a retention policy that determines its lifecycle, storage tier, ' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionPolicy .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'Classification of the asset based on its production workflow stage and quality level. Raw=unprocessed camera footage, Mezzanine=high-quality intermediate, Proxy=low-res preview, Archive=long-term preservation, Master=final approved version.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTitle rdf:type rdf:Property ;
    rdfs:label 'Asset Title' ;
    rdfs:comment 'Primary human-readable title or name of the media asset. Used for search, cataloging, and display in MAM interfaces.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Primary media type classification of the digital object. Determines handling, playback, and workflow routing in the MAM system. [ENUM-REF-CANDIDATE: video|audio|image|graphics|document|subtitle|caption — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bitRateMbps rdf:type rdf:Property ;
    rdfs:label 'Bit Rate Mbps' ;
    rdfs:comment 'Average bit rate of the encoded media in megabits per second. Indicates quality level and bandwidth requirements for streaming and playout.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checksumSha256 rdf:type rdf:Property ;
    rdfs:label 'Checksum Sha256' ;
    rdfs:comment 'SHA-256 cryptographic hash for enhanced integrity verification and chain-of-custody audit trails. Required for regulatory compliance and legal hold.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codec rdf:type rdf:Property ;
    rdfs:label 'Codec' ;
    rdfs:comment 'Video or audio compression codec used for encoding (e.g., H.264, H.265/HEVC, ProRes, DNxHD, AAC, PCM). Critical for quality assessment and transcoding decisions.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentClassification rdf:type rdf:Property ;
    rdfs:label 'Content Classification' ;
    rdfs:comment 'Business classification tags for content categorization (e.g., news, sports, drama, documentary, commercial, promo). Supports search, rights management, and workflow routing. Pipe-separated list for multiple classifications.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingest Timestamp' ;
    rdfs:comment 'Date and time when the asset was first ingested into the MAM system. Marks the beginning of the assets lifecycle in the enterprise repository.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastAccessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Accessed Timestamp' ;
    rdfs:comment 'Date and time of the most recent access or playback of the asset. Used for storage tier optimization and usage analytics.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicates whether the asset is under legal hold and must not be modified or deleted. Overrides retention policies until hold is released.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the asset in its operational lifecycle. Tracks progression from ingest through quality control, active use, archival, and eventual purge. Drives workflow automation and access control. [ENUM-REF-CANDIDATE: ingest|qc_pending|qc_approved|qc_rejected|available|in_use|archived|purged|quarantined — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingSystem rdf:type rdf:Property ;
    rdfs:label 'Originating System' ;
    rdfs:comment 'Source system or device that created or ingested the asset (e.g., camera model, editing suite, ingest station, external vendor). Provides provenance for chain-of-custody tracking.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Completed Timestamp' ;
    rdfs:comment 'Date and time when quality control review was completed. Null if QC is pending or not required.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qcOperator rdf:type rdf:Property ;
    rdfs:label 'Qc Operator' ;
    rdfs:comment 'User ID or name of the operator who performed quality control review. Used for accountability and audit trails.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsRestriction rdf:type rdf:Property ;
    rdfs:label 'Rights Restriction' ;
    rdfs:comment 'Rights and usage restrictions governing distribution and use of the asset. Enforces compliance with licensing agreements, territorial restrictions, and legal holds.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationUri rdf:type rdf:Property ;
    rdfs:label 'Storage Location Uri' ;
    rdfs:comment 'Full URI path to the physical storage location of the media file (e.g., s3://bucket/path, file://server/share/path). Used by MAM for retrieval and playout automation.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTier rdf:type rdf:Property ;
    rdfs:label 'Storage Tier' ;
    rdfs:comment 'Current storage tier assignment based on access frequency and retention policy. Hot=online high-performance, Warm=nearline, Cold=offline tape, Deep-archive=long-term preservation, Glacier=regulatory hold.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timecodeStart rdf:type rdf:Property ;
    rdfs:label 'Timecode Start' ;
    rdfs:comment 'SMPTE timecode of the first frame in HH:MM:SS:FF format. Essential for frame-accurate editing and playout synchronization.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:umid rdf:type rdf:Property ;
    rdfs:label 'Umid' ;
    rdfs:comment 'SMPTE 330M globally unique identifier for the media essence. 64-character hexadecimal string providing universal identification across systems and organizations.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Delivery Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Specific versions may be delivered by different partners (e.g., international dub from foreign partner, localized version from regional distributor). Tracks provenance for quality issues, delivery acc' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:abrLadderRung rdf:type rdf:Property ;
    rdfs:label 'Abr Ladder Rung' ;
    rdfs:comment 'Position in the ABR ladder for HLS or DASH streaming (e.g., 1 for lowest quality, 5 for highest). Enables adaptive streaming based on viewer bandwidth. Null if not part of an ABR ladder.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checksumAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Checksum Algorithm' ;
    rdfs:comment 'Algorithm used to generate the checksum value (MD5, SHA-256, SHA-512). Identifies the hashing method for integrity verification.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumValue rdf:type rdf:Property ;
    rdfs:label 'Checksum Value' ;
    rdfs:comment 'Cryptographic hash (MD5 or SHA-256) of the file content. Ensures integrity verification, detects corruption during transfer or storage, and supports chain-of-custody audit trails for legal hold and regulatory compliance.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drmProtection rdf:type rdf:Property ;
    rdfs:label 'Drm Protection' ;
    rdfs:comment 'Indicates whether this version is protected by DRM encryption (True/False). DRM systems include Widevine, PlayReady, FairPlay. Supports content security and anti-piracy.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proxyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Proxy Expiry Date' ;
    rdfs:comment 'Date when this proxy or preview version expires and should be purged from storage. Applicable only when rendition_purpose is proxy or preview. Supports storage cost optimization and compliance with retention policies.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renditionPurpose rdf:type rdf:Property ;
    rdfs:label 'Rendition Purpose' ;
    rdfs:comment 'Business purpose or use case for this version: playout (broadcast transmission), distribution (delivery to platforms), archive (long-term preservation), preview (review/approval), proxy (low-res editing), watermark (forensic tracking), mezzanine (high-quality master), localized_dub (language variant), thumbnail (visual reference). [ENUM-REF-CANDIDATE: playout|distribution|archive|preview|proxy|watermark|mezzanine|localized_dub|thumbnail — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionHeight rdf:type rdf:Property ;
    rdfs:label 'Resolution Height' ;
    rdfs:comment 'Vertical resolution of the video frame in pixels (e.g., 1080 for 1080p, 2160 for 4K). Used for format classification and quality assessment.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionWidth rdf:type rdf:Property ;
    rdfs:label 'Resolution Width' ;
    rdfs:comment 'Horizontal resolution of the video frame in pixels (e.g., 1920 for 1080p, 3840 for 4K). Used for format classification and quality assessment.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageUri rdf:type rdf:Property ;
    rdfs:label 'Storage Uri' ;
    rdfs:comment 'Full storage path or URI where this version is physically stored (e.g., s3://bucket/path, file://nas/volume/path, https://cdn.example.com/asset). Supports multi-tier storage (hot/warm/cold/archive) and CDN distribution via Akamai.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleTracks rdf:type rdf:Property ;
    rdfs:label 'Subtitle Tracks' ;
    rdfs:comment 'Comma-separated list of ISO 639-2 language codes for embedded subtitle or closed caption tracks (e.g., eng,spa,fra). Supports accessibility compliance (COPPA, FCC) and multi-language distribution.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validated Timestamp' ;
    rdfs:comment 'Timestamp when this version passed quality control (QC) validation and was approved for use. Null if validation is pending or failed.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:watermarkPayload rdf:type rdf:Property ;
    rdfs:label 'Watermark Payload' ;
    rdfs:comment 'Forensic watermark identifier or payload embedded in this version for anti-piracy tracking and content protection. Applicable only when rendition_purpose is watermark. Supports DRM (Digital Rights Management) and content security.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Created Asset Version Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_version. Business justification: Ingest job creates a specific version (typically the mezzanine or raw master). This FK links the ingest job to the version it produced. Populated upon successful ingest completion.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:sourcePartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Source Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Content ingested from partner feeds (satellite, FTP, aspera) requires tracking source partner for SLA compliance monitoring, billing reconciliation, delivery acceptance workflows, and automated partne' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:targetStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Target Storage Location Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.storage_location. Business justification: ingest_job.target_storage_location is a free-text STRING URI referencing the destination storage location. Normalizing this to a FK (target_storage_location_id → storage_location.storage_location_id) ' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:bytesTransferred rdf:type rdf:Property ;
    rdfs:label 'Bytes Transferred' ;
    rdfs:comment 'Total number of bytes successfully transferred during the ingest operation. Used for capacity planning and performance monitoring.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedCaptionPresent rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Present' ;
    rdfs:comment 'Indicates whether closed captions or subtitles are embedded in the ingested media. Required for FCC accessibility compliance validation.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingestEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingest End Timestamp' ;
    rdfs:comment 'Timestamp when the ingest job completed or terminated. Null for jobs still in progress.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ingestSourceType rdf:type rdf:Property ;
    rdfs:label 'Ingest Source Type' ;
    rdfs:comment 'Classification of the media source from which content is being ingested. Determines handling protocols and validation rules.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingest Start Timestamp' ;
    rdfs:comment 'Timestamp when the ingest job began processing. Represents the actual start of media transfer, not the queued time.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:jobNumber rdf:type rdf:Property ;
    rdfs:label 'Job Number' ;
    rdfs:comment 'Human-readable business identifier for the ingest job, typically formatted as prefix-date-sequence (e.g., ING-20240115-0042). Used for operational tracking and reference.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobStatus rdf:type rdf:Property ;
    rdfs:label 'Job Status' ;
    rdfs:comment 'Current lifecycle status of the ingest job. Tracks progression from queued through execution to final disposition.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFormat rdf:type rdf:Property ;
    rdfs:label 'Source Format' ;
    rdfs:comment 'Technical format of the source media file or stream (e.g., MPEG-4, ProRes, MXF, H.264). Used for transcode planning and compatibility validation.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLocation rdf:type rdf:Property ;
    rdfs:label 'Source Location' ;
    rdfs:comment 'Physical or logical location of the source media. May be a tape ID, file path, URL, satellite transponder identifier, or cloud storage bucket path.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFormat rdf:type rdf:Property ;
    rdfs:label 'Target Format' ;
    rdfs:comment 'Desired output format for the ingested media. May differ from source format if transcoding is required during ingest.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferRateMbps rdf:type rdf:Property ;
    rdfs:label 'Transfer Rate Mbps' ;
    rdfs:comment 'Average data transfer rate achieved during ingest, measured in megabits per second. Key performance indicator for ingest infrastructure.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Output Storage Location Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.storage_location. Business justification: transcode_job.output_storage_uri is a free-text STRING URI referencing the destination storage location for transcoded output. Normalizing to a FK (output_storage_location_id → storage_location.storag' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:targetFormatSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Target Format Specification Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.format_specification. Business justification: Normalization: transcode job targets an approved format specification from the catalog. The target_format_specification STRING attribute becomes a FK. Format details retrieved via JOIN.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormatSpecification .

ind:transcodingVendorPartnerId rdf:type rdf:Property ;
    rdfs:label 'Transcoding Vendor Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Transcoding is frequently outsourced to specialist vendors (e.g., Telestream, Encoding.com). Studios track which vendor performed each transcode job for SLA compliance, cost allocation against vendor ' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:abrLadderConfiguration rdf:type rdf:Property ;
    rdfs:label 'Abr Ladder Configuration' ;
    rdfs:comment 'Configuration specification for ABR ladder generation, defining the set of bitrate/resolution variants to be created for adaptive streaming (e.g., 240p@400kbps, 360p@800kbps, 480p@1.2Mbps, 720p@2.5Mbps, 1080p@5Mbps). Applicable when job_type is abr_ladder_generation.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codecParameters rdf:type rdf:Property ;
    rdfs:label 'Codec Parameters' ;
    rdfs:comment 'Detailed codec encoding parameters including profile, level, GOP structure, B-frames, reference frames, and other encoder-specific settings (e.g., x264 preset=medium, crf=23, profile=high, level=4.1).' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Usd' ;
    rdfs:comment 'Estimated processing cost in US dollars for this transcode job, based on compute time, storage, and resource utilization. Used for chargeback and budget tracking.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobPriority rdf:type rdf:Property ;
    rdfs:label 'Job Priority' ;
    rdfs:comment 'Processing priority level for the transcode job, determining queue position and resource allocation. Critical jobs are processed immediately, batch jobs during off-peak hours.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobType rdf:type rdf:Property ;
    rdfs:label 'Job Type' ;
    rdfs:comment 'Classification of the transcode operation: standard transcode for routine format conversion, ABR (Adaptive Bitrate) ladder generation for streaming, proxy creation for editing workflows, delivery package preparation for distribution, or format migration for obsolescence-driven conversions. [ENUM-REF-CANDIDATE: standard_transcode|abr_ladder_generation|proxy_creation|delivery_package|format_migration|tape_digitization|analogue_to_digital — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationReason rdf:type rdf:Property ;
    rdfs:label 'Migration Reason' ;
    rdfs:comment 'Business justification for format migration jobs. Applicable only when job_type is format_migration, tape_digitization, or analogue_to_digital. Captures whether the conversion is driven by format obsolescence (e.g., MPEG-2 to H.265), storage optimization, distribution requirements, or regulatory compliance. [ENUM-REF-CANDIDATE: format_obsolescence|storage_optimization|distribution_requirement|quality_enhancement|compliance_mandate|archive_preservation|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputChecksum rdf:type rdf:Property ;
    rdfs:label 'Output Checksum' ;
    rdfs:comment 'Cryptographic checksum (MD5, SHA-256, or SHA-512) of the output file for integrity verification and chain-of-custody audit trails.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputFileSizeGb rdf:type rdf:Property ;
    rdfs:label 'Output File Size Gb' ;
    rdfs:comment 'Total file size of the transcoded output in gigabytes. Populated upon job completion.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Processing Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from processing start to completion, used for performance monitoring and capacity planning.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing End Timestamp' ;
    rdfs:comment 'Date and time when the transcoding engine completed or terminated processing of this job.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Start Timestamp' ;
    rdfs:comment 'Date and time when the transcoding engine began processing this job.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityValidationResult rdf:type rdf:Property ;
    rdfs:label 'Quality Validation Result' ;
    rdfs:comment 'Outcome of automated quality validation checks performed on the transcoded output, including video integrity, audio sync, and compliance with target specifications.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityValidationScore rdf:type rdf:Property ;
    rdfs:label 'Quality Validation Score' ;
    rdfs:comment 'Numeric quality score (0-100) assigned by automated validation tools, measuring output fidelity against source and target specifications.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:queueEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Queue Entry Timestamp' ;
    rdfs:comment 'Date and time when the transcode job was submitted to the processing queue.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of times this job has been automatically retried after failure, used to prevent infinite retry loops.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceBitrateMbps rdf:type rdf:Property ;
    rdfs:label 'Source Bitrate Mbps' ;
    rdfs:comment 'Average bitrate of the source asset in megabits per second.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceCodec rdf:type rdf:Property ;
    rdfs:label 'Source Codec' ;
    rdfs:comment 'Video codec of the source asset (e.g., H.264, H.265/HEVC, MPEG-2, ProRes, DNxHD).' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Source Duration Seconds' ;
    rdfs:comment 'Duration of the source media asset in seconds.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceFileSizeGb rdf:type rdf:Property ;
    rdfs:label 'Source File Size Gb' ;
    rdfs:comment 'File size of the source asset in gigabytes.' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceResolution rdf:type rdf:Property ;
    rdfs:label 'Source Resolution' ;
    rdfs:comment 'Video resolution of the source asset in pixels (e.g., 1920x1080, 3840x2160, 1280x720).' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transcodingEngine rdf:type rdf:Property ;
    rdfs:label 'Transcoding Engine' ;
    rdfs:comment 'Name and version of the transcoding engine or software used to perform the conversion (e.g., FFmpeg 5.1.2, AWS Elemental MediaConvert, Dalet Brio).' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Media Asset Version Id' ;
    rdfs:comment 'Reference to the specific version of the media asset that underwent this quality control inspection.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:qcVendorPartnerId rdf:type rdf:Property ;
    rdfs:label 'Qc Vendor Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: QC inspections in media broadcasting are routinely performed by third-party QC vendors (e.g., Deluxe, Technicolor). Operations teams track which vendor passed/failed an asset for SLA management, vendo' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:aspectRatioComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Aspect Ratio Compliance Result' ;
    rdfs:comment 'Result of aspect ratio compliance check. Verifies that video aspect ratio (e.g., 16:9, 4:3, 21:9) matches expected format and Active Format Description (AFD) metadata is correct.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioCodecComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Audio Codec Compliance Result' ;
    rdfs:comment 'Result of audio codec format compliance check. Verifies that audio encoding conforms to expected codec standard (e.g., AAC, Dolby Digital, Dolby Atmos, MPEG-1 Layer II).' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioSyncOffsetMs rdf:type rdf:Property ;
    rdfs:label 'Audio Sync Offset Ms' ;
    rdfs:comment 'Measured audio-to-video synchronization offset in milliseconds. Positive values indicate audio leads video; negative values indicate audio lags video. Null if sync check not performed.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioSyncResult rdf:type rdf:Property ;
    rdfs:label 'Audio Sync Result' ;
    rdfs:comment 'Result of audio-to-video synchronization check. Detects lip-sync errors or audio drift.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackFrameCount rdf:type rdf:Property ;
    rdfs:label 'Black Frame Count' ;
    rdfs:comment 'Total number of black frames detected in the media asset. Zero if none detected.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackFrameDetected rdf:type rdf:Property ;
    rdfs:label 'Black Frame Detected' ;
    rdfs:comment 'Indicates whether unintended black frames (video signal dropout or encoding error) were detected during inspection.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:captionValidationResult rdf:type rdf:Property ;
    rdfs:label 'Caption Validation Result' ;
    rdfs:comment 'Result of closed caption (CEA-608, CEA-708) or subtitle validation check. Verifies presence, format compliance, and synchronization of captions.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDefectCount rdf:type rdf:Property ;
    rdfs:label 'Critical Defect Count' ;
    rdfs:comment 'Number of critical-severity defects that block asset approval for playout or distribution. Critical defects require remediation.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of quality defects detected during inspection. Zero indicates no defects found.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectSummary rdf:type rdf:Property ;
    rdfs:label 'Defect Summary' ;
    rdfs:comment 'Structured JSON or delimited text summary of all detected defects with timecode references, severity levels, and defect type codes. Detailed defect records may be stored in a separate qc_defect child table.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedAspectRatio rdf:type rdf:Property ;
    rdfs:label 'Detected Aspect Ratio' ;
    rdfs:comment 'Actual aspect ratio detected in the video stream (e.g., 16:9, 4:3, 1.85:1, 2.39:1). Null if aspect ratio check not performed.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeFrameCount rdf:type rdf:Property ;
    rdfs:label 'Freeze Frame Count' ;
    rdfs:comment 'Total number of freeze frame incidents detected in the media asset. Zero if none detected.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freezeFrameDetected rdf:type rdf:Property ;
    rdfs:label 'Freeze Frame Detected' ;
    rdfs:comment 'Indicates whether freeze frames (static video for extended duration) were detected during inspection.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdrMetadataValidationResult rdf:type rdf:Property ;
    rdfs:label 'Hdr Metadata Validation Result' ;
    rdfs:comment 'Result of High Dynamic Range (HDR) metadata validation check. Verifies presence and correctness of HDR10, HDR10+, Dolby Vision, or HLG metadata. Not applicable for Standard Dynamic Range (SDR) content.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Inspection Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds required to complete the quality control inspection process.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Human-readable business identifier for the inspection record, formatted as QC-YYYYMMDD-NNNNNN.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle state of the quality control inspection process.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when the quality control inspection was performed or completed. Primary business event timestamp.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loudnessComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Loudness Compliance Result' ;
    rdfs:comment 'Result of audio loudness compliance check against regulatory standards (EBU R128 for Europe, ATSC A/85 for North America, ITU-R BS.1770 globally).' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Final pass/fail determination for the quality control inspection. Conditional pass indicates minor issues that do not block playout. Review required indicates human escalation needed.' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcToolName rdf:type rdf:Property ;
    rdfs:label 'Qc Tool Name' ;
    rdfs:comment 'Name and version of the automated quality control software or tool used for inspection (e.g., Baton, Interra, Venera, Dalet QC Module).' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCodecComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Video Codec Compliance Result' ;
    rdfs:comment 'Result of video codec format compliance check. Verifies that video encoding conforms to expected codec standard (e.g., H.264/AVC, H.265/HEVC, MPEG-2, AV1).' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Unique identifier for the storage location within the Media Asset Management (MAM) infrastructure. Primary key.' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:storageVendorPartnerId rdf:type rdf:Property ;
    rdfs:label 'Storage Vendor Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Storage locations are operated by third-party vendors (AWS, Iron Mountain, Spectra Logic). Linking to partner_partner enables vendor contract management, SLA tracking, and cost reconciliation. storage' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:accessProtocol rdf:type rdf:Property ;
    rdfs:label 'Access Protocol' ;
    rdfs:comment 'Network protocol or interface used to access the storage location (NFS = Network File System, SMB = Server Message Block, S3 = Amazon S3 API, SFTP = Secure File Transfer Protocol, iSCSI = Internet Small Computer Systems Interface, Fibre_Channel = FC SAN protocol). [ENUM-REF-CANDIDATE: NFS|SMB|S3|SFTP|iSCSI|Fibre_Channel|HTTP|HTTPS — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCapacityTb rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Tb' ;
    rdfs:comment 'Remaining available storage capacity (total minus used), measured in terabytes (TB). Drives automated alerts and provisioning workflows.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checksumValidationEnabled rdf:type rdf:Property ;
    rdfs:label 'Checksum Validation Enabled' ;
    rdfs:comment 'Indicates whether automated checksum integrity validation is performed on assets stored at this location (True = enabled, False = disabled). Critical for ensuring asset integrity and detecting corruption.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costPerTbPerMonth rdf:type rdf:Property ;
    rdfs:label 'Cost Per Tb Per Month' ;
    rdfs:comment 'Monthly cost per terabyte of storage at this location, used for cost allocation and financial reporting. Includes infrastructure, licensing, and operational costs.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCenterName rdf:type rdf:Property ;
    rdfs:label 'Data Center Name' ;
    rdfs:comment 'Name or identifier of the physical data center or facility housing the storage infrastructure (e.g., \'NYC-DC1\', \'AWS-US-East-1\', \'Azure-WestEurope\').' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionMethod rdf:type rdf:Property ;
    rdfs:label 'Encryption Method' ;
    rdfs:comment 'Encryption algorithm or method applied to data at rest (e.g., \'AES-256\', \'AES-128\', \'RSA-2048\'). Null if encryption is not enabled.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCapacityCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Capacity Check Timestamp' ;
    rdfs:comment 'Timestamp of the most recent capacity measurement or audit for this storage location. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalHoldCapable rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Capable' ;
    rdfs:comment 'Indicates whether this storage location supports legal hold functionality to prevent deletion or modification of assets under litigation or regulatory investigation (True = capable, False = not capable).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mountPoint rdf:type rdf:Property ;
    rdfs:label 'Mount Point' ;
    rdfs:comment 'File system mount point, UNC path, or object storage URI used by MAM systems to access the location (e.g., \'/mnt/production_san\', \'\\\\nas01\\media\', \'s3://bucket-name/prefix\').' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replicationEnabled rdf:type rdf:Property ;
    rdfs:label 'Replication Enabled' ;
    rdfs:comment 'Indicates whether this storage location is replicated to another location for redundancy and disaster recovery (True = replicated, False = not replicated).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restoreTimeObjectiveHours rdf:type rdf:Property ;
    rdfs:label 'Restore Time Objective Hours' ;
    rdfs:comment 'Maximum acceptable time to restore or retrieve assets from this storage location, measured in hours. Critical for disaster recovery and operational planning.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionPolicyDays rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Days' ;
    rdfs:comment 'Default retention period in days for assets stored at this location, after which assets may be migrated or purged per policy. Null if no default retention applies.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageType rdf:type rdf:Property ;
    rdfs:label 'Storage Type' ;
    rdfs:comment 'Classification of the physical or logical storage technology (SAN = Storage Area Network, NAS = Network Attached Storage, LTO_Tape = Linear Tape-Open, Cloud_Object_Storage = S3/Azure Blob/GCS, CDN_Origin = Content Delivery Network origin store, Deep_Archive = long-term cold storage vault).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapacityTb rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Tb' ;
    rdfs:comment 'Total storage capacity of the location measured in terabytes (TB). Used for capacity planning and allocation reporting.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usedCapacityTb rdf:type rdf:Property ;
    rdfs:label 'Used Capacity Tb' ;
    rdfs:comment 'Current amount of storage capacity consumed or allocated, measured in terabytes (TB). Updated periodically to reflect actual usage.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetStorageAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Asset Storage Assignment Id' ;
    rdfs:comment 'Unique identifier for the asset storage assignment record. Primary key for tracking storage placement history.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessFrequency rdf:type rdf:Property ;
    rdfs:label 'Access Frequency' ;
    rdfs:comment 'Number of times this file has been accessed since assignment to this storage location. Used to inform tiering and migration decisions.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'Date when the asset file was migrated, purged, or removed from this storage location. Null if still active at this location.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment End Timestamp' ;
    rdfs:comment 'Precise timestamp when the asset file was migrated, purged, or removed from this storage location. Null if still active.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'Date when the asset file was placed at this storage location. Marks the beginning of the storage assignment period.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the asset file was placed at this storage location. Provides exact time for chain-of-custody audit trails.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Complete file system path or URI where the asset file is physically stored. Enables restore path resolution and file retrieval.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationTrigger rdf:type rdf:Property ;
    rdfs:label 'Migration Trigger' ;
    rdfs:comment 'Reason why the asset was moved to or from this storage location. Captures business or technical driver for storage placement decisions.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replicationCount rdf:type rdf:Property ;
    rdfs:label 'Replication Count' ;
    rdfs:comment 'Number of redundant copies of this file maintained at this storage location. Used for disaster recovery and high availability planning.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageCostPerGb rdf:type rdf:Property ;
    rdfs:label 'Storage Cost Per Gb' ;
    rdfs:comment 'Cost per gigabyte for this storage tier at the time of assignment. Used for storage cost allocation and financial reporting.' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersedesPolicyRetentionPolicyId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Policy Retention Policy Id' ;
    rdfs:comment 'Reference to the previous retention policy that this policy replaces. Null if this is the first version. Supports policy lineage and historical analysis.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionPolicy .

ind:appliesToLegalHold rdf:type rdf:Property ;
    rdfs:label 'Applies To Legal Hold' ;
    rdfs:comment 'Indicates whether this retention policy applies to assets under legal hold. If false, legal hold assets are exempt from automated lifecycle actions governed by this policy.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToSyndicationContent rdf:type rdf:Property ;
    rdfs:label 'Applies To Syndication Content' ;
    rdfs:comment 'Indicates whether this retention policy applies to syndicated content (content resold to multiple outlets). Syndication agreements may impose distinct retention obligations.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetClassScope rdf:type rdf:Property ;
    rdfs:label 'Asset Class Scope' ;
    rdfs:comment 'The category of media assets to which this retention policy applies. Aligns with MAM (Media Asset Management) asset classification in Dalet Galaxy. [ENUM-REF-CANDIDATE: raw|mezzanine|proxy|archive|master|graphics|audio|metadata — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'Checksum Verification Required' ;
    rdfs:comment 'Indicates whether checksum integrity verification is mandatory before executing post-retention actions. Ensures asset integrity throughout the retention lifecycle.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formatMigrationAllowed rdf:type rdf:Property ;
    rdfs:label 'Format Migration Allowed' ;
    rdfs:comment 'Indicates whether format migration (transcoding to newer codecs or containers) is permitted during the retention period. Supports long-term preservation and format obsolescence mitigation.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Retention Period Days' ;
    rdfs:comment 'The maximum number of days an asset may be retained before mandatory action (purge or archive migration). Null indicates indefinite retention.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Retention Period Days' ;
    rdfs:comment 'The minimum number of days an asset must be retained before any deletion or migration action can occur. Enforces regulatory and contractual obligations.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationRecipients rdf:type rdf:Property ;
    rdfs:label 'Notification Recipients' ;
    rdfs:comment 'Comma-separated list of email addresses or role identifiers to be notified when retention actions are triggered (e.g., \'legal@mediabroadcasting.com, content-ops-team\').' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed business description of the retention policy, including rationale, scope, and any special handling instructions.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyOwner rdf:type rdf:Property ;
    rdfs:label 'Policy Owner' ;
    rdfs:comment 'The business role, department, or individual responsible for defining and maintaining this retention policy (e.g., \'Legal & Compliance\', \'Media Operations Director\', \'Chief Content Officer\').' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postRetentionAction rdf:type rdf:Property ;
    rdfs:label 'Post Retention Action' ;
    rdfs:comment 'The action to be taken when the retention period expires. Drives automated lifecycle workflows in MAM (Media Asset Management) systems.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'The regulatory framework, statute, or compliance requirement that mandates or informs this retention policy (e.g., \'FCC 47 CFR 73.1840\', \'Ofcom Section 11\', \'GDPR Article 5\', \'SOX Section 802\', \'Legal Hold Case #12345\').' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionTrigger rdf:type rdf:Property ;
    rdfs:label 'Retention Trigger' ;
    rdfs:comment 'The business event that starts the retention clock for this policy (e.g., when the asset was ingested, when it was first broadcast, when the licensing contract expires, or when a legal hold is placed).' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTierTarget rdf:type rdf:Property ;
    rdfs:label 'Storage Tier Target' ;
    rdfs:comment 'The target storage tier for assets governed by this policy after the retention period. Aligns with tiered storage strategies in MAM (Media Asset Management) and CDN (Content Delivery Network) architectures.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bitRateMode rdf:type rdf:Property ;
    rdfs:label 'Bit Rate Mode' ;
    rdfs:comment 'Encoding bit rate control mode: CBR (Constant Bit Rate), VBR (Variable Bit Rate), or ABR (Average Bit Rate / Adaptive Bitrate Streaming).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date when this format specification is scheduled to be deprecated or retired. Null for formats with no planned end date.' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fileExtension rdf:type rdf:Property ;
    rdfs:label 'File Extension' ;
    rdfs:comment 'Standard file extension for files encoded in this format (e.g., .mxf, .mp4, .mov, .ts, .m3u8).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatCategory rdf:type rdf:Property ;
    rdfs:label 'Format Category' ;
    rdfs:comment 'Classification of the format by its intended use case in the media workflow: ingest (acquisition), mezzanine (high-quality intermediate), proxy (low-res editing), playout (broadcast transmission), OTT delivery (streaming), or archive (long-term preservation).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingStandard rdf:type rdf:Property ;
    rdfs:label 'Governing Standard' ;
    rdfs:comment 'Primary industry or regulatory standard governing this format specification (e.g., ATSC 3.0, DVB-T2, SMPTE ST 2110, ISO/IEC 14496, ITU-R BT.2020).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:horizontalResolution rdf:type rdf:Property ;
    rdfs:label 'Horizontal Resolution' ;
    rdfs:comment 'Horizontal pixel count of the video frame (e.g., 1920 for Full HD, 3840 for UHD).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loudnessStandard rdf:type rdf:Property ;
    rdfs:label 'Loudness Standard' ;
    rdfs:comment 'Audio loudness normalization standard applied (e.g., ITU-R BS.1770-4 LKFS, EBU R128 LUFS, ATSC A/85 for broadcast).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mimeType rdf:type rdf:Property ;
    rdfs:label 'Mime Type' ;
    rdfs:comment 'MIME (Multipurpose Internet Mail Extensions) type for HTTP delivery and content negotiation (e.g., video/mp4, application/mxf, video/MP2T).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcProfile rdf:type rdf:Property ;
    rdfs:label 'Qc Profile' ;
    rdfs:comment 'Quality control validation profile applied to assets in this format, defining automated checks for technical compliance (e.g., video levels, audio loudness, format conformance).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionClass rdf:type rdf:Property ;
    rdfs:label 'Resolution Class' ;
    rdfs:comment 'Video resolution classification: SD (Standard Definition 480/576), HD (720p), FHD (Full HD 1080p), UHD (Ultra HD 2160p), 4K (4096x2160), 8K (7680x4320).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanType rdf:type rdf:Property ;
    rdfs:label 'Scan Type' ;
    rdfs:comment 'Video scanning method: progressive (all lines scanned sequentially, denoted \'p\') or interlaced (alternating fields, denoted \'i\').' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLoudnessLufs rdf:type rdf:Property ;
    rdfs:label 'Target Loudness Lufs' ;
    rdfs:comment 'Target integrated loudness level in LUFS (Loudness Units relative to Full Scale) or LKFS, typically -23 LUFS for broadcast, -14 LUFS for streaming.' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transcodePriority rdf:type rdf:Property ;
    rdfs:label 'Transcode Priority' ;
    rdfs:comment 'Default processing priority for transcode jobs targeting this format: critical (immediate), high (expedited), normal (standard queue), low (off-peak), batch (scheduled bulk processing).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verticalResolution rdf:type rdf:Property ;
    rdfs:label 'Vertical Resolution' ;
    rdfs:comment 'Vertical pixel count of the video frame (e.g., 1080 for Full HD, 2160 for UHD).' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:archiveTier rdf:type rdf:Property ;
    rdfs:label 'Archive Tier' ;
    rdfs:comment 'Storage tier classification for the collection: hot (frequent access), warm (occasional access), cold (rare access), glacier (long-term preservation), or deep-archive (regulatory retention).' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCollectionDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Collection Description' ;
    rdfs:comment 'Detailed narrative description of the collection\'s content, purpose, and editorial context. Used for cataloging and discovery.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCollectionStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Collection Status' ;
    rdfs:comment 'Current lifecycle status of the collection: draft (being assembled), active (available for use), archived (preserved but not active), deprecated (superseded), under-review (pending approval), or locked (no modifications allowed).' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkOperationEnabled rdf:type rdf:Property ;
    rdfs:label 'Bulk Operation Enabled' ;
    rdfs:comment 'Indicates whether bulk operations (bulk QC, bulk rights check, bulk archive, bulk transcode) are enabled for this collection (true) or must be performed individually (false).' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionCode rdf:type rdf:Property ;
    rdfs:label 'Collection Code' ;
    rdfs:comment 'Business identifier or code for the collection, used for external reference and cataloging (e.g., \'GOT-S08-PKG\', \'NEWS-ELEC24-001\').' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionName rdf:type rdf:Property ;
    rdfs:label 'Collection Name' ;
    rdfs:comment 'Human-readable name of the asset collection (e.g., \'Breaking News Package - Election 2024\', \'Game of Thrones Season 8 Bundle\', \'Super Bowl LVIII Highlights\').' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionType rdf:type rdf:Property ;
    rdfs:label 'Collection Type' ;
    rdfs:comment 'Classification of the collection by content grouping purpose: series (episodic television), film-franchise (related films), news-package (story bundle), sports-event (game/match clips), music-album (music tracks), campaign-creative (advertising assets), documentary-series, special-event, archive-bundle, or promo-package. [ENUM-REF-CANDIDATE: series|film-franchise|news-package|sports-event|music-album|campaign-creative|documentary-series|special-event|archive-bundle|promo-package — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curatorName rdf:type rdf:Property ;
    rdfs:label 'Curator Name' ;
    rdfs:comment 'Name of the individual or team responsible for curating and maintaining the collection.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Distribution Window End' ;
    rdfs:comment 'End date of the distribution window after which the collection may no longer be distributed or broadcast. Part of windowing strategy.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionWindowStart rdf:type rdf:Property ;
    rdfs:label 'Distribution Window Start' ;
    rdfs:comment 'Start date of the distribution window during which the collection may be distributed or broadcast. Part of windowing strategy.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:metadataCompletenessScore rdf:type rdf:Property ;
    rdfs:label 'Metadata Completeness Score' ;
    rdfs:comment 'Percentage score (0.00 to 100.00) indicating the completeness of metadata across all assets in the collection. Used for quality assurance and discoverability.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'Business unit or department responsible for the collection (e.g., \'News Editorial\', \'Sports Production\', \'Entertainment Programming\', \'Marketing Creative Services\').' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingFormat rdf:type rdf:Property ;
    rdfs:label 'Packaging Format' ;
    rdfs:comment 'Technical packaging format used for distribution (e.g., \'IMF\', \'DPP\', \'AS-11\', \'ProRes Package\', \'MPEG-DASH Manifest\'). Relevant for distribution deals.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryGenre rdf:type rdf:Property ;
    rdfs:label 'Primary Genre' ;
    rdfs:comment 'Primary content genre or category for the collection (e.g., \'Drama\', \'News\', \'Sports\', \'Documentary\', \'Comedy\', \'Music\', \'Reality\').' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Syndication Eligible Flag' ;
    rdfs:comment 'Indicates whether the collection is eligible for syndication (resale to multiple outlets) based on rights and content suitability (true) or not (false).' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalAssetCount rdf:type rdf:Property ;
    rdfs:label 'Total Asset Count' ;
    rdfs:comment 'Total number of media assets currently included in the collection.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Duration Seconds' ;
    rdfs:comment 'Cumulative playback duration of all time-based assets in the collection, measured in seconds.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStorageSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Total Storage Size Bytes' ;
    rdfs:comment 'Total storage footprint of all assets in the collection, measured in bytes. Used for capacity planning and archival costing.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when the collection was first created in the MAM (Media Asset Management) system.' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:archiveRecordId rdf:type rdf:Property ;
    rdfs:label 'Archive Record Id' ;
    rdfs:comment 'Primary key for archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:archiveStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Archive Storage Location Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.storage_location. Business justification: archive_record describes where an asset is archived (archive_destination_identifier, archive_destination_type, storage_tier) but has no FK to the storage_location master. For archive destinations that' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:custodianPartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Custodian Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Archives may be held at partner facilities (Iron Mountain, AWS Glacier, offsite vaults). Tracks custodian partner for retrieval requests, audit compliance, disaster recovery planning, and vendor perfo' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:archiveCostPerGb rdf:type rdf:Property ;
    rdfs:label 'Archive Cost Per Gb' ;
    rdfs:comment 'The cost per gigabyte for storing the asset in the archive destination, used for financial planning and cost allocation.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:archiveDestinationIdentifier rdf:type rdf:Property ;
    rdfs:label 'Archive Destination Identifier' ;
    rdfs:comment 'Specific identifier for the archive destination such as LTO (Linear Tape-Open) tape barcode, cloud vault identifier, or off-site facility location code.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveDestinationType rdf:type rdf:Property ;
    rdfs:label 'Archive Destination Type' ;
    rdfs:comment 'The type of long-term storage destination where the asset was archived.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Archive File Size Bytes' ;
    rdfs:comment 'The size of the archived media file in bytes, used for storage capacity planning and billing.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:archiveFormat rdf:type rdf:Property ;
    rdfs:label 'Archive Format' ;
    rdfs:comment 'The file format or container format of the archived asset (e.g., MXF, MOV, MP4, ProRes, DNxHD) as stored in the archive.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveJobReference rdf:type rdf:Property ;
    rdfs:label 'Archive Job Reference' ;
    rdfs:comment 'Unique reference number assigned to the archival job or batch process that created this archive record.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveNotes rdf:type rdf:Property ;
    rdfs:label 'Archive Notes' ;
    rdfs:comment 'Free-text notes or comments about the archival process, special handling instructions, or any issues encountered during archival.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveStatus rdf:type rdf:Property ;
    rdfs:label 'Archive Status' ;
    rdfs:comment 'Current lifecycle status of the archived asset indicating its availability and operational state. [ENUM-REF-CANDIDATE: archived|restore_requested|restore_in_progress|restored|purge_pending|purged|failed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveSystemName rdf:type rdf:Property ;
    rdfs:label 'Archive System Name' ;
    rdfs:comment 'Name of the archival system or MAM module that performed the archival operation (e.g., Dalet Galaxy Archive, Spectra Logic).' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archive Timestamp' ;
    rdfs:comment 'Precise timestamp when the archival process completed and the asset was committed to long-term storage.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cloudVaultIdentifier rdf:type rdf:Property ;
    rdfs:label 'Cloud Vault Identifier' ;
    rdfs:comment 'Unique identifier for the cloud deep-archive vault or bucket where the asset is stored (e.g., AWS Glacier vault ARN, Azure Archive Storage container).' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionCodec rdf:type rdf:Property ;
    rdfs:label 'Compression Codec' ;
    rdfs:comment 'The compression codec applied to the media asset for archival storage (e.g., H.264, H.265, JPEG2000, uncompressed).' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltoTapeGeneration rdf:type rdf:Property ;
    rdfs:label 'Lto Tape Generation' ;
    rdfs:comment 'The LTO tape generation standard used for archival (e.g., LTO-8, LTO-9) if the destination is tape-based storage.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oaisComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Oais Compliance Flag' ;
    rdfs:comment 'Indicates whether this archive record complies with ISO 14721 OAIS reference model standards for long-term digital preservation.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offsiteFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Offsite Facility Code' ;
    rdfs:comment 'Code identifying the physical off-site archival facility or vault location where the media is stored.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purgeApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Purge Approval Status' ;
    rdfs:comment 'Approval status for purging the archived asset, ensuring compliance with retention and legal hold requirements before deletion.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purgeScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Purge Scheduled Date' ;
    rdfs:comment 'The scheduled date for purging or permanently deleting the archived asset, based on retention policy expiration.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Restore Completion Date' ;
    rdfs:comment 'The date when the restore operation was completed and the asset was made available for use.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreRequestDate rdf:type rdf:Property ;
    rdfs:label 'Restore Request Date' ;
    rdfs:comment 'The date when a restore request was submitted for this archived asset, if applicable.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreSlaTier rdf:type rdf:Property ;
    rdfs:label 'Restore Sla Tier' ;
    rdfs:comment 'The service level tier defining the expected restore time for retrieving this archived asset (e.g., expedited within hours, standard within days, bulk within weeks).' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restoreTestDate rdf:type rdf:Property ;
    rdfs:label 'Restore Test Date' ;
    rdfs:comment 'The date when the last restore test was performed to verify the integrity and retrievability of the archived asset.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreTestResult rdf:type rdf:Property ;
    rdfs:label 'Restore Test Result' ;
    rdfs:comment 'Outcome of the most recent restore test indicating whether the asset was successfully retrieved and validated.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeBarcode rdf:type rdf:Property ;
    rdfs:label 'Tape Barcode' ;
    rdfs:comment 'Physical barcode identifier on the LTO tape cartridge used for archival, enabling physical inventory tracking.' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLicenseHolderId rdf:type rdf:Property ;
    rdfs:label 'Primary License Holder Id' ;
    rdfs:comment 'Reference to the party granting rights under this agreement (studio, distributor, music publisher, talent guild, production company).' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:primaryLicenseePartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Primary Licensee Partner Partner Id' ;
    rdfs:comment 'FK to partner.partner_partner' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:advancePaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Amount' ;
    rdfs:comment 'Upfront payment made upon execution of the agreement, typically recoupable against future royalties or license fees.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Clearance Required Flag' ;
    rdfs:comment 'Indicates whether additional rights clearance verification is required before content can be broadcast or distributed under this agreement. True = clearance workflow required, False = no additional clearance needed.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaRightsGranted rdf:type rdf:Property ;
    rdfs:label 'Media Rights Granted' ;
    rdfs:comment 'Comma-separated list of media exploitation rights included in this agreement (e.g., linear broadcast, SVOD, AVOD, TVOD, theatrical, home video, digital download, mobile streaming).' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicSyncLicenseFlag rdf:type rdf:Property ;
    rdfs:label 'Music Sync License Flag' ;
    rdfs:comment 'Indicates whether this agreement includes music synchronization rights for use of musical compositions in audiovisual content. True = music sync rights included, False = no music sync rights.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perEpisodeFee rdf:type rdf:Property ;
    rdfs:label 'Per Episode Fee' ;
    rdfs:comment 'License fee charged per episode for episodic content. Applicable to syndication and first-run syndication agreements.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months of each automatic renewal period if auto_renewal_flag is true. Null if agreement does not auto-renew.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:royaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Royalty Calculation Method' ;
    rdfs:comment 'Method used to calculate ongoing royalty payments to the licensor. Determines how revenue is shared or how usage is monetized.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyPercentage rdf:type rdf:Property ;
    rdfs:label 'Royalty Percentage' ;
    rdfs:comment 'Percentage of revenue or receipts paid to the licensor as ongoing royalties. Applicable when royalty_calculation_method is percentage-based.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runCountLimit rdf:type rdf:Property ;
    rdfs:label 'Run Count Limit' ;
    rdfs:comment 'Maximum number of times each episode or program may be broadcast or streamed under this agreement. Common in syndication deals. Null indicates unlimited runs.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLicenseFee rdf:type rdf:Property ;
    rdfs:label 'Total License Fee' ;
    rdfs:comment 'Total contractual payment obligation for the license rights over the full term of the agreement. Sum of all payment milestones.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutApplicable rdf:type rdf:Property ;
    rdfs:label 'Blackout Applicable' ;
    rdfs:comment 'Indicates whether geographic or temporal blackout restrictions apply to this grant (e.g., sports blackouts, regional restrictions).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Applicable' ;
    rdfs:comment 'Indicates whether a carriage fee (distribution payment) is associated with this grant.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityIndicator rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Indicator' ;
    rdfs:comment 'Indicates whether the grant is exclusive (true) or non-exclusive (false). Exclusive grants prevent other parties from exploiting the same rights in the same territory and window.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Number' ;
    rdfs:comment 'Business identifier for the rights grant, typically a human-readable code used in Rightsline and operational workflows.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantStatus rdf:type rdf:Property ;
    rdfs:label 'Grant Status' ;
    rdfs:comment 'Current lifecycle status of the rights grant. Reflects whether the grant is currently in force, expired, or otherwise inactive.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackApplicable rdf:type rdf:Property ;
    rdfs:label 'Holdback Applicable' ;
    rdfs:comment 'Indicates whether a holdback period applies to this grant. Holdbacks restrict exploitation during specific windows to protect other distribution channels.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdbackEndDate rdf:type rdf:Property ;
    rdfs:label 'Holdback End Date' ;
    rdfs:comment 'The end date of the holdback period, after which exploitation may resume. Nullable if no holdback applies.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdbackStartDate rdf:type rdf:Property ;
    rdfs:label 'Holdback Start Date' ;
    rdfs:comment 'The start date of any holdback period during which exploitation is restricted. Nullable if no holdback applies.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mediaType rdf:type rdf:Property ;
    rdfs:label 'Media Type' ;
    rdfs:comment 'The media format or delivery mechanism covered by this grant (e.g., television, film, digital streaming, audio).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicSyncLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Music Sync License Required' ;
    rdfs:comment 'Indicates whether a separate music synchronization license is required for the music tracks embedded in the content.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightType rdf:type rdf:Property ;
    rdfs:label 'Right Type' ;
    rdfs:comment 'Type of distribution or exploitation right granted. Defines the platform or medium for which the content may be used. [ENUM-REF-CANDIDATE: broadcast|svod|avod|tvod|theatrical|home_video|music_sync|podcast|linear|non_linear|vod — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensePermitted rdf:type rdf:Property ;
    rdfs:label 'Sublicense Permitted' ;
    rdfs:comment 'Indicates whether the licensee is permitted to sublicense the rights to third parties.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:talentResidualsApplicable rdf:type rdf:Property ;
    rdfs:label 'Talent Residuals Applicable' ;
    rdfs:comment 'Indicates whether talent residual payments (reuse payments to actors, directors, writers) are triggered by this grant.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windowName rdf:type rdf:Property ;
    rdfs:label 'Window Name' ;
    rdfs:comment 'Named distribution window (e.g., Theatrical, Premium VOD, Pay-TV, Free-TV) that this grant falls within. Used for windowing strategy enforcement.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this window record is currently active and should be considered in availability calculations. False if the window has been superseded, cancelled, or archived.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'The computed net availability status of the content for this window, considering window dates, holdbacks, and blackouts. Refreshed whenever upstream rights or holdback records change. Directly consumed by scheduling and distribution domains to validate playout eligibility.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutReason rdf:type rdf:Property ;
    rdfs:label 'Blackout Reason' ;
    rdfs:comment 'The business or regulatory reason for the blackout restriction (e.g., sports event local blackout, contractual exclusivity, regulatory compliance). Populated only when blackout_flag is true.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceNotes rdf:type rdf:Property ;
    rdfs:label 'Clearance Notes' ;
    rdfs:comment 'Free-text notes documenting clearance issues, pending approvals, conditional restrictions, or special instructions related to rights clearance for this window.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoBlockingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Geo Blocking Required Flag' ;
    rdfs:comment 'Indicates whether geographic blocking technology must be enforced to restrict access to the specified territory. True if geo-blocking is mandatory; false if not required.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAvailabilityRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Availability Refresh Timestamp' ;
    rdfs:comment 'The timestamp when the availability_status was last recalculated. Updated whenever upstream rights, holdback, or blackout records change. Used to track data freshness for scheduling and distribution systems.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:licenseFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'License Fee Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the license fee amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCapType rdf:type rdf:Property ;
    rdfs:label 'Usage Cap Type' ;
    rdfs:comment 'The unit of measure for the usage cap (e.g., streams for SVOD, broadcasts for linear, screenings for theatrical). Defines how usage is counted against the cap.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCapUnits rdf:type rdf:Property ;
    rdfs:label 'Usage Cap Units' ;
    rdfs:comment 'The maximum number of usage units (streams, downloads, broadcasts, screenings) permitted during this window. Used to enforce contractual usage limits.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowExtensionCount rdf:type rdf:Property ;
    rdfs:label 'Window Extension Count' ;
    rdfs:comment 'The number of times this window has been extended beyond its original close date. Tracks amendments and extensions to the original window terms.' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:automatedEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Enforcement Flag' ;
    rdfs:comment 'Indicates whether this holdback restriction is automatically enforced by scheduling and distribution systems or requires manual review.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageNegotiationReference rdf:type rdf:Property ;
    rdfs:label 'Carriage Negotiation Reference' ;
    rdfs:comment 'Reference identifier to the MVPD or vMVPD carriage negotiation that established this holdback restriction.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Workflow Status' ;
    rdfs:comment 'Status of the clearance workflow process that validates whether content can be scheduled or distributed despite this holdback restriction.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Conflict Resolution Notes' ;
    rdfs:comment 'Documentation of any conflicts with other rights, windows, or holdbacks and how they were resolved.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total number of days the holdback restriction is in effect, calculated from start to end date.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementStatus rdf:type rdf:Property ;
    rdfs:label 'Enforcement Status' ;
    rdfs:comment 'Current enforcement state of the holdback restriction, indicating whether it is actively blocking content exploitation or has been modified.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackCode rdf:type rdf:Property ;
    rdfs:label 'Holdback Code' ;
    rdfs:comment 'Business identifier code for the holdback restriction, used for external reference and clearance workflows.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether notification of this holdback restriction has been sent to relevant scheduling, distribution, and operations teams.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedChannel rdf:type rdf:Property ;
    rdfs:label 'Restricted Channel' ;
    rdfs:comment 'Specific broadcast or distribution channel that is restricted from airing or distributing the content during the holdback period.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedFormat rdf:type rdf:Property ;
    rdfs:label 'Restricted Format' ;
    rdfs:comment 'Distribution format or delivery method that is restricted during the holdback period, supporting windowing strategies. [ENUM-REF-CANDIDATE: theatrical|linear_tv|svod|avod|tvod|vod|physical_media|syndication|streaming|broadcast — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedPlatform rdf:type rdf:Property ;
    rdfs:label 'Restricted Platform' ;
    rdfs:comment 'Name or identifier of the platform, distributor, or service that is restricted from exploiting the content during the holdback period. Applies to platform_holdback restriction types.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Classification of the holdback restriction type that defines the nature of the exclusivity period.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the person or role who authorized the waiver or override of the holdback restriction.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved Date' ;
    rdfs:comment 'Date when the waiver or override of the holdback restriction was officially approved.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Business justification or explanation for waiving or overriding the holdback restriction, if applicable.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowingStrategyNotes rdf:type rdf:Property ;
    rdfs:label 'Windowing Strategy Notes' ;
    rdfs:comment 'Additional notes or context explaining how this holdback fits into the overall content windowing and sequential release strategy.' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Blackout Restricted Flag' ;
    rdfs:comment 'Indicates whether the territory is subject to geographic blackout restrictions for certain content (e.g., sports events, theatrical windows). True if blackouts apply, False otherwise.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdbackEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Holdback Eligible Flag' ;
    rdfs:comment 'Indicates whether the territory is eligible for holdback periods in windowing strategies (e.g., delaying SVOD release to protect theatrical revenue). True if holdbacks apply, False otherwise.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internetPenetrationPercent rdf:type rdf:Property ;
    rdfs:label 'Internet Penetration Percent' ;
    rdfs:comment 'Percentage of the population with internet access in the territory (e.g., 95.00 for USA, 60.00 for India). Used for OTT and streaming market opportunity assessment.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isoAlpha2Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 2 Code' ;
    rdfs:comment 'Two-letter ISO 3166-1 alpha-2 country code (e.g., US, GB, CA). Used for system integrations and data exchange with distribution platforms.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoAlpha3Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 3 Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code (e.g., USA, GBR, CAN). Provides additional clarity for territories with similar two-letter codes.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoNumericCode rdf:type rdf:Property ;
    rdfs:label 'Iso Numeric Code' ;
    rdfs:comment 'Three-digit ISO 3166-1 numeric country code (e.g., 840 for USA, 826 for GBR). Language-independent identifier for international systems.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageSecondary rdf:type rdf:Property ;
    rdfs:label 'Language Secondary' ;
    rdfs:comment 'ISO 639-1 or ISO 639-2 code for a secondary or co-official language in the territory (e.g., fr for Canada, ca for Spain). Supports multi-language content delivery and compliance.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ottMarketMaturity rdf:type rdf:Property ;
    rdfs:label 'Ott Market Maturity' ;
    rdfs:comment 'Classification of the territory\'s OTT streaming market maturity: mature (high penetration, competitive), developing (growing adoption), emerging (early stage), nascent (minimal infrastructure). Informs distribution strategy and rights pricing.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:population rdf:type rdf:Property ;
    rdfs:label 'Population' ;
    rdfs:comment 'Total population of the territory. Used for audience reach estimation, market sizing, and rights valuation.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rightsTerritoryStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Territory Status' ;
    rdfs:comment 'Current operational status of the territory in the rights management system: active (available for licensing), inactive (not currently used), restricted (subject to special clearance), pending (under review for activation).' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryGroup rdf:type rdf:Property ;
    rdfs:label 'Territory Group' ;
    rdfs:comment 'Regional grouping of the territory used for rights aggregation and windowing strategies (e.g., EMEA, LATAM, North America, Worldwide, APAC). Enables multi-territory licensing and holdback management. [ENUM-REF-CANDIDATE: worldwide|north_america|latin_america|emea|apac|europe|asia|africa|middle_east|oceania — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Full official name of the territory (e.g., United States, United Kingdom, Canada). Human-readable identifier used in contracts and reporting.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of the territory scope: country (single nation), region (multi-country group), worldwide (global rights), or custom (bespoke territory definition).' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Vat Applicable Flag' ;
    rdfs:comment 'Indicates whether Value-Added Tax (VAT) or Goods and Services Tax (GST) applies to transactions in the territory. True if VAT/GST applies, False otherwise. Used for royalty and subscription billing calculations.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vatRatePercent rdf:type rdf:Property ;
    rdfs:label 'Vat Rate Percent' ;
    rdfs:comment 'Standard VAT or GST rate percentage applicable in the territory (e.g., 20.00 for UK, 19.00 for Germany, 0.00 for territories without VAT). Used for financial reconciliation and revenue recognition.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRatePercent rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate Percent' ;
    rdfs:comment 'Standard withholding tax rate percentage applied to royalty payments to rights holders in the territory (e.g., 30.00 for USA non-resident aliens, 0.00 for domestic). Used for talent residuals and royalty calculations.' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which this royalty rule was approved. Nullable if not yet approved.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'The financial or usage metric upon which the royalty calculation is based (e.g., gross revenue, net revenue, subscriber count, stream count, GRP). [ENUM-REF-CANDIDATE: gross_revenue|net_revenue|subscriber_count|stream_count|grp|unit_sales|advertising_revenue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Deduction Allowed Flag' ;
    rdfs:comment 'Indicates whether deductions (e.g., distribution costs, marketing expenses) are allowed before calculating the royalty. True if deductions are permitted, False otherwise.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Deduction Percentage' ;
    rdfs:comment 'The percentage of revenue or basis that may be deducted before applying the royalty rate. Nullable if no deduction applies.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumCapAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Cap Amount' ;
    rdfs:comment 'The maximum royalty payment cap for this rule. Royalty calculations will not exceed this amount. Nullable if no cap applies.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTiming rdf:type rdf:Property ;
    rdfs:label 'Payment Timing' ;
    rdfs:comment 'The timing of royalty payments relative to the calculation period (e.g., advance, arrears, upon delivery, upon release, milestone-based).' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'The unit of measure for the rate value (e.g., percentage, per stream, per subscriber, per unit, per GRP, flat amount).' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'The numeric rate or percentage applied in the royalty calculation. For percentage-based royalties, this is the percentage (e.g., 15.5 for 15.5%). For per-unit rates, this is the amount per unit.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoupmentFlag rdf:type rdf:Property ;
    rdfs:label 'Recoupment Flag' ;
    rdfs:comment 'Indicates whether this royalty rule includes recoupment provisions (e.g., advance payments must be recouped before additional royalties are paid). True if recoupment applies, False otherwise.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recoupmentThreshold rdf:type rdf:Property ;
    rdfs:label 'Recoupment Threshold' ;
    rdfs:comment 'The monetary threshold that must be recouped before additional royalty payments are made. Nullable if no recoupment applies.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualFormula rdf:type rdf:Property ;
    rdfs:label 'Residual Formula' ;
    rdfs:comment 'The formula or calculation logic for residual payments to talent (actors, directors, writers) based on reuse, reruns, or secondary exploitation. Nullable if not applicable.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Royalty Rule Status' ;
    rdfs:comment 'Current lifecycle status of the royalty rule (e.g., draft, active, suspended, expired, terminated).' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyType rdf:type rdf:Property ;
    rdfs:label 'Royalty Type' ;
    rdfs:comment 'The type of royalty calculation method applied by this rule. Determines how the royalty amount is computed.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business-assigned unique code or identifier for this royalty rule, used for reference in contracts and reporting.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name or title of the royalty rule, describing its purpose or scope (e.g., \'SVOD Revenue Share - Tier 1\', \'Per-Stream Rate - Music Sync\').' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulePriority rdf:type rdf:Property ;
    rdfs:label 'Rule Priority' ;
    rdfs:comment 'The priority or precedence of this royalty rule when multiple rules may apply to the same content or transaction. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'The unit of measure for the threshold value (e.g., revenue, subscriber count, stream count, unit count, GRP).' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'The threshold value that triggers a rate tier change or special calculation logic (e.g., revenue threshold for tiered royalty rates).' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holderId rdf:type rdf:Property ;
    rdfs:label 'Holder Id' ;
    rdfs:comment 'Identifier of the rights holder (licensor, talent guild, music publisher, or syndication partner) to whom this statement is issued. Links to the party receiving royalty payments.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:advanceRecoupmentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Recoupment Amount' ;
    rdfs:comment 'Amount deducted from gross royalties to recoup advances previously paid to the rights holder under the agreement.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentTitleBreakdown rdf:type rdf:Property ;
    rdfs:label 'Content Title Breakdown' ;
    rdfs:comment 'Structured breakdown of royalties by content title or asset. Stored as JSON or delimited string for detailed reporting.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exploitationTypeBreakdown rdf:type rdf:Property ;
    rdfs:label 'Exploitation Type Breakdown' ;
    rdfs:comment 'Structured breakdown of royalties by exploitation type (theatrical, SVOD, AVOD, TVOD, linear, syndication, home video, etc.). Stored as JSON or delimited string for detailed reporting.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Royalty Amount' ;
    rdfs:comment 'Total royalty amount earned by the rights holder before any deductions, recoupments, or adjustments.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumGuaranteeShortfall rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Shortfall' ;
    rdfs:comment 'The difference between the contractual minimum guarantee and actual royalties earned for the period. A positive value indicates the rights holder is entitled to a minimum guarantee payment.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Net Royalty Amount' ;
    rdfs:comment 'Final royalty amount payable to the rights holder after all deductions, recoupments, taxes, and adjustments. This is the amount that will be paid.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Paid Timestamp' ;
    rdfs:comment 'Date and time when payment for this royalty statement was successfully processed and remitted to the rights holder.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:statementDueDate rdf:type rdf:Property ;
    rdfs:label 'Statement Due Date' ;
    rdfs:comment 'The date by which payment of the royalties on this statement is contractually due to the rights holder.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementFrequency rdf:type rdf:Property ;
    rdfs:label 'Statement Frequency' ;
    rdfs:comment 'The reporting frequency for this royalty statement as defined in the underlying rights agreement.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementIssueDate rdf:type rdf:Property ;
    rdfs:label 'Statement Issue Date' ;
    rdfs:comment 'The date on which this royalty statement was officially issued to the rights holder.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementNotes rdf:type rdf:Property ;
    rdfs:label 'Statement Notes' ;
    rdfs:comment 'Free-text notes or comments related to this royalty statement, including explanations of unusual adjustments, special circumstances, or clarifications for the rights holder.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'Externally-known unique business identifier for this royalty statement, used for reference in correspondence and payment processing.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period End Date' ;
    rdfs:comment 'The last date of the reporting period covered by this royalty statement.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period Start Date' ;
    rdfs:comment 'The first date of the reporting period covered by this royalty statement.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementStatus rdf:type rdf:Property ;
    rdfs:label 'Statement Status' ;
    rdfs:comment 'Current lifecycle status of the royalty statement. Draft statements are under review, approved statements are ready for payment, disputed statements have objections from rights holders, paid statements have been settled, and cancelled statements have been voided.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryBreakdown rdf:type rdf:Property ;
    rdfs:label 'Territory Breakdown' ;
    rdfs:comment 'Structured breakdown of royalties by geographic territory or market. Stored as JSON or delimited string for detailed reporting.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualId rdf:type rdf:Property ;
    rdfs:label 'Residual Id' ;
    rdfs:comment 'Unique identifier for the residual payment obligation record. Primary key.' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calculatedResidualAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Residual Amount' ;
    rdfs:comment 'The computed residual payment amount owed to the talent based on the formula type, calculation basis, and applicable rates.' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis Amount' ;
    rdfs:comment 'The base revenue or gross receipts amount used as the input to the residual formula calculation.' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationBasisCurrency rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the calculation basis amount (e.g., USD, GBP, CAD).' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'The date when the residual amount was calculated by the royalty system.' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractCycle rdf:type rdf:Property ;
    rdfs:label 'Contract Cycle' ;
    rdfs:comment 'The collective bargaining agreement cycle or contract period under which this residual is calculated (e.g., 2020-2023, 2023-2026).' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the calculated residual amount (e.g., USD, GBP, CAD).' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exhibitionCount rdf:type rdf:Property ;
    rdfs:label 'Exhibition Count' ;
    rdfs:comment 'The number of times the content was exhibited or broadcast during the residual calculation period, used for per-exhibition or tiered formulas.' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exploitationEndDate rdf:type rdf:Property ;
    rdfs:label 'Exploitation End Date' ;
    rdfs:comment 'The date when the content exploitation period that triggered this residual ended. Nullable for ongoing exploitation.' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exploitationStartDate rdf:type rdf:Property ;
    rdfs:label 'Exploitation Start Date' ;
    rdfs:comment 'The date when the content exploitation period that triggered this residual began (e.g., first streaming availability date, first rerun air date).' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exploitationType rdf:type rdf:Property ;
    rdfs:label 'Exploitation Type' ;
    rdfs:comment 'The type of content reuse or re-exploitation that triggered this residual payment obligation (rerun, streaming, foreign broadcast, home video, SVOD, AVOD, TVOD, syndication, theatrical re-release, clip licensing). [ENUM-REF-CANDIDATE: RERUN|STREAMING|FOREIGN_BROADCAST|HOME_VIDEO|SVOD|AVOD|TVOD|SYNDICATION|THEATRICAL_RERELEASE|CLIP_LICENSING — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulaType rdf:type rdf:Property ;
    rdfs:label 'Formula Type' ;
    rdfs:comment 'The calculation method used to determine the residual amount (fixed amount, percentage of gross receipts, percentage of distributor gross, tiered scale based on exhibition count, per-exhibition fee, minimum guarantee).' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Guild Report Submission Date' ;
    rdfs:comment 'The date when the residual payment was reported to the guild or union. Nullable if not yet reported.' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guildReportSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Guild Report Submitted Flag' ;
    rdfs:comment 'Indicates whether this residual payment has been included in the mandatory guild reporting submission (True/False).' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'The percentage rate applied to the calculation basis when the formula type is percentage-based (e.g., 0.0350 for 3.5%).' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The financial or royalty reporting period to which this residual obligation belongs (e.g., Q1-2024, 2024-H1), used for guild reporting and financial reconciliation.' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Approved Date' ;
    rdfs:comment 'Date when the music synchronization license was officially cleared and approved for use. Nullable if not yet approved.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceRequestedDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Requested Date' ;
    rdfs:comment 'Date when the music synchronization license clearance was initially requested from the rights holder or clearance team.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:composerName rdf:type rdf:Property ;
    rdfs:label 'Composer Name' ;
    rdfs:comment 'Name of the composer or songwriter who created the musical composition.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositionTitle rdf:type rdf:Property ;
    rdfs:label 'Composition Title' ;
    rdfs:comment 'The title of the musical composition or work being licensed for synchronization use.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cueSheetRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cue Sheet Required Flag' ;
    rdfs:comment 'Indicates whether a cue sheet (detailed music usage report) must be filed with performance rights organizations for this license, typically required for broadcast and public performance.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iswcCode rdf:type rdf:Property ;
    rdfs:label 'Iswc Code' ;
    rdfs:comment 'International Standard Musical Work Code uniquely identifying the musical composition being licensed. Format: T-NNNNNNNNN-C where N is digit and C is check digit.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedPlatforms rdf:type rdf:Property ;
    rdfs:label 'Licensed Platforms' ;
    rdfs:comment 'Comma-separated list of distribution platforms and channels where the licensed music may be used (e.g., linear broadcast, SVOD, AVOD, TVOD, theatrical, home video, social media).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proAffiliation rdf:type rdf:Property ;
    rdfs:label 'Pro Affiliation' ;
    rdfs:comment 'Name of the Performance Rights Organization (e.g., ASCAP, BMI, SESAC, PRS, SOCAN) with which the composer or publisher is affiliated for performance royalty collection.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictions rdf:type rdf:Property ;
    rdfs:label 'Restrictions' ;
    rdfs:comment 'Free-text description of any restrictions, limitations, or special conditions attached to this music synchronization license (e.g., no use in advertising, no use with controversial content, limited to specific episodes).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolderName rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Name' ;
    rdfs:comment 'Name of the entity (publisher, record label, production company) that owns or controls the rights to the musical work or sound recording.' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolderType rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Type' ;
    rdfs:comment 'Classification of the rights holder entity (publisher for composition rights, record label for master recording rights, PRO for performance rights organization, independent artist for self-owned rights, production company for commissioned works, collective for rights societies).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyBasis rdf:type rdf:Property ;
    rdfs:label 'Royalty Basis' ;
    rdfs:comment 'The metric or revenue base upon which ongoing royalties are calculated (gross revenue, net revenue, per-stream count, per-download, per-unit sold, or flat fee with no ongoing royalties).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageType rdf:type rdf:Property ;
    rdfs:label 'Usage Type' ;
    rdfs:comment 'Classification of how the music is used within the content asset (background music, theme song, featured performance, promotional use, trailer, opening/closing credits).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystNotes rdf:type rdf:Property ;
    rdfs:label 'Analyst Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the clearance analyst during review. May include references to specific contract clauses, communications with rights holders, or special handling instructions.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingCategory rdf:type rdf:Property ;
    rdfs:label 'Blocking Category' ;
    rdfs:comment 'Classification of the primary reason for clearance denial. Enables reporting on common rights obstacles and process improvement. [ENUM-REF-CANDIDATE: holdback_period|territory_restriction|window_unavailable|rights_expired|music_sync_missing|talent_approval_required|residuals_unpaid|clearance_incomplete — promote to reference product]' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'Detailed explanation of why a clearance request was blocked or denied. May reference specific contract clauses, holdback periods, territorial restrictions, or missing rights. Null if request is cleared.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceDecision rdf:type rdf:Property ;
    rdfs:label 'Clearance Decision' ;
    rdfs:comment 'Final determination made by the clearance analyst regarding whether the content may be exploited as requested. Approved with conditions may require specific usage restrictions or additional payments.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalRequirements rdf:type rdf:Property ;
    rdfs:label 'Conditional Requirements' ;
    rdfs:comment 'Specific conditions or restrictions that must be met for conditional clearance approval. May include required credits, usage limitations, geographic blackouts, or additional royalty payments.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the clearance request was escalated to senior rights management or legal counsel due to complexity, ambiguity, or high business impact. Null if no escalation occurred.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedAudienceReach rdf:type rdf:Property ;
    rdfs:label 'Estimated Audience Reach' ;
    rdfs:comment 'Projected number of unique viewers or households expected to access the content in the requested exploitation. Used for royalty calculations and rights holder reporting.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedGrp rdf:type rdf:Property ;
    rdfs:label 'Estimated Grp' ;
    rdfs:comment 'Projected Gross Rating Point value for the scheduled broadcast or streaming event. GRP represents the sum of ratings achieved by the content and may trigger tiered royalty obligations.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedResidualsAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Residuals Amount' ;
    rdfs:comment 'Projected total residual payments owed to talent if the clearance is approved and content is distributed. Used for financial planning and budget approval workflows.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:integrationStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Status' ;
    rdfs:comment 'Status of data synchronization between Rightsline clearance system and downstream scheduling and playout systems (Ericsson MediaFirst). Ensures cleared content is automatically released to scheduling workflows.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Music Clearance Required' ;
    rdfs:comment 'Indicates whether separate music synchronization licenses must be verified before content can be cleared for distribution. True if content contains licensed music requiring additional clearance.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformChannel rdf:type rdf:Property ;
    rdfs:label 'Platform Channel' ;
    rdfs:comment 'Specific platform, channel, or outlet where the content is intended to be distributed (e.g., HBO Max, NBC Network, YouTube, Hulu). Used to verify platform-specific licensing restrictions.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Submitted Timestamp' ;
    rdfs:comment 'Date and time when the clearance request was initially submitted into the workflow system. Marks the start of the clearance review lifecycle and SLA clock.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedAirDate rdf:type rdf:Property ;
    rdfs:label 'Requested Air Date' ;
    rdfs:comment 'The target date when the content is scheduled to be broadcast, streamed, or published. Critical for verifying that rights are available within the requested window and that no holdback periods are violated.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedAirTime rdf:type rdf:Property ;
    rdfs:label 'Requested Air Time' ;
    rdfs:comment 'Precise timestamp for the intended broadcast or streaming start time, including time zone. Used for daypart-specific rights verification and scheduling coordination.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:residualsTriggered rdf:type rdf:Property ;
    rdfs:label 'Residuals Triggered' ;
    rdfs:comment 'Indicates whether the requested exploitation will trigger residual payments to talent per guild agreements. True if reuse payments are required for this distribution window.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Started Timestamp' ;
    rdfs:comment 'Date and time when a clearance analyst began active review of the request. Used to measure queue time and analyst response performance.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaMet rdf:type rdf:Property ;
    rdfs:label 'Sla Met' ;
    rdfs:comment 'Indicates whether the clearance request was resolved within the defined SLA target hours. Used for operational performance reporting and process improvement.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Number of business hours within which the clearance request must be resolved per service level agreement. Varies by priority level (urgent requests have shorter SLA targets).' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:talentApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Talent Approval Required' ;
    rdfs:comment 'Indicates whether talent (actors, directors, producers) approval or notification is contractually required before the requested exploitation. True if talent has approval rights per guild agreements or individual contracts.' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:advertisingAllowed rdf:type rdf:Property ;
    rdfs:label 'Advertising Allowed' ;
    rdfs:comment 'Indicates whether advertising insertion (pre-roll, mid-roll, post-roll) is permitted during content playback for this availability window. True = ads allowed, False = ad-free distribution only.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availabilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Availability End Date' ;
    rdfs:comment 'The date when the content asset is no longer available for exploitation on the specified platform and territory. Represents the end of the net exploitable window. Nullable for perpetual rights.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availabilityStartDate rdf:type rdf:Property ;
    rdfs:label 'Availability Start Date' ;
    rdfs:comment 'The date when the content asset becomes available for exploitation on the specified platform and territory. Represents the beginning of the net exploitable window.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blackoutIndicator rdf:type rdf:Property ;
    rdfs:label 'Blackout Indicator' ;
    rdfs:comment 'Indicates whether a geographic broadcast restriction (blackout) applies to this availability window. True = blackout in effect, False = no blackout restriction.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:computedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Computed Timestamp' ;
    rdfs:comment 'The timestamp when this availability window record was computed from the intersection of upstream rights grants, holdbacks, and content windows. Represents the calculation execution time.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downloadToOwnAllowed rdf:type rdf:Property ;
    rdfs:label 'Download To Own Allowed' ;
    rdfs:comment 'Indicates whether permanent download (download-to-own, DTO) is permitted during this availability window. True = DTO allowed, False = streaming-only distribution.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Expiration Notification Sent' ;
    rdfs:comment 'Indicates whether an expiration notification has been sent to scheduling and distribution systems alerting them that this availability window is approaching its end date. True = notification sent, False = not yet notified.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verified Timestamp' ;
    rdfs:comment 'The timestamp when this availability window was last verified against upstream rights and clearance records. Used for audit and compliance tracking.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:offlineViewingAllowed rdf:type rdf:Property ;
    rdfs:label 'Offline Viewing Allowed' ;
    rdfs:comment 'Indicates whether temporary offline viewing (download for offline playback with expiration) is permitted during this availability window. True = offline viewing allowed, False = online streaming only.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:simulcastAllowed rdf:type rdf:Property ;
    rdfs:label 'Simulcast Allowed' ;
    rdfs:comment 'Indicates whether simultaneous multi-platform broadcast (simulcast) is permitted during this availability window. True = simulcast allowed, False = platform-exclusive distribution only.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:syndicationAllowed rdf:type rdf:Property ;
    rdfs:label 'Syndication Allowed' ;
    rdfs:comment 'Indicates whether the content can be syndicated (resold to multiple outlets) during this availability window. True = syndication permitted, False = syndication prohibited.' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearancePriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Clearance Priority Level' ;
    rdfs:comment 'Priority level assigned to clearance requests for content from this rights holder. VIP and critical levels receive accelerated processing.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultRoyaltyRate rdf:type rdf:Property ;
    rdfs:label 'Default Royalty Rate' ;
    rdfs:comment 'Default royalty rate percentage applied to new agreements with this rights holder. Can be overridden at the contract level.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityPreference rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Preference' ;
    rdfs:comment 'Rights holder\'s stated preference for exclusivity terms in licensing agreements. Influences windowing strategy and holdback negotiations.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildAffiliation rdf:type rdf:Property ;
    rdfs:label 'Guild Affiliation' ;
    rdfs:comment 'Name of talent guild or performing rights organization (PRO) that this rights holder is affiliated with. Determines residual payment rules and reporting requirements. [ENUM-REF-CANDIDATE: sag_aftra|wga|dga|afm|ascap|bmi|sesac|gema|prs|socan — promote to reference product]' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteeThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Threshold' ;
    rdfs:comment 'Minimum guarantee amount threshold below which this rights holder will not enter licensing agreements. Used for deal structuring and negotiation.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mostFavoredNationsFlag rdf:type rdf:Property ;
    rdfs:label 'Most Favored Nations Flag' ;
    rdfs:comment 'Indicates whether this rights holder has most favored nations clause requiring rate parity with other similar rights holders. True triggers rate comparison workflows.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'Three-letter ISO currency code representing the rights holder\'s preferred currency for royalty payments and contract valuations.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrantIdentifier rdf:type rdf:Property ;
    rdfs:label 'Registrant Identifier' ;
    rdfs:comment 'The ISAN or ISRC registrant identifier assigned to the rights holder by the respective international registration authority. Used for global rights tracking and content identification.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolderCode rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Code' ;
    rdfs:comment 'Internal business identifier code assigned to the rights holder for operational reference and system integration across Rightsline and billing systems.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolderStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Status' ;
    rdfs:comment 'Current lifecycle status of the rights holder relationship. Active status is required for new license agreements and royalty payments.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Classification' ;
    rdfs:comment 'Tax withholding classification for royalty payments. Determines applicable withholding rates based on tax treaties and domestic regulations.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingRate rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Rate' ;
    rdfs:comment 'Applicable tax withholding rate percentage for royalty payments to this rights holder. Derived from tax treaties and domestic law based on withholding classification.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territoryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Territory Of Incorporation' ;
    rdfs:comment 'Three-letter ISO country code representing the legal jurisdiction where the rights holder entity is incorporated or registered. Determines applicable tax treaties and withholding requirements.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountSalesAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Sales Account Id' ;
    rdfs:comment 'Reference to the parent sales account in a hierarchical account structure. Used to model agency networks, holding company subsidiaries, and multi-location advertiser organizations.' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesAccount .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'The strategic tier or classification of the account based on revenue potential, relationship depth, and strategic importance. Higher tiers receive preferential pricing, dedicated support, and priority inventory access.' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Agency Commission Rate' ;
    rdfs:comment 'The commission percentage paid to advertising agencies for media buys placed on behalf of their clients. Typically expressed as a decimal (e.g., 0.1500 for 15%). Null for non-agency accounts.' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenuePotential rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Potential' ;
    rdfs:comment 'The estimated annual revenue opportunity from this account based on historical spend, market share, and sales forecasts. Used for territory planning and quota allocation.' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'The email address of the primary billing contact for invoice delivery and payment correspondence.' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactName rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Name' ;
    rdfs:comment 'The full name of the primary billing contact at the account organization who handles invoices, payment processing, and financial inquiries.' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Phone' ;
    rdfs:comment 'The phone number of the primary billing contact for urgent payment or invoice inquiries.' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingCompanyName rdf:type rdf:Property ;
    rdfs:label 'Holding Company Name' ;
    rdfs:comment 'The name of the parent holding company or corporate group to which this account belongs. Used to aggregate spend and manage relationships at the holding company level (e.g., WPP, Omnicom, Publicis Groupe for agencies).' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'The primary industry vertical or business sector of the account (e.g., Automotive, Financial Services, Retail, Pharmaceutical, Technology). Used for competitive separation and industry-specific rate cards.' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'The date of the most recent sales activity, campaign, or transaction associated with this account. Used to identify dormant accounts and trigger re-engagement campaigns.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesforceAccountReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Reference' ;
    rdfs:comment 'The source system identifier from Salesforce Media Cloud CRM. This is the external key used to synchronize account data between the lakehouse and the operational CRM system.' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignObjective rdf:type rdf:Property ;
    rdfs:label 'Campaign Objective' ;
    rdfs:comment 'Primary marketing objective the advertiser aims to achieve with this campaign. Influences creative strategy, placement selection, and success metrics. [ENUM-REF-CANDIDATE: brand_awareness|product_launch|direct_response|lead_generation|traffic|engagement|video_views|app_installs — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Target date by which the sales team expects to close this opportunity (win or lose). Used for pipeline forecasting and sales velocity tracking. Updated as negotiations progress.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitiveDisplacement rdf:type rdf:Property ;
    rdfs:label 'Competitive Displacement' ;
    rdfs:comment 'Free-text notes capturing competitive intelligence about which competitor this deal may displace or compete against. Used for win/loss analysis and competitive strategy.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Value' ;
    rdfs:comment 'Total estimated revenue value of the opportunity in USD. For advertising deals, represents total campaign spend; for content licensing, represents license fee. Used for revenue forecasting and quota tracking.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastCategory rdf:type rdf:Property ;
    rdfs:label 'Forecast Category' ;
    rdfs:comment 'Sales forecast category indicating confidence level for revenue recognition. Pipeline = early stage; Best Case = likely but not committed; Commit = high confidence; Closed = won. Used for revenue forecasting rollups.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isUpfront rdf:type rdf:Property ;
    rdfs:label 'Is Upfront' ;
    rdfs:comment 'Boolean flag indicating whether this opportunity is part of the annual upfront sales season. True = upfront commitment; False = scatter market or other deal type. Used for upfront tracking and reporting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Origin channel of this sales opportunity. Tracks how the lead was generated for marketing attribution and lead source ROI analysis. [ENUM-REF-CANDIDATE: inbound|outbound|referral|event|partner|renewal|upsell — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossNotes rdf:type rdf:Property ;
    rdfs:label 'Loss Notes' ;
    rdfs:comment 'Free-text detailed explanation of why the opportunity was lost. Captures competitive intelligence, pricing feedback, and strategic insights for future deals.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Primary reason for losing the opportunity if stage is closed-lost. Used for loss analysis, competitive intelligence, and sales process improvement. Null for won or open opportunities.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStep rdf:type rdf:Property ;
    rdfs:label 'Next Step' ;
    rdfs:comment 'Description of the next action or milestone required to advance this opportunity. Used for sales activity tracking and pipeline hygiene. Updated regularly by sales executive.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Descriptive name of the sales opportunity, typically including advertiser name, campaign type, and time period (e.g., \'Acme Corp Q4 Upfront Buy\').' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'Human-readable business identifier for the opportunity, typically auto-generated in format OPP-YYYYNNNN. Used in sales communications and reporting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probability rdf:type rdf:Property ;
    rdfs:label 'Probability' ;
    rdfs:comment 'Estimated likelihood of closing this opportunity as a percentage (0.00 to 100.00). Typically aligned with stage (e.g., Proposal = 40%, Negotiation = 60%). Used for weighted pipeline forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresMakegood rdf:type rdf:Property ;
    rdfs:label 'Requires Makegood' ;
    rdfs:comment 'Boolean flag indicating whether this opportunity includes makegood provisions for audience delivery shortfalls. True = makegoods may be required if audience guarantees are not met. Used for inventory planning.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage in the sales pipeline lifecycle. Tracks progression from initial prospecting through closure. Used for pipeline forecasting and sales funnel analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repId rdf:type rdf:Property ;
    rdfs:label 'Rep Id' ;
    rdfs:comment 'Primary key for rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerRepId rdf:type rdf:Property ;
    rdfs:label 'Manager Rep Id' ;
    rdfs:comment 'Foreign key reference to the sales manager or team lead who supervises this sales representative. Self-referential relationship within the sales rep hierarchy.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:accountPortfolioSegment rdf:type rdf:Property ;
    rdfs:label 'Account Portfolio Segment' ;
    rdfs:comment 'Classification of the account portfolio managed by the sales representative. Indicates whether they manage agency relationships, direct advertiser accounts, distribution partners (MVPD/vMVPD), OTT platforms, syndication buyers, or other client segments. [ENUM-REF-CANDIDATE: agency|direct_advertiser|mvpd|vmvpd|ott_platform|syndicator|international|government — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Quota Amount' ;
    rdfs:comment 'Total annual revenue quota assigned to the sales representative for the current quota period. Measured in the company\'s reporting currency.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionPlanType rdf:type rdf:Property ;
    rdfs:label 'Commission Plan Type' ;
    rdfs:comment 'Type of commission structure applied to the sales representative. Defines how commissions are calculated based on sales performance (e.g., base salary plus commission, commission-only, tiered rates, accelerators for exceeding quota).' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percentage' ;
    rdfs:comment 'Standard commission rate percentage applied to qualified sales revenue. May vary by deal type or quota attainment tier.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealTypeSpecialization rdf:type rdf:Property ;
    rdfs:label 'Deal Type Specialization' ;
    rdfs:comment 'Primary deal type or sales channel specialization for the representative. Indicates whether they focus on national TV advertising, digital campaigns, content licensing, syndication deals, or other revenue streams. [ENUM-REF-CANDIDATE: national_tv|local_tv|digital|syndication|licensing|upfront|scatter|programmatic|sponsorship|multi_platform — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Certified Flag' ;
    rdfs:comment 'Boolean flag indicating whether the sales representative is certified and authorized to sell digital advertising inventory, including OTT, streaming, and programmatic channels.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the sales representative was hired or onboarded into the sales organization.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Performance classification or tier assigned to the sales representative based on quota attainment and sales metrics. Used for recognition, compensation adjustments, and coaching.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quota Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the quota amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Quota Period End Date' ;
    rdfs:comment 'End date of the current quota period for the sales representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotaPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Quota Period Start Date' ;
    rdfs:comment 'Start date of the current quota period for the sales representative. Typically aligns with fiscal year or calendar year.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repName rdf:type rdf:Property ;
    rdfs:label 'Rep Name' ;
    rdfs:comment 'Full legal name of the sales representative as it appears in business records and communications.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repStatus rdf:type rdf:Property ;
    rdfs:label 'Rep Status' ;
    rdfs:comment 'Current operational status of the sales representative within the sales organization. Indicates whether they are actively selling, on leave, or no longer with the company.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceUserReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce User Reference' ;
    rdfs:comment 'Unique user identifier in Salesforce Media Cloud CRM system. Links the sales rep record to their Salesforce user profile for opportunity tracking and pipeline management.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryAssignment rdf:type rdf:Property ;
    rdfs:label 'Territory Assignment' ;
    rdfs:comment 'Geographic or market territory assigned to the sales representative. May be defined by region, DMA (Designated Market Area), or account segment.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfrontCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Upfront Certified Flag' ;
    rdfs:comment 'Boolean flag indicating whether the sales representative is certified and authorized to negotiate and close upfront advertising deals. Upfront deals are advance commitments made during the annual upfront sales event.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentTerritorySalesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Territory Sales Territory Id' ;
    rdfs:comment 'Identifier of the parent territory in a hierarchical territory structure. Null for top-level territories.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTerritory .

ind:accountCount rdf:type rdf:Property ;
    rdfs:label 'Account Count' ;
    rdfs:comment 'Number of active advertiser or agency accounts assigned to this territory.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountSegment rdf:type rdf:Property ;
    rdfs:label 'Account Segment' ;
    rdfs:comment 'Classification of accounts within this territory by size or relationship type: enterprise (largest accounts), major (key accounts), mid_market, small_business, agency (advertising agencies), or direct (direct advertisers).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmaList rdf:type rdf:Property ;
    rdfs:label 'Dma List' ;
    rdfs:comment 'Comma-separated list of Nielsen DMA codes or names included in this territory for broadcast market segmentation.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Textual description of the geographic area covered by this territory (e.g., states, DMAs, postal codes, countries). Free-form field for complex geographic definitions.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineFocus rdf:type rdf:Property ;
    rdfs:label 'Product Line Focus' ;
    rdfs:comment 'Primary advertising product lines or inventory types this territory is authorized to sell (e.g., Linear TV, Digital Video, OTT/Streaming, Radio, Display, Sponsorships). Comma-separated for multiple product lines.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Amount' ;
    rdfs:comment 'Annual or period revenue quota assigned to this territory, used for quota allocation and performance tracking.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueTargetCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the revenue target amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scatterMarketFlag rdf:type rdf:Property ;
    rdfs:label 'Scatter Market Flag' ;
    rdfs:comment 'Indicates whether this territory handles scatter market (last-minute, short-term) ad inventory sales. True if scatter sales are part of territory scope.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Description' ;
    rdfs:comment 'Detailed textual description of the territory scope, coverage rules, special conditions, and strategic objectives.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the territory: active (in use), inactive (not currently assigned), pending (awaiting activation), suspended (temporarily disabled), or archived (historical record).' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfrontParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Upfront Participation Flag' ;
    rdfs:comment 'Indicates whether this territory participates in annual upfront advertising sales events. True if territory is included in upfront planning and commitments.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verticalIndustryFocus rdf:type rdf:Property ;
    rdfs:label 'Vertical Industry Focus' ;
    rdfs:comment 'Primary industry vertical or sector this territory specializes in (e.g., Automotive, Pharmaceutical, Retail, Entertainment, Financial Services, Technology). Used for vertical-based territory models.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availId rdf:type rdf:Property ;
    rdfs:label 'Avail Id' ;
    rdfs:comment 'Unique identifier for the advertising inventory availability record.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesRepId rdf:type rdf:Property ;
    rdfs:label 'Sales Rep Id' ;
    rdfs:comment 'Reference to the sales representative responsible for selling this inventory.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:availCode rdf:type rdf:Property ;
    rdfs:label 'Avail Code' ;
    rdfs:comment 'Business identifier code for this availability record, typically generated by the traffic system.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorCpmUsd rdf:type rdf:Property ;
    rdfs:label 'Floor Cpm Usd' ;
    rdfs:comment 'Minimum Cost Per Thousand Impressions (CPM) rate in USD that the seller will accept for this inventory.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorRateUsd rdf:type rdf:Property ;
    rdfs:label 'Floor Rate Usd' ;
    rdfs:comment 'Minimum unit rate in USD that the seller will accept for this advertising slot.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Expiry Timestamp' ;
    rdfs:comment 'Date and time when the current hold on this inventory will expire if not confirmed.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdPlacedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Placed Timestamp' ;
    rdfs:comment 'Date and time when the current hold was placed on this inventory.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current reservation status of this inventory (available, first hold, second hold, third hold, released, sold, expired). [ENUM-REF-CANDIDATE: available|first_hold|second_hold|third_hold|released|sold|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryType rdf:type rdf:Property ;
    rdfs:label 'Inventory Type' ;
    rdfs:comment 'Type of advertising unit available for sale (spot, sponsorship, integration, digital pre-roll, mid-roll, post-roll, overlay, branded content). [ENUM-REF-CANDIDATE: spot|sponsorship|integration|pre_roll|mid_roll|post_roll|overlay|branded_content — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preemptibleFlag rdf:type rdf:Property ;
    rdfs:label 'Preemptible Flag' ;
    rdfs:comment 'Indicates whether this inventory can be preempted by higher-priority advertising (true) or is guaranteed (false).' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:projectedGrp rdf:type rdf:Property ;
    rdfs:label 'Projected Grp' ;
    rdfs:comment 'Estimated Gross Rating Points this slot is expected to deliver, representing the percentage of the target audience reached multiplied by frequency.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedImpressions rdf:type rdf:Property ;
    rdfs:label 'Projected Impressions' ;
    rdfs:comment 'Estimated number of viewer impressions this advertising slot is expected to deliver based on historical audience data.' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Unit Length Seconds' ;
    rdfs:comment 'Duration of the advertising unit in seconds (e.g., 15, 30, 60 for traditional spots).' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:titleRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Title Relationship Id' ;
    rdfs:comment 'Unique identifier for the title relationship record. Primary key.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentTitleRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Parent Title Relationship Id' ;
    rdfs:comment 'Self-referencing FK on title_relationship (parent_title_relationship_id)' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TitleRelationship .

ind:sourceTitleId rdf:type rdf:Property ;
    rdfs:label 'Source Title Id' ;
    rdfs:comment 'The originating content title in the relationship. References the title that serves as the starting point of the relationship (e.g., the original film in a sequel relationship, the parent series in a spin-off).' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:targetTitleId rdf:type rdf:Property ;
    rdfs:label 'Target Title Id' ;
    rdfs:comment 'The destination content title in the relationship. References the title that is the result or endpoint of the relationship (e.g., the sequel film, the spin-off series, the remake).' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:bidirectionalFlag rdf:type rdf:Property ;
    rdfs:label 'Bidirectional Flag' ;
    rdfs:comment 'Indicates whether the relationship should be surfaced in both directions (e.g., show sequel on original AND show original on sequel). True for symmetric relationships like franchise siblings or crossovers, false for asymmetric relationships like clip-of or compilation.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:canonicalOrder rdf:type rdf:Property ;
    rdfs:label 'Canonical Order' ;
    rdfs:comment 'The sequence position of the target title within a series or franchise when viewed in canonical order (e.g., Episode IV is canonical_order 4 in Star Wars franchise). Null for non-sequential relationships like remakes or crossovers.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chronologicalOrder rdf:type rdf:Property ;
    rdfs:label 'Chronological Order' ;
    rdfs:comment 'The sequence position of the target title when viewed in story chronological order (e.g., Episode I is chronological_order 1 in Star Wars despite being released later). Null for non-sequential relationships.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayPriority rdf:type rdf:Property ;
    rdfs:label 'Display Priority' ;
    rdfs:comment 'Numeric ranking (lower numbers = higher priority) controlling the order in which related titles are displayed in user interfaces, Electronic Program Guides (EPG), and recommendation carousels. Enables editorial control over content discovery presentation.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:editorialNotes rdf:type rdf:Property ;
    rdfs:label 'Editorial Notes' ;
    rdfs:comment 'Free-text notes from content editors or curators explaining the nature, context, or nuances of the relationship. May include information about shared characters, plot connections, or reasons for the relationship classification.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformVisibility rdf:type rdf:Property ;
    rdfs:label 'Platform Visibility' ;
    rdfs:comment 'Comma-separated list of platforms or distribution channels where this relationship should be surfaced (e.g., OTT, Linear, SVOD, AVOD, FAST). Enables platform-specific content discovery strategies. Empty or null indicates visibility across all platforms.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationWeight rdf:type rdf:Property ;
    rdfs:label 'Recommendation Weight' ;
    rdfs:comment 'Numeric weight (0.00 to 100.00) indicating the priority or relevance of this relationship for recommendation engine algorithms. Higher weights indicate stronger recommendation signals. Used to tune content discovery and auto-play sequences.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipDirection rdf:type rdf:Property ;
    rdfs:label 'Relationship Direction' ;
    rdfs:comment 'Indicates the directionality of the relationship. Forward means source points to target, reverse means target points back to source, bidirectional means the relationship is mutual and non-hierarchical (e.g., franchise siblings).' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStrength rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength' ;
    rdfs:comment 'Indicates the strength or importance of the relationship for content discovery and recommendation purposes. Primary relationships are direct and essential (e.g., direct sequel), secondary are significant but less direct (e.g., shared universe), tertiary are weak connections (e.g., cameo appearance), tangential are loosely related (e.g., similar theme).' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'The nature of the relationship between the source and target titles. Defines how the two content assets are connected (e.g., sequel indicates target follows source chronologically, spin-off indicates target derives characters/universe from source, remake indicates target is a new version of source). [ENUM-REF-CANDIDATE: sequel|prequel|remake|reboot|spin-off|compilation|clip-of|franchise-sibling|crossover|adaptation|parody|documentary-of|behind-the-scenes — promote to reference product]' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseOrder rdf:type rdf:Property ;
    rdfs:label 'Release Order' ;
    rdfs:comment 'The sequence position of the target title in the order of original release or premiere dates within the franchise or relationship set. Supports viewing content in historical release sequence.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the user, editor, or system that verified the accuracy of this relationship. Null for unverified relationships. Supports audit trail and quality assurance.' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastId rdf:type rdf:Property ;
    rdfs:label 'Forecast Id' ;
    rdfs:comment 'Unique identifier for the revenue forecast record.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorForecastId rdf:type rdf:Property ;
    rdfs:label 'Prior Forecast Id' ;
    rdfs:comment 'Self-referencing FK on forecast (prior_forecast_id)' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Forecast .

ind:attainmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Attainment Percentage' ;
    rdfs:comment 'Percentage of quota represented by the total forecasted revenue (forecasted revenue / quota * 100).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bestCaseRevenue rdf:type rdf:Property ;
    rdfs:label 'Best Case Revenue' ;
    rdfs:comment 'Revenue amount in the best case forecast category (optimistic scenario including stretch opportunities).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:broadcastYear rdf:type rdf:Property ;
    rdfs:label 'Broadcast Year' ;
    rdfs:comment 'Broadcast year (September to August cycle) this forecast applies to, represented as the starting calendar year.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carriageRevenue rdf:type rdf:Property ;
    rdfs:label 'Carriage Revenue' ;
    rdfs:comment 'Forecasted revenue from carriage fee agreements (distribution payments from cable/satellite providers).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closedRevenue rdf:type rdf:Property ;
    rdfs:label 'Closed Revenue' ;
    rdfs:comment 'Revenue amount from deals already closed and won during this forecast period.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitRevenue rdf:type rdf:Property ;
    rdfs:label 'Commit Revenue' ;
    rdfs:comment 'Revenue amount in the commit forecast category (high confidence deals expected to close).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'Fiscal quarter this forecast applies to (Q1, Q2, Q3, Q4).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastName rdf:type rdf:Property ;
    rdfs:label 'Forecast Name' ;
    rdfs:comment 'Descriptive name for the forecast record, typically including period and rep name.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Number' ;
    rdfs:comment 'Business-readable unique identifier for the forecast submission.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle status of the forecast record.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingRevenue rdf:type rdf:Property ;
    rdfs:label 'Licensing Revenue' ;
    rdfs:comment 'Forecasted revenue from content licensing deals (selling rights to broadcast or distribute content).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerOverrideAmount rdf:type rdf:Property ;
    rdfs:label 'Manager Override Amount' ;
    rdfs:comment 'Revenue amount adjusted by sales manager override, used when manager believes rep forecast needs correction.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Manager Override Reason' ;
    rdfs:comment 'Explanation provided by sales manager for any override adjustment to the forecast.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Time period granularity for this forecast: quarter, broadcast year (Sept-Aug), calendar year, or month.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineRevenue rdf:type rdf:Property ;
    rdfs:label 'Pipeline Revenue' ;
    rdfs:comment 'Revenue amount in the pipeline forecast category (possible deals still in early stages).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaAmount rdf:type rdf:Property ;
    rdfs:label 'Quota Amount' ;
    rdfs:comment 'Assigned sales quota target for this sales rep and period.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scatterRevenue rdf:type rdf:Property ;
    rdfs:label 'Scatter Revenue' ;
    rdfs:comment 'Forecasted revenue from scatter market deals (last-minute ad inventory sales outside upfront commitments).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:syndicationRevenue rdf:type rdf:Property ;
    rdfs:label 'Syndication Revenue' ;
    rdfs:comment 'Forecasted revenue from syndication deals (reselling content to multiple outlets).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalForecastedRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Forecasted Revenue' ;
    rdfs:comment 'Total projected revenue amount for this forecast period across all deal types and categories.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updateFrequency rdf:type rdf:Property ;
    rdfs:label 'Update Frequency' ;
    rdfs:comment 'Expected frequency of forecast updates for this period: weekly (standard selling periods), daily (upfront season), monthly (long-range planning), ad hoc (as needed).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfrontRevenue rdf:type rdf:Property ;
    rdfs:label 'Upfront Revenue' ;
    rdfs:comment 'Forecasted revenue from upfront deals (advance advertising commitments made during upfront season).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToQuota rdf:type rdf:Property ;
    rdfs:label 'Variance To Quota' ;
    rdfs:comment 'Difference between total forecasted revenue and quota amount (positive indicates over-quota forecast, negative indicates gap).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightedPipelineValue rdf:type rdf:Property ;
    rdfs:label 'Weighted Pipeline Value' ;
    rdfs:comment 'Total pipeline value adjusted by probability weights for each opportunity, providing a risk-adjusted forecast.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentVendorId rdf:type rdf:Property ;
    rdfs:label 'Parent Vendor Id' ;
    rdfs:comment 'Reference to the parent vendor if this vendor is a subsidiary or division of a larger vendor organization, enabling hierarchical vendor relationships.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:insuranceCertificateExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Expiration Date' ;
    rdfs:comment 'The date on which the vendor\'s current insurance certificate expires, requiring renewal for continued partnership.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minorityOwnedFlag rdf:type rdf:Property ;
    rdfs:label 'Minority Owned Flag' ;
    rdfs:comment 'Boolean indicator of whether the vendor is certified as a minority-owned business enterprise.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'The overall performance rating of the vendor based on delivery quality, timeliness, and service level adherence.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Boolean indicator of whether the vendor has preferred status for priority consideration in content acquisition and partnership opportunities.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'The assessed risk level associated with doing business with this vendor based on financial stability, compliance history, and operational reliability.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smallBusinessFlag rdf:type rdf:Property ;
    rdfs:label 'Small Business Flag' ;
    rdfs:comment 'Boolean indicator of whether the vendor qualifies as a small business under applicable regulatory definitions.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'The externally-known unique business identifier or code assigned to the vendor for operational reference.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'The full legal name of the vendor organization as registered for business purposes.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current lifecycle status of the vendor relationship indicating whether the vendor is actively engaged, suspended, or terminated.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Classification of the vendor based on their role in the media ecosystem (e.g., studio, syndicator, content provider, MVPD, distributor, production company).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:womanOwnedFlag rdf:type rdf:Property ;
    rdfs:label 'Woman Owned Flag' ;
    rdfs:comment 'Boolean indicator of whether the vendor is certified as a woman-owned business enterprise.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:masterPartnerAgreementId rdf:type rdf:Property ;
    rdfs:label 'Master Partner Agreement Id' ;
    rdfs:comment 'Self-referencing FK on partner_agreement (master_partner_agreement_id)' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Human-readable name or title of the partner agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Period Years' ;
    rdfs:comment 'Duration in years that confidentiality obligations remain in effect after agreement termination.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentCategory rdf:type rdf:Property ;
    rdfs:label 'Content Category' ;
    rdfs:comment 'Primary category of content covered by this agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractOwner rdf:type rdf:Property ;
    rdfs:label 'Contract Owner' ;
    rdfs:comment 'Name or identifier of the business unit or individual responsible for managing this agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValueAmount rdf:type rdf:Property ;
    rdfs:label 'Contract Value Amount' ;
    rdfs:comment 'Total monetary value of the partner agreement over its full term.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Contract Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the contract value amount.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference identifier or storage location for the physical or digital contract document.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction and governing law applicable to this agreement (e.g., State of California, UK Law).' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'Maximum liability amount specified in the agreement for breach or damages.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required for termination or non-renewal of the agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceGuaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Amount' ;
    rdfs:comment 'Monetary value of performance guarantees or minimum commitments specified in the agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentEquipmentItemId rdf:type rdf:Property ;
    rdfs:label 'Parent Equipment Item Id' ;
    rdfs:comment 'Self-referencing FK on equipment_item (parent_equipment_item_id)' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentItem .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original purchase price or acquisition cost of the equipment item in the organization\'s base currency.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetTag rdf:type rdf:Property ;
    rdfs:label 'Asset Tag' ;
    rdfs:comment 'Externally-visible unique asset tag or barcode identifier affixed to the physical equipment for tracking and inventory purposes.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:condition rdf:type rdf:Property ;
    rdfs:label 'Condition' ;
    rdfs:comment 'Assessment of the physical condition and operational readiness of the equipment item.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentValue rdf:type rdf:Property ;
    rdfs:label 'Current Value' ;
    rdfs:comment 'Current estimated market or book value of the equipment item, reflecting depreciation and condition.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyRentalRate rdf:type rdf:Property ;
    rdfs:label 'Daily Rental Rate' ;
    rdfs:comment 'Daily rental cost for this equipment item if it is rented, in the organization\'s base currency.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method used to calculate depreciation of this equipment item over its useful life.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Method by which this equipment item was disposed of after retirement from service.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentItemName rdf:type rdf:Property ;
    rdfs:label 'Equipment Item Name' ;
    rdfs:comment 'Human-readable name or title of the equipment item for identification and display purposes.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentItemStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Item Status' ;
    rdfs:comment 'Current operational status of the equipment item in its lifecycle.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReturnDate rdf:type rdf:Property ;
    rdfs:label 'Expected Return Date' ;
    rdfs:comment 'Scheduled date when the equipment item is expected to be returned from its current assignment.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiration Date' ;
    rdfs:comment 'Date when the current insurance coverage for this equipment item expires.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isRental rdf:type rdf:Property ;
    rdfs:label 'Is Rental' ;
    rdfs:comment 'Indicates whether this equipment item is rented from an external vendor rather than owned by the organization.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date when the most recent maintenance, inspection, or service was performed on this equipment item.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Interval Days' ;
    rdfs:comment 'Standard number of days between scheduled maintenance activities for this equipment item.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next required maintenance or inspection of this equipment item.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technicalSpecifications rdf:type rdf:Property ;
    rdfs:label 'Technical Specifications' ;
    rdfs:comment 'Detailed technical specifications, capabilities, and features of this equipment item relevant to production use.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUsageHours rdf:type rdf:Property ;
    rdfs:label 'Total Usage Hours' ;
    rdfs:comment 'Cumulative total hours of operational usage recorded for this equipment item since acquisition.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful life of the equipment item in years for depreciation and replacement planning purposes.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer or vendor warranty coverage for this equipment item expires.' ;
    rdfs:domain ind:EquipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adobeExperienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Adobe Experience Segment Id' ;
    rdfs:comment 'External identifier linking this offer to the corresponding audience segment in Adobe Experience Platform for personalization.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:supersededOfferId rdf:type rdf:Property ;
    rdfs:label 'Superseded Offer Id' ;
    rdfs:comment 'Self-referencing FK on offer (superseded_offer_id)' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offer .

ind:adSupportedFlag rdf:type rdf:Property ;
    rdfs:label 'Ad Supported Flag' ;
    rdfs:comment 'Indicates whether this offer includes advertising (AVOD model) or is ad-free.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bundleEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Bundle Eligible Flag' ;
    rdfs:comment 'Indicates whether this offer can be bundled with other service offerings.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Commitment Period Months' ;
    rdfs:comment 'Minimum commitment period in months required for this offer. Nullable for no-commitment offers.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:concurrentStreams rdf:type rdf:Property ;
    rdfs:label 'Concurrent Streams' ;
    rdfs:comment 'Maximum number of simultaneous streams allowed under this offer.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentQuality rdf:type rdf:Property ;
    rdfs:label 'Content Quality' ;
    rdfs:comment 'Maximum video quality resolution available under this offer (Standard Definition, High Definition, 4K Ultra HD, 8K).' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDevices rdf:type rdf:Property ;
    rdfs:label 'Max Devices' ;
    rdfs:comment 'Maximum number of devices that can be registered under this offer.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerCode rdf:type rdf:Property ;
    rdfs:label 'Offer Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code for the offer, used in marketing campaigns and promotional materials.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerDescription rdf:type rdf:Property ;
    rdfs:label 'Offer Description' ;
    rdfs:comment 'Detailed description of the offer including benefits, features, and terms presented to subscribers.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerName rdf:type rdf:Property ;
    rdfs:label 'Offer Name' ;
    rdfs:comment 'Human-readable name of the offer displayed to subscribers and in marketing materials.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Status' ;
    rdfs:comment 'Current lifecycle status of the offer indicating its availability and operational state.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerType rdf:type rdf:Property ;
    rdfs:label 'Offer Type' ;
    rdfs:comment 'Classification of the offer based on its business purpose and target audience.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Amount' ;
    rdfs:comment 'The standard price amount charged for this offer per billing cycle.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privacyPolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Version' ;
    rdfs:comment 'Version identifier of the privacy policy applicable to this offer at the time of creation.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'The intended subscriber segment for this offer.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAndConditionsUrl rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Url' ;
    rdfs:comment 'URL to the legal terms and conditions document for this offer.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zuoraProductRatePlanCode rdf:type rdf:Property ;
    rdfs:label 'Zuora Product Rate Plan Code' ;
    rdfs:comment 'External identifier linking this offer to the corresponding product rate plan in Zuora billing system.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewCallId rdf:type rdf:Property ;
    rdfs:label 'Crew Call Id' ;
    rdfs:comment 'Unique surrogate identifier for this crew call record. Primary key for the association.' ;
    rdfs:domain ind:CrewCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Actual Hours Worked' ;
    rdfs:comment 'The actual number of hours this crew member worked on this shoot day, from their call time to their individual wrap time. Used for payroll calculation and overtime determination.' ;
    rdfs:domain ind:CrewCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callStatus rdf:type rdf:Property ;
    rdfs:label 'Call Status' ;
    rdfs:comment 'Lifecycle status of this crew call: scheduled (on call sheet), confirmed (crew acknowledged), checked_in (crew arrived on set), wrapped (crew released), no_show (crew failed to appear), cancelled (shoot day cancelled or crew released before call).' ;
    rdfs:domain ind:CrewCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Flag' ;
    rdfs:comment 'Indicates whether this specific crew member incurred overtime hours on this shoot day. Used for payroll processing and budget tracking. Derived from actual hours worked vs contracted hours.' ;
    rdfs:domain ind:CrewCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelToLocationFlag rdf:type rdf:Property ;
    rdfs:label 'Travel To Location Flag' ;
    rdfs:comment 'Indicates whether this crew member is required to travel to a distant location for this shoot day, triggering per diem and travel time compensation.' ;
    rdfs:domain ind:CrewCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionMembershipId rdf:type rdf:Property ;
    rdfs:label 'Collection Membership Id' ;
    rdfs:comment 'Unique identifier for this collection membership record. Primary key.' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addedByUser rdf:type rdf:Property ;
    rdfs:label 'Added By User' ;
    rdfs:comment 'Username or identifier of the user who added this asset to the collection. Used for audit trail and editorial accountability. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Added Timestamp' ;
    rdfs:comment 'Date and time when this asset was added to the collection. Used for audit trail and membership history tracking. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inclusionEndDate rdf:type rdf:Property ;
    rdfs:label 'Inclusion End Date' ;
    rdfs:comment 'Effective end date for this asset\'s inclusion in the collection, used for time-windowed distribution packages and rights management. Null if inclusion is indefinite.' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inclusionStartDate rdf:type rdf:Property ;
    rdfs:label 'Inclusion Start Date' ;
    rdfs:comment 'Effective start date for this asset\'s inclusion in the collection, used for time-windowed distribution packages and rights management.' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inclusionStatus rdf:type rdf:Property ;
    rdfs:label 'Inclusion Status' ;
    rdfs:comment 'Current lifecycle status of this membership: active (currently included), pending (queued for inclusion), removed (excluded from collection), archived (historical record). Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipRole rdf:type rdf:Property ;
    rdfs:label 'Membership Role' ;
    rdfs:comment 'Classification of the asset\'s role within the collection: primary (main content), supplemental (related content), bonus (extras), trailer (preview), promo (promotional material). Determines how the asset is used in distribution and presentation.' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removedByUser rdf:type rdf:Property ;
    rdfs:label 'Removed By User' ;
    rdfs:comment 'Username or identifier of the user who removed this asset from the collection, if applicable. Null if membership is still active.' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Removed Timestamp' ;
    rdfs:comment 'Date and time when this asset was removed from the collection, if applicable. Null if membership is still active. Used for membership lifecycle tracking.' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packageTitleId rdf:type rdf:Property ;
    rdfs:label 'Package Title Id' ;
    rdfs:comment 'Primary key uniquely identifying each package-title inclusion record' ;
    rdfs:domain ind:PackageTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inclusionDate rdf:type rdf:Property ;
    rdfs:label 'Inclusion Date' ;
    rdfs:comment 'The date when this specific title was added to the package, used for tracking package evolution and content refresh cycles' ;
    rdfs:domain ind:PackageTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Price Contribution Amount' ;
    rdfs:comment 'The allocated or attributed pricing value of this title within the package bundle, used for revenue allocation and package valuation' ;
    rdfs:domain ind:PackageTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:removalDate rdf:type rdf:Property ;
    rdfs:label 'Removal Date' ;
    rdfs:comment 'The date when this title was removed from the package, null if still active. Used for tracking package content changes and rights expiration.' ;
    rdfs:domain ind:PackageTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:segmentMembershipId rdf:type rdf:Property ;
    rdfs:label 'Segment Membership Id' ;
    rdfs:comment 'Unique surrogate identifier for this segment membership record' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentAudienceProfileId rdf:type rdf:Property ;
    rdfs:label 'Segment Audience Profile Id' ;
    rdfs:comment 'Foreign key linking to the audience profile that is a member of this segment' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceProfile .

ind:segmentProfileAudienceProfileId rdf:type rdf:Property ;
    rdfs:label 'Segment Profile Audience Profile Id' ;
    rdfs:comment 'Foreign key linking to the audience profile that is a member of this segment' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceProfile .

ind:aepSegmentMembership rdf:type rdf:Property ;
    rdfs:label 'Aep Segment Membership' ;
    rdfs:comment 'Comma-delimited list of Adobe Experience Platform (AEP) audience segment IDs to which this profile currently belongs. Segments represent behavioral, demographic, or propensity-based audience groups used for personalization, ad targeting, and journey activation. [Moved from audience_profile: This comma-delimited list of segment IDs on audience_profile is a denormalized representation of the many-to-many relationship. It should be replaced by properly normalized segment_membership records with full lifecycle attributes.]' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEvaluatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Evaluated Timestamp' ;
    rdfs:comment 'Timestamp when this membership was last evaluated against the segment definition logic to confirm continued qualification' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:membershipScore rdf:type rdf:Property ;
    rdfs:label 'Membership Score' ;
    rdfs:comment 'Confidence or affinity score (0.00-100.00) indicating how strongly this audience profile matches the segment definition criteria' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformDeviceCertificationId rdf:type rdf:Property ;
    rdfs:label 'Platform Device Certification Id' ;
    rdfs:comment 'Unique surrogate identifier for each platform-device certification record. Primary key.' ;
    rdfs:domain ind:PlatformDeviceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationNotes rdf:type rdf:Property ;
    rdfs:label 'Certification Notes' ;
    rdfs:comment 'Free-text notes documenting certification test results, known issues, or special configuration requirements for this device-platform pairing.' ;
    rdfs:domain ind:PlatformDeviceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSupportedResolution rdf:type rdf:Property ;
    rdfs:label 'Max Supported Resolution' ;
    rdfs:comment 'The maximum video resolution certified for streaming on this device-platform pairing. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:PlatformDeviceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedDrmLevel rdf:type rdf:Property ;
    rdfs:label 'Supported Drm Level' ;
    rdfs:comment 'The DRM security level certified for this device-platform combination (e.g., Widevine L1, L2, L3). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:PlatformDeviceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
