ind:nabcepExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Nabcep Expiration Date' ;
    rdfs:comment 'Expiration date of the NABCEP certification, requiring renewal to maintain certified status.' ;
    rdfs:domain ind:DerInstaller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Program Enrollment Date' ;
    rdfs:comment 'Date the installer was accepted into the utilitys approved installer program.' ;
    rdfs:domain ind:DerInstaller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceTerritoryCoverage rdf:type rdf:Property ;
