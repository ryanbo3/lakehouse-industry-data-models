    rdfs:range xsd:string .

ind:specializationTechnologies rdf:type rdf:Property ;
    rdfs:label 'Specialization Technologies' ;
    rdfs:comment 'Pipe-delimited list of DER technology types the installer specializes in (e.g., Solar PV, Battery Storage, EV Chargers, Wind, CHP). Helps match installers to customer needs.' ;
    rdfs:domain ind:DerInstaller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapacityInstalledKw rdf:type rdf:Property ;
