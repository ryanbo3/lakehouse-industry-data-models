    rdfs:comment 'Total number of DER systems installed by this installer within the utilitys service territory. Indicates installer experience level.' ;
    rdfs:domain ind:DerInstaller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date the installer completed required utility interconnection training program. May be prerequisite for approved installer program enrollment.' ;
    rdfs:domain ind:DerInstaller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:websiteUrl rdf:type rdf:Property ;
