ind:pnodeStatus rdf:type rdf:Property ;
    rdfs:label 'Pnode Status' ;
    rdfs:comment 'Current lifecycle status of the node.' ;
    rdfs:domain ind:Pnode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenancePlanPartsRequirementId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Plan Parts Requirement Id' ;
    rdfs:comment 'Unique identifier for this maintenance plan parts requirement record. Primary key.' ;
    rdfs:domain ind:MaintenancePlanPartsRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alternativePartGroupCode rdf:type rdf:Property ;
    rdfs:label 'Alternative Part Group Code' ;
    rdfs:comment 'Reference to an approved alternative parts group or equivalency list. When substitution_allowed_flag is True, this code identifies which substitute parts are acceptable for this maintenance plan requirement.' ;
    rdfs:domain ind:MaintenancePlanPartsRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionType rdf:type rdf:Property ;
    rdfs:label 'Consumption Type' ;
    rdfs:comment 'Classification of how this part is consumed in the maintenance plan. PLANNED parts are always used; CONTINGENT parts are used only if inspection reveals need; EMERGENCY_SPARE parts are staged but only consumed if failure occurs during maintenance.' ;
    rdfs:domain ind:MaintenancePlanPartsRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityForPlan rdf:type rdf:Property ;
    rdfs:label 'Criticality For Plan' ;
    rdfs:comment 'Criticality rating of this specific part within the context of this maintenance plan. A part may be CRITICAL for one plan (e.g., transformer oil for transformer maintenance) but LOW for another. Drives material availability assurance and expediting decisions.' ;
    rdfs:domain ind:MaintenancePlanPartsRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedUnitCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Cost Usd' ;
    rdfs:comment 'Estimated unit cost of this spare part at the time of maintenance plan definition. Used for maintenance plan cost estimation and budgeting. May differ from current inventory valuation due to price changes or plan-specific procurement terms.' ;
    rdfs:domain ind:MaintenancePlanPartsRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeBufferDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Buffer Days' ;
    rdfs:comment 'Additional lead time buffer (in days) beyond the part\'s standard procurement lead time, specific to this maintenance plan. Accounts for plan-specific logistics complexity, vendor coordination, or regulatory approval requirements. Used to calculate material order trigger dates.' ;
    rdfs:domain ind:MaintenancePlanPartsRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredQuantity rdf:type rdf:Property ;
    rdfs:label 'Required Quantity' ;
    rdfs:comment 'Planned quantity of this spare part required per execution of the maintenance plan. Used for material staging and inventory consumption forecasting. Unit of measure aligns with the spare part\'s base UOM.' ;
    rdfs:domain ind:MaintenancePlanPartsRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Allowed Flag' ;
    rdfs:comment 'Indicates whether an alternative or substitute part can be used if the specified part is unavailable. True allows substitution per approved equivalency list; False requires exact part (common for OEM-specific or safety-critical components).' ;
    rdfs:domain ind:MaintenancePlanPartsRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upgradeCostAllocationId rdf:type rdf:Property ;
    rdfs:label 'Upgrade Cost Allocation Id' ;
    rdfs:comment 'Primary key for the upgrade_cost_allocation association' ;
    rdfs:domain ind:UpgradeCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Payment Date' ;
    rdfs:comment 'Date when the applicant actually paid their cost share for this upgrade. Used for financial reconciliation and queue position management.' ;
    rdfs:domain ind:UpgradeCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Determination Date' ;
    rdfs:comment 'Date when the utility finalized the cost allocation determination for this application-upgrade pair, typically upon completion of the cluster study or independent study.' ;
    rdfs:domain ind:UpgradeCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costAllocationNotes rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Notes' ;
    rdfs:comment 'Free-text notes explaining special circumstances, adjustments, or rationale for this specific cost allocation. Used for regulatory audit trail and dispute resolution.' ;
    rdfs:domain ind:UpgradeCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:switchingStepId rdf:type rdf:Property ;
    rdfs:label 'Switching Step Id' ;
    rdfs:comment 'Unique identifier for this switching step. Primary key for the association.' ;
    rdfs:domain ind:SwitchingStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Timestamp' ;
    rdfs:comment 'Actual date and time when this switching step was executed. Used for audit trail and performance analysis.' ;
    rdfs:domain ind:SwitchingStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedDeviceState rdf:type rdf:Property ;
    rdfs:label 'Confirmed Device State' ;
    rdfs:comment 'Actual confirmed device state after operation execution. May differ from expected state if operation failed.' ;
    rdfs:domain ind:SwitchingStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationType rdf:type rdf:Property ;
    rdfs:label 'Operation Type' ;
    rdfs:comment 'Type of switching operation to be performed on the device. Critical for safety procedures and device state management.' ;
    rdfs:domain ind:SwitchingStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Operator Confirmation Flag' ;
    rdfs:comment 'Indicates whether the operator has confirmed successful execution and device state verification for this step. Required for NERC CIP compliance.' ;
    rdfs:domain ind:SwitchingStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postOperationPosition rdf:type rdf:Property ;
    rdfs:label 'Post Operation Position' ;
    rdfs:comment 'Expected device position after successful execution of this step. Used for confirmation and validation.' ;
    rdfs:domain ind:SwitchingStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preOperationPosition rdf:type rdf:Property ;
    rdfs:label 'Pre Operation Position' ;
    rdfs:comment 'Required device position before this step can be executed. Used for safety verification and operational validation.' ;
    rdfs:domain ind:SwitchingStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyClearanceVerified rdf:type rdf:Property ;
    rdfs:label 'Safety Clearance Verified' ;
    rdfs:comment 'Indicates whether required safety clearances were verified before step execution. Critical for worker safety compliance.' ;
    rdfs:domain ind:SwitchingStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scadaCommandSent rdf:type rdf:Property ;
    rdfs:label 'Scada Command Sent' ;
    rdfs:comment 'Indicates whether a SCADA remote control command was sent for this step (for automated devices). False for manual operations.' ;
    rdfs:domain ind:SwitchingStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Timestamp' ;
    rdfs:comment 'Planned date and time for execution of this switching step. Part of the switching order schedule.' ;
    rdfs:domain ind:SwitchingStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stepCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Step Completion Status' ;
    rdfs:comment 'Current execution status of this switching step. Tracks progression through the step lifecycle.' ;
    rdfs:domain ind:SwitchingStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Step Sequence Number' ;
    rdfs:comment 'Sequential order of this step within the parent switching order. Determines execution order for safety and operational correctness.' ;
    rdfs:domain ind:SwitchingStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rpsPpaContributionId rdf:type rdf:Property ;
    rdfs:label 'Rps Ppa Contribution Id' ;
    rdfs:comment 'Primary key for the rps_ppa_contribution association' ;
    rdfs:domain ind:RpsPpaContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of this PPA contract\'s total annual output allocated to this specific RPS obligation. Used when a single PPA contract is split across multiple state jurisdictions or compliance obligations.' ;
    rdfs:domain ind:RpsPpaContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carveoutTier rdf:type rdf:Property ;
    rdfs:label 'Carveout Tier' ;
    rdfs:comment 'Technology-specific carve-out tier that this contribution satisfies (solar, offshore_wind, storage, general_renewable). RPS obligations have technology-specific requirements, and this attribute tracks which tier each PPA contribution fulfills.' ;
    rdfs:domain ind:RpsPpaContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionMwh rdf:type rdf:Property ;
    rdfs:label 'Contribution Mwh' ;
    rdfs:comment 'Quantity of renewable energy in MWh from this PPA contract that is allocated toward satisfying this specific RPS obligation. This is the core compliance metric tracked for regulatory reporting.' ;
    rdfs:domain ind:RpsPpaContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recRetirementQuantity rdf:type rdf:Property ;
    rdfs:label 'Rec Retirement Quantity' ;
    rdfs:comment 'Quantity of RECs in MWh retired from this PPA contract to satisfy this RPS obligation. May differ from contribution_mwh if RECs are banked or purchased separately.' ;
    rdfs:domain ind:RpsPpaContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .
