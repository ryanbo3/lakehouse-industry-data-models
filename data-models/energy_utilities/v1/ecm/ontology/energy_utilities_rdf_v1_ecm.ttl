    rdfs:range xsd:decimal .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the recurring entry template.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateType rdf:type rdf:Property ;
    rdfs:label 'Template Type' ;
    rdfs:comment 'Category of the recurring entry template indicating its financial purpose.' ;
    rdfs:domain ind:EnergyUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentGroupId rdf:type rdf:Property ;
    rdfs:label 'Parent Group Id' ;
    rdfs:comment 'Identifier of the parent cost element group for hierarchical grouping.' ;
