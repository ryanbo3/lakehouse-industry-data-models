ind:postingDayOfMonth rdf:type rdf:Property ;
    rdfs:label 'Posting Day Of Month' ;
    rdfs:comment 'Day of month on which the entry is posted when frequency is monthly or higher.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingMonth rdf:type rdf:Property ;
    rdfs:label 'Posting Month' ;
    rdfs:comment 'Month of year for annual postings; null for other frequencies.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
