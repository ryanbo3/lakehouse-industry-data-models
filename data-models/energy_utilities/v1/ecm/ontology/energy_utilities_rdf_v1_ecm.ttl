    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'General telephone number for the contractor company.' ;
    rdfs:domain ind:ContractorCompany ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rating rdf:type rdf:Property ;
    rdfs:label 'Rating' ;
    rdfs:comment 'Aggregated rating (e.g., 0-5) based on performance, safety, and compliance.' ;
