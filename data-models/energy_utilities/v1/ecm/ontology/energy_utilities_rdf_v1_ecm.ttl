ind:groupCode rdf:type rdf:Property ;
    rdfs:label 'Group Code' ;
    rdfs:comment 'Short alphanumeric code used to reference the cost element group in external systems.' ;
    rdfs:domain ind:CostElementGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupName rdf:type rdf:Property ;
    rdfs:label 'Group Name' ;
    rdfs:comment 'Human-readable name of the cost element group.' ;
    rdfs:domain ind:CostElementGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupType rdf:type rdf:Property ;
    rdfs:label 'Group Type' ;
    rdfs:comment 'Classification of the group indicating its accounting nature.' ;
    rdfs:domain ind:CostElementGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeprecated rdf:type rdf:Property ;
    rdfs:label 'Is Deprecated' ;
    rdfs:comment 'Indicates whether the group is deprecated and should no longer be used for new postings.' ;
    rdfs:domain ind:CostElementGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rabValuationMethod rdf:type rdf:Property ;
    rdfs:label 'Rab Valuation Method' ;
    rdfs:comment 'Method used to value the group for regulatory asset base calculations.' ;
    rdfs:domain ind:CostElementGroup ;
