    rdfs:comment 'Date the entity was legally formed.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industryCode rdf:type rdf:Property ;
    rdfs:label 'Industry Code' ;
    rdfs:comment 'Six-digit NAICS code representing the entity\'s primary industry.' ;
    rdfs:domain ind:EnergyUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPublic rdf:type rdf:Property ;
    rdfs:label 'Is Public' ;
    rdfs:comment 'True if the entity is publicly listed; otherwise false.' ;
    rdfs:domain ind:EnergyUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityStatusDate rdf:type rdf:Property ;
