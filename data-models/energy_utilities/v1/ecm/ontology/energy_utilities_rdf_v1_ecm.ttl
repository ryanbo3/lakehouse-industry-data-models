    rdfs:comment 'Comma-separated list of sustainability or environmental certifications held by the contractor.' ;
    rdfs:domain ind:ContractorCompany ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSqft rdf:type rdf:Property ;
