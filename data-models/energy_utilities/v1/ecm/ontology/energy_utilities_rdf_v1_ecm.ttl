ind:notificationTemplateId rdf:type rdf:Property ;
    rdfs:label 'Notification Template Id' ;
    rdfs:comment 'Reference to the template used for automated alerts.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MessageTemplate .

ind:activationCriteria rdf:type rdf:Property ;
    rdfs:label 'Activation Criteria' ;
    rdfs:comment 'Conditions that trigger the activation of the plan.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualResponseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Response Time Minutes' ;
    rdfs:comment 'Measured time taken to start response during the last activation.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deactivationCriteria rdf:type rdf:Property ;
    rdfs:label 'Deactivation Criteria' ;
    rdfs:comment 'Conditions that signal the plan can be retired or paused.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Drill Frequency Days' ;
    rdfs:comment 'Number of days between scheduled emergency drills.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drillResultsSummary rdf:type rdf:Property ;
    rdfs:label 'Drill Results Summary' ;
    rdfs:comment 'High-level findings and lessons learned from the last drill.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedResponseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Response Time Minutes' ;
    rdfs:comment 'Target time to initiate response after an event is detected.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isTestPlan rdf:type rdf:Property ;
    rdfs:label 'Is Test Plan' ;
    rdfs:comment 'True if the plan is used for testing or training purposes only.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDrillDate rdf:type rdf:Property ;
    rdfs:label 'Last Drill Date' ;
    rdfs:comment 'Date of the most recent emergency drill.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationMeasures rdf:type rdf:Property ;
    rdfs:label 'Mitigation Measures' ;
    rdfs:comment 'Key actions defined to reduce impact during an emergency.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceRequirements rdf:type rdf:Property ;
    rdfs:label 'Resource Requirements' ;
    rdfs:comment 'Summary of personnel, equipment, and material needed to execute the plan.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Organizational department accountable for maintaining the plan.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Number of months between mandatory plan reviews.' ;
    rdfs:domain ind:EnergyUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountClassification rdf:type rdf:Property ;
    rdfs:label 'Account Classification' ;
    rdfs:comment 'Indicates whether the account is domestic or foreign for regulatory reporting.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'Legal name of the individual or entity that holds the account; may contain PII.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranch rdf:type rdf:Property ;
    rdfs:label 'Bank Branch' ;
    rdfs:comment 'Specific branch or location of the bank where the account is held.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum credit amount authorized for the vendor on this account.' ;
    rdfs:domain ind:EnergyUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'Standardized international account identifier for cross-border transactions.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'True if this is the vendor\'s primary bank account for payments.' ;
    rdfs:domain ind:EnergyUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when the bank account details were last validated by finance.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Domestic routing number (e.g., ABA) used to identify the bank in national payments.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutomated rdf:type rdf:Property ;
    rdfs:label 'Is Automated' ;
    rdfs:comment 'Flag indicating whether the payment run was generated automatically by a scheduled job.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentRunType rdf:type rdf:Property ;
    rdfs:label 'Payment Run Type' ;
    rdfs:comment 'Categorization of the payment run purpose.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPayments rdf:type rdf:Property ;
    rdfs:label 'Total Payments' ;
    rdfs:comment 'Number of individual payment line items included in this run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetsProcessedCount rdf:type rdf:Property ;
    rdfs:label 'Assets Processed Count' ;
    rdfs:comment 'Number of individual fixed-asset records included in the depreciation calculation.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorFlag rdf:type rdf:Property ;
    rdfs:label 'Error Flag' ;
    rdfs:comment 'Indicates whether any errors occurred (true) or the run completed without errors (false).' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:errorsCount rdf:type rdf:Property ;
    rdfs:label 'Errors Count' ;
    rdfs:comment 'Number of errors or exceptions encountered during the run.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Net Depreciation Amount' ;
    rdfs:comment 'Final depreciation amount after adjustments; used for financial reporting.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:period rdf:type rdf:Property ;
    rdfs:label 'Period' ;
    rdfs:comment 'Quarterly reporting period for the depreciation run.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rabValuation rdf:type rdf:Property ;
    rdfs:label 'Rab Valuation' ;
    rdfs:comment 'Valuation of the asset base used for regulatory accounting, captured at run time.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Flag' ;
    rdfs:comment 'True if the run is generated for regulatory reporting purposes (e.g., FERC).' ;
    rdfs:domain ind:EnergyUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runDescription rdf:type rdf:Property ;
    rdfs:label 'Run Description' ;
    rdfs:comment 'Free-form text describing the purpose or special characteristics of the run.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Total Depreciation Amount' ;
    rdfs:comment 'Gross sum of depreciation calculated in the run before any adjustments.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waccUsed rdf:type rdf:Property ;
    rdfs:label 'Wacc Used' ;
    rdfs:comment 'WACC percentage applied in the depreciation calculations for cost of capital considerations.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentWbsElementId rdf:type rdf:Property ;
    rdfs:label 'Parent Wbs Element Id' ;
    rdfs:comment 'Identifier of the immediate parent WBS element in the hierarchy.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:isSummary rdf:type rdf:Property ;
    rdfs:label 'Is Summary' ;
    rdfs:comment 'Indicates whether the element aggregates child elements (true) or represents a leaf work package (false).' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wbsCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Code' ;
    rdfs:comment 'Hierarchical alphanumeric code that uniquely identifies the WBS element within the project hierarchy (e.g., 1.2.3).' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsLevel rdf:type rdf:Property ;
    rdfs:label 'Wbs Level' ;
    rdfs:comment 'Numeric depth of the element within the WBS hierarchy (root = 1).' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wbsName rdf:type rdf:Property ;
    rdfs:label 'Wbs Name' ;
    rdfs:comment 'Human-readable name or title of the WBS element.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsPath rdf:type rdf:Property ;
    rdfs:label 'Wbs Path' ;
    rdfs:comment 'Concatenated path of WBS codes from root to this element (e.g., 1/1.2/1.2.3).' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsType rdf:type rdf:Property ;
    rdfs:label 'Wbs Type' ;
    rdfs:comment 'Category of the WBS element indicating its role in the project hierarchy.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAccount rdf:type rdf:Property ;
    rdfs:label 'Credit Account' ;
    rdfs:comment 'GL account to be credited when the template is applied.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitAccount rdf:type rdf:Property ;
    rdfs:label 'Debit Account' ;
    rdfs:comment 'GL account to be debited when the template is applied.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Recurrence interval for the journal entry generated from the template.' ;
    rdfs:domain ind:EnergyUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intervalMultiplier rdf:type rdf:Property ;
    rdfs:label 'Interval Multiplier' ;
    rdfs:comment 'Multiplier applied to the base frequency (e.g., every 2 weeks).' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether the recurring entry amount is subject to tax.' ;
