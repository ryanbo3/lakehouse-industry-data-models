    rdfs:range xsd:string .

ind:numberOfEmployees rdf:type rdf:Property ;
    rdfs:label 'Number Of Employees' ;
    rdfs:comment 'Total headcount employed by the entity.' ;
    rdfs:domain ind:EnergyUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryContactRole rdf:type rdf:Property ;
