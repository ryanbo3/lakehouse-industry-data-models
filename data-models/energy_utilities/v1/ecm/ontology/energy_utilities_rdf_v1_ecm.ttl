ind:planningCycleCode rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle Code' ;
    rdfs:comment 'Short code representing the planning cycle (e.g., "FY24", "Q2-2024").' ;
    rdfs:domain ind:PlanningPeriod ;
    rdf:type owl:DatatypeProperty ;
