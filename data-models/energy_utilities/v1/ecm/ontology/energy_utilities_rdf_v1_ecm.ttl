    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Indicates whether this period is the default selection for new forecasts.' ;
    rdfs:domain ind:EnergyUtilities ;
    rdf:type owl:DatatypeProperty ;
