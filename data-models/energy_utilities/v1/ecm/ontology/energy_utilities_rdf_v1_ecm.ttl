    rdfs:range xsd:string .

ind:corridorName rdf:type rdf:Property ;
    rdfs:label 'Corridor Name' ;
    rdfs:comment 'Human-readable name of the corridor used in reports and maps.' ;
    rdfs:domain ind:RightOfWayCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorType rdf:type rdf:Property ;
    rdfs:label 'Corridor Type' ;
    rdfs:comment 'Category of the corridor indicating the type of infrastructure it carries.' ;
