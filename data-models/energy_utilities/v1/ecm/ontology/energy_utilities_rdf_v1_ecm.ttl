    rdfs:comment 'Identifier of the internal party responsible for the plan.' ;
    rdfs:domain ind:RecoveryPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:backupLocation rdf:type rdf:Property ;
    rdfs:label 'Backup Location' ;
    rdfs:comment 'Physical or logical location where backups are stored.' ;
    rdfs:domain ind:RecoveryPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupMethod rdf:type rdf:Property ;
    rdfs:label 'Backup Method' ;
    rdfs:comment 'Method used for backing up data for recovery.' ;
    rdfs:domain ind:RecoveryPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationPlan rdf:type rdf:Property ;
    rdfs:label 'Communication Plan' ;
