    rdfs:comment 'Identifier of the immediate parent legal entity, if any.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:ultimateParentLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Ultimate Parent Legal Entity Id' ;
    rdfs:comment 'Identifier of the top-most parent legal entity in the corporate hierarchy.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:annualRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue' ;
    rdfs:comment 'Total revenue reported for the most recent fiscal year.' ;
    rdfs:domain ind:EnergyUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessSegment rdf:type rdf:Property ;
    rdfs:label 'Business Segment' ;
    rdfs:comment 'Primary business segment or line of operation for the entity.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:country rdf:type rdf:Property ;
    rdfs:label 'Country' ;
    rdfs:comment 'Three-letter ISO country code of the entity\'s primary location.' ;
    rdfs:domain ind:EnergyUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
