ind:runName rdf:type rdf:Property ;
    rdfs:label 'Run Name' ;
    rdfs:comment 'Human-readable name describing the market run (e.g., "DA 2024-05-01").' ;
    rdfs:domain ind:MarketRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNotes rdf:type rdf:Property ;
    rdfs:label 'Run Notes' ;
    rdfs:comment 'Free-form comments or observations about the run.' ;
    rdfs:domain ind:MarketRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runPriority rdf:type rdf:Property ;
    rdfs:label 'Run Priority' ;
    rdfs:comment 'Numeric priority used to order runs when multiple are scheduled.' ;
    rdfs:domain ind:MarketRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runResultSummary rdf:type rdf:Property ;
    rdfs:label 'Run Result Summary' ;
    rdfs:comment 'Brief textual summary of key outcomes from the run.' ;
    rdfs:domain ind:MarketRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatusReason rdf:type rdf:Property ;
    rdfs:label 'Run Status Reason' ;
    rdfs:comment 'Explanation for the current status, especially when failed or cancelled.' ;
    rdfs:domain ind:MarketRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runVersion rdf:type rdf:Property ;
    rdfs:label 'Run Version' ;
    rdfs:comment 'Version identifier for the run logic or configuration.' ;
    rdfs:domain ind:MarketRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testRunFlag rdf:type rdf:Property ;
    rdfs:label 'Test Run Flag' ;
    rdfs:comment 'True if the run was executed for testing or validation purposes.' ;
    rdfs:domain ind:MarketRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalValueUsd rdf:type rdf:Property ;
    rdfs:label 'Total Value Usd' ;
    rdfs:comment 'Total monetary value of the cleared energy, expressed in US dollars.' ;
    rdfs:domain ind:MarketRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeMwh rdf:type rdf:Property ;
    rdfs:label 'Total Volume Mwh' ;
    rdfs:comment 'Aggregate energy volume cleared by the run, measured in megawatt-hours.' ;
    rdfs:domain ind:MarketRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constraintDirection rdf:type rdf:Property ;
    rdfs:label 'Constraint Direction' ;
    rdfs:comment 'Direction of power flow to which the constraint applies.' ;
    rdfs:domain ind:TransmissionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintGroup rdf:type rdf:Property ;
    rdfs:label 'Constraint Group' ;
    rdfs:comment 'Logical group identifier for related constraints (e.g., corridor group).' ;
    rdfs:domain ind:TransmissionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintOwner rdf:type rdf:Property ;
    rdfs:label 'Constraint Owner' ;
    rdfs:comment 'Entity (e.g., utility, transmission operator) that owns or administers the constraint.' ;
    rdfs:domain ind:TransmissionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintPriority rdf:type rdf:Property ;
    rdfs:label 'Constraint Priority' ;
    rdfs:comment 'Numeric priority used for conflict resolution when multiple constraints overlap.' ;
    rdfs:domain ind:TransmissionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:constraintRegion rdf:type rdf:Property ;
    rdfs:label 'Constraint Region' ;
    rdfs:comment 'Geographic region or ISO/RTO jurisdiction where the constraint applies.' ;
    rdfs:domain ind:TransmissionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintSource rdf:type rdf:Property ;
    rdfs:label 'Constraint Source' ;
    rdfs:comment 'Originating system or application that supplied the constraint data (e.g., OpenLink Endur).' ;
    rdfs:domain ind:TransmissionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintStatusReason rdf:type rdf:Property ;
    rdfs:label 'Constraint Status Reason' ;
    rdfs:comment 'Free-text reason explaining the current status (e.g., maintenance, regulatory hold).' ;
    rdfs:domain ind:TransmissionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintZone rdf:type rdf:Property ;
    rdfs:label 'Constraint Zone' ;
    rdfs:comment 'Specific market zone or congestion zone impacted by the constraint.' ;
    rdfs:domain ind:TransmissionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatory rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory' ;
    rdfs:comment 'True if the constraint is mandated by a regulator (e.g., FERC).' ;
    rdfs:domain ind:TransmissionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lmpImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Lmp Impact Flag' ;
    rdfs:comment 'Indicates whether the constraint directly influences Locational Marginal Pricing.' ;
    rdfs:domain ind:TransmissionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingRequirement rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirement' ;
    rdfs:comment 'Regulatory reporting regime applicable to the constraint.' ;
    rdfs:domain ind:TransmissionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillaryServiceEligible rdf:type rdf:Property ;
    rdfs:label 'Ancillary Service Eligible' ;
    rdfs:comment 'True if the delivery point can provide or receive ancillary services.' ;
    rdfs:domain ind:Trading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:congestionPriceZone rdf:type rdf:Property ;
    rdfs:label 'Congestion Price Zone' ;
    rdfs:comment 'Identifier of the congestion pricing zone applicable to the delivery point.' ;
    rdfs:domain ind:DeliveryPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGridConnected rdf:type rdf:Property ;
    rdfs:label 'Is Grid Connected' ;
    rdfs:comment 'Indicates whether the delivery point is physically connected to the transmission grid.' ;
    rdfs:domain ind:DeliveryPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMeterReadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Meter Read Timestamp' ;
    rdfs:comment 'Date-time of the most recent meter reading.' ;
    rdfs:domain ind:DeliveryPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:meterReadingIntervalMinutes rdf:type rdf:Property ;
    rdfs:label 'Meter Reading Interval Minutes' ;
    rdfs:comment 'Scheduled interval between meter reads.' ;
    rdfs:domain ind:DeliveryPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metered rdf:type rdf:Property ;
    rdfs:label 'Metered' ;
    rdfs:comment 'Indicates whether the delivery point has an active meter for usage measurement.' ;
    rdfs:domain ind:DeliveryPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:curveCode rdf:type rdf:Property ;
    rdfs:label 'Curve Code' ;
    rdfs:comment 'Business code or ticker used to reference the price curve in trading systems.' ;
    rdfs:domain ind:PriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveName rdf:type rdf:Property ;
    rdfs:label 'Curve Name' ;
    rdfs:comment 'Human-readable name describing the price curve.' ;
    rdfs:domain ind:PriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveType rdf:type rdf:Property ;
    rdfs:label 'Curve Type' ;
    rdfs:comment 'Classification of the curve based on market usage or calculation method.' ;
    rdfs:domain ind:PriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interpolationMethod rdf:type rdf:Property ;
    rdfs:label 'Interpolation Method' ;
    rdfs:comment 'Algorithm used to derive intermediate price values between defined points.' ;
    rdfs:domain ind:PriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointCount rdf:type rdf:Property ;
    rdfs:label 'Point Count' ;
    rdfs:comment 'Total number of price points contained in the curve.' ;
    rdfs:domain ind:PriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractAmount rdf:type rdf:Property ;
    rdfs:label 'Contract Amount' ;
    rdfs:comment 'Total monetary value of the agreement, expressed in the contract currency.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractCurrency rdf:type rdf:Property ;
    rdfs:label 'Contract Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code used for monetary amounts in the agreement.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendedBy rdf:type rdf:Property ;
    rdfs:label 'Last Amended By' ;
    rdfs:comment 'User identifier of the person who performed the most recent update.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingMechanism rdf:type rdf:Property ;
    rdfs:label 'Pricing Mechanism' ;
    rdfs:comment 'Method used to calculate energy price under the agreement.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCycle rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle' ;
    rdfs:comment 'Frequency at which financial settlement occurs for the contract.' ;
    rdfs:domain ind:EnergyUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days the party must notify the counter-party before terminating the agreement.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeMwh rdf:type rdf:Property ;
    rdfs:label 'Volume Mwh' ;
    rdfs:comment 'Total energy volume committed under the agreement, measured in megawatt-hours.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ultimateParentId rdf:type rdf:Property ;
    rdfs:label 'Ultimate Parent Id' ;
    rdfs:comment 'Identifier of the top-most parent entity in the corporate structure.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:businessLine rdf:type rdf:Property ;
    rdfs:label 'Business Line' ;
    rdfs:comment 'Specific line of business the entity participates in.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Country Of Incorporation' ;
    rdfs:comment 'ISO 3166-1 alpha-3 code of the country where the entity was incorporated.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultProbability rdf:type rdf:Property ;
    rdfs:label 'Default Probability' ;
    rdfs:comment 'Probability of default for the entity as calculated by risk models.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalEntityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Identifier' ;
    rdfs:comment 'Global identifier for the legal entity as defined by ISO 17442.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityType rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Type' ;
    rdfs:comment 'Category describing the legal form of the entity.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sector rdf:type rdf:Property ;
    rdfs:label 'Sector' ;
    rdfs:comment 'Broad business sector in which the entity operates.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substationId rdf:type rdf:Property ;
    rdfs:label 'Substation Id' ;
    rdfs:comment 'Identifier of the substation associated with the flowgate.' ;
    rdfs:domain ind:Flowgate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransmissionSubstation .

ind:nextInspectionDue rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due' ;
    rdfs:comment 'Planned date for the next inspection of the flowgate.' ;
