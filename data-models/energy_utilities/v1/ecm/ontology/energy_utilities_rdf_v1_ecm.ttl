    rdfs:comment 'Date when the current status became effective.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:market rdf:type rdf:Property ;
    rdfs:label 'Market' ;
    rdfs:comment 'Name of the exchange where the entity\'s securities are listed.' ;
    rdfs:domain ind:EnergyUtilities ;
