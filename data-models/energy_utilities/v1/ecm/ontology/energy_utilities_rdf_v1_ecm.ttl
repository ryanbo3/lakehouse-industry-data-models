    rdfs:comment 'Primary business purpose of the node within the utility\'s processes.' ;
    rdfs:domain ind:Pnode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endSubstationId rdf:type rdf:Property ;
