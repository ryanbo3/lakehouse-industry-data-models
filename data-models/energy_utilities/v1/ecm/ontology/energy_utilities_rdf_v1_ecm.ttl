ind:typicalFlowMw rdf:type rdf:Property ;
    rdfs:label 'Typical Flow Mw' ;
    rdfs:comment 'Average historical power flow through the flowgate in megawatts.' ;
    rdfs:domain ind:Flowgate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interconnectionPointFlag rdf:type rdf:Property ;
