ind:isPercentageBased rdf:type rdf:Property ;
    rdfs:label 'Is Percentage Based' ;
    rdfs:comment 'Indicates whether the rule uses a percentage rate instead of a fixed amount.' ;
    rdfs:domain ind:SettlementRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:percentageRate rdf:type rdf:Property ;
    rdfs:label 'Percentage Rate' ;
    rdfs:comment 'Percentage rate applied when the rule is percentage based (e.g., 2.5%).' ;
    rdfs:domain ind:SettlementRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roundingMethod rdf:type rdf:Property ;
    rdfs:label 'Rounding Method' ;
    rdfs:comment 'Rounding approach applied to the calculated settlement amount.' ;
    rdfs:domain ind:SettlementRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Version identifier for the rule, allowing tracking of changes over time.' ;
    rdfs:domain ind:SettlementRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Inclusion Flag' ;
    rdfs:comment 'True if taxes are included in the settlement amount; otherwise false.' ;
    rdfs:domain ind:SettlementRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Forecast Horizon Days' ;
    rdfs:comment 'Number of days ahead for which forecasts are generated within this period.' ;
    rdfs:domain ind:PlanningPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:horizonDays rdf:type rdf:Property ;
    rdfs:label 'Horizon Days' ;
    rdfs:comment 'Total number of days covered by the planning period.' ;
