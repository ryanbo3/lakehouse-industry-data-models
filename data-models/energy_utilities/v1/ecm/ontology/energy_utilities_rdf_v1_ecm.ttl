ind:contractorType rdf:type rdf:Property ;
    rdfs:label 'Contractor Type' ;
    rdfs:comment 'Category describing the primary business focus of the contractor.' ;
    rdfs:domain ind:ContractorCompany ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'General email address for the contractor company.' ;
    rdfs:domain ind:ContractorCompany ;
