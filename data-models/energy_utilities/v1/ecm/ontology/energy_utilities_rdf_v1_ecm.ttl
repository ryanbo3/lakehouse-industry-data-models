ind:parentCompanyId rdf:type rdf:Property ;
    rdfs:label 'Parent Company Id' ;
    rdfs:comment 'Identifier of the parent organization if the contractor is a subsidiary.' ;
    rdfs:domain ind:EnergyUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnergyUtilities .

ind:bondCompany rdf:type rdf:Property ;
    rdfs:label 'Bond Company' ;
