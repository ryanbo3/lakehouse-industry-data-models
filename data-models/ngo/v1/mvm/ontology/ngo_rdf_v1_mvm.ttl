# RDFS Schema for Business: Ngo

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/ngo#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Ngo ---
ind:Ngo rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Ngo' ;
    rdfs:comment 'Nonprofit Organizations are mission-driven entities providing humanitarian aid, disaster relief, health services, education, and community development programs to vulnerable and underserved populations worldwide.' .

# --- Domain Classes ---
ind:Beneficiary rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ngo ;
    rdfs:label 'Beneficiary' ;
    rdfs:comment 'Single source of truth for all individuals, households, and communities served by humanitarian and development programs. Owns beneficiary identity, registration, vulnerability profiling, needs assessments, consent management, and case management. Covers IDPs, PoCs (Persons of Concern), GBV survivors, and all target populations tracked in CommCare and KoboToolbox.' .

ind:Program rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ngo ;
    rdfs:label 'Program' ;
    rdfs:comment 'Owns the design, planning, and lifecycle management of all humanitarian and development interventions including WASH, health, nutrition, education, protection, and livelihood programs. Captures Theory of Change (ToC), LogFrame, SDG alignment, sector classifications, RBM (Results-Based Management) frameworks, and program hierarchies from proposal through closeout.' .

ind:Grant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ngo ;
    rdfs:label 'Grant' ;
    rdfs:comment 'Authoritative domain for all grant awards, funding agreements, and donor contracts. Manages grant lifecycle from proposal development and submission through award, amendment, budget tracking, compliance, and closeout. Tracks donor conditions, restricted vs. unrestricted funding, NICRA/ICR rates, and compliance obligations under USAID, BHA, DFID, CERF, and OMB Uniform Guidance 2 CFR 200.' .

ind:Donor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ngo ;
    rdfs:label 'Donor' ;
    rdfs:comment 'SSOT for all donor and funder relationships including institutional donors (USAID, DFID, UN agencies, DAC members), foundations, corporate sponsors, and individual major gift contributors. Manages donor cultivation, prospect research, stewardship, gift processing, pledge management, and CRM constituent engagement in Salesforce Nonprofit Cloud and Raisers Edge NXT.' .

ind:Field rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ngo ;
    rdfs:label 'Field' ;
    rdfs:comment 'Manages field operations, country offices, project sites, humanitarian response logistics, and day-to-day service delivery including distribution events, site management, NFI distributions, WASH interventions, and mobile health outreach. Integrates GIS-based location data, SitRep generation, mobile data collection via KoboToolbox, field assessments (FGD, KII), and OCHA cluster coordination activities.' .

ind:Mel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ngo ;
    rdfs:label 'Mel' ;
    rdfs:comment 'Owns all Monitoring, Evaluation, and Learning (MEL) and MEAL framework data. Manages indicator libraries, LogFrame targets vs. actuals, KPI tracking, PDM (Post-Distribution Monitoring) results, FGD and KII records, DHIS2 aggregate reporting, outcome measurement, impact assessments, and Results-Based Management (RBM) evidence. Supports DAC evaluation criteria and donor performance reporting.' .

ind:Supply rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ngo ;
    rdfs:label 'Supply' ;
    rdfs:comment 'Manages the humanitarian supply chain including procurement, warehousing, inventory of NFIs (Non-Food Items) and medical supplies, last-mile logistics, vendor management, commodity pipelines, in-kind donations, distribution planning, and emergency relief commodities to support field delivery operations.' .

ind:Volunteer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ngo ;
    rdfs:label 'Volunteer' ;
    rdfs:comment 'Manages volunteer recruitment, onboarding, deployment, scheduling, training, recognition, and contribution tracking. Distinct from paid workforce, covers community health workers, field volunteers, and event-based supporters. Tracks volunteer hours, skills, certifications, and engagement across programs coordinated through Microsoft Dynamics 365.' .

ind:Partnership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ngo ;
    rdfs:label 'Partnership' ;
    rdfs:comment 'Owns all inter-organizational relationship data including MoUs (Memoranda of Understanding), LoAs (Letters of Agreement), SoWs (Scope of Work), and sub-award agreements with CSOs, CBOs, INGOs, government bodies, UN agencies, and consortia. Manages partner capacity assessments, due diligence records, sub-grant management, and coordination with OCHA cluster leads and IASC working groups.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ngo ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Authoritative domain for fund accounting, general ledger (GL), Chart of Accounts (CoA), Budget vs. Actual (BvA) tracking, accounts payable (AP), accounts receivable (AR), restricted fund tracking, NICRA (Negotiated Indirect Cost Rate Agreement), grant financial management, and cost allocation. Ensures compliance with FASB ASC 958, GAAP for nonprofits, and OMB Uniform Guidance in SAP S/4HANA and Unit4 ERP.' .

ind:Workforce rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ngo ;
    rdfs:label 'Workforce' ;
    rdfs:comment 'SSOT for all staff and human resources data including employee records, payroll, benefits, talent acquisition, performance management, learning and development, and talent retention in Workday HCM. Covers national and international staff, expatriate management, field personnel, HRIS data, and RACI role assignments across programs.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ngo ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Manages regulatory filing, statutory reporting, and organizational accountability obligations. Covers IRS 501(c)(3) filings, Charity Commission returns, IATI transparency reporting, CHS self-assessments, HAP accountability frameworks, Single Audit requirements for US federal awards, and organizational governance documentation.' .

# --- Data Product Classes (Tables) ---
ind:StaffMember rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Staff Member' ;
    rdfs:comment 'Core master record for all paid staff at Ngo, including national staff, international staff, expatriates, and field personnel. Captures full employee identity (name, date of birth, nationality, gender), employment classification, contract type, duty station, cost center assignment, emergency contact/next-of-kin details, and HRIS identifiers sourced from Workday HCM. Includes separation lifecycle attributes: separation type (resignation, end of contract, redundancy, termination, retirement, death in service), effective date, exit interview completion, final settlement amount, rehire eligibility, and separation reason narrative. Serves as the SSOT for workforce identity across all HR sub-domains, the anchor entity for all workforce transactions, and the single record of employment lifecycle from hire to separation.' .

ind:Position rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Position' ;
    rdfs:comment 'Authorized organizational position (headcount slot) within Ngos structure, distinct from the person filling it. Tracks position title, grade level, FTE allocation, funding source (grant or core), duty station, department, and whether the position is filled or vacant. Includes embedded job profile catalog: job family, job level, job function, competency requirements, minimum qualifications, pay grade band, and career progression path aligned with Workday HCM job catalog. Supports workforce planning, grant-funded headcount tracking, recruitment requisition creation, RACI role assignments, and organizational design.' .

ind:EmploymentContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Employment Contract' ;
    rdfs:comment 'Formal employment agreement record for each staff member, capturing contract type (fixed-term, open-ended, consultancy, secondment), start and end dates, probation period, notice period, salary grade, base salary, currency, duty station, and applicable labor law jurisdiction. Tracks contract renewals and amendments over time. For internationally-recruited staff, includes full expatriate compensation package: hardship allowance tier and amount, housing allowance, education allowance for dependents, home leave entitlement and frequency, relocation allowance, medical evacuation coverage level, R&R cycle, and applicable INGO salary scale (e.g., UN common system, organizational scale). Supports multi-currency compensation across 50+ country operations. Sourced from Workday HCM.' .

ind:OrgUnit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Org Unit' ;
    rdfs:comment 'Organizational unit hierarchy for Ngo, representing departments, divisions, country offices, area/field offices, program units, and cost centers in a recursive parent-child structure. Captures unit name, unit type (HQ department, regional office, country office, field office, program unit), parent unit reference, geographic location, responsible manager, funding model (core vs grant), and active status. Enables hierarchical reporting of headcount, payroll costs, and program staffing across the global organization.' .

ind:JobProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Job Profile' ;
    rdfs:comment 'Standardized job profile catalog defining roles within Ngo, including job family, job level, competency requirements, minimum qualifications, and pay grade band. Used as the template for position creation and recruitment. Aligned with Workday HCM job catalog and HRIS classification standards.' .

ind:PayrollRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Payroll Run' ;
    rdfs:comment 'Payroll processing cycle record capturing each payroll run executed in Workday HCM, including pay period start and end dates, payroll group (national staff, international staff, expat), run status, total gross pay, total deductions, total net pay, currency, and approval status. Serves as the header record for payroll transactions.' .

ind:Payslip rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Payslip' ;
    rdfs:comment 'Individual payslip record for each staff member per payroll cycle, serving as SSOT for both payroll run processing (pay period start/end dates, payroll group — national/international/expat, run sequence number, run status, batch approval, total run aggregates) and individual pay details (gross salary, allowances — housing/hardship/field/expat, statutory deductions — income tax/social security/pension, voluntary deductions, net pay in local and payment currencies). Multi-currency supported for international operations across 50+ countries. Includes payment method, bank details reference, and payroll run approval chain. Supports BvA (Budget vs Actual) payroll cost allocation to grants and programs, donor audit requirements, and statutory payroll reporting.' .

ind:PerformanceReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Performance Review' ;
    rdfs:comment 'Formal performance appraisal record for a staff member covering a defined review period. Captures review cycle (annual, mid-year, probation), overall rating, competency ratings, objective achievement scores, reviewer identity, reviewee acknowledgment, and development recommendations. Supports Ngo\'s talent retention and results-based management (RBM) culture.' .

ind:LeaveRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Leave Request' ;
    rdfs:comment 'Staff leave request and approval record capturing leave type (annual, sick, maternity/paternity, R&R, compassionate, TOIL), requested start date, end date, number of days, approval status, approver, and actual dates taken. Tracks leave balances and entitlements per staff member and supports field rotation and R&R scheduling for humanitarian staff.' .

ind:StaffAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Staff Assignment' ;
    rdfs:comment 'Record of a staff members assignment to a specific program, project, grant, or field operation, capturing assignment type (primary, secondary, surge deployment, TDY/temporary duty), percentage of time allocated, funding source (grant code), duty station, start date, end date, and RACI role (Responsible, Accountable, Consulted, Informed). Enables time-based payroll cost allocation to grants, supports donor-compliant effort reporting, and tracks RACI role assignments across programs for accountability matrices.' .

ind:PartnerOrg rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partnership ;
    rdfs:label 'Partner Org' ;
    rdfs:comment 'Master record and SSOT for all inter-organizational partners including CSOs (Civil Society Organizations), CBOs (Community-Based Organizations), INGOs (International Non-Governmental Organizations), government bodies, UN agencies, and consortia. Captures organizational identity, registration details (registration number, country of registration, registration date), legal status, countries of operation, organizational type classification, accreditation status, and operational capacity summary. Includes embedded contact records for key personnel: focal points, authorized representatives, technical leads, financial officers, and program coordinators with name, title, role type, communication channels (email, phone, messaging), language preference, and active status. This is the SSOT for partner identity, classification, and contact information in the partnership domain.' .

ind:Agreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partnership ;
    rdfs:label 'Agreement' ;
    rdfs:comment 'Core master record for all formal inter-organizational agreements including MoUs (Memoranda of Understanding), LoAs (Letters of Agreement), SoWs (Scope of Work), sub-award agreements, and consortium agreements. Captures agreement type, effective dates, expiry dates, signatory parties, governing law, agreement scope, funding ceiling, current status, and amendment history references. Includes embedded obligation line-items tracking specific deliverables and commitments: obligation description, responsible party, due date, completion status, evidence of fulfillment, and escalation status. Serves as the SSOT for all partnership legal instruments, their tracked commitments, and obligation monitoring in the partnership domain.' .

ind:CapacityAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partnership ;
    rdfs:label 'Capacity Assessment' ;
    rdfs:comment 'Records formal partner capacity assessments conducted prior to or during partnership engagement. Captures assessment methodology (e.g., USAID OCA, DFID OCAT), assessment date, assessor identity, scores across functional areas (financial management, HR, procurement, governance, MEL), overall risk rating, and recommended capacity-building interventions. Essential for due diligence and risk management.' .

ind:DueDiligenceRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partnership ;
    rdfs:label 'Due Diligence Record' ;
    rdfs:comment 'Formal due diligence and partner verification master record covering legal compliance checks, sanctions screening (OFAC, EU, UN), anti-terrorism certification, financial audit review, governance verification, and regulatory standing. Includes embedded accreditation/certification tracking for CHS (Core Humanitarian Standard), Sphere compliance, HAP membership, ISO certifications, and national NGO registration status with issuing body, certificate number, issue date, expiry date, and verification status. Tracks due diligence type, completion date, outcome, risk level, next review date, and responsible staff. Required for compliance with 2 CFR 200, USAID ADS 303, and donor partner vetting regulations. This is the SSOT for all partner verification, screening, and accreditation data in the partnership domain.' .

ind:PartnerContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partnership ;
    rdfs:label 'Partner Contact' ;
    rdfs:comment 'Master record for individual contacts within partner organizations including focal points, authorized representatives, technical leads, and financial officers. Captures name, title, role type, communication channels, language preference, and active status. Supports relationship management and coordination workflows across the partnership lifecycle.' .

ind:AgreementAmendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partnership ;
    rdfs:label 'Agreement Amendment' ;
    rdfs:comment 'Transactional record capturing formal modifications to existing partnership agreements including scope changes, budget realignments, no-cost extensions, period of performance adjustments, and signatory changes. Tracks amendment number, amendment type, effective date, justification, approval authority, and the specific clauses modified. Maintains the full amendment history of each agreement.' .

ind:PartnerPerformanceReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partnership ;
    rdfs:label 'Partner Performance Review' ;
    rdfs:comment 'Periodic performance review records for implementing partners assessing delivery against agreed SoW milestones, reporting compliance, financial accountability, and programmatic quality. Captures review period, performance rating, key findings, corrective action requirements, and reviewer details. Feeds into partnership renewal and risk management decisions.' .

ind:Consortium rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partnership ;
    rdfs:label 'Consortium' ;
    rdfs:comment 'Master record for multi-partner consortia and joint programming arrangements where Ngo acts as lead agency or member. Captures consortium name, lead organization, governance structure (steering committee composition, decision-making protocols), consortium agreement reference, geographic scope, thematic focus, total funding envelope, and operational status. Supports coordination with OCHA cluster leads, IASC working groups, and pooled fund mechanisms. Essential for Grand Bargain localization commitments and joint donor reporting.' .

ind:PartnerReportSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partnership ;
    rdfs:label 'Partner Report Submission' ;
    rdfs:comment 'Tracks all programmatic and financial reports submitted by implementing partners under their sub-award or agreement obligations. Captures report type (narrative, financial, SitRep, PDM), reporting period, submission date, review status, feedback provided, and acceptance date. Supports compliance monitoring and donor reporting obligations under 2 CFR 200.' .

ind:CapacityBuildingPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partnership ;
    rdfs:label 'Capacity Building Plan' ;
    rdfs:comment 'Master record with embedded activity line-items for structured capacity-building interventions developed for partner organizations based on capacity assessment findings. Plan-level data captures objectives, targeted functional areas (financial management, HR, procurement, governance, MEL), timeline, responsible staff, budget allocation, and overall progress status. Activity-level line-items capture individual trainings, mentoring sessions, technical assistance visits, and peer learning events with delivery dates, facilitators, participant lists, topics covered, pre/post assessment scores, and completion status. Supports localization strategies, partner strengthening, and Grand Bargain commitments. This is the SSOT for all capacity-building planning and delivery tracking in the partnership domain.' .

ind:Registrant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Beneficiary ;
    rdfs:label 'Registrant' ;
    rdfs:comment 'Core master entity for every individual registered as a beneficiary or person of concern (PoC). Stores biographic data (name, date of birth, sex, nationality), unique beneficiary ID, registration source system (CommCare, KoboToolbox), protection flags, deduplication status, and full registration metadata including registration date, location, modality (in-person, mobile, remote), registration tool, registering staff, verification documents presented, completeness score, and deduplication check results. Supports re-registration tracking with historical registration events. Serves as the single identity anchor for all beneficiary-domain transactions. Interoperable with UNHCR proGres v4 individual records, WFP SCOPE beneficiary records, and RAIS case records via standard beneficiary ID mapping.' .

ind:Household rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Beneficiary ;
    rdfs:label 'Household' ;
    rdfs:comment 'Master record for a household unit as the primary unit of registration and service delivery in humanitarian contexts. Captures household composition count, head-of-household reference (FK to registrant), geographic location, community/settlement reference, shelter type, displacement status, and household-level vulnerability indicators. Links individual registrants to their household grouping via household_member association for NFI distribution, WASH assessments, and food security programming. Supports WFP SCOPE household registration and UNHCR proGres family composition interoperability.' .

ind:HouseholdMember rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Beneficiary ;
    rdfs:label 'Household Member' ;
    rdfs:comment 'Association entity linking an individual registrant to their household. Captures role (head, spouse, child, dependent, elderly), relationship to head-of-household, membership start/end dates, and demographic attributes relevant to household composition analysis. Enables NFI distribution sizing, dependency ratio calculations, and vulnerability scoring at household level.' .

ind:VulnerabilityProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Beneficiary ;
    rdfs:label 'Vulnerability Profile' ;
    rdfs:comment 'Structured vulnerability assessment record for a registrant or household capturing multi-dimensional vulnerability indicators including food insecurity score (IPC phase classification), protection risk level, disability classification (Washington Group questions), chronic illness flags, GAM/SAM nutritional status (MUAC measurement), GBV exposure flag, displacement category (IDP, refugee, returnee), and composite vulnerability score used for program targeting and prioritization. Distinct from needs_assessment which captures point-in-time sector-specific assessment findings — vulnerability_profile represents the beneficiary\'s current consolidated vulnerability state derived from multiple assessment inputs. Updated when new assessment data materially changes vulnerability classification.' .

ind:NeedsAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Beneficiary ;
    rdfs:label 'Needs Assessment' ;
    rdfs:comment 'Transactional record of a formal needs assessment conducted for an individual beneficiary, household, or community to determine eligibility, vulnerability level, and appropriate service referrals. Captures assessment date, assessment level (individual, household, community), assessment type (initial registration assessment, periodic reassessment, post-crisis rapid assessment, sector-specific deep assessment), sectors assessed (WASH, nutrition, shelter, protection, livelihoods, education), assessment tool identifier (KoboToolbox form ID, CommCare module), field enumerator, geographic coordinates, and scored findings per sector. Owned by beneficiary domain as it determines beneficiary status and targeting — distinct from MEL post-distribution monitoring which measures program effectiveness. Assessment findings feed into vulnerability_profile updates when they materially change vulnerability classification.' .

ind:ConsentRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Beneficiary ;
    rdfs:label 'Consent Record' ;
    rdfs:comment 'Formal consent management record capturing a beneficiary\'s informed consent for data collection, storage, sharing, and program participation. Stores consent type (data processing, photography, case referral, biometric enrollment), consent status (given, withdrawn, pending), consent date, consent method (verbal, written, digital), language of consent, witness details, and CHS (Core Humanitarian Standard) accountability compliance flags.' .

ind:CaseRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Beneficiary ;
    rdfs:label 'Case Record' ;
    rdfs:comment 'Longitudinal case management record for an individual beneficiary requiring structured follow-up. Captures case type (protection, GBV, child protection, PSS, nutrition, health, livelihoods), status (open, in-progress, on-hold, closed), priority level, assigned caseworker, opening/closing dates, referral pathway, outcome classification, and case narrative. Primary operational entity for CommCare case management workflows.' .

ind:CaseAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Beneficiary ;
    rdfs:label 'Case Action' ;
    rdfs:comment 'Transactional log of individual actions, interventions, and follow-up activities taken within a beneficiary case. Captures action type (home visit, counseling session, referral, service provision, follow-up call), action date, action outcome, responsible staff or volunteer, next action due date, and action notes. Enables case progress tracking and workload management for case workers.' .

ind:Referral rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Beneficiary ;
    rdfs:label 'Referral' ;
    rdfs:comment 'Transactional record of a formal referral of a beneficiary from one service provider, program, or organization to another. Captures referral date, referring organization, receiving organization or service, referral reason, referral type (internal, external, emergency), referral status (pending, accepted, completed, declined), follow-up date, and outcome. Supports inter-agency coordination, GBV referral pathways, and protection case management.' .

ind:ProtectionFlag rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Beneficiary ;
    rdfs:label 'Protection Flag' ;
    rdfs:comment 'Master record of active protection concerns and risk flags associated with a beneficiary or household. Captures flag type (GBV risk, child protection, SGBV survivor, unaccompanied minor, UASC, trafficking risk, forced recruitment), flag severity, flag date, flagging source, current status (active, resolved, monitoring), assigned protection officer, and confidentiality classification. Enables protection mainstreaming across all program sectors.' .

ind:DocumentRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Beneficiary ;
    rdfs:label 'Document Record' ;
    rdfs:comment 'Master record of identity and legal documents associated with a beneficiary, including UNHCR registration certificates, national ID cards, birth certificates, marriage certificates, asylum seeker cards, and travel documents. Captures document type, document number, issuing authority, issue date, expiry date, verification status, and document image reference. Supports identity verification, legal status determination, and protection documentation.' .

ind:ProjectSite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Field ;
    rdfs:label 'Project Site' ;
    rdfs:comment 'Master record for each physical field project site or operational location where humanitarian programs are delivered. Captures site identity, GIS coordinates, administrative boundaries (country, region, district), site type (health post, distribution point, WASH facility, school, camp), operational status, accessibility rating, population catchment area, cluster affiliation, and OCHA P-code. Serves as the geographic anchor for all field operations, service delivery events, and SitRep generation.' .

ind:CountryOffice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Field ;
    rdfs:label 'Country Office' ;
    rdfs:comment 'Master record for each NGO country office or sub-office managing field operations within a specific country or region. Captures office name, ISO country code, office type (country office, sub-office, field hub, liaison office), physical address, operational mandate, registration status with host government, legal entity details, and responsible senior management. Links to project sites, grants, and workforce assignments within that country.' .

ind:DistributionEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Field ;
    rdfs:label 'Distribution Event' ;
    rdfs:comment 'Transactional record of a single distribution event (NFI, food, cash, or voucher) conducted at a project site. Captures event date, site, distribution type (general, targeted, blanket, voucher redemption), planned vs. actual beneficiary count, commodity categories, distribution modality (in-kind, cash, voucher, mobile money), responsible cluster, implementing field team, verification method, and PDM scheduling status. Core operational transaction for field service delivery and the primary unit of work for BvA reconciliation against supply pipeline.' .

ind:DistributionLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Field ;
    rdfs:label 'Distribution Line' ;
    rdfs:comment 'Line-item detail within a distribution event capturing each commodity or NFI item distributed. Records item category, item description, unit of measure, planned quantity, actual quantity distributed, unit value, total value, donor earmarking, and pipeline source. Enables granular tracking of what was distributed per event and supports BvA reconciliation against supply chain records.' .

ind:Assessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Field ;
    rdfs:label 'Assessment' ;
    rdfs:comment 'Master record of a structured field assessment conducted to evaluate needs, context, or program outcomes. Covers all assessment types including FGD (Focus Group Discussion), KII (Key Informant Interview), household survey, rapid needs assessment, PDM (Post-Distribution Monitoring) with linked distribution event and utilization/adequacy scoring, market assessment, and MUAC screening. Captures assessment date, project site, methodology, target population, sample size, assessment team, KoboToolbox or CommCare form ID, data collection tool, key findings summary, recommendations, and assessment status (planned, in-progress, completed, validated). For PDM assessments: captures linked distribution event, sample methodology, utilization rate, adequacy score, beneficiary satisfaction, complaints received, and protection concerns noted. Links to assessment_response for individual submissions. Supports MEL indicator tracking, SitRep generation, CHS compliance, accountability to affected populations (AAP), and donor reporting on program quality.' .

ind:AssessmentResponse rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Field ;
    rdfs:label 'Assessment Response' ;
    rdfs:comment 'Individual survey or interview response record collected during a field assessment, sourced from KoboToolbox or CommCare mobile data collection. Captures respondent anonymized ID, assessment form ID, submission timestamp, GPS coordinates of submission, enumerator ID, response status (submitted, validated, rejected), and key structured response fields (household size, displacement status, primary needs, protection concerns). Enables disaggregated analysis by sex, age, IDP status, and vulnerability category.' .

ind:Sitrep rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Field ;
    rdfs:label 'Sitrep' ;
    rdfs:comment 'Situation Report (SitRep) record capturing operational status for a defined reporting period and geographic scope. Includes reporting period (weekly, bi-weekly, monthly), issuing country office, crisis/emergency context, key achievements by sector (beneficiaries reached, distributions completed, WASH coverage, health consultations), operational constraints and access issues, resource gaps, cluster coordination updates, and submission status to OCHA/donors. Supports HRP progress tracking, CERF/CBPF applications, donor narrative reporting, and inter-agency coordination. Generated from aggregated field transaction data.' .

ind:FieldTeam rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Field ;
    rdfs:label 'Field Team' ;
    rdfs:comment 'Master record for a field team or mobile unit deployed to deliver services at project sites. Captures team name, team type (distribution, CHW, WASH, assessment, protection, rapid response), assigned country office, team leader, team composition and size, operational status (active, standby, disbanded), deployment period, assigned vehicle/transport, communication equipment, and language capabilities. Represents the operational unit of deployment distinct from individual workforce records. Enables workload balancing, team performance tracking, and deployment planning.' .

ind:FieldDeployment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Field ;
    rdfs:label 'Field Deployment' ;
    rdfs:comment 'Transactional record of a field team or individual staff member being deployed to a specific project site for a defined operational period. Captures deployment start and end dates, deploying country office, destination project site, deployed field team or individual, deployment purpose (emergency response, routine program delivery, assessment mission, training, surge support), deployment status (planned, active, completed, cancelled), security clearance level required, travel authorization reference, and handover notes. Field domain owns the operational deployment record linking teams to sites for specific missions; workforce domain owns the underlying HR assignment, duty-of-care obligations, and R&R scheduling.' .

ind:AccessConstraint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Field ;
    rdfs:label 'Access Constraint' ;
    rdfs:comment 'Transactional record documenting a humanitarian access constraint affecting field operations at a specific location or along a supply route. Captures constraint type (active conflict, road blockage, administrative denial, armed actor checkpoint, bureaucratic impediment, weather/natural hazard), affected geographic area, start and resolution dates, severity level (1-5), estimated beneficiaries unreached, impact on planned activities, mitigation actions taken, reporting source (OCHA, UNDSS, INSO, field staff), and escalation status. Feeds access monitoring dashboards, donor reporting on operational challenges, and contingency planning.' .

ind:SecurityIncident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Field ;
    rdfs:label 'Security Incident' ;
    rdfs:comment 'Transactional record of a security incident affecting NGO staff, assets, or operations in the field. Captures incident date, location, incident type (armed robbery, carjacking, staff detention, explosive hazard, civil unrest), affected personnel count, asset damage, incident severity (critical, major, minor), immediate response actions taken, reporting status to UNDSS or INSO, and case closure details. Supports duty-of-care obligations and security risk management.' .

ind:Commodity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Commodity' ;
    rdfs:comment 'Master catalog of all humanitarian commodities and relief items managed in the supply chain, including NFIs (Non-Food Items), medical supplies, WASH materials, food commodities, shelter materials, and emergency relief goods. Defines item specifications, unit of measure, commodity category (e.g., shelter, health, nutrition, WASH), SPHERE standards compliance, shelf life, storage requirements (temperature, humidity), hazardous classification, kit/assembly composition (bill of materials for NFI kits), cold-chain requirements, donor restrictions, and procurement lead time. This is the SSOT for all commodity definitions used across procurement, warehousing, and distribution.' .

ind:Warehouse rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Warehouse' ;
    rdfs:comment 'Master record for all physical storage facilities in the humanitarian supply network including central warehouses, field warehouses, transit hubs, pre-positioning depots, and cold-chain facilities. Captures location (GIS coordinates, country, admin level), storage capacity (m³, pallets), facility type, operational status, managing entity, temperature control capability, and OCHA cluster affiliation. Supports last-mile logistics planning and inventory positioning.' .

ind:Vendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Vendor' ;
    rdfs:comment 'Master record for all suppliers, vendors, service providers, and logistics operators engaged in humanitarian procurement and supply chain operations. Covers commodity suppliers, international manufacturers, freight forwarders, clearing agents, trucking companies, air cargo operators, and last-mile delivery partners. Captures vendor registration details, country of operation, commodity categories supplied, transport modes offered (where applicable), pre-qualification status, performance tier, fleet size (for transport providers), blacklist/debarment flags, UN vendor registration number, compliance certifications (e.g., ISO, GMP), and humanitarian logistics network membership (e.g., WFP LHF, UNHRD). SSOT for all supplier and service provider identity within the supply domain.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Transactional record of all procurement purchase orders issued to vendors for humanitarian commodities and services, including embedded line-item detail (commodity, quantity, unit price, delivery schedule per line). Captures PO number, issuing office, vendor, line items with per-line commodity reference, ordered quantity, unit of measure, agreed unit cost, delivery location, and requested delivery date. Also records total PO value, currency, funding source (grant/donor), delivery terms (Incoterms), expected delivery date, approval workflow status, goods receipt status per line, invoice matching status, and ERP document reference. Supports BvA tracking, three-way matching (PO–GRN–Invoice), and donor-restricted fund compliance per 2 CFR 200 Uniform Guidance.' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Transactional record capturing the physical receipt of commodities at a warehouse or field location against a purchase order or in-kind donation. Records receipt date, receiving warehouse, commodity, quantity received, condition on arrival (good/damaged/expired), batch/lot number, expiry date, receiving officer, discrepancy notes, and SAP goods receipt document number. Triggers inventory update and initiates three-way matching for AP payment processing.' .

ind:InventoryBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Inventory Balance' ;
    rdfs:comment 'Current and historical stock balance records for each commodity at each warehouse location. Captures commodity, warehouse, stock quantity on hand, quantity reserved for distribution, quantity in transit, quantity quarantined, reorder level, maximum stock level, last physical count date, and stock valuation. Supports commodity pipeline management, pre-positioning decisions, and OCHA cluster reporting on pipeline gaps.' .

ind:StockMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Stock Movement' ;
    rdfs:comment 'Transactional log of all inventory movements including receipts, issues, transfers between warehouses, adjustments, physical count reconciliations, losses, and write-offs. Each record captures movement type (receipt/issue/transfer/adjustment/physical_count/loss/write-off), commodity, source location, destination location, quantity, movement date, reference document (GRN/waybill/distribution order/count sheet), reason code, authorizing officer, and count team reference (for physical count adjustments). Provides full commodity pipeline audit trail for donor reporting, IATI transparency, inventory accuracy management, and loss detection.' .

ind:DistributionPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Distribution Plan' ;
    rdfs:comment 'Master plan for the distribution of humanitarian commodities to beneficiaries at field locations. Captures distribution plan name, target program, geographic coverage (country/admin levels), planned distribution date range, target beneficiary count, commodity list with planned quantities per beneficiary, distribution modality (direct/voucher/cash-in-kind), responsible field office, and approval status. Links supply chain planning to field operations and MEL targets.' .

ind:DistributionOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Distribution Order' ;
    rdfs:comment 'Operational order authorizing the release and dispatch of commodities from a warehouse to a field distribution point for beneficiary delivery. Captures order number, originating distribution plan, issuing warehouse, destination distribution point, commodity lines with quantities, dispatch date, transport mode, waybill reference, loading officer, and order status (draft/approved/dispatched/delivered/closed). Triggers stock movement and last-mile logistics execution.' .

ind:Waybill rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Waybill' ;
    rdfs:comment 'Transactional shipping document accompanying commodity movements between warehouses or to distribution points. Records waybill number, dispatch date, origin warehouse, destination location, transporter/carrier, vehicle registration, driver details, commodity lines with dispatched quantities, seal numbers, departure time, arrival time, received quantities, and discrepancy notes. Critical for last-mile accountability, loss tracking, and donor audit compliance.' .

ind:ProcurementRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Procurement Request' ;
    rdfs:comment 'Internal requisition raised by program or field teams requesting procurement of commodities or services. Captures requisition number, requesting unit/program, commodity or service description, quantity, estimated budget, urgency level (routine/urgent/emergency), required delivery date, funding source, justification narrative, and approval workflow status. Initiates the procurement cycle and links program needs to supply chain execution.' .

ind:Shipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Shipment' ;
    rdfs:comment 'Master record for international and domestic commodity shipments including sea freight, air freight, and road transport consignments. Captures shipment reference, origin country/port, destination country/port/warehouse, transport mode, carrier/freight forwarder, container/vehicle details, bill of lading or airway bill number, estimated and actual departure/arrival dates, customs clearance status and documentation (import permits, phytosanitary certificates, exemption letters), duty/tax exemption reference, and total cargo weight/volume. Supports pipeline tracking for pre-positioned emergency stocks, customs broker coordination, and import compliance for humanitarian duty-free privileges under host government agreements.' .

ind:Intervention rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Intervention' ;
    rdfs:comment 'Core master entity representing a humanitarian or development program/intervention (e.g., WASH, health, nutrition, education, protection, livelihoods). Captures the full program lifecycle from design through closeout, including program type (emergency vs. development), phase, status, start/end dates, geographic scope, target population summary, organizational ownership, and SDG alignment mappings (goal, target, indicator, alignment type, contribution narrative). This is the primary anchor entity for the program domain and the SSOT for all program-level identity, metadata, design narrative (situation analysis, intervention logic, targeting strategy, sustainability plan), and strategic framework alignment. All other program domain entities reference this as their parent.' .

ind:Component rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Component' ;
    rdfs:comment 'Hierarchical decomposition of a program intervention into components, sub-components, or workstreams (e.g., a WASH program broken into water supply, sanitation, and hygiene promotion components). Captures component name, description, sector, sub-sector, responsible team, geographic focus, budget envelope, start/end dates, and status. Supports multi-sector and integrated programming models. Enables program hierarchy navigation from intervention down to activity level.' .

ind:TargetPopulation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Target Population' ;
    rdfs:comment 'Defines the intended beneficiary population for a program intervention or component, capturing targeting criteria, geographic scope, demographic profile (age, sex, vulnerability category), estimated population size, targeting methodology (e.g., MUAC screening, vulnerability scoring, community-based targeting), inclusion/exclusion criteria, and IDP/PoC/host community breakdown. Distinct from individual beneficiary registration (owned by beneficiary domain) — this is the program-level population planning entity.' .

ind:ProgramAmendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Program Amendment' ;
    rdfs:comment 'Formal amendment or modification record for a program intervention, capturing changes to scope, budget, timeline, geographic coverage, target population, or LogFrame. Stores amendment number, type (no-cost extension, scope change, budget reallocation, geographic expansion), justification narrative, approval date, approving authority (internal and donor), effective date, and before/after comparison of key parameters. Critical for grant compliance and audit trail.' .

ind:RiskRegister rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Risk Register' ;
    rdfs:comment 'Risk register entry for a program intervention, capturing risk description, category (operational, contextual, institutional, fiduciary), likelihood rating, impact rating, risk score, mitigation measures, contingency plan, risk owner, review date, and current status. Supports program design quality, donor compliance (many donors require risk registers), and adaptive management. Versioned to track risk evolution across the program lifecycle.' .

ind:ImplementationPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Implementation Plan' ;
    rdfs:comment 'Detailed implementation plan (work plan) for a program intervention or component, serving as the operational roadmap for field teams and the baseline for progress tracking. Captures planned activities at the task level including activity name, description, type, responsible parties, timelines (Gantt-style), resource requirements, geographic phasing, target beneficiary counts, status tracking, and linkage to LogFrame outputs. Includes comprehensive milestone tracking (program launch, mid-term review, final evaluation, closeout, donor reporting deadlines) with milestone type, planned/actual dates, completion status, deliverable description, sign-off authority, and dependency sequencing. Stores plan version, planning period, approval status, and last revision date. This is the SSOT for all program scheduling, activity sequencing, and milestone management — the schedule authority for donor reporting timelines and grant compliance.' .

ind:BudgetPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Budget Plan' ;
    rdfs:comment 'Program-level budget plan capturing the approved budget envelope for a program intervention, including line-item detail by cost category (personnel, fringe, travel, equipment, supplies, contractual, other direct costs, indirect costs). Stores total approved budget, currency, budget period, budget version, donor-specific budget codes, indirect cost rate (ICR/NICRA), F&A allocation, unit costs, quantities, and budget status. Distinct from the finance domain\'s GL and BvA tracking — this is the program-level planning budget owned by program management.' .

ind:BudgetPlanLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Budget Plan Line' ;
    rdfs:comment 'Individual budget line item within a program budget, capturing cost category (personnel, fringe, travel, equipment, supplies, contractual, other direct costs, indirect costs), budget line description, unit cost, quantity, unit of measure, total planned amount, donor budget code, and cost-sharing flag. Enables granular budget management, BvA tracking linkage to finance domain, and donor financial reporting by budget category.' .

ind:PartnerLinkage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Partner Linkage' ;
    rdfs:comment 'Association entity capturing the relationship between a program intervention and its implementing partners (local NGOs, CBOs, INGOs, government counterparts). Stores partner role (lead implementer, sub-grantee, technical partner, government counterpart), partnership type, geographic scope of partnership, capacity assessment status, sub-award reference, start/end dates, and performance rating. Distinct from the partnership domain\'s MoU/LoA/SoW records which own the legal agreement — this product owns the program-specific partner assignment, role definition, and implementation performance tracking for each intervention.' .

ind:ReviewEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Review Event' ;
    rdfs:comment 'Unified record for all formal program review, reporting, and learning events including mid-term reviews, annual reviews, after-action reviews, donor review missions, progress reports (quarterly, semi-annual, annual, final, SitRep, flash report), and structured learning outputs (lessons learned, best practices, innovations, failure analyses). Captures event/report type, reporting period, date range, review team/author, scope, key findings, narrative sections (progress against outputs, challenges, beneficiary reach figures, financial summary), recommendations, management response, follow-up actions, submission date, submission status, approval workflow, and dissemination status. Serves as the SSOT for all program knowledge events, donor/cluster reporting submissions, and internal governance reporting. Distinct from MEL domain evaluations (which own evaluation methodology, TOR, and evaluator management) — this product owns the program management reporting and review lifecycle.' .

ind:Award rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grant ;
    rdfs:label 'Award' ;
    rdfs:comment 'Master record for each grant award received by the NGO from institutional donors (USAID, BHA, DFID, CERF, UN agencies, foundations, corporates). Captures the full grant lifecycle from award notification through closeout. Stores award number, title, donor reference, award type (cooperative agreement, contract, grant, sub-award, consortium lead, consortium member), total obligated amount in award currency with exchange rate to functional currency, authorized amount, start and end dates, period of performance, award status (pipeline, active, no-cost extension, closed), funding mechanism, geographic scope, thematic sector, applicable regulatory framework (2 CFR 200, USAID ADS, DFID Smart Rules), NICRA/ICR rate reference, restricted vs. unrestricted classification, indirect cost ceiling, and program linkage allocations with funding percentages. SSOT for all grant award identity in the NGO.' .

ind:Proposal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grant ;
    rdfs:label 'Proposal' ;
    rdfs:comment 'Tracks each grant proposal or concept note submitted to a donor or funding body in response to a solicitation or as an unsolicited submission. Captures proposal title, submission date, donor solicitation reference (RFA, RFP, NOFO number), proposal type (full application, concept note, expression of interest, unsolicited), requested amount and currency, proposed period of performance, lead technical sector, proposal status (draft, internal review, submitted, under review, shortlisted, awarded, rejected, withdrawn), win/loss outcome, cost proposal summary, technical approach summary, and linkage to the resulting award if successful. Supports pipeline management, go/no-go decision tracking, win-rate analysis, and strategic business development. Each proposal references the solicitation it responds to (except unsolicited proposals).' .

ind:AwardBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grant ;
    rdfs:label 'Award Budget' ;
    rdfs:comment 'Defines the approved budget structure for a grant award as negotiated with the donor. Stores budget version number, budget period (Year 1, Year 2, etc.), total approved budget in award currency, direct cost ceiling, indirect cost (F&A) ceiling, NICRA rate applied, cost category breakdown (personnel, fringe, travel, equipment, supplies, contractual, other direct costs, indirect), donor-approved budget narrative reference, and budget amendment history flag. Enables BvA (Budget vs. Actual) tracking and donor financial reporting. Distinct from the finance domain\'s general ledger — this is the donor-facing approved budget in the award\'s denomination currency, not the internal GL in functional currency.' .

ind:AwardBudgetLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grant ;
    rdfs:label 'Award Budget Line' ;
    rdfs:comment 'Granular line-item breakdown of an approved award budget. Each record represents a single budget line within a cost category and budget period, capturing line item code, cost category (personnel, fringe, travel, equipment, supplies, contractual, ODC, indirect), budget line description, approved amount, revised amount (post-amendment), cumulative expenditure to date, variance, and allowability flag under applicable donor regulations (2 CFR 200 Subpart E, USAID ADS). Enables detailed BvA analysis, burn-rate monitoring, and donor financial report preparation at the line-item level.' .

ind:GrantAmendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grant ;
    rdfs:label 'Grant Amendment' ;
    rdfs:comment 'Records all formal modifications to a grant award after initial execution. Captures amendment number, amendment type (no-cost extension, budget modification, scope change, key personnel change, geographic expansion, period of performance change), amendment date, donor approval reference, description of changes, revised total obligation, revised end date, and amendment status (pending, approved, executed). Tracks the full amendment history for compliance and audit purposes under OMB Uniform Guidance 2 CFR 200 and USAID ADS.' .

ind:Subaward rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grant ;
    rdfs:label 'Subaward' ;
    rdfs:comment 'Manages sub-awards issued by the NGO as prime recipient to implementing partners (CBOs, local NGOs, contractors). Captures subaward number, type (sub-grant, subcontract, fixed-obligation grant), implementing partner reference, subaward amount, period of performance, flow-down requirements from prime award, FFATA reporting obligation flag, subaward status (active, suspended, terminated, closed), risk rating, monitoring schedule, and pass-through entity compliance obligations under 2 CFR 200.331. Distinct from the partnership domain\'s MoU/LoA — this is the financial and compliance instrument with legal obligation.' .

ind:DonorCondition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grant ;
    rdfs:label 'Donor Condition' ;
    rdfs:comment 'Captures all donor-imposed conditions, special award conditions (SACs), compliance obligations, and key milestone requirements attached to a specific grant award. Each record represents a single condition including condition type (prior approval requirement, restricted cost, reporting obligation, key personnel approval, branding/marking requirement, audit requirement, programmatic milestone, deliverable deadline), condition description, regulatory citation (2 CFR 200 section, USAID ADS chapter, DFID Smart Rule), compliance status (open, met, waived, expired), due date, actual completion date, and responsible staff. Enables proactive compliance management, milestone tracking, and audit readiness.' .

ind:DonorReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grant ;
    rdfs:label 'Donor Report' ;
    rdfs:comment 'SSOT for all donor reporting obligations and submitted reports for each grant award. Defines the complete reporting schedule including report type (SF-425 Federal Financial Report, quarterly programmatic, annual narrative, SitRep, final report, IATI disclosure), reporting frequency (monthly, quarterly, semi-annual, annual, ad hoc), due dates, and responsible staff. Tracks each report submission through its lifecycle: upcoming → draft → submitted → accepted/revision requested → final. Captures submission method (email, donor portal, USAID ASIST, DFID ARIES), financial figures reported, narrative summary reference, version number, and reporting period covered. Supports compliance tracking, donor relationship management, and audit accountability under CHS and HAP standards.' .

ind:FundingSource rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grant ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Reference master for all funding sources and donor funding mechanisms used across grant awards. Captures funding source name, donor organization reference, funding mechanism type (ODA bilateral, multilateral, foundation grant, corporate philanthropy, CERF pooled fund, government contract), ODA/DAC classification, SDG alignment codes, geographic restrictions, thematic restrictions, currency, and IATI organization identifier. Enables portfolio analysis by funding source and donor compliance segmentation. Lives in the grant domain as the grant-facing classification of how funding flows to awards — distinct from the donor domains relationship and stewardship records which track the institutional relationship, communication history, and cultivation pipeline with the funding organization itself.' .

ind:CostShareCommitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grant ;
    rdfs:label 'Cost Share Commitment' ;
    rdfs:comment 'Tracks cost-share and matching fund commitments required by donors as a condition of the grant award. Captures cost-share type (cash, in-kind, third-party), required cost-share amount or percentage, committed amount, verified amount, cost-share source description, verification method, reporting period, and compliance status. Ensures the NGO meets its cost-share obligations under 2 CFR 200.306 and donor-specific matching requirements, and supports documentation for audits.' .

ind:Constituent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Donor ;
    rdfs:label 'Constituent' ;
    rdfs:comment 'Master identity record and single source of truth for all donor and funder constituents across Salesforce Nonprofit Cloud and Raisers Edge NXT. Represents every entity that gives to or funds the NGO — individual major gift contributors, institutional donors (USAID, DFID/FCDO, UN agencies, DAC members), bilateral and multilateral agencies, private foundations, corporate sponsors, and households. Captures full constituent profile including legal name, preferred name/salutation, constituent type (individual, institutional, foundation, corporate, bilateral, multilateral, household), organization affiliation, IATI organization identifier, communication preferences, GDPR/data consent flags, deceased indicator, ODA eligibility flag, indirect cost rate (ICR/NICRA) terms, preferred grant modality, relationship tier, funder classification (bilateral, multilateral, DAC), country of origin, and CRM source system reference. All gift, pledge, grant, soft credit, and cultivation records reference this entity as the authoritative donor identity.' .

ind:Prospect rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Donor ;
    rdfs:label 'Prospect' ;
    rdfs:comment 'Prospect research and donor cultivation pipeline record managed in Raisers Edge NXT and Salesforce Nonprofit Cloud. Tracks prospective donors and funders through the cultivation lifecycle from identification through qualification, cultivation, solicitation, and stewardship. Captures prospect rating, estimated giving capacity, wealth screening score, research stage, assigned major gift officer, next action date, cultivation strategy notes, and linkage-ability-interest (LAI) assessment. Supports the Donor Cultivation and Fundraising core business process.' .

ind:Gift rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Donor ;
    rdfs:label 'Gift' ;
    rdfs:comment 'Authoritative transactional ledger and single source of truth for every financial transaction in the donor domain — gifts, donations, matching gifts, tribute gifts, refunds, adjustments, and acknowledgements — processed through Salesforce Nonprofit Cloud and Raisers Edge NXT. This is the ONE table that answers \'what is this donor\'s total giving?\' Captures gift date, amount, currency, gift type discriminator (cash, check, wire, in-kind, stock, crypto, matching, tribute, refund/adjustment, recurring), fund designation, campaign and appeal attribution, gift source (online, direct mail, event, major gift officer), payment method, batch reference, anonymous flag, restricted vs. unrestricted designation, and GL posting reference. For matching gifts: match ratio, matching employer/corporation, match request date, match approval status, match payment received date, maximum match amount. For tribute gifts: tribute type (in-memoriam, in-honor-of), honoree name, honoree relationship, notification recipient, notification sent flag. For refunds/adjustments: original gift reference, refund date, refund amount, refund reason, refund method, GL reversal reference. For acknowledgements: acknowledgement type, acknowledgement date, receipt number, delivery method, acknowledgement status, IRS-compliant language flag, goods-or-services disclosure. Core financial transaction for donor revenue recognition per FASB ASC 958 and IRS 501(c)(3) substantiation requirements.' .

ind:Pledge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Donor ;
    rdfs:label 'Pledge' ;
    rdfs:comment 'Tracks multi-installment giving commitments, pledge agreements, and their individual installment schedules from donors, managed in Raisers Edge NXT and Salesforce Nonprofit Cloud. Captures pledge date, total pledge amount, installment schedule (monthly, quarterly, annual), number of installments, pledge balance outstanding, pledge status (active, fulfilled, lapsed, written-off), fund designation, campaign, appeal, reminder schedule, and write-off reason. Includes installment-level detail: individual due dates, scheduled amounts, actual payment dates, amounts paid, installment status (scheduled, paid, overdue, skipped, waived), payment method, and linked gift reference upon payment. Enables granular pledge fulfillment tracking, overdue installment identification, automated reminder generation, and BvA (Budget vs. Actual) reconciliation for pledged revenue. Distinct from gift — a pledge is a commitment to give, not a completed transaction.' .

ind:Campaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Donor ;
    rdfs:label 'Campaign' ;
    rdfs:comment 'Fundraising campaign master record managing all donor-facing fundraising initiatives in Salesforce Nonprofit Cloud. Captures campaign name, campaign type (annual fund, capital campaign, emergency appeal, planned giving, corporate partnership, digital/online), campaign goal amount, start and end dates, campaign status, target audience segment, appeal codes associated, total gifts raised to date, number of donors, cost of fundraising, and ROI. Supports campaign performance tracking and donor attribution across all gift transactions.' .

ind:Appeal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Donor ;
    rdfs:label 'Appeal' ;
    rdfs:comment 'Specific fundraising appeal or solicitation package within a campaign, managed in Raisers Edge NXT. An appeal is a targeted ask sent to a defined segment of constituents via a specific channel (direct mail, email, phone, event). Captures appeal code, appeal name, parent campaign, appeal type (acquisition, renewal, upgrade, lapsed reactivation), mailing date, channel (mail, email, phone, digital), cost, number of pieces sent, response rate, and total revenue generated. Enables granular attribution of gifts to specific solicitation efforts.' .

ind:DonorFund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Donor ;
    rdfs:label 'Donor Fund' ;
    rdfs:comment 'Donor-designated fund master record representing the specific programmatic or operational purpose to which a gift is directed. Captures fund code, fund name, fund type (restricted, temporarily restricted, unrestricted, endowment, quasi-endowment), fund description, associated program or project, GL account mapping, fund status (open, closed, suspended), minimum gift threshold, and fund stewardship contact. Serves as the bridge between donor intent (gift designation) and financial stewardship (fund accounting in SAP/Unit4). Distinct from GL account — fund is the donor-facing designation.' .

ind:StewardshipActivity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Donor ;
    rdfs:label 'Stewardship Activity' ;
    rdfs:comment 'Records all donor stewardship touchpoints and relationship management activities conducted by major gift officers and stewardship staff. Captures activity type (acknowledgement letter, impact report, site visit, phone call, event invitation, personal meeting, grant report delivery), activity date, staff member responsible, constituent involved, related gift or pledge, activity outcome, next steps, and stewardship plan stage. Supports the donor cultivation and stewardship lifecycle and enables relationship health tracking in Salesforce Nonprofit Cloud.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Donor ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Donor segmentation master records and constituent-to-segment membership assignments used for targeted fundraising, stewardship, and communication strategies. Captures segment definition (name, type, criteria, owner, creation date, status) and constituent membership records including assignment date, assigned-by staff member, assignment source (manual, automated RFM scoring, wealth screening import), expiry date, is_active flag, and segment transition history. Segment types include giving level (major, mid-level, annual), recency-frequency-monetary (RFM) tier, donor type, geographic, programmatic interest, acquisition channel, and lifecycle stage. Enables LYBUNT (Last Year But Unfortunately Not This Year), SYBUNT, and RFM-based segmentation for direct mail, email, and major gift cultivation strategies. Supports point-in-time segment membership queries and longitudinal donor behavior analysis.' .

ind:PortfolioAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Donor ;
    rdfs:label 'Portfolio Assignment' ;
    rdfs:comment 'Manages the assignment of prospects and donors to major gift officers for cultivation and stewardship. Captures assigned gift officer (staff reference), constituent assigned, portfolio tier (major gift, mid-level, planned giving), assignment date, assignment reason, portfolio status (active, on-hold, transferred), last contact date, and next scheduled contact. Enables portfolio load balancing, officer performance tracking, and relationship continuity management.' .

ind:FundraisingEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Donor ;
    rdfs:label 'Fundraising Event' ;
    rdfs:comment 'Master record for donor-facing fundraising events and attendee registrations including galas, benefit dinners, golf tournaments, virtual fundraisers, and cultivation events managed in Salesforce Nonprofit Cloud. Captures event name, event type, event date and venue, fundraising goal, ticket price tiers, sponsorship levels, total revenue raised, total attendance, event cost, net revenue, and event manager. Includes individual constituent registration records with registration date, registration type (attendee, table sponsor, individual sponsor, volunteer), ticket type and price paid, table assignment, meal preference, attendance confirmation status, check-in timestamp, and post-event follow-up status. Enables event capacity management, seating logistics, and post-event stewardship workflows. Distinct from field operations events — fundraising events are donor cultivation and revenue generation activities.' .

ind:Indicator rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mel ;
    rdfs:label 'Indicator' ;
    rdfs:comment 'Master library of all MEL indicators used across programs and grants. Each record defines one measurable indicator with its definition, calculation method, numerator/denominator (for percentage indicators), unit of measure, data collection frequency, disaggregation dimensions, baseline value, and alignment to SDG goals, DAC criteria, and LogFrame output/outcome levels. Serves as the single source of truth for indicator metadata referenced by targets, results, DHIS2 reporting, and donor performance frameworks.' .

ind:Logframe rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mel ;
    rdfs:label 'Logframe' ;
    rdfs:comment 'Logical Framework (LogFrame) master records defining the results chain hierarchy for each program or grant. Each logframe captures the full intervention logic: goal (impact), purpose (outcome), outputs, activities, assumptions, risks, and objectively verifiable indicators (OVIs) at each level. Includes Theory of Change (ToC) components as embedded rows within the hierarchy. Aligns with DAC evaluation criteria, RBM standards, and donor-specific logframe templates (DFID/FCDO, USAID, EU, ECHO). Links to indicator targets for performance tracking and supports results framework reporting.' .

ind:IndicatorTarget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mel ;
    rdfs:label 'Indicator Target' ;
    rdfs:comment 'Planned targets for each indicator within a specific logframe, grant reporting period, and geographic scope. Stores baseline, target value, target date, disaggregation breakdowns (sex, age, location), and the responsible program unit. Supports BvA-style target vs. actual tracking and donor performance reporting.' .

ind:IndicatorResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mel ;
    rdfs:label 'Indicator Result' ;
    rdfs:comment 'Actual achieved values recorded against indicator targets for a given reporting period, program, and geographic unit. Captures reported value, disaggregation breakdowns (sex, age, disability, location), data source, collection method, verification status, variance from target, and outcome-level change measurements (KAB changes, condition improvements). Covers all indicator levels from output through outcome and impact. Core transactional record for MEL performance tracking, donor reporting, and ToC validation.' .

ind:MealPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mel ;
    rdfs:label 'Meal Plan' ;
    rdfs:comment 'MEAL (Monitoring, Evaluation, Accountability, and Learning) plan document for a program or grant cycle. Defines the overall monitoring strategy, indicator matrix, data collection schedule and methods, responsible MEL staff, tools to be used (KoboToolbox, CommCare, ODK, DHIS2), learning agenda linkage, accountability mechanisms (CHS commitments, feedback channels), reporting calendar, and data management protocols. Serves as the governing MEL framework document that all other MEL products operationalize.' .

ind:Evaluation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mel ;
    rdfs:label 'Evaluation' ;
    rdfs:comment 'Formal evaluation records including baseline, midterm, endline, and impact evaluations. Captures evaluation type (formative, summative, real-time), DAC criteria assessed (relevance, coherence, effectiveness, efficiency, impact, sustainability), methodology, evaluator (internal/external), scope, findings summary, and recommendations. Supports organizational learning and donor accountability.' .

ind:EvaluationFinding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mel ;
    rdfs:label 'Evaluation Finding' ;
    rdfs:comment 'Individual findings, conclusions, and recommendations extracted from formal evaluations. Each record captures the finding statement, DAC criterion it relates to, evidence base, rating (if applicable), responsible unit for follow-up, and implementation status of the recommendation. Enables systematic learning and accountability tracking.' .

ind:QualitativeRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mel ;
    rdfs:label 'Qualitative Record' ;
    rdfs:comment 'Qualitative data collection event records capturing Focus Group Discussions (FGDs), Key Informant Interviews (KIIs), case studies, and Most Significant Change (MSC) stories. Each record stores the collection method type, date, location, facilitator/interviewer, participants (count and disaggregation for FGDs, or informant role/organization for KIIs), topic guide or interview protocol used, key themes emerging, verbatim quotes, findings, consent status, and linked indicator or evaluation. Supports qualitative MEL evidence generation and triangulation with quantitative indicator data for robust program learning.' .

ind:DataCollectionTool rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mel ;
    rdfs:label 'Data Collection Tool' ;
    rdfs:comment 'Registry of MEL data collection instruments including KoboToolbox/ODK forms, CommCare modules, DHIS2 data entry forms, and structured interview guides. Each record captures tool name, version number, linked indicator(s), deployment platform, language(s), target respondent type, geographic deployment scope, approval status, and active/retired lifecycle state. Ensures instrument governance, version control, and traceability from collected data back to the authorized collection tool.' .

ind:Volunteer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Volunteer ;
    rdfs:label 'Volunteer' ;
    rdfs:comment 'Master record for all individuals who serve as volunteers across the organization\'s programs and events. Captures volunteer identity, contact details, demographic profile, volunteer type (community health worker, field volunteer, event-based supporter), onboarding status, availability, language skills, geographic base, emergency contact, and engagement history. This is the SSOT for volunteer identity within the volunteer domain, distinct from paid workforce managed in the workforce domain. Sourced from Microsoft Dynamics 365 for Nonprofits.' .

ind:Application rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Volunteer ;
    rdfs:label 'Application' ;
    rdfs:comment 'Captures the end-to-end recruitment and onboarding application lifecycle for prospective volunteers. Tracks application submission date, recruitment channel, program of interest, screening status, background check outcome, reference check status, interview notes, acceptance or rejection decision, and onboarding completion milestones. Supports the Volunteer and Staff Recruitment and Management core business process.' .

ind:Role rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Volunteer ;
    rdfs:label 'Role' ;
    rdfs:comment 'Defines the catalog of volunteer roles available across programs and field operations. Each role specifies the role title, functional area (e.g., WASH, GBV, PSS, nutrition, logistics), required skills, minimum certification requirements, physical demands, deployment context (field/office/remote), maximum concurrent assignments, and whether the role is active. Acts as the reference catalog for role-based volunteer deployment.' .

ind:VolunteerDeployment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Volunteer ;
    rdfs:label 'Volunteer Deployment' ;
    rdfs:comment 'Authoritative operational record of a volunteer\'s assignment to a specific program, project site, field operation, or event for a defined period. Captures deployment start and end dates, assigned program, field location or country office, role performed (FK to volunteer_role), deployment status (active, completed, withdrawn, suspended), supervising staff member, deployment type (emergency response, development program, event support), FTE equivalent contribution, grant or funding source supporting the position, and any special conditions or security clearance requirements. This is the SSOT for volunteer-to-program assignments, serving both field coordination and MEL/donor accountability reporting. Sourced from Microsoft Dynamics 365.' .

ind:HourLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Volunteer ;
    rdfs:label 'Hour Log' ;
    rdfs:comment 'Authoritative transactional record of volunteer hours contributed per activity, deployment, or event — the timesheet equivalent for unpaid contributors. Captures log date, volunteer (FK to volunteer), deployment or program context (FK to volunteer_deployment), activity type, location, hours claimed, hours verified, verification method (supervisor sign-off, digital check-in/GPS, self-reported), approval status, approving supervisor, and notes. Primary source for donor reporting on volunteer in-kind contributions (valued at fair market rates per IRS guidelines or local equivalents), MEL indicator tracking (e.g., volunteer-hours per beneficiary), recognition milestone triggers, and BvA reporting on volunteer effort allocation across grants. Supports audit trail requirements for institutional donor compliance.' .

ind:Training rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Volunteer ;
    rdfs:label 'Training' ;
    rdfs:comment 'Catalog of training programs, workshops, and capacity-building courses available to volunteers. Captures training title, delivery modality (in-person, e-learning, blended), training category (safety and security, technical skills, CHS orientation, SPHERE standards, GBV awareness, PSEA, first aid), duration, facilitator, accrediting body, certification awarded upon completion, and whether training is mandatory for specific roles. Distinct from the workforce LMS — this catalog is specific to volunteer capacity building.' .

ind:TrainingEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Volunteer ;
    rdfs:label 'Training Enrollment' ;
    rdfs:comment 'Transactional record of a volunteer\'s enrollment in and completion of a specific training course. Captures enrollment date, training, volunteer, enrollment status (registered, in-progress, completed, failed, withdrawn), completion date, assessment score, certification issued, certificate expiry date, and continuing education credits earned. Supports compliance tracking for mandatory training (e.g., PSEA, CHS) and volunteer certification management.' .

ind:Certification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Volunteer ;
    rdfs:label 'Certification' ;
    rdfs:comment 'Unified competency and credential product — the single source of truth for all skills taxonomy and individual volunteer credentials within the volunteer domain. As REFERENCE CATALOG: defines skill categories (medical, logistics, language, psychosocial, WASH, ICT4D, community mobilization), proficiency levels, role-to-skill requirements, and mandatory vs. preferred designations for volunteer_role entries. As INDIVIDUAL RECORDS: tracks specific credentials held by each volunteer including professional licenses, first aid certificates, SPHERE practitioner credentials, PSEA compliance certificates, verified and self-assessed proficiency levels, issuing body, issue and expiry dates, certificate numbers, verification status, renewal requirements, and evidence document references. Supports skill-based volunteer matching, competency gap analysis, compliance tracking, deployment readiness assessment, and training needs identification.' .

ind:VolunteerTeam rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Volunteer ;
    rdfs:label 'Volunteer Team' ;
    rdfs:comment 'Defines volunteer teams or groups organized for specific programs, field operations, or community outreach activities, including team roster membership. Captures team name, team type (community health worker group, distribution team, PSS support group, event crew), program affiliation, geographic area of operation, team lead (volunteer or staff FK), formation and dissolution dates, current status, and member roster with individual roles, join/exit dates, and leadership responsibilities within the team. Enables group-level coordination, communication, shift planning, and historical team composition reporting.' .

ind:FinanceFund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Finance Fund' ;
    rdfs:comment 'Master record for each restricted or unrestricted fund managed by the NGO. Captures fund name, fund code, restriction type (donor-restricted, board-designated, unrestricted), associated grant or donor source, fund purpose, opening balance, currency, fiscal year, fund status, and compliance flags per OMB Uniform Guidance 2 CFR 200 and FASB ASC 958. The SSOT for fund identity used across grant financial management, cost allocation, and BvA reporting in Unit4 ERP and SAP S/4HANA.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Master record for organizational cost centers used to allocate expenses across programs, departments, country offices, and projects. Captures cost center code, name, type (program, administrative, fundraising), responsible manager, parent cost center (for hierarchy), organizational hierarchy level, associated country or region, active status, and functional expense classification per GAAP. The SSOT for organizational cost structure used in SAP S/4HANA and Unit4 ERP for cost allocation, indirect cost recovery, NICRA base calculations, and Budget vs. Actual reporting.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'Authoritative master of the nonprofit\'s Chart of Accounts (CoA) and General Ledger account structure in SAP S/4HANA and Unit4 ERP. Each record represents a GL account within the CoA hierarchy, capturing GL account number, account description, account group, parent account (for CoA hierarchy navigation), hierarchy level, CoA structure code, account type (asset, liability, net asset, revenue, expense), balance sheet or income statement classification, normal debit/credit indicator, currency, fund restriction class (unrestricted, temporarily restricted, permanently restricted per FASB ASC 958), functional expense category (program, management & general, fundraising), natural expense classification, tax relevance, reconciliation account flag, and posting eligibility. Serves as the single authoritative reference (SSOT) for all fund accounting, grant financial management, budget planning, BvA reporting, and GAAP-compliant financial reporting. Subsumes the Chart of Accounts structure — no separate CoA entity exists.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Transactional record of every GL journal entry posted in SAP S/4HANA or Unit4 ERP. Captures document number, posting date, fiscal period, fiscal year, document type (original, reversal, accrual, allocation), posting key, currency, exchange rate, reference document, posting user, approval status, reversal indicator, and source system. The foundational transactional entity for all financial reporting, audit trails, and GAAP-compliant fund accounting. Each journal entry has one or more journal_entry_line records.' .

ind:JournalEntryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry Line' ;
    rdfs:comment 'Individual debit or credit line item within a GL journal entry. Captures line number, GL account, cost center, fund, grant reference, program code, debit or credit amount, functional expense category, natural account classification, tax code, profit center, and narrative description. Enables granular fund accounting, cost allocation, and grant financial reporting at the transaction line level per FASB ASC 958 and OMB Uniform Guidance.' .

ind:Budget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget' ;
    rdfs:comment 'Master budget record for an approved financial plan associated with a grant, program, cost center, or organizational unit. Captures budget code, budget name, budget type (operational, project, grant, capital), fiscal year, total approved amount, currency, budget status (draft, approved, revised, closed), approval date, approving authority, associated fund or grant reference, donor reference, direct cost budget, indirect cost budget, ICR rate applied, NICRA rate reference, budget period start and end dates, approved modifications, cost-share requirement amount, and BvA summary metrics (total actual expenditure, total variance, burn rate). For grant-type budgets, carries grant-specific compliance attributes per OMB 2 CFR 200 and donor requirements (USAID, DFID, UN) including award ceiling, cost-share obligations, and prior approval thresholds. The single SSOT for all approved budget baselines — operational, programmatic, and grant-specific — used in Budget vs. Actual tracking and donor financial reporting.' .

ind:BudgetLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget Line' ;
    rdfs:comment 'Individual line item within an approved budget, representing the planned expenditure or revenue for a specific GL account, cost center, fund, program activity, or period. Captures budget line number, GL account, cost center, fund, program code, budget period (monthly, quarterly, annual), planned amount, revised amount, budget narrative, and expense category. Enables granular BvA tracking, grant financial management, and donor budget reporting at the line level.' .

ind:Payable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Payable' ;
    rdfs:comment 'Unified Accounts Payable (AP) record in SAP S/4HANA managing the full procure-to-pay lifecycle from invoice receipt through payment disbursement. Captures invoice number, vendor reference, invoice date, due date, payment terms, invoice currency, total amount, tax amount, withholding tax, three-way match status (PO, goods receipt, invoice), payment status (open, partially paid, paid, disputed, cancelled), payment date, payment method (wire transfer, check, ACH, mobile money), payment document number, bank account, clearing document reference, payment run ID, exchange rate, cost center, fund, and grant reference. Supports procurement-to-pay cycle, grant expenditure documentation, cash management, and financial audit compliance per OMB Uniform Guidance.' .

ind:PayablePayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Payable Payment' ;
    rdfs:comment 'Accounts Payable (AP) payment transaction recording the disbursement of funds to vendors, partners, or service providers from SAP S/4HANA. Captures payment document number, payment date, payment method (wire transfer, check, ACH, mobile money), bank account, payment currency, exchange rate, total payment amount, clearing document reference, fund, cost center, grant reference, and payment run ID. Supports cash management, grant expenditure reporting, and financial audit compliance.' .

ind:Receivable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Receivable' ;
    rdfs:comment 'Unified Accounts Receivable (AR) record in SAP S/4HANA managing the full donor-billing-to-collection lifecycle from invoice issuance through cash receipt. Captures invoice number, payer reference (donor, government agency, sub-grantee, cost-sharing partner), invoice date, due date, payment terms, invoice currency, total amount, outstanding balance, collection status (open, partially collected, collected, written off), receipt date, receipt method (wire transfer, check, online payment), receipt document number, bank account, clearing document reference, deposit confirmation number, exchange rate, fund, grant reference, and revenue recognition date. Supports grant drawdown tracking, donor billing, revenue recognition per FASB ASC 958, and cash flow management.' .

ind:ReceivableReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Receivable Receipt' ;
    rdfs:comment 'Accounts Receivable (AR) cash receipt recording the collection of funds from donors, government agencies, or sub-grantees in SAP S/4HANA. Captures receipt document number, receipt date, payer reference, receipt method (wire transfer, check, online payment), bank account, receipt currency, exchange rate, amount received, clearing document reference, fund, grant reference, and deposit confirmation number. Supports grant drawdown reconciliation, donor payment tracking, and cash flow management.' .

ind:GrantBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Grant Budget' ;
    rdfs:comment 'Grant-specific budget master record in Unit4 ERP representing the approved financial plan for a single grant award. Captures grant reference, donor reference, grant budget code, total award amount, direct cost budget, indirect cost budget, ICR rate applied, NICRA rate, budget period start and end dates, budget status, approved modifications, cost-share requirement amount, and currency. Distinct from the general budget entity as it carries grant-specific compliance attributes per OMB 2 CFR 200 and donor requirements (USAID, DFID, UN).' .

ind:CostAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Allocation' ;
    rdfs:comment 'Transactional record of indirect cost and shared cost allocations distributed across grants, programs, cost centers, and funds. Captures allocation document number, allocation date, allocation method (direct, proportional, NICRA-based, step-down), source cost center, target cost center, source fund, target fund, grant reference, allocated amount, allocation basis (headcount, square footage, direct costs), allocation rate applied, fiscal period, and approval status. Supports F&A (Facilities and Administration) cost recovery and OMB Uniform Guidance compliance.' .

ind:BankAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Bank Account' ;
    rdfs:comment 'Master record for all organizational bank accounts managed by the NGO across headquarters, regional offices, and country offices. Captures bank account number (masked), bank name, bank branch, SWIFT/BIC code, IBAN, account currency, account type (operating, restricted, payroll, project, donor-specific), country, account status (active, dormant, closed), signatory requirements and thresholds, fund association for restricted accounts, GL reconciliation account reference, and reconciliation frequency. Supports multi-currency cash management, restricted fund segregation, donor ring-fencing requirements, and financial controls across global operations.' .

ind:RegulatoryFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Filing' ;
    rdfs:comment 'Master record of all statutory and regulatory filings including full submission audit trail. Covers IRS Form 990, Charity Commission annual returns, state charitable solicitation registrations, and foreign agent registration filings. Tracks filing type, jurisdiction, due date, submission date, channel (electronic/paper/portal), confirmation number, status lifecycle (draft → submitted → acknowledged → accepted/rejected), preparer, reviewer, filing period, rejection reason codes, and resubmission history. Each submission attempt is recorded for complete audit trail.' .

ind:Obligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Obligation' ;
    rdfs:comment 'Master catalog of all recurring and one-time compliance obligations the organization must fulfill across regulatory, donor, and voluntary accountability frameworks. Includes IRS 990 filings, Charity Commission returns, IATI publications, CHS self-assessments, Single Audit requirements (2 CFR 200), state registrations, OCHA reporting, and donor-specific conditions. Captures obligation name, governing body, legal basis, frequency, jurisdiction, responsible unit, lead time, and risk rating. Overdue obligations escalate to incident records via obligation_schedule monitoring.' .

ind:SingleAudit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Single Audit' ;
    rdfs:comment 'Master record for Single Audit engagements required under OMB Uniform Guidance 2 CFR 200 for organizations expending $750,000 or more in US federal awards in a fiscal year. Captures audit period, auditor firm, engagement type (financial statement audit, compliance audit), federal expenditure threshold, Schedule of Expenditures of Federal Awards (SEFA) reference, audit opinion type, and submission to the Federal Audit Clearinghouse (FAC).' .

ind:AuditFinding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Audit Finding' ;
    rdfs:comment 'Transactional record of each finding, material weakness, significant deficiency, or questioned cost identified during a Single Audit or internal compliance audit. Captures finding reference number, finding type (material weakness, significant deficiency, questioned cost, noncompliance), federal program CFDA number, finding description, condition, criteria, cause, effect, and recommendation. Links to corrective action plans.' .

ind:CorrectiveActionPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Master record of corrective action plans (CAPs) developed in response to audit findings, CHS non-conformities, donor compliance issues, or internal control deficiencies. Captures finding reference, corrective action description, responsible manager, target completion date, actual completion date, verification method, and status (open, in progress, closed, overdue). Supports management response documentation required by 2 CFR 200 and CHS Alliance.' .

ind:GovernancePolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Governance Policy' ;
    rdfs:comment 'Master catalog of organizational governance documents including board-approved policies, bylaws, board resolutions, charters, conflict-of-interest disclosures, and internal control frameworks. Captures document type (policy, resolution, bylaw, charter, COI disclosure), name, category (financial, HR, safeguarding, anti-fraud, data protection, COI), version, effective/expiry dates, approving authority, document owner, review cycle. For resolutions: meeting date, meeting type, resolution text, vote outcome, and resolution number. For COI disclosures: disclosing party, nature of conflict, related party, recusal decision, review outcome, and annual certification status. Supports IRS 990 Schedule O and Part VI governance disclosures, Charity Commission annual returns, and donor due diligence.' .

ind:DonorRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Donor Requirement' ;
    rdfs:comment 'Master record of specific compliance requirements imposed by individual institutional donors (USAID, DFID, EU, UN agencies) on grants awarded to the organization. Captures donor name, grant reference, requirement type (financial reporting, programmatic reporting, audit, visibility, procurement rules, anti-terrorism certification, NICRA application), requirement description, due date, and compliance status. Distinct from general regulatory obligations — these are donor-specific contractual compliance conditions.' .

ind:Incident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Incident' ;
    rdfs:comment 'Transactional record of compliance incidents, violations, near-misses, and whistleblower reports identified within the organization. Covers fraud allegations, financial mismanagement, procurement irregularities, data protection violations, and ethical breaches reported through any channel (internal detection, anonymous hotline, donor notification, whistleblower portal). Captures incident date, type, severity, affected program/grant, reporting channel, reporter anonymity flag, allegation category, investigation status, triage outcome, and resolution. Supports mandatory donor incident reporting, HAP accountability, CHS Commitment 5, and organizational disclosure obligations.' .

ind:StatutoryRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Statutory Registration' ;
    rdfs:comment 'Master record of the organization\'s legal registrations and statutory status across all operating jurisdictions, including US 501(c)(3) IRS determination letter, UK Charity Commission registration, country-level NGO registrations, and foreign agent registrations. Captures jurisdiction, registration type, registration number, registration date, expiry date, registered name, registered address, and renewal requirements. Foundational for legal operating authority and donor eligibility verification.' .

ind:InternalReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Internal Review' ;
    rdfs:comment 'Transactional record of internal compliance reviews, spot checks, and programmatic audits conducted by the compliance or internal audit function. Captures review type (financial spot check, procurement review, programmatic compliance, data protection audit, COI certification review), review scope, country office or program reviewed, review period, lead reviewer, findings count by severity, overall compliance rating, and follow-up actions required. Distinct from external Single Audits — these are internally initiated compliance assurance activities that verify ongoing adherence to policies, donor requirements, and corrective action plan closure.' .

ind:SanctionsScreening rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Sanctions Screening' ;
    rdfs:comment 'Master record of sanctions and debarment screening checks performed against OFAC (Office of Foreign Assets Control), UN Security Council, EU, and other sanctions lists for vendors, partners, staff, and beneficiaries. Captures screening date, subject name, list checked, match result (clear, potential match, confirmed match), resolution action, screener identity, and re-screening frequency. Critical for anti-terrorism certification compliance required by USAID, DFID, and EU donors, and for organizational due diligence under US Executive Orders and UN resolutions.' .

ind:DataQualityAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mel ;
    rdfs:label 'Data Quality Assessment' ;
    rdfs:comment 'Data Quality Assessment (DQA) and Routine Data Quality Audit (RDQA) records capturing systematic verification of MEL data accuracy, completeness, timeliness, and consistency. Stores assessment date, data source audited, indicator(s) reviewed, verification method (spot-check, recount, triangulation), discrepancy findings, corrective actions, and assessor. Supports USAID DQA requirements, Global Fund LFA verification, and internal data governance standards.' .

ind:Community rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Beneficiary ;
    rdfs:label 'Community' ;
    rdfs:comment 'Master record for a community, settlement, camp, or geographic area registered as a collective beneficiary unit for area-based humanitarian programming. Captures community name, geographic coordinates, administrative boundaries (admin1-admin4), settlement type (formal camp, informal settlement, host community, collective center, transit site), estimated population, community leadership contacts, community-level vulnerability indicators (access to water, sanitation coverage, health facility proximity), registration date, and active program associations. Enables community-based targeting for WASH, shelter, food security, and livelihoods interventions where the unit of assistance is the community rather than individual or household. Supports OCHA Common Operational Dataset (COD) alignment and 3W (Who does What Where) reporting.' .

ind:PurchaseOrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Purchase Order Line' ;
    rdfs:comment 'This association product represents the line-item detail of procurement purchase orders, capturing the specific commodities ordered on each PO. Each record links one purchase order to one commodity with line-specific quantities, pricing, delivery schedules, and receipt tracking. This is the operational record that procurement officers create when building multi-line purchase orders and that warehouse staff update when receiving shipments.. Existence Justification: In humanitarian procurement operations, purchase orders routinely contain multiple commodity line items (medical supplies, shelter materials, WASH items on a single PO), and each commodity appears across many purchase orders over time as programs continuously procure relief items. Procurement officers actively manage line-item details including per-line quantities, vendor pricing, delivery schedules, and receipt tracking—this is the operational record that drives three-way matching and inventory management.' .

ind:FiscalPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Master reference table for fiscal_period. Referenced by fiscal_period_id.' .

ind:Country rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Field ;
    rdfs:label 'Country' ;
    rdfs:comment 'Master reference table for country. Referenced by country_id.' .

ind:Emergency rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Field ;
    rdfs:label 'Emergency' ;
    rdfs:comment 'Master reference table for emergency. Referenced by emergency_id.' .

ind:ReportingPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Mel ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'Master reference table for reporting_period. Referenced by reporting_period_id.' .

ind:Program rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Program' ;
    rdfs:comment 'Master reference table for program. Referenced by program_id.' .

ind:TeamMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Volunteer ;
    rdfs:label 'Team Membership' ;
    rdfs:comment 'This association product represents the Membership relationship between volunteer and volunteer_team. It captures the formal enrollment of a volunteer into a team, including their role, tenure dates, membership status, and hours contributed. Each record links one volunteer to one volunteer_team and carries attributes that exist only in the context of that specific membership — enabling accurate roster management, safeguarding compliance (knowing exactly who is or was on each team), and program-level reporting on volunteer contributions.. Existence Justification: In NGO volunteer management, a single volunteer can be a member of multiple teams simultaneously (e.g., a community health worker on both a distribution team and a PSS support group), and each volunteer team has many volunteer members. Team membership is a formally managed business concept with its own lifecycle — volunteers join teams, hold roles within them, contribute hours, and eventually leave — making this a genuine operational M:N relationship, not an analytical correlation.' .

ind:ConsortiumMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partnership ;
    rdfs:label 'Consortium Membership' ;
    rdfs:comment 'This association product represents the formal Membership relationship between a consortium and a partner organization. It captures each partner organization\'s participation in a specific consortium, including their role, funding share, membership period, and reporting obligations. Each record links one consortium to one member partner organization and carries attributes that exist only in the context of that specific membership — data that belongs neither to the consortium master record nor to the partner organization master record alone. Supports OCHA cluster reporting, Grand Bargain localization tracking, and joint donor reporting requirements.. Existence Justification: In the humanitarian NGO sector, a consortium is explicitly a multi-partner arrangement where multiple partner organizations formally participate, each with a defined role, funding share, and membership period. Conversely, a single partner organization routinely participates in multiple consortia simultaneously or over time. The business actively manages consortium membership as a formal operational concept — tracking who is in which consortium, in what role, with what funding share, and for what period — making this a genuine operational M:N relationship, not an analytical correlation.' .

ind:DistributionOrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Distribution Order Line' ;
    rdfs:comment 'This association product represents the Line (order line event) between distribution_order and commodity. It captures each individual commodity line item authorized within a distribution order, recording the specific quantity, valuation, lot traceability, and donor attribution for that commodity on that order. Each record links one distribution_order to one commodity with attributes — quantity, unit value, lot number, expiry date, donor restriction code — that exist only in the context of this specific order-commodity pairing and cannot reside on either the order header or the commodity master alone.. Existence Justification: In humanitarian supply chain operations, a single distribution order invariably authorizes the release of MULTIPLE commodity types simultaneously (e.g., NFI kits, food rations, medical supplies, WASH materials in one dispatch). Conversely, a single commodity (e.g., plastic sheeting) appears across MANY distribution orders over time. The relationship between a distribution order and its commodity lines is a well-recognized operational business entity — the \'distribution order line\' — that carries its own data (quantity ordered, unit value, lot number, expiry date, donor restriction code) that belongs to neither the order nor the commodity master alone.' .

ind:VendorCatalogItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Vendor Catalog Item' ;
    rdfs:comment 'This association product represents the Contract between a vendor and a commodity in the humanitarian supply chain. It captures the negotiated terms under which a vendor is authorized and prequalified to supply a specific commodity, including pricing, lead time, minimum order quantity, and approval status. Each record links one vendor to one commodity and carries attributes that exist only in the context of this vendor-commodity agreement. This is the SSOT for sourcing decisions, price benchmarking, and procurement compliance within the supply domain.. Existence Justification: In humanitarian procurement, vendor prequalification is explicitly commodity-specific — a vendor is approved to supply particular commodities at negotiated prices, lead times, and minimum order quantities. This means one vendor can be prequalified for many commodities, and one commodity can have many approved vendors, each with their own negotiated terms. The \'Vendor Catalog\' or \'Vendor Item Agreement\' is a well-recognized procurement concept in UN/NGO supply chains (used by WFP, UNICEF, ICRC) that is actively created, maintained, and queried by procurement officers.' .

ind:DistributionPlanLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Distribution Plan Line' ;
    rdfs:comment 'This association product represents the Commodity Allocation (Distribution Plan Line) between a distribution_plan and a commodity. It captures the specific quantity, cost, pipeline status, and donor restrictions for each commodity included in a distribution plan. Each record links one distribution_plan to one commodity and carries attributes that exist only in the context of that specific plan-commodity combination — such as the planned quantity per beneficiary, the pipeline fulfillment status, and any donor restrictions applicable to that commodity within that plan. This is the operational record used for pipeline planning, stock reservation, and donor reporting.. Existence Justification: In humanitarian operations, a distribution plan is explicitly a multi-commodity document — a single plan for a refugee camp routinely covers 10-20 different commodity types (food, NFIs, WASH materials, medical supplies) each with distinct planned quantities per beneficiary, unit costs, and pipeline statuses. Conversely, a single commodity (e.g., plastic sheeting) appears across dozens of simultaneous distribution plans across different geographies and programs. The business actively manages this relationship as \'distribution plan lines\' or \'commodity allocations\' — operational records that humans create, update, and delete as part of pipeline planning, stock reservation, and donor reporting.' .

# --- Attribute Properties ---
ind:staffMemberId rdf:type rdf:Property ;
    rdfs:label 'Staff Member Id' ;
    rdfs:comment 'Unique surrogate identifier for each staff member record in the Ngo workforce system. Primary key for the staff_member data product, serving as the anchor entity for all workforce transactions across HR sub-domains.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:jobProfileId rdf:type rdf:Property ;
    rdfs:label 'Job Profile Id' ;
    rdfs:comment 'Foreign key linking to workforce.job_profile. Business justification: staff_member is the core HR master record and currently stores job_title and job_grade as free-text strings. job_profile is the SSOT for standardized role definitions including job family, level, comp' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:supervisorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Staff Member Id' ;
    rdfs:comment 'Reference to the staff_member_id of this staff member\'s direct line manager. Enables organizational hierarchy traversal, RACI reporting, performance management workflows, and approval chain configuration in Workday HCM.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:baseSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Base Salary Amount' ;
    rdfs:comment 'The gross annual base salary of the staff member in the contract currency, as recorded in Workday HCM. Used for payroll processing, Budget versus Actual (BvA) reporting, and grant cost allocation under OMB Uniform Guidance 2 CFR 200.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'The scheduled expiry date of the staff member\'s current employment contract. Null for permanent/open-ended contracts. Used for contract renewal alerts, workforce planning, and grant-funded position management.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'The effective start date of the staff member\'s current employment contract. May differ from hire_date for staff on renewed or amended contracts. Used for contract lifecycle management and compliance tracking.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'The legal nature of the employment arrangement. Determines statutory entitlements, benefits eligibility, payroll treatment, and compliance obligations under local labor law. [ENUM-REF-CANDIDATE: permanent|fixed_term|consultancy|secondment|internship|volunteer_staff — promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The financial cost center code from the Chart of Accounts (CoA) to which the staff member\'s salary and benefits are charged. Enables Budget versus Actual (BvA) reporting and grant fund accounting per OMB Uniform Guidance 2 CFR 200 cost allocation requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The timestamp when the staff member record was first created in the Ngo data platform, in ISO 8601 format with timezone offset (yyyy-MM-ddTHH:mm:ss.SSSXXX). Provides audit trail for data governance and compliance purposes.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'The staff member\'s date of birth in ISO 8601 format (yyyy-MM-dd). Used for age verification, retirement planning, benefits eligibility, and visa/travel documentation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'The organizational department or division to which the staff member is assigned (e.g., Programs, Finance, MEAL, Logistics, HR, Communications). Used for organizational reporting, budget allocation, and RACI assignments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyStation rdf:type rdf:Property ;
    rdfs:label 'Duty Station' ;
    rdfs:comment 'The official location where the staff member is assigned to work, typically expressed as a city and country (e.g., Nairobi, KEN; Kabul, AFG). Used for hardship allowance calculation, security risk management, and field operations coordination per OCHA duty station classifications.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyStationCountry rdf:type rdf:Property ;
    rdfs:label 'Duty Station Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the staff member\'s duty station country. Used for geographic workforce analytics, country-level headcount reporting, and compliance with host-country labor laws.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'The full name of the staff member\'s designated next-of-kin or emergency contact person. Used for critical incident notification, medical emergencies, and death-in-service protocols in field operations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'The telephone number of the staff member\'s designated emergency contact in E.164 international format. Used for critical incident notification and next-of-kin communication in field operations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactRelationship rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Relationship' ;
    rdfs:comment 'The relationship of the emergency contact to the staff member (e.g., spouse, parent, sibling). Used to contextualize next-of-kin notifications and legal next-of-kin determinations in death-in-service cases.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeNumber rdf:type rdf:Property ;
    rdfs:label 'Employee Number' ;
    rdfs:comment 'The human-readable, organization-assigned employee identification number used in payroll, HR correspondence, and access control systems. Distinct from the surrogate staff_member_id.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current lifecycle state of the staff member\'s employment at Ngo. Drives access control, payroll processing, and workforce headcount reporting. \'active\' = currently employed and working; \'on_leave\' = approved absence; \'suspended\' = temporarily not working pending investigation; \'separated\' = employment ended; \'probation\' = within initial probationary period.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the staff member by geographic and operational deployment category. National staff are locally hired; international staff are deployed from another country; expatriates are on international assignment; field personnel are based in program delivery locations. Drives compensation bands, benefits packages, and NICRA cost allocation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitInterviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Completed' ;
    rdfs:comment 'Indicates whether the staff member completed an exit interview prior to or at separation. Used to track organizational learning compliance and ensure knowledge transfer processes are followed per CHS Core Humanitarian Standard accountability requirements.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Final Settlement Amount' ;
    rdfs:comment 'The total monetary amount paid to the staff member as final settlement upon separation, including any outstanding salary, accrued leave payout, severance, and gratuity as applicable under local labor law and contract terms.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftePercentage rdf:type rdf:Property ;
    rdfs:label 'Fte Percentage' ;
    rdfs:comment 'The proportion of full-time hours this staff member is contracted to work, expressed as a percentage (e.g., 100.00 for full-time, 50.00 for half-time). Used for headcount reporting, grant effort allocation, and Indirect Cost Rate (ICR/NICRA) calculations.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'The staff member\'s self-identified gender. Used for workforce diversity reporting, gender-disaggregated MEL indicators, and compliance with donor reporting requirements (e.g., USAID, DFID gender equity mandates).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'The official date on which the staff member commenced employment with Ngo, as recorded in Workday HCM. Used for service length calculations, benefits vesting schedules, probation period tracking, and anniversary-based entitlements.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The timestamp of the most recent update to the staff member record in the Ngo data platform, in ISO 8601 format with timezone offset (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for change data capture, data freshness monitoring, and audit compliance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalFirstName rdf:type rdf:Property ;
    rdfs:label 'Legal First Name' ;
    rdfs:comment 'The staff member\'s legal given name as it appears on official government-issued identification documents. Used for payroll, visa, and compliance documentation.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalLastName rdf:type rdf:Property ;
    rdfs:label 'Legal Last Name' ;
    rdfs:comment 'The staff member\'s legal family/surname as it appears on official government-issued identification documents. Used for payroll, visa, and compliance documentation.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'The staff member\'s nationality represented as an ISO 3166-1 alpha-3 country code (e.g., USA, GBR, KEN). Used for expatriate management, work permit tracking, and national vs. international staff classification.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passportExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Passport Expiry Date' ;
    rdfs:comment 'The expiry date of the staff member\'s passport. Used to trigger renewal alerts and ensure compliance with international travel and visa requirements for field deployments.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passportNumber rdf:type rdf:Property ;
    rdfs:label 'Passport Number' ;
    rdfs:comment 'The staff member\'s passport number, required for international travel, visa applications, and expatriate deployment documentation. Stored securely in compliance with data protection regulations.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'The frequency at which the staff member is paid (e.g., monthly, bi-weekly). Drives payroll cycle scheduling in Workday HCM and cash flow planning for field operations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'The name the staff member prefers to be addressed by in day-to-day operations, which may differ from their legal name. Used in internal communications, email display names, and staff directories.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probationEndDate rdf:type rdf:Property ;
    rdfs:label 'Probation End Date' ;
    rdfs:comment 'The date on which the staff member\'s probationary period is scheduled to end. Used to trigger performance review workflows and confirm or terminate employment within the probation window.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rehireEligible rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligible' ;
    rdfs:comment 'Indicates whether the staff member is eligible for rehire at Ngo following separation. Set to false for staff separated due to gross misconduct, fraud, or serious policy violations. Used during talent acquisition screening.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salaryCurrency rdf:type rdf:Property ;
    rdfs:label 'Salary Currency' ;
    rdfs:comment 'The ISO 4217 three-letter currency code in which the staff member\'s base salary is denominated (e.g., USD, EUR, KES). Required for multi-currency payroll consolidation and grant financial reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationDate rdf:type rdf:Property ;
    rdfs:label 'Separation Date' ;
    rdfs:comment 'The effective date on which the staff member\'s employment with Ngo ended. Used for final payroll processing, benefits termination, access revocation, and workforce attrition reporting.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:separationReason rdf:type rdf:Property ;
    rdfs:label 'Separation Reason' ;
    rdfs:comment 'A free-text narrative describing the specific reason for the staff member\'s separation from Ngo. Complements the separation_type categorical field with contextual detail for HR records, exit documentation, and workforce analytics.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationType rdf:type rdf:Property ;
    rdfs:label 'Separation Type' ;
    rdfs:comment 'The category of employment separation event for staff members whose employment has ended. Drives final settlement calculations, rehire eligibility determination, and statutory reporting. Values: resignation (voluntary), end_of_contract (fixed-term expiry), redundancy (position eliminated), termination (involuntary dismissal), retirement (age/service-based), death_in_service.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workEmail rdf:type rdf:Property ;
    rdfs:label 'Work Email' ;
    rdfs:comment 'The official organizational email address assigned to the staff member. Primary digital contact channel for HR communications, system access provisioning, and donor/partner correspondence.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPermitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Work Permit Expiry Date' ;
    rdfs:comment 'The expiry date of the staff member\'s work permit or visa authorization. Used to trigger renewal workflows and ensure continuous legal authorization to work in the duty station country.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Work Permit Number' ;
    rdfs:comment 'The work permit or visa authorization number for staff members who require legal authorization to work in their duty station country. Null for staff working in their country of nationality.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhone rdf:type rdf:Property ;
    rdfs:label 'Work Phone' ;
    rdfs:comment 'The staff member\'s official work telephone number in E.164 international format. Used for operational communications, field coordination, and emergency contact protocols.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayWorkerReference rdf:type rdf:Property ;
    rdfs:label 'Workday Worker Reference' ;
    rdfs:comment 'The unique worker identifier assigned by Workday HCM, used to cross-reference this record with the source system of record for all HR transactions, payroll, and benefits data.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Unique system-generated identifier for an authorized organizational position (headcount slot) within Ngo\'s structure. This is the primary key for the position entity in Workday HCM.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:complianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.obligation. Business justification: Positions have mandatory compliance obligations (safeguarding-designated roles require specific certifications, field positions require security clearances). Enables role-based compliance tracking and' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Budgeted positions are assigned to cost centers for headcount budgeting and functional expense planning; FK enables position-level cost center reporting essential for NGO organizational budget managem' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:financeFundId rdf:type rdf:Property ;
    rdfs:label 'Finance Fund Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_fund. Business justification: Grant-funded positions require fund-level tracking for donor compliance and position budget management; FK enables fund-level headcount reporting and supports donor requirements for personnel cost tra' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceFund .

ind:hostPartnerOrgId rdf:type rdf:Property ;
    rdfs:label 'Host Partner Org Id' ;
    rdfs:comment 'Foreign key linking to partnership.partner_org. Business justification: NGOs create joint or co-funded positions hosted by partner organizations (embedded technical advisors, joint program coordinators). Linking positions to the host partner org enables tracking of partne' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerOrg .

ind:interventionId rdf:type rdf:Property ;
    rdfs:label 'Intervention Id' ;
    rdfs:comment 'Reference to the program or project to which this position is assigned. Enables grant-funded headcount tracking per program and supports RACI role assignments across programs.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Intervention .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Reference to the organizational department or cost center to which this position belongs. Used in organizational design, Chart of Accounts (CoA) mapping, and headcount reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:reportsToPositionId rdf:type rdf:Property ;
    rdfs:label 'Reports To Position Id' ;
    rdfs:comment 'Reference to the parent position in the organizational hierarchy to which this position reports. Enables organizational chart construction, span-of-control analysis, and RACI role assignment across programs.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:availabilityDate rdf:type rdf:Property ;
    rdfs:label 'Availability Date' ;
    rdfs:comment 'Date from which the position is authorized and available for filling, either through recruitment or internal transfer. Marks the effective start of the headcount slot in the organizational plan.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetedAnnualCost rdf:type rdf:Property ;
    rdfs:label 'Budgeted Annual Cost' ;
    rdfs:comment 'Total budgeted annual cost of the position including salary, benefits, and applicable indirect cost rate (ICR/NICRA), in the salary currency. Used in grant budget justifications, Budget versus Actual (BvA) reporting, and workforce cost planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyStationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Duty Station Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the position is based. Used for expatriate management, tax compliance, and geographic workforce analytics.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date on which the position authorization expires or is eliminated. Nullable for permanent positions. For grant-funded positions, typically aligned with the grant period of performance end date.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filledDate rdf:type rdf:Property ;
    rdfs:label 'Filled Date' ;
    rdfs:comment 'Date on which the position was most recently filled by an incumbent. Used to calculate time-to-fill metrics and vacancy duration reporting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fteAllocation rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation' ;
    rdfs:comment 'Authorized Full-Time Equivalent (FTE) percentage allocated to this position, expressed as a decimal (e.g., 1.00 = full-time, 0.50 = half-time). Used in workforce planning, grant budget justifications, and headcount reporting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingSourceType rdf:type rdf:Property ;
    rdfs:label 'Funding Source Type' ;
    rdfs:comment 'Classification of the primary funding source for this position. \'Grant\' indicates the position is funded by a specific donor award; \'core\' indicates unrestricted organizational funding; \'split\' indicates funding from multiple sources; \'in-kind\' indicates a contributed position; \'cost-share\' indicates a position partially funded as match on a grant.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountPlanYear rdf:type rdf:Property ;
    rdfs:label 'Headcount Plan Year' ;
    rdfs:comment 'Fiscal or calendar year for which this position is authorized in the organizational headcount plan. Used in annual workforce planning cycles and grant budget period alignment.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:icrApplicable rdf:type rdf:Property ;
    rdfs:label 'Icr Applicable' ;
    rdfs:comment 'Indicates whether the Negotiated Indirect Cost Rate Agreement (NICRA) / Indirect Cost Rate (ICR) applies to this position\'s costs when charged to federal grants. Drives Facilities and Administration (F&A) cost calculations in grant financial management.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFieldPosition rdf:type rdf:Property ;
    rdfs:label 'Is Field Position' ;
    rdfs:comment 'Indicates whether this position is classified as a field operations position (True) versus a headquarters or support office position (False). Drives hardship allowance eligibility, security protocols, and field operations staffing analytics.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSupervisory rdf:type rdf:Property ;
    rdfs:label 'Is Supervisory' ;
    rdfs:comment 'Indicates whether this position carries supervisory or managerial responsibility over other positions (True = supervisory). Used in organizational design, RACI role assignments, and span-of-control analytics.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVacant rdf:type rdf:Property ;
    rdfs:label 'Is Vacant' ;
    rdfs:comment 'Indicates whether the position currently has no active incumbent (True = vacant, False = filled). Drives recruitment requisition creation and vacancy reporting to donors and boards.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobDescriptionUrl rdf:type rdf:Property ;
    rdfs:label 'Job Description Url' ;
    rdfs:comment 'URL or document management system reference to the official job description document for this position. Provides access to the full scope of work, responsibilities, and qualifications for recruitment and performance management purposes.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp when this position record was most recently updated, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Supports change tracking, audit compliance, and incremental data pipeline processing.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxSalary rdf:type rdf:Property ;
    rdfs:label 'Max Salary' ;
    rdfs:comment 'Maximum base salary authorized for this position\'s pay grade band, in the local or organizational currency. Used in budget ceiling planning and compensation equity analysis.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Min Education Level' ;
    rdfs:comment 'Minimum academic qualification required for this position as defined in the job profile. Used in recruitment requisition creation and candidate screening. [ENUM-REF-CANDIDATE: none|secondary|diploma|bachelor|master|doctorate|professional — promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minSalary rdf:type rdf:Property ;
    rdfs:label 'Min Salary' ;
    rdfs:comment 'Minimum base salary authorized for this position\'s pay grade band, in the local or organizational currency. Used in budget planning, grant budget justifications, and compensation equity analysis.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Min Years Experience' ;
    rdfs:comment 'Minimum number of years of relevant professional experience required for this position as defined in the job profile. Used in recruitment requisition creation and candidate screening.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payGradeBand rdf:type rdf:Property ;
    rdfs:label 'Pay Grade Band' ;
    rdfs:comment 'Compensation grade band assigned to this position as defined in the organization\'s salary scale (e.g., \'G5\', \'P3\', \'NB4\'). Determines the salary range applicable to the position. Classified as confidential business data.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the position within the organization\'s headcount plan and Workday HCM job catalog. Used in grant proposals, budget submissions, and organizational charts.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle state of the position headcount slot. \'Open\' indicates a vacancy available for recruitment; \'filled\' indicates an active incumbent; \'frozen\' indicates a position on hold due to budget constraints; \'eliminated\' indicates the position has been removed from the headcount plan; \'proposed\' indicates pending organizational approval.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Classification of the position by employment arrangement. \'Permanent\' indicates an indefinite contract; \'fixed-term\' indicates a time-bound contract; \'temporary\' indicates a short-term assignment; \'secondment\' indicates a position filled by staff from a partner organization; \'volunteer\' indicates an unpaid position.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raciRole rdf:type rdf:Property ;
    rdfs:label 'Raci Role' ;
    rdfs:comment 'Primary Responsible Accountable Consulted Informed (RACI) role designation for this position within program delivery processes. Supports organizational design and program accountability frameworks.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCompetencies rdf:type rdf:Property ;
    rdfs:label 'Required Competencies' ;
    rdfs:comment 'Comma-separated list of core competencies required for this position as defined in the Workday HCM competency framework (e.g., \'Results Orientation, Teamwork, Communication, WASH Technical Skills\'). Used in performance management and talent acquisition.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredLanguages rdf:type rdf:Property ;
    rdfs:label 'Required Languages' ;
    rdfs:comment 'Comma-separated list of language proficiency requirements for this position (e.g., \'English (fluent), French (working), Swahili (basic)\'). Critical for field operations positions in multilingual humanitarian contexts.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Salary Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the salary values associated with this position (e.g., \'USD\', \'KES\', \'EUR\'). Required for multi-currency workforce cost reporting and grant budget submissions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Required' ;
    rdfs:comment 'Indicates whether this position requires a formal security clearance or background check (True = required). Relevant for positions handling restricted donor data, financial systems, or operating in high-risk field environments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:staffCategory rdf:type rdf:Property ;
    rdfs:label 'Staff Category' ;
    rdfs:comment 'Classification of the position by staff type. \'National\' refers to locally-hired staff; \'international\' refers to internationally-recruited staff; \'expatriate\' refers to staff deployed from another country; \'consultant\' refers to contracted technical advisors; \'intern\' refers to learning positions. Drives compensation frameworks, benefits eligibility, and visa/work permit requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Official job title of the position as defined in the organizational structure and Workday HCM job catalog. Used in recruitment requisitions, offer letters, and donor/grant reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vacancyReason rdf:type rdf:Property ;
    rdfs:label 'Vacancy Reason' ;
    rdfs:comment 'Reason why the position is currently vacant. Used in workforce analytics, turnover reporting, and recruitment planning. [ENUM-REF-CANDIDATE: new_position|resignation|termination|transfer|promotion|retirement|contract_end — promote to reference product]' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayPositionReference rdf:type rdf:Property ;
    rdfs:label 'Workday Position Reference' ;
    rdfs:comment 'Native position identifier from the Workday HCM source system. Used for data lineage, system reconciliation, and integration with Workday HCM APIs.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentContractId rdf:type rdf:Property ;
    rdfs:label 'Employment Contract Id' ;
    rdfs:comment 'Unique system-generated identifier for each employment contract record in Workday HCM. Serves as the primary key for the employment_contract data product in the workforce domain.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmploymentContract .

ind:awardId rdf:type rdf:Property ;
    rdfs:label 'Award Id' ;
    rdfs:comment 'Foreign key linking to grant.award. Business justification: NGOs must track which grant funds each employment contract for cost allocation, donor compliance, and personnel cost charging. Critical for grant-funded position management, financial reporting, and d' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Award .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Foreign key linking to finance.budget_line. Business justification: Employment contracts consume specific budget lines for personnel costs; FK enables direct linkage between contracted salary costs and approved budget lines, supporting grant budget management and dono' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetLine .

ind:countryOfficeId rdf:type rdf:Property ;
    rdfs:label 'Country Office Id' ;
    rdfs:comment 'Foreign key linking to field.country_office. Business justification: Employment contracts for field staff are issued under a specific country office\'s legal entity and labor jurisdiction. Contract management, legal compliance audits, and payroll processing all require ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CountryOffice .

ind:fundingSourceId rdf:type rdf:Property ;
    rdfs:label 'Funding Source Id' ;
    rdfs:comment 'Foreign key linking to grant.funding_source. Business justification: Donor-funded employment contracts must be traceable to the funding source for compliance with donor staffing requirements, key personnel approvals, and budget accountability. \'funding_source_code\' is ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundingSource .

ind:secondmentPartnerOrgId rdf:type rdf:Property ;
    rdfs:label 'Secondment Partner Org Id' ;
    rdfs:comment 'Foreign key linking to partnership.partner_org. Business justification: NGOs regularly second staff to or receive seconded staff from partner organizations. The employment contract for a seconded staff member must reference the partner org for HR administration, cost reco' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerOrg .

ind:amendmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Effective Date' ;
    rdfs:comment 'The date from which the most recent contract amendment takes effect. Null for original contracts with no amendments. Used in conjunction with amendment_number to track the timeline of contract changes.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential integer tracking the number of amendments made to the original employment contract. Zero indicates the original contract; each amendment increments this counter. Enables tracking of contract renewals, salary revisions, duty station changes, and other modifications over the contract lifecycle.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'The business reason for the most recent contract amendment. Used for HR analytics, audit trails, and workforce planning. [ENUM-REF-CANDIDATE: renewal|salary_revision|duty_station_change|promotion|contract_type_change|scope_change|other — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which the employment contract was formally approved by the authorized signatory. Used in audit trails and compliance reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'The name or identifier of the authorized signatory or approving authority who approved this employment contract. Typically the Country Director, HR Director, or delegated authority per the organization\'s RACI (Responsible Accountable Consulted Informed) framework.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference number assigned to the employment contract, used in HR correspondence, legal documentation, and audit trails. Typically formatted as ORG-YEAR-SEQUENCE (e.g., NGO-2024-EMP0042).' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the employment contract. Draft indicates pending approval; active indicates a currently binding agreement; on_hold covers suspension; terminated covers early cessation; expired covers contracts that reached their end date without renewal; amended covers contracts under revision.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Education Allowance Amount' ;
    rdfs:comment 'The annual monetary amount of education allowance provided for dependent children of expatriate staff members. Covers school fees and related educational expenses at the duty station or in the home country. Expressed in the contract currency. Null for non-expatriate staff or staff without eligible dependents.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardshipAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Hardship Allowance Amount' ;
    rdfs:comment 'The monthly monetary amount of hardship allowance payable to the expatriate staff member based on their hardship tier and salary grade. Expressed in the contract currency. Null for non-expatriate staff or H-classified duty stations.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardshipTier rdf:type rdf:Property ;
    rdfs:label 'Hardship Tier' ;
    rdfs:comment 'The UN/ICSC hardship classification tier assigned to the duty station, determining the hardship allowance percentage applicable to the staff member\'s salary. H = headquarters (no hardship); A through E represent increasing levels of hardship, with E being the most difficult duty stations (e.g., active conflict zones). Null for non-expatriate staff.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeLeaveFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Home Leave Frequency Months' ;
    rdfs:comment 'The number of months between home leave entitlements for expatriate staff, defining how frequently the staff member is entitled to travel to their home country at organizational expense. Typically 12 or 24 months depending on duty station hardship classification. Null for non-expatriate staff.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:housingAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Housing Allowance Amount' ;
    rdfs:comment 'The monthly monetary amount of housing allowance provided to the expatriate staff member at the duty station. Reflects local rental market rates and organizational housing policy. Expressed in the contract currency. Null for non-expatriate staff or staff in NGO-provided accommodation.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:icrRate rdf:type rdf:Property ;
    rdfs:label 'Icr Rate' ;
    rdfs:comment 'The Indirect Cost Rate (ICR) or Facilities and Administration (F&A) rate applicable to this staff member\'s contract for grant cost recovery purposes. Expressed as a decimal (e.g., 0.1500 = 15%). Derived from the organization\'s NICRA (Negotiated Indirect Cost Rate Agreement) with the US government or equivalent donor agreement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingoSalaryScale rdf:type rdf:Property ;
    rdfs:label 'Ingo Salary Scale' ;
    rdfs:comment 'The salary scale framework applied to this contract, particularly relevant for internationally-recruited staff. UN common system applies UN salary tables; organizational_scale uses the NGO\'s internal scale; national_scale applies host-country national staff scales. Determines applicable grade tables and allowance structures.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExpatriate rdf:type rdf:Property ;
    rdfs:label 'Is Expatriate' ;
    rdfs:comment 'Indicates whether the staff member under this contract is classified as an expatriate (internationally-recruited staff deployed outside their home country). Triggers eligibility for expatriate compensation package components including hardship allowance, housing allowance, education allowance, home leave, and R&R.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Labor Law Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction whose labor laws and employment regulations govern this contract (e.g., \'Kenya\', \'Ethiopia\', \'United Kingdom\', \'United States\'). Determines statutory entitlements, termination procedures, and compliance obligations. Critical for multi-country NGO operations.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medevacCoverageLevel rdf:type rdf:Property ;
    rdfs:label 'Medevac Coverage Level' ;
    rdfs:comment 'The tier of medical evacuation coverage provided under this contract, determining the scope of emergency medical transport and treatment entitlements. Full coverage includes international evacuation to a tertiary care facility; basic covers regional evacuation only. Critical for field staff safety and duty of care compliance.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for HR staff to record additional context, special conditions, or exceptions applicable to this employment contract that are not captured in structured fields (e.g., special security arrangements, unique compensation agreements, donor-specific staffing conditions).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'The number of calendar days of advance notice required by either party to terminate the employment contract. Varies by contract type, seniority, and applicable labor law jurisdiction. Used in workforce planning and HR compliance.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relocationAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Relocation Allowance Amount' ;
    rdfs:comment 'The one-time monetary amount provided to cover relocation costs when the staff member moves to the duty station at the start of the contract. Expressed in the contract currency. Null for locally-recruited national staff or contract renewals without relocation.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rnrCycleWeeks rdf:type rdf:Property ;
    rdfs:label 'Rnr Cycle Weeks' ;
    rdfs:comment 'The number of weeks between Rest and Recuperation (R&R) breaks for staff deployed to high-hardship or non-family duty stations. R&R is a mandatory welfare entitlement for staff in difficult operating environments (e.g., every 6, 8, or 12 weeks). Null for staff at H or A hardship-classified duty stations.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salaryFrequency rdf:type rdf:Property ;
    rdfs:label 'Salary Frequency' ;
    rdfs:comment 'The frequency at which the base salary is paid to the staff member. Determines payroll cycle alignment and annualization calculations for budget planning and grant reporting.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryGrade rdf:type rdf:Property ;
    rdfs:label 'Salary Grade' ;
    rdfs:comment 'The compensation band or grade level assigned to the position under this contract, as defined in the NGO\'s salary scale (e.g., UN common system grade G5, P3, or organizational scale Band C). Determines the salary range and step progression applicable to the staff member.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryStep rdf:type rdf:Property ;
    rdfs:label 'Salary Step' ;
    rdfs:comment 'The incremental step within the salary grade assigned to the staff member, reflecting years of experience or merit progression within the grade band (e.g., Step 1, Step 2, Step III). Used in conjunction with salary_grade to determine exact base pay.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The date on which the employment contract becomes effective and the staff member\'s obligations and entitlements commence. Corresponds to the MASTER_AGREEMENT EFFECTIVE_FROM category.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'The actual date on which the employment contract was terminated, if applicable. Distinct from end_date (scheduled expiry); this captures early terminations, resignations, and dismissals. Null for active contracts.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'The reason for contract termination, used in workforce analytics, exit reporting, and compliance with labor law notification requirements. [ENUM-REF-CANDIDATE: resignation|end_of_contract|redundancy|dismissal|mutual_agreement|death|other — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayContractReference rdf:type rdf:Property ;
    rdfs:label 'Workday Contract Reference' ;
    rdfs:comment 'The native contract or worker agreement identifier from Workday HCM, the system of record for this data product. Used for data lineage, source system reconciliation, and integration with Workday payroll and benefits modules.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Org units post financial transactions to specific GL accounts; FK enables automated financial reporting by organizational unit and supports chart of accounts alignment with organizational structure. R' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent organizational unit, enabling recursive parent-child hierarchy traversal for headcount, payroll, and program staffing rollups. Null for the root/top-level unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:annualBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Usd' ;
    rdfs:comment 'Total approved annual operating budget allocated to this organizational unit in US Dollars, covering both core and grant-funded expenditures. Used for BvA reporting, fund accounting, and financial stewardship in SAP S/4HANA and Unit4 ERP.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cityName rdf:type rdf:Property ;
    rdfs:label 'City Name' ;
    rdfs:comment 'Name of the city or locality where the organizational unit\'s primary office is situated. Used for operational logistics, staff deployment planning, and field operations coordination.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code indicating the country where this organizational unit is physically located or registered (e.g., \'KEN\' for Kenya, \'SDN\' for Sudan, \'USA\' for United States). Used for geographic reporting and IATI disclosure.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the primary operating currency of this organizational unit (e.g., \'USD\', \'EUR\', \'KES\'). Used for multi-currency financial reporting and fund accounting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date on which this organizational unit ceased to be operationally effective (dissolution, merger, or restructuring). Null for currently active units. Used for historical headcount and grant financial reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date on which this organizational unit became operationally effective and began appearing in headcount, payroll, and program staffing reports. Supports point-in-time historical analysis.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundingModel rdf:type rdf:Property ;
    rdfs:label 'Funding Model' ;
    rdfs:comment 'Indicates how the organizational unit is financially sustained. \'core\' = funded from unrestricted/core organizational budget; \'grant_funded\' = funded entirely by restricted donor grants; \'mixed\' = combination of core and grant funding; \'self_funded\' = generates own revenue. Critical for fund accounting and BvA reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountActual rdf:type rdf:Property ;
    rdfs:label 'Headcount Actual' ;
    rdfs:comment 'Current number of active staff members assigned to this organizational unit as recorded in Workday HCM. Used for real-time workforce reporting, MEL dashboards, and BvA staffing analysis.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountAuthorized rdf:type rdf:Property ;
    rdfs:label 'Headcount Authorized' ;
    rdfs:comment 'Maximum number of staff positions (both national and international) authorized for this organizational unit as per the approved organizational structure and donor-approved staffing plans. Used for workforce planning and grant compliance.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of this organizational unit within the global hierarchy tree (e.g., 1 = Global HQ, 2 = Regional Office, 3 = Country Office, 4 = Area/Field Office, 5 = Program Unit). Enables efficient hierarchical queries and rollup reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path string representing the full ancestry chain of the organizational unit from root to current node (e.g., \'/1/5/12/34/\'). Enables fast subtree queries for headcount and payroll rollups without recursive joins.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatiOrgIdentifier rdf:type rdf:Property ;
    rdfs:label 'Iati Org Identifier' ;
    rdfs:comment 'Unique International Aid Transparency Initiative (IATI) organization identifier assigned to this unit for transparent aid reporting and donor disclosure. Required for IATI-compliant activity reporting by USAID, DFID, and other ODA donors.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internationalStaffCount rdf:type rdf:Property ;
    rdfs:label 'International Staff Count' ;
    rdfs:comment 'Number of international (expatriate) staff currently assigned to this organizational unit. Used for expatriate management reporting, visa/work permit tracking, and INGO staffing ratio compliance.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFieldOffice rdf:type rdf:Property ;
    rdfs:label 'Is Field Office' ;
    rdfs:comment 'Indicates whether this organizational unit is classified as a field office operating in a humanitarian or development program context (True) versus a non-field administrative or HQ unit (False). Used to apply field-specific HR policies, allowances, and security protocols.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHq rdf:type rdf:Property ;
    rdfs:label 'Is Hq' ;
    rdfs:comment 'Indicates whether this organizational unit is the global or regional headquarters (True). Used to distinguish HQ administrative units from field and country offices in hierarchical reporting and governance structures.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandateDescription rdf:type rdf:Property ;
    rdfs:label 'Mandate Description' ;
    rdfs:comment 'Narrative description of the organizational unit\'s mandate, scope of work (SoW), and primary responsibilities within the Ngo\'s Theory of Change (ToC). Used for onboarding, stakeholder engagement, and compliance reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalStaffCount rdf:type rdf:Property ;
    rdfs:label 'National Staff Count' ;
    rdfs:comment 'Number of national (locally-hired) staff currently assigned to this organizational unit. Supports localization reporting, donor compliance requirements, and INGO staffing ratio analysis.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:officeAddress rdf:type rdf:Property ;
    rdfs:label 'Office Address' ;
    rdfs:comment 'Physical street address of the organizational unit\'s primary office location. Classified as confidential organizational contact data used for operational correspondence, audit, and regulatory filings.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeEmail rdf:type rdf:Property ;
    rdfs:label 'Office Email' ;
    rdfs:comment 'Primary email address for the organizational unit used for official correspondence, donor communications, and regulatory filings. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officePhone rdf:type rdf:Property ;
    rdfs:label 'Office Phone' ;
    rdfs:comment 'Primary telephone number for the organizational unit\'s office. Classified as confidential organizational contact data used for inter-office communications, emergency coordination, and stakeholder engagement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Org Unit Status' ;
    rdfs:comment 'Current lifecycle status of the organizational unit. \'active\' = operational; \'inactive\' = temporarily suspended; \'pending\' = awaiting activation; \'dissolved\' = permanently closed; \'merged\' = absorbed into another unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Code identifying the primary humanitarian or development program this organizational unit is aligned to (e.g., WASH, GBV, PSS, Nutrition). Enables program-level staffing and cost reporting in MEL dashboards and donor reports. Applicable primarily to program_unit type org units.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Name of the geographic region or sub-national administrative area where this unit operates (e.g., \'East Africa\', \'West Africa\', \'Middle East and North Africa\', \'South Asia\'). Supports regional rollup reporting for MEL dashboards and donor reports.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sap Company Code' ;
    rdfs:comment 'SAP S/4HANA company code associated with this organizational unit for General Ledger (GL), Accounts Payable (AP), Accounts Receivable (AR), and fund accounting integration. Enables cross-system financial reconciliation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'UN/UNDSS security phase classification applicable to the location of this organizational unit (Phase 1 = Minimal, Phase 5 = Emergency). Drives staff deployment decisions, field operations protocols, and duty-of-care obligations for expatriate and national staff.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the organizational unit across systems (Workday HCM, SAP S/4HANA Chart of Accounts, Unit4 ERP). Used as the business identifier in cross-system integrations and financial reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitMissionStatement rdf:type rdf:Property ;
    rdfs:label 'Unit Mission Statement' ;
    rdfs:comment 'Formal mission statement specific to this organizational unit, articulating its contribution to the Ngo\'s overall mission and SDG alignment. Used in annual reports, donor communications, and regulatory filings.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Full human-readable name of the organizational unit (e.g., \'East Africa Regional Office\', \'WASH Program Unit – South Sudan\', \'Finance and Administration Department – HQ\'). Used in all reporting, dashboards, and donor communications.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitShortName rdf:type rdf:Property ;
    rdfs:label 'Unit Short Name' ;
    rdfs:comment 'Abbreviated or shortened display name for the organizational unit used in dashboards, SitRep headers, and space-constrained reporting contexts (e.g., \'EA Regional\', \'WASH-SSD\').' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the organizational unit within the global Ngo structure. Drives hierarchical reporting logic and determines applicable governance rules. [ENUM-REF-CANDIDATE: hq_department|regional_office|country_office|area_office|field_office|program_unit|cost_center — promote to reference product]' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this organizational unit record in the source system (Workday HCM). Used for change data capture (CDC), incremental loads, and audit compliance in the Databricks Lakehouse Silver Layer.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:volunteerCount rdf:type rdf:Property ;
    rdfs:label 'Volunteer Count' ;
    rdfs:comment 'Number of active volunteers currently assigned to or managed by this organizational unit, as tracked in Microsoft Dynamics 365 Volunteer Coordination. Used for workforce capacity reporting and donor impact metrics.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workdayOrgReference rdf:type rdf:Property ;
    rdfs:label 'Workday Org Reference' ;
    rdfs:comment 'Native organization identifier assigned by Workday HCM to this organizational unit. Used as the source system key for data integration, reconciliation, and lineage tracking between Workday HCM and the Databricks Lakehouse Silver Layer.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckLevel rdf:type rdf:Property ;
    rdfs:label 'Background Check Level' ;
    rdfs:comment 'Required level of pre-employment background screening for this job profile. \'child_protection\' and \'enhanced\' checks are mandatory for safeguarding-designated roles and roles with access to vulnerable beneficiaries, per CHS and donor requirements.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyFrameworkCode rdf:type rdf:Property ;
    rdfs:label 'Competency Framework Code' ;
    rdfs:comment 'Reference code identifying the competency framework applied to this job profile (e.g., CHS competency framework, Ngo internal framework, IASC humanitarian competencies). Links to the competency library in Workday HCM for performance management and talent development.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coreCompetencies rdf:type rdf:Property ;
    rdfs:label 'Core Competencies' ;
    rdfs:comment 'Comma-separated list of core behavioral and technical competencies required for this job profile as defined in the Workday HCM competency library (e.g., \'Accountability\', \'Communication\', \'Collaboration\', \'Results Orientation\', \'MEAL Proficiency\'). Used in performance reviews and talent assessments.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyStationType rdf:type rdf:Property ;
    rdfs:label 'Duty Station Type' ;
    rdfs:comment 'Classification of the expected duty station for this job profile. \'roving\' indicates the role covers multiple field locations. Drives hardship allowance eligibility, security protocols, and benefits packages for field personnel.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which this job profile version became active and available for use in position creation and recruitment in Workday HCM. Supports versioning and historical tracking of job profile changes.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldExperienceRequired rdf:type rdf:Property ;
    rdfs:label 'Field Experience Required' ;
    rdfs:comment 'Indicates whether prior humanitarian field experience (e.g., deployment in conflict zones, disaster response, IDP (Internally Displaced Person) settings) is a mandatory requirement for this job profile. Critical for operational roles in Ngo\'s field programs.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flsaExemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Flsa Exemption Status' ;
    rdfs:comment 'Indicates whether the job profile is classified as exempt or non-exempt under the US Fair Labor Standards Act (FLSA) for overtime eligibility purposes. \'not_applicable\' for roles outside US jurisdiction. Required for US-based payroll compliance.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icrCostCategory rdf:type rdf:Property ;
    rdfs:label 'Icr Cost Category' ;
    rdfs:comment 'Classification of the job profile\'s cost as direct, indirect, or shared for purposes of grant budget allocation and NICRA (Negotiated Indirect Cost Rate Agreement) compliance. Determines how staff costs are charged to grants and reported to donors such as USAID and BHA.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalRole rdf:type rdf:Property ;
    rdfs:label 'Is Critical Role' ;
    rdfs:comment 'Indicates whether this job profile is designated as a critical or key position within Ngo\'s organizational structure. Critical roles are prioritized in succession planning, talent retention programs, and emergency staffing protocols.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafeguardingDesignated rdf:type rdf:Property ;
    rdfs:label 'Is Safeguarding Designated' ;
    rdfs:comment 'Indicates whether this job profile is designated as a safeguarding role requiring enhanced background checks, child protection clearances, and mandatory safeguarding training. Mandatory for roles working directly with beneficiaries, children, or vulnerable populations.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobCategory rdf:type rdf:Property ;
    rdfs:label 'Job Category' ;
    rdfs:comment 'Classification of the job profile by employment category as used in Ngo HR and payroll systems. Distinguishes national staff, international staff (INGO), expatriates, consultants, volunteers, and interns. Drives benefits eligibility, tax treatment, and regulatory compliance reporting.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamilyGroupName rdf:type rdf:Property ;
    rdfs:label 'Job Family Group Name' ;
    rdfs:comment 'The broader job family group that clusters related job families in the Workday HCM hierarchy (e.g., \'Operations\', \'Finance\', \'Technical Specialists\', \'Leadership\'). Enables enterprise-level workforce analytics and organizational design.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamilyName rdf:type rdf:Property ;
    rdfs:label 'Job Family Name' ;
    rdfs:comment 'The job family grouping to which this profile belongs within the Workday HCM job architecture (e.g., \'Program Management\', \'Finance and Accounting\', \'Monitoring Evaluation and Learning (MEL)\', \'Logistics and Supply Chain\', \'Human Resources\'). Supports workforce planning and compensation benchmarking.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobLevel rdf:type rdf:Property ;
    rdfs:label 'Job Level' ;
    rdfs:comment 'Standardized job level designation indicating seniority and scope of responsibility within the Ngo grading structure (e.g., \'Entry\', \'Junior\', \'Mid\', \'Senior\', \'Lead\', \'Manager\', \'Director\', \'Executive\'). Drives pay grade assignment and career pathing. [ENUM-REF-CANDIDATE: entry|junior|mid|senior|lead|manager|director|executive — promote to reference product]' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyResponsibilities rdf:type rdf:Property ;
    rdfs:label 'Key Responsibilities' ;
    rdfs:comment 'Structured narrative of the primary duties and accountabilities for this job profile. Serves as the basis for position descriptions, performance agreements, and RACI (Responsible Accountable Consulted Informed) role mapping across programs.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageRequirements rdf:type rdf:Property ;
    rdfs:label 'Language Requirements' ;
    rdfs:comment 'Comma-separated list of language proficiency requirements for this job profile (e.g., \'English:Fluent\', \'French:Working\', \'Arabic:Basic\'). Particularly relevant for international and field-based roles in Ngo\'s multi-country operations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadershipCompetencies rdf:type rdf:Property ;
    rdfs:label 'Leadership Competencies' ;
    rdfs:comment 'Comma-separated list of leadership-specific competencies required for managerial and senior roles in this job profile (e.g., \'Strategic Thinking\', \'People Development\', \'Change Management\', \'Stakeholder Engagement\'). Populated only for management-level profiles.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementLevel rdf:type rdf:Property ;
    rdfs:label 'Management Level' ;
    rdfs:comment 'Indicates whether the job profile is for an individual contributor or a people manager role, and at what management tier. Used in organizational design, RACI (Responsible Accountable Consulted Informed) role assignments, and leadership development programs.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'The compensation pay grade band assigned to this job profile (e.g., \'G5\', \'P3\', \'M2\'). Defines the salary range applicable to positions created from this profile. Confidential as it reveals internal compensation structure. Aligned with Ngo\'s compensation framework and NICRA (Negotiated Indirect Cost Rate Agreement) requirements.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGradeMaxUsd rdf:type rdf:Property ;
    rdfs:label 'Pay Grade Max Usd' ;
    rdfs:comment 'Maximum base salary in US Dollars for the pay grade band associated with this job profile. Used in compensation benchmarking, offer approvals, and grant budget ceiling calculations. Confidential as it reveals internal compensation structure.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payGradeMidpointUsd rdf:type rdf:Property ;
    rdfs:label 'Pay Grade Midpoint Usd' ;
    rdfs:comment 'Midpoint salary in US Dollars for the pay grade band, representing the market reference point for fully competent performance in this job profile. Used in compensation equity analysis and salary benchmarking against sector surveys (e.g., Birches Group, Hay Group).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payGradeMinUsd rdf:type rdf:Property ;
    rdfs:label 'Pay Grade Min Usd' ;
    rdfs:comment 'Minimum base salary in US Dollars for the pay grade band associated with this job profile. Used in budget planning, compensation benchmarking, and grant budget preparation. Confidential as it reveals internal compensation structure.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredCertifications rdf:type rdf:Property ;
    rdfs:label 'Preferred Certifications' ;
    rdfs:comment 'Comma-separated list of desirable but non-mandatory professional certifications for this job profile. Used to differentiate candidates during recruitment and to guide learning and development (L&D) planning in Workday HCM LMS.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the job profile within the Workday HCM job catalog and HRIS classification system. Used in position creation, recruitment requisitions, and cross-system integration (e.g., Unit4 ERP, payroll).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable title of the job profile as defined in the Workday HCM job catalog (e.g., \'Field Program Officer\', \'MEAL Coordinator\', \'Finance Manager\'). Used in recruitment postings, organizational charts, and staff communications.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the job profile within the Workday HCM job catalog. \'active\' profiles are available for position creation and recruitment; \'inactive\' or \'archived\' profiles are retired from use.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programArea rdf:type rdf:Property ;
    rdfs:label 'Program Area' ;
    rdfs:comment 'Primary humanitarian or development program area associated with this job profile (e.g., \'WASH (Water Sanitation and Hygiene)\', \'GBV (Gender-Based Violence)\', \'Health\', \'Education\', \'Livelihoods\', \'Nutrition\', \'PSS (Psychosocial Support)\'). Used for workforce planning and program staffing analytics.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Comma-separated list of mandatory professional certifications or licenses required for this job profile (e.g., \'CPA\', \'PMP\', \'CIPS\', \'HEAT Training\', \'SPHERE Certification\'). Used in recruitment screening and compliance tracking in Workday HCM.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgAlignment rdf:type rdf:Property ;
    rdfs:label 'Sdg Alignment' ;
    rdfs:comment 'Comma-separated list of UN Sustainable Development Goal (SDG) numbers that this job profile primarily contributes to (e.g., \'3,4,6\' for Health, Education, WASH roles). Used in donor reporting and IATI (International Aid Transparency Initiative) disclosures.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionEligibility rdf:type rdf:Property ;
    rdfs:label 'Succession Eligibility' ;
    rdfs:comment 'Indicates whether this job profile is included in Ngo\'s formal succession planning program in Workday HCM. Profiles marked as succession-eligible are tracked for talent pipeline development and leadership continuity.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Concise narrative summary of the job profile\'s purpose, primary accountabilities, and organizational context. Used as the opening paragraph in job postings and position descriptions. Aligned with Workday HCM job profile description field.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequirement rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement' ;
    rdfs:comment 'Expected level of travel associated with this job profile. \'field_based\' indicates deployment to humanitarian field operations (e.g., IDP camps, disaster response zones). Used in recruitment communications and duty of care planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version number of the job profile, incremented each time the profile is substantively revised (e.g., competency updates, pay grade changes, qualification changes). Supports audit trail and change management in Workday HCM.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayJobProfileReference rdf:type rdf:Property ;
    rdfs:label 'Workday Job Profile Reference' ;
    rdfs:comment 'The native identifier of this job profile record in the Workday HCM source system. Used for system-of-record traceability, data lineage, and integration with Workday payroll, talent, and learning modules.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Unique system-generated identifier for each payroll run record in Workday HCM. Serves as the primary key for the payroll_run entity.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.bank_account. Business justification: NGO payroll disbursements are made from specific bank accounts; linking enables treasury reconciliation, restricted fund compliance, and audit trail from payroll run to bank transaction. Replaces deno' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:fiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Id' ;
    rdfs:comment 'Foreign key linking to finance.fiscal_period. Business justification: NGO payroll runs must be posted to the correct fiscal period for financial reporting, grant burn-rate tracking, and audit compliance. Finance teams reconcile payroll costs by fiscal period. Replaces d' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Each payroll run generates a corresponding journal entry batch posting salary expenses to the GL; FK provides direct audit trail from payroll run to financial posting, essential for NGO financial audi' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Foreign key linking to program.program. Business justification: NGO donor financial reporting and grant compliance require allocating payroll costs to specific programs. \'program_code\' is a denormalized string; linking payroll_run to program enables program-level ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:statutoryRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Statutory Registration Id' ;
    rdfs:comment 'Foreign key linking to compliance.statutory_registration. Business justification: Payroll runs are executed under a specific legal entity\'s statutory registration (tax ID, employer registration). Payroll tax remittance and statutory reporting require tracing each run to the registe' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StatutoryRegistration .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'The authorization status of the payroll run within the organization\'s approval workflow. Tracks whether the run has been reviewed and approved by the designated approver (e.g., Finance Director, Country Director) before disbursement. Distinct from run_status which tracks the processing lifecycle.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The date and time at which the payroll run received final authorization. Provides an immutable audit record of when approval was granted, supporting segregation of duties controls and compliance with OMB Uniform Guidance internal control requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'The date and time when the payroll calculation was executed in Workday HCM. Marks the business event of gross-to-net computation. Distinct from approved_timestamp and created_timestamp, this captures when the financial figures were computed.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'The total number of employees included in this payroll run. Used for headcount reporting, per-capita cost analysis, and validation that all eligible staff were processed. Reconciled against HRIS (Human Resource Information System) active headcount.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate applied to convert the payroll run amounts from the local currency to the organization\'s functional reporting currency (typically USD). Sourced from the organization\'s treasury or ERP at the time of payroll processing. Required for consolidated financial reporting and BvA (Budget versus Actual) analysis.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the organization\'s functional reporting currency (e.g., USD). Used alongside exchange_rate to express payroll costs in a consistent currency for consolidated financial statements and donor reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantCode rdf:type rdf:Property ;
    rdfs:label 'Grant Code' ;
    rdfs:comment 'The grant identifier to which a portion or all of this payroll run\'s costs are charged. Enables grant-level labor cost tracking and compliance with donor reporting requirements. May be null for unrestricted payroll runs not tied to a specific grant.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRetroactive rdf:type rdf:Property ;
    rdfs:label 'Is Retroactive' ;
    rdfs:comment 'Indicates whether this payroll run includes retroactive pay adjustments for prior pay periods (e.g., backdated salary increases, correction of underpayments). Retroactive runs require special grant cost allocation treatment under OMB Uniform Guidance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'The last calendar date of the pay period covered by this payroll run. Defines the closing boundary of the earnings window. Together with pay_period_start_date, determines the scope of labor costs chargeable to grants and programs.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'The first calendar date of the pay period covered by this payroll run. Defines the beginning of the earnings window for all employees included in the run. Used for time-and-attendance reconciliation and grant cost allocation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The scheduled or actual date on which net pay is disbursed to employees\' bank accounts or via alternative payment methods. Used for cash flow planning, bank reconciliation, and compliance with local labor law payment deadlines.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The disbursement method used to pay employees in this payroll run. In humanitarian contexts, mobile money (e.g., M-Pesa) is common for field staff in remote areas. Determines the payment processing channel and reconciliation approach.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollGroup rdf:type rdf:Property ;
    rdfs:label 'Payroll Group' ;
    rdfs:comment 'Classification of the staff population covered by this payroll run. Distinguishes between national staff (locally hired), international staff (globally mobile), expatriates (expat), volunteers with stipends, and consultants. Drives applicable tax regimes, benefit structures, and compliance reporting requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedBy rdf:type rdf:Property ;
    rdfs:label 'Processed By' ;
    rdfs:comment 'The name or employee identifier of the payroll officer who initiated and processed this payroll run in Workday HCM. Supports RACI (Responsible Accountable Consulted Informed) accountability tracking and audit trail requirements.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retroactivePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Retroactive Period Start Date' ;
    rdfs:comment 'The start date of the prior period for which retroactive pay adjustments are being made in this payroll run. Populated only when is_retroactive is True. Used to correctly allocate retroactive costs to the appropriate grant and fiscal period.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Externally-known business identifier for the payroll run, typically formatted as PR-YYYY-MM-NNNN (e.g., PR-2024-03-0012). Used in audit trails, finance reconciliation, and donor/grant reporting to reference a specific payroll cycle.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle state of the payroll run within Workday HCM. Progresses from draft through calculation, approval, and payment. Cancelled status indicates the run was voided before disbursement. Used for workflow control and audit compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Categorizes the nature of the payroll run. Regular runs follow the standard pay schedule; off-cycle runs address missed payments; supplemental runs cover bonuses or allowances; correction runs fix prior errors; final runs process termination pay. Determines processing rules and audit requirements.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Deductions' ;
    rdfs:comment 'The aggregate of all deductions applied across employees in this payroll run, including statutory taxes, social security contributions, health insurance premiums, pension contributions, and voluntary deductions. Reconciled against payroll liabilities in the General Ledger (GL).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEmployerContributions rdf:type rdf:Property ;
    rdfs:label 'Total Employer Contributions' ;
    rdfs:comment 'The aggregate employer-side payroll costs for this run, including employer social security, pension matching, health insurance, and other statutory employer contributions. Represents the full labor cost burden beyond gross pay, critical for grant budget management and F&A (Facilities and Administration) cost allocation.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossPay rdf:type rdf:Property ;
    rdfs:label 'Total Gross Pay' ;
    rdfs:comment 'The aggregate gross earnings for all employees included in this payroll run before any deductions. Includes base salary, allowances, overtime, and other earnings components. Used for BvA (Budget versus Actual) reporting, grant cost allocation, and financial stewardship.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetPay rdf:type rdf:Property ;
    rdfs:label 'Total Net Pay' ;
    rdfs:comment 'The aggregate net amount disbursed to all employees in this payroll run after all deductions. Equals total_gross_pay minus total_deductions. Used for cash disbursement planning, bank transfer reconciliation, and treasury management.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Total Tax Withheld' ;
    rdfs:comment 'The aggregate income tax and statutory levies withheld from employee earnings in this payroll run. Reported to tax authorities and reconciled against payroll tax liability accounts in the CoA (Chart of Accounts). Supports compliance with IRS and local tax authority reporting.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workdayRunReference rdf:type rdf:Property ;
    rdfs:label 'Workday Run Reference' ;
    rdfs:comment 'The native identifier assigned to this payroll run by Workday HCM, the system of record. Enables traceability back to the source system for audit, reconciliation, and support purposes. Distinct from the Silver layer surrogate key payroll_run_id.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payslipId rdf:type rdf:Property ;
    rdfs:label 'Payslip Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual payslip record in the Workday HCM payroll system. Serves as the primary key for the payslip data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalPayslipId rdf:type rdf:Property ;
    rdfs:label 'Original Payslip Id' ;
    rdfs:comment 'Reference to the original payslip record that this corrected or reversed payslip supersedes. Null for standard payslips; populated only when is_correction is True, enabling full audit trail of payroll corrections.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payslip .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the payroll run containing this payslip was formally approved in the Workday HCM approval workflow. Provides an auditable approval event timestamp for statutory and donor compliance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bankAccountReference rdf:type rdf:Property ;
    rdfs:label 'Bank Account Reference' ;
    rdfs:comment 'Masked or tokenised reference to the employee\'s bank account details used for payment disbursement. Full account details are stored securely in Workday HCM; only a reference token is retained in the Silver Layer for audit traceability without exposing PCI-sensitive data.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerPensionContribution rdf:type rdf:Property ;
    rdfs:label 'Employer Pension Contribution' ;
    rdfs:comment 'Employer\'s contribution to the employee\'s pension or provident fund for the pay period. Recorded separately from employee deductions for total employment cost reporting and grant cost allocation under OMB Uniform Guidance.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerSocialSecurity rdf:type rdf:Property ;
    rdfs:label 'Employer Social Security' ;
    rdfs:comment 'Employer\'s statutory social security or national insurance contribution associated with this payslip. Not deducted from employee pay but recorded for total employment cost reporting, BvA grant cost allocation, and NICRA indirect cost rate calculations.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expatAllowance rdf:type rdf:Property ;
    rdfs:label 'Expat Allowance' ;
    rdfs:comment 'Allowance specific to internationally-recruited expatriate staff, covering relocation, cost-of-living differentials, and international assignment premiums. Applicable only to staff in the expat payroll group.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldAllowance rdf:type rdf:Property ;
    rdfs:label 'Field Allowance' ;
    rdfs:comment 'Allowance paid to staff working in active field operations, remote areas, or humanitarian response zones. Distinct from hardship allowance; compensates for operational field conditions and mobility requirements.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossSalary rdf:type rdf:Property ;
    rdfs:label 'Gross Salary' ;
    rdfs:comment 'Total gross salary amount in local currency before any deductions, representing the employee\'s base contractual pay for the pay period. Forms the basis for all statutory deduction calculations and BvA payroll cost reporting.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardshipAllowance rdf:type rdf:Property ;
    rdfs:label 'Hardship Allowance' ;
    rdfs:comment 'Additional allowance paid to staff deployed in hardship or non-family duty stations as classified by UN/INGO hardship classification frameworks. Compensates for difficult living conditions in humanitarian field operations.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:housingAllowance rdf:type rdf:Property ;
    rdfs:label 'Housing Allowance' ;
    rdfs:comment 'Monetary allowance paid to the employee to cover accommodation costs, commonly provided to international and expat staff in high-cost or insecure duty stations. Taxability varies by country and employment contract type.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incomeTaxDeduction rdf:type rdf:Property ;
    rdfs:label 'Income Tax Deduction' ;
    rdfs:comment 'Statutory income tax withheld from the employee\'s gross pay in accordance with the applicable national tax legislation of the duty station country. Reported to tax authorities and included in statutory payroll filings.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCorrection rdf:type rdf:Property ;
    rdfs:label 'Is Correction' ;
    rdfs:comment 'Indicates whether this payslip is a corrected reissue of a previously reversed payslip. When True, the original_payslip_id field references the superseded payslip for audit trail continuity.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOffCycle rdf:type rdf:Property ;
    rdfs:label 'Is Off Cycle' ;
    rdfs:comment 'Indicates whether this payslip was generated as part of an off-cycle payroll run (e.g., for a new hire mid-period, a termination payment, or a correction) rather than the standard scheduled payroll cycle.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the local currency in which the employee\'s salary components are denominated and calculated. Supports multi-currency payroll operations across 50+ countries.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPayLocal rdf:type rdf:Property ;
    rdfs:label 'Net Pay Local' ;
    rdfs:comment 'Final take-home pay amount in local currency after all statutory and voluntary deductions have been subtracted from gross pay and allowances. Represents the amount the employee is entitled to receive for the pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPayPaymentCurrency rdf:type rdf:Property ;
    rdfs:label 'Net Pay Payment Currency' ;
    rdfs:comment 'Net pay amount converted to the payment currency using the applicable exchange rate. Represents the actual amount disbursed to the employee\'s bank account. May equal net_pay_local when local and payment currencies are the same.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the currency in which net pay is actually disbursed to the employee. May differ from local_currency_code for expatriate staff paid in USD or EUR regardless of duty station.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunSequence rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Sequence' ;
    rdfs:comment 'Sequential run number within the payroll period (e.g., 1 for the primary run, 2 for a supplemental or correction run). Distinguishes regular payroll runs from off-cycle or adjustment runs.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payslipNumber rdf:type rdf:Property ;
    rdfs:label 'Payslip Number' ;
    rdfs:comment 'Externally-visible, human-readable unique reference number for this payslip, typically formatted as PSL-{COUNTRY}-{YEAR}-{MONTH}-{SEQUENCE}. Used in employee communications, statutory filings, and donor audit documentation.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payslipStatus rdf:type rdf:Property ;
    rdfs:label 'Payslip Status' ;
    rdfs:comment 'Current lifecycle state of this individual payslip record. Distinguishes between payslips that have been generated and issued to the employee versus those that have been reversed or superseded by a corrected payslip.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pensionDeduction rdf:type rdf:Property ;
    rdfs:label 'Pension Deduction' ;
    rdfs:comment 'Employee contribution to pension or provident fund deducted from gross pay. Includes both mandatory statutory pension contributions and voluntary supplementary pension scheme contributions where applicable.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSecurityDeduction rdf:type rdf:Property ;
    rdfs:label 'Social Security Deduction' ;
    rdfs:comment 'Statutory social security or national insurance contribution deducted from the employee\'s pay as required by local labour law. Varies by country and employment type; may be zero for certain expat staff under bilateral social security agreements.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAllowances rdf:type rdf:Property ;
    rdfs:label 'Total Allowances' ;
    rdfs:comment 'Sum of all allowance components (housing, hardship, field, expat, transport, and any other applicable allowances) for the pay period in local currency. Used as a subtotal in payslip presentation and BvA reporting.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStatutoryDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Statutory Deductions' ;
    rdfs:comment 'Sum of all mandatory statutory deductions (income tax, social security, pension) for the pay period. Used as a subtotal in payslip presentation and for statutory remittance reconciliation.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportAllowance rdf:type rdf:Property ;
    rdfs:label 'Transport Allowance' ;
    rdfs:comment 'Allowance paid to cover employee commuting or field transportation costs. Commonly provided to national staff in urban and peri-urban duty stations as part of the total compensation package.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voluntaryDeductions rdf:type rdf:Property ;
    rdfs:label 'Voluntary Deductions' ;
    rdfs:comment 'Total of all employee-elected voluntary deductions for the pay period, including staff association fees, health insurance premiums, loan repayments, savings scheme contributions, and other authorised deductions.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique system-generated identifier for the performance review record. Primary key for the performance_review data product in the Workday HCM-sourced workforce domain.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Staff Member Id' ;
    rdfs:comment 'Reference to the staff member (reviewee) who is the subject of this performance review. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:reviewerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Staff Member Id' ;
    rdfs:comment 'Reference to the staff member (manager or designated reviewer) who conducted and submitted this performance review. Supports Results-Based Management (RBM) accountability chains.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accountabilityRating rdf:type rdf:Property ;
    rdfs:label 'Accountability Rating' ;
    rdfs:comment 'Rating assessing the employee\'s demonstrated accountability to affected populations and beneficiaries, a core CHS and HAP requirement for all humanitarian staff. Reflects adherence to feedback mechanisms and complaint handling.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationRating rdf:type rdf:Property ;
    rdfs:label 'Collaboration Rating' ;
    rdfs:comment 'Rating for the collaboration and partnership competency, assessing the employee\'s effectiveness in working across teams, with partner organizations (CSOs, CBOs, INGOs), and with beneficiary communities.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyRatingScore rdf:type rdf:Property ;
    rdfs:label 'Competency Rating Score' ;
    rdfs:comment 'Composite numeric score reflecting the employee\'s average rating across all behavioral competencies assessed in the review (e.g., leadership, collaboration, accountability, humanitarian principles). Supports talent development analytics.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentRecommendations rdf:type rdf:Property ;
    rdfs:label 'Development Recommendations' ;
    rdfs:comment 'Structured recommendations from the reviewer for the employee\'s professional development, including suggested training, mentoring, stretch assignments, or Learning Management System (LMS) courses to address identified gaps.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledged' ;
    rdfs:comment 'Indicates whether the employee has formally acknowledged the performance review in Workday HCM. Required for HR audit compliance and CHS accountability to affected populations standards.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeAcknowledgedDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledged Date' ;
    rdfs:comment 'The date on which the reviewed employee formally acknowledged receipt and review of their performance appraisal in Workday HCM. Required for HAP and CHS accountability compliance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeComments rdf:type rdf:Property ;
    rdfs:label 'Employee Comments' ;
    rdfs:comment 'Free-text comments submitted by the employee at the time of acknowledgment, capturing their response to the review outcome, including any disagreements, additional context, or commitments for the next period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeDisagreementFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Disagreement Flag' ;
    rdfs:comment 'Indicates whether the employee formally disputed or disagreed with the performance review outcome. Triggers the HR grievance and appeals process in accordance with organizational HR policy and CHS accountability standards.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeSelfAssessment rdf:type rdf:Property ;
    rdfs:label 'Employee Self Assessment' ;
    rdfs:comment 'Free-text self-assessment narrative submitted by the employee prior to the review meeting, documenting their own perspective on achievements, challenges, and development needs during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadershipRating rdf:type rdf:Property ;
    rdfs:label 'Leadership Rating' ;
    rdfs:comment 'Rating for the leadership competency dimension, assessing the employee\'s ability to guide teams, make decisions under pressure, and drive program outcomes in humanitarian field contexts.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'The planned date for the employee\'s next performance review or check-in, as agreed during the current review meeting. Supports proactive HR scheduling and talent management planning.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:objectiveAchievementScore rdf:type rdf:Property ;
    rdfs:label 'Objective Achievement Score' ;
    rdfs:comment 'Composite percentage score (0–100) reflecting the degree to which the employee achieved their defined performance objectives during the review period. Derived from individual objective ratings in Workday HCM and used in RBM and LogFrame reporting.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'The holistic performance rating assigned to the employee for the review period, reflecting the reviewer\'s consolidated assessment across all competencies and objectives. Drives talent retention, promotion, and RBM reporting decisions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numeric score corresponding to the overall performance rating on the configured rating scale (e.g., 1.00–5.00). Enables quantitative talent analytics, benchmarking, and Results-Based Management (RBM) reporting.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipRequired rdf:type rdf:Property ;
    rdfs:label 'Pip Required' ;
    rdfs:comment 'Indicates whether a formal Performance Improvement Plan (PIP) has been recommended or initiated as a result of this review, typically triggered by an unsatisfactory or needs_improvement overall rating.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionRecommendation rdf:type rdf:Property ;
    rdfs:label 'Promotion Recommendation' ;
    rdfs:comment 'Indicates whether the reviewer recommends the employee for promotion or advancement to a higher grade or responsibility level based on this review cycle\'s performance outcomes.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingScaleVersion rdf:type rdf:Property ;
    rdfs:label 'Rating Scale Version' ;
    rdfs:comment 'Version identifier of the performance rating scale applied in this review (e.g., \'v2.1-2024\'). Ensures historical comparability as rating scales evolve over time.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Retention Risk Flag' ;
    rdfs:comment 'Indicates whether the reviewer or HR has flagged this employee as at risk of leaving the organization, enabling proactive talent retention interventions. Supports NGO workforce stability in high-turnover humanitarian contexts.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCycleType rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Type' ;
    rdfs:comment 'Classification of the performance review cycle that this appraisal belongs to. Distinguishes annual appraisals, mid-year check-ins, probationary reviews, end-of-contract assessments, and ad hoc reviews triggered by specific events.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'The deadline by which the performance review must be completed and submitted by the reviewer. Used for HR compliance tracking and manager accountability reporting.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Review Meeting Date' ;
    rdfs:comment 'The date on which the formal performance review discussion meeting took place between the reviewer and the employee. Distinct from the submission date; required for CHS accountability documentation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the performance review record (e.g., PR-2024-000123). Used in HR correspondence, audit trails, and donor-funded program compliance reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'The last day of the performance period being evaluated in this review. Together with review_period_start_date, defines the full appraisal window.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'The first day of the performance period being evaluated in this review. Defines the temporal boundary for objective achievement and behavioral observation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle state of the performance review workflow in Workday HCM. Tracks progression from draft through manager completion to employee acknowledgment and final closure.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Review Submitted Date' ;
    rdfs:comment 'The date on which the reviewer formally submitted the completed performance review in Workday HCM. Used to measure timeliness compliance against the review due date.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerNarrative rdf:type rdf:Property ;
    rdfs:label 'Reviewer Narrative' ;
    rdfs:comment 'Free-text qualitative narrative provided by the reviewer summarizing the employee\'s performance, key achievements, areas for improvement, and behavioral observations during the review period. Confidential HR record.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSkillsRating rdf:type rdf:Property ;
    rdfs:label 'Technical Skills Rating' ;
    rdfs:comment 'Rating for the employee\'s technical competency relevant to their functional role (e.g., MEAL methodology, WASH engineering, GBV case management, financial stewardship, ICT4D). Supports targeted learning and development planning.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuesAlignmentRating rdf:type rdf:Property ;
    rdfs:label 'Values Alignment Rating' ;
    rdfs:comment 'Rating assessing the degree to which the employee demonstrates alignment with the NGO\'s core organizational values and humanitarian principles (e.g., humanity, neutrality, impartiality, accountability). Critical for CHS compliance and organizational culture.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveRequestId rdf:type rdf:Property ;
    rdfs:label 'Leave Request Id' ;
    rdfs:comment 'Unique system-generated identifier for each leave request record in the Workday HCM system. Serves as the primary key for the leave_request data product.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Approver Staff Member Id' ;
    rdfs:comment 'Reference to the manager or HR officer responsible for approving or rejecting this leave request. Supports RACI role assignments and delegation of authority tracking.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:primaryLeaveStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Leave Staff Member Id' ;
    rdfs:comment 'Reference to the staff member submitting the leave request. Links to the employee master record in Workday HCM covering national staff, international staff, and expatriate personnel.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:actualDaysTaken rdf:type rdf:Property ;
    rdfs:label 'Actual Days Taken' ;
    rdfs:comment 'Number of working days actually taken by the staff member. Populated upon return from leave and used to update leave balance entitlements. Supports half-day precision.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'The actual date on which the staff member returned from leave. May differ from requested_end_date due to early return, extension, or operational recall.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'The actual date on which the staff member commenced their approved leave. May differ from requested_start_date due to operational adjustments or late approvals.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approverComments rdf:type rdf:Property ;
    rdfs:label 'Approver Comments' ;
    rdfs:comment 'Free-text notes entered by the approving manager or HR officer when approving, rejecting, or modifying the leave request. Supports audit trail and communication.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the leave request was cancelled or withdrawn, either by the employee or by HR. Null if the request was not cancelled.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carryForwardDays rdf:type rdf:Property ;
    rdfs:label 'Carry Forward Days' ;
    rdfs:comment 'Number of unused leave days carried forward from the previous leave year that are being applied to this request. Subject to organizational carry-forward policy limits.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyContactAvailable rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Available' ;
    rdfs:comment 'Indicates whether the staff member has confirmed they can be reached in an emergency during their leave period. Particularly relevant for field staff and humanitarian response contexts.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementDays rdf:type rdf:Property ;
    rdfs:label 'Entitlement Days' ;
    rdfs:comment 'Total number of days the staff member is entitled to for the applicable leave type in the current leave year, as defined by their contract, grade, and duty station policy.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handoverCompleted rdf:type rdf:Property ;
    rdfs:label 'Handover Completed' ;
    rdfs:comment 'Indicates whether the staff member has completed a formal handover of duties and responsibilities before commencing leave. Critical for field operations continuity and program delivery.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRnrEligible rdf:type rdf:Property ;
    rdfs:label 'Is Rnr Eligible' ;
    rdfs:comment 'Indicates whether the staff member is eligible for Rest and Recuperation (R&R) leave based on their duty station hardship classification. True for staff posted to hardship or non-family duty stations per OCHA/UNDSS security phase criteria.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Leave Balance After' ;
    rdfs:comment 'The staff member\'s remaining leave balance (in days) for the applicable leave type after the leave has been taken and confirmed. Updated upon return from leave.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Leave Balance Before' ;
    rdfs:comment 'The staff member\'s available leave balance (in days) for the applicable leave type at the time the request was submitted. Enables entitlement validation and balance tracking.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveDestinationCountry rdf:type rdf:Property ;
    rdfs:label 'Leave Destination Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the staff member will spend their leave. Required for R&R and annual leave for international/expatriate staff for security tracking and travel authorization.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveReason rdf:type rdf:Property ;
    rdfs:label 'Leave Reason' ;
    rdfs:comment 'Free-text description of the reason provided by the staff member for the leave request. May contain sensitive personal information (e.g., medical, family). Classified as confidential.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Classification of the leave being requested. Covers standard humanitarian workforce leave categories: Annual (vacation), Sick, Maternity/Paternity, Rest and Recuperation (R&R) for field staff, Compassionate (bereavement/family emergency), and Time Off In Lieu (TOIL) for overtime compensation.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveYear rdf:type rdf:Property ;
    rdfs:label 'Leave Year' ;
    rdfs:comment 'The calendar or fiscal year to which this leave request applies (e.g., 2024). Used for annual entitlement tracking, carry-forward calculations, and year-end reporting.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalCertificateReceived rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Received' ;
    rdfs:comment 'Indicates whether the required medical certificate has been received and verified by HR. Relevant for sick leave requests where documentation is mandatory per organizational policy.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificateRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Required' ;
    rdfs:comment 'Indicates whether a medical certificate is required for this leave request based on leave type and duration policy (e.g., sick leave exceeding 3 consecutive days). Drives compliance workflow in Workday HCM.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Structured or free-text reason provided by the approver when rejecting a leave request. Required for rejected requests to support employee relations and grievance management.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Externally visible, human-readable reference number assigned to the leave request (e.g., LR-2024-000123). Used in correspondence, approvals, and audit trails.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDays rdf:type rdf:Property ;
    rdfs:label 'Requested Days' ;
    rdfs:comment 'Number of working days requested for the leave period, as submitted by the employee. Supports half-day increments (e.g., 0.5). Excludes weekends and public holidays per the applicable country calendar.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedEndDate rdf:type rdf:Property ;
    rdfs:label 'Requested End Date' ;
    rdfs:comment 'The date the staff member has requested their leave to end (inclusive). Combined with requested_start_date to determine the requested duration.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedStartDate rdf:type rdf:Property ;
    rdfs:label 'Requested Start Date' ;
    rdfs:comment 'The date the staff member has requested their leave to begin. Used for scheduling, coverage planning, and field rotation management.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rnrCycleDays rdf:type rdf:Property ;
    rdfs:label 'Rnr Cycle Days' ;
    rdfs:comment 'The number of days between R&R breaks applicable to the staff member\'s duty station (e.g., 42 days, 56 days, 84 days). Determined by the hardship classification of the duty station.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityClearanceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Confirmed' ;
    rdfs:comment 'Indicates whether the staff member\'s travel to the leave destination has been cleared by the security team. Required for international staff and field personnel traveling to or from high-risk areas.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'The date and time when the staff member formally submitted the leave request in Workday HCM. Serves as the principal business event timestamp for the transaction lifecycle.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supportingDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Ref' ;
    rdfs:comment 'Reference number or file path to supporting documentation attached to the leave request (e.g., medical certificate for sick leave, death certificate for compassionate leave). Stored in the document management system.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toilHoursAccrued rdf:type rdf:Property ;
    rdfs:label 'Toil Hours Accrued' ;
    rdfs:comment 'Number of overtime hours accrued by the staff member that are being converted to Time Off In Lieu (TOIL). Applicable only for TOIL leave type requests. Supports overtime compensation tracking.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workdayLeaveRequestReference rdf:type rdf:Property ;
    rdfs:label 'Workday Leave Request Reference' ;
    rdfs:comment 'The native leave request identifier from the Workday HCM source system. Enables traceability back to the system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Staff Assignment Id' ;
    rdfs:comment 'Unique system-generated identifier for each staff assignment record in Workday HCM. Serves as the primary key for the staff_assignment data product.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Foreign key linking to partnership.partnership_agreement. Business justification: Staff costs charged under partnership agreements must be traceable to the specific agreement for donor reporting, effort certification, and audit compliance. This direct link supports IATI reporting a' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:donorRequirementId rdf:type rdf:Property ;
    rdfs:label 'Donor Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.donor_requirement. Business justification: Donor agreements include key personnel clauses and nationality/qualification requirements for assigned staff. NGO grants management requires verifying each staff assignment satisfies applicable donor ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DonorRequirement .

ind:emergencyId rdf:type rdf:Property ;
    rdfs:label 'Emergency Id' ;
    rdfs:comment 'Foreign key linking to field.emergency. Business justification: Surge and emergency response staff assignments are made against specific declared emergencies. Donor accountability reports, emergency response plans, and HR surge capacity tracking all require linkin' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Emergency .

ind:partnerOrgId rdf:type rdf:Property ;
    rdfs:label 'Partner Org Id' ;
    rdfs:comment 'Foreign key linking to partnership.partner_org. Business justification: NGOs regularly deploy staff to partner organizations (technical assistance, secondments, embedded advisors). Linking staff assignments to the partner org enables tracking of partner-deployed staff, lo' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerOrg .

ind:primaryWorkforceStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Staff Member Id' ;
    rdfs:comment 'Reference to the staff member record in the workforce master data. Links the assignment to the individual employee or contractor being assigned.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:projectSiteId rdf:type rdf:Property ;
    rdfs:label 'Project Site Id' ;
    rdfs:comment 'Reference to the specific project or sub-component within a program to which the staff member is assigned. Supports project-level cost allocation and effort reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectSite .

ind:tertiaryWorkforceApprovedByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Workforce Approved By Staff Member Id' ;
    rdfs:comment 'Reference to the staff member (typically HR manager or program director) who approved this assignment in Workday HCM. Supports authorization audit trails and accountability documentation.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The date on which the staff assignment was formally approved through the Workday HCM business process workflow. Marks the transition from \'draft\' to \'active\' status and establishes the authorization audit trail.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this staff assignment, used in donor reports, effort certification forms, and cross-system references (e.g., ASN-2024-WASH-001). Sourced from Workday HCM assignment reference number.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text field for additional context, special conditions, or operational notes related to this staff assignment. May include information on acting capacity, special donor conditions, or field-specific requirements not captured in structured fields.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle state of the staff assignment record. \'draft\' indicates pending approval; \'active\' indicates currently deployed; \'on_hold\' indicates temporarily suspended; \'completed\' indicates successfully concluded; \'cancelled\' indicates terminated before completion.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classification of the nature of the staff assignment. \'primary\' indicates the main assignment; \'secondary\' indicates a concurrent partial assignment; \'surge_deployment\' indicates emergency response deployment; \'tdy\' (Temporary Duty) indicates short-term field deployment; \'secondment\' indicates inter-agency placement; \'consultant\' indicates contracted technical assistance.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyCountryCode rdf:type rdf:Property ;
    rdfs:label 'Duty Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the staff member is deployed for this assignment (e.g., \'SSD\' for South Sudan, \'HTI\' for Haiti). Used for hardship classification, tax treaty application, and OCHA country-level reporting.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effortCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Effort Certification Required' ;
    rdfs:comment 'Indicates whether this assignment requires periodic effort certification by the staff member or supervisor (True), as mandated for federally-funded grants under OMB Uniform Guidance 2 CFR 200 §200.430. Drives the effort certification workflow in the GMS.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effortPercent rdf:type rdf:Property ;
    rdfs:label 'Effort Percent' ;
    rdfs:comment 'The percentage of the staff member\'s total working time allocated to this specific assignment, expressed as a decimal percentage (e.g., 50.00 for 50%). Must sum to 100% across all active assignments for a staff member. Critical for donor-compliant effort reporting and payroll cost allocation to grants per OMB Uniform Guidance 2 CFR 200 §200.430.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fteEquivalent rdf:type rdf:Property ;
    rdfs:label 'Fte Equivalent' ;
    rdfs:comment 'The full-time equivalent value of this assignment, calculated as effort_percent / 100. For example, a 50% assignment equals 0.50 FTE. Used for workforce capacity planning, budget forecasting, and donor reporting on staffing levels.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardshipLevel rdf:type rdf:Property ;
    rdfs:label 'Hardship Level' ;
    rdfs:comment 'The UN/ICSC hardship classification level for the duty station of this assignment (A=normal; B=some hardship; C=hardship; D=extreme hardship; E=unaccompanied). Determines hardship allowance entitlements and R&R (Rest and Recuperation) schedules for international and expatriate staff.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCostShared rdf:type rdf:Property ;
    rdfs:label 'Is Cost Shared' ;
    rdfs:comment 'Indicates whether the payroll costs for this assignment are shared across multiple grants or funding sources (True). When True, the effort_percent and grant_code fields define the primary allocation, and supplementary cost-share records exist for the remaining allocation.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFieldDeployment rdf:type rdf:Property ;
    rdfs:label 'Is Field Deployment' ;
    rdfs:comment 'Indicates whether this assignment involves deployment to a field or humanitarian response location (True) as opposed to a headquarters or regional office posting (False). Used to trigger field-specific HR policies, security protocols, and allowance calculations.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSurgeDeployment rdf:type rdf:Property ;
    rdfs:label 'Is Surge Deployment' ;
    rdfs:comment 'Indicates whether this assignment is classified as a surge deployment in response to an acute humanitarian emergency (True). Surge deployments trigger expedited onboarding, emergency per diem rates, and OCHA SitRep staffing reporting.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastEffortCertifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Effort Certified Date' ;
    rdfs:comment 'The date on which the most recent effort certification was completed and approved for this assignment. Used to track compliance with periodic effort reporting requirements under OMB Uniform Guidance and donor agreements.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safeguardingTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Training Completed' ;
    rdfs:comment 'Indicates whether the staff member has completed mandatory safeguarding and protection training prior to or during this assignment (True). Required by CHS Alliance Core Humanitarian Standard and donor compliance frameworks for all field deployments.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityClearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Level' ;
    rdfs:comment 'The security clearance level required and held by the staff member for this assignment. Relevant for assignments in conflict-affected or high-security environments. \'classified\' indicates government-level clearance for assignments with bilateral donors such as USAID or DFID.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdyPurpose rdf:type rdf:Property ;
    rdfs:label 'Tdy Purpose' ;
    rdfs:comment 'Description of the business purpose for a Temporary Duty (TDY) assignment, such as \'emergency response support\', \'capacity building mission\', or \'program assessment\'. Required for TDY travel authorization and donor reporting. Applicable only when assignment_type = \'tdy\'.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayAssignmentRef rdf:type rdf:Property ;
    rdfs:label 'Workday Assignment Ref' ;
    rdfs:comment 'The source system reference identifier for this assignment record in Workday HCM. Enables traceability back to the system of record for reconciliation, audit, and data lineage purposes.' ;
    rdfs:domain ind:StaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipManagerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Partnership management best practice assigns NGO staff as relationship owner for each partner organization. Critical for due diligence oversight, capacity assessment coordination, performance monitori' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Current accreditation status of the partner organization against recognized humanitarian or development standards such as the Core Humanitarian Standard (CHS), HAP (Humanitarian Accountability Partnership), or equivalent national accreditation bodies.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedRepName rdf:type rdf:Property ;
    rdfs:label 'Authorized Rep Name' ;
    rdfs:comment 'Full name of the individual legally authorized to sign agreements (MoUs, LoAs, SoWs, sub-award agreements) on behalf of the partner organization. Required for agreement execution and legal compliance.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedRepTitle rdf:type rdf:Property ;
    rdfs:label 'Authorized Rep Title' ;
    rdfs:comment 'Official title of the authorized signatory at the partner organization (e.g., Executive Director, CEO, Country Representative). Validates signing authority for sub-award and partnership agreements.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCountry rdf:type rdf:Property ;
    rdfs:label 'Bank Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the partner organization\'s primary bank account is held. Used for international wire transfer compliance and OFAC/sanctions screening.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Name of the primary banking institution used by the partner organization for receiving sub-grant disbursements. Required for financial due diligence and sub-award payment processing in SAP S/4HANA and Unit4 ERP.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Capacity Assessment Date' ;
    rdfs:comment 'Date on which the most recent formal partner capacity assessment was conducted. Used to determine whether a reassessment is due and to track the currency of due diligence records.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Capacity Assessment Score' ;
    rdfs:comment 'Numeric score (typically 0–100) resulting from the most recent formal partner capacity assessment covering governance, financial management, HR, and program delivery. Used to determine sub-award eligibility, required oversight level, and capacity-strengthening needs under OMB Uniform Guidance.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chsCertified rdf:type rdf:Property ;
    rdfs:label 'Chs Certified' ;
    rdfs:comment 'Indicates whether the partner organization holds a valid Core Humanitarian Standard (CHS) certification. CHS certification demonstrates commitment to accountability, quality, and improvement in humanitarian response.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clusterMemberships rdf:type rdf:Property ;
    rdfs:label 'Cluster Memberships' ;
    rdfs:comment 'Comma-separated list of OCHA humanitarian cluster(s) in which the partner organization holds active membership or co-lead roles (e.g., WASH, Health, Shelter, Food Security, Protection). Used for coordination mapping and IASC working group engagement tracking.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countriesOfOperation rdf:type rdf:Property ;
    rdfs:label 'Countries Of Operation' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where the partner organization has active field operations. Distinct from country of registration. Used for geographic coverage analysis and OCHA 3W (Who does What Where) reporting.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDiligenceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Expiry Date' ;
    rdfs:comment 'Date on which the current due diligence clearance expires and a new assessment must be completed before the partner can enter into new sub-award or partnership agreements.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDiligenceStatus rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Status' ;
    rdfs:comment 'Current status of the partner organization\'s due diligence vetting process. \'Expired\' indicates that a previously completed assessment has passed its validity period and renewal is required before new agreements can be executed.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financeContactEmail rdf:type rdf:Property ;
    rdfs:label 'Finance Contact Email' ;
    rdfs:comment 'Email address of the partner organization\'s designated financial officer or finance focal point. Used for Budget versus Actual (BvA) reporting, financial documentation requests, and sub-grant financial management communications.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foundingYear rdf:type rdf:Property ;
    rdfs:label 'Founding Year' ;
    rdfs:comment 'Calendar year in which the partner organization was founded or established. Used to assess organizational maturity, track record, and eligibility for capacity-strengthening programs.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hqAddress rdf:type rdf:Property ;
    rdfs:label 'Hq Address' ;
    rdfs:comment 'Full mailing address of the partner organization\'s global headquarters including street, city, postal code, and country. Used for official correspondence, legal notices, and sub-award agreement documentation.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqCity rdf:type rdf:Property ;
    rdfs:label 'Hq City' ;
    rdfs:comment 'City where the partner organization\'s global headquarters is located. Used for correspondence, coordination meetings, and geographic reporting.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqCountry rdf:type rdf:Property ;
    rdfs:label 'Hq Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the partner organization\'s global headquarters is located. Used for geographic analysis, donor reporting, and OCHA cluster coordination mapping.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missionStatement rdf:type rdf:Property ;
    rdfs:label 'Mission Statement' ;
    rdfs:comment 'Official mission statement of the partner organization describing its core purpose and mandate. Used for alignment assessment with Ngo\'s Theory of Change (ToC) and program design.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgAcronym rdf:type rdf:Property ;
    rdfs:label 'Org Acronym' ;
    rdfs:comment 'Commonly used acronym or short name for the partner organization (e.g., CARE, IRC, MSF). Widely used in SitReps, cluster coordination, and OCHA reporting to identify partners concisely.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgName rdf:type rdf:Property ;
    rdfs:label 'Org Name' ;
    rdfs:comment 'Full legal registered name of the partner organization as it appears on official registration documents. Used as the primary human-readable identity label for the partner across all systems including Microsoft Dynamics 365 and Salesforce Nonprofit Cloud.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgType rdf:type rdf:Property ;
    rdfs:label 'Org Type' ;
    rdfs:comment 'Categorical classification of the partner organization type. Distinguishes between International Non-Governmental Organizations (INGOs), Civil Society Organizations (CSOs), Community-Based Organizations (CBOs), UN agencies, government bodies, consortia, private sector entities, and academic institutions. Drives eligibility rules for sub-award agreements and due diligence requirements. [ENUM-REF-CANDIDATE: INGO|NGO|CSO|CBO|UN_AGENCY|GOVERNMENT|CONSORTIUM|PRIVATE_SECTOR|ACADEMIC — promote to reference product]' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgWebsite rdf:type rdf:Property ;
    rdfs:label 'Org Website' ;
    rdfs:comment 'Official public website URL of the partner organization. Used for due diligence verification, public profile validation, and IATI transparency reporting.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipStatus rdf:type rdf:Property ;
    rdfs:label 'Partnership Status' ;
    rdfs:comment 'Current lifecycle status of the partner organization relationship. Controls whether the partner is eligible for new agreements, sub-awards, or field collaboration. \'pending_vetting\' indicates due diligence is in progress; \'blacklisted\' indicates the partner is barred from engagement per donor or regulatory requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 or ISO 639-2 language code representing the partner organization\'s preferred language for official communications, reporting, and agreement documentation (e.g., \'en\', \'fr\', \'ar\', \'es\').' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Official email address of the primary focal point at the partner organization. Used for formal communications, agreement notifications, and reporting requests.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary focal point or authorized representative at the partner organization. This is the principal contact for partnership coordination, agreement negotiations, and official communications.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Direct phone number (including country code) for the primary focal point at the partner organization. Used for urgent field coordination and emergency communications.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Job title or designation of the primary focal point at the partner organization (e.g., Country Director, Partnership Manager, Executive Director). Used to assess seniority and authority level for agreement signing.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedAt rdf:type rdf:Property ;
    rdfs:label 'Record Created At' ;
    rdfs:comment 'Timestamp indicating when the partner organization record was first created in the system. Serves as the audit trail creation marker and supports data lineage tracking in the Databricks Silver Layer.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedAt rdf:type rdf:Property ;
    rdfs:label 'Record Updated At' ;
    rdfs:comment 'Timestamp indicating when the partner organization record was most recently modified. Used for change tracking, data freshness monitoring, and incremental load processing in the Databricks Lakehouse Silver Layer.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sanctionsScreenDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screen Date' ;
    rdfs:comment 'Date on which the most recent sanctions screening was completed for the partner organization. Used to determine whether re-screening is required before new agreements or disbursements.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsScreened rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screened' ;
    rdfs:comment 'Indicates whether the partner organization has been screened against applicable sanctions lists (e.g., OFAC SDN List, UN Consolidated Sanctions List, EU Sanctions List) as part of the due diligence process. Required for USAID and US Government-funded programs.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:staffCount rdf:type rdf:Property ;
    rdfs:label 'Staff Count' ;
    rdfs:comment 'Total number of paid staff (national and international) employed by the partner organization at the time of last capacity assessment. Used as an indicator of organizational capacity for program delivery and sub-award management.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Government-issued tax identification number (e.g., EIN in the US, VAT number in the EU) for the partner organization. Required for financial transactions, sub-award agreements, and compliance with NICRA (Negotiated Indirect Cost Rate Agreement) reporting.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thematicFocusAreas rdf:type rdf:Property ;
    rdfs:label 'Thematic Focus Areas' ;
    rdfs:comment 'Comma-separated list of primary thematic areas in which the partner organization operates (e.g., WASH, GBV, PSS, Health, Education, Livelihoods, NFI Distribution). Used for partner matching in program design and cluster coordination with OCHA.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantBudgetId rdf:type rdf:Property ;
    rdfs:label 'Grant Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.grant_budget. Business justification: NGO finance teams link partnership agreements to grant budgets for sub-award burn-rate monitoring, donor compliance reporting, and budget vs. actual analysis. A domain expert expects every implementin' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GrantBudget .

ind:programManagerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Program Manager Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Partnership agreements require designated NGO program manager for oversight, amendment approvals, performance review sign-off, and donor reporting accountability. Distinct from partner_org relationshi' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the partnership agreement. draft = under preparation; pending_signature = awaiting execution; active = fully executed and in force; suspended = temporarily halted; expired = past end date without renewal; terminated = ended before expiry; amended = superseded by an amendment. [ENUM-REF-CANDIDATE: draft|pending_signature|active|suspended|expired|terminated|amended — promote to reference product]' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the formal inter-organizational legal instrument. MoU = Memorandum of Understanding; LoA = Letter of Agreement; SoW = Scope of Work; sub_award = sub-grant or sub-award agreement; consortium = multi-party consortium agreement; other = any other instrument type. [ENUM-REF-CANDIDATE: MoU|LoA|SoW|sub_award|consortium|framework|other — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date on which the most recent amendment to the agreement was executed. Null for original agreements with no amendments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Narrative summary of the changes introduced by the most recent amendment (e.g., budget increase, no-cost extension, scope modification). Null for original agreements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Capacity Assessment Status' ;
    rdfs:comment 'Status of the partner due diligence and capacity assessment conducted prior to or during the agreement. not_required = exempt; pending = assessment initiated but not complete; completed = assessment passed; failed = partner did not meet threshold; waived = formally waived by authorized approver.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterLeadAgency rdf:type rdf:Property ;
    rdfs:label 'Cluster Lead Agency' ;
    rdfs:comment 'Name of the OCHA cluster lead agency (e.g., UNICEF for WASH, WFP for Food Security) under whose coordination framework the agreement\'s activities are implemented. Relevant for humanitarian response agreements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Agreed mechanism for resolving disputes arising under the agreement. Captured from the legal instrument\'s dispute resolution clause.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDiligenceRiskRating rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Risk Rating' ;
    rdfs:comment 'Risk rating assigned to the partner following due diligence review. Informs monitoring intensity, financial controls, and reporting requirements under the agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'The date on which the agreement was formally signed and executed by all required parties. May differ from the effective start date if the agreement is backdated or has a future commencement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundingCeilingAmount rdf:type rdf:Property ;
    rdfs:label 'Funding Ceiling Amount' ;
    rdfs:comment 'Maximum total financial value authorized under the agreement in the agreement\'s stated currency. For sub-awards, this is the maximum sub-grant amount. Null for non-financial MoUs.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Free-text description of the geographic area covered by the agreement (e.g., \'Borno and Yobe States, Nigeria\' or \'Kabul Province, Afghanistan\'). Used for operational planning and GIS-based reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawCountryCode rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern the interpretation and enforcement of the agreement (e.g., GBR, USA, CHE).' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatiActivityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Iati Activity Identifier' ;
    rdfs:comment 'IATI-standard activity identifier for the agreement, enabling public disclosure and cross-organization traceability on the IATI Registry (e.g., \'GB-CHC-123456-WASH-NGA-2024\').' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indirectCostRate rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Rate' ;
    rdfs:comment 'Negotiated Indirect Cost Rate (NICRA) or agreed Facilities and Administration (F&A) rate applied to direct costs under this agreement, expressed as a decimal (e.g., 0.1500 = 15%). Relevant for US federal sub-awards under OMB Uniform Guidance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isConsortiumAgreement rdf:type rdf:Property ;
    rdfs:label 'Is Consortium Agreement' ;
    rdfs:comment 'Indicates whether this agreement governs a multi-party consortium arrangement (True) rather than a bilateral agreement (False). Consortium agreements may have additional members tracked separately.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubAward rdf:type rdf:Property ;
    rdfs:label 'Is Sub Award' ;
    rdfs:comment 'Indicates whether this agreement is a sub-award (True) or a prime/direct agreement (False). Drives compliance requirements under OMB Uniform Guidance 2 CFR 200 for pass-through entities.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Lead Organization Name' ;
    rdfs:comment 'Legal name of the primary organization (typically the prime recipient or lead INGO) that is the principal party initiating or managing the agreement. Serves as the PARTY_REFERENCE anchor for the agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalCountryCode rdf:type rdf:Property ;
    rdfs:label 'Operational Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary country where the agreement\'s activities are implemented (e.g., SSD, YEM, HTI).' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Parent Agreement Reference' ;
    rdfs:comment 'Agreement reference number of the parent or prime agreement under which this sub-award or amendment was issued. Enables hierarchical agreement traceability. Null for top-level agreements.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programSector rdf:type rdf:Property ;
    rdfs:label 'Program Sector' ;
    rdfs:comment 'Humanitarian or development sector under which the agreement\'s activities fall. WASH = Water Sanitation and Hygiene; GBV = Gender-Based Violence; PSS = Psychosocial Support. [ENUM-REF-CANDIDATE: WASH|health|education|food_security|protection|shelter|livelihoods|GBV|PSS|nutrition|other — promote to reference product]' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the agreement, used in correspondence, filing, and cross-system lookups (e.g., MOU-2024-0042, LOA-2023-WASH-007). Serves as the BUSINESS_IDENTIFIER for this agreement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Indicates whether the agreement contains a renewal or extension option clause (True) that allows the parties to extend the agreement beyond the effective end date without a full renegotiation.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Agreed frequency at which the partner must submit programmatic and/or financial reports under the agreement (e.g., monthly SitRep, quarterly narrative, annual audit).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Narrative description of the agreed scope of work, activities, and deliverables covered by the agreement. Summarizes the SoW or program objectives as stated in the legal instrument.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgAlignmentCodes rdf:type rdf:Property ;
    rdfs:label 'Sdg Alignment Codes' ;
    rdfs:comment 'Comma-separated list of UN Sustainable Development Goal (SDG) goal numbers to which the agreement\'s activities contribute (e.g., \'3,6,16\'). Used for donor reporting and IATI disclosure.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryNameLead rdf:type rdf:Property ;
    rdfs:label 'Signatory Name Lead' ;
    rdfs:comment 'Full name of the authorized signatory representing the lead organization on the agreement. Captured for legal validity and audit purposes.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryNamePartner rdf:type rdf:Property ;
    rdfs:label 'Signatory Name Partner' ;
    rdfs:comment 'Full name of the authorized signatory representing the partner organization on the agreement. Captured for legal validity and audit purposes.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of calendar days\' written notice required by either party to terminate the agreement without cause, as specified in the termination clause.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:theoryOfChangeReference rdf:type rdf:Property ;
    rdfs:label 'Theory Of Change Reference' ;
    rdfs:comment 'Reference identifier or title of the Theory of Change (ToC) or LogFrame (Logical Framework) document that underpins the program activities governed by this agreement. Links the agreement to the MEL framework.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Capacity Assessment Id' ;
    rdfs:comment 'Unique system-generated identifier for each partner capacity assessment record. Primary key for the capacity_assessment data product.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityAssessment .

ind:primaryCapacityStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Capacity Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or consultant who led the capacity assessment process. Used for accountability, quality assurance, and audit trail purposes.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:priorAssessmentCapacityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Prior Assessment Capacity Assessment Id' ;
    rdfs:comment 'Reference to the immediately preceding capacity assessment record for the same partner, enabling longitudinal tracking of capacity development progress over time.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityAssessment .

ind:subawardId rdf:type rdf:Property ;
    rdfs:label 'Subaward Id' ;
    rdfs:comment 'Foreign key linking to grant.subaward. Business justification: Capacity assessments directly inform subaward risk ratings and payment modality decisions. This FK links the assessment to the specific subaward it informed, enabling subaward monitoring teams to retr' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subaward .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The principal date on which the capacity assessment was conducted or the field data collection was completed. Used as the primary business event date for reporting and due diligence timelines.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assessment End Date' ;
    rdfs:comment 'Date on which the capacity assessment process was formally concluded and the final report was issued.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Assessment Location Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the country where the capacity assessment was physically conducted. Relevant for field-based assessments of local partners.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Assessment Methodology' ;
    rdfs:comment 'Standardized framework or tool used to conduct the capacity assessment. Common methodologies include USAID Organizational Capacity Assessment (OCA), DFID Organizational Capacity Assessment Tool (OCAT), ECHO Partner Assessment for Capacity Assessment (PACA), IRC Collaborative Capacity Assessment Tool (CCAT), and UNDP Capacity Scorecard. [ENUM-REF-CANDIDATE: USAID_OCA|DFID_OCAT|ECHO_PACA|IRC_CCAT|UNDP_CAPACITY_SCORECARD|OTHER — promote to reference product]' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Assessment Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this capacity assessment, used in correspondence, donor reporting, and audit trails (e.g., NGO-CA-2024-000123).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReportUrl rdf:type rdf:Property ;
    rdfs:label 'Assessment Report Url' ;
    rdfs:comment 'URL or document management system path to the full capacity assessment report. Classified as confidential due to sensitive organizational information about the partner.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScope rdf:type rdf:Property ;
    rdfs:label 'Assessment Scope' ;
    rdfs:comment 'Indicates the depth and modality of the assessment: FULL (comprehensive on-site assessment covering all functional areas), ABBREVIATED (targeted review of selected areas), DESK_REVIEW (document-based review without site visit), FIELD_VISIT (on-site verification component).' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Start Date' ;
    rdfs:comment 'Date on which the capacity assessment process formally commenced, including document review and stakeholder engagement initiation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle state of the capacity assessment record: DRAFT (initiated but not submitted), IN_PROGRESS (assessment underway), COMPLETED (assessment finalized), VALIDATED (reviewed and approved by authorized staff), ARCHIVED (superseded or closed).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentToolVersion rdf:type rdf:Property ;
    rdfs:label 'Assessment Tool Version' ;
    rdfs:comment 'Version number or edition of the assessment methodology tool used (e.g., \'USAID OCA v3.0\', \'DFID OCAT 2019\'). Ensures comparability of scores across assessments conducted using different tool versions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of when and why the assessment was conducted: PRE_AWARD (due diligence before partnership), PERIODIC (scheduled review during partnership), TRIGGERED (event-driven reassessment due to risk flag), or CLOSE_OUT (end-of-partnership evaluation).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityBuildingPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Capacity Building Plan Required' ;
    rdfs:comment 'Indicates whether the assessment results mandate the development of a formal capacity-building plan (True) or whether the partner\'s capacity is sufficient without a structured intervention plan (False).' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enhancedMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Enhanced Monitoring Required' ;
    rdfs:comment 'Indicates whether the assessment outcome requires enhanced programmatic or financial monitoring of the partner (True), such as more frequent reporting, additional site visits, or pre-approval of expenditures, as mandated by donor regulations.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialMgmtScore rdf:type rdf:Property ;
    rdfs:label 'Financial Mgmt Score' ;
    rdfs:comment 'Numeric score assigned to the partner\'s financial management functional area, covering accounting systems, internal controls, audit compliance, and fund stewardship. Typically scored on a 0–100 or 1–5 scale per the assessment methodology.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialRiskRating rdf:type rdf:Property ;
    rdfs:label 'Financial Risk Rating' ;
    rdfs:comment 'Specific risk rating for the partner\'s financial management functional area, used to determine sub-award monitoring intensity, payment modality, and required financial controls.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceScore rdf:type rdf:Property ;
    rdfs:label 'Governance Score' ;
    rdfs:comment 'Numeric score for the partner\'s organizational governance functional area, including board oversight, legal registration, organizational policies, and leadership accountability.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hrMgmtScore rdf:type rdf:Property ;
    rdfs:label 'Hr Mgmt Score' ;
    rdfs:comment 'Numeric score for the partner\'s human resources management functional area, including HR policies, recruitment practices, staff development, and safeguarding compliance.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itSystemsScore rdf:type rdf:Property ;
    rdfs:label 'It Systems Score' ;
    rdfs:comment 'Numeric score for the partner\'s ICT4D and information systems functional area, covering data management infrastructure, cybersecurity practices, and digital reporting capabilities.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Findings Summary' ;
    rdfs:comment 'Concise narrative summary of the principal findings from the capacity assessment, highlighting major strengths, critical gaps, and priority areas for improvement across all assessed functional areas.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:koboSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Kobo Submission Reference' ;
    rdfs:comment 'Unique submission identifier from KoboToolbox or similar field data collection platform used to capture assessment data in the field. Enables traceability back to the source data collection record.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAssessorName rdf:type rdf:Property ;
    rdfs:label 'Lead Assessor Name' ;
    rdfs:comment 'Full name of the individual who led the capacity assessment. Retained for reporting and audit purposes even when the staff record may change.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAssessorOrganization rdf:type rdf:Property ;
    rdfs:label 'Lead Assessor Organization' ;
    rdfs:comment 'Name of the organization to which the lead assessor belongs (e.g., the NGO\'s headquarters, an independent consulting firm, or a donor agency). Relevant when external assessors are engaged.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melScore rdf:type rdf:Property ;
    rdfs:label 'Mel Score' ;
    rdfs:comment 'Numeric score for the partner\'s Monitoring, Evaluation, and Learning (MEL) functional area, covering data collection systems, indicator tracking, reporting quality, and learning practices.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'Scheduled date by which the next capacity assessment must be completed, based on risk rating, donor requirements, or organizational policy. Drives compliance monitoring and workflow triggers.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallRiskRating rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Rating' ;
    rdfs:comment 'Categorical risk classification assigned to the partner based on the capacity assessment results: LOW (strong capacity, minimal oversight needed), MEDIUM (adequate capacity with some gaps), HIGH (significant capacity gaps requiring intensive support), CRITICAL (fundamental weaknesses posing fiduciary or programmatic risk).' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Composite numeric score representing the partner\'s overall organizational capacity across all assessed functional areas. Calculated per the assessment methodology\'s weighting scheme and recorded as the official assessment result.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerSelfAssessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Partner Self Assessment Completed' ;
    rdfs:comment 'Indicates whether the partner organization completed a self-assessment component prior to or alongside the external assessment (True). Many OCA methodologies include a parallel self-assessment to identify perception gaps.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerSelfAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Partner Self Assessment Score' ;
    rdfs:comment 'Overall score submitted by the partner organization in their self-assessment component. Compared against the external assessor\'s score to identify perception gaps and inform capacity-building dialogue.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentModalityRecommendation rdf:type rdf:Property ;
    rdfs:label 'Payment Modality Recommendation' ;
    rdfs:comment 'Payment modality recommended for sub-award disbursements based on the partner\'s financial risk rating: ADVANCE (funds transferred before expenditure), REIMBURSEMENT (funds transferred after expenditure documentation), DIRECT_PAYMENT (NGO pays vendors directly on partner\'s behalf), MIXED (combination of modalities).' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementScore rdf:type rdf:Property ;
    rdfs:label 'Procurement Score' ;
    rdfs:comment 'Numeric score for the partner\'s procurement and supply chain management functional area, covering procurement policies, competitive bidding, vendor management, and asset control.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programMgmtScore rdf:type rdf:Property ;
    rdfs:label 'Program Mgmt Score' ;
    rdfs:comment 'Numeric score for the partner\'s program design and management functional area, including project planning, implementation capacity, beneficiary targeting, and service delivery quality.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedInterventions rdf:type rdf:Property ;
    rdfs:label 'Recommended Interventions' ;
    rdfs:comment 'Narrative description of the specific capacity-building interventions recommended based on assessment findings, such as financial management training, procurement system upgrades, MEL system strengthening, or governance policy development.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreScaleMax rdf:type rdf:Property ;
    rdfs:label 'Score Scale Max' ;
    rdfs:comment 'The maximum possible score on the scoring scale used by the assessment methodology (e.g., 100 for percentage-based scales, 5 for Likert-based scales). Required to normalize scores across different methodologies for comparative analytics.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date on which the capacity assessment was formally reviewed and validated by the authorized staff member, marking the record as officially approved for use in partnership and sub-award decisions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDiligenceRecordId rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Record Id' ;
    rdfs:comment 'Unique system-generated identifier for the due diligence and partner verification record. Primary key for this entity. Entity role: MASTER_AGREEMENT — this record represents a formal compliance verification container with its own lifecycle, effective dates, and binding outcome.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sanctionsScreeningId rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Id' ;
    rdfs:comment 'Foreign key linking to compliance.sanctions_screening. Business justification: Due diligence records must reference specific sanctions screening results for anti-terrorism compliance and donor requirements. Mandatory step in partner vetting. Links DD workflow to compliance evide' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsScreening .

ind:amlCftCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Cft Check Status' ;
    rdfs:comment 'Result of Anti-Money Laundering (AML) and Counter-Financing of Terrorism (CFT) due diligence checks conducted on the partner organization and its key principals, per FATF Recommendations and donor requirements.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:antiTerrorismCertDate rdf:type rdf:Property ;
    rdfs:label 'Anti Terrorism Cert Date' ;
    rdfs:comment 'Date on which the partner\'s anti-terrorism certification was signed and received. Required for USAID and BHA-funded sub-awards.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:antiTerrorismCertification rdf:type rdf:Property ;
    rdfs:label 'Anti Terrorism Certification' ;
    rdfs:comment 'Indicates whether the partner has signed and submitted a valid anti-terrorism certification (e.g., USAID Standard Provision — Certification Regarding Terrorist Financing) as required for US Government-funded awards.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chsCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Chs Cert Expiry Date' ;
    rdfs:comment 'Date on which the partner\'s CHS certification expires. Triggers renewal alerts and may affect partner eligibility for humanitarian sub-awards.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chsCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Chs Certificate Number' ;
    rdfs:comment 'Official certificate number issued by the CHS Alliance upon successful third-party verification of the partner\'s compliance with the Core Humanitarian Standard.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chsCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Chs Certification Status' ;
    rdfs:comment 'Accreditation status of the partner against the Core Humanitarian Standard on Quality and Accountability (CHS). Certified status requires third-party verification by the CHS Alliance.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Calendar date on which all due diligence checks were completed and a final outcome was recorded. Null if the process is still in progress.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionsOfApproval rdf:type rdf:Property ;
    rdfs:label 'Conditions Of Approval' ;
    rdfs:comment 'Free-text description of any conditions, restrictions, or corrective actions attached to an approved-with-conditions outcome. Documents required remediation steps and timelines before full approval is granted.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debarmentCheckDate rdf:type rdf:Property ;
    rdfs:label 'Debarment Check Date' ;
    rdfs:comment 'Date on which the most recent debarment and suspension check was performed against SAM.gov and equivalent exclusion registries.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:debarmentCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Debarment Check Status' ;
    rdfs:comment 'Result of verification against the US System for Award Management (SAM.gov) exclusions list and equivalent debarment/suspension registries to confirm the partner is not excluded from receiving federal awards.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diligenceStatus rdf:type rdf:Property ;
    rdfs:label 'Diligence Status' ;
    rdfs:comment 'Current lifecycle state of the due diligence record, tracking progress from initiation through completion or failure. Drives workflow routing and compliance dashboards.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diligenceType rdf:type rdf:Property ;
    rdfs:label 'Diligence Type' ;
    rdfs:comment 'Classification of the due diligence exercise by its trigger and scope. Pre-award is conducted before sub-award execution; periodic review is scheduled; triggered review is initiated by a risk event; close-out is conducted at agreement end; enhanced due diligence applies to high-risk partners.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAuditOpinion rdf:type rdf:Property ;
    rdfs:label 'Financial Audit Opinion' ;
    rdfs:comment 'Type of auditor\'s opinion issued in the partner\'s most recent external financial audit. An unqualified (clean) opinion is required for most donor sub-award eligibility. Adverse or disclaimer opinions trigger enhanced due diligence.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAuditReviewed rdf:type rdf:Property ;
    rdfs:label 'Financial Audit Reviewed' ;
    rdfs:comment 'Indicates whether the partner\'s most recent external financial audit report has been reviewed and assessed as part of this due diligence exercise.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialAuditYear rdf:type rdf:Property ;
    rdfs:label 'Financial Audit Year' ;
    rdfs:comment 'Fiscal year covered by the most recent external financial audit report reviewed during due diligence. Used to assess currency of financial information.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:governanceVerified rdf:type rdf:Property ;
    rdfs:label 'Governance Verified' ;
    rdfs:comment 'Indicates whether the partner\'s governance structure (board composition, conflict of interest policies, organizational chart, and decision-making authority) has been reviewed and verified.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hapMembershipStatus rdf:type rdf:Property ;
    rdfs:label 'Hap Membership Status' ;
    rdfs:comment 'Indicates the partner\'s membership status with the Humanitarian Accountability Partnership (HAP), a predecessor accountability framework now integrated into the CHS Alliance.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiationDate rdf:type rdf:Property ;
    rdfs:label 'Initiation Date' ;
    rdfs:comment 'Calendar date on which the due diligence process was formally initiated for this partner. Marks the start of the MASTER_AGREEMENT effective period for compliance tracking purposes.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isoCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso Cert Expiry Date' ;
    rdfs:comment 'Date on which the partner\'s ISO certification expires. Null if no ISO certification is held or if certification is not time-limited.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isoCertificationType rdf:type rdf:Property ;
    rdfs:label 'Iso Certification Type' ;
    rdfs:comment 'Type of ISO certification held by the partner organization (e.g., ISO 9001 Quality Management, ISO 27001 Information Security). Null if no ISO certification is held. [ENUM-REF-CANDIDATE: ISO_9001|ISO_27001|ISO_14001|ISO_45001|ISO_31000|none — promote to reference product]' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalRegistrationVerified rdf:type rdf:Property ;
    rdfs:label 'Legal Registration Verified' ;
    rdfs:comment 'Indicates whether the partner\'s legal registration and incorporation status in its country of operation has been verified against official national NGO registration records or company registry.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ngoRegistrationCountry rdf:type rdf:Property ;
    rdfs:label 'Ngo Registration Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction in which the partner is legally registered as an NGO or nonprofit entity.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ngoRegistrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Ngo Registration Expiry Date' ;
    rdfs:comment 'Date on which the partner\'s national NGO registration expires and must be renewed. Null if registration is perpetual. Triggers compliance alerts when approaching expiry.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ngoRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Ngo Registration Number' ;
    rdfs:comment 'Official registration number issued by the national NGO regulatory authority or charity commission in the partner\'s country of primary operation. Key identifier for legal compliance verification.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallOutcome rdf:type rdf:Property ;
    rdfs:label 'Overall Outcome' ;
    rdfs:comment 'Final determination of the due diligence exercise indicating whether the partner is cleared for sub-award or partnership engagement. Approved with conditions requires a documented corrective action plan.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Record Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference code assigned to this due diligence record, used in correspondence, audit trails, and donor reporting. Format: DDR-YYYY-NNNNNN.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerNotes rdf:type rdf:Property ;
    rdfs:label 'Reviewer Notes' ;
    rdfs:comment 'Confidential narrative notes recorded by the responsible staff member summarizing key findings, concerns, and recommendations from the due diligence review. Restricted to compliance and partnership leadership.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Composite risk rating assigned to the partner following due diligence, reflecting financial, governance, compliance, and operational risk factors. Determines monitoring intensity and sub-award conditions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Numeric composite risk score (typically 0–100) calculated from weighted assessment criteria across financial, governance, legal, and operational dimensions. Supports quantitative risk ranking across the partner portfolio.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeguardingPolicyVerified rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Policy Verified' ;
    rdfs:comment 'Indicates whether the partner has a documented and operational safeguarding policy covering protection from sexual exploitation, abuse, and harassment (PSEAH), child protection, and GBV prevention, as required by IASC and donor standards.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sphereComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Sphere Compliance Status' ;
    rdfs:comment 'Assessment of the partner\'s operational compliance with the Sphere Humanitarian Charter and Minimum Standards in Humanitarian Response, covering WASH, food security, shelter, and health sectors.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerContactId rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Id' ;
    rdfs:comment 'Unique system-generated identifier for the partner contact record. Primary key for the partner_contact data product within the partnership domain.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:focalPointStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Focal Point Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: NGO partnership teams assign individual staff as day-to-day focal points for specific partner contacts (distinct from the org-level relationship manager). This supports contact management, meeting sch' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:clusterMembership rdf:type rdf:Property ;
    rdfs:label 'Cluster Membership' ;
    rdfs:comment 'Name of the OCHA humanitarian cluster(s) or IASC working group(s) in which this contact participates as a representative or lead (e.g., WASH Cluster, Health Cluster, Protection Cluster, Food Security Cluster). Supports inter-agency coordination tracking.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date on which the partner contact provided or last renewed their data sharing consent. Used to track consent validity periods and trigger re-consent workflows in compliance with GDPR and organizational data protection policies.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the partner contact record. Indicates whether the contact is actively engaged in partnership coordination, temporarily unavailable, or no longer with the organization.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the partner contact has provided explicit consent for their personal data to be shared with third parties, donor agencies, or inter-agency coordination bodies. Required for compliance with GDPR, data protection regulations, and the Core Humanitarian Standard (CHS) accountability principles.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates that the partner contact has requested to not be contacted, or has been flagged by the organization as ineligible for outreach. Overrides all communication workflows and must be respected in all outreach campaigns.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the partner contact individual. Used for personalized communication and formal correspondence across the partnership lifecycle.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAuthorizedSignatory rdf:type rdf:Property ;
    rdfs:label 'Is Authorized Signatory' ;
    rdfs:comment 'Indicates whether the partner contact is an authorized legal signatory for agreements such as Memoranda of Understanding (MoU), Letters of Agreement (LoA), sub-award agreements, and Scope of Work (SoW) documents. Critical for compliance with OMB Uniform Guidance 2 CFR 200 and donor requirements.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFinancialAuthorized rdf:type rdf:Property ;
    rdfs:label 'Is Financial Authorized' ;
    rdfs:comment 'Indicates whether the partner contact holds financial authorization authority, such as approving sub-grant disbursements, signing financial reports, or authorizing Budget versus Actual (BvA) submissions. Supports financial stewardship and fund accounting controls.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this individual is the designated primary focal point for the partner organization. Only one contact per organization should be flagged as primary. Drives automated routing of official communications and partnership notifications.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title or designation of the partner contact within their organization (e.g., Country Director, Finance Manager, Program Coordinator). Used in formal correspondence and stakeholder mapping.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'Date of the most recent recorded interaction or communication with the partner contact. Used to identify dormant relationships, prioritize re-engagement, and support relationship management workflows in the Constituent Relationship Management (CRM) system.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the partner contact individual. Combined with first_name to form the full display name for reporting and relationship management.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinProfile rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile' ;
    rdfs:comment 'LinkedIn professional profile URL for the partner contact. Used for prospect research, due diligence verification, and professional background validation during partner capacity assessments.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or second given name of the partner contact, used in formal legal correspondence and official documentation such as Memoranda of Understanding (MoU) and Letters of Agreement (LoA).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile or cellular phone number for the partner contact in E.164 international format. Critical for field operations communication, WhatsApp coordination, and emergency contact in humanitarian contexts.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Channel' ;
    rdfs:comment 'The partner contact\'s preferred communication channel for receiving outreach and coordination messages. Supports effective stakeholder engagement and respects communication preferences in diverse field contexts.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary professional email address for the partner contact. Used as the main digital communication channel for coordination, reporting, and official correspondence including Memoranda of Understanding (MoU) and Scope of Work (SoW) exchanges.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Primary telephone number for the partner contact in E.164 international format. Used for urgent coordination, field communications, and stakeholder engagement across the partnership lifecycle.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Functional role classification of the contact within the partnership relationship. Determines the contact\'s authority and responsibilities in coordination workflows. [ENUM-REF-CANDIDATE: focal_point|authorized_representative|technical_lead|financial_officer|program_manager|legal_signatory|cluster_coordinator|field_officer — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Honorific or title prefix used when addressing the partner contact in formal communications (e.g., Mr., Ms., Dr., Prof.).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skypeHandle rdf:type rdf:Property ;
    rdfs:label 'Skype Handle' ;
    rdfs:comment 'Skype username or identifier for the partner contact. Used for virtual coordination meetings, remote field communications, and inter-agency conference calls in areas with limited connectivity.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this partner contact record originated (e.g., Salesforce Nonprofit Cloud, Microsoft Dynamics 365 for Nonprofits, Raisers Edge NXT). Supports data lineage tracking and master data management reconciliation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemContactReference rdf:type rdf:Property ;
    rdfs:label 'Source System Contact Reference' ;
    rdfs:comment 'The unique identifier assigned to this contact record in the originating operational system of record (e.g., Salesforce Contact ID, Dynamics 365 Contact GUID). Enables cross-system reconciliation and data lineage tracing in the lakehouse Silver layer.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date on which the partner contact\'s identity and credentials were last verified as part of the partner due diligence process. Used to schedule re-verification cycles and maintain compliance audit trails.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of the identity and credential verification process for the partner contact. Supports due diligence requirements for sub-award management and partner capacity assessments per USAID, DFID, and OMB Uniform Guidance 2 CFR 200 requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Agreement Amendment Id' ;
    rdfs:comment 'Unique system-generated identifier for each formal modification record to a partnership agreement. Serves as the primary key for the agreement_amendment entity.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:donorFundId rdf:type rdf:Property ;
    rdfs:label 'Donor Fund Id' ;
    rdfs:comment 'Foreign key linking to donor.donor_fund. Business justification: Agreement amendments affecting budget or scope require donor prior approval when funded by restricted donor funds. The existing donor_approval_reference field signals this process. NGO grants managers' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DonorFund .

ind:grantAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Grant Amendment Id' ;
    rdfs:comment 'Foreign key linking to grant.grant_amendment. Business justification: When a donor issues a grant amendment, NGOs must cascade changes into partnership agreement amendments. This FK links the triggering grant amendment to the resulting agreement amendment — a mandatory ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GrantAmendment .

ind:primaryAgreementStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Agreement Staff Member Id' ;
    rdfs:comment 'Reference to the staff member record of the individual who formally approved this amendment. Links to the workforce domain for accountability and audit trail purposes.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle state of the amendment record. Draft indicates preparation in progress; pending_approval indicates submission to approval authority; approved indicates fully executed; rejected indicates declined by approver; superseded indicates replaced by a subsequent amendment; withdrawn indicates retracted before approval.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentTitle rdf:type rdf:Property ;
    rdfs:label 'Amendment Title' ;
    rdfs:comment 'Short descriptive title summarizing the purpose of the amendment (e.g., \'No-Cost Extension to December 2025\', \'Budget Realignment Q3 2024\'). Used in correspondence, dashboards, and partner communications.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the formal modification being made to the agreement. Scope change alters deliverables or geographic coverage; budget realignment redistributes funds across cost categories; no-cost extension extends the period without additional funding; period of performance adjusts start/end dates; signatory change updates authorized representatives. [ENUM-REF-CANDIDATE: scope_change|budget_realignment|no_cost_extension|period_of_performance|signatory_change|other — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or title of the individual, committee, or organizational body with delegated authority to approve this amendment (e.g., Country Director, Grants Manager, Donor Agreement Officer). Supports RACI accountability tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryTargetChange rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Target Change' ;
    rdfs:comment 'Indicates whether this amendment modifies the target beneficiary numbers, population groups, or vulnerability criteria for the program. True = beneficiary targets modified; False = no change. Relevant for MEL/MEAL reporting and SDG indicator tracking.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Change Amount' ;
    rdfs:comment 'The net monetary change to the agreement budget introduced by this amendment (revised_budget_amount minus original_budget_amount). Positive values indicate budget increases; negative values indicate reductions. Null for non-financial amendments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clausesModified rdf:type rdf:Property ;
    rdfs:label 'Clauses Modified' ;
    rdfs:comment 'Enumeration or description of the specific agreement clauses, articles, or sections that are modified by this amendment (e.g., \'Article 3 — Scope of Work, Article 7 — Budget\'). Supports legal review and compliance tracking.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'File path, document management system reference, or URL pointing to the executed amendment document (signed PDF or equivalent). Supports audit trail and compliance evidence requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Donor Approval Reference' ;
    rdfs:comment 'Reference number, letter identifier, or correspondence tracking code for the donor\'s written prior approval of this amendment. Required for audit evidence when donor_prior_approval_required is True.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorPriorApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Donor Prior Approval Required' ;
    rdfs:comment 'Indicates whether this amendment requires prior written approval from the donor or prime recipient before implementation, as mandated under 2 CFR 200.308 or specific award terms. True = prior approval required; False = notification only or no approval needed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionDurationDays rdf:type rdf:Property ;
    rdfs:label 'Extension Duration Days' ;
    rdfs:comment 'Number of calendar days by which the period of performance is extended by this amendment. Null for non-extension amendments. Used for program planning, resource allocation, and donor reporting on timeline changes.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicScopeChange rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope Change' ;
    rdfs:comment 'Indicates whether this amendment modifies the geographic coverage or operational areas of the agreement (e.g., adding or removing districts, countries, or OCHA cluster areas). True = geographic scope modified; False = no geographic change.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmsReference rdf:type rdf:Property ;
    rdfs:label 'Gms Reference' ;
    rdfs:comment 'External reference identifier for this amendment as recorded in the Grant Management System (GMS) or donor\'s award management platform (e.g., USAID ASIST, DFID ARIES). Enables cross-system reconciliation and donor audit support.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isNoCostExtension rdf:type rdf:Property ;
    rdfs:label 'Is No Cost Extension' ;
    rdfs:comment 'Indicates whether this amendment constitutes a no-cost extension (NCE), extending the period of performance without additional funding. True = NCE; False = other amendment type. Critical for grant closeout planning and donor reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Narrative explanation of the business rationale for the amendment, including the circumstances that necessitated the change (e.g., context changes, operational constraints, donor-directed modifications). Required for donor reporting and audit compliance under 2 CFR 200.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ngoSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Ngo Signatory Name' ;
    rdfs:comment 'Full name of the authorized representative of Ngo who signs this amendment on behalf of the organization. Required for legal enforceability and signatory change tracking.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Original Budget Amount' ;
    rdfs:comment 'The total authorized budget of the agreement prior to this amendment, expressed in the agreement currency. Retained for Budget versus Actual (BvA) analysis and audit trail of financial modifications.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalEndDate rdf:type rdf:Property ;
    rdfs:label 'Original End Date' ;
    rdfs:comment 'The end date of the period of performance as defined in the agreement prior to this amendment. Used to calculate extension duration and track no-cost extension history.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalStartDate rdf:type rdf:Property ;
    rdfs:label 'Original Start Date' ;
    rdfs:comment 'The start date of the period of performance as defined in the agreement prior to this amendment. Retained for audit trail and comparison purposes when a period-of-performance amendment is processed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Partner Signatory Name' ;
    rdfs:comment 'Full name of the authorized representative of the partner organization who signs this amendment on behalf of the CSO, CBO, INGO, government body, or UN agency. Required for signatory change amendments and legal enforceability.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedBeneficiaryTarget rdf:type rdf:Property ;
    rdfs:label 'Revised Beneficiary Target' ;
    rdfs:comment 'Updated total number of direct beneficiaries targeted under the agreement following this amendment. Null if beneficiary_target_change is False. Used for MEL/MEAL indicator tracking and donor results reporting.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Budget Amount' ;
    rdfs:comment 'The total authorized budget of the agreement as updated by this amendment. Null if this amendment does not modify the budget. Used for BvA reporting and donor financial compliance.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedEndDate rdf:type rdf:Property ;
    rdfs:label 'Revised End Date' ;
    rdfs:comment 'The updated end date of the period of performance as established by this amendment. Null if this amendment does not modify the end date. Key field for no-cost extension tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisedStartDate rdf:type rdf:Property ;
    rdfs:label 'Revised Start Date' ;
    rdfs:comment 'The updated start date of the period of performance as established by this amendment. Null if this amendment does not modify the start date.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Change Description' ;
    rdfs:comment 'Detailed narrative describing changes to the Scope of Work (SoW), program activities, geographic coverage, target beneficiary populations, or deliverables introduced by this amendment. Null if amendment type is not scope_change.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'The date on which the amendment request was formally submitted to the approval authority or donor/prime for review. Used to track processing timelines and compliance with advance notification requirements under 2 CFR 200.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerPerformanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Partner Performance Review Id' ;
    rdfs:comment 'Unique system-generated identifier for each partner performance review record. Primary key for the partner_performance_review data product.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerPerformanceReview .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.budget. Business justification: Partner performance reviews assess budget_utilisation_rate as a core financial performance indicator. NGO program managers need the linked budget record to compute accurate utilization scores and prod' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:implementationPlanId rdf:type rdf:Property ;
    rdfs:label 'Implementation Plan Id' ;
    rdfs:comment 'Reference to the program or project that the implementing partner is delivering under review.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ImplementationPlan .

ind:internalReviewId rdf:type rdf:Property ;
    rdfs:label 'Internal Review Id' ;
    rdfs:comment 'Foreign key linking to compliance.internal_review. Business justification: Partner performance reviews may trigger or reference internal compliance reviews when issues are identified. Links performance monitoring to compliance oversight. Essential for integrated risk managem' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalReview .

ind:primaryPartnerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Partner Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or team lead who conducted and is accountable for this performance review.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:areasForImprovement rdf:type rdf:Property ;
    rdfs:label 'Areas For Improvement' ;
    rdfs:comment 'Narrative description of performance gaps, weaknesses, or risks identified during the review that require corrective action or capacity strengthening.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryFeedbackIncorporated rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Feedback Incorporated' ;
    rdfs:comment 'Indicates whether beneficiary feedback (e.g., from Post-Distribution Monitoring (PDM), Focus Group Discussions (FGD), or KoboToolbox surveys) was incorporated into the review findings.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetUtilisationRate rdf:type rdf:Property ;
    rdfs:label 'Budget Utilisation Rate' ;
    rdfs:comment 'Percentage of the sub-award budget expended by the partner during the review period (0.00–100.00). Key Budget versus Actual (BvA) indicator for financial stewardship assessment.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityBuildingAreas rdf:type rdf:Property ;
    rdfs:label 'Capacity Building Areas' ;
    rdfs:comment 'Narrative description of specific capacity building areas recommended for the partner (e.g., financial management, MEL systems, safeguarding, ICT4D). Populated when capacity_building_recommended is True.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityBuildingRecommended rdf:type rdf:Property ;
    rdfs:label 'Capacity Building Recommended' ;
    rdfs:comment 'Indicates whether the reviewer recommends a formal capacity building or organisational development intervention for the partner based on identified gaps.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of required corrective actions, including specific steps the partner must take to address identified deficiencies. Populated when corrective_action_required is True.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Deadline by which the partner must demonstrate completion of required corrective actions. Null when corrective_action_required is False.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether a formal Corrective Action Plan (CAP) is required as an outcome of this review. True triggers a CAP workflow in the partnership management system.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current status of the corrective action plan associated with this review. Tracks partner remediation progress for risk management and compliance reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldVisitConducted rdf:type rdf:Property ;
    rdfs:label 'Field Visit Conducted' ;
    rdfs:comment 'Indicates whether a physical field visit to the partner\'s implementation site was conducted as part of this review. Required for high-risk partners per OMB Uniform Guidance subrecipient monitoring standards.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialAccountabilityRating rdf:type rdf:Property ;
    rdfs:label 'Financial Accountability Rating' ;
    rdfs:comment 'Rating of the partner\'s financial management practices including Budget versus Actual (BvA) variance, expenditure documentation, and compliance with Indirect Cost Rate (ICR) / NICRA requirements.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneAchievementRate rdf:type rdf:Property ;
    rdfs:label 'Milestone Achievement Rate' ;
    rdfs:comment 'Percentage of agreed SoW milestones achieved within the review period (0.00–100.00). Key Results-Based Management (RBM) indicator for partner performance tracking.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestonesAchievedCount rdf:type rdf:Property ;
    rdfs:label 'Milestones Achieved Count' ;
    rdfs:comment 'Number of SoW milestones fully achieved within the review period. Numerator for milestone achievement rate calculation.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestonesPlannedCount rdf:type rdf:Property ;
    rdfs:label 'Milestones Planned Count' ;
    rdfs:comment 'Total number of SoW milestones scheduled for delivery within the review period. Denominator for milestone achievement rate calculation.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Scheduled date for the next performance review of this partner under the current agreement. Determined by risk level and agreement terms.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Overall Performance Rating' ;
    rdfs:comment 'Composite performance rating assigned to the partner for the review period. Drives partnership renewal, risk classification, and sub-award decisions. Aligned with DAC evaluation criteria.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Overall Performance Score' ;
    rdfs:comment 'Numeric composite score (e.g., 0.00–100.00) aggregating all scored dimensions of the review. Enables quantitative ranking and trend analysis across partners.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Partner Acknowledgement Date' ;
    rdfs:comment 'Date on which the implementing partner formally acknowledged the review findings. Null until acknowledgement is received.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerAcknowledgementReceived rdf:type rdf:Property ;
    rdfs:label 'Partner Acknowledgement Received' ;
    rdfs:comment 'Indicates whether the implementing partner has formally acknowledged receipt of the review findings and agreed corrective actions. Required for CHS accountability compliance.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnershipRenewalRecommendation rdf:type rdf:Property ;
    rdfs:label 'Partnership Renewal Recommendation' ;
    rdfs:comment 'Reviewer\'s recommendation on whether to renew, conditionally renew, or terminate the partnership agreement based on this review\'s findings. Feeds into partnership pipeline decisions.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticQualityRating rdf:type rdf:Property ;
    rdfs:label 'Programmatic Quality Rating' ;
    rdfs:comment 'Rating of the partner\'s delivery quality against agreed SoW milestones, Theory of Change (ToC) outputs, and LogFrame indicators. Distinct from financial accountability.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Reporting Compliance Rating' ;
    rdfs:comment 'Rating of the partner\'s adherence to agreed reporting schedules, SitRep submissions, and donor reporting requirements including IATI data publication obligations.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportsDueCount rdf:type rdf:Property ;
    rdfs:label 'Reports Due Count' ;
    rdfs:comment 'Total number of reports required from the partner during the review period per the agreement schedule.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportsSubmittedCount rdf:type rdf:Property ;
    rdfs:label 'Reports Submitted Count' ;
    rdfs:comment 'Number of required narrative and financial reports submitted by the partner during the review period.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'The actual calendar date on which the performance review meeting or assessment was conducted with the partner.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewMethod rdf:type rdf:Property ;
    rdfs:label 'Review Method' ;
    rdfs:comment 'Methodology used to conduct the performance review. Field visits provide direct observation; desk reviews rely on submitted documentation; joint reviews involve donor or cluster lead participation.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Review Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this review for tracking in correspondence, donor reports, and audit trails. Format: PPR-YYYY-NNNNNN.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Classification of the review occasion. Scheduled reviews occur at fixed intervals per the SoW; triggered reviews are initiated by risk events or compliance concerns; final reviews occur at agreement close-out.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeguardingComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Compliance Rating' ;
    rdfs:comment 'Rating of the partner\'s compliance with safeguarding policies including GBV prevention, child protection, and HAP/CHS accountability commitments.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthsNoted rdf:type rdf:Property ;
    rdfs:label 'Strengths Noted' ;
    rdfs:comment 'Narrative description of the partner\'s notable strengths and positive performance areas identified during the review. Used for learning and best-practice documentation.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consortiumId rdf:type rdf:Property ;
    rdfs:label 'Consortium Id' ;
    rdfs:comment 'Unique system-generated identifier for the consortium record. Primary key for the consortium master data product within the partnership domain.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consortium .

ind:managingOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Managing Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Consortium operations are managed by a specific NGO org unit (country office or thematic department). This link enables organizational accountability reporting, budget ownership tracking, and headcoun' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:ngoFocalPointStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Ngo Focal Point Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Consortium management requires designated NGO staff focal point for coordination, steering committee participation, and member communication. Standard practice in multi-agency humanitarian response co' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:primaryDonorConstituentId rdf:type rdf:Property ;
    rdfs:label 'Primary Donor Constituent Id' ;
    rdfs:comment 'FK to donor.constituent' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:singleAuditId rdf:type rdf:Property ;
    rdfs:label 'Single Audit Id' ;
    rdfs:comment 'Foreign key linking to compliance.single_audit. Business justification: Consortia receiving US federal funds above threshold require single audits per OMB Uniform Guidance. Links consortium structure to regulatory audit requirement. Essential for federal grant compliance ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SingleAudit .

ind:chsComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Chs Compliance Status' ;
    rdfs:comment 'Status of the consortium\'s adherence to the Core Humanitarian Standard (CHS) on Quality and Accountability, assessed through partner due diligence and capacity assessments.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consortiumName rdf:type rdf:Property ;
    rdfs:label 'Consortium Name' ;
    rdfs:comment 'Official full name of the multi-partner consortium or joint programming arrangement as registered with the lead donor or coordinating body (e.g., OCHA cluster).' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consortiumType rdf:type rdf:Property ;
    rdfs:label 'Consortium Type' ;
    rdfs:comment 'Classification of the consortium arrangement indicating Ngo\'s role and the structural form. Lead_agency means Ngo is the prime recipient; member means Ngo is a sub-partner; pooled_fund indicates a CERF or similar mechanism. [ENUM-REF-CANDIDATE: lead_agency|member|co_implementer|pooled_fund|consortium_of_consortia — promote to reference product]' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionMakingProtocol rdf:type rdf:Property ;
    rdfs:label 'Decision Making Protocol' ;
    rdfs:comment 'Formal protocol governing how decisions are made within the consortium. Consensus requires unanimous agreement; majority_vote uses simple majority; lead_agency_authority delegates decisions to the prime recipient; weighted_vote allocates votes by funding share.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingCurrency rdf:type rdf:Property ;
    rdfs:label 'Funding Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the total funding envelope (e.g., USD, EUR, GBP). Aligns with IATI currency reporting standards and SAP S/4HANA fund accounting.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceStructure rdf:type rdf:Property ;
    rdfs:label 'Governance Structure' ;
    rdfs:comment 'Narrative description of the consortium\'s governance model including steering committee composition, decision-making protocols, voting rights, and escalation procedures as defined in the consortium agreement.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grandBargainLocalization rdf:type rdf:Property ;
    rdfs:label 'Grand Bargain Localization' ;
    rdfs:comment 'Indicates whether this consortium is formally counted toward Ngo\'s Grand Bargain localization commitments, specifically the 25% funding to local and national actors target.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iascWorkingGroup rdf:type rdf:Property ;
    rdfs:label 'Iasc Working Group' ;
    rdfs:comment 'Name of the IASC working group or task force with which this consortium coordinates, relevant for inter-agency humanitarian response planning and joint needs assessments.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatiIdentifier rdf:type rdf:Property ;
    rdfs:label 'Iati Identifier' ;
    rdfs:comment 'Globally unique IATI activity identifier for the consortium, enabling public transparency reporting on aid flows, partner contributions, and results per IATI Standard requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Localization Percentage' ;
    rdfs:comment 'Percentage of the total consortium funding envelope directed to local and national CSOs or CBOs as sub-partners, tracked against Grand Bargain 25% localization commitment.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:logframeRef rdf:type rdf:Property ;
    rdfs:label 'Logframe Ref' ;
    rdfs:comment 'Reference identifier or document title of the consortium\'s Logical Framework (LogFrame) used for results-based management (RBM), KPI tracking, and donor reporting.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melFrameworkRef rdf:type rdf:Property ;
    rdfs:label 'Mel Framework Ref' ;
    rdfs:comment 'Reference identifier or document title of the consortium\'s joint MEL (Monitoring Evaluation and Learning) or MEAL (Monitoring Evaluation Accountability and Learning) framework used for collective results measurement.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Total number of partner organizations formally participating in the consortium, including lead agency and all sub-partners (INGOs, CSOs, CBOs, UN agencies, government bodies).' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ngoFundingShare rdf:type rdf:Property ;
    rdfs:label 'Ngo Funding Share' ;
    rdfs:comment 'Portion of the total consortium funding envelope allocated to Ngo, whether as lead agency managing sub-awards or as a sub-partner receiving a sub-grant. Used for BvA (Budget versus Actual) reporting and ICR/NICRA calculations.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ngoRole rdf:type rdf:Property ;
    rdfs:label 'Ngo Role' ;
    rdfs:comment 'Specific role that Ngo plays within this consortium arrangement. Lead_agency means Ngo holds the prime award and manages sub-awards; co_lead means shared leadership; sub_partner means Ngo receives a sub-award from the lead.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ochaClusterAlignment rdf:type rdf:Property ;
    rdfs:label 'Ocha Cluster Alignment' ;
    rdfs:comment 'Name of the OCHA humanitarian cluster(s) or sector working group(s) to which this consortium is formally aligned or co-leads (e.g., WASH Cluster, Food Security Cluster, Health Cluster, Protection Cluster).' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current lifecycle state of the consortium. Pipeline indicates pre-formation; active indicates ongoing joint programming; suspended indicates temporary halt; closed indicates completed; dissolved indicates formally terminated with no further obligations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pooledFundMechanism rdf:type rdf:Property ;
    rdfs:label 'Pooled Fund Mechanism' ;
    rdfs:comment 'Name of the pooled funding mechanism associated with the consortium if applicable (e.g., CERF, Country-Based Pooled Fund (CBPF), ECHO, BHA). Supports ODA tracking and joint donor reporting.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceCode rdf:type rdf:Property ;
    rdfs:label 'Reference Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the consortium by the lead donor, OCHA, or internal grant management system (GMS) for cross-system identification and reporting.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or commonly used name or acronym for the consortium used in SitReps, donor reports, and inter-agency communications.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:steeringCommitteeComposition rdf:type rdf:Property ;
    rdfs:label 'Steering Committee Composition' ;
    rdfs:comment 'Description of the steering committee membership including designated representatives from each partner organization, their roles (chair, co-chair, member), and meeting frequency.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thematicFocus rdf:type rdf:Property ;
    rdfs:label 'Thematic Focus' ;
    rdfs:comment 'Primary humanitarian or development sector(s) addressed by the consortium (e.g., WASH, GBV, food security, health, education, PSS). Aligns with OCHA cluster system and IASC sector classifications.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoryOfChangeRef rdf:type rdf:Property ;
    rdfs:label 'Theory Of Change Ref' ;
    rdfs:comment 'Reference identifier or document title of the consortium\'s Theory of Change (ToC) that articulates the causal pathway from inputs and activities to intended outcomes and impact. Used in MEL and MEAL frameworks.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Total Funding Amount' ;
    rdfs:comment 'Total funding envelope committed to the consortium across all member organizations and donor sources, expressed in the reporting currency. Used for Grand Bargain localization tracking and joint donor reporting.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerReportSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Partner Report Submission Id' ;
    rdfs:comment 'Unique system-generated identifier for each partner report submission record. Primary key for this entity.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerReportSubmission .

ind:budgetPlanId rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Id' ;
    rdfs:comment 'Foreign key linking to program.budget_plan. Business justification: Partner financial reports must reference the approved budget plan for budget-vs-actual variance analysis, expenditure verification against approved line items, burn rate tracking, and financial accoun' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetPlan .

ind:donorReportId rdf:type rdf:Property ;
    rdfs:label 'Donor Report Id' ;
    rdfs:comment 'Foreign key linking to grant.donor_report. Business justification: NGO compliance officers consolidate partner report submissions into donor reports. This FK enables the donor reporting aggregation process — tracing which partner submissions fed each donor report — r' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DonorReport .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'The date on which the report was formally accepted by the organization, signifying that all reporting obligations for the period have been satisfactorily met by the implementing partner.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiariesReached rdf:type rdf:Property ;
    rdfs:label 'Beneficiaries Reached' ;
    rdfs:comment 'Total number of direct beneficiaries (Persons of Concern, IDPs, or target population) reached by the partner\'s program activities during the reporting period, as reported by the partner.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clusterSector rdf:type rdf:Property ;
    rdfs:label 'Cluster Sector' ;
    rdfs:comment 'The humanitarian cluster or sector (e.g., WASH, Health, Shelter, Food Security, Protection, GBV) under which the partner\'s reported activities fall, aligned with OCHA cluster coordination structures.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysLate rdf:type rdf:Property ;
    rdfs:label 'Days Late' ;
    rdfs:comment 'Number of calendar days by which the submission exceeded the due date. Zero or negative values indicate on-time or early submission. Used for partner performance scoring and compliance reporting.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path to the primary report document stored in the document management system or GMS (Grant Management System), enabling direct access to the submitted report file.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorReportingObligation rdf:type rdf:Property ;
    rdfs:label 'Donor Reporting Obligation' ;
    rdfs:comment 'Indicates whether this partner report submission is required to satisfy a specific donor reporting obligation (e.g., USAID BHA, DFID, CERF), meaning the data must be incorporated into the prime recipient\'s donor report.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The contractually obligated deadline by which the partner was required to submit this report, as specified in the sub-award agreement or LoA.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feedbackProvided rdf:type rdf:Property ;
    rdfs:label 'Feedback Provided' ;
    rdfs:comment 'Detailed written feedback, comments, or queries provided by the reviewer to the implementing partner following the review of the submitted report. Captures specific issues, clarifications required, or commendations.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialDocumentationAttached rdf:type rdf:Property ;
    rdfs:label 'Financial Documentation Attached' ;
    rdfs:comment 'Indicates whether the partner attached supporting financial documentation (receipts, invoices, bank statements) to this report submission as required under 2 CFR 200 and the sub-award agreement.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Description of the geographic areas (districts, regions, or country) where the partner implemented activities during the reporting period, as reported. May reference GIS coordinates or administrative boundaries.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLateSubmission rdf:type rdf:Property ;
    rdfs:label 'Is Late Submission' ;
    rdfs:comment 'Indicates whether the report was submitted after the contractually obligated due date. True if submission_date is after due_date. Used for partner performance monitoring and compliance tracking.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:melIndicatorsReported rdf:type rdf:Property ;
    rdfs:label 'Mel Indicators Reported' ;
    rdfs:comment 'Indicates whether the partner included MEL (Monitoring Evaluation and Learning) indicator data and results in this report submission, as required by the sub-award agreement.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:narrativeSummary rdf:type rdf:Property ;
    rdfs:label 'Narrative Summary' ;
    rdfs:comment 'A concise summary of the programmatic progress, key achievements, challenges, and lessons learned as reported by the implementing partner for the reporting period.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Numeric quality assessment score assigned by the reviewer to the submitted report, typically on a standardized scale (e.g., 0–100). Reflects completeness, accuracy, and adherence to reporting standards. Used for partner performance monitoring.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Additional notes, contextual observations, or internal comments recorded by the grants management team regarding this report submission, such as exceptional circumstances, force majeure events, or escalation notes.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportPeriodFrequency rdf:type rdf:Property ;
    rdfs:label 'Report Period Frequency' ;
    rdfs:comment 'The scheduled reporting cadence for this submission as defined in the sub-award agreement, indicating whether the report covers a monthly, quarterly, semi-annual, annual, or ad hoc period.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportTitle rdf:type rdf:Property ;
    rdfs:label 'Report Title' ;
    rdfs:comment 'The formal title or name of the submitted report document as provided by the implementing partner, used for identification and document management purposes.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the report submitted by the partner. Narrative reports cover programmatic progress; financial reports cover expenditure against budget (BvA); SitRep (Situation Report) covers operational context; PDM (Post-Distribution Monitoring) covers distribution outcomes; combined covers both narrative and financial. [ENUM-REF-CANDIDATE: narrative|financial|situation_report|post_distribution_monitoring|combined|other — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportVersion rdf:type rdf:Property ;
    rdfs:label 'Report Version' ;
    rdfs:comment 'Sequential version number of the report submission, incremented each time the partner resubmits a revised version following feedback or a revision request. Version 1 is the initial submission.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'The last day of the period covered by this report submission, as defined in the sub-award or agreement reporting schedule.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'The first day of the period covered by this report submission, as defined in the sub-award or agreement reporting schedule.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'The date on which the review of the partner report was completed and a decision (accepted, feedback issued, or rejected) was communicated to the partner.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'The date on which the formal review of the submitted report was initiated by the grants management team.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionDeadline rdf:type rdf:Property ;
    rdfs:label 'Revision Deadline' ;
    rdfs:comment 'The deadline by which the implementing partner must resubmit a revised report following a revision request or feedback issuance. Null if no revision has been requested.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The actual calendar date on which the partner submitted this report to the organization. Used to calculate timeliness and compliance with reporting obligations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'The channel or mechanism through which the partner submitted the report, such as email, online portal, GMS (Grant Management System) upload, hard copy, or KoboToolbox.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this report submission, used in correspondence with the partner and in donor reporting systems such as Unit4 ERP or GMS.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBeneficiaries rdf:type rdf:Property ;
    rdfs:label 'Target Beneficiaries' ;
    rdfs:comment 'The planned number of beneficiaries the partner was expected to reach during the reporting period as defined in the sub-award agreement or LogFrame targets.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalExpenditureReported rdf:type rdf:Property ;
    rdfs:label 'Total Expenditure Reported' ;
    rdfs:comment 'The total financial expenditure reported by the implementing partner for the reporting period, as stated in the financial report. Used for Budget versus Actual (BvA) analysis and donor financial reporting.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityBuildingPlanId rdf:type rdf:Property ;
    rdfs:label 'Capacity Building Plan Id' ;
    rdfs:comment 'Unique system-generated identifier for the capacity building plan record. Primary key for this entity. Role: MASTER_AGREEMENT — this product represents a structured, time-bound plan (agreement-like container) governing capacity-building interventions for a partner organization.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityBuildingPlan .

ind:correctiveActionPlanId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Id' ;
    rdfs:comment 'Foreign key linking to compliance.corrective_action_plan. Business justification: Capacity building plans are directly created in response to corrective action plans when audit findings or compliance incidents identify partner capability gaps (e.g., a CAP finding of weak financial ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveActionPlan .

ind:baselineCapacityScore rdf:type rdf:Property ;
    rdfs:label 'Baseline Capacity Score' ;
    rdfs:comment 'Numeric score representing the partner organization\'s overall organizational capacity at the time of the baseline assessment, prior to plan implementation. Typically scored on a standardized scale (e.g., 1–5 or 0–100) per the assessment tool used.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityScoreScale rdf:type rdf:Property ;
    rdfs:label 'Capacity Score Scale' ;
    rdfs:comment 'The scoring scale used for baseline, target, and current capacity scores in this plan (e.g., \'1_to_5\', \'0_to_100\'). Ensures consistent interpretation of scores across different assessment tools and reporting periods.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chsStandardAligned rdf:type rdf:Property ;
    rdfs:label 'Chs Standard Aligned' ;
    rdfs:comment 'Indicates whether this capacity building plan is designed in alignment with the Core Humanitarian Standard (CHS) on Quality and Accountability, ensuring the partner is supported to meet CHS commitments.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentCapacityScore rdf:type rdf:Property ;
    rdfs:label 'Current Capacity Score' ;
    rdfs:comment 'Most recently recorded organizational capacity score for the partner, updated following periodic reassessments or milestone reviews during plan implementation. Enables tracking of progress toward the target capacity score.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Donor Reporting Required' ;
    rdfs:comment 'Indicates whether progress on this capacity building plan must be reported to the donor as part of grant compliance obligations. True = donor reporting required; False = internal plan only.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expenditureToDateUsd rdf:type rdf:Property ;
    rdfs:label 'Expenditure To Date Usd' ;
    rdfs:comment 'Cumulative actual expenditure incurred against this capacity building plan to date, expressed in US Dollars (USD). Used for Budget versus Actual (BvA) tracking and financial stewardship reporting.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:genderMainstreamingIncluded rdf:type rdf:Property ;
    rdfs:label 'Gender Mainstreaming Included' ;
    rdfs:comment 'Indicates whether gender mainstreaming and Gender-Based Violence (GBV) prevention components are explicitly included in this capacity building plan, in line with donor gender policies and SDG (Sustainable Development Goal) 5 commitments.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grandBargainCommitmentRef rdf:type rdf:Property ;
    rdfs:label 'Grand Bargain Commitment Ref' ;
    rdfs:comment 'Reference code or description of the specific Grand Bargain commitment (e.g., Workstream 2 — Localization) that this capacity building plan contributes to. Supports donor accountability and IATI transparency reporting.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationRegion rdf:type rdf:Property ;
    rdfs:label 'Implementation Region' ;
    rdfs:comment 'Sub-national region, state, or province where the partner organization and this capacity building plan are primarily based. Supports geographic disaggregation in MEL dashboards and GIS (Geographic Information System) reporting.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date of the most recent formal review or progress assessment of this capacity building plan, during which activity completion, capacity scores, and budget utilization were evaluated.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localizationStrategyAligned rdf:type rdf:Property ;
    rdfs:label 'Localization Strategy Aligned' ;
    rdfs:comment 'Indicates whether this capacity building plan is formally aligned with Ngo\'s localization strategy and Grand Bargain commitments to strengthen local and national actors. True = aligned and documented; False = not formally aligned.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallObjective rdf:type rdf:Property ;
    rdfs:label 'Overall Objective' ;
    rdfs:comment 'High-level statement of the primary objective of this capacity building plan, describing the intended organizational capability improvement to be achieved by the plan\'s end date.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallProgressStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Progress Status' ;
    rdfs:comment 'Qualitative assessment of the overall implementation progress of the capacity building plan relative to the planned timeline and milestones. Distinct from plan_status (lifecycle state); this reflects delivery performance.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerFocalPointName rdf:type rdf:Property ;
    rdfs:label 'Partner Focal Point Name' ;
    rdfs:comment 'Full name of the designated focal point or primary contact person at the partner organization who is responsible for coordinating and participating in capacity building activities under this plan.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerFocalPointTitle rdf:type rdf:Property ;
    rdfs:label 'Partner Focal Point Title' ;
    rdfs:comment 'Job title or role of the partner organization\'s designated focal point for this capacity building plan (e.g., \'Executive Director\', \'Finance Manager\', \'MEL Officer\').' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Plan Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this capacity building plan, used in donor reports, partner correspondence, and IATI disclosures. Format: CBP-[PartnerCode]-[Year]-[Sequence].' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the capacity building plan. \'draft\' = under development; \'active\' = approved and in implementation; \'on_hold\' = temporarily suspended; \'completed\' = all activities delivered and closed; \'cancelled\' = plan discontinued.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planTitle rdf:type rdf:Property ;
    rdfs:label 'Plan Title' ;
    rdfs:comment 'Human-readable title of the capacity building plan, typically referencing the partner organization name and the primary functional area targeted (e.g., \'Financial Management Strengthening Plan — Partner XYZ 2024\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the primary focus area of the capacity building plan. \'organizational\' = overall organizational development; \'technical\' = sector-specific technical skills; \'financial\' = financial management and accountability; \'governance\' = board and leadership strengthening; \'mel\' = Monitoring, Evaluation, and Learning (MEL) systems. [ENUM-REF-CANDIDATE: organizational|technical|financial|governance|mel|procurement|hr|communications|safeguarding — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeguardingComponentIncluded rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Component Included' ;
    rdfs:comment 'Indicates whether this capacity building plan includes a dedicated safeguarding (Protection from Sexual Exploitation and Abuse — PSEA) component. Required for compliance with donor safeguarding policies and CHS commitments.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCapacityScore rdf:type rdf:Property ;
    rdfs:label 'Target Capacity Score' ;
    rdfs:comment 'Numeric score representing the desired organizational capacity level to be achieved by the partner organization upon successful completion of this plan. Used to measure progress and plan effectiveness.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetedFunctionalAreas rdf:type rdf:Property ;
    rdfs:label 'Targeted Functional Areas' ;
    rdfs:comment 'Comma-separated list of organizational functional areas targeted by this plan for strengthening, as identified in the capacity assessment. Common values include: financial management, human resources, procurement, governance, MEL (Monitoring Evaluation and Learning), safeguarding, communications, ICT4D (Information and Communication Technology for Development).' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoryOfChangeSummary rdf:type rdf:Property ;
    rdfs:label 'Theory Of Change Summary' ;
    rdfs:comment 'Narrative summary of the Theory of Change (ToC) underpinning this capacity building plan, describing the causal pathway from planned interventions to expected organizational capability improvements and ultimate program outcomes.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalActivitiesCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Activities Completed' ;
    rdfs:comment 'Count of capacity building activity line-items that have been fully delivered and marked as completed under this plan. Used to calculate overall plan completion rate for MEL dashboards and donor reporting.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalActivitiesPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Activities Planned' ;
    rdfs:comment 'Total number of capacity building activity line-items (trainings, mentoring sessions, technical assistance visits, peer learning events) planned under this plan. Used for progress tracking and workload planning.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Total Budget Usd' ;
    rdfs:comment 'Total approved budget allocated for the implementation of this capacity building plan, expressed in US Dollars (USD). Covers all activity costs including training, technical assistance, materials, and facilitator fees.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrantId rdf:type rdf:Property ;
    rdfs:label 'Registrant Id' ;
    rdfs:comment 'Unique surrogate identifier for each registrant record in the beneficiary domain. Serves as the primary key and identity anchor for all beneficiary-domain transactions across CommCare, KoboToolbox, and interoperability mappings to UNHCR proGres v4, WFP SCOPE, and RAIS.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registrant .

ind:deduplicationMasterRegistrantId rdf:type rdf:Property ;
    rdfs:label 'Deduplication Master Registrant Id' ;
    rdfs:comment 'The beneficiary_id of the authoritative master record when this registrant has been identified as a duplicate. Null for unique records. Enables lineage tracing from duplicate to canonical record for audit and reporting.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registrant .

ind:householdId rdf:type rdf:Property ;
    rdfs:label 'Household Id' ;
    rdfs:comment 'Identifier linking this registrant to their household unit. Enables household-level aggregation for NFI distribution, WASH targeting, and food security assessments. Household head registrant carries the authoritative household record.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:warehouseId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Id' ;
    rdfs:comment 'Foreign key linking to supply.warehouse. Business justification: Individual beneficiaries collect assistance from assigned warehouses/distribution points. Critical for voucher programs, individual assistance, and beneficiary notification systems. Enables proximity-' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:ageYears rdf:type rdf:Property ;
    rdfs:label 'Age Years' ;
    rdfs:comment 'Registrant\'s age in whole years at the time of registration. Stored explicitly to support age-band analytics and program eligibility checks when date_of_birth is estimated or unavailable. Derived from date_of_birth where known; otherwise entered directly.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completenessScore rdf:type rdf:Property ;
    rdfs:label 'Completeness Score' ;
    rdfs:comment 'Percentage score (0–100) reflecting the completeness of the registrant\'s registration profile based on mandatory and recommended fields populated. Used for data quality monitoring, field staff performance tracking, and MEL data quality assessments.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentGiven rdf:type rdf:Property ;
    rdfs:label 'Consent Given' ;
    rdfs:comment 'Indicates whether the registrant (or legal guardian for minors) has provided informed consent for data collection, storage, and use per organizational data protection policy and applicable regulations. Mandatory for all registrations per CHS Commitment 4.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfOriginCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 code for the registrant\'s country of origin. Distinct from nationality for stateless persons and IDPs. Used for displacement tracking, protection analysis, and OCHA SitRep reporting.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deduplicationStatus rdf:type rdf:Property ;
    rdfs:label 'Deduplication Status' ;
    rdfs:comment 'Current status of the deduplication check for this registrant record. \'Duplicate\' records are suppressed from active program counts. \'Merged\' indicates the record was consolidated with a master record. Supports USAID and DFID double-counting prevention requirements.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disabilityType rdf:type rdf:Property ;
    rdfs:label 'Disability Type' ;
    rdfs:comment 'Classification of the registrant\'s disability type per Washington Group Short Set categories. Used for targeted accommodation planning, assistive device provision, and inclusive program design. Only populated when has_disability is True. [ENUM-REF-CANDIDATE: mobility|vision|hearing|cognitive|psychosocial|multiple|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'The registrant\'s family name or surname as recorded at registration. Combined with given_name for full identity display and deduplication matching.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:givenName rdf:type rdf:Property ;
    rdfs:label 'Given Name' ;
    rdfs:comment 'The registrant\'s given name (first name) as recorded at registration. Used for identity verification, case management, and beneficiary communication.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasDisability rdf:type rdf:Property ;
    rdfs:label 'Has Disability' ;
    rdfs:comment 'Indicates whether the registrant has a reported disability. Used for inclusive programming, accessibility accommodations, and Washington Group Short Set disaggregation in MEL reporting per IASC disability inclusion guidelines.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGbvSurvivor rdf:type rdf:Property ;
    rdfs:label 'Is Gbv Survivor' ;
    rdfs:comment 'Indicates whether the registrant has been identified as a Gender-Based Violence (GBV) survivor. Triggers GBV case management referral, PSS services, and safe space access. Stored with highest data protection classification per GBV information management principles.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPregnantOrLactating rdf:type rdf:Property ;
    rdfs:label 'Is Pregnant Or Lactating' ;
    rdfs:comment 'Indicates whether the registrant is a pregnant or lactating woman (PLW). Triggers priority access to nutrition programs (SAM/GAM treatment, supplementary feeding), antenatal care referrals, and PLW-specific NFI kits.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnaccompaniedMinor rdf:type rdf:Property ;
    rdfs:label 'Is Unaccompanied Minor' ;
    rdfs:comment 'Indicates whether the registrant is an unaccompanied or separated child (UASC). Triggers child protection protocols, best-interest assessments, and mandatory referral to child protection case management per UNHCR/UNICEF UASC guidelines.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Verification Date' ;
    rdfs:comment 'Date of the most recent identity or liveness verification for this registrant. Used to flag records requiring re-verification per program cycle requirements and to support active beneficiary count accuracy for donor reporting.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:muacCm rdf:type rdf:Property ;
    rdfs:label 'Muac Cm' ;
    rdfs:comment 'Mid-Upper Arm Circumference (MUAC) measurement in centimetres recorded at registration or nutrition screening. Used to classify acute malnutrition status (SAM: <11.5cm, MAM: 11.5–12.5cm) per Sphere/WHO nutrition protocols. Applicable for children 6–59 months and PLW.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nationalityCode rdf:type rdf:Property ;
    rdfs:label 'Nationality Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the registrant\'s nationality. Used for protection status determination, IDP/refugee classification, and donor reporting disaggregation.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pocCategory rdf:type rdf:Property ;
    rdfs:label 'Poc Category' ;
    rdfs:comment 'UNHCR-aligned classification of the registrant\'s protection status as a Person of Concern (PoC). Drives protection programming, legal aid eligibility, and UNHCR/OCHA statistical reporting. [ENUM-REF-CANDIDATE: refugee|idp|returnee|stateless|asylum_seeker|host_community|other — promote to reference product]' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Language Code' ;
    rdfs:comment 'ISO 639 language code for the registrant\'s preferred communication language. Used to assign appropriate interpreters, translated materials, and language-appropriate PSS services. Supports CHS Commitment 4 on accessible communication.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionFlag rdf:type rdf:Property ;
    rdfs:label 'Protection Flag' ;
    rdfs:comment 'Master protection concern flag indicating the registrant has one or more active protection risks (GBV, UASC, trafficking, detention risk, etc.). Triggers protection case management workflow and restricts data sharing per CHS data protection principles.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reRegistrationCount rdf:type rdf:Property ;
    rdfs:label 'Re Registration Count' ;
    rdfs:comment 'Number of times this registrant has been re-registered in the system (e.g., after displacement, camp relocation, or annual verification cycles). Supports re-registration tracking and historical registration event analysis.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'The date on which the registrant was first formally registered into the beneficiary system. Used as the baseline date for program enrollment timelines, cohort analysis, and compliance reporting to donors (USAID BHA, DFID).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationModality rdf:type rdf:Property ;
    rdfs:label 'Registration Modality' ;
    rdfs:comment 'The channel or method through which the registrant was enrolled. Distinguishes in-person field registration, mobile data collection (KoboToolbox/CommCare), remote registration (phone/online), and self-registration kiosks. Informs data quality scoring and verification requirements.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Registration Source System' ;
    rdfs:comment 'The operational system of record from which this registrant record originated. Supports data lineage, deduplication across systems, and interoperability mapping to UNHCR proGres v4, WFP SCOPE, and RAIS.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the registrant record. Controls eligibility for program services, NFI distributions, and case management workflows. \'Duplicate\' status is set by the deduplication process; \'departed\' indicates the individual has left the program area.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationTool rdf:type rdf:Property ;
    rdfs:label 'Registration Tool' ;
    rdfs:comment 'The specific data collection tool or form used to capture the registration. Distinguishes KoboToolbox survey forms, CommCare mobile case forms, paper-based forms, and direct system entry. Informs data quality and field validation rules.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationType rdf:type rdf:Property ;
    rdfs:label 'Registration Type' ;
    rdfs:comment 'Classifies the registrant as an individual, household head, household member, or community-level registration. Determines the unit of analysis for program targeting, NFI distribution, and beneficiary counting methodologies.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sex rdf:type rdf:Property ;
    rdfs:label 'Sex' ;
    rdfs:comment 'Biological sex of the registrant as recorded at registration. Used for DAC-compliant gender disaggregation in MEL reporting, GBV protection screening, and SPHERE-aligned needs assessments.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The native record identifier from the originating source system (e.g., CommCare case_id, KoboToolbox submission UUID, proGres v4 individual_id). Enables bidirectional traceability and re-synchronization with operational systems.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Verification Document Number' ;
    rdfs:comment 'The document number from the identity verification document presented at registration (e.g., national ID number, passport number, UNHCR card number). Stored encrypted; used for deduplication and re-registration identity matching.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDocumentType rdf:type rdf:Property ;
    rdfs:label 'Verification Document Type' ;
    rdfs:comment 'Type of identity verification document presented at registration. Used for identity assurance scoring, fraud prevention, and compliance with donor KYB (Know Your Beneficiary) requirements. \'Community attestation\' applies where formal documents are unavailable.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerabilityCategory rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Category' ;
    rdfs:comment 'Categorical classification of the registrant\'s vulnerability level derived from the vulnerability_score. Drives program targeting decisions, priority service access, and donor reporting on most-vulnerable population coverage.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerabilityScore rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Score' ;
    rdfs:comment 'Composite vulnerability index score calculated from the needs assessment, capturing food insecurity, protection risks, health status, and displacement severity. Used for program prioritization, targeting, and MEL outcome tracking. Score range and methodology defined per program LogFrame.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communityId rdf:type rdf:Property ;
    rdfs:label 'Community Id' ;
    rdfs:comment 'Reference to the community or settlement record where the household is located. Supports geographic aggregation for WASH assessments, food security cluster reporting, and GIS-based programme planning via Humanitarian OpenStreetMap.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Community .

ind:enumeratorVolunteerId rdf:type rdf:Property ;
    rdfs:label 'Enumerator Volunteer Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer. Business justification: Household registration: volunteers conduct household registrations in the field. Tracking the enumerating volunteer per household is standard for data quality audits, supervision accountability, and r' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:admin1Name rdf:type rdf:Property ;
    rdfs:label 'Admin1 Name' ;
    rdfs:comment 'Name of the first-level administrative division (region, province, or state) where the household is located. Aligns with OCHA Common Operational Datasets (CODs) administrative boundary layer 1 for GIS mapping and cluster reporting.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admin2Name rdf:type rdf:Property ;
    rdfs:label 'Admin2 Name' ;
    rdfs:comment 'Name of the second-level administrative division (district, county, or department) where the household is located. Used for sub-national programme targeting, cluster coordination, and DHIS2 geographic disaggregation.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childrenUnder5Count rdf:type rdf:Property ;
    rdfs:label 'Children Under5 Count' ;
    rdfs:comment 'Number of children aged 0–4 years in the household. Critical for nutrition programme targeting (Global Acute Malnutrition / Severe Acute Malnutrition screening), UNICEF child protection reporting, and SPHERE minimum standards for child-specific NFI distributions.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commcareCaseReference rdf:type rdf:Property ;
    rdfs:label 'Commcare Case Reference' ;
    rdfs:comment 'Unique case identifier from CommCare mobile case management system for this household. Enables bidirectional synchronisation between the lakehouse silver layer and CommCare for community health worker follow-up, beneficiary tracking, and case status updates.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentObtained rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained' ;
    rdfs:comment 'Indicates whether informed consent for data collection and processing was obtained from the head of household at the time of registration. Mandatory for GDPR compliance, CHS Commitment 4 accountability, and HAP Standard data protection requirements.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the household\'s country of origin or habitual residence prior to displacement. Required for UNHCR refugee population statistics, OCHA Humanitarian Response Plan disaggregation, and IATI geographic coding.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCountry rdf:type rdf:Property ;
    rdfs:label 'Current Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the household is currently residing. Used for cross-border programme coordination, OCHA SitRep geographic disaggregation, and IATI location reporting.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deregistrationDate rdf:type rdf:Property ;
    rdfs:label 'Deregistration Date' ;
    rdfs:comment 'Calendar date on which the household exited or was closed from the programme. Nullable for active households. Used to calculate programme duration, exit analysis, and MEL outcome tracking. Corresponds to the effective-until date of the household registration agreement.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:displacementDate rdf:type rdf:Property ;
    rdfs:label 'Displacement Date' ;
    rdfs:comment 'Date on which the household was displaced from their place of habitual residence. Used for durable solutions planning, return and reintegration programming, and UNHCR proGres displacement history tracking.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:displacementStatus rdf:type rdf:Property ;
    rdfs:label 'Displacement Status' ;
    rdfs:comment 'Classification of the household\'s displacement situation. Internally Displaced Person (IDP), refugee, returnee, host community, stateless, or asylum seeker. Determines eligibility for specific UNHCR, OCHA, and WFP programme streams and drives proGres v4 population group assignment. [ENUM-REF-CANDIDATE: idp|refugee|returnee|host_community|stateless|asylum_seeker — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elderlyCount rdf:type rdf:Property ;
    rdfs:label 'Elderly Count' ;
    rdfs:comment 'Number of household members aged 60 years or older. Used for vulnerability scoring, priority targeting in food security and health programmes, and age-disaggregated donor reporting per OCHA and IASC standards.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exitReason rdf:type rdf:Property ;
    rdfs:label 'Exit Reason' ;
    rdfs:comment 'Reason for the household\'s exit or closure from the programme. Used for MEL outcome analysis, durable solutions tracking, and donor reporting on programme completion rates. Nullable for active households. [ENUM-REF-CANDIDATE: graduated|relocated|deceased|voluntary_withdrawal|ineligible|duplicate|lost_to_followup — promote to reference product]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:femaleCount rdf:type rdf:Property ;
    rdfs:label 'Female Count' ;
    rdfs:comment 'Number of female individuals in the household. Required for sex-disaggregated reporting to OCHA, USAID, and DFID donors. Supports gender analysis in MEL frameworks and IASC gender marker compliance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:foodSecurityStatus rdf:type rdf:Property ;
    rdfs:label 'Food Security Status' ;
    rdfs:comment 'Household-level food security classification based on the Integrated Food Security Phase Classification (IPC) or Household Food Insecurity Access Scale (HFIAS). Drives WFP food assistance targeting, cash transfer programme eligibility, and OCHA food security cluster reporting.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gbvRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Gbv Risk Flag' ;
    rdfs:comment 'Indicates whether the household has been identified as at elevated risk of or affected by Gender-Based Violence (GBV). Classified restricted due to sensitivity. Triggers referral to GBV case management, PSS (Psychosocial Support) services, and safe space programming. Access strictly controlled per GBV information management protocols.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the household\'s physical location in decimal degrees (WGS84). Captured via KoboToolbox GPS widget during field registration. Used for GIS mapping, proximity analysis, and Humanitarian OpenStreetMap integration. Classified confidential as precise location of vulnerable individuals.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the household\'s physical location in decimal degrees (WGS84). Captured via KoboToolbox GPS widget during field registration. Used for GIS mapping, proximity analysis, and Humanitarian OpenStreetMap integration. Classified confidential as precise location of vulnerable individuals.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hasPregnantLactating rdf:type rdf:Property ;
    rdfs:label 'Has Pregnant Lactating' ;
    rdfs:comment 'Indicates whether the household includes at least one pregnant or lactating woman (PLW). Critical flag for nutrition programme targeting (supplementary feeding, micronutrient supplementation), SPHERE nutrition standards compliance, and UNICEF/WFP PLW-specific assistance eligibility.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasUnaccompaniedMinor rdf:type rdf:Property ;
    rdfs:label 'Has Unaccompanied Minor' ;
    rdfs:comment 'Indicates whether the household includes an unaccompanied or separated child (UASC). Triggers child protection case management protocols in CommCare, UNHCR UASC registration procedures, and UNICEF child protection programme referrals.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFemaleHeaded rdf:type rdf:Property ;
    rdfs:label 'Is Female Headed' ;
    rdfs:comment 'Indicates whether the household is headed by a woman. Key targeting criterion for GBV (Gender-Based Violence) prevention programmes, women\'s economic empowerment initiatives, and IASC gender marker reporting. Required for USAID gender equality disaggregation.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'Date of the most recent household-level needs assessment or vulnerability re-assessment conducted. Used to identify households overdue for reassessment, track MEL data currency, and ensure programme targeting reflects current conditions per MEAL cycle requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maleCount rdf:type rdf:Property ;
    rdfs:label 'Male Count' ;
    rdfs:comment 'Number of male individuals in the household. Required for sex-disaggregated reporting to OCHA, USAID, and DFID donors. Supports gender analysis in MEL frameworks and IASC gender marker compliance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pwdCount rdf:type rdf:Property ;
    rdfs:label 'Pwd Count' ;
    rdfs:comment 'Number of household members with a physical, sensory, intellectual, or psychosocial disability. Required for IASC disability inclusion reporting, Washington Group Short Set disaggregation, and inclusive programming compliance under the CRPD.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the household at point of registration. Used across field operations, NFI distribution lists, WASH assessments, and food security programming as the primary cross-system reference. Corresponds to the SCOPE household token or proGres case number.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanitationFacilityType rdf:type rdf:Property ;
    rdfs:label 'Sanitation Facility Type' ;
    rdfs:comment 'Classification of the household\'s primary sanitation facility. Core WASH indicator for SPHERE minimum standards, OCHA WASH cluster reporting, and WHO/UNICEF Joint Monitoring Programme (JMP) SDG 6 tracking. [ENUM-REF-CANDIDATE: flush_toilet|pit_latrine|ventilated_pit|open_defecation|communal_latrine|none — promote to reference product]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelterOwnership rdf:type rdf:Property ;
    rdfs:label 'Shelter Ownership' ;
    rdfs:comment 'Tenure status of the household\'s current shelter. Distinguishes owned, rented, informal/squatter, organisation-provided, or communal arrangements. Used for durable solutions planning, land rights programming, and UNHCR shelter vulnerability assessments.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelterType rdf:type rdf:Property ;
    rdfs:label 'Shelter Type' ;
    rdfs:comment 'Classification of the household\'s current shelter situation. Used for SPHERE shelter standard compliance assessments, NFI kit targeting (shelter kits vs. core relief items), and OCHA shelter cluster reporting. [ENUM-REF-CANDIDATE: permanent|semi-permanent|temporary|makeshift|collective_centre|host_family|none — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Total count of individuals residing in the household at the time of last registration or update. Used for NFI distribution quantity calculations, food ration sizing, WASH facility planning, and WFP SCOPE entitlement computation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waterSourceType rdf:type rdf:Property ;
    rdfs:label 'Water Source Type' ;
    rdfs:comment 'Classification of the household\'s primary drinking water source. Core WASH (Water, Sanitation and Hygiene) indicator required for SPHERE minimum standards compliance, OCHA WASH cluster reporting, and DHIS2 WASH indicator tracking. [ENUM-REF-CANDIDATE: piped|borehole|protected_spring|unprotected_spring|surface_water|trucked|rainwater — promote to reference product]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdMemberId rdf:type rdf:Property ;
    rdfs:label 'Household Member Id' ;
    rdfs:comment 'Unique surrogate identifier for each household member association record in the beneficiary domain. Primary key for this entity.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseRecordId rdf:type rdf:Property ;
    rdfs:label 'Case Record Id' ;
    rdfs:comment 'Reference to the CommCare or Microsoft Dynamics 365 case management record associated with this household member. Used for case follow-up, service delivery tracking, and MEL (Monitoring Evaluation and Learning) outcome measurement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CaseRecord .

ind:ageEstimated rdf:type rdf:Property ;
    rdfs:label 'Age Estimated' ;
    rdfs:comment 'Indicates whether the recorded age or date of birth is an estimate rather than a verified value. Common in humanitarian field contexts where documentation is unavailable. Affects data quality scoring for MEL reporting.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentWithdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawal Date' ;
    rdfs:comment 'Date on which this household member or their guardian withdrew consent for data processing. Triggers data anonymisation or deletion workflows per GDPR Article 17 right to erasure.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Method used to collect this household member\'s registration data. FGD (Focus Group Discussion), KII (Key Informant Interview), KoboToolbox survey, or CommCare mobile form. Used for data quality assessment and MEL methodology documentation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Disability Status' ;
    rdfs:comment 'Recorded disability classification for the household member using the Washington Group Short Set framework. Used for inclusive programming, NFI adaptation, and SPHERE accessibility compliance reporting. [ENUM-REF-CANDIDATE: none|physical|sensory|cognitive|psychosocial|multiple|prefer_not_to_say — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationLevel rdf:type rdf:Property ;
    rdfs:label 'Education Level' ;
    rdfs:comment 'Highest level of education attained by this household member. Used for livelihood program targeting, literacy-based service adaptation, and SDG (Sustainable Development Goal) 4 education indicator reporting. [ENUM-REF-CANDIDATE: none|primary_incomplete|primary_complete|secondary_incomplete|secondary_complete|tertiary|vocational|other — promote to reference product]' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderIdentity rdf:type rdf:Property ;
    rdfs:label 'Gender Identity' ;
    rdfs:comment 'Self-identified gender of the household member, captured where programmatically relevant (e.g., GBV programs, PSS (Psychosocial Support) services). Distinct from biological sex. Collected only with informed consent per data protection standards.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHeadOfHousehold rdf:type rdf:Property ;
    rdfs:label 'Is Head Of Household' ;
    rdfs:comment 'Indicates whether this member is the designated head of household. Only one member per household should have this flag set to true. Used for primary contact identification, distribution authorization, and household-level reporting.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:livelihoodStatus rdf:type rdf:Property ;
    rdfs:label 'Livelihood Status' ;
    rdfs:comment 'Current livelihood or employment status of the household member. Used for economic vulnerability assessment, cash transfer program eligibility, and livelihoods program targeting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberCode rdf:type rdf:Property ;
    rdfs:label 'Member Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this household member association, used in field operations, PDM (Post-Distribution Monitoring) forms, and inter-agency data sharing.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberRole rdf:type rdf:Property ;
    rdfs:label 'Member Role' ;
    rdfs:comment 'Functional role of this individual within the household structure, used for program targeting, NFI kit sizing, and household vulnerability profiling. Distinct from relationship_to_head which captures kinship; this captures programmatic classification.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipEndDate rdf:type rdf:Property ;
    rdfs:label 'Membership End Date' ;
    rdfs:comment 'Date on which this individual\'s membership in the household ended, due to departure, transfer, death, or administrative closure. Null if membership is currently active.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipEndReason rdf:type rdf:Property ;
    rdfs:label 'Membership End Reason' ;
    rdfs:comment 'Reason code explaining why this individual\'s household membership ended. Required for attrition analysis, household composition tracking, and MEL (Monitoring Evaluation and Learning) reporting.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStartDate rdf:type rdf:Property ;
    rdfs:label 'Membership Start Date' ;
    rdfs:comment 'Date on which this individual formally joined or was registered as a member of the household. Used to determine eligibility windows for program benefits and historical household composition analysis.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of this individual\'s membership in the household. Drives eligibility for household-level distributions and services. \'transferred\' indicates movement to another household; \'departed\' indicates voluntary exit.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:muacAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Muac Assessment Date' ;
    rdfs:comment 'Date on which the MUAC (Mid-Upper Arm Circumference) measurement was recorded for this household member. Used to determine recency of nutritional screening and trigger follow-up assessments per SPHERE protocols.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pregnantOrLactating rdf:type rdf:Property ;
    rdfs:label 'Pregnant Or Lactating' ;
    rdfs:comment 'Indicates whether this household member is currently pregnant or lactating. Used for nutrition program targeting (e.g., SAM/GAM treatment), supplementary feeding eligibility, and SPHERE maternal health standards compliance.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Primary Language Code' ;
    rdfs:comment 'ISO 639-1/639-2 language code for the primary language spoken by this household member. Used for communication planning, interpreter assignment, and ensuring informed consent is obtained in the member\'s language per CHS (Core Humanitarian Standard).' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionConcernFlag rdf:type rdf:Property ;
    rdfs:label 'Protection Concern Flag' ;
    rdfs:comment 'Indicates whether this household member has an active protection concern (e.g., GBV risk, child protection issue, trafficking risk). Triggers case escalation in CommCare and referral to protection cluster. Stored as restricted due to sensitivity.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Registration Location Code' ;
    rdfs:comment 'Code identifying the geographic location (camp, settlement, community, or administrative unit) where this household member was registered. Used for geographic disaggregation in MEL reporting and GIS (Geographic Information System) mapping.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipToHead rdf:type rdf:Property ;
    rdfs:label 'Relationship To Head' ;
    rdfs:comment 'Describes the kinship or social relationship of this member to the designated head of household. Used for dependency ratio calculations, vulnerability scoring, and NFI distribution entitlement. [ENUM-REF-CANDIDATE: head|spouse|child|parent|sibling|dependent|other_relative|non_relative — promote to reference product]' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schoolEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'School Enrollment Status' ;
    rdfs:comment 'Current school enrollment status for household members of school age. Used for education program targeting, out-of-school children identification, and SDG 4 indicator tracking in DHIS2.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unaccompaniedMinor rdf:type rdf:Property ;
    rdfs:label 'Unaccompanied Minor' ;
    rdfs:comment 'Indicates whether this household member is an unaccompanied or separated child (UASC). Triggers child protection protocols, case management escalation in CommCare, and mandatory reporting to child protection clusters.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vulnerabilityProfileId rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Profile Id' ;
    rdfs:comment 'Unique system-generated identifier for the vulnerability profile record. Primary key for this entity.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VulnerabilityProfile .

ind:assessingVolunteerId rdf:type rdf:Property ;
    rdfs:label 'Assessing Volunteer Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer. Business justification: Vulnerability assessment quality assurance: trained volunteers (community health volunteers, enumerators) conduct vulnerability assessments. Tracking the assessing volunteer per profile is required fo' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:previousProfileVulnerabilityProfileId rdf:type rdf:Property ;
    rdfs:label 'Previous Profile Vulnerability Profile Id' ;
    rdfs:comment 'Reference to the immediately preceding vulnerability profile record for this registrant, enabling longitudinal tracking of vulnerability changes over time. Populated when profile_status is \'superseded\' or when a new profile replaces an existing one.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VulnerabilityProfile .

ind:reportingPeriodId rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Id' ;
    rdfs:comment 'Foreign key linking to mel.reporting_period. Business justification: Periodic vulnerability reassessment tracking: Vulnerability profiles are reassessed at MEL-defined intervals (baseline, midline, endline). Linking to reporting_period enables MEL teams to identify whi' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingPeriod .

ind:chronicIllnessFlag rdf:type rdf:Property ;
    rdfs:label 'Chronic Illness Flag' ;
    rdfs:comment 'Indicates whether the beneficiary has one or more documented chronic illnesses (e.g., HIV/AIDS, tuberculosis, diabetes, hypertension) that increase vulnerability and require sustained health service access. Drives health program targeting and DHIS2 health indicator reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chronicIllnessType rdf:type rdf:Property ;
    rdfs:label 'Chronic Illness Type' ;
    rdfs:comment 'Coded description of the primary chronic illness condition affecting the beneficiary (e.g., HIV_AIDS, tuberculosis, diabetes, hypertension, malnutrition_chronic). Populated only when chronic_illness_flag is True. Aligned with ICD-11 coding where applicable.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositeVulnerabilityScore rdf:type rdf:Property ;
    rdfs:label 'Composite Vulnerability Score' ;
    rdfs:comment 'Aggregated multi-dimensional vulnerability score derived from weighted combination of food insecurity (IPC phase), protection risk, disability, nutritional status, displacement category, and other assessed indicators. Used for program targeting, beneficiary prioritization, and Results-Based Management (RBM) reporting. Score range typically 0.00–100.00.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Flag' ;
    rdfs:comment 'Indicates whether informed consent was obtained from the beneficiary or their legal guardian prior to data collection and vulnerability profiling. Mandatory for compliance with data protection regulations and CHS accountability standards.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Flag' ;
    rdfs:comment 'Indicates whether the beneficiary has consented to their vulnerability data being shared with partner organizations and inter-agency coordination bodies (e.g., UNHCR, OCHA clusters). Governs data sharing under inter-agency data sharing agreements.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disabilityClassification rdf:type rdf:Property ;
    rdfs:label 'Disability Classification' ;
    rdfs:comment 'Functional difficulty domain identified using the Washington Group Short Set on Functioning (WG-SS) questions. Captures the primary domain of disability: seeing, hearing, mobility, cognition, self-care, or communication. Used for inclusive programming and disability-disaggregated reporting per CRPD. [ENUM-REF-CANDIDATE: none|seeing|hearing|mobility|cognition|self_care|communication|multiple — promote to reference product]' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disabilitySeverity rdf:type rdf:Property ;
    rdfs:label 'Disability Severity' ;
    rdfs:comment 'Severity of functional difficulty as measured by the Washington Group Short Set (WG-SS) response scale: no difficulty, some difficulty, a lot of difficulty, or cannot do at all. Used alongside disability_classification for disaggregated disability reporting.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displacementCategory rdf:type rdf:Property ;
    rdfs:label 'Displacement Category' ;
    rdfs:comment 'Classification of the beneficiary\'s displacement status per UNHCR definitions. Internally Displaced Person (IDP) refers to those displaced within their country; refugee refers to those who have crossed international borders; returnee refers to those who have returned to their place of origin. Drives program eligibility and UNHCR/OCHA reporting.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elderlyMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Elderly Member Flag' ;
    rdfs:comment 'Indicates whether the household includes one or more elderly members (typically aged 60+). Elderly individuals are a recognized vulnerable group requiring targeted assistance per SPHERE and IASC age and disability inclusion guidelines.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:femaleHeadedHouseholdFlag rdf:type rdf:Property ;
    rdfs:label 'Female Headed Household Flag' ;
    rdfs:comment 'Indicates whether the household is headed by a woman. Female-headed households are recognized as a priority vulnerability category in humanitarian programming due to heightened protection risks and reduced access to resources. Used for gender-disaggregated reporting.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gbvExposureFlag rdf:type rdf:Property ;
    rdfs:label 'Gbv Exposure Flag' ;
    rdfs:comment 'Indicates whether the beneficiary has been identified as a survivor or at-risk individual for Gender-Based Violence (GBV). Triggers referral to GBV case management services and specialized support programs. Handled with strict confidentiality per GBV information management protocols.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicAreaCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Area Code' ;
    rdfs:comment 'Standardized code identifying the geographic area (admin level 2 or 3) where the beneficiary is located at the time of assessment. Used for geographic targeting, GIS mapping, and OCHA cluster reporting. Aligned with OCHA Common Operational Datasets (COD) administrative boundary codes.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipcPhase rdf:type rdf:Property ;
    rdfs:label 'Ipc Phase' ;
    rdfs:comment 'Food insecurity severity classification using the Integrated Food Security Phase Classification (IPC) scale: 1=Minimal, 2=Stressed, 3=Crisis, 4=Emergency, 5=Famine/Catastrophe. Used for food assistance targeting and donor reporting to BHA/USAID.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:muacMm rdf:type rdf:Property ;
    rdfs:label 'Muac Mm' ;
    rdfs:comment 'Mid-Upper Arm Circumference (MUAC) measurement in millimetres, used as the primary anthropometric indicator for acute malnutrition screening in children under 5 and pregnant/lactating women. Thresholds: <115mm = SAM, 115–124mm = MAM, ≥125mm = normal. Collected via KoboToolbox or CommCare field surveys.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReassessmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Reassessment Date' ;
    rdfs:comment 'Scheduled date for the next vulnerability reassessment to ensure the profile reflects the beneficiary\'s current vulnerability state. Drives field operations scheduling and MEL monitoring cycles. Typically set based on program-specific reassessment frequency protocols.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nutritionalStatus rdf:type rdf:Property ;
    rdfs:label 'Nutritional Status' ;
    rdfs:comment 'Nutritional status classification based on anthropometric screening. Severe Acute Malnutrition (SAM) indicates MUAC < 115mm or WHZ < -3; Moderate Acute Malnutrition (MAM) indicates MUAC 115–124mm or WHZ -2 to -3; normal indicates adequate nutritional status. Used for therapeutic feeding program targeting and Global Acute Malnutrition (GAM) rate reporting.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pregnantLactatingFlag rdf:type rdf:Property ;
    rdfs:label 'Pregnant Lactating Flag' ;
    rdfs:comment 'Indicates whether the household includes a pregnant or lactating woman (PLW). PLWs are a priority group for nutrition programming (supplementary feeding), antenatal care, and maternal health services. Used for CMAM and nutrition program targeting.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profileCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Created Timestamp' ;
    rdfs:comment 'Timestamp when this vulnerability profile record was first created in the system. Used for audit trail and data lineage tracking.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profileSource rdf:type rdf:Property ;
    rdfs:label 'Profile Source' ;
    rdfs:comment 'Indicates the operational process or event that triggered the creation or update of this vulnerability profile. \'post_distribution_monitoring\' refers to Post-Distribution Monitoring (PDM) assessments; \'emergency_screening\' refers to rapid assessments during acute crises. Used for MEL data quality analysis.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Updated Timestamp' ;
    rdfs:comment 'Timestamp when this vulnerability profile was last modified, reflecting the most recent update to any vulnerability indicator. Triggers downstream re-targeting and prioritization workflows.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:protectionRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Protection Risk Level' ;
    rdfs:comment 'Assessed level of protection risk for the individual or household, encompassing threats of violence, exploitation, abuse, and discrimination. Classified by a trained protection officer. Drives case prioritization and referral pathways per UNHCR Protection Framework.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pssNeedFlag rdf:type rdf:Property ;
    rdfs:label 'Pss Need Flag' ;
    rdfs:comment 'Indicates whether the beneficiary has been assessed as requiring Psychosocial Support (PSS) services, including mental health support, trauma counselling, or community-based psychosocial activities. Triggers referral to PSS programming.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelterAdequacy rdf:type rdf:Property ;
    rdfs:label 'Shelter Adequacy' ;
    rdfs:comment 'Assessment of the beneficiary\'s shelter situation against SPHERE minimum standards. \'none\' indicates no shelter; \'inadequate\' indicates shelter below minimum standards; \'transitional\' indicates temporary/emergency shelter; \'adequate\' indicates shelter meeting minimum standards. Drives NFI and shelter program targeting.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unaccompaniedMinorFlag rdf:type rdf:Property ;
    rdfs:label 'Unaccompanied Minor Flag' ;
    rdfs:comment 'Indicates whether the beneficiary is an unaccompanied or separated child (UASC) — a child under 18 separated from both parents and other relatives and not being cared for by a responsible adult. Triggers child protection case management and family tracing and reunification (FTR) services.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vulnerabilityTier rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Tier' ;
    rdfs:comment 'Categorical tier derived from the composite vulnerability score, used for operational targeting and prioritization decisions. \'critical\' indicates immediate life-saving intervention required; \'high\' indicates priority program enrollment; \'medium\' and \'low\' indicate standard program eligibility. Distinct from composite_vulnerability_score which is the numeric value.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:washAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Wash Access Flag' ;
    rdfs:comment 'Indicates whether the beneficiary household has adequate access to safe water, sanitation, and hygiene (WASH) facilities meeting SPHERE minimum standards. False indicates a WASH vulnerability requiring intervention. Used for WASH sector targeting and OCHA cluster reporting.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:needsAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Needs Assessment Id' ;
    rdfs:comment 'Unique system-generated identifier for each needs assessment record. Primary key for the needs_assessment data product within the beneficiary domain.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NeedsAssessment .

ind:assessorPositionId rdf:type rdf:Property ;
    rdfs:label 'Assessor Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Needs assessments are conducted by staff in specific positions (Nutrition Officer, Protection Officer, WASH Engineer). Linking to position enables assessment quality analysis by position type and staf' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:commodityId rdf:type rdf:Property ;
    rdfs:label 'Commodity Id' ;
    rdfs:comment 'Foreign key linking to supply.commodity. Business justification: Needs assessments identify specific commodity requirements (NFI kits, food baskets, WASH items, shelter materials) for beneficiaries. Essential for humanitarian needs-based procurement planning and Sp' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Commodity .

ind:componentId rdf:type rdf:Property ;
    rdfs:label 'Component Id' ;
    rdfs:comment 'Foreign key linking to program.component. Business justification: Needs assessments in NGOs are commissioned by specific program components to inform component-level design and targeting decisions. Component-level aggregation of assessment findings is required for c' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Component .

ind:dataCollectionToolId rdf:type rdf:Property ;
    rdfs:label 'Data Collection Tool Id' ;
    rdfs:comment 'The unique identifier of the data collection instrument used to conduct this assessment. For KoboToolbox, this is the form UID (e.g., \'aXmK3p9QrT\'). For CommCare, this is the module ID. Enables traceability back to the specific questionnaire version and supports data quality audits.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataCollectionTool .

ind:fieldTeamId rdf:type rdf:Property ;
    rdfs:label 'Field Team Id' ;
    rdfs:comment 'Foreign key linking to field.field_team. Business justification: Field teams conduct needs assessments; supervisors need team-level assessment quality assurance and workload tracking. enumerator_volunteer_id covers individual enumerators but not the deploying field' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldTeam .

ind:primaryBeneficiaryStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Beneficiary Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or volunteer who conducted the field assessment. Used for quality assurance, inter-rater reliability checks, and enumerator performance monitoring.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:assessmentLevel rdf:type rdf:Property ;
    rdfs:label 'Assessment Level' ;
    rdfs:comment 'The unit of analysis at which this needs assessment was conducted. \'individual\' targets a single beneficiary (e.g., GBV survivor, SAM case); \'household\' targets a family unit; \'community\' targets a settlement or geographic cluster. Determines which of beneficiary_id, household_id, or community_id is populated.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'The form of informed consent obtained. \'verbal\' is spoken consent recorded by enumerator; \'written\' is signed consent form; \'proxy\' is consent given by a guardian or community leader on behalf of a vulnerable individual (e.g., child, person with disability). Relevant for legal compliance and data protection audits.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationScore rdf:type rdf:Property ;
    rdfs:label 'Education Score' ;
    rdfs:comment 'Numeric score for the education sector assessment findings. Null if education was not included in sectors_assessed. Covers school access, enrollment barriers, learning environment safety, and teacher availability against SPHERE/INEE minimum standards.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enumeratorNotes rdf:type rdf:Property ;
    rdfs:label 'Enumerator Notes' ;
    rdfs:comment 'Free-text qualitative observations recorded by the field enumerator during the assessment. Captures contextual information not covered by structured questions (e.g., security constraints, access limitations, observed conditions). Used by supervisors during validation review.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:femaleHeadedHousehold rdf:type rdf:Property ;
    rdfs:label 'Female Headed Household' ;
    rdfs:comment 'Indicates whether the assessed household is headed by a female. Female-headed households are a standard vulnerability marker in humanitarian targeting criteria and are required for gender disaggregation in donor reports (USAID, DFID/FCDO, UN Women standards).' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpsAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Gps Accuracy Meters' ;
    rdfs:comment 'Estimated GPS accuracy in meters at the time of coordinate capture, as reported by the mobile device. KoboToolbox and CommCare record this automatically. Values above 30 meters may indicate unreliable location data and trigger data quality flags.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (WGS84 decimal degrees) of the assessment location captured by the field enumerator\'s device via KoboToolbox or CommCare GPS capture. Used for GIS mapping, cluster analysis, and geographic targeting in humanitarian response planning.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:livelihoodsScore rdf:type rdf:Property ;
    rdfs:label 'Livelihoods Score' ;
    rdfs:comment 'Numeric score for the livelihoods sector assessment findings. Null if livelihoods was not included in sectors_assessed. Covers income sources, asset ownership, market access, and economic vulnerability indicators.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (WGS84 decimal degrees) of the assessment location captured by the field enumerator\'s device. Used alongside latitude for GIS mapping, spatial clustering, and geographic targeting in humanitarian response planning.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nutritionScore rdf:type rdf:Property ;
    rdfs:label 'Nutrition Score' ;
    rdfs:comment 'Numeric score for the nutrition sector assessment findings. Null if nutrition was not included in sectors_assessed. Incorporates Global Acute Malnutrition (GAM) and Severe Acute Malnutrition (SAM) indicators where applicable. Feeds into DHIS2 nutrition indicator tracking.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallVulnerabilityScore rdf:type rdf:Property ;
    rdfs:label 'Overall Vulnerability Score' ;
    rdfs:comment 'Composite numeric score representing the assessed subject\'s overall vulnerability level, calculated from sector-specific findings using the program\'s scoring methodology (e.g., 0–100 scale). Feeds into vulnerability_profile updates when the score materially changes vulnerability classification. This is a raw assessment output, not a derived KPI.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:personsWithDisabilityCount rdf:type rdf:Property ;
    rdfs:label 'Persons With Disability Count' ;
    rdfs:comment 'Number of household members with a physical, sensory, intellectual, or psychosocial disability. Required for disability-inclusive programming per IASC Guidelines on Inclusion of Persons with Disabilities in Humanitarian Action and CRPD compliance reporting.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protectionScore rdf:type rdf:Property ;
    rdfs:label 'Protection Score' ;
    rdfs:comment 'Numeric score for the protection sector assessment findings. Null if protection was not included in sectors_assessed. Covers GBV risk, child protection, housing land and property rights, and documentation status. Sensitive findings are handled per GBV information management protocols.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referralRecommended rdf:type rdf:Property ;
    rdfs:label 'Referral Recommended' ;
    rdfs:comment 'Indicates whether the assessment findings recommend referral of the beneficiary or household to one or more service providers or program interventions. When TRUE, a referral pathway is initiated in CommCare case management. Drives downstream case management workflow.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralSectors rdf:type rdf:Property ;
    rdfs:label 'Referral Sectors' ;
    rdfs:comment 'Pipe-delimited list of sectors to which the beneficiary or household is being referred based on assessment findings (e.g., \'nutrition|PSS|WASH\'). Populated only when referral_recommended is TRUE. Drives service pathway activation in CommCare and Microsoft Dynamics 365 case management.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorsAssessed rdf:type rdf:Property ;
    rdfs:label 'Sectors Assessed' ;
    rdfs:comment 'Pipe-delimited list of humanitarian/development sectors covered in this assessment (e.g., \'WASH|nutrition|shelter|protection|livelihoods|education\'). Sectors align with IASC cluster system. Determines which sector-specific scored findings fields are populated. [ENUM-REF-CANDIDATE: WASH|nutrition|shelter|protection|livelihoods|education|health|food_security|NFI|PSS — promote to reference product]' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelterScore rdf:type rdf:Property ;
    rdfs:label 'Shelter Score' ;
    rdfs:comment 'Numeric score for the shelter sector assessment findings. Null if shelter was not included in sectors_assessed. Assessed against SPHERE minimum standards for covered living space, structural safety, and thermal comfort.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Source Submission Reference' ;
    rdfs:comment 'The native submission or case ID from the originating source system (KoboToolbox submission UUID or CommCare case ID). Enables exact record traceability back to the source system for data reconciliation, duplicate detection, and audit purposes.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorValidationNotes rdf:type rdf:Property ;
    rdfs:label 'Supervisor Validation Notes' ;
    rdfs:comment 'Free-text notes entered by the supervising data manager or MEL officer during the assessment review and validation process. Documents reasons for rejection, data quality concerns, or approval rationale. Populated when assessment_status transitions to \'validated\' or \'rejected\'.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'The date and time when the assessment record was validated or rejected by the supervising staff member. Distinct from assessment_date (field event) and created_timestamp (record creation). Used for SLA monitoring of data quality review turnaround.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:washScore rdf:type rdf:Property ;
    rdfs:label 'Wash Score' ;
    rdfs:comment 'Numeric score for the Water, Sanitation and Hygiene (WASH) sector assessment findings. Null if WASH was not included in sectors_assessed. Scored against SPHERE minimum standards for water access, sanitation facilities, and hygiene promotion.' ;
    rdfs:domain ind:NeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'Unique system-generated identifier for each consent record. Primary key for the consent_record data product within the beneficiary domain.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectingPartnerOrgId rdf:type rdf:Property ;
    rdfs:label 'Collecting Partner Org Id' ;
    rdfs:comment 'Foreign key linking to partnership.partner_org. Business justification: Data protection frameworks (GDPR, CHS Standard 7) require tracking which implementing partner collected beneficiary consent. Consent audits and data-sharing compliance reviews depend on knowing the co' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerOrg .

ind:consentingVolunteerId rdf:type rdf:Property ;
    rdfs:label 'Consenting Volunteer Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer. Business justification: Informed consent collection: volunteers collect consent from beneficiaries in the field. Tracking the volunteer who obtained consent is required for GDPR/data protection compliance audits and consent ' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:governancePolicyId rdf:type rdf:Property ;
    rdfs:label 'Governance Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.governance_policy. Business justification: Consent collection must comply with specific governance policies (data protection policy, GDPR policy, photography/biometric policy). Linking consent_record to the governing governance_policy ensures ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GovernancePolicy .

ind:incidentId rdf:type rdf:Property ;
    rdfs:label 'Incident Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_incident. Business justification: Consent violations (unauthorized data sharing, biometric data misuse, photography without consent) constitute compliance incidents. Linking consent_record to compliance_incident enables tracing which ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:primaryConsentStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Consent Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or field worker who witnessed the consent process. Links to the workforce staff_member record for accountability and audit trail purposes.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:biometricEnrollmentPermitted rdf:type rdf:Property ;
    rdfs:label 'Biometric Enrollment Permitted' ;
    rdfs:comment 'Indicates whether the beneficiary has consented to biometric data enrollment (fingerprint, iris scan, facial recognition) for identity verification and deduplication purposes. True = biometric enrollment permitted; False = not permitted.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chsComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Chs Compliance Flag' ;
    rdfs:comment 'Indicates whether this consent record meets all requirements of the Core Humanitarian Standard (CHS) Commitment 4 on accountability to affected populations. True = CHS compliant; False = non-compliant or pending review. Used in CHS certification audits.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Collection Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the country where consent was collected (e.g., \'SOM\' for Somalia, \'SSD\' for South Sudan). Supports multi-country program reporting and regulatory compliance.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionLocation rdf:type rdf:Property ;
    rdfs:label 'Collection Location' ;
    rdfs:comment 'Name or description of the physical location where consent was collected (e.g., registration site name, health facility, IDP camp name, community center). Supports geographic analysis and field operations reporting.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentFormVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Form Version' ;
    rdfs:comment 'Version identifier of the consent form template used at the time of consent collection (e.g., v1.0, v2.3). Enables tracking of which version of the consent language and terms the beneficiary agreed to, critical for compliance audits.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLanguage rdf:type rdf:Property ;
    rdfs:label 'Consent Language' ;
    rdfs:comment 'ISO 639-1 or ISO 639-3 language code representing the language in which consent was communicated and obtained. Ensures accountability that consent was given in the beneficiary\'s understood language (e.g., \'ar\' for Arabic, \'fr\' for French, \'so\' for Somali). Critical for CHS accountability compliance.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The method by which consent was obtained from the beneficiary. \'verbal\' for spoken agreement (audio-recorded or witnessed); \'written\' for signed paper form; \'digital\' for electronic signature or mobile app confirmation; \'thumbprint\' for biometric ink impression; \'proxy\' for consent given by a guardian or authorized representative on behalf of a minor or incapacitated individual.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Consent Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference code assigned to this consent record, used in field operations, case referrals, and compliance reporting. Format: CNS-[COUNTRY]-[YEAR]-[SEQUENCE].' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle status of the consent record. \'given\' indicates active informed consent; \'withdrawn\' indicates the beneficiary has revoked consent; \'pending\' indicates consent is awaited; \'expired\' indicates the consent period has lapsed; \'refused\' indicates explicit refusal.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Days' ;
    rdfs:comment 'The number of days for which the beneficiary\'s data may be retained under this consent, as agreed at the time of consent collection. Drives automated data retention and deletion workflows. Aligned with GDPR storage limitation principle.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataScope rdf:type rdf:Property ;
    rdfs:label 'Data Scope' ;
    rdfs:comment 'Description of the specific data elements, activities, or purposes covered by this consent record (e.g., \'collection and storage of household survey data\', \'sharing of case data with UNHCR for referral\'). Defines the boundaries of what the beneficiary has consented to.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureReference rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Reference' ;
    rdfs:comment 'Reference identifier or hash of the digital signature captured when consent_method is \'digital\'. Links to the secure digital signature storage system. Not the signature itself — a reference token for audit trail purposes.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'The date from which the consent becomes legally and operationally binding. May differ from consent_date if there is a processing delay or a future-dated consent arrangement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date on which the consent expires and must be renewed. Nullable for open-ended consents. Supports automated consent renewal workflows and compliance with data retention policies.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formAttachmentReference rdf:type rdf:Property ;
    rdfs:label 'Form Attachment Reference' ;
    rdfs:comment 'File path, URL, or document management system reference to the scanned or digital copy of the signed consent form. Enables retrieval of the original consent document for audit and legal purposes.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether the EU General Data Protection Regulation (GDPR) applies to this consent record based on the beneficiary\'s location, the organization\'s jurisdiction, or the data controller\'s domicile. True = GDPR applies; False = GDPR does not apply.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:informedConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Verified' ;
    rdfs:comment 'Indicates whether a supervisor or quality assurance officer has verified that the consent was truly informed (i.e., the beneficiary understood the purpose, scope, and their rights before consenting). True = verified; False = pending verification.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProxyConsent rdf:type rdf:Property ;
    rdfs:label 'Is Proxy Consent' ;
    rdfs:comment 'Indicates whether consent was given by a proxy (guardian, parent, or authorized representative) on behalf of a minor, elderly, or incapacitated beneficiary. True = proxy consent; False = direct consent from the beneficiary.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photographyPermitted rdf:type rdf:Property ;
    rdfs:label 'Photography Permitted' ;
    rdfs:comment 'Indicates whether the beneficiary has consented to being photographed or filmed for organizational communications, donor reporting, or advocacy purposes. True = photography/media use permitted; False = not permitted.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proxyName rdf:type rdf:Property ;
    rdfs:label 'Proxy Name' ;
    rdfs:comment 'Full name of the proxy individual (guardian, parent, or authorized representative) who provided consent on behalf of the beneficiary. Populated only when is_proxy_consent is True.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proxyRelationship rdf:type rdf:Property ;
    rdfs:label 'Proxy Relationship' ;
    rdfs:comment 'The relationship of the proxy consent giver to the beneficiary (e.g., parent, guardian, legal representative). Populated only when is_proxy_consent is True. [ENUM-REF-CANDIDATE: parent|guardian|spouse|sibling|community_leader|legal_representative|other — promote to reference product]' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sharingPermitted rdf:type rdf:Property ;
    rdfs:label 'Sharing Permitted' ;
    rdfs:comment 'Indicates whether the beneficiary has consented to their data being shared with third-party organizations (e.g., partner NGOs, UN agencies, government bodies). True = sharing permitted; False = sharing not permitted. Critical for inter-agency data sharing compliance.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sharingRestrictions rdf:type rdf:Property ;
    rdfs:label 'Sharing Restrictions' ;
    rdfs:comment 'Free-text description of any specific restrictions or conditions placed by the beneficiary on data sharing (e.g., \'not to be shared with government authorities\', \'only for health program purposes\'). Populated when sharing_permitted is True but with conditions.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The unique identifier of this consent record in the originating operational system (CommCare case ID, KoboToolbox submission UUID, Dynamics 365 record ID). Enables traceability and reconciliation between the lakehouse silver layer and source systems.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'The date on which the beneficiary formally withdrew their previously given consent. Populated only when consent_status is \'withdrawn\'. Triggers downstream data deletion or anonymization workflows per GDPR right to erasure.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Free-text description of the reason provided by the beneficiary or their representative for withdrawing consent. Populated only when consent_status is \'withdrawn\'. Used for accountability reporting and program improvement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessName rdf:type rdf:Property ;
    rdfs:label 'Witness Name' ;
    rdfs:comment 'Full name of the field staff member or community witness who witnessed the consent process. Required for verbal and thumbprint consent methods to ensure accountability and legal validity.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedVolunteerId rdf:type rdf:Property ;
    rdfs:label 'Assigned Volunteer Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer. Business justification: Case management: community case workers and protection volunteers are assigned to support cases alongside staff. Tracking the assigned volunteer per case is required for caseload management, supervisi' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:distributionOrderId rdf:type rdf:Property ;
    rdfs:label 'Distribution Order Id' ;
    rdfs:comment 'Foreign key linking to supply.distribution_order. Business justification: Case-driven distribution: protection, nutrition, and health case records directly trigger distribution orders (e.g., therapeutic food for SAM cases, dignity kits for GBV cases). NGO case managers need' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionOrder .

ind:caseNarrative rdf:type rdf:Property ;
    rdfs:label 'Case Narrative' ;
    rdfs:comment 'Free-text longitudinal narrative documenting the beneficiary\'s situation, interventions provided, progress notes, and caseworker observations. Contains sensitive personal and protection information. Restricted access per data protection protocols.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Human-readable, externally-known unique case reference code assigned at registration. Used in field communications, referral letters, and donor/compliance reporting. Format: CASE-{PROGRAM_CODE}-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casePlanDeveloped rdf:type rdf:Property ;
    rdfs:label 'Case Plan Developed' ;
    rdfs:comment 'Indicates whether a formal individualized case plan has been developed and documented for this beneficiary. A case plan is a mandatory element of structured case management per IASC standards.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseStage rdf:type rdf:Property ;
    rdfs:label 'Case Stage' ;
    rdfs:comment 'Current stage within the structured case management workflow cycle (intake → assessment → planning → intervention → monitoring → closure). Distinct from case_status; represents the process phase rather than the operational state.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle state of the case record within the CommCare case management workflow. Drives operational dashboards, caseload reporting, and MEL tracking.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the case by humanitarian sector or service modality. Drives workflow routing, referral pathways, and MEL indicator disaggregation. [ENUM-REF-CANDIDATE: protection|gbv|child_protection|pss|nutrition|health|livelihoods — promote to reference product]' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Calendar date on which the case was formally closed. Null if the case remains open or in-progress. Used to calculate case duration and throughput metrics.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Standardized reason for case closure. Used for caseload quality analysis, MEL outcome disaggregation, and donor accountability reporting. [ENUM-REF-CANDIDATE: services_completed|voluntary_withdrawal|lost_to_followup|transferred|deceased|duplicate|other — promote to reference product]' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isChildCase rdf:type rdf:Property ;
    rdfs:label 'Is Child Case' ;
    rdfs:comment 'Indicates whether the beneficiary is a child (under 18 years of age). Triggers child protection protocols, guardian consent requirements, and UNICEF/child protection cluster reporting obligations.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGbvCase rdf:type rdf:Property ;
    rdfs:label 'Is Gbv Case' ;
    rdfs:comment 'Indicates whether this case involves Gender-Based Violence (GBV). Enables secure, disaggregated GBV caseload reporting while maintaining strict data protection protocols per IASC GBV guidelines.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIdpCase rdf:type rdf:Property ;
    rdfs:label 'Is Idp Case' ;
    rdfs:comment 'Indicates whether the beneficiary is an Internally Displaced Person (IDP). Used for OCHA displacement tracking, Cluster reporting, and disaggregated humanitarian response analysis.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastFollowupDate rdf:type rdf:Property ;
    rdfs:label 'Last Followup Date' ;
    rdfs:comment 'Date of the most recent caseworker interaction or follow-up visit recorded for this case. Used to identify inactive cases and trigger escalation workflows.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalAidRequired rdf:type rdf:Property ;
    rdfs:label 'Legal Aid Required' ;
    rdfs:comment 'Indicates whether the beneficiary requires legal aid services as part of the case management plan (e.g., documentation, asylum claims, GBV legal redress). Triggers referral to legal service providers.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextFollowupDate rdf:type rdf:Property ;
    rdfs:label 'Next Followup Date' ;
    rdfs:comment 'Scheduled date for the next planned caseworker interaction or home visit. Drives field scheduling and caseload management in CommCare.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nutritionStatus rdf:type rdf:Property ;
    rdfs:label 'Nutrition Status' ;
    rdfs:comment 'Classified nutritional status of the beneficiary based on MUAC and/or weight-for-height z-score. SAM = Severe Acute Malnutrition; MAM = Moderate Acute Malnutrition. Drives therapeutic feeding program enrollment and DHIS2 health indicator reporting.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onHoldReason rdf:type rdf:Property ;
    rdfs:label 'On Hold Reason' ;
    rdfs:comment 'Free-text or coded reason explaining why the case has been placed on hold (e.g., beneficiary unreachable, security access constraints, awaiting referral response). Populated only when case_status = on_hold.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Calendar date on which the case was formally opened and registered in the case management system. Used for caseload aging analysis and response time measurement.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcomeClassification rdf:type rdf:Property ;
    rdfs:label 'Outcome Classification' ;
    rdfs:comment 'Standardized classification of the case result at closure. Used for MEL outcome reporting, donor accountability, and Theory of Change (ToC) validation. [ENUM-REF-CANDIDATE: goal_achieved|partially_achieved|not_achieved|lost_to_followup|referred_out|deceased — promote to reference product]' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentingIssue rdf:type rdf:Property ;
    rdfs:label 'Presenting Issue' ;
    rdfs:comment 'Primary issue or need presented by the beneficiary at case intake, as documented by the caseworker (e.g., acute malnutrition, GBV incident, displacement, lack of shelter, psychosocial distress).' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Urgency classification assigned to the case based on vulnerability assessment, protection risk, or medical severity. Determines response time SLAs and caseworker allocation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pssSessionCount rdf:type rdf:Property ;
    rdfs:label 'Pss Session Count' ;
    rdfs:comment 'Number of Psychosocial Support (PSS) sessions attended by the beneficiary under this case. Used for MEL output tracking, minimum dose compliance, and donor reporting on PSS program reach.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referralDate rdf:type rdf:Property ;
    rdfs:label 'Referral Date' ;
    rdfs:comment 'Date on which the beneficiary was referred to an external service or organization. Used to measure referral response time and inter-agency coordination effectiveness.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralDestination rdf:type rdf:Property ;
    rdfs:label 'Referral Destination' ;
    rdfs:comment 'Name or code of the organization, facility, or service to which the beneficiary was referred out from this case (e.g., health clinic, legal aid, shelter). Supports inter-agency referral pathway tracking.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Channel or entity through which the beneficiary was referred into this case. Used for referral pathway analysis and community outreach effectiveness reporting. [ENUM-REF-CANDIDATE: self_referral|community_referral|health_facility|partner_org|government|hotline|other — promote to reference product]' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPlanInPlace rdf:type rdf:Property ;
    rdfs:label 'Safety Plan In Place' ;
    rdfs:comment 'Indicates whether a formal safety plan has been developed and agreed with the beneficiary, particularly for GBV and protection cases. Required element of minimum case management standards.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceModality rdf:type rdf:Property ;
    rdfs:label 'Service Modality' ;
    rdfs:comment 'Mode of service delivery used for this case (e.g., in-person clinic visit, remote counselling, mobile outreach, group PSS session, home visit). Used for operational planning and cost analysis.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Supervisor Review Required' ;
    rdfs:comment 'Indicates whether this case has been flagged for mandatory supervisory review, typically due to critical priority, complex protection risk, or escalation trigger. Supports quality assurance and safeguarding protocols.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseActionId rdf:type rdf:Property ;
    rdfs:label 'Case Action Id' ;
    rdfs:comment 'Unique system-generated identifier for each case action record within the beneficiary case management system. Primary key for the case_action data product.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CaseAction .

ind:volunteerId rdf:type rdf:Property ;
    rdfs:label 'Volunteer Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer. Business justification: Case management actions are frequently performed by trained volunteers (community health workers, protection monitors, PSS facilitators). Essential for tracking who delivered services, accountability,' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:actionCategory rdf:type rdf:Property ;
    rdfs:label 'Action Category' ;
    rdfs:comment 'Humanitarian sector or thematic category under which this action falls, aligned with OCHA cluster system and IATI sector codes. Enables cross-sector analysis and cluster reporting. [ENUM-REF-CANDIDATE: protection|health|nutrition|wash|shelter|education|livelihoods|psychosocial|food_security|cash_and_voucher — promote to reference product]' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionDate rdf:type rdf:Property ;
    rdfs:label 'Action Date' ;
    rdfs:comment 'The actual calendar date on which the case action was performed or delivered in the field. This is the principal real-world event date used for MEL reporting, PDM analysis, and donor reporting.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionOutcome rdf:type rdf:Property ;
    rdfs:label 'Action Outcome' ;
    rdfs:comment 'The result or outcome of the case action as assessed by the case worker at the time of completion. Used for MEL indicator tracking, Results-Based Management (RBM) reporting, and LogFrame output measurement.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Action Reference Number' ;
    rdfs:comment 'Externally visible, human-readable reference number assigned to this case action for use in field reports, SitReps, and donor reporting. Follows the format CA-YYYY-NNNNNN.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle status of the case action, tracking progression from planning through completion or cancellation. Used for workload management and case progress monitoring.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Timestamp' ;
    rdfs:comment 'Precise date and time at which the case action was recorded or submitted in the system, including timezone offset. Used for audit trails, data quality checks, and real-time field monitoring.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the type of intervention or activity performed during this case action. Drives workflow routing, reporting disaggregation, and MEL indicator tracking. [ENUM-REF-CANDIDATE: home_visit|counseling_session|referral|service_provision|follow_up_call|group_session|needs_assessment|distribution|medical_consultation|legal_aid|psychosocial_support|community_mobilization — promote to reference product]' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adminLevel1Code rdf:type rdf:Property ;
    rdfs:label 'Admin Level1 Code' ;
    rdfs:comment 'ISO 3166-2 or OCHA P-Code for the first administrative division (e.g., state, province, region) where the action was conducted. Used for geographic disaggregation in donor and cluster reports.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adminLevel2Code rdf:type rdf:Property ;
    rdfs:label 'Admin Level2 Code' ;
    rdfs:comment 'OCHA P-Code for the second administrative division (e.g., district, county, woreda) where the action was conducted. Enables sub-national geographic disaggregation for MEL and cluster reporting.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Duration in minutes of the case action or intervention session. Used for workload analysis, staff time tracking, and service intensity measurement in MEL frameworks.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Free-text description of the reason this case action was escalated to a higher authority or inter-agency body. Confidential case management information.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequired rdf:type rdf:Property ;
    rdfs:label 'Escalation Required' ;
    rdfs:comment 'Indicates whether this case action has triggered an escalation to a supervisor, protection officer, or inter-agency coordination body due to severity, risk, or unresolved needs.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether a follow-up action is required after this case action. When true, next_action_due_date must be populated. Drives automated task creation in CommCare and Dynamics 365.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpType rdf:type rdf:Property ;
    rdfs:label 'Follow Up Type' ;
    rdfs:comment 'Type of follow-up action planned for this case after the current action is completed. Used to pre-populate the next case action record and support case worker scheduling.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSensitiveCase rdf:type rdf:Property ;
    rdfs:label 'Is Sensitive Case' ;
    rdfs:comment 'Indicates whether this case action relates to a sensitive protection case such as GBV, child protection, or trafficking. Triggers enhanced data access controls and confidentiality protocols.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:muacMeasurementMm rdf:type rdf:Property ;
    rdfs:label 'Muac Measurement Mm' ;
    rdfs:comment 'Mid-Upper Arm Circumference (MUAC) measurement in millimetres recorded during a nutrition screening action. Used to classify Global Acute Malnutrition (GAM) and Severe Acute Malnutrition (SAM) status per SPHERE standards.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Due Date' ;
    rdfs:comment 'The date by which the next follow-up action or intervention for this case must be completed. Drives case worker task queues and escalation alerts in CommCare and Dynamics 365.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcomeNotes rdf:type rdf:Property ;
    rdfs:label 'Outcome Notes' ;
    rdfs:comment 'Free-text narrative describing the outcome of the case action, observations made during the visit or session, and any contextual information relevant to case progress. Confidential case management information.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionConcernType rdf:type rdf:Property ;
    rdfs:label 'Protection Concern Type' ;
    rdfs:comment 'Specific protection concern category associated with this case action, used for disaggregated protection cluster reporting. Confidential and access-restricted. [ENUM-REF-CANDIDATE: gbv|child_protection|trafficking|idp_displacement|statelessness|forced_recruitment|detention|none — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pssSessionNumber rdf:type rdf:Property ;
    rdfs:label 'Pss Session Number' ;
    rdfs:comment 'Sequential session number for Psychosocial Support (PSS) interventions, tracking the beneficiary\'s progression through a structured PSS program. Applicable when action_type is \'counseling_session\'.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referralReason rdf:type rdf:Property ;
    rdfs:label 'Referral Reason' ;
    rdfs:comment 'Description of the reason the beneficiary was referred to another service or organization. Confidential case management information used for inter-agency coordination and case continuity.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The originally planned date on which this case action was scheduled to occur. Compared against action_date to measure timeliness and adherence to case plans.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceItemsProvided rdf:type rdf:Property ;
    rdfs:label 'Service Items Provided' ;
    rdfs:comment 'Description of specific Non-Food Items (NFIs), services, or assistance items provided to the beneficiary during this action (e.g., hygiene kit, food ration, cash transfer amount). Used for distribution tracking and PDM.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorReviewDate rdf:type rdf:Property ;
    rdfs:label 'Supervisor Review Date' ;
    rdfs:comment 'Date on which a supervisor reviewed and validated this case action record. Populated when supervisor_reviewed is true.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisorReviewed rdf:type rdf:Property ;
    rdfs:label 'Supervisor Reviewed' ;
    rdfs:comment 'Indicates whether a supervisor or team leader has reviewed and validated this case action record. Supports quality assurance, accountability, and CHS compliance verification.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralId rdf:type rdf:Property ;
    rdfs:label 'Referral Id' ;
    rdfs:comment 'Unique identifier for the referral transaction. Primary key for the referral data product.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivingOrganizationPartnerOrgId rdf:type rdf:Property ;
    rdfs:label 'Receiving Organization Partner Org Id' ;
    rdfs:comment 'Identifier of the organization or service provider that is receiving and expected to act on the referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerOrg .

ind:receivingStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Receiving Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member at the receiving organization who is assigned to handle this referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:referralPartnerOrgId rdf:type rdf:Property ;
    rdfs:label 'Referral Partner Org Id' ;
    rdfs:comment 'Identifier of the organization or partner that is initiating and submitting the referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerOrg .

ind:referralStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Referral Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member or case worker who initiated the referral on behalf of the beneficiary.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:referringVolunteerId rdf:type rdf:Property ;
    rdfs:label 'Referring Volunteer Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer. Business justification: Community volunteers identify and refer beneficiaries to specialized services (health, protection, legal aid). Critical for community-based protection, health outreach, and early identification progra' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:beneficiarySatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Satisfaction Rating' ;
    rdfs:comment 'Numeric rating provided by the beneficiary indicating their satisfaction with the referral process and services received, typically on a scale of 1-5.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Explanation for why the referral was cancelled before completion, including beneficiary circumstances or organizational constraints.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Classification of the sensitivity of the referral case, particularly important for Gender-Based Violence (GBV) and protection cases requiring special handling.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Name of the operational system from which this referral record originated, such as CommCare, KoboToolbox, or Microsoft Dynamics 365.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'Explanation provided when a referral is declined by the receiving organization or rejected by the beneficiary.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedResponseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Response Date' ;
    rdfs:comment 'Target date by which the receiving organization is expected to acknowledge or respond to the referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feedbackReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Feedback Received Flag' ;
    rdfs:comment 'Indicates whether feedback was received from the beneficiary regarding their satisfaction with the referral process and services received.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed Flag' ;
    rdfs:comment 'Indicates whether the scheduled follow-up with the beneficiary or receiving organization has been completed.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Scheduled date for follow-up contact with the beneficiary or receiving organization to verify service delivery and outcome.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gbvCaseFlag rdf:type rdf:Property ;
    rdfs:label 'Gbv Case Flag' ;
    rdfs:comment 'Indicates whether this referral is related to a Gender-Based Violence (GBV) case, requiring adherence to specialized GBV referral pathways and confidentiality protocols.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Detailed description of the outcome of the referral, including services provided, beneficiary response, and any follow-up actions required.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeCategory rdf:type rdf:Property ;
    rdfs:label 'Outcome Category' ;
    rdfs:comment 'Standardized classification of the referral outcome for reporting and analysis purposes.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Detailed explanation of why the beneficiary is being referred, including specific needs, conditions, or circumstances that necessitate the referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Receiving Organization Name' ;
    rdfs:comment 'Name of the organization or service provider receiving the referral, for tracking and reporting purposes.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingServiceType rdf:type rdf:Property ;
    rdfs:label 'Receiving Service Type' ;
    rdfs:comment 'Specific type of service or program that the beneficiary is being referred to at the receiving organization.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingStaffName rdf:type rdf:Property ;
    rdfs:label 'Receiving Staff Name' ;
    rdfs:comment 'Full name of the staff member at the receiving organization who accepted or is processing the referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralCategory rdf:type rdf:Property ;
    rdfs:label 'Referral Category' ;
    rdfs:comment 'Primary service category or sector for which the beneficiary is being referred. Aligned with humanitarian cluster system and Sphere standards. [ENUM-REF-CANDIDATE: health|protection|shelter|wash|nutrition|education|livelihoods|psychosocial|legal|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralNumber rdf:type rdf:Property ;
    rdfs:label 'Referral Number' ;
    rdfs:comment 'Human-readable business identifier for the referral, used for tracking and communication across organizations.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralStatus rdf:type rdf:Property ;
    rdfs:label 'Referral Status' ;
    rdfs:comment 'Current lifecycle status of the referral indicating whether it has been accepted, is being processed, completed, or declined by the receiving organization.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralType rdf:type rdf:Property ;
    rdfs:label 'Referral Type' ;
    rdfs:comment 'Classification of the referral based on organizational scope and urgency. Internal referrals are within the same organization, external are to partner organizations, emergency referrals require immediate action.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referringStaffContact rdf:type rdf:Property ;
    rdfs:label 'Referring Staff Contact' ;
    rdfs:comment 'Phone number or email address of the referring staff member for coordination and follow-up communication.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referringStaffName rdf:type rdf:Property ;
    rdfs:label 'Referring Staff Name' ;
    rdfs:comment 'Full name of the staff member who initiated the referral, for contact and follow-up purposes.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Date' ;
    rdfs:comment 'Date when the service was actually delivered to the beneficiary by the receiving organization.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:protectionFlagId rdf:type rdf:Property ;
    rdfs:label 'Protection Flag Id' ;
    rdfs:comment 'Unique identifier for the protection flag record. Primary key.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAssignedProtectionOfficerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Assigned Protection Officer Staff Member Id' ;
    rdfs:comment 'Reference to the protection officer or case worker currently responsible for managing this protection flag and coordinating response.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:reportingVolunteerId rdf:type rdf:Property ;
    rdfs:label 'Reporting Volunteer Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer. Business justification: Protection monitoring: volunteers (community protection monitors) identify and report protection flags. Tracking the reporting volunteer is required for accountability, supervision, and protection inc' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date when the protection flag was escalated to higher authority or specialized protection services.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External identifier from the source system or partner organization. Used for cross-system reconciliation and data integration.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagCode rdf:type rdf:Property ;
    rdfs:label 'Flag Code' ;
    rdfs:comment 'Standardized code identifying the protection flag type. Used for system integration and reporting aggregation.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagDate rdf:type rdf:Property ;
    rdfs:label 'Flag Date' ;
    rdfs:comment 'Date when the protection concern was first identified or flagged. Represents the business event timestamp for this protection record.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flagSeverity rdf:type rdf:Property ;
    rdfs:label 'Flag Severity' ;
    rdfs:comment 'Severity level of the protection concern indicating urgency of response and level of risk to the beneficiary.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagStatus rdf:type rdf:Property ;
    rdfs:label 'Flag Status' ;
    rdfs:comment 'Current lifecycle status of the protection flag indicating whether it requires active intervention, ongoing monitoring, or has been resolved.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagType rdf:type rdf:Property ;
    rdfs:label 'Flag Type' ;
    rdfs:comment 'Category of protection concern. GBV (Gender-Based Violence), SGBV (Sexual and Gender-Based Violence), UASC (Unaccompanied and Separated Children). [ENUM-REF-CANDIDATE: GBV Risk|Child Protection|SGBV Survivor|Unaccompanied Minor|UASC|Trafficking Risk|Forced Recruitment|Disability Protection|Elderly at Risk|Medical Vulnerability — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flaggingSource rdf:type rdf:Property ;
    rdfs:label 'Flagging Source' ;
    rdfs:comment 'Name of the organization, program, or system that originally flagged this protection concern. May reference partner organizations or internal programs.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identification Method' ;
    rdfs:comment 'Method or channel through which the protection concern was identified. FGD (Focus Group Discussion), KII (Key Informant Interview). [ENUM-REF-CANDIDATE: Field Assessment|Community Referral|Self-Reported|Partner Organization|Health Screening|Household Survey|Focus Group Discussion|Key Informant Interview — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateNeeds rdf:type rdf:Property ;
    rdfs:label 'Immediate Needs' ;
    rdfs:comment 'Description of immediate protection needs or interventions required to address the flagged concern. Used for rapid response planning.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this protection flag is currently active and requires ongoing attention. Derived from flag_status but provided for simplified querying.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Last Follow Up Date' ;
    rdfs:comment 'Date of the most recent follow-up visit or assessment conducted for this protection flag.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalActionRequired rdf:type rdf:Property ;
    rdfs:label 'Legal Action Required' ;
    rdfs:comment 'Indicates whether the protection concern requires legal intervention, law enforcement involvement, or judicial proceedings.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this protection flag record was last modified. Audit trail field for data governance and change tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nextFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Next Follow Up Date' ;
    rdfs:comment 'Scheduled date for the next follow-up visit or assessment to monitor the protection concern and beneficiary status.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pssProvided rdf:type rdf:Property ;
    rdfs:label 'Pss Provided' ;
    rdfs:comment 'Indicates whether Psychosocial Support (PSS) services have been provided to the beneficiary as part of protection response.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralMade rdf:type rdf:Property ;
    rdfs:label 'Referral Made' ;
    rdfs:comment 'Indicates whether the beneficiary has been referred to specialized protection services or partner organizations for support.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralOrganization rdf:type rdf:Property ;
    rdfs:label 'Referral Organization' ;
    rdfs:comment 'Name of the organization or service provider to which the beneficiary was referred for specialized protection support.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'Reporting period during which this protection flag was active or recorded. Format: YYYY-QN for quarterly or YYYY-MM for monthly reporting.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date when the protection concern was resolved or the flag was closed. Null if the flag is still active or under monitoring.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Narrative description of how the protection concern was resolved, interventions provided, and outcomes achieved.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed narrative description of the specific protection risk or concern. Contains sensitive information about the nature of the threat or vulnerability.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRecordId rdf:type rdf:Property ;
    rdfs:label 'Document Record Id' ;
    rdfs:comment 'Unique identifier for the document record. Primary key for the document_record product.' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capturingVolunteerId rdf:type rdf:Property ;
    rdfs:label 'Capturing Volunteer Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer. Business justification: Document capture chain-of-custody: volunteers capture beneficiary identity documents during field registration. Tracking the capturing volunteer is required for data quality audits, GDPR compliance, a' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:captureDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Capture Device Code' ;
    rdfs:comment 'Unique identifier of the mobile device, scanner, or workstation used to capture the document. Supports audit trail and data quality tracking.' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureMethod rdf:type rdf:Property ;
    rdfs:label 'Capture Method' ;
    rdfs:comment 'The method used to capture the document information into the system (e.g., mobile scan via KoboToolbox, flatbed scanner, photograph, manual data entry).' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCondition rdf:type rdf:Property ;
    rdfs:label 'Document Condition' ;
    rdfs:comment 'Physical condition of the document at the time of registration or verification. Impacts reliability for identity verification.' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentImageReference rdf:type rdf:Property ;
    rdfs:label 'Document Image Reference' ;
    rdfs:comment 'File path, URL, or storage reference to the scanned or photographed image of the document. Used for audit and verification purposes.' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Document Language Code' ;
    rdfs:comment 'ISO 639-1 or ISO 639-2 language code indicating the primary language in which the document is written.' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The unique alphanumeric identifier printed on the document by the issuing authority. Used for identity verification and legal status determination.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the identity or legal document. Common types include UNHCR registration certificates, national ID cards, birth certificates, marriage certificates, asylum seeker cards, and travel documents.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryIdentityDocument rdf:type rdf:Property ;
    rdfs:label 'Is Primary Identity Document' ;
    rdfs:comment 'Boolean flag indicating whether this document is the primary identity document for the beneficiary. True if this is the main document used for identity verification.' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which the document was officially issued by the authority. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'The government agency, international organization, or official body that issued the document (e.g., Ministry of Interior, UNHCR, National Registration Bureau).' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the country or territory where the document was issued.' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalStatusIndicator rdf:type rdf:Property ;
    rdfs:label 'Legal Status Indicator' ;
    rdfs:comment 'The legal status of the beneficiary as evidenced by this document. Supports protection case management and eligibility determination for humanitarian assistance. [ENUM-REF-CANDIDATE: refugee|asylum_seeker|idp|stateless|citizen|resident|undocumented — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'The number of days for which this document record must be retained according to organizational policy, donor requirements, or legal obligations. After this period, the record may be archived or deleted.' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The method or process used to verify the authenticity of the document (e.g., visual inspection, biometric matching, confirmation with issuing authority).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryId rdf:type rdf:Property ;
    rdfs:label 'Country Id' ;
    rdfs:comment 'Foreign key linking to field.country. Business justification: project_site has country_code (STRING) but no FK to the country reference table. The country table contains authoritative country metadata including codes, names, region, operational status, and human' ;
    rdfs:domain ind:Field ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.obligation. Business justification: Project sites in certain jurisdictions require site-specific compliance obligations (environmental permits, local authority operating approvals, land use permits). Linking project_site to obligation e' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:siteManagerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Site Manager Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: project_site.site_manager_name is a classic denormalization of a staff_member FK. Site manager accountability, performance reviews, and operational reporting all require a proper FK. site_manager_name' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accessibilityRating rdf:type rdf:Property ;
    rdfs:label 'Accessibility Rating' ;
    rdfs:comment 'Assessment of physical accessibility to the project site considering road conditions, security, terrain, and seasonal factors.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adminLevel1 rdf:type rdf:Property ;
    rdfs:label 'Admin Level 1' ;
    rdfs:comment 'First-level administrative division (e.g., state, province, region) where the project site is located.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adminLevel2 rdf:type rdf:Property ;
    rdfs:label 'Admin Level 2' ;
    rdfs:comment 'Second-level administrative division (e.g., district, county, department) where the project site is located.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adminLevel3 rdf:type rdf:Property ;
    rdfs:label 'Admin Level 3' ;
    rdfs:comment 'Third-level administrative division (e.g., municipality, sub-district, commune) where the project site is located.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date when the project site was officially closed or decommissioned. Null for active sites.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clusterAffiliation rdf:type rdf:Property ;
    rdfs:label 'Cluster Affiliation' ;
    rdfs:comment 'OCHA humanitarian cluster(s) that this project site is affiliated with for coordination purposes. [ENUM-REF-CANDIDATE: health|nutrition|wash|shelter|protection|education|food_security|logistics|emergency_telecom|camp_coordination|early_recovery — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for official communication with the project site.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary phone number for reaching the project site or site manager.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electricityAvailable rdf:type rdf:Property ;
    rdfs:label 'Electricity Available' ;
    rdfs:comment 'Indicates whether electrical power is available at the project site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:establishmentDate rdf:type rdf:Property ;
    rdfs:label 'Establishment Date' ;
    rdfs:comment 'Date when the project site was officially established and became operational.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityOwnership rdf:type rdf:Property ;
    rdfs:label 'Facility Ownership' ;
    rdfs:comment 'Legal ownership or usage arrangement for the physical facility at the project site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisDataSource rdf:type rdf:Property ;
    rdfs:label 'Gis Data Source' ;
    rdfs:comment 'Source system or method used to capture GIS coordinates for this project site (e.g., GPS device, OpenStreetMap, satellite imagery).' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internetConnectivity rdf:type rdf:Property ;
    rdfs:label 'Internet Connectivity' ;
    rdfs:comment 'Type of internet connectivity available at the project site for data collection and reporting.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:koboCollectionEnabled rdf:type rdf:Property ;
    rdfs:label 'Kobo Collection Enabled' ;
    rdfs:comment 'Indicates whether mobile data collection via KoboToolbox is enabled and operational at this site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pcode rdf:type rdf:Property ;
    rdfs:label 'Pcode' ;
    rdfs:comment 'OCHA-assigned unique place code (P-code) for standardized geographic referencing in humanitarian operations and reporting.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationCatchment rdf:type rdf:Property ;
    rdfs:label 'Population Catchment' ;
    rdfs:comment 'Estimated number of beneficiaries or persons of concern (PoC) within the service catchment area of this project site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the project site location, if applicable.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAddress rdf:type rdf:Property ;
    rdfs:label 'Site Address' ;
    rdfs:comment 'Physical street address or location description of the project site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Site Area Sqm' ;
    rdfs:comment 'Total physical area of the project site measured in square meters.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the project site for field operations and reporting. Used in SitReps and OCHA coordination.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteDescription rdf:type rdf:Property ;
    rdfs:label 'Site Description' ;
    rdfs:comment 'Detailed narrative description of the project site including physical characteristics, surrounding environment, and operational context.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Human-readable name of the project site or operational location.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the project site based on its primary function and service delivery model.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterSourceAvailable rdf:type rdf:Property ;
    rdfs:label 'Water Source Available' ;
    rdfs:comment 'Indicates whether a reliable water source is available at or near the project site for WASH operations.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentOfficeCountryOfficeId rdf:type rdf:Property ;
    rdfs:label 'Parent Office Country Office Id' ;
    rdfs:comment 'Reference to the parent country office or regional office to which this office reports, enabling hierarchical office structure.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CountryOffice .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address or building location of the country office.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information such as suite, floor, or building name.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the country office is located.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryDirectorEmail rdf:type rdf:Property ;
    rdfs:label 'Country Director Email' ;
    rdfs:comment 'Email address of the country director for official communications.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryDirectorName rdf:type rdf:Property ;
    rdfs:label 'Country Director Name' ;
    rdfs:comment 'Full name of the senior management official responsible for leading the country office operations.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for official correspondence with the country office.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergencyResponse rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Response' ;
    rdfs:comment 'Indicates whether this office was established specifically for emergency or humanitarian crisis response operations.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Official legal name under which the country office is registered with host government authorities, which may differ from the operational office name.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mouEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Mou Effective Date' ;
    rdfs:comment 'Date when the Memorandum of Understanding (MoU) with the host government became effective.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mouExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Mou Expiry Date' ;
    rdfs:comment 'Date when the current Memorandum of Understanding (MoU) with the host government expires.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mouWithGovernment rdf:type rdf:Property ;
    rdfs:label 'Mou With Government' ;
    rdfs:comment 'Indicates whether a formal Memorandum of Understanding (MoU) is in place with the host government defining the terms of operation.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ochaClusterParticipation rdf:type rdf:Property ;
    rdfs:label 'Ocha Cluster Participation' ;
    rdfs:comment 'List of Office for the Coordination of Humanitarian Affairs (OCHA) humanitarian clusters in which this country office actively participates (e.g., WASH, Health, Protection, Education).' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeCode rdf:type rdf:Property ;
    rdfs:label 'Office Code' ;
    rdfs:comment 'Unique business identifier for the country office following organizational naming convention (e.g., KEN-NAI01 for Nairobi office in Kenya).' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeName rdf:type rdf:Property ;
    rdfs:label 'Office Name' ;
    rdfs:comment 'Official name of the country office or sub-office (e.g., Kenya Country Office, Nairobi Sub-Office).' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeType rdf:type rdf:Property ;
    rdfs:label 'Office Type' ;
    rdfs:comment 'Classification of the office based on its operational mandate and scope within the organizational hierarchy.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalMandate rdf:type rdf:Property ;
    rdfs:label 'Operational Mandate' ;
    rdfs:comment 'Description of the office\'s operational mandate, including sectors of focus (e.g., Water Sanitation and Hygiene (WASH), health, education, protection) and target populations served.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact telephone number for the country office.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Registration Expiry Date' ;
    rdfs:comment 'Date when the current host government registration expires and requires renewal.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region within the host country.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the country office location (e.g., Africa/Nairobi, Asia/Damascus) for scheduling and coordination purposes.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionEventId rdf:type rdf:Property ;
    rdfs:label 'Distribution Event Id' ;
    rdfs:comment 'Unique identifier for the distribution event. Primary key.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionEvent .

ind:fieldDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Field Deployment Id' ;
    rdfs:comment 'Foreign key linking to field.field_deployment. Business justification: Distribution events are executed by deployed field teams during specific deployment periods. While distribution_event already has field_team_id, linking to the specific field_deployment record enables' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldDeployment .

ind:mealPlanId rdf:type rdf:Property ;
    rdfs:label 'Meal Plan Id' ;
    rdfs:comment 'Foreign key linking to mel.meal_plan. Business justification: Distribution events have pdm_scheduled_flag and pdm_completion_date governed by the MEAL plan\'s PDM cycle requirements. MEAL coordinators must link distributions to the MEAL plan to enforce post-distr' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MealPlan .

ind:actualBeneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Actual Beneficiary Count' ;
    rdfs:comment 'Actual number of beneficiaries who received assistance in this distribution event, verified through registration or biometric verification.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the distribution event concluded.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualExpenditureAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Expenditure Amount' ;
    rdfs:comment 'Total actual expenditure incurred for this distribution event, including commodity costs, logistics, and operational expenses.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualHouseholdCount rdf:type rdf:Property ;
    rdfs:label 'Actual Household Count' ;
    rdfs:comment 'Actual number of households that received assistance in this distribution event.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when the distribution event commenced on the ground.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Total budget amount allocated for this distribution event, used for Budget versus Actual (BvA) reconciliation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityCategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Category' ;
    rdfs:comment 'Primary category of items distributed in this event. For NFI distributions may include shelter materials, hygiene kits, blankets; for food distributions may include staple foods, fortified foods; for WASH may include water containers, purification tablets. Pipe-enum overflow candidate with 15+ standard categories.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionEventCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Event Code' ;
    rdfs:comment 'Externally-known unique business identifier for the distribution event, typically formatted as country-cluster-sequence (e.g., SYR-WASH-000123).' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionEventName rdf:type rdf:Property ;
    rdfs:label 'Distribution Event Name' ;
    rdfs:comment 'Human-readable name or title of the distribution event for reporting and communication purposes.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Distribution Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the distribution event location, captured via GPS or GIS system.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Distribution Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the distribution event location, captured via GPS or GIS system.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionLocationName rdf:type rdf:Property ;
    rdfs:label 'Distribution Location Name' ;
    rdfs:comment 'Human-readable name of the distribution location (e.g., community center, camp sector, village name).' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionModality rdf:type rdf:Property ;
    rdfs:label 'Distribution Modality' ;
    rdfs:comment 'Method of assistance delivery: in-kind (physical goods), cash (physical currency), voucher (paper/card voucher), mobile money (digital wallet), e-transfer (bank transfer), or hybrid (combination of modalities).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current lifecycle status of the distribution event in the operational workflow. [ENUM-REF-CANDIDATE: planned|approved|in_progress|completed|cancelled|suspended|under_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionType rdf:type rdf:Property ;
    rdfs:label 'Distribution Type' ;
    rdfs:comment 'Classification of the distribution approach: general (universal coverage), targeted (specific beneficiary criteria), blanket (entire population segment), voucher redemption (voucher exchange), emergency response (rapid onset), or seasonal (recurring planned distribution).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Narrative description of any incident, disruption, or complaint that occurred during the distribution event.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Incident Reported Flag' ;
    rdfs:comment 'Indicates whether any security incident, operational disruption, or beneficiary complaint was reported during this distribution event.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pdmCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Pdm Completion Date' ;
    rdfs:comment 'Date when the Post-Distribution Monitoring activity for this distribution event was completed.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pdmScheduledFlag rdf:type rdf:Property ;
    rdfs:label 'Pdm Scheduled Flag' ;
    rdfs:comment 'Indicates whether a Post-Distribution Monitoring activity has been scheduled for this distribution event to assess beneficiary satisfaction and assistance effectiveness.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedBeneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Planned Beneficiary Count' ;
    rdfs:comment 'Target number of beneficiaries planned to receive assistance in this distribution event.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedHouseholdCount rdf:type rdf:Property ;
    rdfs:label 'Planned Household Count' ;
    rdfs:comment 'Target number of households planned to receive assistance in this distribution event.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sitrepIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Sitrep Included Flag' ;
    rdfs:comment 'Indicates whether this distribution event has been included in a Situation Report (SitRep) submitted to OCHA or other coordination bodies.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionLineId rdf:type rdf:Property ;
    rdfs:label 'Distribution Line Id' ;
    rdfs:comment 'Unique identifier for the distribution line item. Primary key.' ;
    rdfs:domain ind:DistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualQuantityDistributed rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity Distributed' ;
    rdfs:comment 'The actual quantity of the item that was distributed to beneficiaries. Used for BvA (Budget versus Actual) reconciliation and MEL reporting.' ;
    rdfs:domain ind:DistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Batch or lot number of the distributed item. Critical for traceability, quality control, and recall management, especially for food, health, and pharmaceutical items.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Count' ;
    rdfs:comment 'Number of individual beneficiaries or households who received this specific item in this distribution line. Supports disaggregated MEL reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionMethod rdf:type rdf:Property ;
    rdfs:label 'Distribution Method' ;
    rdfs:comment 'The method or modality used to distribute this item (e.g., direct hand distribution, voucher redemption, cash transfer for purchase, mobile distribution unit, fixed distribution site).' ;
    rdfs:domain ind:DistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatiTransactionType rdf:type rdf:Property ;
    rdfs:label 'Iati Transaction Type' ;
    rdfs:comment 'IATI-compliant transaction type code for this distribution line, supporting international aid transparency and reporting.' ;
    rdfs:domain ind:DistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'High-level category of the distributed item. NFI = Non-Food Item, WASH = Water Sanitation and Hygiene.' ;
    rdfs:domain ind:DistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemCode rdf:type rdf:Property ;
    rdfs:label 'Item Code' ;
    rdfs:comment 'Standardized code identifying the specific commodity or NFI item. May align with supply chain master item codes or donor-specific item catalogs.' ;
    rdfs:domain ind:DistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Detailed textual description of the distributed item including specifications, brand, quality grade, or other distinguishing characteristics.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the distribution event. Used for ordering and referencing specific items within the distribution.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Identifier of the user or system that last modified this distribution line record. Supports accountability and audit trail.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineSource rdf:type rdf:Property ;
    rdfs:label 'Pipeline Source' ;
    rdfs:comment 'Identifier of the supply pipeline or procurement source from which the item was drawn (e.g., central warehouse, local procurement, in-kind donation, CERF allocation).' ;
    rdfs:domain ind:DistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'The quantity of the item that was planned or targeted for distribution in this line item, as per the distribution plan or LogFrame target.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCheckDate rdf:type rdf:Property ;
    rdfs:label 'Quality Check Date' ;
    rdfs:comment 'Date when the quality inspection was performed on this distribution line item.' ;
    rdfs:domain ind:DistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Check Status' ;
    rdfs:comment 'Result of quality inspection performed on this item batch before or during distribution. Ensures compliance with SPHERE and CHS standards.' ;
    rdfs:domain ind:DistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'The total monetary value of this distribution line (typically unit_value × actual_quantity_distributed). Supports financial reconciliation and grant expenditure tracking.' ;
    rdfs:domain ind:DistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The unit in which the item quantity is measured (e.g., pieces, kilograms, liters, boxes, kits, households).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitValue rdf:type rdf:Property ;
    rdfs:label 'Unit Value' ;
    rdfs:comment 'The monetary value per unit of the distributed item. Used for financial tracking and donor reporting.' ;
    rdfs:domain ind:DistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Difference between planned_quantity and actual_quantity_distributed. Positive values indicate over-distribution, negative values indicate under-distribution. Used for BvA analysis.' ;
    rdfs:domain ind:DistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReason rdf:type rdf:Property ;
    rdfs:label 'Variance Reason' ;
    rdfs:comment 'Explanation for any significant variance between planned and actual quantities. Supports accountability and learning in MEL processes.' ;
    rdfs:domain ind:DistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Identifier of the user or system that created this distribution line record. Supports accountability and audit trail.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentId rdf:type rdf:Property ;
    rdfs:label 'Assessment Id' ;
    rdfs:comment 'Unique identifier for the field assessment record. Primary key.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assessment .

ind:evaluationId rdf:type rdf:Property ;
    rdfs:label 'Evaluation Id' ;
    rdfs:comment 'Foreign key linking to mel.evaluation. Business justification: Assessments provide primary data for evaluations. Evaluators use assessment data (needs, PDM, baseline) as evidence. Essential for evaluation methodology traceability and DAC criteria verification in ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Evaluation .

ind:indicatorId rdf:type rdf:Property ;
    rdfs:label 'Indicator Id' ;
    rdfs:comment 'Foreign key linking to mel.indicator. Business justification: Assessments (baseline, endline, needs) directly measure indicator progress. Nonprofit M&E requires linking assessment findings to specific indicators for results reporting and donor compliance. No exi' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Indicator .

ind:teamLeadStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Team Lead Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Assessments require designated team lead for operational accountability, coordination, and donor reporting compliance. Essential for tracking who is responsible for assessment quality and findings val' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:adequacyScore rdf:type rdf:Property ;
    rdfs:label 'Adequacy Score' ;
    rdfs:comment 'For PDM assessments: score representing beneficiary assessment of whether the distributed items met their needs in terms of quantity, quality, and timeliness. Typically on a scale of 1-5 or 1-10.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentCode rdf:type rdf:Property ;
    rdfs:label 'Assessment Code' ;
    rdfs:comment 'Externally-known unique business identifier for the assessment, used in reporting and coordination with partners.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentName rdf:type rdf:Property ;
    rdfs:label 'Assessment Name' ;
    rdfs:comment 'Human-readable name or title of the assessment, describing its purpose and scope.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiarySatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Satisfaction Score' ;
    rdfs:comment 'Overall satisfaction rating provided by beneficiaries regarding the program or distribution. Supports Accountability to Affected Populations (AAP) and CHS compliance.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clusterCoordinationBody rdf:type rdf:Property ;
    rdfs:label 'Cluster Coordination Body' ;
    rdfs:comment 'The OCHA cluster or sector coordination group to which this assessment is reported (e.g., WASH Cluster, Health Cluster, Food Security Cluster).' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintsReceivedCount rdf:type rdf:Property ;
    rdfs:label 'Complaints Received Count' ;
    rdfs:comment 'Number of complaints or grievances raised by beneficiaries during the assessment. Critical for accountability and feedback mechanisms.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataCollectionTool rdf:type rdf:Property ;
    rdfs:label 'Data Collection Tool' ;
    rdfs:comment 'The digital or physical tool used to capture assessment data in the field. [ENUM-REF-CANDIDATE: KoboToolbox|CommCare|ODK|paper_form|mobile_app|DHIS2|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Internal quality score assessing completeness, accuracy, and reliability of the assessment data. Used for MEL quality control.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorVisibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Visibility Flag' ;
    rdfs:comment 'Indicates whether this assessment is designated for inclusion in donor reports and external visibility materials.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Precise date and time when the assessment fieldwork was completed.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:melIndicatorLinked rdf:type rdf:Property ;
    rdfs:label 'Mel Indicator Linked' ;
    rdfs:comment 'Flag indicating whether this assessment is linked to specific MEL indicators in the logical framework (LogFrame) or results framework.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'The research methodology employed for data collection and analysis.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionConcernsDescription rdf:type rdf:Property ;
    rdfs:label 'Protection Concerns Description' ;
    rdfs:comment 'Detailed description of any protection concerns identified, including nature of risk and affected population. Confidential to ensure beneficiary safety.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionConcernsNoted rdf:type rdf:Property ;
    rdfs:label 'Protection Concerns Noted' ;
    rdfs:comment 'Flag indicating whether any protection concerns (GBV, child protection, safety risks) were identified during the assessment. Triggers referral protocols.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendations rdf:type rdf:Property ;
    rdfs:label 'Recommendations' ;
    rdfs:comment 'Actionable recommendations derived from the assessment findings for program adjustments, response planning, or advocacy.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportUrl rdf:type rdf:Property ;
    rdfs:label 'Report Url' ;
    rdfs:comment 'Link to the full assessment report document stored in the document management system or shared drive.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleMethodology rdf:type rdf:Property ;
    rdfs:label 'Sample Methodology' ;
    rdfs:comment 'The sampling approach used to select assessment participants. Particularly important for PDM assessments to ensure representativeness.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'The number of individuals, households, or units included in the assessment sample.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Precise date and time when the assessment fieldwork began.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetPopulation rdf:type rdf:Property ;
    rdfs:label 'Target Population' ;
    rdfs:comment 'Description of the population segment or beneficiary group targeted by this assessment (e.g., IDPs, host community, women-headed households, children under 5).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamSize rdf:type rdf:Property ;
    rdfs:label 'Team Size' ;
    rdfs:comment 'Number of enumerators, facilitators, or team members who participated in conducting the assessment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Percent' ;
    rdfs:comment 'For PDM assessments: percentage of beneficiaries who reported using the distributed items as intended. Key indicator of program effectiveness.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'Name or identifier of the staff member who validated the assessment data and findings.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentResponseId rdf:type rdf:Property ;
    rdfs:label 'Assessment Response Id' ;
    rdfs:comment 'Unique identifier for the assessment response record. Primary key for individual survey or interview responses collected during field assessments.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAssessmentRegistrantId rdf:type rdf:Property ;
    rdfs:label 'Primary Assessment Registrant Id' ;
    rdfs:comment 'Foreign key linking to beneficiary.registrant. Business justification: PDM and assessment surveys collect individual beneficiary responses. Required for beneficiary satisfaction tracking, accountability to affected populations (AAP), and individual-level feedback analysi' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registrant .

ind:childrenUnder5Count rdf:type rdf:Property ;
    rdfs:label 'Children Under 5 Count' ;
    rdfs:comment 'Number of children under 5 years of age in the household. Critical for nutrition, health, and protection program targeting.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentDataSharing rdf:type rdf:Property ;
    rdfs:label 'Consent Data Sharing' ;
    rdfs:comment 'Indicator that the respondent has provided informed consent for their data to be shared with partner organizations for service delivery purposes.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentFollowUp rdf:type rdf:Property ;
    rdfs:label 'Consent Follow Up' ;
    rdfs:comment 'Indicator that the respondent has consented to be contacted for follow-up assessments or post-distribution monitoring activities.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:debtBurdenFlag rdf:type rdf:Property ;
    rdfs:label 'Debt Burden Flag' ;
    rdfs:comment 'Indicator that the household is experiencing significant debt burden affecting their ability to meet basic needs. Used for economic vulnerability profiling.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disabilityPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Disability Present Flag' ;
    rdfs:comment 'Indicator that one or more household members have a disability. Used for inclusive programming and accessibility considerations.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displacementDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Displacement Duration Months' ;
    rdfs:comment 'Number of months the household has been displaced from their place of origin. Indicates protractedness of displacement and informs durable solutions programming.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:educationAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Education Access Flag' ;
    rdfs:comment 'Indicator that school-age children in the household have access to education services. Monitors education in emergencies programming effectiveness.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:elderlyOver60Count rdf:type rdf:Property ;
    rdfs:label 'Elderly Over 60 Count' ;
    rdfs:comment 'Number of elderly individuals over 60 years of age in the household. Used for vulnerability assessment and targeted assistance programs.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:foodSecurityScore rdf:type rdf:Property ;
    rdfs:label 'Food Security Score' ;
    rdfs:comment 'Calculated food security index based on household consumption patterns and coping strategies. Higher scores indicate greater food insecurity.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdSize rdf:type rdf:Property ;
    rdfs:label 'Household Size' ;
    rdfs:comment 'Total number of individuals in the respondent household. Key demographic indicator for needs assessment and resource allocation calculations.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Interview Duration Minutes' ;
    rdfs:comment 'Total time in minutes taken to complete the assessment interview. Used for quality control and enumerator performance monitoring.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewLanguage rdf:type rdf:Property ;
    rdfs:label 'Interview Language' ;
    rdfs:comment 'Language in which the assessment interview was conducted. Important for data quality assessment and ensuring linguistic accessibility.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyIncomeUsd rdf:type rdf:Property ;
    rdfs:label 'Monthly Income Usd' ;
    rdfs:comment 'Estimated total monthly household income in United States Dollars. Used for economic vulnerability assessment and cash transfer program targeting.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryNeedCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Need Category' ;
    rdfs:comment 'The most urgent need identified by the respondent household. Used for prioritization and resource allocation in humanitarian response. [ENUM-REF-CANDIDATE: food|water|shelter|health|protection|education|nfi|wash|livelihoods|psychosocial — promote to reference product]' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Referral Required Flag' ;
    rdfs:comment 'Indicator that the assessment identified needs requiring referral to specialized services such as protection, health, or case management.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current lifecycle status of the assessment response indicating data quality validation state and approval workflow position.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelterCondition rdf:type rdf:Property ;
    rdfs:label 'Shelter Condition' ;
    rdfs:comment 'Assessment of the physical condition and habitability of the household shelter. Used for prioritizing shelter repair and upgrade interventions.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionLatitude rdf:type rdf:Property ;
    rdfs:label 'Submission Latitude' ;
    rdfs:comment 'GPS latitude coordinate captured at the time and location of survey submission. Used for spatial analysis and verification of field coverage.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionLongitude rdf:type rdf:Property ;
    rdfs:label 'Submission Longitude' ;
    rdfs:comment 'GPS longitude coordinate captured at the time and location of survey submission. Used for spatial analysis and verification of field coverage.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationNotes rdf:type rdf:Property ;
    rdfs:label 'Validation Notes' ;
    rdfs:comment 'Free-text notes from data validation and quality assurance review. Documents any data quality issues, corrections, or contextual information.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterAccessMinutes rdf:type rdf:Property ;
    rdfs:label 'Water Access Minutes' ;
    rdfs:comment 'Time in minutes required for household members to access safe drinking water. Key WASH (Water Sanitation and Hygiene) indicator for service delivery monitoring.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sitrepId rdf:type rdf:Property ;
    rdfs:label 'Sitrep Id' ;
    rdfs:comment 'Unique identifier for the situation report record.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sitrepApprovedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Sitrep Approved By Staff Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who approved this situation report for submission or publication.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:sitrepStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Sitrep Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who prepared this situation report.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accessImpedimentsCount rdf:type rdf:Property ;
    rdfs:label 'Access Impediments Count' ;
    rdfs:comment 'Number of access impediments or incidents that restricted humanitarian operations during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adminLevel1Name rdf:type rdf:Property ;
    rdfs:label 'Admin Level 1 Name' ;
    rdfs:comment 'Name of the first-level administrative division (province, state, region) covered by this report.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adminLevel2Name rdf:type rdf:Property ;
    rdfs:label 'Admin Level 2 Name' ;
    rdfs:comment 'Name of the second-level administrative division (district, county) covered by this report.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cerfApplicationStatus rdf:type rdf:Property ;
    rdfs:label 'Cerf Application Status' ;
    rdfs:comment 'Status of any CERF funding application related to operations covered by this report.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterCoordinationUpdates rdf:type rdf:Property ;
    rdfs:label 'Cluster Coordination Updates' ;
    rdfs:comment 'Summary of cluster coordination activities, inter-agency meetings, and coordination outcomes during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisisContextSummary rdf:type rdf:Property ;
    rdfs:label 'Crisis Context Summary' ;
    rdfs:comment 'Brief narrative summary of the emergency or crisis context, including key developments during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorSubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Donor Submission Required' ;
    rdfs:comment 'Indicates whether this situation report is required to be submitted to donors as part of grant reporting obligations.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:educationBeneficiariesReached rdf:type rdf:Property ;
    rdfs:label 'Education Beneficiaries Reached' ;
    rdfs:comment 'Number of children and youth reached through education programs during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:foodDistributionsCompleted rdf:type rdf:Property ;
    rdfs:label 'Food Distributions Completed' ;
    rdfs:comment 'Number of food distribution events completed during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fundingGapUsd rdf:type rdf:Property ;
    rdfs:label 'Funding Gap Usd' ;
    rdfs:comment 'Estimated funding gap in US dollars for operations covered by this report.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthConsultationsCompleted rdf:type rdf:Property ;
    rdfs:label 'Health Consultations Completed' ;
    rdfs:comment 'Number of health consultations or medical encounters completed during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hrpProgressPercentage rdf:type rdf:Property ;
    rdfs:label 'Hrp Progress Percentage' ;
    rdfs:comment 'Percentage of Humanitarian Response Plan targets achieved as of the end of the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nfiDistributionsCompleted rdf:type rdf:Property ;
    rdfs:label 'Nfi Distributions Completed' ;
    rdfs:comment 'Number of non-food item distribution events completed during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nfiKitsDistributed rdf:type rdf:Property ;
    rdfs:label 'Nfi Kits Distributed' ;
    rdfs:comment 'Total number of NFI kits or packages distributed during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ochaSubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Ocha Submission Required' ;
    rdfs:comment 'Indicates whether this situation report is required to be submitted to OCHA for coordination purposes.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalConstraints rdf:type rdf:Property ;
    rdfs:label 'Operational Constraints' ;
    rdfs:comment 'Narrative description of operational constraints, access issues, security incidents, or logistical challenges encountered during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionCasesRegistered rdf:type rdf:Property ;
    rdfs:label 'Protection Cases Registered' ;
    rdfs:comment 'Number of new protection cases registered during the reporting period, including GBV, child protection, and other protection concerns.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date when the situation report was officially published or released.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known unique identifier for this situation report, typically following organizational numbering convention.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the situation report (draft, under review, approved, submitted to OCHA/donors, published, archived).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceGapsSummary rdf:type rdf:Property ;
    rdfs:label 'Resource Gaps Summary' ;
    rdfs:comment 'Narrative description of critical resource gaps, funding shortfalls, or supply needs identified during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityIncidentsCount rdf:type rdf:Property ;
    rdfs:label 'Security Incidents Count' ;
    rdfs:comment 'Number of security incidents affecting staff, operations, or beneficiaries during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shelterUnitsProvided rdf:type rdf:Property ;
    rdfs:label 'Shelter Units Provided' ;
    rdfs:comment 'Number of shelter units (tents, transitional shelters, housing units) provided during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalBeneficiariesReached rdf:type rdf:Property ;
    rdfs:label 'Total Beneficiaries Reached' ;
    rdfs:comment 'Total number of unique beneficiaries reached across all sectors during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:washBeneficiariesReached rdf:type rdf:Property ;
    rdfs:label 'Wash Beneficiaries Reached' ;
    rdfs:comment 'Number of beneficiaries reached through WASH interventions during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaderPositionId rdf:type rdf:Property ;
    rdfs:label 'Leader Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Each field team has a designated team leader position in the org structure. HR succession planning, position vacancy management, and accountability frameworks all require knowing which authorized posi' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:activitiesCompletedCount rdf:type rdf:Property ;
    rdfs:label 'Activities Completed Count' ;
    rdfs:comment 'Total number of field activities, distributions, assessments, or service delivery events completed by this team.' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiariesServedCount rdf:type rdf:Property ;
    rdfs:label 'Beneficiaries Served Count' ;
    rdfs:comment 'Cumulative number of unique beneficiaries or PoC (Persons of Concern) served by this team since deployment start.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the monthly operational budget (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationEquipment rdf:type rdf:Property ;
    rdfs:label 'Communication Equipment' ;
    rdfs:comment 'Description of communication equipment assigned to the team (e.g., satellite phones, radios, mobile devices, GPS units) to maintain contact with coordination centers and ensure safety.' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Coverage Area Description' ;
    rdfs:comment 'Textual description of the geographic area or communities covered by this team (e.g., \'Northern District villages\', \'IDP (Internally Displaced Person) camps in Region 3\').' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentEndDate rdf:type rdf:Property ;
    rdfs:label 'Deployment End Date' ;
    rdfs:comment 'Planned or actual date when the team deployment concluded or is scheduled to conclude. Null for ongoing deployments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deploymentStartDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Start Date' ;
    rdfs:comment 'Date when the team was first deployed or became operational.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gpsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled' ;
    rdfs:comment 'Indicates whether GPS tracking is enabled for this team\'s movements and field activities for safety monitoring and activity verification.' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the most recent formal performance review or evaluation conducted for this team.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSitrepDate rdf:type rdf:Property ;
    rdfs:label 'Last Sitrep Date' ;
    rdfs:comment 'Date when the team last submitted a SitRep (Situation Report) to the coordination center or country office.' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobileDataCollectionPlatform rdf:type rdf:Property ;
    rdfs:label 'Mobile Data Collection Platform' ;
    rdfs:comment 'Name of the mobile data collection tool or platform used by this team (e.g., KoboToolbox, CommCare, ODK, DHIS2 mobile).' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyOperationalBudget rdf:type rdf:Property ;
    rdfs:label 'Monthly Operational Budget' ;
    rdfs:comment 'Planned monthly operational budget allocated for this team\'s activities, including salaries, transport, supplies, and per diems.' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Most recent performance assessment rating for the team based on MEL (Monitoring Evaluation and Learning) indicators, service delivery quality, and beneficiary feedback.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'ISO 639-3 three-letter code for the primary language spoken by the team for beneficiary communication (e.g., ENG for English, ARA for Arabic, FRA for French).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyClearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Clearance Level' ;
    rdfs:comment 'Security risk level classification for the team\'s operational area, aligned with UN security phase system. Determines safety protocols and movement restrictions.' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamCode rdf:type rdf:Property ;
    rdfs:label 'Team Code' ;
    rdfs:comment 'Short alphanumeric code used for operational identification and reporting (e.g., \'DT-001\', \'MHU-03\', \'WASH-A\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamName rdf:type rdf:Property ;
    rdfs:label 'Team Name' ;
    rdfs:comment 'Human-readable name or designation of the field team (e.g., \'Delta Distribution Team\', \'Mobile Health Unit 3\', \'WASH Response Team Alpha\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamType rdf:type rdf:Property ;
    rdfs:label 'Team Type' ;
    rdfs:comment 'Classification of the team based on its primary operational function. Distribution teams handle NFI (Non-Food Item) distributions; CHW (Community Health Worker) teams provide mobile health outreach; WASH (Water Sanitation and Hygiene) teams deliver water and sanitation interventions; assessment teams conduct FGD (Focus Group Discussion) and KII (Key Informant Interview); protection teams address GBV (Gender-Based Violence) and child protection; rapid response teams handle emergency deployments; nutrition teams manage SAM (Severe Acute Malnutrition) and GAM (Global Acute Malnutrition) programs; education teams deliver learning programs; shelter teams provide housing assistance; logistics teams manage supply chain and transport. [ENUM-REF-CANDIDATE: distribution|community_health_worker|wash|assessment|protection|rapid_response|nutrition|education|shelter|logistics — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCertifications rdf:type rdf:Property ;
    rdfs:label 'Training Certifications' ;
    rdfs:comment 'Comma-separated list of key training certifications held by team members (e.g., \'SPHERE\', \'CHS\', \'PSS (Psychosocial Support)\', \'GBV Response\', \'First Aid\').' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deployingCountryOfficeId rdf:type rdf:Property ;
    rdfs:label 'Deploying Country Office Id' ;
    rdfs:comment 'Reference to the country office or organizational unit that is sending the field team or staff member on deployment.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CountryOffice .

ind:primaryFieldDeployedStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Field Deployed Staff Member Id' ;
    rdfs:comment 'Reference to the individual staff member being deployed. Nullable if the deployment is for a team rather than an individual.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accommodationType rdf:type rdf:Property ;
    rdfs:label 'Accommodation Type' ;
    rdfs:comment 'Type of accommodation arranged for the deployed personnel during the mission.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Estimated total cost of the deployment in the organization\'s functional currency, including travel, accommodation, per diem, and operational expenses.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deploymentCode rdf:type rdf:Property ;
    rdfs:label 'Deployment Code' ;
    rdfs:comment 'Human-readable unique code for the deployment, typically formatted as country-office-prefix followed by sequential number (e.g., SYR-000123).' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Status' ;
    rdfs:comment 'Current lifecycle status of the deployment: planned (approved but not yet started), active (team is currently deployed), completed (deployment finished successfully), cancelled (deployment did not proceed), or suspended (temporarily paused).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentType rdf:type rdf:Property ;
    rdfs:label 'Deployment Type' ;
    rdfs:comment 'Classification of the deployment purpose: emergency response for rapid humanitarian crises, routine program delivery for ongoing operations, assessment mission for needs evaluation, training for capacity building, surge support for temporary reinforcement, or monitoring visit for MEL activities.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'The planned duration of the deployment in calendar days, calculated from start date to end date.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gisTrackEnabled rdf:type rdf:Property ;
    rdfs:label 'Gis Track Enabled' ;
    rdfs:comment 'Indicates whether GPS tracking and GIS data collection are enabled for this deployment to capture movement and location data for security and operational monitoring.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handoverNotes rdf:type rdf:Property ;
    rdfs:label 'Handover Notes' ;
    rdfs:comment 'Free-text notes documenting key information, lessons learned, outstanding issues, and recommendations for follow-up recorded at the conclusion of the deployment.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageType rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Type' ;
    rdfs:comment 'Level of insurance coverage provided for this deployment, reflecting the risk profile of the destination and activities.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Required' ;
    rdfs:comment 'Indicates whether medical clearance or specific vaccinations are required for this deployment due to health risks at the destination.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purposeDescription rdf:type rdf:Property ;
    rdfs:label 'Purpose Description' ;
    rdfs:comment 'Detailed narrative describing the specific objectives, activities, and expected outcomes of this deployment mission.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseType rdf:type rdf:Property ;
    rdfs:label 'Response Type' ;
    rdfs:comment 'Classification of the humanitarian context for this deployment: rapid onset emergency (sudden disaster), protracted crisis (long-term displacement), development program (routine service delivery), or recovery transition (post-crisis stabilization).' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sitrepReference rdf:type rdf:Property ;
    rdfs:label 'Sitrep Reference' ;
    rdfs:comment 'Reference to the situation report or operational update that triggered or documented this deployment, enabling traceability to humanitarian response coordination.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportationMode rdf:type rdf:Property ;
    rdfs:label 'Transportation Mode' ;
    rdfs:comment 'Primary mode of transportation used to reach the deployment site.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelAuthorizationReference rdf:type rdf:Property ;
    rdfs:label 'Travel Authorization Reference' ;
    rdfs:comment 'Reference number or code for the official travel authorization document approving this deployment, used for duty-of-care and insurance purposes.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessConstraintId rdf:type rdf:Property ;
    rdfs:label 'Access Constraint Id' ;
    rdfs:comment 'Unique identifier for the humanitarian access constraint record.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedShipmentId rdf:type rdf:Property ;
    rdfs:label 'Affected Shipment Id' ;
    rdfs:comment 'Foreign key linking to supply.shipment. Business justification: Access constraints (roadblocks, armed conflict, bureaucratic delays) directly impact shipment delivery. Linking access_constraint to affected shipment enables donor reporting on pipeline delays, insur' ;
    rdfs:domain ind:Field ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:reportingStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Reporting Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Access constraints are reported and owned by specific staff members (security/access officers). Accountability frameworks, OCHA reporting, and incident follow-up all require identifying the responsibl' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:securityIncidentId rdf:type rdf:Property ;
    rdfs:label 'Security Incident Id' ;
    rdfs:comment 'Foreign key linking to field.security_incident. Business justification: Access constraints are often caused by security incidents. The access_constraint table has a boolean flag \'security_incident_linked\' indicating when a constraint is related to a security incident. Add' ;
    rdfs:domain ind:Field ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SecurityIncident .

ind:affectedActivitiesDescription rdf:type rdf:Property ;
    rdfs:label 'Affected Activities Description' ;
    rdfs:comment 'Narrative description of the planned humanitarian activities that were delayed, cancelled, or modified due to the access constraint. May include distribution events, mobile health clinics, WASH interventions, or protection services.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedLocationName rdf:type rdf:Property ;
    rdfs:label 'Affected Location Name' ;
    rdfs:comment 'Name of the geographic location, project site, or supply route affected by the access constraint. May reference a specific village, district, road segment, or border crossing.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedPcode rdf:type rdf:Property ;
    rdfs:label 'Affected Pcode' ;
    rdfs:comment 'OCHA-standard place code (P-Code) identifying the administrative area affected by the constraint. Enables standardized geographic aggregation and mapping across humanitarian datasets.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeRouteAvailable rdf:type rdf:Property ;
    rdfs:label 'Alternative Route Available' ;
    rdfs:comment 'Indicates whether an alternative access route or delivery mechanism is available to reach the affected beneficiaries.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternativeRouteDescription rdf:type rdf:Property ;
    rdfs:label 'Alternative Route Description' ;
    rdfs:comment 'Description of the alternative route, delivery mechanism, or programming modality used to mitigate the access constraint (e.g., river transport, air drop, remote cash transfer, partner-led distribution).' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:armedActorInvolved rdf:type rdf:Property ;
    rdfs:label 'Armed Actor Involved' ;
    rdfs:comment 'Name or identifier of the armed actor (state or non-state) responsible for or associated with the access constraint. Confidential due to security and negotiation sensitivity.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintCode rdf:type rdf:Property ;
    rdfs:label 'Constraint Code' ;
    rdfs:comment 'Externally-known unique code for the access constraint, typically formatted as AC-{COUNTRY}-{SEQUENCE} for tracking and reporting purposes.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintEndDate rdf:type rdf:Property ;
    rdfs:label 'Constraint End Date' ;
    rdfs:comment 'Date when the access constraint was resolved or mitigated, allowing resumption of normal operations. Null if constraint remains active.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constraintNotes rdf:type rdf:Property ;
    rdfs:label 'Constraint Notes' ;
    rdfs:comment 'Additional contextual notes, observations, or lessons learned related to the access constraint. May include details on community dynamics, seasonal patterns, or coordination challenges.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintStartDate rdf:type rdf:Property ;
    rdfs:label 'Constraint Start Date' ;
    rdfs:comment 'Date when the access constraint was first identified or reported. Marks the beginning of the impediment to humanitarian operations.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constraintStatus rdf:type rdf:Property ;
    rdfs:label 'Constraint Status' ;
    rdfs:comment 'Current lifecycle status of the access constraint. Active indicates ongoing impediment; monitoring indicates under observation; mitigated indicates workaround implemented; resolved indicates constraint removed; escalated indicates elevated to senior management or OCHA coordination.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintType rdf:type rdf:Property ;
    rdfs:label 'Constraint Type' ;
    rdfs:comment 'Classification of the humanitarian access constraint affecting field operations. Active conflict includes armed hostilities; road blockage includes physical barriers; administrative denial includes government refusals; armed actor checkpoint includes non-state armed group controls; bureaucratic impediment includes visa/permit delays; weather/natural hazard includes floods, landslides, or extreme weather.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Donor Notification Date' ;
    rdfs:comment 'Date when donors were formally notified of the access constraint and its impact on program delivery. Null if notification not required or not yet sent.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Donor Notification Required' ;
    rdfs:comment 'Indicates whether the access constraint requires formal notification to donors due to significant impact on grant deliverables, budget reallocation, or no-cost extension requests.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationStatus rdf:type rdf:Property ;
    rdfs:label 'Escalation Status' ;
    rdfs:comment 'Indicates whether and to what level the access constraint has been escalated for senior management attention or inter-agency coordination. Used for tracking high-severity incidents requiring strategic intervention.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedBeneficiariesUnreached rdf:type rdf:Property ;
    rdfs:label 'Estimated Beneficiaries Unreached' ;
    rdfs:comment 'Estimated number of beneficiaries (Persons of Concern, PoC) who could not be reached or served due to this access constraint. Used for impact assessment and donor reporting.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactOnProgramTimeline rdf:type rdf:Property ;
    rdfs:label 'Impact On Program Timeline' ;
    rdfs:comment 'Description of how the access constraint affected program implementation timelines, including delays in days/weeks and impact on grant deliverables and reporting milestones.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Mitigation Actions Taken' ;
    rdfs:comment 'Description of actions taken to mitigate or work around the access constraint, such as alternative routes, negotiation with armed actors, remote programming, or partner-led delivery.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationRequired rdf:type rdf:Property ;
    rdfs:label 'Negotiation Required' ;
    rdfs:comment 'Indicates whether humanitarian access negotiation with armed actors, government authorities, or community leaders is required to resolve the constraint.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingSource rdf:type rdf:Property ;
    rdfs:label 'Reporting Source' ;
    rdfs:comment 'Entity or system that reported the access constraint. OCHA (Office for the Coordination of Humanitarian Affairs), UNDSS (UN Department of Safety and Security), INSO (International NGO Safety Organisation), field staff, partner organization, cluster lead, or other source. [ENUM-REF-CANDIDATE: ocha|undss|inso|field_staff|partner_org|cluster_lead|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityIncidentLinked rdf:type rdf:Property ;
    rdfs:label 'Security Incident Linked' ;
    rdfs:comment 'Indicates whether the access constraint is linked to a specific security incident (e.g., attack on humanitarian workers, kidnapping, armed confrontation).' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Severity rating of the access constraint on a scale of 1 to 5, where 1 represents minor delays and 5 represents complete access denial with life-threatening conditions. Used for prioritization and escalation decisions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sitrepIncluded rdf:type rdf:Property ;
    rdfs:label 'Sitrep Included' ;
    rdfs:comment 'Indicates whether this access constraint was included in an OCHA or organizational Situation Report (SitRep) for external stakeholder communication.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primarySecurityFocalPointStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Security Focal Point Staff Member Id' ;
    rdfs:comment 'Reference to the designated security focal point or security manager responsible for managing the incident response and investigation.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:affectedPersonnelCount rdf:type rdf:Property ;
    rdfs:label 'Affected Personnel Count' ;
    rdfs:comment 'Total number of NGO staff, volunteers, or contractors directly affected by the security incident (injured, detained, threatened, or otherwise impacted).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetDamageDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Damage Description' ;
    rdfs:comment 'Narrative description of damage to organizational assets (vehicles, equipment, facilities, supplies) resulting from the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseClosedDate rdf:type rdf:Property ;
    rdfs:label 'Case Closed Date' ;
    rdfs:comment 'Date when the security incident case was formally closed after investigation and resolution (yyyy-MM-dd format).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Taken' ;
    rdfs:comment 'Description of corrective or preventive actions implemented following the security incident to mitigate future risk (e.g., enhanced security protocols, staff training, route changes).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAssetLossUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Asset Loss Usd' ;
    rdfs:comment 'Estimated monetary value of asset damage or loss in United States Dollars (USD) resulting from the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:immediateResponseActions rdf:type rdf:Property ;
    rdfs:label 'Immediate Response Actions' ;
    rdfs:comment 'Description of immediate actions taken by field staff or security personnel in response to the security incident (e.g., evacuation, medical assistance, notification of authorities, lockdown).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Date when the security incident occurred in the field (yyyy-MM-dd format).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentLocationName rdf:type rdf:Property ;
    rdfs:label 'Incident Location Name' ;
    rdfs:comment 'Descriptive name or address of the specific location where the security incident occurred (e.g., village name, road name, facility name).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentSeverity rdf:type rdf:Property ;
    rdfs:label 'Incident Severity' ;
    rdfs:comment 'Severity classification of the security incident based on impact to personnel, assets, and operations. Critical = life-threatening or major asset loss; Major = serious injury or significant damage; Moderate = minor injury or moderate damage; Minor = no injury, minimal damage.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle status of the security incident case in the investigation and resolution workflow.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTime rdf:type rdf:Property ;
    rdfs:label 'Incident Time' ;
    rdfs:comment 'Precise date and time when the security incident occurred, in local time zone (yyyy-MM-ddTHH:mm:ss.SSSXXX format).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Classification of the security incident by nature of threat or event. [ENUM-REF-CANDIDATE: armed_robbery|carjacking|kidnapping|staff_detention|explosive_hazard|civil_unrest|armed_conflict|theft|burglary|assault|sexual_violence|harassment|vehicle_accident|fire|natural_disaster|health_emergency|other — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insoReportDate rdf:type rdf:Property ;
    rdfs:label 'Inso Report Date' ;
    rdfs:comment 'Date when the security incident was reported to INSO, if applicable (yyyy-MM-dd format).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationFindings rdf:type rdf:Property ;
    rdfs:label 'Investigation Findings' ;
    rdfs:comment 'Summary of findings from the security incident investigation, including root causes, contributing factors, and lessons learned.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current status of the internal or external investigation into the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localAuthoritiesReportDate rdf:type rdf:Property ;
    rdfs:label 'Local Authorities Report Date' ;
    rdfs:comment 'Date when the security incident was reported to local authorities, if applicable (yyyy-MM-dd format).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policeCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Police Case Number' ;
    rdfs:comment 'Official case or reference number assigned by local law enforcement authorities for the security incident, if reported.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the security incident was first reported to the organization\'s security management system (yyyy-MM-ddTHH:mm:ss.SSSXXX format).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportedToInso rdf:type rdf:Property ;
    rdfs:label 'Reported To Inso' ;
    rdfs:comment 'Indicates whether the security incident was formally reported to the International NGO Safety Organisation (INSO) for coordination and information sharing among NGOs.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedToLocalAuthorities rdf:type rdf:Property ;
    rdfs:label 'Reported To Local Authorities' ;
    rdfs:comment 'Indicates whether the security incident was reported to local law enforcement or government authorities.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedToUndss rdf:type rdf:Property ;
    rdfs:label 'Reported To Undss' ;
    rdfs:comment 'Indicates whether the security incident was formally reported to the United Nations Department of Safety and Security (UNDSS) for coordination and situational awareness.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:staffFatalityCount rdf:type rdf:Property ;
    rdfs:label 'Staff Fatality Count' ;
    rdfs:comment 'Number of staff members who died as a result of the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:staffInjuredCount rdf:type rdf:Property ;
    rdfs:label 'Staff Injured Count' ;
    rdfs:comment 'Number of staff members who sustained physical injuries as a result of the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:undssReportDate rdf:type rdf:Property ;
    rdfs:label 'Undss Report Date' ;
    rdfs:comment 'Date when the security incident was reported to UNDSS, if applicable (yyyy-MM-dd format).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coldChainRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required Flag' ;
    rdfs:comment 'Indicates whether the commodity requires continuous temperature-controlled storage and transport (cold chain) from procurement through distribution, typical for vaccines and certain medical supplies.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the commodity item across procurement, warehousing, and distribution systems. Often aligned with UNSPSC or internal cataloging standards.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityDescription rdf:type rdf:Property ;
    rdfs:label 'Commodity Description' ;
    rdfs:comment 'Detailed textual description of the commodity including specifications, intended use, and any special characteristics relevant to field operations and beneficiary distribution.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityName rdf:type rdf:Property ;
    rdfs:label 'Commodity Name' ;
    rdfs:comment 'Full descriptive name of the humanitarian commodity or relief item as it appears in procurement documents and distribution manifests.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityStatus rdf:type rdf:Property ;
    rdfs:label 'Commodity Status' ;
    rdfs:comment 'Current lifecycle status of the commodity in the master catalog (e.g., active for procurement and distribution, inactive, discontinued, pending approval, restricted use).' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Restricted Flag' ;
    rdfs:comment 'Indicates whether the commodity is subject to donor-imposed restrictions on use, distribution geography, or beneficiary eligibility, requiring compliance tracking in distribution planning.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:donorRestrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Donor Restriction Notes' ;
    rdfs:comment 'Free-text description of specific donor restrictions or conditions attached to the commodity, including geographic limitations, beneficiary eligibility criteria, or usage constraints.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harmonizedTariffCode rdf:type rdf:Property ;
    rdfs:label 'Harmonized Tariff Code' ;
    rdfs:comment 'International Harmonized System (HS) tariff classification code for the commodity, used for customs clearance, import/export documentation, and duty calculation.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'Specific hazard classification code or category (e.g., flammable, corrosive, toxic, biohazard) if the commodity is flagged as hazardous material, following UN or GHS standards.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether the commodity is classified as hazardous material requiring special handling, storage, and transport procedures per international safety standards.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inKindDonationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'In Kind Donation Eligible Flag' ;
    rdfs:comment 'Indicates whether the commodity is eligible to be received as an in-kind donation from corporate or individual donors, subject to organizational acceptance policies and quality standards.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kitAssemblyFlag rdf:type rdf:Property ;
    rdfs:label 'Kit Assembly Flag' ;
    rdfs:comment 'Indicates whether the commodity is a pre-assembled kit or bundle composed of multiple component items (e.g., hygiene kit, shelter kit, medical kit) rather than a single item.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kitComponentCount rdf:type rdf:Property ;
    rdfs:label 'Kit Component Count' ;
    rdfs:comment 'Number of distinct component items included in the kit or assembly if the commodity is flagged as a kit, used for bill of materials tracking and inventory management.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'Username or identifier of the user who most recently modified the commodity record, supporting audit trail and data governance requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the manufacturer or producer of the commodity, important for quality assurance, traceability, and compliance with donor or regulatory requirements.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Manufacturer-assigned part number or model identifier for the commodity, used for precise specification matching and procurement accuracy.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum quantity that must be ordered from suppliers per procurement transaction, driven by vendor requirements or economic order quantity considerations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Procurement Lead Time Days' ;
    rdfs:comment 'Average number of days required from purchase order issuance to commodity receipt at warehouse, used for supply chain planning and emergency response preparedness.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityCertification rdf:type rdf:Property ;
    rdfs:label 'Quality Certification' ;
    rdfs:comment 'Quality certifications or standards compliance held by the commodity (e.g., ISO, WHO prequalification, FDA approval, CE marking), ensuring safety and efficacy for humanitarian use.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'Inventory level threshold that triggers automatic reorder or procurement action to maintain adequate stock for field operations and emergency response.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Number of days the commodity remains usable and safe from the date of manufacture or receipt, critical for inventory rotation and distribution planning.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text instructions for special handling, storage, or transport requirements not captured in structured fields, including fragility, orientation, stacking limits, or security considerations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sphereCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sphere Compliant Flag' ;
    rdfs:comment 'Indicates whether the commodity meets Sphere Humanitarian Charter and Minimum Standards for quality, safety, and appropriateness in humanitarian response.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardUnitCost rdf:type rdf:Property ;
    rdfs:label 'Standard Unit Cost' ;
    rdfs:comment 'Standard or average cost per unit of measure for the commodity, used for budgeting, procurement planning, and financial reporting. Currency is organizational default unless otherwise specified.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageHumidityMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Max Percent' ;
    rdfs:comment 'Maximum relative humidity percentage allowed in storage environment to prevent commodity degradation, mold, or spoilage.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max Celsius' ;
    rdfs:comment 'Maximum storage temperature in degrees Celsius required to maintain commodity integrity and safety, particularly critical for medical supplies and cold-chain items.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min Celsius' ;
    rdfs:comment 'Minimum storage temperature in degrees Celsius required to maintain commodity integrity and safety, particularly critical for medical supplies and cold-chain items.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Secondary classification providing finer granularity within the primary commodity category (e.g., within WASH: hygiene kits, water purification tablets, sanitation supplies).' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumePerUnitCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Per Unit Cubic Meters' ;
    rdfs:comment 'Volume in cubic meters occupied by a single unit of the commodity, used for warehouse space planning, transport capacity optimization, and last-mile logistics.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightPerUnitKg rdf:type rdf:Property ;
    rdfs:label 'Weight Per Unit Kg' ;
    rdfs:comment 'Weight in kilograms of a single unit of the commodity, used for logistics planning, freight cost calculation, and warehouse capacity management.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Manager Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Warehouses require designated managers for accountability, security clearance, inventory oversight, and operational decision-making. Nonprofit supply chain audits and donor compliance reports require ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accessRestrictions rdf:type rdf:Property ;
    rdfs:label 'Access Restrictions' ;
    rdfs:comment 'Description of any access restrictions or special requirements for entering the warehouse facility.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line of the warehouse facility.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for additional location details such as building or unit number.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date when the warehouse facility was officially commissioned and became operational.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsBonded rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded' ;
    rdfs:comment 'Indicates whether the warehouse operates as a customs bonded facility allowing duty-free storage of international goods.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the warehouse facility was decommissioned and ceased operations, if applicable.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emergencyAccess247 rdf:type rdf:Property ;
    rdfs:label 'Emergency Access 24 7' ;
    rdfs:comment 'Indicates whether the warehouse can be accessed 24 hours a day, 7 days a week for emergency response operations.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the warehouse based on its role in the humanitarian supply network.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forkliftCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Forklift Capacity Kg' ;
    rdfs:comment 'Maximum lifting capacity of forklifts available at the warehouse, measured in kilograms.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gisAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Gis Accuracy Meters' ;
    rdfs:comment 'Accuracy of the GIS coordinates measured in meters, indicating the precision of the location data.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Indicates whether the warehouse is certified to store hazardous materials according to international standards.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent safety, security, or compliance inspection of the warehouse facility.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loadingDocksCount rdf:type rdf:Property ;
    rdfs:label 'Loading Docks Count' ;
    rdfs:comment 'Number of loading docks available at the warehouse for receiving and dispatching cargo.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managingEntity rdf:type rdf:Property ;
    rdfs:label 'Managing Entity' ;
    rdfs:comment 'Type of entity responsible for the day-to-day management and operation of the warehouse facility.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalHours rdf:type rdf:Property ;
    rdfs:label 'Operational Hours' ;
    rdfs:comment 'Standard operating hours of the warehouse facility including days and times of operation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership or usage arrangement for the warehouse facility.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity M3' ;
    rdfs:comment 'Total storage capacity of the warehouse measured in cubic meters (m³).' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCapacityPallets rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Pallets' ;
    rdfs:comment 'Total storage capacity of the warehouse measured in standard pallet positions.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Indicates whether the warehouse has temperature control capability for cold-chain commodities.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureRangeMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max C' ;
    rdfs:comment 'Maximum temperature that can be maintained in the warehouse for cold-chain storage, measured in degrees Celsius.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min C' ;
    rdfs:comment 'Minimum temperature that can be maintained in the warehouse for cold-chain storage, measured in degrees Celsius.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code for the warehouse facility used in logistics documentation and tracking systems.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseName rdf:type rdf:Property ;
    rdfs:label 'Warehouse Name' ;
    rdfs:comment 'Official name of the warehouse facility as recognized by the organization and partners.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsSystemName rdf:type rdf:Property ;
    rdfs:label 'Wms System Name' ;
    rdfs:comment 'Name of the warehouse management system software used to track inventory and operations at this facility.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Unique identifier for the vendor record. Primary key for the vendor entity.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'The vendor\'s primary bank account number for payment processing and fund transfers.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Bank Swift Code' ;
    rdfs:comment 'SWIFT/BIC code of the vendor\'s bank, used for international wire transfers and cross-border payments.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blacklistEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Blacklist Effective Date' ;
    rdfs:comment 'The date when the vendor blacklist or debarment status became effective.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blacklistExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Blacklist Expiry Date' ;
    rdfs:comment 'The date when the vendor blacklist or debarment status expires, after which the vendor may be eligible for reinstatement (nullable for permanent debarments).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blacklistFlag rdf:type rdf:Property ;
    rdfs:label 'Blacklist Flag' ;
    rdfs:comment 'Boolean indicator (True/False) showing whether the vendor is currently blacklisted or debarred from humanitarian procurement due to fraud, corruption, poor performance, or ethical violations.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blacklistReason rdf:type rdf:Property ;
    rdfs:label 'Blacklist Reason' ;
    rdfs:comment 'Detailed explanation of why the vendor was blacklisted or debarred, including the nature of the violation and the decision authority.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOperation rdf:type rdf:Property ;
    rdfs:label 'Country Of Operation' ;
    rdfs:comment 'Primary country where the vendor operates or is registered, using ISO 3166-1 alpha-3 country code (e.g., USA, GBR, KEN).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetSize rdf:type rdf:Property ;
    rdfs:label 'Fleet Size' ;
    rdfs:comment 'Number of vehicles or transport units in the vendor\'s fleet (applicable for transport and logistics providers). Indicates capacity for humanitarian logistics operations.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Flag' ;
    rdfs:comment 'Boolean indicator (True/False) showing whether the vendor holds Good Manufacturing Practice (GMP) certification, required for pharmaceutical and medical supply vendors.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:humanitarianNetworkMembership rdf:type rdf:Property ;
    rdfs:label 'Humanitarian Network Membership' ;
    rdfs:comment 'Comma-separated list of humanitarian logistics networks or consortia the vendor is a member of, such as WFP Logistics Hub Framework (LHF), UNHRD (UN Humanitarian Response Depot), or Logistics Cluster.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoCertification rdf:type rdf:Property ;
    rdfs:label 'Iso Certification' ;
    rdfs:comment 'Comma-separated list of ISO certifications held by the vendor, such as ISO 9001 (Quality Management), ISO 14001 (Environmental Management), or ISO 45001 (Occupational Health and Safety).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Last Performance Score' ;
    rdfs:comment 'The most recent performance score assigned to the vendor during the last performance review, typically on a scale of 0-100 or 0-5, measuring quality, delivery, compliance, and responsiveness.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Standard payment terms offered by the vendor, expressed as the number of days from invoice date to payment due date (e.g., 30, 60, 90 days).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Classification tier based on the vendor\'s historical performance, quality, delivery reliability, and compliance with humanitarian standards. Tier 1 represents preferred vendors with excellent track records.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prequalificationDate rdf:type rdf:Property ;
    rdfs:label 'Prequalification Date' ;
    rdfs:comment 'The date when the vendor successfully completed the prequalification process and was approved for humanitarian procurement.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prequalificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Prequalification Expiry Date' ;
    rdfs:comment 'The date when the vendor\'s prequalification status expires and requires renewal or reassessment.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prequalificationStatus rdf:type rdf:Property ;
    rdfs:label 'Prequalification Status' ;
    rdfs:comment 'Indicates whether the vendor has completed and passed the organization\'s prequalification process for humanitarian procurement, ensuring compliance with quality, ethical, and operational standards.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'The vendor\'s tax identification number (TIN), VAT number, or equivalent tax registration identifier issued by the country of operation.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportModesOffered rdf:type rdf:Property ;
    rdfs:label 'Transport Modes Offered' ;
    rdfs:comment 'Comma-separated list of transportation modes offered by the vendor (applicable for logistics and transport providers), such as air freight, sea freight, road transport, rail transport, or last-mile delivery.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unVendorNumber rdf:type rdf:Property ;
    rdfs:label 'Un Vendor Number' ;
    rdfs:comment 'The unique vendor registration number assigned by the United Nations Global Marketplace (UNGM) for vendors participating in UN procurement.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Internal unique alphanumeric code assigned to the vendor for procurement and supply chain operations.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'The full legal name of the vendor, supplier, or service provider as registered with governing authorities.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current lifecycle status of the vendor in the procurement system, indicating whether the vendor is eligible for new contracts and purchase orders.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Classification of the vendor based on the primary service or product category they provide in the humanitarian supply chain. [ENUM-REF-CANDIDATE: commodity_supplier|manufacturer|freight_forwarder|clearing_agent|trucking_company|air_cargo_operator|last_mile_delivery_partner|warehouse_operator|service_provider|customs_broker|cold_chain_provider — promote to reference product]' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseCapacitySqm rdf:type rdf:Property ;
    rdfs:label 'Warehouse Capacity Sqm' ;
    rdfs:comment 'Total warehouse storage capacity in square meters available from the vendor (applicable for warehouse operators and logistics providers).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Unique system identifier for the purchase order record. Primary key.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:approvedByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Approved By Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: NGO procurement compliance (USAID, ECHO, UN rules) requires a named approving officer on every PO for donor audits and segregation-of-duties controls. The PO tracks approval_workflow_status and approv' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:awardBudgetLineId rdf:type rdf:Property ;
    rdfs:label 'Award Budget Line Id' ;
    rdfs:comment 'Foreign key linking to grant.award_budget_line. Business justification: POs must be coded to a specific donor award budget line for expenditure tracking and donor financial reporting. NGO finance teams post PO commitments against award_budget_line to monitor burn rates an' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AwardBudgetLine .

ind:procurementRequestId rdf:type rdf:Property ;
    rdfs:label 'Procurement Request Id' ;
    rdfs:comment 'Foreign key linking to supply.procurement_request. Business justification: A purchase order is the fulfillment of a procurement request — the PR is the parent document that authorizes procurement, and the PO is the resulting transactional document issued to a vendor. Adding ' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementRequest .

ind:requestingOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Requesting Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: NGO internal charge-back, budget accountability, and donor reporting require POs to be attributed to the requesting org unit directly. While procurement_request links to org_unit, the PO itself needs ' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Date when goods were actually received and verified. Populated upon goods receipt and used for vendor on-time delivery KPI tracking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Status' ;
    rdfs:comment 'Current status of the purchase order in the multi-level approval workflow. Tracks progression through procurement authority levels per delegation of authority matrix.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddress rdf:type rdf:Property ;
    rdfs:label 'Delivery Address' ;
    rdfs:comment 'Full physical delivery address for commodity shipment. Captured for logistics coordination and proof of delivery. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Flag' ;
    rdfs:comment 'Indicates whether this purchase order was issued under emergency procurement procedures due to humanitarian crisis or disaster response. Allows expedited approval and relaxed competitive bidding requirements per CERF (Central Emergency Response Fund) guidelines.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erpDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Erp Document Reference' ;
    rdfs:comment 'Reference number or document ID from the source ERP system (SAP S/4HANA, Unit4, etc.). Used for system integration, reconciliation, and audit trail back to operational system of record.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Vendor-committed delivery date as agreed in the purchase order. Used for goods receipt scheduling and vendor performance measurement.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Total freight, shipping, and logistics charges for delivery of commodities. Critical for last-mile logistics cost tracking.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Status' ;
    rdfs:comment 'Aggregate status of goods receipt across all purchase order line items. Used for three-way matching (PO-GRN-Invoice) and inventory management.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'Delivery terms defining the division of costs and risks between buyer and seller per Incoterms 2020 (e.g., DDP = Delivered Duty Paid, FOB = Free On Board). Critical for humanitarian supply chain cost allocation. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceMatchingStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Matching Status' ;
    rdfs:comment 'Status of three-way matching between purchase order, goods receipt note, and vendor invoice. Critical for accounts payable processing and financial control per 2 CFR 200.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Agreed payment terms with vendor (e.g., Net 30, Net 60, 50% advance / 50% on delivery). Governs accounts payable scheduling and cash flow management.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'Date when the purchase order was officially issued to the vendor. Principal business event timestamp for procurement tracking and lead time calculation.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known unique purchase order document number issued to vendor. Business identifier used in procurement communications and three-way matching (PO-GRN-Invoice).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order in the procurement workflow. Tracks progression from draft through approval, issuance, goods receipt, and closure. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|issued|partially_received|fully_received|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order type: standard (one-time procurement), blanket (recurring deliveries), contract (long-term agreement), emergency (urgent humanitarian response), framework (pre-negotiated terms).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementMethod rdf:type rdf:Property ;
    rdfs:label 'Procurement Method' ;
    rdfs:comment 'Method used to select the vendor: competitive bidding, request for quotation (RFQ), sole source justification, framework agreement, or emergency procurement waiver. Required for donor compliance and audit trail per 2 CFR 200.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Date by which the requesting program needs the commodities delivered. Used for procurement lead time planning and emergency response timeline tracking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Sum of all line item amounts before taxes, duties, and freight charges. Base procurement value for budget tracking.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax amount (VAT, GST, sales tax) applied to this purchase order. May be zero for tax-exempt humanitarian procurement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Grand total value of the purchase order including subtotal, taxes, freight, and all other charges. Used for budget commitment and three-way matching.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Unique identifier for the goods receipt transaction. Primary key for this entity.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:purchaseOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Line Id' ;
    rdfs:comment 'Foreign key linking to supply.purchase_order_line. Business justification: Goods receipts are processed against specific purchase order lines (line-level receipt matching), not just the header PO. Adding purchase_order_line_id enables three-way matching at the line level (PO' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrderLine .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Reference to the inbound shipment or logistics movement that delivered these goods.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:waybillId rdf:type rdf:Property ;
    rdfs:label 'Waybill Id' ;
    rdfs:comment 'Foreign key linking to supply.waybill. Business justification: Goods receipts are recorded when commodities arrive at a warehouse. The waybill is the shipping document that accompanies the delivery. The goods_receipt table has delivery_note_number (STRING) which ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Waybill .

ind:conditionOnArrival rdf:type rdf:Property ;
    rdfs:label 'Condition On Arrival' ;
    rdfs:comment 'Assessment of the physical condition of the goods upon receipt. Good indicates acceptable condition, damaged indicates physical damage, expired indicates past expiry date, partial_damage indicates some units damaged, quality_issue indicates substandard quality.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Date' ;
    rdfs:comment 'Date on which the goods cleared customs and were released for delivery to the warehouse or field location.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsCleared rdf:type rdf:Property ;
    rdfs:label 'Customs Cleared' ;
    rdfs:comment 'Indicates whether the goods have cleared customs and import formalities. True if cleared, False if pending customs clearance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicates whether there was a discrepancy between ordered and received quantities or condition. True if discrepancy exists, False if receipt matches order exactly.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Detailed notes explaining any discrepancies in quantity, quality, or condition between what was ordered and what was received. Includes reasons for rejection or partial acceptance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCharges rdf:type rdf:Property ;
    rdfs:label 'Freight Charges' ;
    rdfs:comment 'Transportation and freight costs associated with this goods receipt, if separately tracked.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Indicates whether the received goods require formal quality inspection before being released to inventory. True for medical supplies, food items, and high-value commodities.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Status of the quality inspection process. Pending indicates inspection not yet completed, passed indicates goods approved for use, failed indicates goods rejected, waived indicates inspection was not required.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Supplier or donor lot number for the received commodity, used for tracking and quality control purposes.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'Date on which the commodity was manufactured, used to calculate shelf life and ensure quality standards.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'The quantity of the commodity that was originally ordered on the purchase order or expected from the donation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'The actual quantity of the commodity physically received and accepted at the warehouse or field location.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRejected rdf:type rdf:Property ;
    rdfs:label 'Quantity Rejected' ;
    rdfs:comment 'The quantity of the commodity that was rejected upon receipt due to damage, expiry, or quality issues.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The date on which the goods were physically received at the warehouse or field location. This is the principal business event date for this transaction.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Document Number' ;
    rdfs:comment 'The externally-known unique document number for this goods receipt, typically generated by the ERP system (e.g., SAP goods receipt document number).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the goods receipt transaction. Draft indicates pending finalization, posted indicates completed and inventory updated, reversed indicates a correction was applied, cancelled indicates the receipt was voided.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Precise date and time when the goods receipt was recorded in the system, including time zone information.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Unique serial number for individually tracked items such as medical equipment, vehicles, or high-value assets.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Specific storage location or bin within the warehouse where the received goods were placed. Used for precise inventory tracking.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Total cost of the goods received, calculated as quantity received multiplied by unit cost. Used for accounts payable and budget tracking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Cost per unit of the received commodity as stated on the purchase order or donation valuation. Used for inventory valuation and financial accounting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryBalanceId rdf:type rdf:Property ;
    rdfs:label 'Inventory Balance Id' ;
    rdfs:comment 'Unique identifier for the inventory balance record. Primary key for this entity.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCountStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Last Count Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Physical inventory counts in NGO warehouses require a named responsible staff member for audit accountability, donor commodity verification reports, and SPHERE/cluster compliance. The inventory_balanc' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:donorRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Restriction Flag' ;
    rdfs:comment 'Indicates whether this inventory is subject to donor-imposed restrictions on use, distribution, or geographic allocation. True if restricted, False if unrestricted.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Expiration or best-before date for perishable commodities such as medical supplies, food, or nutrition items. Used for FEFO (First Expired First Out) distribution planning.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inKindDonationFlag rdf:type rdf:Property ;
    rdfs:label 'In Kind Donation Flag' ;
    rdfs:comment 'Indicates whether this inventory was received as an in-kind donation rather than purchased. True if in-kind donation, False if purchased. Used for donor reporting and GAAP compliance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'Date of the most recent inventory transaction (receipt, issue, transfer, or adjustment) for this balance record. Used for aging analysis and pipeline monitoring.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or cycle count for this commodity at this warehouse. Used for inventory accuracy tracking and audit compliance.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'Maximum stock capacity or target level for this commodity at this warehouse. Used for inventory optimization and storage planning.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipelineStatus rdf:type rdf:Property ;
    rdfs:label 'Pipeline Status' ;
    rdfs:comment 'Current status of the inventory balance in the commodity pipeline. Used for OCHA cluster reporting and pipeline gap analysis.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Net quantity available for new distribution allocations. Calculated as quantity_on_hand minus quantity_reserved minus quantity_quarantined.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityInTransit rdf:type rdf:Property ;
    rdfs:label 'Quantity In Transit' ;
    rdfs:comment 'Quantity currently in transit to this warehouse from suppliers or other warehouses. Not yet available for distribution.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current physical stock quantity available in the warehouse. Represents the total inventory balance at the snapshot date.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityQuarantined rdf:type rdf:Property ;
    rdfs:label 'Quantity Quarantined' ;
    rdfs:comment 'Quantity held in quarantine due to quality issues, expiration concerns, or pending inspection. Not available for distribution.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Quantity allocated or reserved for planned distribution events but not yet dispatched. Reduces available stock for new allocations.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderLevel rdf:type rdf:Property ;
    rdfs:label 'Reorder Level' ;
    rdfs:comment 'Minimum stock level threshold that triggers a replenishment order. Used for pipeline management and pre-positioning decisions.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'Date for which this inventory balance snapshot is recorded. Supports historical trend analysis and time-series reporting.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Required storage condition for the commodity. Used for warehouse capacity planning and quality assurance.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValuation rdf:type rdf:Property ;
    rdfs:label 'Total Valuation' ;
    rdfs:comment 'Total monetary value of the inventory balance. Calculated as quantity_on_hand multiplied by unit_cost. Used for financial statements and donor reporting.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseLocation rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location' ;
    rdfs:comment 'Geographic location of the warehouse including city, region, or country. Used for logistics planning and SitRep reporting.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Unique identifier for the stock movement transaction record. Primary key for the stock movement log.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_finding. Business justification: Inventory discrepancies, unauthorized movements, or missing documentation identified during audits become findings requiring corrective action. Real business process: audit resolution and inventory co' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:primaryStockWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Warehouse Id' ;
    rdfs:comment 'Identifier of the warehouse, distribution point, or field location to which the commodity is being moved. Null for issue transactions to final beneficiaries or write-offs.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:sourceWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Source Warehouse Id' ;
    rdfs:comment 'Foreign key linking to supply.warehouse. Business justification: Stock movements track inventory transfers between warehouses or within a warehouse. The source_location_id (BIGINT) currently holds the origin warehouse reference. Renaming to source_warehouse_id and ' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:authorizingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Authorizing Officer Name' ;
    rdfs:comment 'Full name of the staff member who authorized this stock movement. Denormalized for reporting and audit trail readability.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the transport carrier or logistics service provider responsible for moving the commodity (applicable for transfers and receipts). Null for internal hand-carry movements.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countTeamReference rdf:type rdf:Property ;
    rdfs:label 'Count Team Reference' ;
    rdfs:comment 'Reference identifier for the physical inventory count team or cycle that generated this movement record (applicable only for movement_type = physical_count). Links to physical inventory count documentation.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Date on which quality inspection was performed on the commodity. Null if inspection was not required or waived.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Name of the staff member or third-party inspector who performed the quality inspection. Null if inspection was not required or waived.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementDate rdf:type rdf:Property ;
    rdfs:label 'Movement Date' ;
    rdfs:comment 'Business date on which the stock movement occurred or is scheduled to occur. This is the operational event date, distinct from system audit timestamps.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:movementNumber rdf:type rdf:Property ;
    rdfs:label 'Movement Number' ;
    rdfs:comment 'Externally-known unique reference number for this stock movement transaction, used for audit trail and cross-system reconciliation. Format typically includes movement type prefix and sequential number.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of the stock movement transaction. Tracks workflow state from initiation through completion or cancellation. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|in_transit|completed|cancelled|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Timestamp' ;
    rdfs:comment 'Precise date and time when the physical stock movement was executed or recorded. Used for detailed audit trail and sequence reconstruction.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'Classification of the stock movement transaction. Receipt = goods received into warehouse; Issue = goods distributed/issued out; Transfer = movement between warehouses; Adjustment = correction entry; Physical_count = reconciliation from physical inventory count; Loss = documented loss/damage; Write_off = removal from inventory due to expiry/obsolescence. [ENUM-REF-CANDIDATE: receipt|issue|transfer|adjustment|physical_count|loss|write_off — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Result of quality inspection performed on the commodity at the time of receipt or movement. Pending = inspection not yet completed; Passed = meets quality standards; Failed = rejected; Waived = inspection requirement waived for emergency; Not_required = commodity type does not require inspection.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of the commodity being moved in the transaction. Always positive; movement direction is determined by movement_type. Precision supports fractional units for medical supplies and bulk commodities.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code explaining the business reason for the stock movement. Critical for loss analysis, donor reporting, and pipeline management. Normal_receipt = routine procurement; Emergency_receipt = rapid response; Beneficiary_distribution = direct aid delivery; Program_issue = program consumption; Inter_warehouse_transfer = logistics optimization; Count_adjustment = inventory reconciliation; Expiry/Damage/Theft/Loss_in_transit/Obsolescence = loss categories. [ENUM-REF-CANDIDATE: normal_receipt|emergency_receipt|beneficiary_distribution|program_issue|inter_warehouse_transfer|count_adjustment|expiry|damage|theft|loss_in_transit|obsolescence — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text detailed explanation of the reason for the stock movement, especially for adjustments, losses, and write-offs. Provides context beyond the standardized reason code.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'Unique number of the source document (GRN, waybill, distribution order, count sheet, etc.) that authorizes or records this movement. Provides full audit trail linkage.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of source document that authorizes or records this stock movement. GRN = Goods Received Note; Waybill = transport document; Distribution_order = beneficiary distribution plan; Count_sheet = physical inventory count; Adjustment_memo = correction authorization; Loss_report = documented loss/damage; Write_off_authorization = disposal approval. [ENUM-REF-CANDIDATE: GRN|waybill|distribution_order|count_sheet|adjustment_memo|loss_report|write_off_authorization — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking number for the shipment associated with this stock movement. Enables real-time visibility of in-transit commodities.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Mode of transportation used for this stock movement (applicable for transfers and receipts). Road = truck/vehicle; Air = aircraft; Sea = ship/barge; Rail = train; Pipeline = bulk liquid/gas; Hand_carry = manual transport for small quantities.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPlanId rdf:type rdf:Property ;
    rdfs:label 'Distribution Plan Id' ;
    rdfs:comment 'Unique identifier for the distribution plan. Primary key for the distribution plan entity.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionPlan .

ind:awardBudgetId rdf:type rdf:Property ;
    rdfs:label 'Award Budget Id' ;
    rdfs:comment 'Foreign key linking to grant.award_budget. Business justification: Distribution plans are funded against a specific approved award budget period. NGO program teams must confirm the distribution plan is within the approved award budget before execution, supporting \'di' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AwardBudget .

ind:primaryDistributionStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who approved this distribution plan.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:targetPopulationId rdf:type rdf:Property ;
    rdfs:label 'Target Population Id' ;
    rdfs:comment 'Foreign key linking to program.target_population. Business justification: Distribution plan to target population linkage: distribution plans are designed to serve specific target populations (e.g., IDPs, refugees). Direct linkage enables beneficiary coverage analysis — comp' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TargetPopulation .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether formal approval is required before this distribution plan can be executed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficiaryCategory rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Category' ;
    rdfs:comment 'Primary category of beneficiaries targeted by this distribution plan. IDP (Internally Displaced Person), PoC (Person of Concern), refugee, host community, returnee, or other vulnerable population classification.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinationCluster rdf:type rdf:Property ;
    rdfs:label 'Coordination Cluster' ;
    rdfs:comment 'Humanitarian cluster or sector coordinating this distribution (e.g., Food Security, WASH, Shelter, Health, Protection).' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionDurationDays rdf:type rdf:Property ;
    rdfs:label 'Distribution Duration Days' ;
    rdfs:comment 'Planned duration in days for the distribution activities to be completed.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Distribution Frequency' ;
    rdfs:comment 'Planned frequency of distribution events under this plan (one-time, recurring weekly, monthly, etc.).' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Budget Amount' ;
    rdfs:comment 'Estimated total budget allocated for this distribution plan including commodity costs, logistics, and operational expenses.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTotalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Volume M3' ;
    rdfs:comment 'Estimated total volume in cubic meters of all commodities to be distributed under this plan.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTotalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Weight Kg' ;
    rdfs:comment 'Estimated total weight in kilograms of all commodities to be distributed under this plan.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Primary funding source or donor supporting this distribution plan (e.g., USAID, DFID, CERF, private donations).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageAdmin1 rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Admin1' ;
    rdfs:comment 'First-level administrative division (province, state, region) where distribution will occur.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageAdmin2 rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Admin2' ;
    rdfs:comment 'Second-level administrative division (district, county) where distribution will occur.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageAdmin3 rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Admin3' ;
    rdfs:comment 'Third-level administrative division (sub-district, municipality) where distribution will occur.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageCountry rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Country' ;
    rdfs:comment 'Three-letter ISO country code where the distribution will take place.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melIndicatorAlignment rdf:type rdf:Property ;
    rdfs:label 'Mel Indicator Alignment' ;
    rdfs:comment 'Key MEL indicators or KPIs (Key Performance Indicators) that this distribution plan contributes to achieving.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Scheduled date when distribution activities are planned to be completed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled date when distribution activities are planned to begin.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetBeneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Target Beneficiary Count' ;
    rdfs:comment 'Planned number of individual beneficiaries or households to be reached by this distribution plan.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetHouseholdCount rdf:type rdf:Property ;
    rdfs:label 'Target Household Count' ;
    rdfs:comment 'Planned number of households to receive assistance under this distribution plan.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:constituentId rdf:type rdf:Property ;
    rdfs:label 'Constituent Id' ;
    rdfs:comment 'Reference to the donor organization funding the commodities in this distribution order. Links order to donor restrictions and reporting requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:primaryDistributionIssuingWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Issuing Warehouse Id' ;
    rdfs:comment 'Reference to the warehouse from which commodities will be released and dispatched. Source location for stock movement.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:customsClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Required Flag' ;
    rdfs:comment 'Indicates whether this distribution order requires customs clearance for cross-border shipment. Triggers customs documentation and compliance processes.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsReference rdf:type rdf:Property ;
    rdfs:label 'Customs Reference' ;
    rdfs:comment 'Reference number for customs clearance documentation if cross-border shipment is required. Used for tracking and compliance verification.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Special instructions or notes for the delivery of commodities to the destination distribution point. May include access constraints, security protocols, or handling requirements.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchDate rdf:type rdf:Property ;
    rdfs:label 'Dispatch Date' ;
    rdfs:comment 'Date when commodities were physically dispatched from the issuing warehouse. Marks the start of last-mile logistics execution.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:driverContact rdf:type rdf:Property ;
    rdfs:label 'Driver Contact' ;
    rdfs:comment 'Contact phone number for the driver during transit. Enables real-time communication for tracking and issue resolution during delivery.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'Name of the driver responsible for transporting the commodities. Used for accountability and security purposes in field operations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Flag' ;
    rdfs:comment 'Indicates whether this distribution order is part of an emergency response operation. True for rapid-onset disaster or crisis response orders.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedValueUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Value Usd' ;
    rdfs:comment 'Estimated total monetary value of all commodities in this distribution order, expressed in US dollars. Used for financial tracking and donor reporting.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdCount rdf:type rdf:Property ;
    rdfs:label 'Household Count' ;
    rdfs:comment 'Estimated number of households that will be served by this distribution order. Key metric for humanitarian assistance planning and reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalSuppliesFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Supplies Flag' ;
    rdfs:comment 'Indicates whether this distribution order contains medical supplies or pharmaceuticals. Triggers special handling and regulatory compliance requirements.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nfiFlag rdf:type rdf:Property ;
    rdfs:label 'Nfi Flag' ;
    rdfs:comment 'Indicates whether this distribution order contains Non-Food Items such as shelter materials, hygiene kits, or household supplies. Used for commodity classification.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Date when the distribution order was created and entered into the system. Business event timestamp for order initiation.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Human-readable unique order number assigned to this distribution order for tracking and reference purposes. Format: DO-YYYYMMDD-sequence.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the distribution order. Tracks progression from draft through approval, dispatch, transit, delivery, and closure. [ENUM-REF-CANDIDATE: draft|approved|dispatched|in_transit|delivered|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Planned date for delivery of commodities to the destination distribution point. Used for logistics planning and beneficiary communication.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialHandlingRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Handling Requirements' ;
    rdfs:comment 'Specific handling requirements for commodities in this order, such as fragile items, hazardous materials, or temperature-sensitive goods. Ensures proper care during transport.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCommodityLines rdf:type rdf:Property ;
    rdfs:label 'Total Commodity Lines' ;
    rdfs:comment 'Total number of distinct commodity line items included in this distribution order. Summary count for order complexity assessment.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'Aggregate quantity of all commodities in this distribution order, expressed in standard units. Summary measure for order volume.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'Total volume of all commodities in this distribution order, measured in cubic meters. Used for warehouse space and transport capacity planning.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total weight of all commodities in this distribution order, measured in kilograms. Used for transport planning and capacity management.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportCostUsd rdf:type rdf:Property ;
    rdfs:label 'Transport Cost Usd' ;
    rdfs:comment 'Actual or estimated cost of transporting commodities from warehouse to distribution point, expressed in US dollars. Used for budget tracking and cost analysis.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleRegistration rdf:type rdf:Property ;
    rdfs:label 'Vehicle Registration' ;
    rdfs:comment 'Registration number or identifier of the vehicle used for transporting commodities. Used for fleet management and security tracking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waybillReference rdf:type rdf:Property ;
    rdfs:label 'Waybill Reference' ;
    rdfs:comment 'Reference number of the transport waybill or shipping document accompanying the commodity shipment. Used for tracking and proof of dispatch.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchedByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Dispatched By Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: NGO supply chain accountability requires a named NGO staff member who authorized and dispatched each waybill — distinct from the external driver. This supports internal audit, loss/diversion investiga' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:originWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Origin Warehouse Id' ;
    rdfs:comment 'Reference to the warehouse from which the commodities were dispatched. Links to warehouse master data.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:waybillWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Waybill Warehouse Id' ;
    rdfs:comment 'Reference to the destination location (warehouse, distribution point, or project site) where commodities are being delivered.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:arrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Arrival Timestamp' ;
    rdfs:comment 'Precise date and time when the vehicle arrived at the destination location. Used to calculate actual transit time and delivery performance.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Official customs declaration or clearance document number for cross-border shipments. Required for international humanitarian aid movements.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Departure Timestamp' ;
    rdfs:comment 'Precise date and time when the vehicle departed from the origin warehouse. Used for transit time analysis and security tracking.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discrepancyQuantity rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Quantity' ;
    rdfs:comment 'Difference between total dispatched and total received quantities. Positive values indicate shortages, negative values indicate overages.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Total distance in kilometers between origin and destination. Used for cost calculation and transit time estimation.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverContactNumber rdf:type rdf:Property ;
    rdfs:label 'Driver Contact Number' ;
    rdfs:comment 'Mobile phone number of the driver for real-time communication during transit. Essential for emergency contact and route coordination.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Driver License Number' ;
    rdfs:comment 'Official driver license number for verification and compliance purposes. Required for audit trails and security checks.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Planned or expected date of arrival at destination. Used for distribution planning and beneficiary communication.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Reference number of the cargo insurance policy covering this shipment. Required for claims processing in case of loss or damage.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Indicates whether cargo insurance is required for this shipment. True for high-value or high-risk shipments.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Receipt Signature Captured Flag' ;
    rdfs:comment 'Indicates whether a physical or digital signature was captured upon receipt. True if signature obtained, False otherwise.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedByName rdf:type rdf:Property ;
    rdfs:label 'Received By Name' ;
    rdfs:comment 'Full name of the person who received and signed for the shipment at destination. Critical for accountability and audit trail.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedByTitle rdf:type rdf:Property ;
    rdfs:label 'Received By Title' ;
    rdfs:comment 'Job title or role of the person who received the shipment. Provides context for authorization level and responsibility.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeDescription rdf:type rdf:Property ;
    rdfs:label 'Route Description' ;
    rdfs:comment 'Description of the planned transport route including major waypoints, checkpoints, or transit hubs. Important for security planning in conflict zones.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicates whether the security seal was intact upon arrival at destination. True if intact, False if broken or tampered.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Unique security seal number applied to the shipment container or vehicle to prevent tampering. Critical for loss prevention and donor audit compliance.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the waybill shipment. Tracks progression from dispatch through final receipt and reconciliation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classification of the shipment purpose. Distinguishes between emergency relief, routine program supplies, warehouse transfers, and returns.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this shipment requires temperature-controlled transport (cold chain). True for medical supplies, vaccines, or perishable items.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum acceptable temperature in Celsius for temperature-controlled shipments. Exceedance may compromise commodity efficacy.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum acceptable temperature in Celsius for temperature-controlled shipments. Critical for cold chain compliance and commodity quality.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDispatchedQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Dispatched Quantity' ;
    rdfs:comment 'Aggregate quantity of all commodity items dispatched on this waybill. Sum of all line-item dispatched quantities.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReceivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Received Quantity' ;
    rdfs:comment 'Aggregate quantity of all commodity items received at destination. Used to calculate overall shipment discrepancy.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportCostAmount rdf:type rdf:Property ;
    rdfs:label 'Transport Cost Amount' ;
    rdfs:comment 'Total cost incurred for transporting this shipment. Includes carrier fees, fuel surcharges, and handling charges.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Transport Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the transport cost amount. Essential for multi-currency operations and financial reporting.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waybillNumber rdf:type rdf:Property ;
    rdfs:label 'Waybill Number' ;
    rdfs:comment 'Externally-known unique waybill document number used for tracking and reference by transporters, warehouses, and auditors. Typically follows organizational numbering convention.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Id' ;
    rdfs:comment 'Identifier of a preferred or pre-qualified vendor for this procurement, if applicable. May be based on prior performance, framework agreements, or emergency response partnerships.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:requestingProjectSiteId rdf:type rdf:Property ;
    rdfs:label 'Requesting Project Site Id' ;
    rdfs:comment 'Identifier of the specific field project site or location where the procured items or services will be delivered or utilized.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectSite .

ind:requestingStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Requesting Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: NGO procurement policies and donor audit requirements mandate a named individual requester on every procurement request for accountability and segregation-of-duties. The existing FK covers org_unit bu' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:approvalLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Level Required' ;
    rdfs:comment 'Highest approval authority level required for this procurement request based on value thresholds and organizational delegation of authority: team lead, program manager, country director, regional director, headquarters procurement, Chief Financial Officer (CFO), or Chief Executive Officer (CEO). [ENUM-REF-CANDIDATE: team_lead|program_manager|country_director|regional_director|hq_procurement|cfo|ceo — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Required' ;
    rdfs:comment 'Boolean flag indicating whether this procurement requires additional compliance checks such as sanctions screening, export control review, or anti-terrorism financing verification. True if compliance check is required, false otherwise.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Assessment' ;
    rdfs:comment 'Classification of the environmental impact of this procurement: not required (no significant impact), low impact (minimal environmental footprint), moderate impact (some environmental considerations), high impact (significant environmental review needed), or assessment pending (evaluation in progress).' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Cost' ;
    rdfs:comment 'Total estimated cost for the entire procurement request, calculated as quantity requested multiplied by estimated unit cost. May include additional costs such as shipping or taxes.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Cost' ;
    rdfs:comment 'Estimated cost per unit of the requested item or service. Used for budget planning and approval thresholds.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:justificationNarrative rdf:type rdf:Property ;
    rdfs:label 'Justification Narrative' ;
    rdfs:comment 'Detailed business justification for this procurement request. Explains the program need, beneficiary impact, alignment with Theory of Change (ToC) or Logical Framework (LogFrame), and why this procurement is necessary.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localProcurementPreference rdf:type rdf:Property ;
    rdfs:label 'Local Procurement Preference' ;
    rdfs:comment 'Boolean flag indicating whether this procurement should prioritize local or in-country vendors to support local economies and reduce lead times. True if local preference applies, false otherwise.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Numeric quantity of the item or service being requested. May represent units, volume, weight, or service hours depending on the request type.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date on which this procurement request was formally submitted for review and approval. Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the procurement request: draft (being prepared), submitted (awaiting review), under review (being evaluated), approved (authorized for procurement), rejected (not approved), cancelled (withdrawn), in procurement (being sourced), or fulfilled (completed). [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|cancelled|in_procurement|fulfilled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the procurement request by the nature of what is being requested: goods, services, works, consultancy, Non-Food Items (NFI), medical supplies, equipment, vehicle, or construction. [ENUM-REF-CANDIDATE: goods|services|works|consultancy|nfi|medical_supplies|equipment|vehicle|construction — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the requested items or services must be delivered to the requesting location. Critical for supply chain planning and program delivery timelines.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Externally visible unique requisition number assigned to this procurement request. Used for tracking and reference across systems and communications.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soleSourceJustification rdf:type rdf:Property ;
    rdfs:label 'Sole Source Justification' ;
    rdfs:comment 'Justification narrative if this procurement is requested as a sole-source (non-competitive) procurement. Must explain why competitive bidding is not feasible or appropriate.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Classification of the urgency of this procurement request: routine (standard lead time), urgent (expedited processing), emergency (immediate need), or life-saving (critical humanitarian response).' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Responsible Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: NGO import/export compliance and customs clearance processes require a named responsible staff member per shipment for duty exemption applications, import permit management, and donor audit trails. Th' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Actual date when the shipment arrived at the destination port or warehouse, as confirmed by receiving personnel.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Date' ;
    rdfs:comment 'Actual date when the shipment departed from the origin port or warehouse, as confirmed by the carrier or freight forwarder.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Bill of Lading number for sea freight or Airway Bill number for air freight, serving as the legal document of title and receipt for the cargo.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Reference Number' ;
    rdfs:comment 'Carrier-assigned tracking number or booking reference for the shipment.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'ISO container number for sea freight (e.g., ABCD1234567) or vehicle registration/truck number for road transport.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Type of container or vehicle used: 20ft or 40ft standard containers, 40ft high cube for volume cargo, refrigerated for cold chain medical supplies, open top or flat rack for oversized items, truck for road transport, or aircraft for air freight. [ENUM-REF-CANDIDATE: 20ft_standard|40ft_standard|40ft_high_cube|refrigerated|open_top|flat_rack|truck|aircraft — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerName rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Name' ;
    rdfs:comment 'Name of the licensed customs broker or clearing agent engaged to facilitate customs clearance and import documentation in the destination country.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Status' ;
    rdfs:comment 'Current status of customs clearance process: not required for domestic shipments, pending initiation, documentation submitted to customs broker, under review by customs authority, cleared and released, held for inspection or additional documentation, or exemption granted under humanitarian duty-free privileges. [ENUM-REF-CANDIDATE: not_required|pending|documentation_submitted|under_review|cleared|held|exemption_granted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the shipment destination country (e.g., SYR, YEM, SDN for field operations).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationName rdf:type rdf:Property ;
    rdfs:label 'Destination Location Name' ;
    rdfs:comment 'Human-readable name of the final destination warehouse, project site, or distribution point for the shipment.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPortCode rdf:type rdf:Property ;
    rdfs:label 'Destination Port Code' ;
    rdfs:comment 'UN/LOCODE or IATA code for the arrival port (sea) or airport (air) where the shipment enters the destination country.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyExemptionReference rdf:type rdf:Property ;
    rdfs:label 'Duty Exemption Reference' ;
    rdfs:comment 'Reference number or letter from host government granting duty and tax exemption for humanitarian relief goods under bilateral agreements or United Nations privileges.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'Planned or estimated date when the shipment is expected to arrive at the destination port or warehouse.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Departure Date' ;
    rdfs:comment 'Planned or estimated date when the shipment is scheduled to depart from the origin port or warehouse.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCostUsd rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Usd' ;
    rdfs:comment 'Total freight transportation cost in United States Dollars, including carrier charges, fuel surcharges, and handling fees.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'UN hazardous materials classification code (e.g., UN1170 for ethanol, UN3373 for biological substances) if the shipment contains dangerous goods requiring special handling and documentation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Import Permit Number' ;
    rdfs:comment 'Government-issued import permit or license number required for controlled goods such as medical supplies, pharmaceuticals, or telecommunications equipment.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuredValueUsd rdf:type rdf:Property ;
    rdfs:label 'Insured Value Usd' ;
    rdfs:comment 'Declared value of the shipment cargo in United States Dollars for insurance purposes, representing the replacement cost of the goods.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfCartons rdf:type rdf:Property ;
    rdfs:label 'Number Of Cartons' ;
    rdfs:comment 'Total count of individual cartons, boxes, or packages in the shipment, used for inventory reconciliation and distribution planning.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfPallets rdf:type rdf:Property ;
    rdfs:label 'Number Of Pallets' ;
    rdfs:comment 'Total count of pallets or skids in the shipment, used for warehouse handling and loading dock planning.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the shipment origin country (e.g., USA, DNK, ARE for procurement hubs).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocationName rdf:type rdf:Property ;
    rdfs:label 'Origin Location Name' ;
    rdfs:comment 'Human-readable name of the origin location, warehouse, or facility from which the shipment departs.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPortCode rdf:type rdf:Property ;
    rdfs:label 'Origin Port Code' ;
    rdfs:comment 'UN/LOCODE or IATA code for the departure port (sea) or airport (air) from which the shipment originates.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phytosanitaryCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Phytosanitary Certificate Number' ;
    rdfs:comment 'Certificate number issued by the origin country plant protection authority for shipments containing agricultural products, seeds, or wooden packaging materials, certifying compliance with international phytosanitary standards.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCargoVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Cargo Volume M3' ;
    rdfs:comment 'Total volume of the shipment cargo in cubic meters, used for warehouse space planning and freight costing for volumetric shipments.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCargoWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Cargo Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment cargo in kilograms, including packaging and pallets, used for freight costing and capacity planning.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementingOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Implementing Org Unit Id' ;
    rdfs:comment 'Identifier of the organizational unit (country office, regional office, or headquarters division) responsible for implementing this intervention.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:chsCompliant rdf:type rdf:Property ;
    rdfs:label 'Chs Compliant' ;
    rdfs:comment 'Indicates whether the intervention design and implementation plan adhere to the Core Humanitarian Standard on Quality and Accountability, covering nine commitments from needs assessment through accountability to affected populations.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disabilityInclusionMarkerScore rdf:type rdf:Property ;
    rdfs:label 'Disability Inclusion Marker Score' ;
    rdfs:comment 'Score indicating the level of disability inclusion in the intervention design and implementation. 0: not disability inclusive; 1: disability visible; 2: disability integrated; 3: disability targeted; 4: disability transformative.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNoHarmAssessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Do No Harm Assessment Completed' ;
    rdfs:comment 'Indicates whether a Do No Harm analysis was conducted to identify and mitigate potential negative impacts of the intervention on conflict dynamics, social cohesion, or vulnerable groups.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalImpactAssessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Assessment Completed' ;
    rdfs:comment 'Indicates whether an environmental impact assessment was conducted to evaluate and mitigate potential environmental harm from intervention activities (e.g., water extraction, waste disposal, construction).' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderMarkerScore rdf:type rdf:Property ;
    rdfs:label 'Gender Marker Score' ;
    rdfs:comment 'IASC Gender Marker score indicating the extent to which the intervention integrates gender equality. 0: no gender integration; 1: contributes to gender equality; 2a: has gender equality as a significant objective; 2b: has gender equality as the principal objective.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interventionCode rdf:type rdf:Property ;
    rdfs:label 'Intervention Code' ;
    rdfs:comment 'Externally-known unique business identifier for the intervention, used in donor reporting, grant proposals, and field operations. Often follows organizational or donor-specific coding conventions.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interventionName rdf:type rdf:Property ;
    rdfs:label 'Intervention Name' ;
    rdfs:comment 'Full descriptive name of the intervention as it appears in grant proposals, donor reports, and public communications.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interventionStatus rdf:type rdf:Property ;
    rdfs:label 'Intervention Status' ;
    rdfs:comment 'Current lifecycle status of the intervention. Pipeline: concept or proposal stage; Approved: funding secured, not yet started; Active: implementation underway; Suspended: temporarily paused; Completed: activities finished, closeout pending; Closed: fully closed out with final reports submitted.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interventionType rdf:type rdf:Property ;
    rdfs:label 'Intervention Type' ;
    rdfs:comment 'Classification of the intervention based on its primary purpose and timeframe. Emergency response interventions address immediate humanitarian crises; development interventions focus on long-term sustainable change; recovery interventions bridge emergency and development; resilience interventions build capacity to withstand future shocks; advocacy interventions influence policy and systems; capacity building interventions strengthen partner organizations.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logframeDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Logframe Document Url' ;
    rdfs:comment 'URL or file path to the intervention\'s Logical Framework Matrix document, which details the intervention logic, indicators, means of verification, and assumptions.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logic rdf:type rdf:Property ;
    rdfs:label 'Logic' ;
    rdfs:comment 'Structured description of the intervention\'s logical framework (LogFrame): how activities will produce outputs, how outputs will lead to outcomes, and how outcomes will contribute to impact. Includes key assumptions and risks at each level.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melPlanDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Mel Plan Document Url' ;
    rdfs:comment 'URL or file path to the intervention\'s MEL plan, which outlines the monitoring framework, evaluation schedule, data collection methods, and learning agenda.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Current operational phase within the intervention lifecycle. Design: developing ToC, LogFrame, and proposal; Startup: mobilizing resources, recruiting staff, establishing field presence; Implementation: delivering activities and services; Closeout: finalizing activities, conducting evaluations, submitting final reports.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rbmFrameworkApplied rdf:type rdf:Property ;
    rdfs:label 'Rbm Framework Applied' ;
    rdfs:comment 'Indicates whether the intervention applies a formal Results-Based Management framework with defined inputs, activities, outputs, outcomes, and impact, along with indicators and targets at each level.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdgAlignmentType rdf:type rdf:Property ;
    rdfs:label 'Sdg Alignment Type' ;
    rdfs:comment 'Nature of the intervention\'s contribution to the SDG. Direct: intervention activities directly advance the SDG indicator; Indirect: intervention creates conditions that support SDG progress; Enabling: intervention builds capacity or systems that enable others to advance the SDG.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgContributionNarrative rdf:type rdf:Property ;
    rdfs:label 'Sdg Contribution Narrative' ;
    rdfs:comment 'Qualitative description of how the intervention contributes to the identified SDG goal, target, and indicator. Articulates the causal pathway and expected magnitude of contribution.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgGoalPrimary rdf:type rdf:Property ;
    rdfs:label 'Sdg Goal Primary' ;
    rdfs:comment 'Primary UN Sustainable Development Goal that this intervention contributes to, expressed as SDG number (e.g., SDG1 for No Poverty, SDG3 for Good Health and Well-being, SDG6 for Clean Water and Sanitation).' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgIndicatorPrimary rdf:type rdf:Property ;
    rdfs:label 'Sdg Indicator Primary' ;
    rdfs:comment 'Specific SDG indicator used to measure the intervention\'s contribution to the primary target (e.g., 6.1.1 for proportion of population using safely managed drinking water services).' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgTargetPrimary rdf:type rdf:Property ;
    rdfs:label 'Sdg Target Primary' ;
    rdfs:comment 'Specific SDG target within the primary goal that this intervention addresses (e.g., 6.1 for universal access to safe drinking water, 3.8 for universal health coverage).' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sector rdf:type rdf:Property ;
    rdfs:label 'Sector' ;
    rdfs:comment 'Primary humanitarian or development sector of the intervention. WASH (Water Sanitation and Hygiene), health, nutrition, education, protection (including GBV and child protection), shelter/NFI, livelihoods, and food security are the most common sectors aligned with Sphere standards and cluster coordination mechanisms. [ENUM-REF-CANDIDATE: wash|health|nutrition|education|protection|shelter|livelihoods|food_security — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:situationAnalysis rdf:type rdf:Property ;
    rdfs:label 'Situation Analysis' ;
    rdfs:comment 'Detailed analysis of the humanitarian or development context that justifies the intervention. Includes needs assessment findings, vulnerability analysis, root causes of the problem, and gaps in existing services or coverage.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subSector rdf:type rdf:Property ;
    rdfs:label 'Sub Sector' ;
    rdfs:comment 'Detailed sub-classification within the primary sector. For example, within WASH: water supply, sanitation facilities, hygiene promotion; within health: primary health care, maternal health, mental health and PSS; within protection: GBV prevention and response, child protection, mine action.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityPlan rdf:type rdf:Property ;
    rdfs:label 'Sustainability Plan' ;
    rdfs:comment 'Strategy for ensuring that intervention benefits and capacities endure beyond the project period. Includes plans for local ownership, capacity building, resource mobilization, policy advocacy, and transition or exit strategies.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBeneficiaryUnit rdf:type rdf:Property ;
    rdfs:label 'Target Beneficiary Unit' ;
    rdfs:comment 'Unit of measurement for target beneficiaries. Individuals: unique persons; Households: family units; Communities: villages or settlements; Institutions: schools, health facilities, or organizations.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingStrategy rdf:type rdf:Property ;
    rdfs:label 'Targeting Strategy' ;
    rdfs:comment 'Methodology and criteria for identifying and selecting beneficiaries. Describes vulnerability criteria, geographic targeting, inclusion/exclusion criteria, and mechanisms to ensure equitable access and prevent exclusion errors.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoryOfChangeNarrative rdf:type rdf:Property ;
    rdfs:label 'Theory Of Change Narrative' ;
    rdfs:comment 'Comprehensive narrative describing the intervention\'s Theory of Change: the causal pathway from inputs and activities through outputs, outcomes, and impact. Articulates assumptions, preconditions, and the logic connecting intervention activities to intended long-term change.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'Total approved budget for the intervention across all funding sources, expressed in the organization\'s reporting currency. Includes direct program costs, indirect costs, and any cost-sharing or in-kind contributions.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementingPartnerOrgId rdf:type rdf:Property ;
    rdfs:label 'Implementing Partner Org Id' ;
    rdfs:comment 'Foreign key linking to partnership.partner_org. Business justification: In NGO sub-award structures, individual components are assigned to specific implementing partner orgs. This link supports component-level partner accountability tracking, sub-award financial reporting' ;
    rdfs:domain ind:Program ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerOrg .

ind:parentComponentId rdf:type rdf:Property ;
    rdfs:label 'Parent Component Id' ;
    rdfs:comment 'Reference to the parent component if this is a sub-component or workstream. Null for top-level components. Supports hierarchical program navigation.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Component .

ind:responsibleManagerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: NGO component accountability reporting and donor audits require identifying the specific staff member responsible for each component. \'responsible_manager\' is a denormalized name string; a proper FK e' ;
    rdfs:domain ind:Component ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:responsibleOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Responsible Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Organizational accountability for component delivery is a core NGO management requirement. \'responsible_team\' is a denormalized string; linking to org_unit enables budget-by-unit reporting, field offi' ;
    rdfs:domain ind:Program ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of formal amendments or revisions made to the component design, scope, or budget since initial approval. Tracks change management history.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetEnvelopeAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Envelope Amount' ;
    rdfs:comment 'Total allocated budget for this component in the program\'s base currency. Represents the financial ceiling for component activities and procurement.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentCode rdf:type rdf:Property ;
    rdfs:label 'Component Code' ;
    rdfs:comment 'Externally-known unique business identifier for the component, used in donor reporting, grant management systems, and field operations documentation.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Detailed narrative describing the component\'s objectives, scope, target beneficiaries, and expected outcomes. Supports Theory of Change (ToC) articulation.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentName rdf:type rdf:Property ;
    rdfs:label 'Component Name' ;
    rdfs:comment 'Human-readable name of the program component (e.g., \'Water Supply Infrastructure\', \'Hygiene Promotion\', \'Community Health Worker Training\').' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentStatus rdf:type rdf:Property ;
    rdfs:label 'Component Status' ;
    rdfs:comment 'Current lifecycle status of the component (planned, active, on hold, completed, closed, cancelled). Tracks component progression through implementation phases.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Classification of the component within the program structure (component, sub-component, workstream, activity cluster, pilot, scale-up).' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossCuttingThemes rdf:type rdf:Property ;
    rdfs:label 'Cross Cutting Themes' ;
    rdfs:comment 'Cross-cutting priorities integrated into this component (e.g., gender equality, disability inclusion, environmental sustainability, conflict sensitivity, accountability to affected populations).' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dacSectorCode rdf:type rdf:Property ;
    rdfs:label 'Dac Sector Code' ;
    rdfs:comment 'Five-digit OECD DAC sector code for standardized sector classification and donor reporting (e.g., 14010 for Water Resources Policy, 12220 for Basic Health Care).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicFocus rdf:type rdf:Property ;
    rdfs:label 'Geographic Focus' ;
    rdfs:comment 'Primary geographic area(s) where this component is implemented (country, region, district, camp, or community names). Supports spatial analysis and field coordination.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Grant Requirement Flag' ;
    rdfs:comment 'Indicates whether this component is mandated by a specific grant agreement or donor requirement (True) or is discretionary within the program design (False).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementationModality rdf:type rdf:Property ;
    rdfs:label 'Implementation Modality' ;
    rdfs:comment 'Delivery approach for this component (direct implementation by NGO staff, partner-led, consortium, sub-award, community-based organization). Affects partnership and compliance requirements.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationFlag rdf:type rdf:Property ;
    rdfs:label 'Integration Flag' ;
    rdfs:comment 'Indicates whether this component is part of an integrated multi-sector program (True) or a standalone single-sector intervention (False). Supports integrated programming analysis.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent formal amendment to the component. Null if no amendments have been made.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Mitigation Strategy' ;
    rdfs:comment 'Summary of key risk mitigation measures and contingency plans in place for this component. Supports program risk management and donor assurance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'Scheduled frequency for Monitoring Evaluation and Learning (MEL) data collection and progress reporting for this component. [ENUM-REF-CANDIDATE: weekly|biweekly|monthly|quarterly|semi_annual|annual|event_based — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageRangeMax rdf:type rdf:Property ;
    rdfs:label 'Age Range Max' ;
    rdfs:comment 'Maximum age in years for individuals in the target population. Null if no maximum age restriction applies.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeMin rdf:type rdf:Property ;
    rdfs:label 'Age Range Min' ;
    rdfs:comment 'Minimum age in years for individuals in the target population. Null if no minimum age restriction applies.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Date when the baseline data or needs assessment for this target population was collected or published.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Source of the population data or needs assessment used to define this target population (e.g., \'OCHA Humanitarian Needs Overview 2024\', \'Baseline Survey March 2024\', \'Government Census 2023\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNoHarmConsiderations rdf:type rdf:Property ;
    rdfs:label 'Do No Harm Considerations' ;
    rdfs:comment 'Documentation of potential risks and mitigation strategies to ensure the targeting approach does not inadvertently cause harm, stigma, or conflict within communities.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedPopulationSize rdf:type rdf:Property ;
    rdfs:label 'Estimated Population Size' ;
    rdfs:comment 'Estimated total number of individuals in the target population based on needs assessment, census data, or other planning sources.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Criteria that explicitly exclude individuals or households from the target population, ensuring appropriate targeting and avoiding duplication with other programs.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderIntegrationApproach rdf:type rdf:Property ;
    rdfs:label 'Gender Integration Approach' ;
    rdfs:comment 'Description of how gender considerations and gender-based vulnerabilities are integrated into the targeting and selection of this population.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostCommunityPopulationCount rdf:type rdf:Property ;
    rdfs:label 'Host Community Population Count' ;
    rdfs:comment 'Estimated number of host community members (non-displaced local population) within the target population. Null if not applicable.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:idpPopulationCount rdf:type rdf:Property ;
    rdfs:label 'Idp Population Count' ;
    rdfs:comment 'Estimated number of Internally Displaced Persons (IDPs) within the target population. Null if not applicable.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Inclusion Criteria' ;
    rdfs:comment 'Detailed criteria that define who is eligible to be included in the target population (e.g., \'Children aged 6-59 months with MUAC < 12.5 cm\', \'Households with female head and 3+ dependents\').' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedReach rdf:type rdf:Property ;
    rdfs:label 'Planned Reach' ;
    rdfs:comment 'Number of individuals the program plans to reach or serve from this target population, considering resource constraints and program scope.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:populationCode rdf:type rdf:Property ;
    rdfs:label 'Population Code' ;
    rdfs:comment 'Short alphanumeric code or identifier used in reporting and documentation to reference this target population (e.g., \'TP-001\', \'WASH-IDPs-2024\').' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationDescription rdf:type rdf:Property ;
    rdfs:label 'Population Description' ;
    rdfs:comment 'Detailed narrative description of the target population, including demographic characteristics, vulnerability profile, and rationale for targeting.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationName rdf:type rdf:Property ;
    rdfs:label 'Population Name' ;
    rdfs:comment 'Human-readable name or label for this target population segment (e.g., \'Malnourished Children Under 5 in Borno State\', \'IDP Women Heads of Household\').' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionMainstreamingFlag rdf:type rdf:Property ;
    rdfs:label 'Protection Mainstreaming Flag' ;
    rdfs:comment 'Indicates whether protection principles and safeguarding measures are integrated into the targeting and service delivery for this population.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refugeePopulationCount rdf:type rdf:Property ;
    rdfs:label 'Refugee Population Count' ;
    rdfs:comment 'Estimated number of refugees within the target population. Null if not applicable.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential version number tracking revisions to this target population definition over time.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Explanation or justification for the most recent revision to this target population definition (e.g., \'Updated based on new needs assessment\', \'Expanded geographic scope\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorClassification rdf:type rdf:Property ;
    rdfs:label 'Sector Classification' ;
    rdfs:comment 'Primary humanitarian or development sector that this target population is associated with, aligned with cluster coordination frameworks. [ENUM-REF-CANDIDATE: wash|health|nutrition|education|protection|shelter|livelihoods|food_security|multi_sector — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sexDisaggregation rdf:type rdf:Property ;
    rdfs:label 'Sex Disaggregation' ;
    rdfs:comment 'Sex or gender composition of the target population (e.g., \'female\' for women-only programs, \'all\' for mixed populations).' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPopulationStatus rdf:type rdf:Property ;
    rdfs:label 'Target Population Status' ;
    rdfs:comment 'Current lifecycle status of the target population definition within the program planning and execution workflow.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingMethodology rdf:type rdf:Property ;
    rdfs:label 'Targeting Methodology' ;
    rdfs:comment 'Primary approach or method used to identify and select beneficiaries from the target population (e.g., MUAC screening for malnutrition, vulnerability scoring, community-based targeting). [ENUM-REF-CANDIDATE: community_based|vulnerability_scoring|muac_screening|household_economy_approach|geographic|categorical|self_targeting|mixed_methods — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Program Amendment Id' ;
    rdfs:comment 'Unique identifier for the program amendment record. Primary key.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvingDonorConstituentId rdf:type rdf:Property ;
    rdfs:label 'Approving Donor Constituent Id' ;
    rdfs:comment 'Foreign key linking to donor.constituent. Business justification: Amendment approval audit trail: Donor constituents (bilateral donors, foundations) must formally approve program amendments. program_amendment.donor_approving_authority is a denormalized text field; r' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:createdByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Created By Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Amendment audit trails require staff linkage for compliance, donor reporting, and internal controls. Standard practice in grant-funded nonprofit program management.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:logframeId rdf:type rdf:Property ;
    rdfs:label 'Logframe Id' ;
    rdfs:comment 'Foreign key linking to mel.mel_logframe. Business justification: Program amendments with logframe_revision_flag=true directly modify the logframe. Linking program_amendment to mel_logframe creates an audit trail of which amendment version corresponds to which logfr' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Logframe .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: Program amendments often require regulatory filing (donor material change notifications, grant amendment submissions, board resolution filings). Essential for tracking amendment compliance in nonprofi' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Additional notes for audit and compliance purposes, including process deviations, special approvals, or historical context.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetChangeCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Change Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget change amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Compliance Impact Assessment' ;
    rdfs:comment 'Assessment of how this amendment affects compliance with donor requirements, regulatory obligations, and organizational policies.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageChange rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Change' ;
    rdfs:comment 'Description of changes to geographic scope, including new districts, provinces, or countries added or removed from program coverage.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalApprovingAuthority rdf:type rdf:Property ;
    rdfs:label 'Internal Approving Authority' ;
    rdfs:comment 'Name or title of the internal organizational authority (e.g., Program Director, Country Director, Chief Executive Officer) who approved the amendment.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logframeRevisionFlag rdf:type rdf:Property ;
    rdfs:label 'Logframe Revision Flag' ;
    rdfs:comment 'Indicates whether this amendment includes changes to the program LogFrame (results framework, indicators, targets, or assumptions). True if LogFrame is revised, False otherwise.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logframeRevisionSummary rdf:type rdf:Property ;
    rdfs:label 'Logframe Revision Summary' ;
    rdfs:comment 'Summary of changes made to the LogFrame, including modified indicators, revised targets, new outputs, or updated assumptions.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTargetBeneficiaries rdf:type rdf:Property ;
    rdfs:label 'Original Target Beneficiaries' ;
    rdfs:comment 'The planned number of direct beneficiaries before this amendment, captured for before/after comparison.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedTargetBeneficiaries rdf:type rdf:Property ;
    rdfs:label 'Revised Target Beneficiaries' ;
    rdfs:comment 'The new planned number of direct beneficiaries after this amendment is applied, null if the amendment does not affect beneficiary targets.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Assessment of risks introduced or mitigated by this amendment, including operational, financial, reputational, or compliance risks.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgAlignmentChange rdf:type rdf:Property ;
    rdfs:label 'Sdg Alignment Change' ;
    rdfs:comment 'Description of changes to SDG alignment resulting from this amendment, including new SDG targets added or removed.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorClassificationChange rdf:type rdf:Property ;
    rdfs:label 'Sector Classification Change' ;
    rdfs:comment 'Description of changes to sector classifications (e.g., WASH, Health, Nutrition, Education, Protection) resulting from scope modifications.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderConsultationSummary rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Consultation Summary' ;
    rdfs:comment 'Summary of consultations conducted with beneficiaries, partners, local authorities, and other stakeholders regarding the proposed amendment.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Reference' ;
    rdfs:comment 'Reference to supporting documents (e.g., revised budget, updated LogFrame, donor correspondence) stored in document management system.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPopulationChange rdf:type rdf:Property ;
    rdfs:label 'Target Population Change' ;
    rdfs:comment 'Description of changes to target beneficiary population, including adjustments to demographic criteria, vulnerability profiles, or total beneficiary numbers.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timelineExtensionDays rdf:type rdf:Property ;
    rdfs:label 'Timeline Extension Days' ;
    rdfs:comment 'Number of calendar days by which the program implementation period is extended (positive for extensions, negative for reductions, zero if no timeline change).' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskRegisterId rdf:type rdf:Property ;
    rdfs:label 'Risk Register Id' ;
    rdfs:comment 'Unique identifier for the risk register entry. Primary key for the risk register product.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskRegister .

ind:riskOwnerOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Risk Owner Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Organizational risk escalation and CHS compliance require identifying which org unit owns each risk. \'risk_owner\' and \'risk_owner_email\' are denormalized strings; linking to org_unit enables risk aggr' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:affectedSdg rdf:type rdf:Property ;
    rdfs:label 'Affected Sdg' ;
    rdfs:comment 'Reference to the Sustainable Development Goal(s) that may be impacted if this risk materializes. Supports alignment with global development frameworks and donor reporting.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSector rdf:type rdf:Property ;
    rdfs:label 'Affected Sector' ;
    rdfs:comment 'Program sector(s) that would be impacted by the risk (e.g., WASH, Health, Nutrition, Education, Protection, Livelihoods). Supports sector-specific risk analysis and reporting.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyPlan rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan' ;
    rdfs:comment 'Detailed response plan to be activated if the risk materializes. Includes trigger points, escalation procedures, alternative delivery mechanisms, and resource reallocation strategies.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicates whether the risk requires escalation to senior management or board level due to its severity or potential organizational impact. True if escalation is required; false otherwise.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identificationDate rdf:type rdf:Property ;
    rdfs:label 'Identification Date' ;
    rdfs:comment 'Date when the risk was first identified and entered into the risk register. Supports risk lifecycle tracking and audit trails.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactRating rdf:type rdf:Property ;
    rdfs:label 'Impact Rating' ;
    rdfs:comment 'Qualitative assessment of the severity of consequences if the risk materializes. Considers impact on beneficiaries, program objectives, organizational reputation, and donor relations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactScore rdf:type rdf:Property ;
    rdfs:label 'Impact Score' ;
    rdfs:comment 'Numeric score representing the severity of impact if the risk occurs, typically on a scale of 1-5 where 1 is very low and 5 is very high. Used for quantitative risk prioritization.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentRiskScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Score' ;
    rdfs:comment 'Calculated risk score before mitigation measures are applied, typically the product of likelihood_score and impact_score. Represents the raw exposure level.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:likelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Likelihood Rating' ;
    rdfs:comment 'Qualitative assessment of the probability that the risk will materialize during the program lifecycle. Typically rated on a five-point scale aligned with organizational risk appetite.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:likelihoodScore rdf:type rdf:Property ;
    rdfs:label 'Likelihood Score' ;
    rdfs:comment 'Numeric score representing the likelihood of risk occurrence, typically on a scale of 1-5 where 1 is very low and 5 is very high. Used for quantitative risk prioritization.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Calculated risk score after mitigation measures are applied. Represents the remaining exposure after controls are in place. Used to assess whether risk is within acceptable tolerance.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Classification of the risk type. Operational risks relate to program delivery; contextual risks relate to external environment (security, political); institutional risks relate to organizational capacity; fiduciary risks relate to financial management and compliance; programmatic risks relate to program design and effectiveness; reputational risks relate to organizational standing.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCode rdf:type rdf:Property ;
    rdfs:label 'Risk Code' ;
    rdfs:comment 'Unique business identifier for the risk entry, typically following organizational risk coding standards (e.g., OPR-001, CTX-045). Used for cross-referencing in donor reports and internal risk management systems.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle state of the risk. Open indicates newly identified; monitoring indicates active tracking; mitigated indicates controls are effective; closed indicates risk no longer relevant; materialized indicates risk has occurred.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Risk Subcategory' ;
    rdfs:comment 'More granular classification within the risk category (e.g., security incident, supply chain disruption, fraud, partner capacity, beneficiary access). Allows for detailed risk taxonomy alignment.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTitle rdf:type rdf:Property ;
    rdfs:label 'Risk Title' ;
    rdfs:comment 'Short, descriptive title of the risk for quick identification and reporting purposes.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volunteerTeamId rdf:type rdf:Property ;
    rdfs:label 'Volunteer Team Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer_team. Business justification: Implementation plans designate responsible execution units; in NGO field operations, volunteer teams are formally assigned to implement specific plans. Program managers need this link to track team ac' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VolunteerTeam .

ind:assumptions rdf:type rdf:Property ;
    rdfs:label 'Assumptions' ;
    rdfs:comment 'Key assumptions underlying the implementation plan, including security conditions, partner capacity, beneficiary access, and external dependencies.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinationMechanism rdf:type rdf:Property ;
    rdfs:label 'Coordination Mechanism' ;
    rdfs:comment 'Description of coordination mechanisms with partners, clusters, local authorities, and other stakeholders for implementation plan execution.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disaggregationApproach rdf:type rdf:Property ;
    rdfs:label 'Disaggregation Approach' ;
    rdfs:comment 'Description of how beneficiary data will be disaggregated (by gender, age, disability, displacement status, etc.) for equity and accountability.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Last Revision Date' ;
    rdfs:comment 'Date of the most recent revision or amendment to this implementation plan.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:logframeReference rdf:type rdf:Property ;
    rdfs:label 'Logframe Reference' ;
    rdfs:comment 'Reference identifier linking this implementation plan to specific outputs and activities in the program LogFrame.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringApproach rdf:type rdf:Property ;
    rdfs:label 'Monitoring Approach' ;
    rdfs:comment 'Description of the monitoring and evaluation approach for tracking implementation plan progress, including data collection methods and frequency.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known unique business identifier for the implementation plan, used in donor reporting and field communications.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planManagerName rdf:type rdf:Property ;
    rdfs:label 'Plan Manager Name' ;
    rdfs:comment 'Full name of the staff member serving as the implementation plan manager or work plan coordinator.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version number of the implementation plan following semantic versioning (e.g., 1.0, 1.1, 2.0) to track revisions and amendments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the planning period covered by this implementation plan, marking the scheduled completion of all activities.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the planning period covered by this implementation plan, marking the beginning of scheduled activities.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resourceRequirementsSummary rdf:type rdf:Property ;
    rdfs:label 'Resource Requirements Summary' ;
    rdfs:comment 'Summary of human resources, equipment, supplies, and other resources required to execute this implementation plan.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMitigationSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Summary' ;
    rdfs:comment 'Summary of key risks identified and mitigation strategies planned to ensure implementation plan success.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBeneficiaryType rdf:type rdf:Property ;
    rdfs:label 'Target Beneficiary Type' ;
    rdfs:comment 'Unit of measurement for target beneficiaries (individuals, households, communities, or institutions).' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tocReference rdf:type rdf:Property ;
    rdfs:label 'Toc Reference' ;
    rdfs:comment 'Reference identifier linking this implementation plan to the program Theory of Change pathway and assumptions.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPlannedActivities rdf:type rdf:Property ;
    rdfs:label 'Total Planned Activities' ;
    rdfs:comment 'Total number of discrete activities scheduled in this implementation plan.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPlannedMilestones rdf:type rdf:Property ;
    rdfs:label 'Total Planned Milestones' ;
    rdfs:comment 'Total number of key milestones defined in this implementation plan for progress tracking and donor reporting.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAssumptions rdf:type rdf:Property ;
    rdfs:label 'Budget Assumptions' ;
    rdfs:comment 'Key assumptions underlying the budget plan, such as exchange rates, inflation rates, beneficiary numbers, or activity volumes.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNarrative rdf:type rdf:Property ;
    rdfs:label 'Budget Narrative' ;
    rdfs:comment 'Detailed narrative justification and explanation of the budget plan, including assumptions, methodologies, and cost calculations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetOwner rdf:type rdf:Property ;
    rdfs:label 'Budget Owner' ;
    rdfs:comment 'Name or identifier of the program manager or budget holder responsible for this budget plan.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Budget Period End Date' ;
    rdfs:comment 'End date of the budget period this plan covers.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Budget Period Start Date' ;
    rdfs:comment 'Start date of the budget period this plan covers.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetPlanName rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Name' ;
    rdfs:comment 'Descriptive name or title of the budget plan, typically aligned with program or grant phase.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Number' ;
    rdfs:comment 'Externally-known unique identifier or code for this budget plan, used in donor reporting and financial communications.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the budget plan in the approval and execution workflow. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|active|amended|closed|rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget plan indicating whether it is the original approved budget, a revision, supplemental funding, or closeout budget.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Version Number' ;
    rdfs:comment 'Version number of this budget plan, incremented with each revision or amendment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Notes regarding compliance requirements, restrictions, or special conditions attached to this budget plan.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractualCosts rdf:type rdf:Property ;
    rdfs:label 'Contractual Costs' ;
    rdfs:comment 'Total budgeted amount for contractual services, consultants, and sub-awards.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costShareAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Share Amount' ;
    rdfs:comment 'Total budgeted amount of cost sharing or matching funds contributed by the organization or other sources.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorBudgetCode rdf:type rdf:Property ;
    rdfs:label 'Donor Budget Code' ;
    rdfs:comment 'Donor-specific budget classification code or identifier required for reporting and compliance.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCosts rdf:type rdf:Property ;
    rdfs:label 'Equipment Costs' ;
    rdfs:comment 'Total budgeted amount for equipment purchases with unit cost exceeding capitalization threshold.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financeContact rdf:type rdf:Property ;
    rdfs:label 'Finance Contact' ;
    rdfs:comment 'Name or identifier of the finance team member responsible for financial oversight of this budget plan.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fringeBenefitsCosts rdf:type rdf:Property ;
    rdfs:label 'Fringe Benefits Costs' ;
    rdfs:comment 'Total budgeted amount for fringe benefits associated with personnel costs.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indirectCosts rdf:type rdf:Property ;
    rdfs:label 'Indirect Costs' ;
    rdfs:comment 'Total budgeted amount for indirect costs (Facilities and Administration), calculated by applying the indirect cost rate to the direct cost base.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:personnelCosts rdf:type rdf:Property ;
    rdfs:label 'Personnel Costs' ;
    rdfs:comment 'Total budgeted amount for personnel salaries and wages.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suppliesCosts rdf:type rdf:Property ;
    rdfs:label 'Supplies Costs' ;
    rdfs:comment 'Total budgeted amount for supplies and consumable materials.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalApprovedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Approved Budget Amount' ;
    rdfs:comment 'Total approved budget amount for this plan, representing the sum of all cost categories.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDirectCosts rdf:type rdf:Property ;
    rdfs:label 'Total Direct Costs' ;
    rdfs:comment 'Sum of all direct cost categories before indirect costs are applied.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelCosts rdf:type rdf:Property ;
    rdfs:label 'Travel Costs' ;
    rdfs:comment 'Total budgeted amount for travel expenses including international and domestic travel.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetPlanLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Line Id' ;
    rdfs:comment 'Unique identifier for the budget plan line item. Primary key for this entity.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetPlanLine .

ind:activityCode rdf:type rdf:Property ;
    rdfs:label 'Activity Code' ;
    rdfs:comment 'Program activity or intervention code that this budget line supports. Links budget to program implementation activities.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowableCostFlag rdf:type rdf:Property ;
    rdfs:label 'Allowable Cost Flag' ;
    rdfs:comment 'Indicates whether this cost is allowable under the grant or donor regulations. Used for budget review and compliance validation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetPlanLineStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Line Status' ;
    rdfs:comment 'Current lifecycle status of the budget line item. Tracks approval workflow and execution state. [ENUM-REF-CANDIDATE: draft|submitted|approved|active|revised|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BudgetPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'General Ledger account code from the organization\'s Chart of Accounts. Links budget planning to financial accounting and enables BvA tracking.' ;
    rdfs:domain ind:BudgetPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'Primary budget classification category following standard nonprofit and federal grant budget structures. Used for donor reporting and financial compliance. [ENUM-REF-CANDIDATE: personnel|fringe_benefits|travel|equipment|supplies|contractual|subawards|other_direct_costs|indirect_costs — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSharingAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Sharing Amount' ;
    rdfs:comment 'The portion of the total planned amount that represents cost sharing or matching contribution. Used for grant compliance reporting.' ;
    rdfs:domain ind:BudgetPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costSharingFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Sharing Flag' ;
    rdfs:comment 'Indicates whether this budget line includes cost sharing or matching funds from the organization or other sources. Critical for grant compliance.' ;
    rdfs:domain ind:BudgetPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costSharingSource rdf:type rdf:Property ;
    rdfs:label 'Cost Sharing Source' ;
    rdfs:comment 'The source of cost sharing funds (e.g., organizational reserves, other grants, in-kind contributions, partner contributions).' ;
    rdfs:domain ind:BudgetPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSubcategory rdf:type rdf:Property ;
    rdfs:label 'Cost Subcategory' ;
    rdfs:comment 'Detailed subcategory within the primary cost category for granular budget tracking (e.g., international travel, local travel, office supplies, medical supplies).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directCostFlag rdf:type rdf:Property ;
    rdfs:label 'Direct Cost Flag' ;
    rdfs:comment 'Indicates whether this budget line is a direct cost (true) or an indirect/overhead cost (false). Used for indirect cost rate calculations and compliance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year to which this budget line belongs. Enables fiscal year-based budget reporting and analysis.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Detailed narrative description of the budget line item explaining the purpose, justification, and planned use of funds.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPlannedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Planned Amount' ;
    rdfs:comment 'The total budgeted amount for this line item, typically calculated as quantity multiplied by unit cost. Primary financial value for budget versus actual (BvA) tracking.' ;
    rdfs:domain ind:BudgetPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerLinkageId rdf:type rdf:Property ;
    rdfs:label 'Partner Linkage Id' ;
    rdfs:comment 'Unique identifier for the program-partner linkage record. Primary key.' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerConstituentId rdf:type rdf:Property ;
    rdfs:label 'Partner Constituent Id' ;
    rdfs:comment 'Foreign key linking to donor.constituent. Business justification: Partner organizations may also be donors/funders. Tracks dual-role relationships where implementing partners are also funding partners. Essential for relationship management, conflict-of-interest trac' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:beneficiaryReachedCount rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Reached Count' ;
    rdfs:comment 'Actual number of beneficiaries reached by this partner to date within this program.' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiaryTargetCount rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Target Count' ;
    rdfs:comment 'Target number of beneficiaries this partner is responsible for reaching within this program.' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityBuildingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capacity Building Required Flag' ;
    rdfs:comment 'Indicates whether capacity building or technical assistance is required for this partner to successfully implement the program (True/False).' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communityBasedOrganizationFlag rdf:type rdf:Property ;
    rdfs:label 'Community Based Organization Flag' ;
    rdfs:comment 'Indicates whether this partner is a community-based organization (CBO) operating at grassroots level (True/False).' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of the partner with donor requirements, regulatory standards, and organizational policies for this program (e.g., compliant, non-compliant, conditional, under review, not assessed).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMonitoringVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Monitoring Visit Date' ;
    rdfs:comment 'Date of the most recent field monitoring visit to the partners implementation sites for this program.' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Last Report Submission Date' ;
    rdfs:comment 'Date when the partner last submitted a progress or financial report for this program.' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localPartnerFlag rdf:type rdf:Property ;
    rdfs:label 'Local Partner Flag' ;
    rdfs:comment 'Indicates whether this partner is a local or national organization (as opposed to an international organization) (True/False).' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monitoringVisitCount rdf:type rdf:Property ;
    rdfs:label 'Monitoring Visit Count' ;
    rdfs:comment 'Total number of field monitoring visits conducted to this partners implementation sites for this program.' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnershipRole rdf:type rdf:Property ;
    rdfs:label 'Partnership Role' ;
    rdfs:comment 'The functional role the partner organization plays in this program intervention (e.g., lead implementer, sub-grantee, technical partner, government counterpart, consortium member, capacity building partner).' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipType rdf:type rdf:Property ;
    rdfs:label 'Partnership Type' ;
    rdfs:comment 'Classification of the partnership arrangement (e.g., direct implementation, sub-award, technical assistance, coordination, joint implementation, government collaboration).' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Performance Review Date' ;
    rdfs:comment 'Date of the most recent performance review or evaluation of the partners implementation activities.' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk rating assigned to this partnership based on capacity assessment, due diligence, and operational context (e.g., low, medium, high, critical).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorFocus rdf:type rdf:Property ;
    rdfs:label 'Sector Focus' ;
    rdfs:comment 'Primary humanitarian or development sector(s) this partner is responsible for within the program (e.g., WASH, health, nutrition, education, protection, livelihoods). May be multi-sector.' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewEventId rdf:type rdf:Property ;
    rdfs:label 'Review Event Id' ;
    rdfs:comment 'Unique identifier for the program review, reporting, or learning event. Primary key.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadAuthorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Lead Author Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Donor reporting and CHS compliance require identifying the accountable staff member who authored each review/evaluation. \'lead_author_name\' is a denormalized string; a proper FK enables staff performa' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:recipientConstituentId rdf:type rdf:Property ;
    rdfs:label 'Recipient Constituent Id' ;
    rdfs:comment 'Foreign key linking to donor.constituent. Business justification: Donor report submission tracking: Review events (donor reports, evaluations) are submitted to specific donor constituent organizations. NGOs track which constituent received each report for stewardshi' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:triggeringInternalReviewId rdf:type rdf:Property ;
    rdfs:label 'Triggering Internal Review Id' ;
    rdfs:comment 'Foreign key linking to compliance.internal_review. Business justification: Program review events (mid-term evaluations, after-action reviews) are often triggered by or conducted alongside compliance internal reviews. NGO compliance officers need to trace which internal revie' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalReview .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the individual or role who formally approved this review event or report.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryReachChildren rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Reach Children' ;
    rdfs:comment 'Number of children (under 18) reached during the reporting period.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiaryReachFemale rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Reach Female' ;
    rdfs:comment 'Number of female beneficiaries reached during the reporting period.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiaryReachMale rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Reach Male' ;
    rdfs:comment 'Number of male beneficiaries reached during the reporting period.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiaryReachTotal rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Reach Total' ;
    rdfs:comment 'Total number of beneficiaries reached during the reporting period, as reported in this review event.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:challengesNarrative rdf:type rdf:Property ;
    rdfs:label 'Challenges Narrative' ;
    rdfs:comment 'Narrative description of challenges, constraints, and obstacles encountered during the reporting period.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterSubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Cluster Submission Flag' ;
    rdfs:comment 'Indicates whether this report was submitted to a humanitarian cluster coordination mechanism (e.g., WASH cluster, Health cluster).' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disseminationDate rdf:type rdf:Property ;
    rdfs:label 'Dissemination Date' ;
    rdfs:comment 'Date the report or learning output was published or disseminated to stakeholders.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Business identifier or reference code for the review event, often used in donor correspondence and internal tracking systems.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the review event or report. Tracks progression from draft through submission, approval, and dissemination. [ENUM-REF-CANDIDATE: draft|in_progress|submitted|under_review|approved|published|archived|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the review or reporting event. Includes formal reviews (mid-term, annual, after-action, donor missions), periodic reports (quarterly, semi-annual, annual, final, SitRep, flash), and structured learning outputs (lessons learned, best practices, innovations, failure analyses). [ENUM-REF-CANDIDATE: mid_term_review|annual_review|after_action_review|donor_review_mission|quarterly_progress_report|semi_annual_report|annual_report|final_report|sitrep|flash_report|lessons_learned|best_practice_documentation|innovation_case_study|failure_analysis — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executiveSummary rdf:type rdf:Property ;
    rdfs:label 'Executive Summary' ;
    rdfs:comment 'High-level summary of the review event or report, capturing key messages for senior management and donors.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActions rdf:type rdf:Property ;
    rdfs:label 'Follow Up Actions' ;
    rdfs:comment 'List or narrative of follow-up actions agreed upon in response to the review findings and recommendations.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyFindings rdf:type rdf:Property ;
    rdfs:label 'Key Findings' ;
    rdfs:comment 'Summary of the key findings from the review, assessment, or reporting period. Captures evidence-based observations.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonsLearnedSummary rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned Summary' ;
    rdfs:comment 'Summary of lessons learned during the reporting period or review, intended to inform future programming and organizational learning.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementResponse rdf:type rdf:Property ;
    rdfs:label 'Management Response' ;
    rdfs:comment 'Formal response from program management to the findings and recommendations, including acceptance, rejection, or modification of recommendations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:progressNarrative rdf:type rdf:Property ;
    rdfs:label 'Progress Narrative' ;
    rdfs:comment 'Detailed narrative describing progress against planned outputs, outcomes, and activities during the reporting period.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Review Team Members' ;
    rdfs:comment 'Comma-separated list or narrative description of the review team members or contributors.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sphereStandardsAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Sphere Standards Applied Flag' ;
    rdfs:comment 'Indicates whether Sphere Humanitarian Charter and Minimum Standards were applied or assessed in this review event.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:advancePaymentAllowed rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Allowed' ;
    rdfs:comment 'Indicates whether the donor allows advance payments or if reimbursement-only is required.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agreementSignedDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Signed Date' ;
    rdfs:comment 'The date on which the award agreement was signed by both the donor and the NGO.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Required' ;
    rdfs:comment 'Indicates whether the award requires a specific audit (e.g., A-133 single audit, donor-specific audit).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Audit Threshold Amount' ;
    rdfs:comment 'The expenditure threshold that triggers audit requirements under this award.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedAmount rdf:type rdf:Property ;
    rdfs:label 'Authorized Amount' ;
    rdfs:comment 'The maximum amount authorized for expenditure under this award, which may differ from the obligated amount due to amendments or modifications.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardNumber rdf:type rdf:Property ;
    rdfs:label 'Award Number' ;
    rdfs:comment 'The externally-known unique award number assigned by the donor or funding agency. This is the official reference number used in all donor communications and reporting.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardStatus rdf:type rdf:Property ;
    rdfs:label 'Award Status' ;
    rdfs:comment 'Current lifecycle status of the award: pipeline (anticipated), active (in execution), no-cost extension (extended without additional funds), suspended, or closed.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardType rdf:type rdf:Property ;
    rdfs:label 'Award Type' ;
    rdfs:comment 'The classification of the funding mechanism: cooperative agreement, contract, grant, sub-award, consortium lead, or consortium member.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandingMarkingRequirements rdf:type rdf:Property ;
    rdfs:label 'Branding Marking Requirements' ;
    rdfs:comment 'Donor-specific requirements for branding, marking, and visibility of donor support in program materials and communications.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeoutDate rdf:type rdf:Property ;
    rdfs:label 'Closeout Date' ;
    rdfs:comment 'The date on which the award was officially closed out after all financial and programmatic reporting requirements were completed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Share Percentage' ;
    rdfs:comment 'The percentage of total project costs that must be contributed by the NGO as cost-sharing, expressed as a decimal.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costShareRequired rdf:type rdf:Property ;
    rdfs:label 'Cost Share Required' ;
    rdfs:comment 'Indicates whether the award requires the NGO to provide cost-sharing or matching funds.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the award amount is denominated.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Donor Reference Number' ;
    rdfs:comment 'The donor\'s internal reference or tracking number for this award, distinct from the award number.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateToFunctional rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate To Functional' ;
    rdfs:comment 'The exchange rate used to convert the award currency to the NGO\'s functional currency for accounting purposes.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Functional Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code of the NGO\'s functional currency for financial reporting.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Fund Restriction Type' ;
    rdfs:comment 'Classification of the award funds as unrestricted, temporarily restricted, or permanently restricted per ASC 958 accounting standards.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indirectCostCeiling rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Ceiling' ;
    rdfs:comment 'The maximum indirect cost rate allowed by the donor for this award, expressed as a decimal.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nicraIcrRate rdf:type rdf:Property ;
    rdfs:label 'Nicra Icr Rate' ;
    rdfs:comment 'The negotiated indirect cost rate applicable to this award, expressed as a decimal (e.g., 0.1500 for 15%).' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'The date on which the NGO received official notification of the award from the donor.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodOfPerformanceMonths rdf:type rdf:Property ;
    rdfs:label 'Period Of Performance Months' ;
    rdfs:comment 'The total duration of the award period of performance expressed in months.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Primary Country Code' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country code for the primary country of implementation.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'The applicable regulatory framework governing this award (e.g., 2 CFR 200, USAID ADS, DFID Smart Rules, UN Financial Regulations).' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Any special conditions, restrictions, or requirements imposed by the donor on this award.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thematicSector rdf:type rdf:Property ;
    rdfs:label 'Thematic Sector' ;
    rdfs:comment 'The primary thematic sector or focus area of the award (e.g., WASH, health, education, protection, food security).' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalObligatedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Obligated Amount' ;
    rdfs:comment 'The total amount of funds obligated by the donor under this award in the award currency.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalObligatedAmountFunctional rdf:type rdf:Property ;
    rdfs:label 'Total Obligated Amount Functional' ;
    rdfs:comment 'The total obligated amount converted to the NGO\'s functional currency using the exchange rate.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposalId rdf:type rdf:Property ;
    rdfs:label 'Proposal Id' ;
    rdfs:comment 'Unique identifier for the grant proposal or concept note submission. Primary key for the proposal data product.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consortiumLeadPartnerOrgId rdf:type rdf:Property ;
    rdfs:label 'Consortium Lead Partner Org Id' ;
    rdfs:comment 'Foreign key linking to partnership.partner_org. Business justification: Proposals are frequently developed with a consortium lead partner. This FK replaces the denormalized consortium_lead_organization text field with a proper reference to partner_org, enabling business d' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerOrg .

ind:leadProposalWriterStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Lead Proposal Writer Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: BD pipeline management and win/loss analysis require linking proposals to the staff member who led writing. Workload reporting, capacity planning, and staff performance reviews reference proposal auth' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:prospectId rdf:type rdf:Property ;
    rdfs:label 'Prospect Id' ;
    rdfs:comment 'Foreign key linking to donor.prospect. Business justification: NGO business development pipeline tracks proposals against prospect records. Win/loss analysis by prospect cultivation stage, proposal conversion rates by prospect rating, and solicitation amount accu' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prospect .

ind:awardNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Award Notification Date' ;
    rdfs:comment 'Date the organization was officially notified of the award decision by the donor. Null if proposal was not awarded or decision is still pending.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessDevelopmentOwner rdf:type rdf:Property ;
    rdfs:label 'Business Development Owner' ;
    rdfs:comment 'Name or identifier of the business development staff member responsible for managing this proposal opportunity and donor relationship.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Completed' ;
    rdfs:comment 'Boolean flag indicating whether compliance and risk review was completed before submission. Ensures adherence to donor regulations and organizational policies.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costProposalSummary rdf:type rdf:Property ;
    rdfs:label 'Cost Proposal Summary' ;
    rdfs:comment 'Summary of the cost proposal structure, including major budget categories, cost-sharing arrangements, and indirect cost rate applied. Provides financial overview without detailed line items.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goNoGoDecision rdf:type rdf:Property ;
    rdfs:label 'Go No Go Decision' ;
    rdfs:comment 'Internal decision on whether to pursue this funding opportunity. Tracks strategic alignment, capacity assessment, and risk evaluation outcomes.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goNoGoDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Go No Go Decision Date' ;
    rdfs:comment 'Date the internal go/no-go decision was made regarding pursuit of this funding opportunity.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indirectCostRateProposed rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Rate Proposed' ;
    rdfs:comment 'Indirect cost rate (ICR) or facilities and administration (F&A) rate proposed in the budget, expressed as a percentage. May reference the organization\'s NICRA (Negotiated Indirect Cost Rate Agreement).' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Internal Review Date' ;
    rdfs:comment 'Date the proposal completed internal review and was approved for submission by organizational leadership or review committee.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTechnicalSector rdf:type rdf:Property ;
    rdfs:label 'Lead Technical Sector' ;
    rdfs:comment 'Primary technical sector or thematic area for the proposed intervention (e.g., WASH, Health, Education, Protection, Livelihoods, GBV, Nutrition). Aligns with DAC sector codes and organizational program taxonomy.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipModel rdf:type rdf:Property ;
    rdfs:label 'Partnership Model' ;
    rdfs:comment 'Organizational role and partnership structure for this proposal. Indicates whether the organization is applying as prime recipient, sub-awardee, consortium member, joint venture partner, or solo applicant.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalStatus rdf:type rdf:Property ;
    rdfs:label 'Proposal Status' ;
    rdfs:comment 'Current lifecycle status of the proposal. Tracks progression from draft through internal review, submission, donor review, shortlisting, and final outcome (awarded, rejected, or withdrawn). [ENUM-REF-CANDIDATE: draft|internal_review|submitted|under_review|shortlisted|awarded|rejected|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalType rdf:type rdf:Property ;
    rdfs:label 'Proposal Type' ;
    rdfs:comment 'Classification of the proposal submission format and stage. Indicates whether this is a full application, concept note, expression of interest, unsolicited submission, pre-proposal, or letter of inquiry.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Proposed Duration Months' ;
    rdfs:comment 'Total duration of the proposed project period of performance expressed in months. Calculated from proposed start and end dates.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedEndDate rdf:type rdf:Property ;
    rdfs:label 'Proposed End Date' ;
    rdfs:comment 'Proposed end date for the period of performance if the grant is awarded. Marks the conclusion of the planned implementation timeline.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedStartDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Start Date' ;
    rdfs:comment 'Proposed start date for the period of performance if the grant is awarded. Marks the beginning of the planned implementation timeline.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedAmount rdf:type rdf:Property ;
    rdfs:label 'Requested Amount' ;
    rdfs:comment 'Total funding amount requested from the donor in the proposal currency. Represents the gross budget request before any donor adjustments or negotiations.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Requested Amount Usd' ;
    rdfs:comment 'Total funding amount requested converted to USD using the exchange rate at submission date. Enables cross-proposal comparison and pipeline analysis in a common currency.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedCurrency rdf:type rdf:Property ;
    rdfs:label 'Requested Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the requested funding amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalApproachSummary rdf:type rdf:Property ;
    rdfs:label 'Technical Approach Summary' ;
    rdfs:comment 'High-level summary of the proposed technical approach, methodology, and intervention strategy. Captures key elements of the Theory of Change (ToC) and implementation plan.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winLossOutcome rdf:type rdf:Property ;
    rdfs:label 'Win Loss Outcome' ;
    rdfs:comment 'Final outcome of the proposal submission. Indicates whether the proposal was won (awarded), lost (rejected), is still pending donor decision, or was withdrawn by the organization.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardCurrency rdf:type rdf:Property ;
    rdfs:label 'Award Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the budget is denominated (e.g., USD, EUR, GBP). This is the donor-facing currency.' ;
    rdfs:domain ind:AwardBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNarrativeReference rdf:type rdf:Property ;
    rdfs:label 'Budget Narrative Reference' ;
    rdfs:comment 'Reference identifier or document location for the detailed budget narrative that explains and justifies each budget line item. Typically a document management system reference.' ;
    rdfs:domain ind:AwardBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNotes rdf:type rdf:Property ;
    rdfs:label 'Budget Notes' ;
    rdfs:comment 'Free-text field for additional notes, clarifications, or special conditions related to this budget version.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPeriod rdf:type rdf:Property ;
    rdfs:label 'Budget Period' ;
    rdfs:comment 'The budget period this budget covers, typically expressed as Year 1, Year 2, etc., or Period 1, Period 2, etc., or Full Award Period for multi-year consolidated budgets.' ;
    rdfs:domain ind:AwardBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Budget Submission Date' ;
    rdfs:comment 'The date this budget version was submitted to the donor for review and approval.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Donor Approval Date' ;
    rdfs:comment 'The date the donor officially approved this budget version.' ;
    rdfs:domain ind:AwardBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indirectCostBase rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Base' ;
    rdfs:comment 'The cost base to which the NICRA rate is applied. Common bases include Modified Total Direct Costs (MTDC), Total Direct Costs, or Salaries and Wages.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAmendment rdf:type rdf:Property ;
    rdfs:label 'Is Amendment' ;
    rdfs:comment 'Flag indicating whether this budget version is an amendment to a previously approved budget (True) or the original budget (False).' ;
    rdfs:domain ind:AwardBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nicraRateApplied rdf:type rdf:Property ;
    rdfs:label 'Nicra Rate Applied' ;
    rdfs:comment 'The indirect cost rate (expressed as a percentage) applied to calculate F&A costs. This is the rate from the organizations NICRA with the cognizant federal agency.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preparedBy rdf:type rdf:Property ;
    rdfs:label 'Prepared By' ;
    rdfs:comment 'Name or identifier of the staff member who prepared this budget version.' ;
    rdfs:domain ind:AwardBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalApprovedBudget rdf:type rdf:Property ;
    rdfs:label 'Total Approved Budget' ;
    rdfs:comment 'The total approved budget amount for this budget period in the award currency. Sum of all direct and indirect costs.' ;
    rdfs:domain ind:AwardBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalIndirectCosts rdf:type rdf:Property ;
    rdfs:label 'Total Indirect Costs' ;
    rdfs:comment 'Total indirect costs (Facilities and Administration / F&A) approved for this budget period. Calculated by applying the NICRA rate to the approved direct cost base.' ;
    rdfs:domain ind:AwardBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financeBudgetLineId rdf:type rdf:Property ;
    rdfs:label 'Finance Budget Line Id' ;
    rdfs:comment 'Foreign key linking to finance.budget_line. Business justification: Award budget line items must link to finance budget lines for detailed expenditure tracking, budget-to-actual variance reporting, and grant financial statement preparation. Nonprofits track grant budg' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetLine .

ind:allocabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Allocability Flag' ;
    rdfs:comment 'Indicates whether costs charged to this budget line are allocable to the grant award in accordance with relative benefits received, per OMB Uniform Guidance 2 CFR 200.405.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Allowability Flag' ;
    rdfs:comment 'Indicates whether this budget line item is allowable under applicable donor regulations (OMB Uniform Guidance 2 CFR 200 Subpart E, USAID ADS). True if allowable; False if unallowable or requires special approval.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Original approved budget amount for this line item as authorized in the initial grant award agreement.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Approved Amount Usd' ;
    rdfs:comment 'Approved budget amount converted to United States Dollars for standardized reporting and analysis.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetLineStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Line Status' ;
    rdfs:comment 'Current lifecycle status of the budget line item within the award budget structure.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costShareRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Share Required Flag' ;
    rdfs:comment 'Indicates whether this budget line requires cost sharing or matching funds from the organization or other non-federal sources, per donor agreement terms.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulativeExpenditure rdf:type rdf:Property ;
    rdfs:label 'Cumulative Expenditure' ;
    rdfs:comment 'Total actual expenditure incurred against this budget line from award inception through the current reporting period.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeExpenditureUsd rdf:type rdf:Property ;
    rdfs:label 'Cumulative Expenditure Usd' ;
    rdfs:comment 'Cumulative expenditure converted to United States Dollars for standardized variance analysis and donor reporting.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Donor Reporting Category' ;
    rdfs:comment 'Donor-specific classification or reporting code required for financial reports submitted to the funding agency (e.g., BHA, USAID, DFID, CERF).' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Fiscal period (month, quarter, or custom period) within the fiscal year to which this budget line applies.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General ledger account code in the organizations chart of accounts (CoA) to which expenditures for this budget line are posted.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indirectCostAmount rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Amount' ;
    rdfs:comment 'Calculated indirect cost (facilities and administration) amount allocated to this budget line based on the applied NICRA rate.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineItemCode rdf:type rdf:Property ;
    rdfs:label 'Line Item Code' ;
    rdfs:comment 'Unique alphanumeric code identifying this budget line within the award budget structure, often aligned with donor or organizational chart of accounts.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonablenessFlag rdf:type rdf:Property ;
    rdfs:label 'Reasonableness Flag' ;
    rdfs:comment 'Indicates whether the budgeted amount is reasonable and does not exceed what a prudent person would incur under similar circumstances, per OMB Uniform Guidance 2 CFR 200.404.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisedAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Amount' ;
    rdfs:comment 'Current authorized budget amount for this line item after any approved amendments, budget reallocations, or modifications. Null if no revisions have occurred.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Revised Amount Usd' ;
    rdfs:comment 'Revised budget amount converted to United States Dollars. Null if no revisions have occurred.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Date of the most recent budget revision or amendment affecting this line item. Null if no revisions have occurred.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier or file path to supporting documentation for this budget line (e.g., quotes, justifications, donor correspondence).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Difference between the current authorized budget (revised or approved) and cumulative expenditure. Positive indicates under-spend; negative indicates over-spend.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Variance expressed as a percentage of the current authorized budget, used for burn-rate monitoring and budget-versus-actual (BvA) analysis.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preparedByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Prepared By Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Grant amendment preparation is a named compliance workflow requiring staff accountability for audit trails. Amendments affecting budget, scope, or timeline must be traceable to the preparing staff mem' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:supersedesAmendmentGrantAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Amendment Grant Amendment Id' ;
    rdfs:comment 'Reference to a previous amendment that this amendment supersedes or replaces. Used to track amendment version history.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GrantAmendment .

ind:approvedByTitle rdf:type rdf:Property ;
    rdfs:label 'Approved By Title' ;
    rdfs:comment 'Title or position of the donor agency official who approved this amendment (e.g., Grants Officer, Agreement Officer, Program Officer).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetModificationSummary rdf:type rdf:Property ;
    rdfs:label 'Budget Modification Summary' ;
    rdfs:comment 'Summary of budget line item changes resulting from this amendment. Describes reallocations, increases, or decreases across cost categories.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingChange rdf:type rdf:Property ;
    rdfs:label 'Funding Change' ;
    rdfs:comment 'Net change in funding resulting from this amendment. Positive values indicate funding increases, negative values indicate decreases. Zero for non-financial amendments.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Geographic Change Description' ;
    rdfs:comment 'Description of any changes to the geographic coverage or implementation locations resulting from this amendment (e.g., expansion to new regions, closure of field sites).' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Internal Approval Date' ;
    rdfs:comment 'Date when the amendment request was approved internally by the nonprofit organization before submission to the donor.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalApproverName rdf:type rdf:Property ;
    rdfs:label 'Internal Approver Name' ;
    rdfs:comment 'Name of the internal organizational authority who approved the amendment request (e.g., Executive Director, Chief Grants Officer).' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyPersonnelChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Key Personnel Change Description' ;
    rdfs:comment 'Description of any changes to key personnel roles, including additions, removals, or role modifications. Key personnel typically include Principal Investigator, Project Director, and other critical leadership positions.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTotalObligation rdf:type rdf:Property ;
    rdfs:label 'Original Total Obligation' ;
    rdfs:comment 'Total obligated funding amount before this amendment. Provides baseline for calculating the impact of funding changes.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodExtensionDays rdf:type rdf:Property ;
    rdfs:label 'Period Extension Days' ;
    rdfs:comment 'Number of calendar days by which the period of performance is extended by this amendment. Calculated as the difference between revised and original end dates.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedTotalObligation rdf:type rdf:Property ;
    rdfs:label 'Revised Total Obligation' ;
    rdfs:comment 'Total obligated funding amount after applying this amendment. Equals original total obligation plus amendment funding change.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:termsAndConditionsChange rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Change' ;
    rdfs:comment 'Description of any modifications to the legal terms, conditions, reporting requirements, or compliance obligations under the grant agreement.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursedAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursed Amount' ;
    rdfs:comment 'The cumulative amount disbursed to the implementing partner to date. Tracks actual cash transferred against the obligated amount.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'The nine-digit DUNS number of the implementing partner organization. Required for FFATA reporting and federal subawards.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffataReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ffata Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this subaward is subject to FFATA reporting requirements (typically subawards of $30,000 or more from federal sources).' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flowDownRequirements rdf:type rdf:Property ;
    rdfs:label 'Flow Down Requirements' ;
    rdfs:comment 'Narrative description of the prime award terms and conditions that must be flowed down to the subrecipient, including compliance obligations, reporting requirements, and audit provisions.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsrsReportDate rdf:type rdf:Property ;
    rdfs:label 'Fsrs Report Date' ;
    rdfs:comment 'The date when the subaward was reported to the FFATA Subaward Reporting System (FSRS), if applicable.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligatedAmount rdf:type rdf:Property ;
    rdfs:label 'Obligated Amount' ;
    rdfs:comment 'The current total obligated amount under the subaward, including any amendments. May differ from the original total subaward amount due to modifications.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentSchedule rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule' ;
    rdfs:comment 'The schedule or basis on which payments are made to the implementing partner (e.g., advance, reimbursement, milestone-based).' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodOfPerformanceEndDate rdf:type rdf:Property ;
    rdfs:label 'Period Of Performance End Date' ;
    rdfs:comment 'The date when the subaward period of performance ends. Defines the end of the implementing partners authorized work period.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodOfPerformanceStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Of Performance Start Date' ;
    rdfs:comment 'The date when the subaward period of performance begins. Defines the start of the implementing partners authorized work period.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance' ;
    rdfs:comment 'The remaining unspent balance of the subaward. Calculated as obligated amount minus disbursed amount.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:singleAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Single Audit Required Flag' ;
    rdfs:comment 'Indicates whether the implementing partner is required to undergo a Single Audit per 2 CFR 200 Subpart F based on federal expenditure thresholds.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subawardDescription rdf:type rdf:Property ;
    rdfs:label 'Subaward Description' ;
    rdfs:comment 'Detailed narrative description of the subaward scope, objectives, deliverables, and expected outcomes.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subawardNumber rdf:type rdf:Property ;
    rdfs:label 'Subaward Number' ;
    rdfs:comment 'The externally-known unique business identifier for this subaward. Used in all legal documents, reporting, and correspondence.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subawardStatus rdf:type rdf:Property ;
    rdfs:label 'Subaward Status' ;
    rdfs:comment 'Current lifecycle status of the subaward. Tracks the subaward from initial draft through active performance to closeout.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subawardType rdf:type rdf:Property ;
    rdfs:label 'Subaward Type' ;
    rdfs:comment 'Classification of the subaward instrument type. Determines the legal and compliance framework applicable to the subaward.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSubawardAmount rdf:type rdf:Property ;
    rdfs:label 'Total Subaward Amount' ;
    rdfs:comment 'The total obligated amount of the subaward in the subaward currency. Represents the maximum financial obligation to the implementing partner.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSubawardAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Total Subaward Amount Usd' ;
    rdfs:comment 'The total subaward amount converted to USD for consolidated reporting and analysis. Conversion uses the exchange rate at the time of subaward execution.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ueiNumber rdf:type rdf:Property ;
    rdfs:label 'Uei Number' ;
    rdfs:comment 'The twelve-character alphanumeric Unique Entity Identifier assigned to the implementing partner by SAM.gov. Replaces DUNS for federal reporting.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorConditionId rdf:type rdf:Property ;
    rdfs:label 'Donor Condition Id' ;
    rdfs:comment 'Unique identifier for the donor condition record. Primary key for the donor_condition data product.' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indicatorTargetId rdf:type rdf:Property ;
    rdfs:label 'Indicator Target Id' ;
    rdfs:comment 'Foreign key linking to mel.indicator_target. Business justification: Donor special award conditions frequently require achieving a specific indicator target value by a deadline (e.g., \'80% of target X by Year 2\'). Linking donor_condition to indicator_target enables com' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndicatorTarget .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'The date on which the donor condition was actually met or the required action was completed. Null if the condition is not yet met.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Reference Number' ;
    rdfs:comment 'Reference number or identifier for the formal approval document or communication (e.g., approval letter number, email reference).' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionCategory rdf:type rdf:Property ;
    rdfs:label 'Condition Category' ;
    rdfs:comment 'Broader categorization of the condition by functional area. Values: financial (budget, cost, financial reporting), programmatic (deliverables, milestones, beneficiary targets), administrative (staffing, procurement, subcontracting), compliance (regulatory, legal, policy adherence), safeguarding (protection, GBV prevention, child safeguarding), environmental (environmental impact, WASH standards).' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionDescription rdf:type rdf:Property ;
    rdfs:label 'Condition Description' ;
    rdfs:comment 'Detailed narrative description of the donor condition, including specific requirements, deliverables, thresholds, and any contextual information provided by the donor.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Condition Reference Number' ;
    rdfs:comment 'Externally-known unique identifier or code assigned to this donor condition by the donor or grant management system (e.g., SAC-2024-001, COND-BHA-45).' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionTitle rdf:type rdf:Property ;
    rdfs:label 'Condition Title' ;
    rdfs:comment 'Short, human-readable title or summary of the donor condition (e.g., \'Quarterly Financial Report Submission\', \'Prior Approval for Subawards Over $100K\').' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'Classification of the donor condition indicating the nature of the compliance obligation. Values: prior_approval_requirement (donor must approve before action), restricted_cost (specific cost category restrictions), reporting_obligation (scheduled or ad-hoc reporting requirement), key_personnel_approval (approval required for key staff changes), branding_marking_requirement (logo, attribution, visibility requirements), audit_requirement (financial or programmatic audit mandate).' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverable Description' ;
    rdfs:comment 'Detailed description of the specific deliverable, report, approval, or action required to satisfy this condition.' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Donor Contact Email' ;
    rdfs:comment 'Email address of the donor representative responsible for this condition.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorContactName rdf:type rdf:Property ;
    rdfs:label 'Donor Contact Name' ;
    rdfs:comment 'Name of the donor representative or grants officer who is the point of contact for questions or clarifications regarding this condition.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Days' ;
    rdfs:comment 'Number of days before the due date when this condition should be escalated to senior management or flagged for urgent attention.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financialThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Threshold Amount' ;
    rdfs:comment 'Monetary threshold associated with this condition (e.g., prior approval required for subawards exceeding $100,000). Null if the condition does not have a financial threshold.' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialThresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Threshold Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial threshold amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSpecialAwardCondition rdf:type rdf:Property ;
    rdfs:label 'Is Special Award Condition' ;
    rdfs:comment 'Boolean flag indicating whether this condition is a Special Award Condition (SAC) imposed by the donor due to identified risks or past performance issues. True if this is a SAC, False otherwise.' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextRecurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Next Recurrence Date' ;
    rdfs:comment 'For recurring conditions, the date of the next scheduled occurrence or deadline. Null for one-time conditions.' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recurrenceFrequency rdf:type rdf:Property ;
    rdfs:label 'Recurrence Frequency' ;
    rdfs:comment 'Indicates whether this condition is a one-time requirement or recurs on a regular schedule. Values: one_time (single occurrence), monthly, quarterly, semi_annually, annually, as_needed (triggered by specific events).' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'Reference to the specific regulatory or policy section that mandates or governs this condition (e.g., \'2 CFR 200.308\', \'USAID ADS 303.3.10\', \'DFID Smart Rule 4.2.3\').' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sacJustification rdf:type rdf:Property ;
    rdfs:label 'Sac Justification' ;
    rdfs:comment 'Narrative explanation provided by the donor for why this Special Award Condition was imposed, including any identified risks or deficiencies.' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Date' ;
    rdfs:comment 'The date on which the donor formally waived this condition. Null if the condition was not waived.' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverJustification rdf:type rdf:Property ;
    rdfs:label 'Waiver Justification' ;
    rdfs:comment 'Narrative explanation provided by the donor or documented by the organization for why the condition was waived.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDonorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Donor Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or MEL officer responsible for preparing and submitting this donor report.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:auditFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Audit Findings Count' ;
    rdfs:comment 'Number of audit findings or compliance issues identified by internal or external auditors related to this reporting period, if applicable.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Amount' ;
    rdfs:comment 'The difference between the budgeted amount and the actual expenditure for the reporting period, calculated as actual minus budget (positive indicates overspend, negative indicates underspend).' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Percentage' ;
    rdfs:comment 'The budget variance expressed as a percentage of the budgeted amount, calculated as (actual - budget) / budget * 100.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Flag' ;
    rdfs:comment 'Boolean flag indicating whether the responsible staff member has certified that this report complies with all donor requirements, grant terms, and applicable regulations (True = certified, False = not certified).' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulativeExpenditureToDate rdf:type rdf:Property ;
    rdfs:label 'Cumulative Expenditure To Date' ;
    rdfs:comment 'Total cumulative expenditure reported to the donor from the grant start date through the end of this reporting period.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of calendar days by which the report submission was late, calculated as submission date minus due date. Null or zero if submitted on time.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:donorAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Donor Acceptance Date' ;
    rdfs:comment 'The date on which the donor formally accepted or approved this report submission, marking it as satisfactory and compliant.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorFeedbackSummary rdf:type rdf:Property ;
    rdfs:label 'Donor Feedback Summary' ;
    rdfs:comment 'Summary of feedback, comments, or recommendations provided by the donor in response to this report submission.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateUsed rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Used' ;
    rdfs:comment 'The foreign exchange rate applied to convert the reported financial amount from the grant currency to USD, if applicable.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialAmountReported rdf:type rdf:Property ;
    rdfs:label 'Financial Amount Reported' ;
    rdfs:comment 'Total financial expenditure or disbursement amount reported to the donor for the reporting period, in the grant currency.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialAmountReportedUsd rdf:type rdf:Property ;
    rdfs:label 'Financial Amount Reported Usd' ;
    rdfs:comment 'Total financial expenditure or disbursement amount reported to the donor, converted to United States Dollars (USD) for standardized reporting and analysis.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial amounts reported in this donor report (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFinalVersion rdf:type rdf:Property ;
    rdfs:label 'Is Final Version' ;
    rdfs:comment 'Boolean flag indicating whether this version of the donor report is the final, accepted version (True) or an interim/draft version (False).' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverdue rdf:type rdf:Property ;
    rdfs:label 'Is Overdue' ;
    rdfs:comment 'Boolean flag indicating whether this donor report was submitted after its due date (True = overdue, False = submitted on time or not yet due).' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyPerformanceIndicatorsMet rdf:type rdf:Property ;
    rdfs:label 'Key Performance Indicators Met' ;
    rdfs:comment 'Number of Key Performance Indicators (KPIs) or LogFrame indicators that met or exceeded their targets during the reporting period.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:keyPerformanceIndicatorsTotal rdf:type rdf:Property ;
    rdfs:label 'Key Performance Indicators Total' ;
    rdfs:comment 'Total number of Key Performance Indicators (KPIs) or LogFrame indicators being tracked and reported for this grant during the reporting period.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportNotes rdf:type rdf:Property ;
    rdfs:label 'Report Notes' ;
    rdfs:comment 'Free-text field for internal notes, special circumstances, or additional context related to this donor report submission.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Report Reference Number' ;
    rdfs:comment 'Externally-known unique identifier or tracking number for this donor report submission, often assigned by the donor or grant management system.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionRequestedDate rdf:type rdf:Property ;
    rdfs:label 'Revision Requested Date' ;
    rdfs:comment 'The date on which the donor requested revisions or additional information for this report, if applicable.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allowableCostCategories rdf:type rdf:Property ;
    rdfs:label 'Allowable Cost Categories' ;
    rdfs:comment 'Comma-separated list of cost categories or Chart of Accounts codes that are allowable under this funding source (e.g., personnel, travel, equipment, supplies). Used to enforce budget compliance and prevent unallowable cost charges.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRequirement rdf:type rdf:Property ;
    rdfs:label 'Audit Requirement' ;
    rdfs:comment 'The type of audit required by the donor for grants funded by this source. Single audit refers to OMB Uniform Guidance 2 CFR 200 Subpart F audits; program-specific audit refers to audits of individual programs; financial audit refers to organization-wide financial statement audits; no audit required indicates the donor does not mandate an audit.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetFlexibility rdf:type rdf:Property ;
    rdfs:label 'Budget Flexibility' ;
    rdfs:comment 'Classification of the degree of budget flexibility allowed by the donor for grants funded by this source. Fixed budgets require donor approval for any changes; flexible within categories allows reallocation within cost categories; flexible with approval allows reallocation with prior donor consent; fully flexible allows unrestricted reallocation.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetRevisionThreshold rdf:type rdf:Property ;
    rdfs:label 'Budget Revision Threshold' ;
    rdfs:comment 'The percentage threshold (expressed as a decimal, e.g., 0.1000 for 10%) above which budget revisions or reallocations require prior donor approval. Null if no threshold applies.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closeoutPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Closeout Period Days' ;
    rdfs:comment 'The number of calendar days after the grant end date within which all closeout activities (final reports, financial reconciliation, asset disposition) must be completed for grants funded by this source.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'Comma-separated list of regulatory and compliance frameworks that govern the use of this funding source (e.g., OMB Uniform Guidance 2 CFR 200, USAID Standard Provisions, DFID Terms and Conditions, CERF Grant Agreement). Used to segment compliance obligations by funding source.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonName rdf:type rdf:Property ;
    rdfs:label 'Contact Person Name' ;
    rdfs:comment 'The name of the primary contact person at the donor organization responsible for this funding source. Used for relationship management and grant administration inquiries.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Donor Reporting Frequency' ;
    rdfs:comment 'The frequency at which the donor organization requires narrative and financial reports for grants funded by this source. Drives reporting calendar and compliance tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingEndDate rdf:type rdf:Property ;
    rdfs:label 'Funding End Date' ;
    rdfs:comment 'The date on which this funding source expires or is no longer available for new grant awards. Represents the end of the funding period. Nullable for open-ended funding sources.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundingMechanismType rdf:type rdf:Property ;
    rdfs:label 'Funding Mechanism Type' ;
    rdfs:comment 'Classification of the funding mechanism through which resources are provided. Distinguishes between Official Development Assistance (ODA) bilateral and multilateral channels, foundation grants, corporate philanthropy, Central Emergency Response Fund (CERF) pooled funds, government contracts, private donations, and endowment income. [ENUM-REF-CANDIDATE: oda_bilateral|oda_multilateral|foundation_grant|corporate_philanthropy|cerf_pooled_fund|government_contract|private_donation|endowment_income — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSourceCode rdf:type rdf:Property ;
    rdfs:label 'Funding Source Code' ;
    rdfs:comment 'The unique alphanumeric code or identifier assigned to this funding source by the donor organization or internal grant management system for tracking and reporting purposes.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSourceDescription rdf:type rdf:Property ;
    rdfs:label 'Funding Source Description' ;
    rdfs:comment 'Detailed narrative description of the funding source, including its purpose, strategic priorities, target beneficiary populations, and any special conditions or donor intent. Used for internal reference and proposal development.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSourceName rdf:type rdf:Property ;
    rdfs:label 'Funding Source Name' ;
    rdfs:comment 'The official name of the funding source or funding mechanism as recognized by the donor organization and used in grant agreements.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSourceStatus rdf:type rdf:Property ;
    rdfs:label 'Funding Source Status' ;
    rdfs:comment 'Current lifecycle status of the funding source indicating whether it is actively available for grant awards, temporarily suspended, permanently closed, pending activation, or under review.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingStartDate rdf:type rdf:Property ;
    rdfs:label 'Funding Start Date' ;
    rdfs:comment 'The date from which this funding source becomes available for grant awards and disbursements. Represents the beginning of the funding period.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes or regional designations indicating geographic areas where this funding source may be used. Empty if no geographic restrictions apply.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatiOrganizationIdentifier rdf:type rdf:Property ;
    rdfs:label 'Iati Organization Identifier' ;
    rdfs:comment 'The globally unique IATI organization identifier for the donor organization providing this funding source. Enables cross-organizational aid transparency reporting and data exchange.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indirectCostRateType rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Rate Type' ;
    rdfs:comment 'The type of indirect cost rate mechanism applicable to this funding source. NICRA refers to a formally negotiated rate; de minimis refers to the 10% rate allowed under 2 CFR 200.414(f); cost reimbursement, fixed rate, and negotiated rate represent other donor-specific mechanisms.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nicraRate rdf:type rdf:Property ;
    rdfs:label 'Nicra Rate' ;
    rdfs:comment 'The negotiated indirect cost rate (expressed as a decimal, e.g., 0.1500 for 15%) applicable to this funding source for recovering facilities and administration costs. Used for US federal grants under OMB Uniform Guidance 2 CFR 200.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:odaDacClassification rdf:type rdf:Property ;
    rdfs:label 'Oda Dac Classification' ;
    rdfs:comment 'The OECD Development Assistance Committee classification code for this funding source if it qualifies as Official Development Assistance. Used for international aid transparency and reporting to DAC member countries.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementStandards rdf:type rdf:Property ;
    rdfs:label 'Procurement Standards' ;
    rdfs:comment 'Description of the procurement and contracting standards that must be followed when using this funding source (e.g., OMB Uniform Guidance 2 CFR 200.318-200.326, USAID Mandatory Standard Provisions, DFID Procurement Guidelines). Ensures compliance with donor procurement rules.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programIncomeTreatment rdf:type rdf:Property ;
    rdfs:label 'Program Income Treatment' ;
    rdfs:comment 'The method by which program income earned under grants funded by this source must be treated per OMB Uniform Guidance 2 CFR 200.307. Addition means income is added to the grant; deduction means income reduces the donor share; cost-sharing means income is used to meet cost-share requirements; no program income indicates the funding source does not generate program income.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Record Retention Years' ;
    rdfs:comment 'The number of years that financial and programmatic records for grants funded by this source must be retained after grant closeout, as required by the donor or applicable regulations (e.g., OMB Uniform Guidance requires 3 years).' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subawardAllowed rdf:type rdf:Property ;
    rdfs:label 'Subaward Allowed' ;
    rdfs:comment 'Boolean flag indicating whether this funding source permits the organization to issue subawards or subgrants to implementing partners and community-based organizations.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subawardApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Subaward Approval Required' ;
    rdfs:comment 'Boolean flag indicating whether the donor organization must provide prior written approval before the organization can issue subawards using this funding source.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thematicRestriction rdf:type rdf:Property ;
    rdfs:label 'Thematic Restriction' ;
    rdfs:comment 'Description of thematic or sectoral restrictions on the use of this funding source (e.g., WASH programs only, education initiatives, health services, emergency response). Empty if no thematic restrictions apply.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFundingAvailable rdf:type rdf:Property ;
    rdfs:label 'Total Funding Available' ;
    rdfs:comment 'The total amount of funding available from this source across all grant awards, expressed in the funding source currency. May represent a ceiling or allocation limit.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unallowableCostCategories rdf:type rdf:Property ;
    rdfs:label 'Unallowable Cost Categories' ;
    rdfs:comment 'Comma-separated list of cost categories or Chart of Accounts codes that are explicitly unallowable under this funding source (e.g., alcohol, entertainment, lobbying). Used to enforce budget compliance and prevent unallowable cost charges.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costShareCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Cost Share Commitment Id' ;
    rdfs:comment 'Unique identifier for the cost-share commitment record. Primary key.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:donorConstituentId rdf:type rdf:Property ;
    rdfs:label 'Donor Constituent Id' ;
    rdfs:comment 'Foreign key linking to donor.constituent. Business justification: Cost share commitments often provided by external donors/foundations as matching funds. Tracks which donor constituent provided the cost share for grant compliance, donor recognition, and stewardship ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:volunteerDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Volunteer Deployment Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer_deployment. Business justification: Cost-share commitments sourced from volunteer labor must reference the specific deployment generating the in-kind contribution. cost_share_commitment already has volunteer_hourly_rate and volunteer_ho' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VolunteerDeployment .

ind:auditFindingReference rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Reference' ;
    rdfs:comment 'Reference to any audit findings or observations related to this cost-share commitment, if applicable.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Date' ;
    rdfs:comment 'Date on which the cost-share commitment was formally made by the NGO or partner organization.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commitmentNotes rdf:type rdf:Property ;
    rdfs:label 'Commitment Notes' ;
    rdfs:comment 'Additional notes, comments, or context regarding this cost-share commitment, including any special conditions or donor instructions.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Reference Number' ;
    rdfs:comment 'External reference number or code assigned to this cost-share commitment for tracking and reporting purposes.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the cost-share commitment: planned (identified but not yet committed), committed (formally committed), verified (documentation complete and approved), partially_verified (some verification complete), non_compliant (commitment not met), or waived (donor waived requirement).' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Amount formally committed by the NGO or partner to meet the cost-share requirement, expressed in the grant currency.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costShareSourceDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Share Source Description' ;
    rdfs:comment 'Detailed description of the source of the cost-share contribution, including the contributing organization, department, or funding stream.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costShareType rdf:type rdf:Property ;
    rdfs:label 'Cost Share Type' ;
    rdfs:comment 'Type of cost-share contribution: cash (direct monetary contribution), in-kind (goods or services), third-party (contributions from external partners), or volunteer (volunteer time and services).' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inKindValuationMethod rdf:type rdf:Property ;
    rdfs:label 'In Kind Valuation Method' ;
    rdfs:comment 'Method used to value in-kind contributions (e.g., fair market value, independent appraisal, standard volunteer rate, depreciated asset value). Applicable only when cost_share_type is in-kind.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this cost-share commitment is mandatory per the grant agreement (true) or voluntary (false).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRestrictedFund rdf:type rdf:Property ;
    rdfs:label 'Is Restricted Fund' ;
    rdfs:comment 'Indicates whether the cost-share contribution comes from restricted funds (true) or unrestricted funds (false).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredCostShareAmount rdf:type rdf:Property ;
    rdfs:label 'Required Cost Share Amount' ;
    rdfs:comment 'Total cost-share amount required by the donor as a condition of the grant award, expressed in the grant currency.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredCostSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Required Cost Share Percentage' ;
    rdfs:comment 'Required cost-share expressed as a percentage of total project costs (e.g., 25.00 for 25% match requirement).' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Source Organization Name' ;
    rdfs:comment 'Name of the organization providing the cost-share contribution (may be the NGO itself, a partner, or a third-party donor).' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedAmount rdf:type rdf:Property ;
    rdfs:label 'Verified Amount' ;
    rdfs:comment 'Amount of cost-share that has been verified through documentation and approved by the donor or auditor, expressed in the grant currency.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volunteerHourlyRate rdf:type rdf:Property ;
    rdfs:label 'Volunteer Hourly Rate' ;
    rdfs:comment 'Standard hourly rate used to value volunteer time for cost-share purposes. Applicable only when cost_share_type is volunteer.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volunteerHours rdf:type rdf:Property ;
    rdfs:label 'Volunteer Hours' ;
    rdfs:comment 'Total number of volunteer hours contributed as part of this cost-share commitment. Applicable only when cost_share_type is volunteer.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'The constituent\'s preferred method of communication for stewardship, acknowledgment, and cultivation activities.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constituentType rdf:type rdf:Property ;
    rdfs:label 'Constituent Type' ;
    rdfs:comment 'The classification of the constituent entity. Individual = private person major gift donor; Institutional = government agency or public sector donor (USAID, DFID/FCDO); Foundation = private or family foundation; Corporate = business or corporate sponsor; Bilateral = government-to-government donor (DAC member); Multilateral = international organization (UN agencies, World Bank); Household = family unit for joint giving. [ENUM-REF-CANDIDATE: individual|institutional|foundation|corporate|bilateral|multilateral|household — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Crm Source Record Code' ;
    rdfs:comment 'The unique identifier of this constituent record in the source CRM system. Used for data lineage, reconciliation, and bi-directional sync.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Crm Source System' ;
    rdfs:comment 'The source CRM system from which this constituent record originated. Salesforce Nonprofit Cloud = Salesforce NPSP or Nonprofit Cloud; Raisers Edge NXT = Blackbaud Raisers Edge NXT; Other = other donor management system.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dacMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Dac Member Flag' ;
    rdfs:comment 'Indicates whether this constituent is a member of the OECD Development Assistance Committee. True = DAC member; False = not a DAC member. Used for ODA reporting and donor classification.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deceasedDate rdf:type rdf:Property ;
    rdfs:label 'Deceased Date' ;
    rdfs:comment 'The date on which the constituent passed away. Used for planned giving, estate gift tracking, and memorial acknowledgment.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deceasedFlag rdf:type rdf:Property ;
    rdfs:label 'Deceased Flag' ;
    rdfs:comment 'Indicates whether the constituent is deceased. True = deceased; False = living. Used to prevent inappropriate communications and for planned giving tracking.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Email Opt In Flag' ;
    rdfs:comment 'Indicates whether the constituent has explicitly consented to receive email communications. True = opted in; False = opted out or consent not given.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedGivingCapacity rdf:type rdf:Property ;
    rdfs:label 'Estimated Giving Capacity' ;
    rdfs:comment 'The estimated total giving capacity of the constituent based on wealth screening, prospect research, and capacity analysis. Expressed in USD. Used for major gift solicitation strategy and campaign goal setting.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstGiftDate rdf:type rdf:Property ;
    rdfs:label 'First Gift Date' ;
    rdfs:comment 'The date of the first gift or grant received from this constituent. Used for donor tenure analysis, anniversary recognition, and retention metrics.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:funderClassification rdf:type rdf:Property ;
    rdfs:label 'Funder Classification' ;
    rdfs:comment 'The classification of the funder based on international development and humanitarian standards. Bilateral = government-to-government donor; Multilateral = international organization (UN, World Bank); DAC Member = OECD Development Assistance Committee member country; Foundation = private or family foundation; Corporate = business or corporate sponsor; Individual = private individual donor; Other = other funder type. [ENUM-REF-CANDIDATE: bilateral|multilateral|dac_member|foundation|corporate|individual|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'The date on which the constituent provided GDPR consent for data processing. Used for audit and compliance tracking.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the constituent has provided explicit consent for data processing under GDPR requirements. True = consent given; False = consent not given or withdrawn.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:largestGiftAmount rdf:type rdf:Property ;
    rdfs:label 'Largest Gift Amount' ;
    rdfs:comment 'The amount of the largest single gift or grant received from this constituent. Expressed in USD. Used for major gift benchmarking and solicitation strategy.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastGiftDate rdf:type rdf:Property ;
    rdfs:label 'Last Gift Date' ;
    rdfs:comment 'The date of the most recent gift or grant received from this constituent. Used for lapsed donor identification, recency-frequency-monetary (RFM) analysis, and re-engagement campaigns.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The full legal name of the constituent as registered with government authorities or as appears on official documents. For individuals, this is the full legal name; for organizations, this is the registered entity name.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifetimeGivingTotal rdf:type rdf:Property ;
    rdfs:label 'Lifetime Giving Total' ;
    rdfs:comment 'The cumulative total of all gifts and grants received from this constituent since the first gift date. Expressed in USD. Used for donor recognition, stewardship segmentation, and major gift qualification.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mailingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line1' ;
    rdfs:comment 'The first line of the constituent\'s mailing address, typically containing street number and street name or PO Box.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line2' ;
    rdfs:comment 'The second line of the constituent\'s mailing address, typically containing apartment, suite, or building information.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'The city or municipality of the constituent\'s mailing address.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Country Code' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country code of the constituent\'s mailing address (e.g., USA, GBR, CHE).' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'The postal code or ZIP code of the constituent\'s mailing address.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Mailing State Province' ;
    rdfs:comment 'The state, province, or administrative region of the constituent\'s mailing address.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odaEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Oda Eligibility Flag' ;
    rdfs:comment 'Indicates whether gifts from this constituent qualify as ODA under DAC (Development Assistance Committee) criteria. True = ODA-eligible; False = not ODA-eligible. Used for IATI reporting and donor transparency.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organizationAffiliation rdf:type rdf:Property ;
    rdfs:label 'Organization Affiliation' ;
    rdfs:comment 'The name of the organization or institution the constituent is affiliated with. For individual donors, this may be their employer or foundation board membership; for institutional contacts, this is the parent agency or department.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredGrantModality rdf:type rdf:Property ;
    rdfs:label 'Preferred Grant Modality' ;
    rdfs:comment 'The type of grant funding this donor typically provides. Restricted = tied to specific projects or activities; Unrestricted = general operating support; Project = specific project funding; Program = program-level funding; Core = institutional core support; Capital = infrastructure or capital expenditure; Endowment = long-term endowment funding. [ENUM-REF-CANDIDATE: restricted|unrestricted|project|program|core|capital|endowment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectResearchRating rdf:type rdf:Property ;
    rdfs:label 'Prospect Research Rating' ;
    rdfs:comment 'The wealth screening and prospect research rating assigned to this constituent. A = highest capacity and propensity; B = high capacity; C = moderate capacity; D = lower capacity; Unrated = not yet screened. Used for major gift cultivation and campaign planning.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The timestamp when this constituent record was first created in the system. Used for audit trail and data lineage.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'The current lifecycle status of this constituent record. Active = current and valid; Inactive = no longer active but retained for history; Merged = merged into another record; Duplicate = identified as duplicate; Archived = archived for compliance retention.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The timestamp when this constituent record was last updated. Used for change tracking, data freshness monitoring, and incremental load processing.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:relationshipTier rdf:type rdf:Property ;
    rdfs:label 'Relationship Tier' ;
    rdfs:comment 'The donor cultivation and stewardship tier assigned to this constituent based on giving history, capacity, and engagement. Major = major gift donor; Principal = top-tier institutional funder; Leadership = leadership circle member; Sustaining = recurring donor; Annual = annual fund donor; Lapsed = former donor; Prospect = prospective donor under cultivation. [ENUM-REF-CANDIDATE: major|principal|leadership|sustaining|annual|lapsed|prospect — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to donor.campaign. Business justification: Prospects are often identified through specific campaigns (e.g., acquisition campaign identifies new prospects). Campaign attribution for prospect identification enables source tracking and campaign e' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:prospectAssignedResearcherStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Prospect Assigned Researcher Staff Member Id' ;
    rdfs:comment 'Reference to the prospect research professional assigned to conduct research on this prospect. Links to staff record in HRIS or CRM.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:prospectStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Prospect Staff Member Id' ;
    rdfs:comment 'Reference to the major gift officer or fundraising staff member assigned primary responsibility for cultivating this prospect. Links to staff record in HRIS (Human Resource Information System) or CRM.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:abilityScore rdf:type rdf:Property ;
    rdfs:label 'Ability Score' ;
    rdfs:comment 'Ability score component of the LAI (Linkage-Ability-Interest) assessment. Measures financial capacity to make a significant gift. Typically scored 1-5.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardAffiliation rdf:type rdf:Property ;
    rdfs:label 'Board Affiliation' ;
    rdfs:comment 'Known board memberships or trustee positions held by the prospect at other nonprofit organizations, foundations, or corporate boards. Indicates philanthropic engagement and network connections.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date when the prospect converted to an active donor by making their first gift or grant commitment. Null if not yet converted.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cultivationStrategy rdf:type rdf:Property ;
    rdfs:label 'Cultivation Strategy' ;
    rdfs:comment 'Detailed narrative describing the cultivation strategy, engagement plan, and relationship-building approach for this prospect. Includes key talking points, areas of interest, preferred communication channels, and strategic next steps.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Explanation for why the prospect was disqualified from active cultivation. Null if prospect is not disqualified. Examples: \'Insufficient capacity\', \'No mission alignment\', \'Unresponsive to outreach\', \'Ethical concerns\'.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorRecognitionPreference rdf:type rdf:Property ;
    rdfs:label 'Donor Recognition Preference' ;
    rdfs:comment 'Prospect\'s stated preference for public recognition of their giving. Public (full recognition in donor lists and materials), Anonymous (no public attribution), Limited (recognition in select contexts only), No Preference (not yet specified).' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCapacity rdf:type rdf:Property ;
    rdfs:label 'Estimated Capacity' ;
    rdfs:comment 'Estimated total giving capacity of the prospect in USD. Based on wealth screening, research, and capacity assessment. For institutional donors, represents estimated annual grant-making budget available for alignment with organizational mission.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedGiftRangeMax rdf:type rdf:Property ;
    rdfs:label 'Estimated Gift Range Max' ;
    rdfs:comment 'Maximum estimated gift amount expected from this prospect in USD. Upper bound of the anticipated solicitation range.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedGiftRangeMin rdf:type rdf:Property ;
    rdfs:label 'Estimated Gift Range Min' ;
    rdfs:comment 'Minimum estimated gift amount expected from this prospect in USD. Lower bound of the anticipated solicitation range.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Anticipated date when the prospect is expected to make a commitment decision or when grant award notification is expected.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicInterest rdf:type rdf:Property ;
    rdfs:label 'Geographic Interest' ;
    rdfs:comment 'Geographic regions or countries where the prospect has expressed interest in supporting programs. Comma-separated list of ISO 3166-1 alpha-3 country codes or regional descriptors.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestScore rdf:type rdf:Property ;
    rdfs:label 'Interest Score' ;
    rdfs:comment 'Interest score component of the LAI (Linkage-Ability-Interest) assessment. Measures alignment of prospect\'s philanthropic interests with organizational mission and programs. Typically scored 1-5.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the most recent meaningful contact or engagement with the prospect. Includes meetings, calls, events, correspondence.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastContactType rdf:type rdf:Property ;
    rdfs:label 'Last Contact Type' ;
    rdfs:comment 'Type of the most recent contact or engagement activity with the prospect. [ENUM-REF-CANDIDATE: meeting|phone_call|email|event|site_visit|proposal_submission|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkageScore rdf:type rdf:Property ;
    rdfs:label 'Linkage Score' ;
    rdfs:comment 'Linkage score component of the LAI (Linkage-Ability-Interest) assessment. Measures strength of existing connections to the organization (board members, staff, volunteers, beneficiaries). Typically scored 1-5.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mailingAddress rdf:type rdf:Property ;
    rdfs:label 'Mailing Address' ;
    rdfs:comment 'Full mailing address for prospect correspondence. Includes street address, city, state/province, postal code, and country.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Date' ;
    rdfs:comment 'Scheduled date for the next cultivation activity or touchpoint with this prospect. Used for pipeline management and follow-up tracking.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextActionDescription rdf:type rdf:Property ;
    rdfs:label 'Next Action Description' ;
    rdfs:comment 'Description of the planned next cultivation action or engagement activity (e.g., \'Schedule site visit\', \'Send program impact report\', \'Invite to annual gala\', \'Submit grant proposal\').' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousGivingHistory rdf:type rdf:Property ;
    rdfs:label 'Previous Giving History' ;
    rdfs:comment 'Summary of the prospect\'s known philanthropic giving history to other organizations or prior gifts to this organization. Includes gift amounts, recipient organizations, and giving patterns.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Probability Percentage' ;
    rdfs:comment 'Estimated probability (0-100%) that this prospect will convert to an active donor and make a gift. Used for pipeline forecasting and weighted revenue projections.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programInterestArea rdf:type rdf:Property ;
    rdfs:label 'Program Interest Area' ;
    rdfs:comment 'Primary program area or thematic focus that aligns with the prospect\'s philanthropic interests (e.g., \'WASH\', \'Education\', \'Health\', \'Emergency Response\', \'Gender Equality\'). May reference SDG (Sustainable Development Goal) alignment.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectName rdf:type rdf:Property ;
    rdfs:label 'Prospect Name' ;
    rdfs:comment 'Full legal or preferred name of the prospective donor or funder. For institutional donors, this is the organization name.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectStatus rdf:type rdf:Property ;
    rdfs:label 'Prospect Status' ;
    rdfs:comment 'Current operational status of the prospect record. Active (currently being cultivated), Inactive (no current engagement), Disqualified (determined not viable), Converted (became active donor), On Hold (temporarily paused cultivation).' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectType rdf:type rdf:Property ;
    rdfs:label 'Prospect Type' ;
    rdfs:comment 'Classification of the prospect by donor category. Individual (major gift prospects), Foundation (private/family/community foundations), Corporate (corporate sponsors), Institutional (USAID, DFID, DAC members), Government (bilateral government donors), Multilateral (UN agencies, World Bank, regional development banks).' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date when the prospect was qualified as a viable cultivation target after initial research and assessment. Null if not yet qualified.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rating rdf:type rdf:Property ;
    rdfs:label 'Rating' ;
    rdfs:comment 'Qualitative rating assigned by prospect research or major gift officer indicating overall prospect quality and likelihood of conversion. A+ (highest priority, strongest capacity and affinity), D (lowest priority).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchStage rdf:type rdf:Property ;
    rdfs:label 'Research Stage' ;
    rdfs:comment 'Current stage of prospect research activities. Not Started (no research conducted), Preliminary (initial screening and public records review), In Depth (comprehensive research including wealth screening and relationship mapping), Completed (research finalized and briefing prepared), Ongoing Monitoring (periodic updates and news monitoring).' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitationAmount rdf:type rdf:Property ;
    rdfs:label 'Solicitation Amount' ;
    rdfs:comment 'Specific dollar amount being requested or proposed in the current solicitation. Null if not yet at solicitation stage.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solicitationDate rdf:type rdf:Property ;
    rdfs:label 'Solicitation Date' ;
    rdfs:comment 'Date when the formal ask or grant proposal was submitted to the prospect. Null if not yet solicited.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceOfWealth rdf:type rdf:Property ;
    rdfs:label 'Source Of Wealth' ;
    rdfs:comment 'Primary source of the prospect\'s wealth or funding capacity (e.g., \'Technology entrepreneur\', \'Inherited wealth\', \'Real estate\', \'Government appropriation\', \'Endowment income\'). For institutional donors, describes funding source.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage in the donor cultivation pipeline lifecycle. Identification (newly identified prospect), Qualification (research and capacity assessment underway), Cultivation (relationship building and engagement), Solicitation (active proposal or ask), Negotiation (terms and agreement discussion), Stewardship (post-gift relationship management).' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wealthScreeningScore rdf:type rdf:Property ;
    rdfs:label 'Wealth Screening Score' ;
    rdfs:comment 'Quantitative wealth screening score from third-party wealth screening service (e.g., WealthEngine, iWave). Typically scaled 0-100 indicating relative wealth capacity.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftId rdf:type rdf:Property ;
    rdfs:label 'Gift Id' ;
    rdfs:comment 'Unique identifier for the gift transaction. Primary key for the gift data product.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gift .

ind:appealId rdf:type rdf:Property ;
    rdfs:label 'Appeal Id' ;
    rdfs:comment 'Reference to the specific appeal or solicitation within a campaign that generated this gift.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appeal .

ind:fundraisingEventId rdf:type rdf:Property ;
    rdfs:label 'Fundraising Event Id' ;
    rdfs:comment 'Foreign key linking to donor.fundraising_event. Business justification: Gifts can be made at or through fundraising events (ticket purchase, auction bid, event donation). Event attribution enables event ROI calculation, revenue tracking, and event effectiveness analysis. ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundraisingEvent .

ind:giftConstituentId rdf:type rdf:Property ;
    rdfs:label 'Gift Constituent Id' ;
    rdfs:comment 'Reference to the donor who made this gift. Links to the donor master record in the donor domain.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:giftMatchingEmployerConstituentId rdf:type rdf:Property ;
    rdfs:label 'Gift Matching Employer Constituent Id' ;
    rdfs:comment 'Reference to the corporate donor or employer providing the matching gift. Populated only when matching_gift_flag is true.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:originalGiftId rdf:type rdf:Property ;
    rdfs:label 'Original Gift Id' ;
    rdfs:comment 'Reference to the original employee gift that this matching gift is matching. Populated only for matching gifts.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gift .

ind:pledgeId rdf:type rdf:Property ;
    rdfs:label 'Pledge Id' ;
    rdfs:comment 'Foreign key linking to donor.pledge. Business justification: Gifts can be payments against pledges. This FK is CRITICAL for pledge fulfillment tracking, balance calculation, and installment schedule management. Nullable (not all gifts are pledge payments; some ' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pledge .

ind:receivableId rdf:type rdf:Property ;
    rdfs:label 'Receivable Id' ;
    rdfs:comment 'Foreign key linking to finance.receivable. Business justification: A gift payment may settle an outstanding AR receivable (grant drawdown billing, pledged amount invoiced). Linking gift to receivable enables cash application and AR reconciliation — a core nonprofit f' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Receivable .

ind:solicitorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Solicitor Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Gift officer attribution is a core NGO fundraising process: gifts must be credited to the soliciting staff member for fundraiser performance reports, portfolio ROI analysis, and compensation/incentive' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:acknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Date' ;
    rdfs:comment 'Date the donor acknowledgement or thank-you letter was sent for this gift.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgementType rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Type' ;
    rdfs:comment 'Classification of the donor acknowledgement or thank-you communication sent for this gift. [ENUM-REF-CANDIDATE: standard|personalized|major-gift|planned-giving|corporate|foundation|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The gross monetary value of the gift in the transaction currency before any adjustments or fees.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:anonymousFlag rdf:type rdf:Property ;
    rdfs:label 'Anonymous Flag' ;
    rdfs:comment 'Indicates whether the donor requested anonymity for this gift in public recognition and donor lists.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Transaction processing fees or costs deducted from the gross gift amount (e.g., credit card fees, wire transfer fees).' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftDate rdf:type rdf:Property ;
    rdfs:label 'Gift Date' ;
    rdfs:comment 'The date the gift was received or pledged. This is the principal business event timestamp for revenue recognition per FASB ASC 958.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:giftNumber rdf:type rdf:Property ;
    rdfs:label 'Gift Number' ;
    rdfs:comment 'Externally-known unique business identifier for this gift transaction, used for donor communication and receipt references.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftStatus rdf:type rdf:Property ;
    rdfs:label 'Gift Status' ;
    rdfs:comment 'Current lifecycle status of the gift transaction in the processing workflow.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftType rdf:type rdf:Property ;
    rdfs:label 'Gift Type' ;
    rdfs:comment 'Discriminator indicating the nature and form of the gift. Determines processing rules, revenue recognition treatment, and IRS substantiation requirements. [ENUM-REF-CANDIDATE: cash|check|wire|in-kind|stock|cryptocurrency|matching|tribute|pledge|recurring|refund|adjustment — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date this gift transaction was posted to the general ledger for financial reporting.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsServicesValue rdf:type rdf:Property ;
    rdfs:label 'Goods Services Value' ;
    rdfs:comment 'Fair market value of any goods or services provided to the donor in exchange for the gift, required for IRS substantiation and deductibility calculation.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:honoreeName rdf:type rdf:Property ;
    rdfs:label 'Honoree Name' ;
    rdfs:comment 'Full name of the person being honored or memorialized by this tribute gift. Populated only when tribute_flag is true.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Irs Compliant Flag' ;
    rdfs:comment 'Indicates whether the gift acknowledgement includes IRS-required substantiation language for charitable contribution deductions per IRS Publication 1771.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Match Approval Status' ;
    rdfs:comment 'Current status of the matching gift request with the employer. Populated only for matching gifts.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchRatio rdf:type rdf:Property ;
    rdfs:label 'Match Ratio' ;
    rdfs:comment 'The employer matching ratio (e.g., 1.00 for 1:1, 2.00 for 2:1, 0.50 for 1:2). Populated only for matching gifts.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchRequestDate rdf:type rdf:Property ;
    rdfs:label 'Match Request Date' ;
    rdfs:comment 'Date the matching gift request was submitted to the employer. Populated only for matching gifts.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchingGiftFlag rdf:type rdf:Property ;
    rdfs:label 'Matching Gift Flag' ;
    rdfs:comment 'Indicates whether this gift is a corporate matching gift from an employer matching an employees donation.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The net amount received after deducting processing fees, transaction costs, or goods-and-services fair market value per IRS requirements.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationRecipientAddress rdf:type rdf:Property ;
    rdfs:label 'Notification Recipient Address' ;
    rdfs:comment 'Mailing address for sending tribute gift notification to the honorees family or designated recipient.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRecipientName rdf:type rdf:Property ;
    rdfs:label 'Notification Recipient Name' ;
    rdfs:comment 'Name of the person who should be notified about this tribute gift (typically a family member of the honoree).' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the tribute gift notification has been sent to the designated recipient.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'The interface or touchpoint through which the donor made the gift, used for campaign attribution and channel effectiveness analysis. [ENUM-REF-CANDIDATE: online|mobile-app|direct-mail|phone|in-person|event|major-gift-officer|peer-to-peer|text-to-give|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Unique receipt number issued for this gift for IRS substantiation and donor tax deduction purposes.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Flag' ;
    rdfs:comment 'Indicates whether this record represents a gift refund or reversal transaction.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundReason rdf:type rdf:Property ;
    rdfs:label 'Refund Reason' ;
    rdfs:comment 'Explanation or business reason for refunding or reversing this gift. Populated only when refund_flag is true.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionDescription rdf:type rdf:Property ;
    rdfs:label 'Restriction Description' ;
    rdfs:comment 'Detailed narrative of any donor-imposed restrictions, purpose designations, or conditions on the use of the gift funds.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Classification of donor-imposed restrictions on the use of the gift per FASB ASC 958 net asset classification requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tributeFlag rdf:type rdf:Property ;
    rdfs:label 'Tribute Flag' ;
    rdfs:comment 'Indicates whether this gift is made in honor or memory of another person (tribute gift).' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tributeType rdf:type rdf:Property ;
    rdfs:label 'Tribute Type' ;
    rdfs:comment 'Classification of the tribute gift as either in honor of a living person or in memory of a deceased person. Populated only when tribute_flag is true.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'The date on which the pledge acknowledgment was sent to the donor.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentSent rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Sent' ;
    rdfs:comment 'Indicates whether a pledge acknowledgment letter or receipt has been sent to the donor.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'The cumulative amount paid to date across all installments. Updated as installment payments are received.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceOutstanding rdf:type rdf:Property ;
    rdfs:label 'Balance Outstanding' ;
    rdfs:comment 'The remaining unpaid balance on the pledge. Calculated as total_pledge_amount minus amount_paid.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date on which the donor or organization cancelled the pledge commitment. Populated only when pledge_status is cancelled.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstInstallmentDate rdf:type rdf:Property ;
    rdfs:label 'First Installment Date' ;
    rdfs:comment 'The scheduled due date for the first installment payment.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Date' ;
    rdfs:comment 'The date on which the pledge was fully paid and marked as fulfilled. Populated only when pledge_status is fulfilled.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Installment Frequency' ;
    rdfs:comment 'The recurring schedule for installment payments. One-time for single-payment pledges; monthly, quarterly, semi-annual, annual for standard recurring schedules; custom for irregular or donor-specified schedules.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installmentsPaid rdf:type rdf:Property ;
    rdfs:label 'Installments Paid' ;
    rdfs:comment 'The count of installments that have been fully paid to date. Updated as installment payments are received.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentsRemaining rdf:type rdf:Property ;
    rdfs:label 'Installments Remaining' ;
    rdfs:comment 'The count of installments that are still unpaid. Calculated as number_of_installments minus installments_paid.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAnonymous rdf:type rdf:Property ;
    rdfs:label 'Is Anonymous' ;
    rdfs:comment 'Indicates whether the donor has requested that this pledge be kept anonymous in public recognition and reporting.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMatchingGiftEligible rdf:type rdf:Property ;
    rdfs:label 'Is Matching Gift Eligible' ;
    rdfs:comment 'Indicates whether this pledge is eligible for corporate matching gift programs.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this pledge is a recurring sustainer commitment with ongoing installments beyond the initial schedule.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInstallmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Installment Date' ;
    rdfs:comment 'The scheduled due date for the final installment payment.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'The amount of the most recent installment payment received.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'The date on which the most recent installment payment was received.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextInstallmentAmount rdf:type rdf:Property ;
    rdfs:label 'Next Installment Amount' ;
    rdfs:comment 'The scheduled amount for the next unpaid installment.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInstallmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Installment Due Date' ;
    rdfs:comment 'The due date for the next unpaid installment. Used for reminder generation and overdue tracking.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfInstallments rdf:type rdf:Property ;
    rdfs:label 'Number Of Installments' ;
    rdfs:comment 'The total number of scheduled installment payments for this pledge. For one-time pledges, this is 1.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pledgeDate rdf:type rdf:Property ;
    rdfs:label 'Pledge Date' ;
    rdfs:comment 'The date on which the donor made the pledge commitment. This is the principal business event timestamp for the pledge.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pledgeNumber rdf:type rdf:Property ;
    rdfs:label 'Pledge Number' ;
    rdfs:comment 'Human-readable business identifier for the pledge commitment, often displayed on donor communications and receipts.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pledgeStatus rdf:type rdf:Property ;
    rdfs:label 'Pledge Status' ;
    rdfs:comment 'Current lifecycle status of the pledge commitment. Active indicates ongoing installment schedule; fulfilled indicates all installments paid; lapsed indicates overdue with no recent payment; written-off indicates uncollectible; cancelled indicates donor withdrew commitment; pending indicates awaiting approval or activation.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pledgeType rdf:type rdf:Property ;
    rdfs:label 'Pledge Type' ;
    rdfs:comment 'Classification of the pledge based on its purpose and structure. Standard for general multi-installment pledges; sustainer for recurring monthly giving; major gift for high-value commitments; planned giving for estate or deferred gifts; capital campaign for infrastructure projects; endowment for permanent fund contributions.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderSchedule rdf:type rdf:Property ;
    rdfs:label 'Reminder Schedule' ;
    rdfs:comment 'The timing for automated payment reminders sent to the donor before each installment due date.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPledgeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Pledge Amount' ;
    rdfs:comment 'The total monetary value committed by the donor across all installments. This is the gross pledge amount before any payments.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'The outstanding balance amount that was written off. Populated only when pledge_status is written_off.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The date on which the pledge was written off as uncollectible. Populated only when pledge_status is written_off.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffReason rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason' ;
    rdfs:comment 'Free-text explanation for why the pledge was written off (e.g., donor deceased, donor financial hardship, unable to contact, donor dispute).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCampaignId rdf:type rdf:Property ;
    rdfs:label 'Parent Campaign Id' ;
    rdfs:comment 'Reference to a parent campaign if this campaign is part of a larger multi-phase or hierarchical campaign structure.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:acknowledgmentTemplate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Template' ;
    rdfs:comment 'Name or identifier of the donor acknowledgment letter or email template used for gifts to this campaign.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealChannel rdf:type rdf:Property ;
    rdfs:label 'Appeal Channel' ;
    rdfs:comment 'Primary communication channel used to solicit donations for this campaign. [ENUM-REF-CANDIDATE: direct_mail|email|social_media|website|event|phone|peer_to_peer — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealDescription rdf:type rdf:Property ;
    rdfs:label 'Appeal Description' ;
    rdfs:comment 'Detailed narrative describing the campaign\'s mission, beneficiaries, and impact story used in donor communications.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Short alphanumeric code used for internal tracking and gift attribution. Often used in appeal codes and donation forms.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'The full name of the fundraising campaign as displayed to donors and staff.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the campaign indicating its operational state.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the fundraising campaign by its strategic purpose and donor engagement model.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfFundraising rdf:type rdf:Property ;
    rdfs:label 'Cost Of Fundraising' ;
    rdfs:comment 'Total expenses incurred to execute the campaign, including marketing, events, staff time, and materials.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorCount rdf:type rdf:Property ;
    rdfs:label 'Donor Count' ;
    rdfs:comment 'Total number of unique donors who have contributed to this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:giftCount rdf:type rdf:Property ;
    rdfs:label 'Gift Count' ;
    rdfs:comment 'Total number of individual gift transactions attributed to this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goalAmount rdf:type rdf:Property ;
    rdfs:label 'Goal Amount' ;
    rdfs:comment 'The target fundraising amount the campaign aims to raise, expressed in the organization\'s base currency.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactReportUrl rdf:type rdf:Property ;
    rdfs:label 'Impact Report Url' ;
    rdfs:comment 'Web address of the campaign impact report or results summary shared with donors.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPublic rdf:type rdf:Property ;
    rdfs:label 'Is Public' ;
    rdfs:comment 'Boolean flag indicating whether the campaign is publicly visible on the organization\'s website and donation pages.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchingGiftEligible rdf:type rdf:Property ;
    rdfs:label 'Matching Gift Eligible' ;
    rdfs:comment 'Boolean flag indicating whether donations to this campaign are eligible for corporate matching gift programs.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roiPercentage rdf:type rdf:Property ;
    rdfs:label 'Roi Percentage' ;
    rdfs:comment 'Calculated return on investment for the campaign, expressed as a percentage of net revenue over cost.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stewardshipPlan rdf:type rdf:Property ;
    rdfs:label 'Stewardship Plan' ;
    rdfs:comment 'Description of the donor stewardship and engagement activities planned for campaign contributors.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceSegment rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segment' ;
    rdfs:comment 'Description of the donor segment or constituency this campaign is designed to engage (e.g., major donors, monthly sustainers, corporate partners, lapsed donors).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDeductible rdf:type rdf:Property ;
    rdfs:label 'Tax Deductible' ;
    rdfs:comment 'Boolean flag indicating whether donations to this campaign are tax-deductible under IRS 501(c)(3) regulations or equivalent.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalRaisedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Raised Amount' ;
    rdfs:comment 'Cumulative amount of gifts and pledges received to date for this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appealCode rdf:type rdf:Property ;
    rdfs:label 'Appeal Code' ;
    rdfs:comment 'Externally-known unique code for the appeal used in gift attribution and tracking (e.g., DM2024Q1, EMAIL-SPRING, PHONE-EOY).' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealName rdf:type rdf:Property ;
    rdfs:label 'Appeal Name' ;
    rdfs:comment 'Human-readable name of the appeal (e.g., Spring Direct Mail Appeal, Year-End Email Solicitation).' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Current lifecycle status of the appeal.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealType rdf:type rdf:Property ;
    rdfs:label 'Appeal Type' ;
    rdfs:comment 'Classification of the appeal based on donor lifecycle stage and solicitation strategy.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:askAmount rdf:type rdf:Property ;
    rdfs:label 'Ask Amount' ;
    rdfs:comment 'Suggested or recommended gift amount presented to constituents in the appeal solicitation.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:askString rdf:type rdf:Property ;
    rdfs:label 'Ask String' ;
    rdfs:comment 'Formatted ask string presented to constituents showing multiple giving levels (e.g., $50, $100, $250, $500, Other).' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageGiftAmount rdf:type rdf:Property ;
    rdfs:label 'Average Gift Amount' ;
    rdfs:comment 'Average gift size for responses to this appeal calculated as total_revenue_amount / response_count.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Primary communication channel through which the appeal is delivered to constituents. [ENUM-REF-CANDIDATE: direct_mail|email|phone|digital|event|face_to_face|social_media — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlGroupFlag rdf:type rdf:Property ;
    rdfs:label 'Control Group Flag' ;
    rdfs:comment 'Indicates whether this appeal represents the control group in an A/B test (true) or a test variant (false).' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred to execute the appeal including production, postage, vendor fees, and staff time.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the appeal cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingDate rdf:type rdf:Property ;
    rdfs:label 'Mailing Date' ;
    rdfs:comment 'Date the appeal solicitation was sent or deployed to the target segment.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packageDescription rdf:type rdf:Property ;
    rdfs:label 'Package Description' ;
    rdfs:comment 'Detailed description of the solicitation package contents including letter, brochure, reply device, premium, and other components.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piecesSent rdf:type rdf:Property ;
    rdfs:label 'Pieces Sent' ;
    rdfs:comment 'Total count of solicitation pieces (letters, emails, calls) sent to constituents for this appeal.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:premiumOffered rdf:type rdf:Property ;
    rdfs:label 'Premium Offered' ;
    rdfs:comment 'Description of any premium or thank-you gift offered to donors responding to this appeal (e.g., tote bag, calendar, recognition pin).' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseCount rdf:type rdf:Property ;
    rdfs:label 'Response Count' ;
    rdfs:comment 'Total number of constituents who responded to the appeal with a gift or pledge.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseRatePercent rdf:type rdf:Property ;
    rdfs:label 'Response Rate Percent' ;
    rdfs:comment 'Percentage of constituents who responded to the appeal calculated as (response_count / pieces_sent) * 100.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the total revenue amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiRatio rdf:type rdf:Property ;
    rdfs:label 'Roi Ratio' ;
    rdfs:comment 'Return on investment ratio for the appeal calculated as total_revenue_amount / cost_amount. Values greater than 1.0 indicate positive ROI.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testSegmentFlag rdf:type rdf:Property ;
    rdfs:label 'Test Segment Flag' ;
    rdfs:comment 'Indicates whether this appeal is part of an A/B test or experimental segment for testing messaging, package, or channel effectiveness.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Amount' ;
    rdfs:comment 'Total gross revenue generated by gifts and pledges attributed to this appeal.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balance rdf:type rdf:Property ;
    rdfs:label 'Balance' ;
    rdfs:comment 'Current available balance in the fund representing cumulative gifts received minus disbursements and allocations. Updated through integration with SAP S/4HANA or Unit4 ERP fund accounting modules.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryPopulation rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Population' ;
    rdfs:comment 'Description of the target beneficiary population or vulnerable group that this fund is designated to serve (e.g., IDPs, refugees, children under 5, women survivors of GBV).' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endowmentSpendingPolicy rdf:type rdf:Property ;
    rdfs:label 'Endowment Spending Policy' ;
    rdfs:comment 'Description of the board-approved spending policy for endowment funds, including annual distribution rate, calculation methodology, and underwater endowment provisions per ASC 958.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundCategory rdf:type rdf:Property ;
    rdfs:label 'Fund Category' ;
    rdfs:comment 'High-level classification of the fund\'s purpose for portfolio management and strategic planning. Distinguishes operating funds from capital campaigns, emergency response funds, and endowments. [ENUM-REF-CANDIDATE: operating|capital|program|emergency_response|endowment|scholarship|research — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundCode rdf:type rdf:Property ;
    rdfs:label 'Fund Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the fund in donor communications, grant agreements, and financial reports. Used as the business identifier for fund accounting and stewardship.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundDescription rdf:type rdf:Property ;
    rdfs:label 'Fund Description' ;
    rdfs:comment 'Detailed narrative describing the purpose, scope, and intended use of the fund. Captures donor intent and programmatic objectives for stewardship and compliance reporting.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundName rdf:type rdf:Property ;
    rdfs:label 'Fund Name' ;
    rdfs:comment 'Full descriptive name of the fund as presented to donors and in financial statements. Human-readable identity label for the fund.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundStatus rdf:type rdf:Property ;
    rdfs:label 'Fund Status' ;
    rdfs:comment 'Current lifecycle state of the fund indicating whether it is actively accepting gifts and disbursing funds, or has been closed or temporarily suspended.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundType rdf:type rdf:Property ;
    rdfs:label 'Fund Type' ;
    rdfs:comment 'Classification of the fund based on donor restrictions and organizational policy. Determines accounting treatment per ASC 958 net asset classification requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inceptionDate rdf:type rdf:Property ;
    rdfs:label 'Inception Date' ;
    rdfs:comment 'Date when the fund was established and opened for gift acceptance. Marks the beginning of the fund\'s lifecycle.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investmentPolicy rdf:type rdf:Property ;
    rdfs:label 'Investment Policy' ;
    rdfs:comment 'Summary of investment strategy and asset allocation policy for endowment or quasi-endowment funds. References board-approved investment policy statement.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGiftAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Gift Amount' ;
    rdfs:comment 'Minimum contribution threshold required to designate a gift to this fund. Used for major gift funds, endowments, and named funds with donor-established minimums.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Restriction Expiration Date' ;
    rdfs:comment 'Date when time-based donor restrictions expire and temporarily restricted funds are released to unrestricted net assets. Nullable for perpetual or purpose-only restrictions.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetCountries rdf:type rdf:Property ;
    rdfs:label 'Target Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where the fund\'s resources are designated to be used. Supports geographic restriction tracking and field operations planning.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stewardshipActivityId rdf:type rdf:Property ;
    rdfs:label 'Stewardship Activity Id' ;
    rdfs:comment 'Unique identifier for the stewardship activity record. Primary key.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationFindingId rdf:type rdf:Property ;
    rdfs:label 'Evaluation Finding Id' ;
    rdfs:comment 'Foreign key linking to mel.evaluation_finding. Business justification: Stewardship activities communicate specific evaluation findings to donors — management response updates, finding closure notifications, and corrective action progress. stewardship_activity has evaluat' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EvaluationFinding .

ind:indicatorResultId rdf:type rdf:Property ;
    rdfs:label 'Indicator Result Id' ;
    rdfs:comment 'Foreign key linking to mel.indicator_result. Business justification: Stewardship activities (impact briefings, site visit reports, donor updates) reference specific indicator results to demonstrate program impact. stewardship_activity has indicator_id but not indicator' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndicatorResult .

ind:acknowledgementSentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Sent Date' ;
    rdfs:comment 'The date on which the acknowledgement communication was sent to the donor. Nullable if no acknowledgement was sent.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgementSentFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Sent Flag' ;
    rdfs:comment 'Boolean indicator of whether a formal acknowledgement or thank-you communication was sent following this stewardship activity.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activityDate rdf:type rdf:Property ;
    rdfs:label 'Activity Date' ;
    rdfs:comment 'The date on which the stewardship activity was conducted or scheduled. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activityDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Description' ;
    rdfs:comment 'Detailed narrative description of the stewardship activity, including context, discussion points, and any relevant details captured by the staff member.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityOutcome rdf:type rdf:Property ;
    rdfs:label 'Activity Outcome' ;
    rdfs:comment 'Summary of the outcome or result of the stewardship activity, including donor response, feedback received, and any commitments made.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current lifecycle status of the stewardship activity indicating whether it is planned, completed, cancelled, rescheduled, or pending.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activitySubject rdf:type rdf:Property ;
    rdfs:label 'Activity Subject' ;
    rdfs:comment 'Brief subject line or title summarizing the purpose of the stewardship activity.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Classification of the stewardship activity. [ENUM-REF-CANDIDATE: acknowledgement_letter|impact_report|site_visit|phone_call|event_invitation|personal_meeting|grant_report_delivery|thank_you_call|donor_briefing|recognition_event — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Number of individuals who participated in the stewardship activity, including staff and constituents. Applicable for meetings, site visits, and events.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'The medium or channel through which the stewardship activity was conducted (in-person meeting, phone call, email, video conference, postal mail, or event).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'The actual date on which the stewardship activity was marked as completed. Nullable for activities that are planned or cancelled.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorResponse rdf:type rdf:Property ;
    rdfs:label 'Donor Response' ;
    rdfs:comment 'The donor\'s response to any solicitation or engagement request made during the stewardship activity.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorSentiment rdf:type rdf:Property ;
    rdfs:label 'Donor Sentiment' ;
    rdfs:comment 'Qualitative assessment of the donor\'s sentiment or engagement level observed during the stewardship activity, used for relationship health tracking.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementScore rdf:type rdf:Property ;
    rdfs:label 'Engagement Score' ;
    rdfs:comment 'Quantitative engagement score assigned to the activity based on donor responsiveness, interest level, and interaction quality. Scale typically 1-10.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'The target date by which follow-up action should be completed. Nullable if no follow-up is required.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Boolean indicator of whether follow-up action is required based on the outcome of this stewardship activity.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactStorySharedFlag rdf:type rdf:Property ;
    rdfs:label 'Impact Story Shared Flag' ;
    rdfs:comment 'Boolean indicator of whether a beneficiary impact story or program outcome was shared with the donor during this activity.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical or virtual location where the stewardship activity took place (office address, donor site, event venue, or virtual meeting platform).' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextSteps rdf:type rdf:Property ;
    rdfs:label 'Next Steps' ;
    rdfs:comment 'Documented follow-up actions or next steps identified during or after the stewardship activity to continue donor cultivation.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Solicitation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the solicitation amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitationMadeFlag rdf:type rdf:Property ;
    rdfs:label 'Solicitation Made Flag' ;
    rdfs:comment 'Boolean indicator of whether a funding solicitation or ask was made to the donor during this stewardship activity.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stewardshipPlanStage rdf:type rdf:Property ;
    rdfs:label 'Stewardship Plan Stage' ;
    rdfs:comment 'The stage in the donor cultivation and stewardship lifecycle that this activity supports, aligned with the organization\'s donor relationship management framework.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Unique identifier for the donor segment record. Primary key.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Owner Staff Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:segmentCreatedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Segment Created By Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who created this segment record.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:segmentLastModifiedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Segment Last Modified By Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who last modified this segment record.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:segmentStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Segment Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member (fundraiser, development officer, or marketing manager) responsible for managing and stewarding this segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'Primary channel through which donors in this segment were acquired (e.g., \'Direct Mail\', \'Online Campaign\', \'Event\', \'Peer-to-Peer\', \'Major Gift Officer\'). Null if not channel-specific.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteria rdf:type rdf:Property ;
    rdfs:label 'Criteria' ;
    rdfs:comment 'Business rules or filter logic defining segment membership (e.g., \'Total giving >= $10,000 in last 12 months\', \'RFM score >= 400\', \'Geographic region = East Africa\').' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion Flag' ;
    rdfs:comment 'Flag indicating whether this segment represents an exclusion list (true) or an inclusion list (false). Exclusion segments are used to suppress communications.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:givingLevelMax rdf:type rdf:Property ;
    rdfs:label 'Giving Level Max' ;
    rdfs:comment 'Maximum cumulative giving amount threshold for inclusion in this segment (e.g., $49,999 for mid-level segment). Null if no upper bound.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:givingLevelMin rdf:type rdf:Property ;
    rdfs:label 'Giving Level Min' ;
    rdfs:comment 'Minimum cumulative giving amount threshold for inclusion in this segment (e.g., $10,000 for major donor segment). Null if not applicable.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDynamic rdf:type rdf:Property ;
    rdfs:label 'Is Dynamic' ;
    rdfs:comment 'Flag indicating whether segment membership is dynamically recalculated based on criteria (true) or manually managed (false).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Date' ;
    rdfs:comment 'Date when the segment membership was last recalculated or updated.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Donor lifecycle stage this segment represents: prospect (not yet donated), first_time (new donor), repeat (multi-year donor), lapsed (inactive), lybunt (Last Year But Unfortunately Not This Year), sybunt (Some Years But Unfortunately Not This Year), major (major gift donor), planned_giving (legacy/bequest donor). [ENUM-REF-CANDIDATE: prospect|first_time|repeat|lapsed|lybunt|sybunt|major|planned_giving — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticFocus rdf:type rdf:Property ;
    rdfs:label 'Programmatic Focus' ;
    rdfs:comment 'Thematic program area or SDG (Sustainable Development Goal) focus that defines this segment (e.g., \'WASH (Water Sanitation and Hygiene)\', \'Education\', \'Health\', \'Emergency Response\'). Null if not program-specific.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'Frequency at which dynamic segment membership is recalculated: daily, weekly, monthly, quarterly, on_demand (triggered by user), manual (no automatic refresh).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfmScoreMax rdf:type rdf:Property ;
    rdfs:label 'Rfm Score Max' ;
    rdfs:comment 'Maximum RFM (Recency-Frequency-Monetary) composite score for inclusion in this segment. Null if no upper bound.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfmScoreMin rdf:type rdf:Property ;
    rdfs:label 'Rfm Score Min' ;
    rdfs:comment 'Minimum RFM (Recency-Frequency-Monetary) composite score for inclusion in this segment. Null if RFM scoring not used.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Short alphanumeric code or abbreviation for the segment used in reporting and campaign tagging (e.g., MAJ-2024, LYBUNT-Q1, MID-ANN).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the segment purpose, target audience, and business rationale (e.g., \'Donors who gave last year but not this year, targeted for re-engagement\').' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the donor segment (e.g., Major Donors 2024, LYBUNT Q1, Mid-Level Annual Givers).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment: active (in use for campaigns), inactive (temporarily disabled), archived (historical, no longer used), draft (under development).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segment by its primary segmentation dimension: giving_level (major, mid-level, annual), rfm_tier (recency-frequency-monetary scoring), donor_type (individual, institutional, foundation, corporate), geographic (region-based), programmatic_interest (thematic focus area), acquisition_channel (source of donor acquisition).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stewardshipTier rdf:type rdf:Property ;
    rdfs:label 'Stewardship Tier' ;
    rdfs:comment 'Level of stewardship and engagement this segment receives: standard (basic acknowledgment), enhanced (personalized updates), premium (quarterly reports and calls), vip (executive engagement and site visits).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'Reason for exclusion if this is a suppression segment (e.g., \'Do Not Contact\', \'Deceased\', \'Unsubscribed\', \'Litigation Hold\'). Null if not an exclusion segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMemberCount rdf:type rdf:Property ;
    rdfs:label 'Target Member Count' ;
    rdfs:comment 'Planned or target number of members for this segment, used for capacity planning and campaign sizing.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wealthScreeningTier rdf:type rdf:Property ;
    rdfs:label 'Wealth Screening Tier' ;
    rdfs:comment 'Wealth capacity rating tier from prospect research or wealth screening services (e.g., \'High Net Worth\', \'Ultra High Net Worth\', \'Mid-Level Capacity\'). Null if wealth screening not applied.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when the donor segment was first created in the CRM (Constituent Relationship Management) system.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portfolioAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Assignment Id' ;
    rdfs:comment 'Primary key for portfolio_assignment' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPortfolioStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Portfolio Staff Member Id' ;
    rdfs:comment 'Reference to the major gift officer or fundraising staff member responsible for cultivating this constituent. Links to the staff/workforce record.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:affinityFocusArea rdf:type rdf:Property ;
    rdfs:label 'Affinity Focus Area' ;
    rdfs:comment 'The program area, cause, or mission focus that aligns with the constituent\'s philanthropic interests. Used for matching donors with appropriate gift officers and program staff.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Assignment Created By' ;
    rdfs:comment 'Username or identifier of the system user who created this portfolio assignment record. Used for audit trail and accountability.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Created Timestamp' ;
    rdfs:comment 'System timestamp when this portfolio assignment record was first created in the CRM system. Used for data lineage and audit purposes.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'The date when the constituent was assigned to the gift officer\'s portfolio. Marks the start of the cultivation relationship.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'The date when the portfolio assignment was terminated or transferred. Null for active assignments. Used for calculating relationship duration and officer performance metrics.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Assignment Modified By' ;
    rdfs:comment 'Username or identifier of the system user who last modified this portfolio assignment record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Modified Timestamp' ;
    rdfs:comment 'System timestamp when this portfolio assignment record was last updated. Used for tracking data freshness and change history.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'The business rationale for assigning this constituent to the gift officer. Provides context for portfolio management decisions and relationship continuity. [ENUM-REF-CANDIDATE: new_prospect|capacity_upgrade|geographic_alignment|relationship_transfer|officer_departure|portfolio_rebalance|strategic_priority|donor_request — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the portfolio assignment became effective. Used for tracking officer workload and relationship tenure.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:capacityCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Capacity Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated capacity amount. Supports multi-currency fundraising operations for international donors.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFrequencyTargetDays rdf:type rdf:Property ;
    rdfs:label 'Contact Frequency Target Days' ;
    rdfs:comment 'The target number of days between meaningful contacts for this portfolio tier. Used to monitor adherence to cultivation standards and identify overdue outreach.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementReadinessIndicator rdf:type rdf:Property ;
    rdfs:label 'Engagement Readiness Indicator' ;
    rdfs:comment 'Assessment of the constituent\'s current receptiveness to cultivation and solicitation activities. Informs timing and approach for next moves.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCapacityAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Capacity Amount' ;
    rdfs:comment 'The prospect research team\'s estimate of the constituent\'s philanthropic capacity. Used for portfolio segmentation and solicitation strategy. Confidential business intelligence.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedAskAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Ask Amount' ;
    rdfs:comment 'The planned solicitation amount for the next major gift request. Based on capacity research, giving history, and strategic priorities. Confidential cultivation planning data.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedAskDate rdf:type rdf:Property ;
    rdfs:label 'Expected Ask Date' ;
    rdfs:comment 'The target date for making the next major gift solicitation. Used for pipeline forecasting and officer activity planning.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicTerritory rdf:type rdf:Property ;
    rdfs:label 'Geographic Territory' ;
    rdfs:comment 'The geographic region or territory this constituent belongs to, used for portfolio segmentation when officers are assigned by geography. May be city, state, region, or country.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastGiftAmount rdf:type rdf:Property ;
    rdfs:label 'Last Gift Amount' ;
    rdfs:comment 'The monetary value of the most recent gift from this constituent. Used for upgrade potential assessment and solicitation sizing.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextContactScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Contact Scheduled Date' ;
    rdfs:comment 'The planned date for the next cultivation contact or stewardship touchpoint. Used for officer task management and ensuring consistent donor engagement.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portfolioLoadWeight rdf:type rdf:Property ;
    rdfs:label 'Portfolio Load Weight' ;
    rdfs:comment 'Weighted value representing the workload contribution of this assignment to the officer\'s total portfolio. Higher-tier prospects carry greater weight. Used for portfolio load balancing.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Portfolio Priority Rank' ;
    rdfs:comment 'Numeric ranking of this constituent within the officer\'s portfolio based on giving capacity, engagement readiness, and strategic importance. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portfolioStatus rdf:type rdf:Property ;
    rdfs:label 'Portfolio Status' ;
    rdfs:comment 'Current state of the portfolio assignment. Active indicates ongoing cultivation; on-hold indicates temporary pause; transferred indicates reassignment to another officer; inactive indicates no current engagement; graduated indicates moved to sustained giving program; declined indicates prospect declined engagement.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioTier rdf:type rdf:Property ;
    rdfs:label 'Portfolio Tier' ;
    rdfs:comment 'Classification of the portfolio segment based on giving capacity and cultivation strategy. Determines the level of personalized engagement and stewardship required.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Proposal Submitted Date' ;
    rdfs:comment 'The date when the most recent gift proposal was submitted to the constituent. Used for tracking proposal aging and follow-up timing.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposalSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Proposal Submitted Flag' ;
    rdfs:comment 'Indicates whether a formal gift proposal has been submitted to this constituent. True if proposal is pending or under consideration; false otherwise.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipStrengthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength Score' ;
    rdfs:comment 'Numeric score (typically 1-10 or 1-100) representing the depth and quality of the relationship between the gift officer and constituent. Used for prioritization and readiness assessment.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:solicitationStage rdf:type rdf:Property ;
    rdfs:label 'Solicitation Stage' ;
    rdfs:comment 'Current stage in the major gift fundraising cycle. Tracks progression from initial prospect identification through post-gift stewardship.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLifetimeGivingAmount rdf:type rdf:Property ;
    rdfs:label 'Total Lifetime Giving Amount' ;
    rdfs:comment 'Cumulative total of all gifts from this constituent to the organization across their entire giving history. Used for portfolio segmentation and recognition planning.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Date' ;
    rdfs:comment 'The date when the constituent was transferred from the previous gift officer to the current officer. Null if this is the initial assignment.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventManagerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Event Manager Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Fundraising event accountability requires linking the responsible staff member for post-event performance reviews, cost attribution, and HR workload reporting. Existing plain-text columns event_manage' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:capacityTotal rdf:type rdf:Property ;
    rdfs:label 'Capacity Total' ;
    rdfs:comment 'The maximum number of attendees the event can accommodate based on venue or platform constraints.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'The username or identifier of the system user who created this fundraising event record.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The scheduled date on which the fundraising event takes place.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed narrative description of the fundraising event, including purpose, activities, and beneficiary impact.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventEndTime rdf:type rdf:Property ;
    rdfs:label 'Event End Time' ;
    rdfs:comment 'The precise date and time when the fundraising event is scheduled to conclude.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventName rdf:type rdf:Property ;
    rdfs:label 'Event Name' ;
    rdfs:comment 'The official name or title of the fundraising event (e.g., Annual Gala, Spring Golf Tournament, Virtual Benefit Concert).' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStartTime rdf:type rdf:Property ;
    rdfs:label 'Event Start Time' ;
    rdfs:comment 'The precise date and time when the fundraising event is scheduled to begin.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fundraisingGoalAmount rdf:type rdf:Property ;
    rdfs:label 'Fundraising Goal Amount' ;
    rdfs:comment 'The target revenue amount the organization aims to raise from this event.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isTaxDeductible rdf:type rdf:Property ;
    rdfs:label 'Is Tax Deductible' ;
    rdfs:comment 'Indicates whether contributions made to this event qualify for tax deduction under IRS 501(c)(3) regulations or equivalent.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVirtualEvent rdf:type rdf:Property ;
    rdfs:label 'Is Virtual Event' ;
    rdfs:comment 'Indicates whether the fundraising event is conducted virtually (online) rather than at a physical venue.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The username or identifier of the system user who last modified this fundraising event record.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netRevenue rdf:type rdf:Property ;
    rdfs:label 'Net Revenue' ;
    rdfs:comment 'The net proceeds from the event, calculated as total revenue raised minus total event cost.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationCloseDate rdf:type rdf:Property ;
    rdfs:label 'Registration Close Date' ;
    rdfs:comment 'The date when registration for the event closes and no further registrations are accepted.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationOpenDate rdf:type rdf:Property ;
    rdfs:label 'Registration Open Date' ;
    rdfs:comment 'The date when registration for the event opens to constituents.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorshipLevelsAvailable rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Levels Available' ;
    rdfs:comment 'Comma-separated list or description of sponsorship tiers offered for the event (e.g., Platinum, Gold, Silver, Bronze).' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDeductiblePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Deductible Percentage' ;
    rdfs:comment 'The percentage of ticket price or contribution that qualifies as a tax-deductible charitable donation (e.g., 70% if 30% represents fair market value of goods/services received).' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ticketPriceTiers rdf:type rdf:Property ;
    rdfs:label 'Ticket Price Tiers' ;
    rdfs:comment 'Description or list of ticket pricing options available for attendees (e.g., General Admission, VIP, Student, Early Bird).' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAttendance rdf:type rdf:Property ;
    rdfs:label 'Total Attendance' ;
    rdfs:comment 'The actual number of individuals who attended the fundraising event, confirmed via check-in or participation tracking.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalEventCost rdf:type rdf:Property ;
    rdfs:label 'Total Event Cost' ;
    rdfs:comment 'The total expenses incurred to plan, organize, and execute the fundraising event (venue, catering, marketing, staff, etc.).' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRegistrations rdf:type rdf:Property ;
    rdfs:label 'Total Registrations' ;
    rdfs:comment 'The total number of individuals who registered for the fundraising event.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRevenueRaised rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Raised' ;
    rdfs:comment 'The actual total revenue generated from the fundraising event, including ticket sales, sponsorships, donations, and auction proceeds.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:venueAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Venue Address Line1' ;
    rdfs:comment 'First line of the street address for the event venue.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Venue Address Line2' ;
    rdfs:comment 'Second line of the street address for the event venue (suite, floor, building).' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueCity rdf:type rdf:Property ;
    rdfs:label 'Venue City' ;
    rdfs:comment 'City where the event venue is located.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueCountryCode rdf:type rdf:Property ;
    rdfs:label 'Venue Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the event venue location.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueName rdf:type rdf:Property ;
    rdfs:label 'Venue Name' ;
    rdfs:comment 'The name of the physical or virtual venue where the fundraising event is hosted.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venuePostalCode rdf:type rdf:Property ;
    rdfs:label 'Venue Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the event venue location.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueStateProvince rdf:type rdf:Property ;
    rdfs:label 'Venue State Province' ;
    rdfs:comment 'State or province where the event venue is located.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualPlatform rdf:type rdf:Property ;
    rdfs:label 'Virtual Platform' ;
    rdfs:comment 'Name of the online platform or service used to host the virtual fundraising event (e.g., Zoom, Microsoft Teams, custom web portal).' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleVolunteerRoleId rdf:type rdf:Property ;
    rdfs:label 'Responsible Volunteer Role Id' ;
    rdfs:comment 'Foreign key linking to volunteer.role. Business justification: NGO MEL systems assign specific volunteer roles as responsible data collectors for each indicator (e.g., community health volunteer role for health indicators). This drives training compliance checks ' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Role .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'The initial measured value of the indicator at the start of the program or project, used as the reference point for measuring change and progress.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Formula or methodology used to calculate the indicator value. For ratio indicators, includes numerator and denominator definitions. For count indicators, specifies aggregation rules.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dacCriteriaAlignment rdf:type rdf:Property ;
    rdfs:label 'Dac Criteria Alignment' ;
    rdfs:comment 'The OECD DAC (Development Assistance Committee) evaluation criteria that this indicator addresses: relevance, coherence, effectiveness, efficiency, impact, or sustainability. Multiple criteria may be comma-separated.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Data Collection Frequency' ;
    rdfs:comment 'How often data for this indicator is collected and reported (e.g., monthly, quarterly, annually, one-time baseline/endline). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi-annually|annually|one-time|event-based — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definition rdf:type rdf:Property ;
    rdfs:label 'Definition' ;
    rdfs:comment 'Detailed technical definition of what the indicator measures, including scope, boundaries, and any specific criteria or conditions that must be met.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denominatorDescription rdf:type rdf:Property ;
    rdfs:label 'Denominator Description' ;
    rdfs:comment 'Definition of the denominator for percentage or ratio indicators. Describes the total population or base being measured. Null for count-based indicators.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dhis2IndicatorCode rdf:type rdf:Property ;
    rdfs:label 'Dhis2 Indicator Code' ;
    rdfs:comment 'The unique identifier for this indicator in the DHIS2 (District Health Information System 2) platform, used for integration and data synchronization.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directionOfChange rdf:type rdf:Property ;
    rdfs:label 'Direction Of Change' ;
    rdfs:comment 'The desired direction of change for this indicator to represent positive program impact (increase for positive indicators like vaccination coverage, decrease for negative indicators like malnutrition rates).' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disaggregationDimensions rdf:type rdf:Property ;
    rdfs:label 'Disaggregation Dimensions' ;
    rdfs:comment 'Comma-separated list of dimensions by which this indicator should be disaggregated for analysis (e.g., age, gender, location, disability status, IDP/refugee status). Critical for equity and inclusion analysis.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorCategory rdf:type rdf:Property ;
    rdfs:label 'Indicator Category' ;
    rdfs:comment 'Measurement category of the indicator: quantitative (numeric), qualitative (descriptive), or composite (combination of multiple measures).' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorCode rdf:type rdf:Property ;
    rdfs:label 'Indicator Code' ;
    rdfs:comment 'Unique business identifier code for the indicator used across programs and grants. Often follows organizational or donor-specific coding conventions.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorName rdf:type rdf:Property ;
    rdfs:label 'Indicator Name' ;
    rdfs:comment 'Full descriptive name of the indicator as it appears in LogFrames (Logical Frameworks), donor reports, and MEL (Monitoring Evaluation and Learning) dashboards.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorStatus rdf:type rdf:Property ;
    rdfs:label 'Indicator Status' ;
    rdfs:comment 'Current lifecycle status of the indicator in the MEL (Monitoring Evaluation and Learning) system.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorType rdf:type rdf:Property ;
    rdfs:label 'Indicator Type' ;
    rdfs:comment 'Classification of the indicator within the Results-Based Management (RBM) results chain: input (resources), process (activities), output (deliverables), outcome (short-term change), or impact (long-term change).' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustom rdf:type rdf:Property ;
    rdfs:label 'Is Custom' ;
    rdfs:comment 'Flag indicating whether this is a custom indicator developed specifically for this organization or program (true) or a standard indicator from an external framework (false).' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logframeLevel rdf:type rdf:Property ;
    rdfs:label 'Logframe Level' ;
    rdfs:comment 'The level in the LogFrame (Logical Framework) hierarchy where this indicator is positioned: goal (impact), purpose (outcome), output (deliverable), or activity (process).' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numeratorDescription rdf:type rdf:Property ;
    rdfs:label 'Numerator Description' ;
    rdfs:comment 'Definition of the numerator for percentage or ratio indicators. Describes what is being counted in the top of the fraction. Null for count-based indicators.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDate rdf:type rdf:Property ;
    rdfs:label 'Target Date' ;
    rdfs:comment 'The date by which the target value is expected to be achieved.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The planned or target value that the program aims to achieve for this indicator by the end of the reporting period or project lifecycle.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:theme rdf:type rdf:Property ;
    rdfs:label 'Theme' ;
    rdfs:comment 'Cross-cutting theme or focus area this indicator addresses (e.g., Gender Equality, Child Protection, Climate Adaptation, Disability Inclusion, GBV (Gender-Based Violence) Prevention).' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantAwardId rdf:type rdf:Property ;
    rdfs:label 'Grant Award Id' ;
    rdfs:comment 'Reference to the grant or award that this logical framework supports. Links the LogFrame to the funding source and donor requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Award .

ind:parentLogframeMelLogframeId rdf:type rdf:Property ;
    rdfs:label 'Parent Logframe Mel Logframe Id' ;
    rdfs:comment 'Self-referencing foreign key to the parent LogFrame entry in the hierarchy. Enables nested results chains where outputs roll up to outcomes, outcomes to goals.' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Logframe .

ind:responsiblePositionId rdf:type rdf:Property ;
    rdfs:label 'Responsible Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: NGO logframe management assigns accountability to positions (not just individuals) for continuity during staff turnover. The plain-text \'responsible_party\' denormalizes position data. Logframe account' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'Date of the most recent actual measurement. Used to track reporting currency and identify data staleness.' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'Most recent measured or reported value for the indicator. Updated through Monitoring Evaluation and Learning (MEL) data collection activities such as Post-Distribution Monitoring (PDM), Focus Group Discussions (FGD), or District Health Information System 2 (DHIS2) reporting.' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dacEvaluationCriterion rdf:type rdf:Property ;
    rdfs:label 'Dac Evaluation Criterion' ;
    rdfs:comment 'Development Assistance Committee (DAC) evaluation criterion that this LogFrame element addresses. Used to align program design with international evaluation standards.' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorTemplateType rdf:type rdf:Property ;
    rdfs:label 'Donor Template Type' ;
    rdfs:comment 'Identifies the donor-specific logical framework template or format used. Different donors require different LogFrame structures and terminology. [ENUM-REF-CANDIDATE: DFID|FCDO|USAID|EU|ECHO|UN|World Bank|Generic|Other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchySequence rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Sequence' ;
    rdfs:comment 'Numeric ordering within the results chain hierarchy. Used to maintain the logical sequence of goals, outcomes, outputs, and activities.' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interventionStatement rdf:type rdf:Property ;
    rdfs:label 'Intervention Statement' ;
    rdfs:comment 'Narrative description of the intervention logic at this level of the results chain. Describes what the program intends to achieve or deliver.' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomIndicator rdf:type rdf:Property ;
    rdfs:label 'Is Custom Indicator' ;
    rdfs:comment 'Flag indicating whether this is a custom indicator defined by the implementing organization rather than a standard donor or sector indicator.' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatoryDonorIndicator rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory Donor Indicator' ;
    rdfs:comment 'Flag indicating whether this indicator is a mandatory reporting requirement from the donor. Mandatory indicators cannot be modified without prior approval.' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logframeCode rdf:type rdf:Property ;
    rdfs:label 'Logframe Code' ;
    rdfs:comment 'Business identifier or reference code for the logical framework, often aligned with donor proposal numbering or internal program codes.' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logframeName rdf:type rdf:Property ;
    rdfs:label 'Logframe Name' ;
    rdfs:comment 'Descriptive name or title of the logical framework, typically reflecting the program or intervention name.' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meansOfVerification rdf:type rdf:Property ;
    rdfs:label 'Means Of Verification' ;
    rdfs:comment 'Data source or method by which the indicator will be measured and verified. Examples include surveys, administrative records, Post-Distribution Monitoring (PDM), or District Health Information System 2 (DHIS2) reports.' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melLogframeStatus rdf:type rdf:Property ;
    rdfs:label 'Mel Logframe Status' ;
    rdfs:comment 'Current status of this LogFrame element in its lifecycle. Tracks whether targets are being met and whether the intervention logic remains valid. [ENUM-REF-CANDIDATE: Draft|Active|On Track|At Risk|Behind Schedule|Achieved|Closed|Cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectivelyVerifiableIndicator rdf:type rdf:Property ;
    rdfs:label 'Objectively Verifiable Indicator' ;
    rdfs:comment 'The measurable indicator that will be used to verify achievement of this results chain level. Links to the indicator library for tracking.' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultsChainLevel rdf:type rdf:Property ;
    rdfs:label 'Results Chain Level' ;
    rdfs:comment 'Hierarchical level within the results chain that this LogFrame row represents. Defines whether this is a goal, outcome, output, or activity level entry. [ENUM-REF-CANDIDATE: Goal|Impact|Purpose|Outcome|Output|Activity|Input — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:risks rdf:type rdf:Property ;
    rdfs:label 'Risks' ;
    rdfs:comment 'Identified risks or threats that could prevent achievement of this results chain level. Used for risk mitigation planning and adaptive management.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoryOfChangeComponent rdf:type rdf:Property ;
    rdfs:label 'Theory Of Change Component' ;
    rdfs:comment 'Identifies which component of the Theory of Change (ToC) this LogFrame row represents. Links the LogFrame to the broader causal pathway and intervention logic.' ;
    rdfs:domain ind:Logframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier for the logical framework. LogFrames are often revised during program amendments or mid-term reviews.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryIndicatorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Indicator Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or MEL officer accountable for tracking and reporting on this target.' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:disaggregationAgeGroup rdf:type rdf:Property ;
    rdfs:label 'Disaggregation Age Group' ;
    rdfs:comment 'Age group category for this target (e.g., 0-5, 6-17, 18-59, 60+). Supports age-sensitive programming and reporting.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disaggregationDisabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Disaggregation Disability Status' ;
    rdfs:comment 'Disability status disaggregation for this target, supporting inclusive programming and Washington Group standards.' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disaggregationDisplacementStatus rdf:type rdf:Property ;
    rdfs:label 'Disaggregation Displacement Status' ;
    rdfs:comment 'Displacement or migration status disaggregation (e.g., IDP, refugee, returnee, host community, Person of Concern).' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disaggregationSex rdf:type rdf:Property ;
    rdfs:label 'Disaggregation Sex' ;
    rdfs:comment 'Sex-based disaggregation category for this target (male, female, other, not specified). Used for gender-sensitive monitoring.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorReportingRequirement rdf:type rdf:Property ;
    rdfs:label 'Donor Reporting Requirement' ;
    rdfs:comment 'Specific donor reporting requirement or framework that this target must satisfy (e.g., USAID F indicator, DFID logframe output 2.1).' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'How often this indicator target is measured and reported (daily, weekly, monthly, quarterly, semi-annually, annually, one-time, continuous). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi_annually|annually|one_time|continuous — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Business identifier or code for this indicator target, often used in donor reports and LogFrame documentation.' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDescription rdf:type rdf:Property ;
    rdfs:label 'Target Description' ;
    rdfs:comment 'Detailed narrative description of what this target represents, including context and rationale.' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetName rdf:type rdf:Property ;
    rdfs:label 'Target Name' ;
    rdfs:comment 'Human-readable name or label for this indicator target.' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStatus rdf:type rdf:Property ;
    rdfs:label 'Target Status' ;
    rdfs:comment 'Current lifecycle status of the indicator target: draft (being defined), approved (validated by stakeholders), active (currently being tracked), on_track (progressing as planned), at_risk (may not be achieved), off_track (unlikely to be achieved), achieved (target met), not_achieved (target not met), revised (target has been modified), cancelled (target no longer applicable). [ENUM-REF-CANDIDATE: draft|approved|active|on_track|at_risk|off_track|achieved|not_achieved|revised|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetType rdf:type rdf:Property ;
    rdfs:label 'Target Type' ;
    rdfs:comment 'Classification of the target based on the results chain level: output (direct deliverables), outcome (intermediate results), impact (long-term change), process (operational efficiency), or input (resources).' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationSource rdf:type rdf:Property ;
    rdfs:label 'Verification Source' ;
    rdfs:comment 'The source or means of verification for this target (e.g., program records, beneficiary surveys, third-party evaluation, DHIS2 reports).' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectedByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Collected By Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Data quality assessments and MEAL audits require traceability to the staff member who collected indicator data. Currently tracked as collection_team text; FK enables accountability audits and capacity' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'Date when the indicator data was physically collected in the field or extracted from source systems. Distinct from reporting period dates.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributingFactors rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors' ;
    rdfs:comment 'Description of key factors that contributed to achievement or non-achievement of the indicator target. Supports learning and adaptive management.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActions rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions' ;
    rdfs:comment 'Documented corrective actions planned or taken in response to under-performance. Part of adaptive management and continuous improvement.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeResult rdf:type rdf:Property ;
    rdfs:label 'Cumulative Result' ;
    rdfs:comment 'Cumulative total of indicator results from program start through current reporting period. Used for life-of-project performance tracking.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityNotes rdf:type rdf:Property ;
    rdfs:label 'Data Quality Notes' ;
    rdfs:comment 'Free-text notes documenting data quality issues, limitations, or contextual factors affecting the reliability of this indicator result.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disaggregationDisability rdf:type rdf:Property ;
    rdfs:label 'Disaggregation Disability' ;
    rdfs:comment 'Disability status disaggregation per Washington Group Short Set. Required for inclusive programming and disability-focused donor reporting.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceFilePath rdf:type rdf:Property ;
    rdfs:label 'Evidence File Path' ;
    rdfs:comment 'File path or document reference to supporting evidence for this indicator result. Includes photos, survey data files, or verification reports.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicLevel rdf:type rdf:Property ;
    rdfs:label 'Geographic Level' ;
    rdfs:comment 'Administrative level at which this indicator result was measured. Enables hierarchical geographic aggregation and sub-national analysis.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorLevel rdf:type rdf:Property ;
    rdfs:label 'Indicator Level' ;
    rdfs:comment 'Level of the indicator in the results chain per Theory of Change (ToC). Distinguishes between immediate outputs, medium-term outcomes, and long-term impact.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMilestone rdf:type rdf:Property ;
    rdfs:label 'Is Milestone' ;
    rdfs:comment 'Indicates whether this indicator result represents a contractual milestone or critical deliverable per grant agreement terms.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:narrativeDescription rdf:type rdf:Property ;
    rdfs:label 'Narrative Description' ;
    rdfs:comment 'Qualitative narrative describing the context, achievements, challenges, and lessons learned related to this indicator result. Used in donor reports.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedToDonor rdf:type rdf:Property ;
    rdfs:label 'Reported To Donor' ;
    rdfs:comment 'Indicates whether this indicator result has been included in formal donor reporting. Tracks reporting compliance and audit trail.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Current workflow status of the indicator result record. Tracks approval and review lifecycle.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValue rdf:type rdf:Property ;
    rdfs:label 'Result Value' ;
    rdfs:comment 'Actual achieved value recorded for the indicator during the reporting period. The primary quantitative outcome measurement.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceFromTarget rdf:type rdf:Property ;
    rdfs:label 'Variance From Target' ;
    rdfs:comment 'Calculated difference between actual result and target value. Positive values indicate over-achievement, negative values indicate under-achievement.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the MEL officer or evaluator who verified this indicator result. Supports accountability and quality assurance.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMealStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Meal Staff Member Id' ;
    rdfs:comment 'Reference to the MEL staff member who is the lead or primary responsible party for implementing this MEAL plan.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accountabilityMechanisms rdf:type rdf:Property ;
    rdfs:label 'Accountability Mechanisms' ;
    rdfs:comment 'Description of accountability mechanisms embedded in the MEAL plan, including beneficiary feedback channels, complaint response mechanisms, and Core Humanitarian Standard (CHS) commitments.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Completion Date' ;
    rdfs:comment 'Date when the baseline assessment was completed. Baseline data provides the starting point for measuring program outcomes and impact.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiaryFeedbackChannels rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Feedback Channels' ;
    rdfs:comment 'Description of channels through which beneficiaries can provide feedback, complaints, and suggestions, including hotlines, suggestion boxes, community meetings, and digital platforms.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated' ;
    rdfs:comment 'Total budget allocated for implementing this MEAL plan, including costs for data collection, evaluation, staff time, tools, and analysis.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chsCommitmentAlignment rdf:type rdf:Property ;
    rdfs:label 'Chs Commitment Alignment' ;
    rdfs:comment 'Description of how this MEAL plan aligns with and monitors the nine Core Humanitarian Standard commitments to communities and people affected by crisis.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dacCriteriaCoverage rdf:type rdf:Property ;
    rdfs:label 'Dac Criteria Coverage' ;
    rdfs:comment 'Description of which DAC evaluation criteria (relevance, coherence, effectiveness, efficiency, impact, sustainability) are addressed in this MEAL plan and how they will be assessed.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMethods rdf:type rdf:Property ;
    rdfs:label 'Data Collection Methods' ;
    rdfs:comment 'Enumeration and description of data collection methods to be used, including surveys, Key Informant Interviews (KII), Focus Group Discussions (FGD), Post-Distribution Monitoring (PDM), and direct observation.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionTools rdf:type rdf:Property ;
    rdfs:label 'Data Collection Tools' ;
    rdfs:comment 'List of digital and paper-based tools and platforms to be used for data collection, such as KoboToolbox, CommCare, ODK, DHIS2, mobile data collection apps, and paper forms.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataDisaggregationPlan rdf:type rdf:Property ;
    rdfs:label 'Data Disaggregation Plan' ;
    rdfs:comment 'Description of how data will be disaggregated for analysis, including by age, gender, disability status, geographic location, and other relevant demographic and vulnerability factors.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataManagementProtocols rdf:type rdf:Property ;
    rdfs:label 'Data Management Protocols' ;
    rdfs:comment 'Description of data management protocols, including data storage, security, privacy, access controls, backup procedures, and compliance with data protection regulations.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityProtocols rdf:type rdf:Property ;
    rdfs:label 'Data Quality Protocols' ;
    rdfs:comment 'Description of data quality assurance and quality control protocols, including validation rules, data cleaning procedures, inter-rater reliability checks, and data verification processes.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorReportingRequirements rdf:type rdf:Property ;
    rdfs:label 'Donor Reporting Requirements' ;
    rdfs:comment 'Description of specific donor reporting requirements that this MEAL plan must satisfy, including report formats, indicators, frequency, and submission deadlines.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endlinePlannedDate rdf:type rdf:Property ;
    rdfs:label 'Endline Planned Date' ;
    rdfs:comment 'Planned date for the endline evaluation. Endline evaluations measure final outcomes and impact at the conclusion of the program cycle.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ethicalConsiderations rdf:type rdf:Property ;
    rdfs:label 'Ethical Considerations' ;
    rdfs:comment 'Description of ethical considerations and safeguards in data collection and evaluation, including informed consent procedures, do-no-harm principles, and protection of vulnerable populations.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationStrategy rdf:type rdf:Property ;
    rdfs:label 'Evaluation Strategy' ;
    rdfs:comment 'Description of the evaluation strategy, including planned evaluations (baseline, midline, endline), evaluation questions, methodologies, and timing aligned with DAC criteria.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorCount rdf:type rdf:Property ;
    rdfs:label 'Indicator Count' ;
    rdfs:comment 'Total number of Key Performance Indicators (KPI) and monitoring indicators defined in the indicator matrix for this MEAL plan.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:learningAgenda rdf:type rdf:Property ;
    rdfs:label 'Learning Agenda' ;
    rdfs:comment 'Description of the learning agenda, including key learning questions, knowledge management activities, and how learning will be captured and disseminated to inform adaptive management.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:midlinePlannedDate rdf:type rdf:Property ;
    rdfs:label 'Midline Planned Date' ;
    rdfs:comment 'Planned date for the midline evaluation. Midline evaluations assess progress toward outcomes at the midpoint of the program cycle.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringStrategy rdf:type rdf:Property ;
    rdfs:label 'Monitoring Strategy' ;
    rdfs:comment 'Comprehensive description of the monitoring strategy, including frequency, methods, data sources, and responsible parties for ongoing program monitoring.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rbmFrameworkAlignment rdf:type rdf:Property ;
    rdfs:label 'Rbm Framework Alignment' ;
    rdfs:comment 'Description of how this MEAL plan aligns with the organization\'s Results-Based Management framework and donor RBM requirements.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCalendar rdf:type rdf:Property ;
    rdfs:label 'Reporting Calendar' ;
    rdfs:comment 'Description of the reporting calendar, including frequency and timing of internal reports, donor reports, Situation Reports (SitRep), and other MEL deliverables.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionHistory rdf:type rdf:Property ;
    rdfs:label 'Revision History' ;
    rdfs:comment 'Summary of major revisions and amendments to the MEAL plan over its lifecycle, including dates and reasons for changes.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Plan' ;
    rdfs:comment 'Description of risks to MEL implementation (e.g., access constraints, security incidents, data quality issues) and mitigation strategies.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tocNarrative rdf:type rdf:Property ;
    rdfs:label 'Toc Narrative' ;
    rdfs:comment 'Narrative description of the Theory of Change that underpins this MEAL plan. Explains the causal pathway from inputs to impact and the assumptions being tested.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionedByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Commissioned By Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Evaluation management requires tracking internal staff who commissioned and oversee evaluations (distinct from external lead_evaluator_name). Essential for budget accountability, management response t' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:leadEvaluatorVolunteerId rdf:type rdf:Property ;
    rdfs:label 'Lead Evaluator Volunteer Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer. Business justification: Community-led and peer evaluations in NGOs are conducted by volunteer evaluators. evaluation.lead_evaluator_name is plain text denormalization. Linking to volunteer.volunteer_id enables evaluation qua' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual total cost incurred for conducting the evaluation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiarySampleSize rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Sample Size' ;
    rdfs:comment 'Number of beneficiaries or respondents included in the evaluation sample for primary data collection.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total budget allocated for conducting the evaluation, including consultant fees, travel, data collection, and report production costs.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coherenceRating rdf:type rdf:Property ;
    rdfs:label 'Coherence Rating' ;
    rdfs:comment 'Rating of the program\'s coherence (compatibility with other interventions, internal consistency) per DAC criteria (2019 revision).' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dacCriteriaAssessed rdf:type rdf:Property ;
    rdfs:label 'Dac Criteria Assessed' ;
    rdfs:comment 'Comma-separated list of DAC evaluation criteria assessed: relevance, coherence, effectiveness, efficiency, impact, sustainability. May include all or a subset depending on evaluation design.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Rating' ;
    rdfs:comment 'Rating of the program\'s effectiveness (extent to which objectives were achieved) per DAC criteria.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficiencyRating rdf:type rdf:Property ;
    rdfs:label 'Efficiency Rating' ;
    rdfs:comment 'Rating of the program\'s efficiency (value for money, resource utilization) per DAC criteria.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsApprovalObtained rdf:type rdf:Property ;
    rdfs:label 'Ethics Approval Obtained' ;
    rdfs:comment 'Indicates whether ethics approval or institutional review board clearance was obtained for the evaluation, particularly for studies involving vulnerable populations (true/false).' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evaluationCode rdf:type rdf:Property ;
    rdfs:label 'Evaluation Code' ;
    rdfs:comment 'Externally-known unique code or reference number for the evaluation, used in donor reports and internal tracking.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationScope rdf:type rdf:Property ;
    rdfs:label 'Evaluation Scope' ;
    rdfs:comment 'Detailed description of the evaluation scope, including geographic coverage, beneficiary segments, program components, and time period covered.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current lifecycle status of the evaluation: planned (scheduled but not started), inception (terms of reference development), fieldwork (data collection in progress), analysis (data analysis phase), draft_report (draft under review), final_report (completed), disseminated (findings shared with stakeholders), or cancelled. [ENUM-REF-CANDIDATE: planned|inception|fieldwork|analysis|draft_report|final_report|disseminated|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Type' ;
    rdfs:comment 'Type of evaluation conducted: baseline (pre-intervention), midterm (mid-cycle), endline (post-intervention), impact (long-term outcomes), formative (process improvement), summative (final judgment), or real-time (during crisis). [ENUM-REF-CANDIDATE: baseline|midterm|endline|impact|formative|summative|real-time — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorType rdf:type rdf:Property ;
    rdfs:label 'Evaluator Type' ;
    rdfs:comment 'Type of evaluator conducting the assessment: internal (staff-led), external (independent consultant or firm), joint (internal and external collaboration), or participatory (beneficiary-led).' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'Executive summary of key evaluation findings, including strengths, weaknesses, and evidence against DAC criteria.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadEvaluatorName rdf:type rdf:Property ;
    rdfs:label 'Lead Evaluator Name' ;
    rdfs:comment 'Name of the lead evaluator or evaluation firm responsible for conducting the evaluation.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
    rdfs:comment 'Key lessons learned from the evaluation that can inform future program design, implementation, and organizational learning.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementResponseDate rdf:type rdf:Property ;
    rdfs:label 'Management Response Date' ;
    rdfs:comment 'Date when the management response to evaluation recommendations was formally completed and approved.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementResponseStatus rdf:type rdf:Property ;
    rdfs:label 'Management Response Status' ;
    rdfs:comment 'Status of the management response to evaluation recommendations: pending (not yet started), in_progress (being drafted), completed (response finalized and action plan developed), or not_required.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Primary purpose of the evaluation: accountability (donor reporting), learning (organizational improvement), decision_making (strategic planning), or compliance (regulatory requirement).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceConducted rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Conducted' ;
    rdfs:comment 'Indicates whether independent quality assurance review of the evaluation was conducted (true/false).' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendationsSummary rdf:type rdf:Property ;
    rdfs:label 'Recommendations Summary' ;
    rdfs:comment 'Summary of actionable recommendations arising from the evaluation, including strategic, operational, and programmatic improvements.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relevanceRating rdf:type rdf:Property ;
    rdfs:label 'Relevance Rating' ;
    rdfs:comment 'Rating of the program\'s relevance (alignment with beneficiary needs, country priorities, and organizational strategy) per DAC criteria.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityRating rdf:type rdf:Property ;
    rdfs:label 'Sustainability Rating' ;
    rdfs:comment 'Rating of the program\'s sustainability (likelihood that benefits will continue after program closure) per DAC criteria.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionOwnerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Action Owner Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Management response tracking and corrective action monitoring require linking findings to accountable staff member. Currently text field responsible_person_name; FK enables performance tracking, workl' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:triggeredAgreementAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Triggered Agreement Amendment Id' ;
    rdfs:comment 'Foreign key linking to partnership.agreement_amendment. Business justification: Evaluation findings trigger agreement amendments (scope changes, budget reallocations, no-cost extensions). NGOs formally track which amendment was triggered by which evaluation finding as part of man' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgreementAmendment .

ind:actionPlan rdf:type rdf:Property ;
    rdfs:label 'Action Plan' ;
    rdfs:comment 'Detailed plan outlining the steps, resources, and timeline for implementing the recommendation.' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Final notes or comments documenting the closure or resolution of this finding or recommendation.' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossCuttingTheme rdf:type rdf:Property ;
    rdfs:label 'Cross Cutting Theme' ;
    rdfs:comment 'Cross-cutting themes addressed by this finding (e.g., gender equality, disability inclusion, environmental sustainability, accountability).' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dacCriterion rdf:type rdf:Property ;
    rdfs:label 'Dac Criterion' ;
    rdfs:comment 'The DAC evaluation criterion this finding relates to: relevance, coherence, effectiveness, efficiency, impact, or sustainability.' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorName rdf:type rdf:Property ;
    rdfs:label 'Evaluator Name' ;
    rdfs:comment 'Name of the lead evaluator or evaluation team member who documented this finding.' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceBase rdf:type rdf:Property ;
    rdfs:label 'Evidence Base' ;
    rdfs:comment 'Summary of the data sources and evidence that support this finding (e.g., FGD results, KII transcripts, PDM data, program records).' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDate rdf:type rdf:Property ;
    rdfs:label 'Finding Date' ;
    rdfs:comment 'Date when the finding was formally documented or recorded in the evaluation report.' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Sequential or hierarchical identifier for the finding within the evaluation report (e.g., F1, F2.1, Finding-03).' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatement rdf:type rdf:Property ;
    rdfs:label 'Finding Statement' ;
    rdfs:comment 'The full text of the finding, conclusion, or recommendation as documented in the evaluation report.' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Classification of the evaluation output: finding (observation), conclusion (interpretation), recommendation (action), lesson learned, or good practice.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationProgressPercentage rdf:type rdf:Property ;
    rdfs:label 'Implementation Progress Percentage' ;
    rdfs:comment 'Percentage completion of the recommendation implementation (0.00 to 100.00).' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current status of the recommendation or corrective action: not started, in progress, partially implemented, fully implemented, closed, or rejected.' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskImplication rdf:type rdf:Property ;
    rdfs:label 'Risk Implication' ;
    rdfs:comment 'Description of risks or potential negative consequences if the finding or recommendation is not addressed.' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned or agreed date by which the recommendation should be implemented or the issue addressed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualitativeRecordId rdf:type rdf:Property ;
    rdfs:label 'Qualitative Record Id' ;
    rdfs:comment 'Primary key for qualitative_record' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualitativeRecord .

ind:dataCollectorVolunteerId rdf:type rdf:Property ;
    rdfs:label 'Data Collector Volunteer Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer. Business justification: Volunteers frequently conduct KIIs, FGDs, community consultations as trained data collectors. MEL quality assurance requires tracking collector identity for verification, bias assessment, and data qua' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:primaryQualitativeStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Qualitative Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who facilitated the FGD or conducted the KII.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:tertiaryQualitativeTranslatorStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Qualitative Translator Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member or volunteer who provided translation services during the session.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:collectionEndTime rdf:type rdf:Property ;
    rdfs:label 'Collection End Time' ;
    rdfs:comment 'Timestamp when the qualitative data collection session ended.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:collectionMethodType rdf:type rdf:Property ;
    rdfs:label 'Collection Method Type' ;
    rdfs:comment 'Type of qualitative data collection method used. FGD = Focus Group Discussion, KII = Key Informant Interview, MSC = Most Significant Change.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStartTime rdf:type rdf:Property ;
    rdfs:label 'Collection Start Time' ;
    rdfs:comment 'Timestamp when the qualitative data collection session began.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataQualityRating rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rating' ;
    rdfs:comment 'Assessment of the quality of the qualitative data collected, based on completeness, clarity, and reliability.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informantOrganization rdf:type rdf:Property ;
    rdfs:label 'Informant Organization' ;
    rdfs:comment 'Organization or institution the key informant represents (for KIIs), e.g., Ministry of Health, local CBO, partner NGO.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informantRole rdf:type rdf:Property ;
    rdfs:label 'Informant Role' ;
    rdfs:comment 'Role or position of the key informant (for KIIs), e.g., community leader, health worker, teacher, local government official.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informedConsentObtained rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Obtained' ;
    rdfs:comment 'Indicates whether informed consent was obtained from all participants prior to the qualitative data collection.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyThemesEmerging rdf:type rdf:Property ;
    rdfs:label 'Key Themes Emerging' ;
    rdfs:comment 'Summary of key themes, patterns, or insights that emerged from the qualitative data collection session.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageUsed rdf:type rdf:Property ;
    rdfs:label 'Language Used' ;
    rdfs:comment 'Primary language used during the qualitative data collection session.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantAgeGroupDistribution rdf:type rdf:Property ;
    rdfs:label 'Participant Age Group Distribution' ;
    rdfs:comment 'Distribution of participants by age group (e.g., 0-5: 2, 6-17: 5, 18-59: 8, 60+: 3). Free-text summary of age disaggregation.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantCount rdf:type rdf:Property ;
    rdfs:label 'Participant Count' ;
    rdfs:comment 'Total number of participants in the qualitative data collection event (for FGDs) or 1 for KIIs.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantFemaleCount rdf:type rdf:Property ;
    rdfs:label 'Participant Female Count' ;
    rdfs:comment 'Number of female participants in the qualitative data collection event.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantMaleCount rdf:type rdf:Property ;
    rdfs:label 'Participant Male Count' ;
    rdfs:comment 'Number of male participants in the qualitative data collection event.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantOtherGenderCount rdf:type rdf:Property ;
    rdfs:label 'Participant Other Gender Count' ;
    rdfs:comment 'Number of participants identifying as other gender in the qualitative data collection event.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTheme rdf:type rdf:Property ;
    rdfs:label 'Primary Theme' ;
    rdfs:comment 'Primary theme or topic area explored in the qualitative data collection (e.g., access to services, community perceptions, program satisfaction).' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualitativeRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Qualitative Record Status' ;
    rdfs:comment 'Current lifecycle status of the qualitative data collection record.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingConsentObtained rdf:type rdf:Property ;
    rdfs:label 'Recording Consent Obtained' ;
    rdfs:comment 'Indicates whether explicit consent was obtained from participants to record the session (audio or video).' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordingMethod rdf:type rdf:Property ;
    rdfs:label 'Recording Method' ;
    rdfs:comment 'Method used to record the qualitative data collection session (e.g., audio recording, written notes, digital form).' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topicGuideUsed rdf:type rdf:Property ;
    rdfs:label 'Topic Guide Used' ;
    rdfs:comment 'Name or identifier of the topic guide, interview protocol, or discussion guide used for the qualitative data collection.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationRequired rdf:type rdf:Property ;
    rdfs:label 'Translation Required' ;
    rdfs:comment 'Indicates whether translation or interpretation services were required during the qualitative data collection.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verbatimQuotes rdf:type rdf:Property ;
    rdfs:label 'Verbatim Quotes' ;
    rdfs:comment 'Selected verbatim quotes from participants or key informants that illustrate key findings or themes. Confidential to protect participant identity.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedVolunteerRoleId rdf:type rdf:Property ;
    rdfs:label 'Authorized Volunteer Role Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer_role. Business justification: Data collection tools specify which volunteer roles are authorized to administer them (e.g., community health workers for health surveys, enumerators for household surveys). Required for training plan' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Role .

ind:primaryDataStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Data Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who approved the data collection tool.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:requiredTrainingId rdf:type rdf:Property ;
    rdfs:label 'Required Training Id' ;
    rdfs:comment 'Foreign key linking to volunteer.training. Business justification: NGO data quality protocols require volunteers to complete specific training before using data collection tools (e.g., ODK training before deploying a household survey tool). This link enforces trainin' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Training .

ind:consentMechanism rdf:type rdf:Property ;
    rdfs:label 'Consent Mechanism' ;
    rdfs:comment 'Method by which informed consent is obtained from respondents using this tool.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProtectionCompliance rdf:type rdf:Property ;
    rdfs:label 'Data Protection Compliance' ;
    rdfs:comment 'Data protection and privacy framework to which this tool adheres. GDPR (General Data Protection Regulation), DPA (Data Protection Act), CHS (Core Humanitarian Standard).' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityValidationRules rdf:type rdf:Property ;
    rdfs:label 'Data Quality Validation Rules' ;
    rdfs:comment 'Description or reference to validation rules embedded in the tool to ensure data quality at point of collection.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCompletionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Time Minutes' ;
    rdfs:comment 'Expected time in minutes required to complete the data collection tool.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ethicalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Ethical Review Status' ;
    rdfs:comment 'Status of ethical review or institutional review board (IRB) approval for the data collection tool.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalToolUrl rdf:type rdf:Property ;
    rdfs:label 'External Tool Url' ;
    rdfs:comment 'URL or hyperlink to the external platform where the tool is hosted or accessed.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:questionCount rdf:type rdf:Property ;
    rdfs:label 'Question Count' ;
    rdfs:comment 'Total number of questions or data fields in the collection tool.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:respondentType rdf:type rdf:Property ;
    rdfs:label 'Respondent Type' ;
    rdfs:comment 'Classification of the target respondent or data subject for this collection tool. [ENUM-REF-CANDIDATE: beneficiary|household|community_leader|key_informant|staff|partner|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolCode rdf:type rdf:Property ;
    rdfs:label 'Tool Code' ;
    rdfs:comment 'Unique business identifier code for the data collection tool, used for external reference and integration.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Tool Documentation Url' ;
    rdfs:comment 'URL or reference to documentation, user guides, or training materials for the data collection tool.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolName rdf:type rdf:Property ;
    rdfs:label 'Tool Name' ;
    rdfs:comment 'Human-readable name of the data collection tool or instrument.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolStatus rdf:type rdf:Property ;
    rdfs:label 'Tool Status' ;
    rdfs:comment 'Current lifecycle status of the data collection tool.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolType rdf:type rdf:Property ;
    rdfs:label 'Tool Type' ;
    rdfs:comment 'Classification of the data collection tool by format and platform.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Availability Hours Per Week' ;
    rdfs:comment 'Number of hours per week the volunteer is available to contribute, used for scheduling and capacity planning.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current availability status of the volunteer for new assignments. Available indicates ready for deployment, unavailable indicates temporarily not available, on assignment indicates currently deployed, on leave indicates scheduled absence, and inactive indicates not currently volunteering.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'Date when the most recent background check was completed for the volunteer.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Status of the volunteers background check or vetting process. Not required indicates no check needed for this role, pending indicates check requested, in progress indicates check underway, cleared indicates check passed, flagged indicates issues identified, and expired indicates check needs renewal.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifications rdf:type rdf:Property ;
    rdfs:label 'Certifications' ;
    rdfs:comment 'Comma-separated list of professional certifications, licenses, and credentials held by the volunteer, such as first aid, WASH (Water Sanitation and Hygiene) training, PSS (Psychosocial Support) certification, or medical licenses.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalVolunteerCode rdf:type rdf:Property ;
    rdfs:label 'External Volunteer Code' ;
    rdfs:comment 'Business identifier for the volunteer as known in Microsoft Dynamics 365 for Nonprofits or other external systems. Used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstVolunteerDate rdf:type rdf:Property ;
    rdfs:label 'First Volunteer Date' ;
    rdfs:comment 'Date of the volunteers first volunteer activity or assignment with the organization.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicBase rdf:type rdf:Property ;
    rdfs:label 'Geographic Base' ;
    rdfs:comment 'Primary geographic location or region where the volunteer is based and prefers to serve, used for matching volunteers to local programs and field operations.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVolunteerDate rdf:type rdf:Property ;
    rdfs:label 'Last Volunteer Date' ;
    rdfs:comment 'Date of the volunteers most recent volunteer activity or assignment with the organization.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile phone number for the volunteer, used for SMS notifications and field coordination.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completion Date' ;
    rdfs:comment 'Date when the volunteer completed all onboarding requirements and became eligible for deployment.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Current status of the volunteers onboarding process. Pending indicates application received, in progress indicates onboarding steps underway, completed indicates fully onboarded and ready for deployment, expired indicates onboarding credentials need renewal, and inactive indicates volunteer is not currently active.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionLevel rdf:type rdf:Property ;
    rdfs:label 'Recognition Level' ;
    rdfs:comment 'Recognition tier or award level assigned to the volunteer based on their contribution hours, impact, and tenure. Used for volunteer appreciation programs and engagement tracking.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skills rdf:type rdf:Property ;
    rdfs:label 'Skills' ;
    rdfs:comment 'Comma-separated list of skills, competencies, and professional qualifications the volunteer possesses, used for matching volunteers to program needs and deployment opportunities.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalVolunteerHours rdf:type rdf:Property ;
    rdfs:label 'Total Volunteer Hours' ;
    rdfs:comment 'Cumulative total number of hours the volunteer has contributed across all assignments and programs since registration.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volunteerType rdf:type rdf:Property ;
    rdfs:label 'Volunteer Type' ;
    rdfs:comment 'Classification of the volunteer based on their role and engagement model. Community health workers provide ongoing health services, field volunteers support program delivery, event-based supporters assist with specific events, skilled professionals offer specialized expertise, youth volunteers are under 25, and corporate volunteers come through employer partnerships.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:willingToTravel rdf:type rdf:Property ;
    rdfs:label 'Willing To Travel' ;
    rdfs:comment 'Indicates whether the volunteer is willing to travel outside their geographic base for assignments, deployments, or emergency response.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicationId rdf:type rdf:Property ;
    rdfs:label 'Application Id' ;
    rdfs:comment 'Unique identifier for the volunteer application record. Primary key.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Application .

ind:roleId rdf:type rdf:Property ;
    rdfs:label 'Role Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer_role. Business justification: Volunteer applications are submitted FOR a specific volunteer role. The application has denormalized volunteer_role_type (STRING) which should be normalized to FK to volunteer_role catalog. This allow' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Role .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'The date on which the volunteer application was submitted by the applicant.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Externally visible unique application reference number assigned to this volunteer application for tracking and communication purposes.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the volunteer application in the recruitment and onboarding workflow. [ENUM-REF-CANDIDATE: submitted|under_review|screening|interview_scheduled|accepted|rejected|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Completed Date' ;
    rdfs:comment 'The date on which the background check was completed.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckOutcome rdf:type rdf:Property ;
    rdfs:label 'Background Check Outcome' ;
    rdfs:comment 'The final outcome or result of the background check process.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Background Check Required' ;
    rdfs:comment 'Indicates whether a background check is required for this volunteer application based on role sensitivity and organizational policy.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Commitment Duration Months' ;
    rdfs:comment 'The number of months the applicant is willing to commit to the volunteer role.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'The date on which the final decision on the volunteer application was made.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionMadeBy rdf:type rdf:Property ;
    rdfs:label 'Decision Made By' ;
    rdfs:comment 'Name or identifier of the staff member or committee who made the final decision on the application.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionStatus rdf:type rdf:Property ;
    rdfs:label 'Decision Status' ;
    rdfs:comment 'The final decision status on the volunteer application: whether the applicant has been accepted, rejected, or placed on a waitlist.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactProvided rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Provided' ;
    rdfs:comment 'Indicates whether the volunteer has provided emergency contact information as part of the onboarding process.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Hours Per Week' ;
    rdfs:comment 'The number of hours per week the applicant is available to volunteer.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Interview Completed Date' ;
    rdfs:comment 'The date on which the interview was conducted.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interviewNotes rdf:type rdf:Property ;
    rdfs:label 'Interview Notes' ;
    rdfs:comment 'Internal notes and observations recorded by the interviewer during or after the volunteer interview.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Interview Outcome' ;
    rdfs:comment 'The outcome or recommendation resulting from the volunteer interview.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewRequired rdf:type rdf:Property ;
    rdfs:label 'Interview Required' ;
    rdfs:comment 'Indicates whether an interview is required as part of the volunteer application process for this role.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interviewScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Interview Scheduled Date' ;
    rdfs:comment 'The date and time when the interview with the applicant is scheduled.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:languagesSpoken rdf:type rdf:Property ;
    rdfs:label 'Languages Spoken' ;
    rdfs:comment 'Comma-separated list of languages the applicant speaks, relevant for field operations and beneficiary communication.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:motivationStatement rdf:type rdf:Property ;
    rdfs:label 'Motivation Statement' ;
    rdfs:comment 'Applicant\'s written statement explaining their motivation for volunteering and alignment with the organization\'s mission.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completed Date' ;
    rdfs:comment 'The date on which the volunteer successfully completed all onboarding requirements and is ready for deployment.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingStartDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Start Date' ;
    rdfs:comment 'The date on which the volunteer onboarding process began.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orientationCompleted rdf:type rdf:Property ;
    rdfs:label 'Orientation Completed' ;
    rdfs:comment 'Indicates whether the volunteer has completed the required orientation session introducing them to the organization\'s mission, values, and policies.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredStartDate rdf:type rdf:Property ;
    rdfs:label 'Preferred Start Date' ;
    rdfs:comment 'The date on which the applicant indicates they are available to begin volunteering.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousVolunteerExperience rdf:type rdf:Property ;
    rdfs:label 'Previous Volunteer Experience' ;
    rdfs:comment 'Narrative description of the applicant\'s prior volunteer experience with this organization or other NGOs, CSOs, or INGOs.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruitmentChannel rdf:type rdf:Property ;
    rdfs:label 'Recruitment Channel' ;
    rdfs:comment 'The channel or source through which the applicant learned about the volunteer opportunity and submitted their application.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceCheckCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Reference Check Completed Date' ;
    rdfs:comment 'The date on which reference checks were completed.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referenceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Reference Check Status' ;
    rdfs:comment 'Status of the reference check process, including verification of applicant\'s professional or personal references.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Screening Completed Date' ;
    rdfs:comment 'The date on which the initial screening process was completed.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningStatus rdf:type rdf:Property ;
    rdfs:label 'Screening Status' ;
    rdfs:comment 'Status of the initial screening process to assess applicant suitability and alignment with volunteer role requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillsOffered rdf:type rdf:Property ;
    rdfs:label 'Skills Offered' ;
    rdfs:comment 'Comma-separated list or narrative description of the skills, competencies, and expertise the applicant brings to the volunteer role.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Training Completed' ;
    rdfs:comment 'Indicates whether the volunteer has completed all required role-specific training modules.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deploymentContext rdf:type rdf:Property ;
    rdfs:label 'Deployment Context' ;
    rdfs:comment 'The operational context in which this volunteer role is typically deployed, aligned with program phases and humanitarian response cycles. [ENUM-REF-CANDIDATE: Emergency Response|Development Program|Advocacy Campaign|Community Outreach|Capacity Building|Disaster Relief|Long-Term Recovery — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTimeCommitmentHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Time Commitment Hours' ;
    rdfs:comment 'Expected number of volunteer hours per week or per assignment period for this role, used for scheduling and capacity planning.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'The primary program or operational area where this volunteer role is deployed. WASH (Water Sanitation and Hygiene), GBV (Gender-Based Violence), PSS (Psychosocial Support), MEAL (Monitoring Evaluation Accountability and Learning), ICT4D (Information and Communication Technology for Development). [ENUM-REF-CANDIDATE: WASH|GBV|PSS|Nutrition|Logistics|Health|Education|Protection|Shelter|Livelihoods|MEAL|Communications|Fundraising|Administration|ICT4D — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Required' ;
    rdfs:comment 'Indicates whether the organization must provide or verify insurance coverage (medical, liability, travel) for volunteers in this role.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumConcurrentAssignments rdf:type rdf:Property ;
    rdfs:label 'Maximum Concurrent Assignments' ;
    rdfs:comment 'Maximum number of volunteers that can be simultaneously assigned to this role, used for capacity planning and deployment management.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumAgeRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Requirement' ;
    rdfs:comment 'Minimum age in years that a volunteer must be to be eligible for this role, based on legal, safety, and program requirements.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalDemands rdf:type rdf:Property ;
    rdfs:label 'Physical Demands' ;
    rdfs:comment 'Level of physical exertion and mobility required for this volunteer role, ranging from sedentary office work to strenuous field activities.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSkills rdf:type rdf:Property ;
    rdfs:label 'Preferred Skills' ;
    rdfs:comment 'Comma-separated list of desirable but not mandatory skills that would enhance volunteer effectiveness in this role.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionProgramEligible rdf:type rdf:Property ;
    rdfs:label 'Recognition Program Eligible' ;
    rdfs:comment 'Indicates whether volunteers in this role are eligible for formal recognition programs, awards, or certificates upon completion.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteWorkEligible rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligible' ;
    rdfs:comment 'Indicates whether this volunteer role can be performed remotely or requires physical presence at a specific location.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingRequirements rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirements' ;
    rdfs:comment 'Description of reporting obligations for volunteers in this role, including frequency, format, and content of activity reports or timesheets.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSkills rdf:type rdf:Property ;
    rdfs:label 'Required Skills' ;
    rdfs:comment 'Comma-separated list of essential skills, competencies, and technical abilities required to perform this volunteer role effectively.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleCode rdf:type rdf:Property ;
    rdfs:label 'Role Code' ;
    rdfs:comment 'Unique business identifier code for the volunteer role used across systems and documentation.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleDescription rdf:type rdf:Property ;
    rdfs:label 'Role Description' ;
    rdfs:comment 'Comprehensive description of the volunteer role including responsibilities, typical activities, and expected contributions to program outcomes.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleStatus rdf:type rdf:Property ;
    rdfs:label 'Role Status' ;
    rdfs:comment 'Current lifecycle status of the volunteer role indicating whether it is available for recruitment and assignment.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stipendAmount rdf:type rdf:Property ;
    rdfs:label 'Stipend Amount' ;
    rdfs:comment 'Standard stipend or per diem amount provided to volunteers in this role, if applicable. Null if no stipend is provided.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stipendCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Stipend Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the stipend amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stipendEligible rdf:type rdf:Property ;
    rdfs:label 'Stipend Eligible' ;
    rdfs:comment 'Indicates whether volunteers in this role are eligible to receive a stipend, per diem, or other financial support to cover expenses.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisionLevel rdf:type rdf:Property ;
    rdfs:label 'Supervision Level' ;
    rdfs:comment 'Level of supervision and oversight required for volunteers in this role, ranging from independent work to intensive direct supervision.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeCommitmentUnit rdf:type rdf:Property ;
    rdfs:label 'Time Commitment Unit' ;
    rdfs:comment 'Unit of measure for the estimated time commitment (e.g., hours per week, total hours for event-based roles).' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequired rdf:type rdf:Property ;
    rdfs:label 'Travel Required' ;
    rdfs:comment 'Indicates whether this volunteer role requires travel to field sites, beneficiary locations, or other operational areas.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typicalAssignmentDurationDays rdf:type rdf:Property ;
    rdfs:label 'Typical Assignment Duration Days' ;
    rdfs:comment 'Standard length of a volunteer assignment in this role measured in days, used for planning and volunteer expectation setting.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:servedCommunityId rdf:type rdf:Property ;
    rdfs:label 'Served Community Id' ;
    rdfs:comment 'Foreign key linking to beneficiary.community. Business justification: Deployment community tracking: volunteer deployments target specific communities. This link enables community-level volunteer coverage analysis, gap identification, and program reporting — essential f' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Community .

ind:actualHours rdf:type rdf:Property ;
    rdfs:label 'Actual Hours' ;
    rdfs:comment 'The total number of volunteer hours actually contributed during this deployment, tracked for MEL and donor reporting.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deploymentNumber rdf:type rdf:Property ;
    rdfs:label 'Deployment Number' ;
    rdfs:comment 'Human-readable unique business identifier for the deployment assignment, used for tracking and reporting.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursContributed rdf:type rdf:Property ;
    rdfs:label 'Hours Contributed' ;
    rdfs:comment 'Total number of hours the volunteer has contributed during this specific deployment to this partner organization. Used for tracking volunteer engagement and reporting.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'The name of the specific location, community, or facility where the volunteer is deployed.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orientationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Orientation Completed Date' ;
    rdfs:comment 'The date when the volunteer completed the deployment-specific orientation or onboarding.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orientationCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Orientation Completed Flag' ;
    rdfs:comment 'Indicates whether the volunteer has completed the required orientation or onboarding for this specific deployment.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedHours rdf:type rdf:Property ;
    rdfs:label 'Planned Hours' ;
    rdfs:comment 'The total number of volunteer hours planned or expected for this deployment assignment.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'The priority level of this deployment assignment, indicating urgency and importance for resource allocation and coordination.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionAwardedFlag rdf:type rdf:Property ;
    rdfs:label 'Recognition Awarded Flag' ;
    rdfs:comment 'Indicates whether the volunteer received formal recognition or an award for their contribution during this deployment.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'The administrative region, province, or district within the country where the volunteer is deployed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteDeploymentFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Deployment Flag' ;
    rdfs:comment 'Indicates whether this is a remote or virtual deployment where the volunteer contributes remotely rather than being physically present at the project site.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:role rdf:type rdf:Property ;
    rdfs:label 'Role' ;
    rdfs:comment 'Specific role or function the volunteer performs during this deployment (e.g., Community Health Worker, Field Coordinator, Training Facilitator). The same volunteer may have different roles at different partner organizations.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'The unique identifier of this deployment record in the source system.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volunteerDeploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Volunteer Deployment Status' ;
    rdfs:comment 'Current lifecycle status of the deployment. Active indicates ongoing assignment, Completed indicates successfully finished deployment, Suspended indicates temporarily paused, Cancelled indicates terminated before completion.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hourLogId rdf:type rdf:Property ;
    rdfs:label 'Hour Log Id' ;
    rdfs:comment 'Unique identifier for the volunteer hour log entry. Primary key for the hour log record.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_finding. Business justification: Federal single audits routinely question specific volunteer hour log records as questioned costs or in-kind valuation discrepancies. Linking hour_log to audit_finding enables auditors and compliance s' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking to detailed audit trail records for this hour log entry. Supports institutional donor compliance and audit requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceCode rdf:type rdf:Property ;
    rdfs:label 'Device Code' ;
    rdfs:comment 'Identifier of the device used to submit or verify the volunteer hours. Supports digital check-in and GPS verification methods.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorReportEligible rdf:type rdf:Property ;
    rdfs:label 'Donor Report Eligible' ;
    rdfs:comment 'Flag indicating whether the volunteer hours are eligible for inclusion in donor reports and institutional compliance reporting.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Timestamp when the volunteer activity ended. Used to calculate duration and validate claimed hours.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fairMarketValueRate rdf:type rdf:Property ;
    rdfs:label 'Fair Market Value Rate' ;
    rdfs:comment 'Fair market value rate per hour used to calculate the in-kind contribution value of volunteer hours. Based on IRS guidelines or local equivalents.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursClaimed rdf:type rdf:Property ;
    rdfs:label 'Hours Claimed' ;
    rdfs:comment 'Number of volunteer hours claimed or self-reported by the volunteer for the activity. Initial submission value before verification.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursVerified rdf:type rdf:Property ;
    rdfs:label 'Hours Verified' ;
    rdfs:comment 'Number of volunteer hours verified and approved by a supervisor or through automated validation. Final accepted value for reporting.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inKindValue rdf:type rdf:Property ;
    rdfs:label 'In Kind Value' ;
    rdfs:comment 'Calculated in-kind contribution value of the volunteer hours (hours_verified × fair_market_value_rate). Used for donor reporting and financial statements.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGroupActivity rdf:type rdf:Property ;
    rdfs:label 'Is Group Activity' ;
    rdfs:comment 'Flag indicating whether the volunteer activity was performed as part of a group or team (true) versus individually (false).' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOvertime rdf:type rdf:Property ;
    rdfs:label 'Is Overtime' ;
    rdfs:comment 'Flag indicating whether the volunteer hours exceed the standard expected commitment for the period. Used for volunteer engagement monitoring.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVirtual rdf:type rdf:Property ;
    rdfs:label 'Is Virtual' ;
    rdfs:comment 'Flag indicating whether the volunteer activity was performed virtually or remotely (true) versus on-site (false).' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logDate rdf:type rdf:Property ;
    rdfs:label 'Log Date' ;
    rdfs:comment 'The calendar date on which the volunteer hours were contributed. Primary business event date for timesheet reporting.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionMilestoneTriggered rdf:type rdf:Property ;
    rdfs:label 'Recognition Milestone Triggered' ;
    rdfs:comment 'Flag indicating whether this hour log entry triggered a volunteer recognition milestone (e.g., 100 hours, 500 hours). Used to automate recognition workflows.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Timestamp when the volunteer activity started. Provides precise timing for shift-based or event-based volunteer work.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Date and time when the volunteer hour log entry was initially submitted by the volunteer. Records the moment of timesheet submission.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trainingId rdf:type rdf:Property ;
    rdfs:label 'Training Id' ;
    rdfs:comment 'Unique identifier for the training program. Primary key.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Training .

ind:accreditingBody rdf:type rdf:Property ;
    rdfs:label 'Accrediting Body' ;
    rdfs:comment 'Official organization or institution that accredits or endorses this training program, such as SPHERE Association, CHS Alliance, or national certification bodies.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Method used to assess volunteer competency and completion: written exam, practical demonstration, project submission, peer review, or no formal assessment.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableLanguages rdf:type rdf:Property ;
    rdfs:label 'Available Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639-3 language codes for all languages in which this training is available, supporting multilingual volunteer populations.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationAwarded rdf:type rdf:Property ;
    rdfs:label 'Certification Awarded' ;
    rdfs:comment 'Name of the certificate or credential awarded to volunteers upon successful completion of the training program.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationValidityMonths rdf:type rdf:Property ;
    rdfs:label 'Certification Validity Months' ;
    rdfs:comment 'Number of months the certification remains valid before renewal or recertification is required. Null if certification does not expire.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chsStandardAlignment rdf:type rdf:Property ;
    rdfs:label 'Chs Standard Alignment' ;
    rdfs:comment 'Specific Core Humanitarian Standard (CHS) commitments that this training addresses, ensuring accountability and quality in humanitarian response.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerParticipant rdf:type rdf:Property ;
    rdfs:label 'Cost Per Participant' ;
    rdfs:comment 'Average cost incurred by the organization per volunteer participant for delivering this training, including materials, facilitator fees, and venue costs. Used for budget planning and grant reporting.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryModality rdf:type rdf:Property ;
    rdfs:label 'Delivery Modality' ;
    rdfs:comment 'Method by which the training is delivered to volunteers: in-person classroom, e-learning online, blended (combination), virtual instructor-led, or self-paced.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total duration of the training program measured in hours, including all sessions and modules.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date when this training program is scheduled to be retired or replaced. Null if no end date is planned.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilitatorName rdf:type rdf:Property ;
    rdfs:label 'Facilitator Name' ;
    rdfs:comment 'Name of the primary facilitator or instructor responsible for delivering the training program.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'Primary language in which the training is delivered, using ISO 639-3 three-letter language codes (e.g., ENG for English, FRA for French, ARA for Arabic).' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsUrl rdf:type rdf:Property ;
    rdfs:label 'Materials Url' ;
    rdfs:comment 'Web URL where training materials, resources, and documentation can be accessed by volunteers and facilitators.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxParticipants rdf:type rdf:Property ;
    rdfs:label 'Max Participants' ;
    rdfs:comment 'Maximum number of volunteers that can enroll in a single session or cohort of this training program. Null if no limit.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Passing Score Percentage' ;
    rdfs:comment 'Minimum percentage score required for volunteers to pass the training assessment and receive certification. Null if no assessment.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisites rdf:type rdf:Property ;
    rdfs:label 'Prerequisites' ;
    rdfs:comment 'Required prior training, certifications, or experience that volunteers must have before enrolling in this training program.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sphereStandardAlignment rdf:type rdf:Property ;
    rdfs:label 'Sphere Standard Alignment' ;
    rdfs:comment 'Specific SPHERE Humanitarian Charter and Minimum Standards chapters or technical standards that this training covers (e.g., WASH, Shelter, Health).' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Description of the intended volunteer audience for this training, such as community health workers, field volunteers, event-based supporters, or program-specific volunteers.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCategory rdf:type rdf:Property ;
    rdfs:label 'Training Category' ;
    rdfs:comment 'Classification of the training program. Categories include safety and security, technical skills, Core Humanitarian Standard (CHS) orientation, SPHERE standards, Gender-Based Violence (GBV) awareness, Protection from Sexual Exploitation and Abuse (PSEA), first aid, and other capacity-building areas.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCode rdf:type rdf:Property ;
    rdfs:label 'Training Code' ;
    rdfs:comment 'Externally-known unique code for the training program used in volunteer systems and communications.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDescription rdf:type rdf:Property ;
    rdfs:label 'Training Description' ;
    rdfs:comment 'Detailed description of the training program content, learning objectives, and expected outcomes for volunteers.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingStatus rdf:type rdf:Property ;
    rdfs:label 'Training Status' ;
    rdfs:comment 'Current lifecycle status of the training program: draft (under development), active (available for enrollment), suspended (temporarily unavailable), retired (no longer offered), or under review (being updated).' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Training Enrollment Id' ;
    rdfs:comment 'Unique identifier for the training enrollment record. Primary key.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instructorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Instructor Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Links volunteer training enrollment to staff member who delivered the training. Essential for instructor workload management, training quality assessment, and compliance with training delivery standar' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:assessmentAttempts rdf:type rdf:Property ;
    rdfs:label 'Assessment Attempts' ;
    rdfs:comment 'Number of times the volunteer attempted the training course assessment.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numeric score achieved by the volunteer on the training course assessment or examination, typically expressed as a percentage.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'Date on which the training certificate expires and requires renewal or recertification.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'Date on which the training certificate was issued to the volunteer.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique certificate reference number issued to the volunteer upon successful completion of the training course.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Issued Flag' ;
    rdfs:comment 'Indicates whether a certification was issued to the volunteer upon successful completion of the training course.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceTrainingCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Training Category' ;
    rdfs:comment 'Category of compliance or regulatory training that this enrollment represents, such as Protection from Sexual Exploitation and Abuse (PSEA), Core Humanitarian Standard (CHS), safeguarding, data protection, health and safety, or financial integrity. [ENUM-REF-CANDIDATE: psea|chs|safeguarding|data_protection|health_safety|financial_integrity|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationCredits rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Credits' ;
    rdfs:comment 'Number of continuing education or professional development credits earned by the volunteer upon successful completion of the training course.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentCost rdf:type rdf:Property ;
    rdfs:label 'Enrollment Cost' ;
    rdfs:comment 'Cost incurred by the organization for enrolling the volunteer in the training course, including tuition, materials, and administrative fees.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Enrollment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the enrollment cost.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date on which the volunteer was enrolled in the training course.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Human-readable unique enrollment reference number assigned to this training enrollment for tracking and reporting purposes.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSource rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source' ;
    rdfs:comment 'Source or channel through which the volunteer was enrolled in the training course.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the training enrollment indicating the volunteers progress through the course.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackComments rdf:type rdf:Property ;
    rdfs:label 'Feedback Comments' ;
    rdfs:comment 'Free-text comments provided by the volunteer regarding their experience with the training course, including suggestions for improvement.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackRating rdf:type rdf:Property ;
    rdfs:label 'Feedback Rating' ;
    rdfs:comment 'Numeric rating provided by the volunteer evaluating the quality and effectiveness of the training course, typically on a scale of 1 to 5.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mandatoryTrainingFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Training Flag' ;
    rdfs:comment 'Indicates whether this training course is mandatory for the volunteer based on their role, program assignment, or organizational policy (e.g., PSEA, CHS, safeguarding).' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score required to pass the training course assessment, typically expressed as a percentage.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Recertification Due Date' ;
    rdfs:comment 'Date by which the volunteer must complete recertification or refresher training to maintain their certification status.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recertification Required Flag' ;
    rdfs:comment 'Indicates whether the volunteer is required to undergo recertification or refresher training after the certificate expiry date.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date on which the volunteer successfully completed the training course.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingDeliveryMode rdf:type rdf:Property ;
    rdfs:label 'Training Delivery Mode' ;
    rdfs:comment 'Mode or format in which the training course was delivered to the volunteer.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingHours rdf:type rdf:Property ;
    rdfs:label 'Training Hours' ;
    rdfs:comment 'Total number of hours the volunteer spent in the training course, including instruction, practice, and assessment time.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingLanguage rdf:type rdf:Property ;
    rdfs:label 'Training Language' ;
    rdfs:comment 'Primary language in which the training course content was delivered to the volunteer.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingStartDate rdf:type rdf:Property ;
    rdfs:label 'Training Start Date' ;
    rdfs:comment 'Date on which the volunteer began the training course.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingWithdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Training Withdrawal Date' ;
    rdfs:comment 'Date on which the volunteer withdrew from the training course before completion.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Unique identifier for the certification record. Primary key for the certification entity.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verifiedByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Verified By Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Tracks which staff member verified volunteer certification authenticity. Critical for audit trail, compliance with safeguarding requirements, and accountability in volunteer credentialing process. No ' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'Name of the accreditation or regulatory body that oversees the issuing organization (e.g., national medical board, international humanitarian standards body). Used for credential validation.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentPassingScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Passing Score' ;
    rdfs:comment 'Minimum score required to pass the certification assessment. Used to determine whether the volunteer met competency standards.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Full name of the certification, credential, or training program (e.g., Certified Emergency Medical Technician, SPHERE Practitioner Certificate, PSEA Compliance Training, Community Health Worker Level 2).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Type of certification record: professional license (e.g., nursing, medical), certificate (e.g., first aid, SPHERE practitioner), training completion, self-assessed proficiency, verified competency, or compliance certificate (e.g., Protection from Sexual Exploitation and Abuse (PSEA), safeguarding).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'Regulatory or organizational compliance category this certification satisfies: Protection from Sexual Exploitation and Abuse (PSEA), safeguarding, data protection, security clearance, health and safety, ethics, or none for non-compliance certifications. [ENUM-REF-CANDIDATE: psea|safeguarding|data_protection|security|health_safety|ethics|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationHours rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours' ;
    rdfs:comment 'Number of continuing education or professional development hours required for renewal. Null if not applicable.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the certification cost amount.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfIssue rdf:type rdf:Property ;
    rdfs:label 'Country Of Issue' ;
    rdfs:comment 'Three-letter ISO country code of the country where the certification was issued. Relevant for professional licenses and country-specific credentials.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentEligible rdf:type rdf:Property ;
    rdfs:label 'Deployment Eligible' ;
    rdfs:comment 'Indicates whether this certification qualifies the volunteer for field deployment. True for certifications that meet deployment readiness criteria (verified, current, and role-appropriate).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the supporting documentation (certificate scan, transcript, license copy) stored in the document management system.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'Name of the organization, institution, or authority that issued the certification (e.g., Red Cross, Sphere Association, Ministry of Health, professional licensing board, internal training department).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageOfCertification rdf:type rdf:Property ;
    rdfs:label 'Language Of Certification' ;
    rdfs:comment 'Primary language in which the certification training and assessment were conducted. Important for language-specific skill matching and deployment planning.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when the certification was most recently verified by the organization through documentation review or third-party confirmation.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level' ;
    rdfs:comment 'Level of proficiency or competency in the skill: beginner (basic awareness), intermediate (can perform with supervision), advanced (can perform independently), expert (can train others), master (recognized authority).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedByOrganization rdf:type rdf:Property ;
    rdfs:label 'Recognized By Organization' ;
    rdfs:comment 'Indicates whether this certification is formally recognized and accepted by the organization for volunteer deployment and role assignment. False for certifications that are recorded but not organizationally endorsed.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reimbursedByOrganization rdf:type rdf:Property ;
    rdfs:label 'Reimbursed By Organization' ;
    rdfs:comment 'Indicates whether the organization reimbursed the volunteer for the cost of obtaining this certification. Used for financial tracking and volunteer benefit reporting.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'Number of months between required renewals for time-limited certifications. Null if renewal is not required or frequency is irregular.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Indicates whether this certification requires periodic renewal to remain valid. True for time-limited certifications (e.g., first aid, PSEA training), false for permanent credentials.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skillCategory rdf:type rdf:Property ;
    rdfs:label 'Skill Category' ;
    rdfs:comment 'Primary category of the skill or competency. Aligns with organizational skill taxonomy including medical, logistics, language, psychosocial support (PSS), Water Sanitation and Hygiene (WASH), Information and Communication Technology for Development (ICT4D), community mobilization, protection, nutrition, and education. [ENUM-REF-CANDIDATE: medical|logistics|language|psychosocial|wash|ict4d|community_mobilization|protection|nutrition|education — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillName rdf:type rdf:Property ;
    rdfs:label 'Skill Name' ;
    rdfs:comment 'Specific name of the skill or competency (e.g., First Aid, Community Health Worker Training, SPHERE Standards, Gender-Based Violence (GBV) Response, Mid-Upper Arm Circumference (MUAC) Screening, Psychosocial Support (PSS) Facilitation).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocation rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation' ;
    rdfs:comment 'The financial budget allocated to support this volunteer team\'s operations, including training, supplies, and recognition activities. Stored in the organization\'s base currency.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentMemberCount rdf:type rdf:Property ;
    rdfs:label 'Current Member Count' ;
    rdfs:comment 'The current number of active volunteers who are members of this team.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'The date on which the volunteer team was officially dissolved or deactivated. Null if the team is still active.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentAssigned rdf:type rdf:Property ;
    rdfs:label 'Equipment Assigned' ;
    rdfs:comment 'Description or list of equipment, supplies, or Non-Food Items (NFI) assigned to the team for operational use (e.g., \'Mobile tablets, first aid kits, distribution tents, hygiene kits\').' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'The date on which the volunteer team was officially formed and became operational.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicArea rdf:type rdf:Property ;
    rdfs:label 'Geographic Area' ;
    rdfs:comment 'Textual description of the geographic area, district, camp, or community where the team is deployed (e.g., \'District 5, Northern Province\', \'Refugee Camp B, Sector 3\').' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingFrequency rdf:type rdf:Property ;
    rdfs:label 'Meeting Frequency' ;
    rdfs:comment 'The regular frequency at which the team holds coordination or planning meetings.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionAwardsCount rdf:type rdf:Property ;
    rdfs:label 'Recognition Awards Count' ;
    rdfs:comment 'Total number of recognition awards, certificates, or commendations received by the team for outstanding service.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyIncidentsCount rdf:type rdf:Property ;
    rdfs:label 'Safety Incidents Count' ;
    rdfs:comment 'Total number of safety or security incidents involving team members during operations.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletionRequired rdf:type rdf:Property ;
    rdfs:label 'Training Completion Required' ;
    rdfs:comment 'Indicates whether all team members are required to complete specific training or certification before joining the team.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volunteerTeamStatus rdf:type rdf:Property ;
    rdfs:label 'Volunteer Team Status' ;
    rdfs:comment 'Current operational status of the volunteer team in its lifecycle.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentFundFinanceFundId rdf:type rdf:Property ;
    rdfs:label 'Parent Fund Finance Fund Id' ;
    rdfs:comment 'Reference to a parent fund if this fund is a sub-fund or component of a larger fund structure. Enables hierarchical fund accounting and roll-up reporting.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceFund .

ind:auditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Required Flag' ;
    rdfs:comment 'Indicates whether this fund is subject to external audit requirements under OMB Uniform Guidance Single Audit provisions or donor-specific audit clauses.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccountsSegment rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Segment' ;
    rdfs:comment 'The fund dimension segment code in the organization\'s Chart of Accounts structure. Used for General Ledger posting and financial reporting in SAP S/4HANA.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'The date and time when the fund was officially closed. Marks the completion of the fund lifecycle and triggers closeout procedures per OMB Uniform Guidance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the fund is currently in compliance with all donor conditions, OMB Uniform Guidance requirements, and internal policies. False triggers compliance review workflows.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'The current available balance in the fund after all posted transactions. Updated in real-time by the ERP system for fund availability checking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expendedAmount rdf:type rdf:Property ;
    rdfs:label 'Expended Amount' ;
    rdfs:comment 'Total amount expended from the fund during the current fiscal period. Tracks actual spending against budget for BvA reporting.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'The date of the most recent external audit that included this fund. Used for audit cycle tracking and compliance monitoring.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReportDate rdf:type rdf:Property ;
    rdfs:label 'Last Report Date' ;
    rdfs:comment 'The date when the most recent financial report was submitted to the donor for this fund. Tracks reporting compliance and timeliness.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Name of the staff member or department responsible for managing and overseeing the fund. Accountable for fund stewardship and compliance.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchFulfilledAmount rdf:type rdf:Property ;
    rdfs:label 'Match Fulfilled Amount' ;
    rdfs:comment 'The total amount of matching funds or in-kind contributions fulfilled to date. Tracked for grant reporting and compliance verification.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Match Requirement Percentage' ;
    rdfs:comment 'The percentage of matching funds or cost share required by the donor or grant agreement. Critical for tracking cost share commitments and compliance.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'The scheduled date for the next external audit covering this fund. Supports audit planning and documentation preparation.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Report Due Date' ;
    rdfs:comment 'The due date for the next scheduled financial report to the donor. Critical for compliance and relationship management.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'The fund balance at the beginning of the current fiscal year or at fund inception. Represents the starting financial position for Budget versus Actual (BvA) tracking.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Reference to the parent cost center in the organizational hierarchy. Enables roll-up reporting from field offices to regional hubs to headquarters. Nullable for top-level cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'The total approved budget amount for this cost center for the current fiscal year. Used in Budget versus Actual (BvA) variance analysis and financial stewardship reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'The SAP S/4HANA or Unit4 ERP company code representing the legal entity to which this cost center belongs. Used for multi-entity consolidation and statutory reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'The SAP S/4HANA controlling area (CO module) to which this cost center is assigned. Controlling areas represent organizational units for internal cost accounting and management reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'The methodology used to allocate shared or indirect costs to this cost center. Direct allocation assigns costs explicitly; proportional uses a percentage driver; headcount allocates by staff count; square footage uses physical space; activity-based costing (ABC) uses cost drivers; not allocated for cost centers that do not receive shared cost allocations.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'SAP S/4HANA cost center category classification. Production cost centers deliver direct program services; service cost centers provide internal support; administrative cost centers manage overhead; auxiliary cost centers support shared services; project cost centers are time-bound; temporary cost centers are short-term or pilot initiatives.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Detailed narrative description of the cost center\'s purpose, scope, and responsibilities. Includes information on program activities, geographic coverage, donor restrictions, and organizational context.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The full descriptive name of the cost center as it appears in financial reports and organizational charts.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active cost centers accept expense postings; inactive cost centers are temporarily disabled; suspended cost centers are under review; closed cost centers are permanently retired; pending activation cost centers are awaiting approval.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by functional expense category per GAAP for nonprofits. Program cost centers support direct mission delivery; administrative cost centers support organizational management; fundraising cost centers support donor cultivation and gift processing; general and administrative (G&A) support overall operations; mission support provides enabling services; field operations manage country office and site-level activities.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalExpenseClassification rdf:type rdf:Property ;
    rdfs:label 'Functional Expense Classification' ;
    rdfs:comment 'GAAP functional expense category per FASB ASC 958-720. Program services are mission-delivery activities; management and general (M&G) are administrative overhead; fundraising supports donor cultivation; membership development supports constituent engagement. Required for Form 990 and audited financial statements.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indirectCostEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Eligible Flag' ;
    rdfs:comment 'Indicates whether expenses posted to this cost center are eligible for indirect cost recovery under the organization\'s Negotiated Indirect Cost Rate Agreement (NICRA). True for direct program cost centers; false for administrative or already-indirect cost centers. Used in Facilities and Administration (F&A) cost allocation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nicraBaseCategory rdf:type rdf:Property ;
    rdfs:label 'Nicra Base Category' ;
    rdfs:comment 'The indirect cost base category used for calculating indirect cost recovery for this cost center per the organization\'s NICRA with the federal government. Modified Total Direct Costs (MTDC) is the most common base; direct salaries and wages is used for some research organizations; total direct costs includes all direct expenses. Not applicable for cost centers that do not participate in indirect cost allocation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'The profit center code for organizations using profit center accounting in SAP S/4HANA. Used for segment reporting and internal performance measurement. Nullable for nonprofits not using profit center structures.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearToDateActualAmount rdf:type rdf:Property ;
    rdfs:label 'Year To Date Actual Amount' ;
    rdfs:comment 'The cumulative actual expenses posted to this cost center from the start of the fiscal year to the current reporting period. Used in BvA reporting and burn rate analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountDescription rdf:type rdf:Property ;
    rdfs:label 'Account Description' ;
    rdfs:comment 'Detailed business description of the GL account purpose, usage guidelines, and what types of transactions should be posted to this account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'The account group or category within the Chart of Accounts structure (e.g., \'Current Assets\', \'Fixed Assets\', \'Restricted Contributions\', \'Program Expenses\').' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The human-readable descriptive name of the GL account (e.g., \'Cash - Operating Account\', \'Grant Revenue - USAID\', \'Program Salaries - WASH\').' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The externally-known unique account number within the Chart of Accounts (CoA) structure. This is the business identifier used in SAP S/4HANA and Unit4 ERP for all financial transactions and reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOwner rdf:type rdf:Property ;
    rdfs:label 'Account Owner' ;
    rdfs:comment 'The name or identifier of the business owner or responsible party for this GL account (e.g., Finance Director, Program Manager, Grant Manager).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'The current lifecycle status of the GL account: active (available for posting), inactive (temporarily suspended), blocked (posting prohibited), or closed (permanently retired).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'The fundamental accounting classification of the GL account: asset, liability, net asset (equity for nonprofits per FASB ASC 958), revenue, or expense.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetControlFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Control Flag' ;
    rdfs:comment 'Indicates whether this account is subject to budget control and Budget versus Actual (BvA) monitoring. When true, transactions require budget availability checking before posting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coaStructureCode rdf:type rdf:Property ;
    rdfs:label 'Coa Structure Code' ;
    rdfs:comment 'The Chart of Accounts structure identifier or version code. Nonprofits may maintain multiple CoA structures for different legal entities or reporting requirements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account Number' ;
    rdfs:comment 'The GL account number used for consolidated financial reporting across multiple legal entities or country offices. Used when the nonprofit has a multi-entity structure.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationBaseFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Base Flag' ;
    rdfs:comment 'Indicates whether this account serves as an allocation base for distributing indirect costs across programs and grants (e.g., direct salaries, total direct costs).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReportingCode rdf:type rdf:Property ;
    rdfs:label 'External Reporting Code' ;
    rdfs:comment 'The mapping code used for external regulatory reporting (e.g., IRS Form 990 line item, IATI activity code, donor-specific reporting category).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementClassification rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Classification' ;
    rdfs:comment 'The primary financial statement where this account appears: balance sheet (statement of financial position), statement of activities (income statement equivalent for nonprofits), statement of functional expenses, statement of cash flows, or off-balance-sheet.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalExpenseCategory rdf:type rdf:Property ;
    rdfs:label 'Functional Expense Category' ;
    rdfs:comment 'The functional expense classification required by FASB ASC 958 for expense accounts: program services, management and general (administrative), fundraising, or not applicable (for non-expense accounts). Used for Form 990 reporting and functional expense allocation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundRestrictionClass rdf:type rdf:Property ;
    rdfs:label 'Fund Restriction Class' ;
    rdfs:comment 'The net asset restriction classification per FASB ASC 958: unrestricted (no donor restrictions), temporarily restricted (time or purpose restrictions), or permanently restricted (endowment principal). Critical for nonprofit fund accounting and donor compliance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Grant Eligible Flag' ;
    rdfs:comment 'Indicates whether expenses posted to this account are eligible for reimbursement under federal grants per OMB Uniform Guidance 2 CFR 200. Critical for grant financial management and cost allocation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indirectCostPoolFlag rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Pool Flag' ;
    rdfs:comment 'Indicates whether this account is part of the indirect cost pool for Negotiated Indirect Cost Rate Agreement (NICRA) calculations and Facilities and Administration (F&A) cost allocation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPostingDate rdf:type rdf:Property ;
    rdfs:label 'Last Posting Date' ;
    rdfs:comment 'The date of the most recent transaction posted to this GL account. Used for account activity monitoring and dormant account identification.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:naturalExpenseClassification rdf:type rdf:Property ;
    rdfs:label 'Natural Expense Classification' ;
    rdfs:comment 'The natural classification of expense by type (e.g., salaries, benefits, travel, supplies, professional fees, rent, utilities). Used alongside functional classification for comprehensive expense reporting per FASB ASC 958.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalBalanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Normal Balance Indicator' ;
    rdfs:comment 'Indicates whether this account normally carries a debit or credit balance per double-entry accounting principles.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Eligible Flag' ;
    rdfs:comment 'Indicates whether transactions can be directly posted to this account (true for detail accounts) or if it is a summary/roll-up account that only receives aggregated balances (false).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programServiceCode rdf:type rdf:Property ;
    rdfs:label 'Program Service Code' ;
    rdfs:comment 'The program or service line code that this account supports (e.g., WASH, Health, Education, Emergency Response). Used for program-level financial reporting and Monitoring Evaluation and Learning (MEL).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Flag' ;
    rdfs:comment 'Indicates whether this account requires regular reconciliation (e.g., bank accounts, accounts receivable, accounts payable control accounts). Used for internal control and audit compliance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdgAlignmentCode rdf:type rdf:Property ;
    rdfs:label 'Sdg Alignment Code' ;
    rdfs:comment 'The United Nations Sustainable Development Goal(s) that activities posted to this account contribute toward (e.g., SDG 1 - No Poverty, SDG 6 - Clean Water and Sanitation). Used for impact reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRelevanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Tax Relevance Indicator' ;
    rdfs:comment 'Indicates the tax treatment of transactions posted to this account: taxable income, non-taxable, tax-exempt per IRS 501(c)(3) regulations, or not applicable.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unrelatedBusinessIncomeFlag rdf:type rdf:Property ;
    rdfs:label 'Unrelated Business Income Flag' ;
    rdfs:comment 'Indicates whether revenue posted to this account constitutes Unrelated Business Income (UBI) subject to taxation under IRS regulations for tax-exempt organizations.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date the journal entry document was created or originated, which may differ from the posting date. Used for audit trail and document sequencing.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryDescription rdf:type rdf:Property ;
    rdfs:label 'Entry Description' ;
    rdfs:comment 'Detailed narrative description of the business purpose and nature of this journal entry. Provides context for financial reviewers, auditors, and future reference.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdjustment rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is a manual adjustment or correction entry (as opposed to a system-generated or routine operational entry). True for adjustments; false for standard entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInterCompany rdf:type rdf:Property ;
    rdfs:label 'Is Inter Company' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry represents an inter-company or inter-entity transaction requiring elimination in consolidated financial statements. True for inter-company entries; false otherwise.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'Ledger group or ledger type identifier (e.g., leading ledger, extension ledger, parallel accounting ledger) used in systems supporting multiple parallel accounting views. Supports GAAP and IFRS parallel reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The business date on which this journal entry was posted to the general ledger. This is the effective date for financial reporting and determines which fiscal period the entry impacts.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'System-specific posting key code (from SAP or Unit4) that determines the account type (debit/credit) and controls which fields are required during entry. Technical control field for ERP posting logic.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle status of the journal entry in the approval and posting workflow. Tracks progression from draft creation through approval to final posting in the general ledger.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is a reversal of a previously posted entry. True if this entry reverses another entry; false otherwise.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Free-text explanation of why this journal entry was reversed. Required for audit compliance and internal control documentation when reversal_indicator is true.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the original journal entry that this entry reverses. Populated only when reversal_indicator is true. Maintains bidirectional audit trail for reversals.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for the journal entry line product.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalLineJournalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Original Line Journal Entry Line Id' ;
    rdfs:comment 'Reference to the original journal entry line ID that this line reverses or corrects. Null if this is not a reversal. Supports audit trail and error correction tracking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntryLine .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The credit amount for this journal entry line in the functional currency. Null or zero if this is a debit line. Used for double-entry bookkeeping per GAAP.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'The debit amount for this journal entry line in the functional currency. Null or zero if this is a credit line. Used for double-entry bookkeeping per GAAP.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Donor Restriction Type' ;
    rdfs:comment 'Classification of donor restrictions on the funds used in this line item per FASB ASC 958: unrestricted, temporarily restricted (time or purpose), or permanently restricted (endowment).' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Boolean indicator of whether this line item represents an intercompany or inter-entity transaction between organizational units or affiliated entities.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The vendor invoice number or internal invoice reference associated with this line item. Used for accounts payable reconciliation and audit trails.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naturalAccountClassification rdf:type rdf:Property ;
    rdfs:label 'Natural Account Classification' ;
    rdfs:comment 'The natural classification of the expense by type of expenditure (e.g., salaries, benefits, travel, supplies). Complements functional expense reporting per FASB ASC 958. [ENUM-REF-CANDIDATE: salary|benefits|travel|supplies|equipment|occupancy|professional_services — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'The payment reference or check number associated with this line item for accounts payable or accounts receivable transactions. Supports cash reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'The profit center or revenue-generating unit associated with this line item. Used for revenue attribution and financial performance analysis by business unit.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Boolean indicator of whether this line item is a reversal or correction of a previous journal entry line. Used for audit trails and error correction tracking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'Reference to the source document or transaction that generated this journal entry line (e.g., invoice ID, payroll batch ID, grant disbursement ID). Supports audit trails.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax code or VAT code applicable to this line item. Used for tax compliance, reporting, and recovery in jurisdictions where the nonprofit operates.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedModificationsCount rdf:type rdf:Property ;
    rdfs:label 'Approved Modifications Count' ;
    rdfs:comment 'The number of formal modifications or amendments that have been approved for this budget since initial approval. Tracks budget revision history and compliance with donor prior-approval requirements.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'The name or title of the individual or body that approved this budget (e.g., Chief Financial Officer, Executive Director, Board of Directors, Donor Program Officer).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardCeilingAmount rdf:type rdf:Property ;
    rdfs:label 'Award Ceiling Amount' ;
    rdfs:comment 'The maximum allowable expenditure under the grant award, including all approved modifications. For grant-type budgets, this represents the donor\'s total funding commitment and cannot be exceeded without prior approval.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying this budget in financial systems and donor reports. Used as the business identifier for budget tracking and reference.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Descriptive name of the budget, typically including program or grant reference for easy identification by finance and program staff.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:burnRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Burn Rate Percentage' ;
    rdfs:comment 'The percentage of the total approved budget that has been expended to date. Calculated as (total_actual_expenditure / total_approved_amount) * 100. Used to monitor spending pace and forecast budget depletion.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costShareRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Share Requirement Amount' ;
    rdfs:comment 'The amount of cost-sharing or matching funds required by the donor as a condition of the grant. Represents the organization\'s commitment to contribute resources beyond the donor award.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directCostBudget rdf:type rdf:Property ;
    rdfs:label 'Direct Cost Budget' ;
    rdfs:comment 'The portion of the total budget allocated to direct costs that can be specifically attributed to program activities, such as salaries, supplies, and travel directly supporting the program or grant.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:icrRateApplied rdf:type rdf:Property ;
    rdfs:label 'Icr Rate Applied' ;
    rdfs:comment 'The indirect cost rate percentage applied to calculate the indirect cost budget. Expressed as a percentage (e.g., 15.00 for 15%). May be based on NICRA or donor-imposed rate caps.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indirectCostBudget rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Budget' ;
    rdfs:comment 'The portion of the total budget allocated to indirect costs (overhead, facilities, administration) that support the organization but cannot be directly attributed to a single program or grant. Calculated using the Indirect Cost Rate (ICR).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Modification Date' ;
    rdfs:comment 'The date of the most recent approved modification to this budget. Used to track budget revision history and ensure compliance with donor reporting timelines.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'The name or identifier of the individual responsible for managing and monitoring this budget (e.g., Program Manager, Finance Manager). Accountable for budget performance and variance management.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The date when this budget period ends. For grant budgets, this aligns with the award period end date. Used to calculate burn rate and remaining budget availability.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The date when this budget period begins. For grant budgets, this aligns with the award period start date. Critical for Budget vs. Actual (BvA) tracking and compliance reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorApprovalThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Approval Threshold Amount' ;
    rdfs:comment 'The monetary threshold above which budget modifications or reallocations require prior written approval from the donor. Varies by donor and grant terms (e.g., USAID, DFID, UN agencies).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalActualExpenditure rdf:type rdf:Property ;
    rdfs:label 'Total Actual Expenditure' ;
    rdfs:comment 'The cumulative actual expenditure recorded against this budget to date. Used in Budget vs. Actual (BvA) variance analysis and burn rate calculations.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalApprovedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Approved Amount' ;
    rdfs:comment 'The total approved budget amount for this budget period, including both direct and indirect costs. Represents the authorized spending ceiling.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Total Variance Amount' ;
    rdfs:comment 'The difference between the total approved budget amount and the total actual expenditure. Positive variance indicates under-spending; negative variance indicates over-spending. Key metric for Budget vs. Actual (BvA) reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate shared or indirect costs to this budget line. Ensures transparent and auditable cost allocation per OMB Uniform Guidance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of total cost allocated to this budget line when using proportional allocation methods. Expressed as a decimal (e.g., 0.2500 for 25%).' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetPeriodType rdf:type rdf:Property ;
    rdfs:label 'Budget Period Type' ;
    rdfs:comment 'Granularity of the budget period for this line item. Determines reporting frequency and BvA tracking intervals.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costShareSource rdf:type rdf:Property ;
    rdfs:label 'Cost Share Source' ;
    rdfs:comment 'Source of cost-sharing contribution for this budget line. Distinguishes between organizational funds, third-party contributions, in-kind, or cash match.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costType rdf:type rdf:Property ;
    rdfs:label 'Cost Type' ;
    rdfs:comment 'Classification of cost as direct (attributable to a single program), indirect (Facilities and Administration / F&A), or shared (allocated across multiple programs). Critical for NICRA compliance.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorBudgetCategory rdf:type rdf:Property ;
    rdfs:label 'Donor Budget Category' ;
    rdfs:comment 'Donor-specific budget category or line item code as required by the funding source. Maps internal budget structure to donor reporting templates.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseCategory rdf:type rdf:Property ;
    rdfs:label 'Expense Category' ;
    rdfs:comment 'High-level classification of the budget line expenditure type. Aligns with OMB Uniform Guidance cost categories and donor budget templates. [ENUM-REF-CANDIDATE: personnel|travel|equipment|supplies|contractual|other_direct|indirect — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAllowable rdf:type rdf:Property ;
    rdfs:label 'Is Allowable' ;
    rdfs:comment 'Indicates whether this budget line represents an allowable cost under the grant terms and OMB Uniform Guidance. Used for compliance validation.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCostShare rdf:type rdf:Property ;
    rdfs:label 'Is Cost Share' ;
    rdfs:comment 'Indicates whether this budget line represents a cost-sharing or matching contribution required by the donor. Critical for grant compliance tracking.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalAmount rdf:type rdf:Property ;
    rdfs:label 'Original Amount' ;
    rdfs:comment 'Initial planned expenditure or revenue amount for this budget line as approved in the original budget submission. Baseline for tracking budget changes.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitDescription rdf:type rdf:Property ;
    rdfs:label 'Unit Description' ;
    rdfs:comment 'Description of the unit of measure for this budget line (e.g., staff month, trip, item, training session). Provides context for quantity-based budget calculations.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payableId rdf:type rdf:Property ;
    rdfs:label 'Payable Id' ;
    rdfs:comment 'Primary key for payable' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payable .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Early payment discount or negotiated discount amount applied to the invoice. Reduces the net payable amount. In invoice currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Date the invoice was flagged as disputed. Used for vendor relationship management and dispute resolution tracking. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Payable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Reason code or description if the invoice is disputed (e.g., pricing discrepancy, quantity mismatch, quality issue). Null if not disputed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'Invoice net amount converted to the organization\'s functional currency using the exchange rate. Used for general ledger posting and financial reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Invoice Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the invoice is denominated (e.g., USD, EUR, GBP). Required for multi-currency operations and exchange rate tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date the vendor issued the invoice. Used to calculate payment terms and aging. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description of the goods or services covered by this invoice. Provides business context for the expenditure.' ;
    rdfs:domain ind:Payable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Gross Amount' ;
    rdfs:comment 'Total invoice amount before taxes and adjustments. Base amount for goods or services procured, in invoice currency.' ;
    rdfs:domain ind:Payable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceNetAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Net Amount' ;
    rdfs:comment 'Net payable amount after applying taxes, withholding tax, and discounts. This is the amount to be paid to the vendor. In invoice currency.' ;
    rdfs:domain ind:Payable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Received Date' ;
    rdfs:comment 'Date the invoice was received by the organization. Used for processing time tracking and internal controls. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Payable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isGrantEligible rdf:type rdf:Property ;
    rdfs:label 'Is Grant Eligible' ;
    rdfs:comment 'Flag indicating whether this expenditure is allowable and allocable to the associated grant per OMB Uniform Guidance cost principles. True if eligible, False if not.' ;
    rdfs:domain ind:Payable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'System-generated payment document number or check number. Links the payable to the actual payment transaction for reconciliation and audit.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the payable invoice in the procure-to-pay process. Tracks progression from invoice receipt through payment disbursement. [ENUM-REF-CANDIDATE: open|scheduled|partially_paid|paid|disputed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way match validation comparing purchase order, goods receipt, and invoice. Matched status is required for automated payment approval per internal controls.' ;
    rdfs:domain ind:Payable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Amount of tax withheld at source per local tax regulations. Reduces the net payment to vendor. In invoice currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payablePaymentId rdf:type rdf:Property ;
    rdfs:label 'Payable Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts payable payment transaction. Primary key for the payable payment record.' ;
    rdfs:domain ind:PayablePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which the payment cleared the bank and the funds were successfully transferred to the vendor. Used for cash reconciliation and liquidity management.' ;
    rdfs:domain ind:PayablePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isGrantFunded rdf:type rdf:Property ;
    rdfs:label 'Is Grant Funded' ;
    rdfs:comment 'Boolean flag indicating whether this payment is funded by a specific grant or donor award. Used for grant expenditure tracking and donor reporting.' ;
    rdfs:domain ind:PayablePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIndirectCost rdf:type rdf:Property ;
    rdfs:label 'Is Indirect Cost' ;
    rdfs:comment 'Boolean flag indicating whether this payment represents an indirect cost (Facilities and Administration) subject to the Negotiated Indirect Cost Rate Agreement (NICRA). Used for federal grant compliance.' ;
    rdfs:domain ind:PayablePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'The final net amount disbursed to the vendor after applying discounts, withholding taxes, and other adjustments. This is the actual cash outflow.' ;
    rdfs:domain ind:PayablePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The total gross amount of the payment in the payment currency before any adjustments or deductions. This is the principal monetary value of the disbursement.' ;
    rdfs:domain ind:PayablePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Description' ;
    rdfs:comment 'A detailed description of the purpose or nature of the payment. Provides context for financial reporting, audit, and grant compliance.' ;
    rdfs:domain ind:PayablePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the payment by its business purpose or recipient category. Distinguishes between vendor payments, partner disbursements, grant advances, staff reimbursements, and other payment types. [ENUM-REF-CANDIDATE: vendor_payment|partner_payment|grant_advance|reimbursement|petty_cash|salary|consultant_fee — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PayablePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agingDays rdf:type rdf:Property ;
    rdfs:label 'Aging Days' ;
    rdfs:comment 'Number of days the receivable has been outstanding since the invoice date, used for aging analysis and collection prioritization.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allowanceForDoubtfulAccounts rdf:type rdf:Property ;
    rdfs:label 'Allowance For Doubtful Accounts' ;
    rdfs:comment 'Estimated amount of this receivable that may not be collectible, supporting the contra-asset allowance account per GAAP.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'Email address of the billing contact at the payer organization for invoice delivery and payment coordination.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactName rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Name' ;
    rdfs:comment 'Name of the contact person at the payer organization responsible for processing and approving payment of this invoice.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Phone' ;
    rdfs:comment 'Phone number of the billing contact at the payer organization for follow-up on payment status and dispute resolution.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDescription rdf:type rdf:Property ;
    rdfs:label 'Billing Description' ;
    rdfs:comment 'Narrative description of the goods, services, or grant deliverables for which this invoice was issued to the payer.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current status of the receivable in the collection lifecycle, tracking progress from issuance through final resolution.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Deposit Confirmation Number' ;
    rdfs:comment 'Bank-provided confirmation or transaction number for the deposit, enabling bank reconciliation and audit trail.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicator of whether the payer has disputed this invoice, triggering special handling and resolution processes.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which the invoice dispute was resolved, allowing the receivable to return to normal collection status.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Amount' ;
    rdfs:comment 'Total amount billed on the invoice in the invoice currency, representing the full receivable value at issuance.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'Method by which the invoice was delivered to the payer (e.g., email, postal mail, electronic portal).' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceSentDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Sent Date' ;
    rdfs:comment 'Date on which the invoice was sent or delivered to the payer, establishing the start of the payment terms period.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReminderDate rdf:type rdf:Property ;
    rdfs:label 'Last Reminder Date' ;
    rdfs:comment 'Date on which the most recent payment reminder or collection notice was sent to the payer.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the user who last modified this receivable invoice record, supporting accountability and audit trail.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Current unpaid balance remaining on the invoice after applying all receipts, adjustments, and write-offs.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptMethod rdf:type rdf:Property ;
    rdfs:label 'Receipt Method' ;
    rdfs:comment 'Method or instrument by which payment was received from the payer (e.g., wire transfer, check, ACH, online payment).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue associated with this receivable was recognized in the general ledger per FASB ASC 958 revenue recognition principles.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivableReceiptId rdf:type rdf:Property ;
    rdfs:label 'Receivable Receipt Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable cash receipt transaction. Primary key for the receivable receipt record.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'The check number if the receipt method is check. Used for tracking and reconciliation of paper-based payments.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'Reference to the clearing document in the financial system that links this receipt to the original accounts receivable invoice or pledge. Used for AR reconciliation.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Date' ;
    rdfs:comment 'The date when funds were physically deposited into the bank account. Used for bank reconciliation and cash flow analysis.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorRestrictionPurpose rdf:type rdf:Property ;
    rdfs:label 'Donor Restriction Purpose' ;
    rdfs:comment 'Description of the donor-imposed restriction on the use of funds (e.g., specific program, geographic area, or time period). Critical for restricted fund compliance.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantDrawdownRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Drawdown Request Number' ;
    rdfs:comment 'Reference to the grant drawdown or reimbursement request submitted to the donor or government agency. Links receipt to the originating funding request for compliance tracking.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isInKindConversion rdf:type rdf:Property ;
    rdfs:label 'Is In Kind Conversion' ;
    rdfs:comment 'Indicates whether this cash receipt represents the monetization or conversion of a previously recorded in-kind donation (e.g., sale of donated goods).' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMatchingGift rdf:type rdf:Property ;
    rdfs:label 'Is Matching Gift' ;
    rdfs:comment 'Indicates whether this receipt is a matching gift from a corporate donor or foundation matching an individual donor\'s contribution.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRefund rdf:type rdf:Property ;
    rdfs:label 'Is Refund' ;
    rdfs:comment 'Indicates whether this receipt is a refund or return of funds previously disbursed (e.g., sub-grantee returning unused funds, vendor refund).' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payerReference rdf:type rdf:Property ;
    rdfs:label 'Payer Reference' ;
    rdfs:comment 'External reference or remittance information provided by the payer (donor, government agency, or sub-grantee) to identify the purpose of the payment.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptAmount rdf:type rdf:Property ;
    rdfs:label 'Receipt Amount' ;
    rdfs:comment 'The total amount of cash received in the receipt currency. This is the gross amount before any adjustments or allocations.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptChannel rdf:type rdf:Property ;
    rdfs:label 'Receipt Channel' ;
    rdfs:comment 'The interface or channel through which the payment was received (e.g., bank transfer, mail, online donor portal, mobile app, in-person at field office).' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Receipt Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the payment was received (e.g., USD, EUR, GBP). Critical for multi-currency grant management.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'The date when this receipt was successfully reconciled with the bank statement. Used for cash management and audit compliance.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of bank reconciliation for this receipt. Tracks whether the receipt has been matched to the bank statement and any discrepancies resolved.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireTransferReference rdf:type rdf:Property ;
    rdfs:label 'Wire Transfer Reference' ;
    rdfs:comment 'Bank wire transfer reference number or SWIFT message identifier for electronic fund transfers. Used for high-value grant drawdowns and major gifts.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetManagerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Budget Manager Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:GrantBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:approvedModificationCount rdf:type rdf:Property ;
    rdfs:label 'Approved Modification Count' ;
    rdfs:comment 'Number of approved budget modifications or amendments made since the original budget approval. Tracks budget revision history.' ;
    rdfs:domain ind:GrantBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Budget Approval Date' ;
    rdfs:comment 'Date when the grant budget was officially approved by the donor and became effective for expenditure authorization.' ;
    rdfs:domain ind:GrantBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'Classification of the budget by funding purpose and restriction type. Aligns with FASB ASC 958 net asset classification requirements.' ;
    rdfs:domain ind:GrantBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCloseoutDate rdf:type rdf:Property ;
    rdfs:label 'Budget Closeout Date' ;
    rdfs:comment 'Date when the grant budget was officially closed out after all financial reporting and reconciliation requirements were completed.' ;
    rdfs:domain ind:GrantBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isMultiYear rdf:type rdf:Property ;
    rdfs:label 'Is Multi Year' ;
    rdfs:comment 'Indicates whether this budget spans multiple fiscal years (True) or is contained within a single fiscal year (False).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalAwardAmount rdf:type rdf:Property ;
    rdfs:label 'Total Award Amount' ;
    rdfs:comment 'Total approved funding amount for the grant award. Represents the ceiling for all expenditures under this budget.' ;
    rdfs:domain ind:GrantBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Unique identifier for the cost allocation transaction record. Primary key.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Source Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Cost allocations originate from a source cost center. This FK enables tracking which cost center is the source of allocated costs. Label prefix \'source_\' distinguishes this from target_cost_center_id.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:sourceFinanceFundId rdf:type rdf:Property ;
    rdfs:label 'Source Finance Fund Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_fund. Business justification: Cost allocations originate from a source fund. This FK enables tracking which fund is the source of allocated costs and ensures compliance with donor restrictions. Label prefix \'source_\' distinguishes' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceFund .

ind:targetCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Target Cost Center Id' ;
    rdfs:comment 'FK to finance.cost_center' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:targetFinanceFundId rdf:type rdf:Property ;
    rdfs:label 'Target Finance Fund Id' ;
    rdfs:comment 'FK to finance.finance_fund' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceFund .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The monetary value of the cost being allocated from the source to the target. Represents the actual dollar amount distributed in this allocation transaction.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBasis rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis' ;
    rdfs:comment 'The quantitative basis or driver used to calculate the allocation distribution, such as headcount, square footage, direct costs, full-time equivalents (FTE), revenue, beneficiary count, transaction volume, or time spent. [ENUM-REF-CANDIDATE: headcount|square_footage|direct_costs|fte|revenue|beneficiary_count|transaction_volume|time_spent — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationBasisQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Quantity' ;
    rdfs:comment 'The quantitative measure of the allocation basis used in the calculation (e.g., number of employees, square feet, total direct costs). Used in conjunction with allocation_rate to compute allocated_amount.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBasisUnit rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Unit' ;
    rdfs:comment 'The unit of measure for the allocation basis quantity (e.g., employees, square_feet, USD, FTE, hours).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date on which the cost allocation was executed and recorded in the general ledger.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes or comments providing additional context, justification, or documentation for this cost allocation transaction.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRate rdf:type rdf:Property ;
    rdfs:label 'Allocation Rate' ;
    rdfs:comment 'The rate or percentage applied to the allocation basis to calculate the allocated amount. For NICRA-based allocations, this represents the negotiated indirect cost rate.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle status of the cost allocation transaction: draft (being prepared), pending approval (awaiting review), approved (authorized), posted (recorded in GL), reversed (cancelled), or rejected (not approved).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPool rdf:type rdf:Property ;
    rdfs:label 'Cost Pool' ;
    rdfs:comment 'The name or identifier of the cost pool from which costs are being allocated. Cost pools aggregate similar indirect costs for distribution.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFaCost rdf:type rdf:Property ;
    rdfs:label 'Is Fa Cost' ;
    rdfs:comment 'Boolean flag indicating whether this allocation represents Facilities and Administration (F&A) costs, also known as indirect costs, that are recoverable under federal grants.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which this cost allocation was reversed or cancelled, if applicable. Null if the allocation has not been reversed.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountNumberMasked rdf:type rdf:Property ;
    rdfs:label 'Account Number Masked' ;
    rdfs:comment 'Partially masked version of the bank account number for display in reports and user interfaces (e.g., ****1234). Protects sensitive financial data while allowing account identification.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBalance rdf:type rdf:Property ;
    rdfs:label 'Available Balance' ;
    rdfs:comment 'The available balance in the bank account, accounting for pending transactions, holds, and minimum balance requirements. Represents the actual funds available for disbursement. Denominated in the account currency.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankBranchCode rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Code' ;
    rdfs:comment 'The unique code assigned to the bank branch by the financial institution or national banking authority. Used for domestic payment routing and reconciliation.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchName rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Name' ;
    rdfs:comment 'The name or identifier of the specific bank branch where the account is domiciled. Supports localized banking operations and correspondence.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactEmail rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Email' ;
    rdfs:comment 'The email address of the primary contact person at the financial institution for this bank account. Used for correspondence and issue resolution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactName rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Name' ;
    rdfs:comment 'The name of the primary contact person at the financial institution for this bank account. Supports relationship management and issue resolution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactPhone rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Phone' ;
    rdfs:comment 'The phone number of the primary contact person at the financial institution for this bank account. Used for urgent inquiries and issue resolution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingDate rdf:type rdf:Property ;
    rdfs:label 'Closing Date' ;
    rdfs:comment 'The date when the bank account was officially closed. Null for active or dormant accounts. Marks the end of the account lifecycle.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'The International Bank Account Number, a standardized international numbering system for bank accounts. Used primarily in Europe and other regions for cross-border payments. Format varies by country but always starts with 2-letter country code followed by 2 check digits.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestBearingFlag rdf:type rdf:Property ;
    rdfs:label 'Interest Bearing Flag' ;
    rdfs:comment 'Indicates whether this bank account earns interest on deposited funds. True if interest-bearing; false otherwise. Relevant for savings accounts and certain restricted fund accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'The annual interest rate applied to this bank account, expressed as a decimal (e.g., 0.0250 for 2.5%). Applicable only for interest-bearing accounts. Used for interest income forecasting and financial planning.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'The date when the bank account was last successfully reconciled against the General Ledger (GL). Used to monitor compliance with reconciliation frequency requirements and identify overdue reconciliations.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'The date of the most recent transaction (deposit, withdrawal, or transfer) on this bank account. Used to identify dormant accounts and monitor account activity.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumBalanceRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Requirement' ;
    rdfs:comment 'The minimum balance that must be maintained in this bank account to avoid fees or penalties, as stipulated by the financial institution. Denominated in the account currency.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'The date when the bank account was officially opened with the financial institution. Marks the start of the account lifecycle.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'The maximum overdraft amount permitted on this bank account, if overdraft protection is enabled. Denominated in the account currency. Null if no overdraft protection exists.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdraftProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Overdraft Protection Flag' ;
    rdfs:comment 'Indicates whether this bank account has overdraft protection enabled. True if overdraft protection is active; false otherwise. Overdraft protection allows transactions to proceed even if the account balance is insufficient, subject to bank terms.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationFrequency rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Frequency' ;
    rdfs:comment 'The required frequency for reconciling this bank account against the General Ledger (GL). High-volume or high-risk accounts may require daily reconciliation; lower-activity accounts may be reconciled monthly or quarterly per internal controls policy.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'The 9-digit routing transit number (RTN) used in the United States for domestic wire transfers, ACH transactions, and check processing. Identifies the financial institution in the US banking system.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Signatory Requirement' ;
    rdfs:comment 'The number and level of authorized signatories required to approve transactions on this bank account. Single signatory allows one authorized person; dual signatory requires two; triple requires three; board approval requires formal board resolution. Supports segregation of duties and fraud prevention.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Signatory Threshold Amount' ;
    rdfs:comment 'The monetary threshold above which elevated signatory requirements apply. For example, transactions below this amount may require single signatory, while transactions above require dual or board approval. Denominated in the account currency.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'The Society for Worldwide Interbank Financial Telecommunication (SWIFT) code, also known as Bank Identifier Code (BIC). An 8 or 11-character code used for international wire transfers and cross-border payments. Format: 4-letter bank code, 2-letter country code, 2-character location code, optional 3-character branch code.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalFilingRegulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Original Filing Regulatory Filing Id' ;
    rdfs:comment 'Reference to the original regulatory filing record that this amendment corrects or supersedes. Null if this is an original filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:amendmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Flag' ;
    rdfs:comment 'Indicates whether this filing is an amendment or correction of a previously submitted filing. True if this is an amended return, false if original filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'Full name of the individual authorized to sign and submit the regulatory filing on behalf of the organization. Typically an officer or director with legal authority.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Title' ;
    rdfs:comment 'Official title or position of the authorized signatory. Examples include Executive Director, Board Chair, President, or Chief Executive Officer (CEO).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedDueDate rdf:type rdf:Property ;
    rdfs:label 'Extended Due Date' ;
    rdfs:comment 'New filing deadline after an approved extension. Replaces the original due date for compliance tracking purposes.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Granted Flag' ;
    rdfs:comment 'Indicates whether the requested filing deadline extension was granted by the regulatory authority. True if extension was approved, false if denied or not applicable.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Requested Flag' ;
    rdfs:comment 'Indicates whether an extension of the filing deadline was requested from the regulatory authority. True if extension was requested, false otherwise.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Amount' ;
    rdfs:comment 'Monetary fee charged by the regulatory authority for processing the filing. Amount in the organizations functional currency.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the filing fee amount. Examples include USD, GBP, EUR.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFeePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Payment Date' ;
    rdfs:comment 'Date on which the filing fee was paid to the regulatory authority. Used to confirm payment and avoid processing delays.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingNotes rdf:type rdf:Property ;
    rdfs:label 'Filing Notes' ;
    rdfs:comment 'Free-text field for internal notes, comments, or special circumstances related to the filing. Used to document unusual situations, preparer communications, or follow-up actions required.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Number' ;
    rdfs:comment 'Externally-known unique identifier or confirmation number assigned by the regulatory authority or filing system upon submission. Examples include IRS e-file confirmation number, Charity Commission submission reference, or state registration number.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period End Date' ;
    rdfs:comment 'End date of the fiscal or reporting period covered by this regulatory filing. Defines the conclusion of the time span for which financial and operational data are reported.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period Start Date' ;
    rdfs:comment 'Start date of the fiscal or reporting period covered by this regulatory filing. Defines the beginning of the time span for which financial and operational data are reported.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory filing. Tracks progression from initial draft through submission, acknowledgment, and final acceptance or rejection by the regulatory authority. [ENUM-REF-CANDIDATE: draft|submitted|acknowledged|accepted|rejected|resubmitted|withdrawn|pending_review — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerName rdf:type rdf:Property ;
    rdfs:label 'Preparer Name' ;
    rdfs:comment 'Full name of the individual or firm responsible for preparing the regulatory filing. May be internal staff or external consultant/accountant.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerOrganization rdf:type rdf:Property ;
    rdfs:label 'Preparer Organization' ;
    rdfs:comment 'Name of the organization or firm employing the preparer, if applicable. Identifies external accounting firms, consultancies, or legal advisors engaged to prepare the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerPtin rdf:type rdf:Property ;
    rdfs:label 'Preparer Ptin' ;
    rdfs:comment 'IRS-issued Preparer Tax Identification Number for the individual who prepared the filing. Required for paid tax return preparers in the United States.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Indicates whether this filing is subject to public disclosure requirements. True for filings that must be made available for public inspection (e.g., IRS Form 990), false for confidential regulatory reports.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date on which the regulatory authority rejected the filing due to errors, omissions, or non-compliance. Triggers resubmission workflow.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code assigned by the regulatory authority indicating the specific reason for filing rejection. Used to identify and correct errors for resubmission. [ENUM-REF-CANDIDATE: IRS Reject Code 0001|0002|0003|0004|0005|0006|... — promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of why the filing was rejected by the regulatory authority. Provides context and guidance for corrective action.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionCount rdf:type rdf:Property ;
    rdfs:label 'Resubmission Count' ;
    rdfs:comment 'Number of times this filing has been resubmitted after rejection. Tracks the iteration history for audit and quality improvement purposes.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Full name of the individual responsible for reviewing and approving the regulatory filing before submission. Typically a senior finance officer, legal counsel, or executive director.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerTitle rdf:type rdf:Property ;
    rdfs:label 'Reviewer Title' ;
    rdfs:comment 'Job title or role of the individual who reviewed and approved the filing. Examples include Chief Financial Officer (CFO), Executive Director, or Board Treasurer.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Method or channel through which the filing was submitted to the regulatory authority. Distinguishes between electronic filing systems, paper mail, online portals, and third-party filing services.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chsSelfAssessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Chs Self Assessment Required' ;
    rdfs:comment 'Indicates whether this obligation requires a self-assessment against the Core Humanitarian Standard (CHS) commitments.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationRequired rdf:type rdf:Property ;
    rdfs:label 'Documentation Required' ;
    rdfs:comment 'Description of the documents, reports, or evidence that must be prepared or submitted to fulfill this obligation (e.g., \'Audited financial statements\', \'Program impact report\', \'Beneficiary data summary\', \'Board meeting minutes\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorFunderName rdf:type rdf:Property ;
    rdfs:label 'Donor Funder Name' ;
    rdfs:comment 'The name of the donor, funder, or granting organization that requires this obligation, if applicable (e.g., \'USAID\', \'DFID\', \'Bill & Melinda Gates Foundation\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearApplicable rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Applicable' ;
    rdfs:comment 'The fiscal year or reporting period to which this obligation applies (e.g., \'FY2024\', \'2024\', \'Q1-2024\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'How often the obligation must be fulfilled: annual, quarterly, monthly, semi-annual, biennial, one-time (single occurrence), ad-hoc (irregular), event-driven (triggered by specific events). [ENUM-REF-CANDIDATE: annual|quarterly|monthly|semi-annual|biennial|one-time|ad-hoc|event-driven — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'The regulatory authority, oversight body, or standard-setting organization that mandates or oversees this obligation (e.g., \'Internal Revenue Service\', \'Charity Commission\', \'OCHA\', \'CHS Alliance\', \'USAID\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Grant Agreement Reference' ;
    rdfs:comment 'Reference number or identifier of the grant agreement, contract, or Memorandum of Understanding (MoU) that establishes this obligation, if applicable.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatiPublicationRequired rdf:type rdf:Property ;
    rdfs:label 'Iati Publication Required' ;
    rdfs:comment 'Indicates whether this obligation requires publication of data to the IATI Registry for transparency and accountability.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'The geographic or organizational scope where this obligation applies (e.g., \'United States\', \'United Kingdom\', \'European Union\', \'Global\', \'State of California\', \'Country Office Kenya\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Last Completed Date' ;
    rdfs:comment 'The date when this obligation was most recently fulfilled or submitted successfully.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'The number of days in advance that preparation or submission must begin to meet the obligation deadline.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The specific law, regulation, standard, or contractual clause that establishes this obligation (e.g., \'IRC Section 501(c)(3)\', \'2 CFR 200.501\', \'CHS Commitment 1\', \'Grant Agreement Clause 12.3\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'The next scheduled date by which this obligation must be fulfilled or submitted.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Internal or external reference code for the obligation (e.g., \'IRS-990\', \'CC-AR\', \'IATI-PUB\', \'CHS-SA\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'The official name or title of the compliance obligation (e.g., \'IRS Form 990 Annual Return\', \'Charity Commission Annual Return\', \'IATI Publication\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Status' ;
    rdfs:comment 'Current lifecycle status of the obligation: active (in force and must be fulfilled), pending (upcoming or not yet effective), completed (fulfilled for current period), overdue (past due date and not fulfilled), waived (exempted or not applicable), suspended (temporarily not enforced).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the obligation by its source or nature: regulatory (government-mandated), donor (funder-specific requirement), voluntary (self-imposed accountability framework), contractual (grant or partnership agreement condition), statutory (legal requirement).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Description of the consequences, penalties, or sanctions that may result from non-compliance (e.g., \'Loss of tax-exempt status\', \'Fines up to $50,000\', \'Grant suspension\', \'Reputational damage\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePerson rdf:type rdf:Property ;
    rdfs:label 'Responsible Person' ;
    rdfs:comment 'The name or identifier of the individual accountable for ensuring this obligation is fulfilled (e.g., \'Chief Financial Officer\', \'Compliance Manager\', \'MEL Director\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleUnit rdf:type rdf:Property ;
    rdfs:label 'Responsible Unit' ;
    rdfs:comment 'The department, team, or organizational unit responsible for fulfilling this obligation (e.g., \'Finance Department\', \'Compliance Office\', \'MEL Team\', \'Legal Affairs\', \'Country Office\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:singleAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Single Audit Required' ;
    rdfs:comment 'Indicates whether this obligation requires a Single Audit under 2 CFR 200 Subpart F for US federal awards exceeding the threshold.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionUrl rdf:type rdf:Property ;
    rdfs:label 'Submission Url' ;
    rdfs:comment 'The web address or portal URL where the obligation must be submitted, if applicable.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCostAmount rdf:type rdf:Property ;
    rdfs:label 'Audit Cost Amount' ;
    rdfs:comment 'Total cost paid or payable to the auditor firm for conducting the Single Audit engagement.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditFindingCount rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Count' ;
    rdfs:comment 'Total number of audit findings reported in the Schedule of Findings and Questioned Costs.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit Period End Date' ;
    rdfs:comment 'The ending date of the fiscal year or audit period covered by this Single Audit engagement.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Audit Period Start Date' ;
    rdfs:comment 'The beginning date of the fiscal year or audit period covered by this Single Audit engagement.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditReportDate rdf:type rdf:Property ;
    rdfs:label 'Audit Report Date' ;
    rdfs:comment 'Date when the auditor issued the final Single Audit report package.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the Single Audit engagement: planned, in_progress, fieldwork_complete, report_draft, report_final, submitted_to_fac, or closed. [ENUM-REF-CANDIDATE: planned|in_progress|fieldwork_complete|report_draft|report_final|submitted_to_fac|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditYear rdf:type rdf:Property ;
    rdfs:label 'Audit Year' ;
    rdfs:comment 'The fiscal year for which the Single Audit is being conducted, typically a four-digit year (e.g., 2023).' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Auditor Contact Email' ;
    rdfs:comment 'Email address of the primary auditor contact for this Single Audit engagement.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorContactName rdf:type rdf:Property ;
    rdfs:label 'Auditor Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the auditor firm responsible for this engagement.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Auditor Contact Phone' ;
    rdfs:comment 'Phone number of the primary auditor contact for this Single Audit engagement.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorEin rdf:type rdf:Property ;
    rdfs:label 'Auditor Ein' ;
    rdfs:comment 'Federal Employer Identification Number of the auditor firm conducting the Single Audit.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorFirmName rdf:type rdf:Property ;
    rdfs:label 'Auditor Firm Name' ;
    rdfs:comment 'Name of the independent certified public accounting firm or auditor conducting the Single Audit.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOpinionType rdf:type rdf:Property ;
    rdfs:label 'Compliance Opinion Type' ;
    rdfs:comment 'Type of audit opinion issued on compliance with federal award requirements: unmodified (clean), qualified, adverse, or disclaimer of opinion.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Date' ;
    rdfs:comment 'Date when the organization submitted its corrective action plan to address audit findings.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlanSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Submitted Flag' ;
    rdfs:comment 'Indicates whether the organization submitted a corrective action plan addressing audit findings as required.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engagementLetterDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Letter Date' ;
    rdfs:comment 'Date when the audit engagement letter was signed between the organization and the auditor firm.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:federalExpenditureAmount rdf:type rdf:Property ;
    rdfs:label 'Federal Expenditure Amount' ;
    rdfs:comment 'Total amount of federal awards expended by the organization during the audit period, triggering Single Audit requirement if $750,000 or more.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldworkEndDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork End Date' ;
    rdfs:comment 'Date when the auditor completed fieldwork for the Single Audit.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkStartDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Start Date' ;
    rdfs:comment 'Date when the auditor began on-site or remote fieldwork for the Single Audit.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialStatementOpinionType rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Opinion Type' ;
    rdfs:comment 'Type of audit opinion issued on the organization\'s financial statements: unmodified (clean), qualified, adverse, or disclaimer of opinion.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goingConcernIssueFlag rdf:type rdf:Property ;
    rdfs:label 'Going Concern Issue Flag' ;
    rdfs:comment 'Indicates whether the auditor raised substantial doubt about the organization\'s ability to continue as a going concern.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalControlOpinionType rdf:type rdf:Property ;
    rdfs:label 'Internal Control Opinion Type' ;
    rdfs:comment 'Type of audit opinion issued on internal control over financial reporting and compliance: unmodified, qualified, adverse, or disclaimer.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowRiskAuditeeFlag rdf:type rdf:Property ;
    rdfs:label 'Low Risk Auditee Flag' ;
    rdfs:comment 'Indicates whether the organization qualifies as a low-risk auditee under OMB Uniform Guidance criteria, which may reduce the number of major programs tested.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorProgramCount rdf:type rdf:Property ;
    rdfs:label 'Major Program Count' ;
    rdfs:comment 'Number of federal programs identified as major programs requiring detailed compliance testing under the risk-based approach.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialWeaknessIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Material Weakness Identified Flag' ;
    rdfs:comment 'Indicates whether the auditor identified any material weaknesses in internal control over financial reporting or compliance.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:questionedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Questioned Cost Amount' ;
    rdfs:comment 'Total dollar amount of questioned costs identified by the auditor across all federal programs.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sefaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sefa Reference Number' ;
    rdfs:comment 'Reference number or identifier for the Schedule of Expenditures of Federal Awards (SEFA) prepared as part of the Single Audit package.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significantDeficiencyIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Significant Deficiency Identified Flag' ;
    rdfs:comment 'Indicates whether the auditor identified any significant deficiencies in internal control over financial reporting or compliance.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'The actual date on which the finding was fully resolved and remediated, as verified by management or subsequent audit. Null if the finding is still open or in remediation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Name of the external audit firm or auditor who identified this finding during the audit engagement.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causeDescription rdf:type rdf:Property ;
    rdfs:label 'Cause Description' ;
    rdfs:comment 'Explanation of the underlying reason or root cause that led to the condition. This identifies why the deficiency occurred (e.g., lack of training, inadequate controls, resource constraints).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cfdaNumber rdf:type rdf:Property ;
    rdfs:label 'Cfda Number' ;
    rdfs:comment 'The five-digit CFDA number (now known as Assistance Listings number) identifying the federal program under which the finding was identified. Format is XX.XXX where the first two digits represent the federal agency and the last three represent the specific program.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirementType rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Type' ;
    rdfs:comment 'The specific type of compliance requirement that was violated or not met, as defined in the OMB Compliance Supplement (e.g., Activities Allowed or Unallowed, Allowable Costs/Cost Principles, Cash Management, Eligibility, Equipment and Real Property Management, Matching, Period of Performance, Procurement, Program Income, Reporting, Subrecipient Monitoring, Special Tests and Provisions).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Criteria Description' ;
    rdfs:comment 'Description of the required standard, regulation, policy, or grant provision that was not met. This establishes the benchmark against which the condition is measured.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectDescription rdf:type rdf:Property ;
    rdfs:label 'Effect Description' ;
    rdfs:comment 'Description of the actual or potential impact or consequence of the finding. This explains what harm or risk resulted from the condition (e.g., misstated financial statements, unallowable costs charged to grant, noncompliance with donor restrictions).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Resolution Date' ;
    rdfs:comment 'The target date by which the organization expects to fully resolve and remediate this finding based on the corrective action plan.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Fac Submission Date' ;
    rdfs:comment 'The date on which the audit report containing this finding was submitted to the Federal Audit Clearinghouse. Null if not yet submitted.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:federalAgencyName rdf:type rdf:Property ;
    rdfs:label 'Federal Agency Name' ;
    rdfs:comment 'Name of the federal agency that provided the funding for the program under which this finding was identified (e.g., USAID, BHA, Department of State, HHS).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:federalAwardIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Federal Award Identification Number' ;
    rdfs:comment 'The unique Federal Award Identification Number assigned by the federal agency to the specific award under which this finding was identified.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingIdentifiedDate rdf:type rdf:Property ;
    rdfs:label 'Finding Identified Date' ;
    rdfs:comment 'The date on which the auditor formally identified and documented this finding during the audit fieldwork or reporting process.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Reference Number' ;
    rdfs:comment 'The externally-known unique reference number assigned to this audit finding by the auditor, typically following the format YYYY-NNN or similar audit-specific numbering convention.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the audit finding. Open indicates newly identified and not yet addressed. In remediation indicates corrective action plan is being implemented. Resolved indicates corrective actions completed and pending verification. Closed indicates finding fully remediated and verified. Repeat finding indicates this issue was identified in a prior audit period.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingTitle rdf:type rdf:Property ;
    rdfs:label 'Finding Title' ;
    rdfs:comment 'Brief descriptive title or summary of the audit finding, providing a high-level overview of the issue identified.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFraudIndicator rdf:type rdf:Property ;
    rdfs:label 'Is Fraud Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this finding includes indicators of potential fraud, waste, or abuse. True if fraud indicators are present and require further investigation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMaterialWeakness rdf:type rdf:Property ;
    rdfs:label 'Is Material Weakness' ;
    rdfs:comment 'Boolean flag indicating whether this finding represents a material weakness in internal control over financial reporting or compliance. True if the finding is classified as a material weakness.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeatFinding rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Finding' ;
    rdfs:comment 'Boolean flag indicating whether this finding was previously identified in a prior audit period and has not been fully resolved. True if this is a repeat finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSignificantDeficiency rdf:type rdf:Property ;
    rdfs:label 'Is Significant Deficiency' ;
    rdfs:comment 'Boolean flag indicating whether this finding represents a significant deficiency in internal control. True if the finding is classified as a significant deficiency.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorFindingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Prior Finding Reference Number' ;
    rdfs:comment 'Reference number of the prior audit finding if this is a repeat finding. Links to the original finding from a previous audit period.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:questionedCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Questioned Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the questioned cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationDescription rdf:type rdf:Property ;
    rdfs:label 'Recommendation Description' ;
    rdfs:comment 'Auditor\'s recommendation for corrective action to address the finding. This provides guidance on steps the organization should take to remediate the deficiency.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedToFederalAuditClearinghouse rdf:type rdf:Property ;
    rdfs:label 'Reported To Federal Audit Clearinghouse' ;
    rdfs:comment 'Boolean flag indicating whether this finding has been reported to the Federal Audit Clearinghouse as part of the Single Audit submission. True if reported to FAC.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the individual assigned primary responsibility for implementing the corrective action plan and resolving this finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCorrectiveStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Corrective Staff Member Id' ;
    rdfs:comment 'Identifier of the manager or staff member accountable for implementing the corrective action plan.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:tertiaryCorrectiveResponsibleManagerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Corrective Responsible Manager Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:tertiaryCorrectiveStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Corrective Staff Member Id' ;
    rdfs:comment 'Identifier of the user who created the corrective action plan record.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:auditReportReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Reference' ;
    rdfs:comment 'Reference to the audit report document that contains the original finding, including report number and page reference.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capNumber rdf:type rdf:Property ;
    rdfs:label 'Cap Number' ;
    rdfs:comment 'Business identifier for the corrective action plan, typically formatted as CAP-YYYY-NNN or similar organizational convention.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capStatus rdf:type rdf:Property ;
    rdfs:label 'Cap Status' ;
    rdfs:comment 'Current lifecycle status of the corrective action plan, tracking progress from initiation through closure. [ENUM-REF-CANDIDATE: draft|open|in_progress|pending_verification|closed|overdue|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated financial cost to implement the corrective action plan, including staff time, system changes, training, and other resources.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findingSeverity rdf:type rdf:Property ;
    rdfs:label 'Finding Severity' ;
    rdfs:comment 'Severity level of the finding as assessed by auditors or compliance reviewers, indicating urgency and risk exposure.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveMeasures rdf:type rdf:Property ;
    rdfs:label 'Preventive Measures' ;
    rdfs:comment 'Description of preventive measures implemented to reduce the risk of recurrence, such as policy changes, training programs, or system controls.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceRisk rdf:type rdf:Property ;
    rdfs:label 'Recurrence Risk' ;
    rdfs:comment 'Assessment of the risk that the finding could recur if corrective actions are not sustained or are inadequately implemented.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Date' ;
    rdfs:comment 'Date when the finding and corrective action plan were reported to regulatory authorities. Null if reporting not required or not yet submitted.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether the finding and corrective action plan must be reported to regulatory authorities such as IRS, Charity Commission, or OCHA.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Department or organizational unit responsible for executing the corrective action plan.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Analysis of the underlying root cause(s) that led to the finding, supporting effective remediation and prevention of recurrence.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sphereStandardReference rdf:type rdf:Property ;
    rdfs:label 'Sphere Standard Reference' ;
    rdfs:comment 'Reference to the specific Sphere Humanitarian Charter or Minimum Standard that was not met, if the finding relates to humanitarian quality standards.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationNotes rdf:type rdf:Property ;
    rdfs:label 'Verification Notes' ;
    rdfs:comment 'Detailed notes from the verification process, documenting evidence reviewed and conclusions reached regarding corrective action effectiveness.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByPolicyGovernancePolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Policy Governance Policy Id' ;
    rdfs:comment 'Reference to the governance policy that supersedes this document. Used to track policy version lineage when a new version replaces an older one. Null if this is the current active version.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GovernancePolicy .

ind:annualCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Annual Certification Status' ;
    rdfs:comment 'For conflict-of-interest (COI) disclosures: the status of the annual COI certification requirement for the disclosing party. Indicates whether the annual disclosure has been completed, is pending, is overdue, or is not required for this document type.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'For conflict-of-interest (COI) disclosures: the date on which the disclosing party signed the annual COI certification. Null for non-COI documents or uncertified disclosures.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disclosingParty rdf:type rdf:Property ;
    rdfs:label 'Disclosing Party' ;
    rdfs:comment 'For conflict-of-interest (COI) disclosures: the name of the board member, officer, or key employee making the disclosure. Null for non-COI documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentOwner rdf:type rdf:Property ;
    rdfs:label 'Document Owner' ;
    rdfs:comment 'The department, role, or individual responsible for maintaining, updating, and ensuring compliance with the governance policy.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governancePolicyCategory rdf:type rdf:Property ;
    rdfs:label 'Governance Policy Category' ;
    rdfs:comment 'The functional category or domain of the governance policy. Includes financial management, human resources (HR), safeguarding, anti-fraud, data protection, and conflict-of-interest (COI) policies.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governancePolicyDescription rdf:type rdf:Property ;
    rdfs:label 'Governance Policy Description' ;
    rdfs:comment 'A detailed narrative description of the governance policy\'s purpose, scope, and key provisions.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governancePolicyStatus rdf:type rdf:Property ;
    rdfs:label 'Governance Policy Status' ;
    rdfs:comment 'Current lifecycle status of the governance policy. Indicates whether the document is in draft, active and enforceable, under review for revision, superseded by a newer version, or archived.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irs990DisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Irs 990 Disclosure Required' ;
    rdfs:comment 'Boolean flag indicating whether this governance policy or resolution must be disclosed on the organization\'s IRS Form 990 (Schedule O or Part VI).' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meetingDate rdf:type rdf:Property ;
    rdfs:label 'Meeting Date' ;
    rdfs:comment 'For board resolutions: the date of the board or committee meeting at which the resolution was passed. Null for non-resolution documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingType rdf:type rdf:Property ;
    rdfs:label 'Meeting Type' ;
    rdfs:comment 'For board resolutions: the type of meeting at which the resolution was passed (regular, special, annual, or emergency). Null for non-resolution documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:natureOfConflict rdf:type rdf:Property ;
    rdfs:label 'Nature Of Conflict' ;
    rdfs:comment 'For conflict-of-interest (COI) disclosures: a description of the nature and circumstances of the potential or actual conflict of interest. Null for non-COI documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'The official name or title of the governance policy, resolution, bylaw, or charter document.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'The unique business identifier or reference number assigned to the governance document for tracking and citation purposes.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recusalDecision rdf:type rdf:Property ;
    rdfs:label 'Recusal Decision' ;
    rdfs:comment 'For conflict-of-interest (COI) disclosures: whether the disclosing party recused themselves from decision-making related to the conflict. Null for non-COI documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNumber rdf:type rdf:Property ;
    rdfs:label 'Resolution Number' ;
    rdfs:comment 'For board resolutions: the unique sequential identifier assigned to the resolution for tracking and reference. Null for non-resolution documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionText rdf:type rdf:Property ;
    rdfs:label 'Resolution Text' ;
    rdfs:comment 'For board resolutions: the full text of the resolution as recorded in the meeting minutes. Null for non-resolution documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'The frequency in months at which the governance policy is scheduled for mandatory review and potential revision.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Review Outcome' ;
    rdfs:comment 'For conflict-of-interest (COI) disclosures: the outcome of the board or committee review of the disclosed conflict (approved with safeguards, mitigated through controls, prohibited transaction, or still under review). Null for non-COI documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'The organizational units, geographic regions, or functional areas to which the governance policy applies.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voteOutcome rdf:type rdf:Property ;
    rdfs:label 'Vote Outcome' ;
    rdfs:comment 'For board resolutions: the outcome of the vote on the resolution (passed, failed, tabled for future consideration, or withdrawn). Null for non-resolution documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votesAbstained rdf:type rdf:Property ;
    rdfs:label 'Votes Abstained' ;
    rdfs:comment 'For board resolutions: the number of board members who abstained from voting on the resolution. Null for non-resolution documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:votesAgainst rdf:type rdf:Property ;
    rdfs:label 'Votes Against' ;
    rdfs:comment 'For board resolutions: the number of votes cast against the resolution. Null for non-resolution documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:votesFor rdf:type rdf:Property ;
    rdfs:label 'Votes For' ;
    rdfs:comment 'For board resolutions: the number of votes cast in favor of the resolution. Null for non-resolution documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDonorModifiedByUserStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Donor Modified By User Staff Member Id' ;
    rdfs:comment 'Reference to the user who last modified this compliance requirement record, used for audit trail and accountability.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:actualEffortHours rdf:type rdf:Property ;
    rdfs:label 'Actual Effort Hours' ;
    rdfs:comment 'The actual number of staff hours expended in fulfilling this compliance requirement, used for future planning and cost analysis.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverableFormat rdf:type rdf:Property ;
    rdfs:label 'Deliverable Format' ;
    rdfs:comment 'The required format or medium for the compliance deliverable, such as PDF report, online portal submission, or physical document.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Effort Hours' ;
    rdfs:comment 'The estimated number of staff hours required to complete and submit this compliance requirement.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Internal Policy Reference' ;
    rdfs:comment 'Reference to the organization\'s internal policy or procedure document that governs how this compliance requirement is fulfilled.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceConsequence rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Consequence' ;
    rdfs:comment 'Description of the potential consequences or penalties for failing to meet this compliance requirement, such as grant suspension, fund recovery, or donor relationship damage.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Risk Level' ;
    rdfs:comment 'The assessed risk level to the organization if this compliance requirement is not met, considering financial, reputational, and operational impacts.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementDescription rdf:type rdf:Property ;
    rdfs:label 'Requirement Description' ;
    rdfs:comment 'Detailed narrative description of the compliance requirement, including specific obligations, deliverables, and conditions imposed by the donor.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Requirement Reference Number' ;
    rdfs:comment 'External reference number or code assigned by the donor to this compliance requirement, used for tracking and correspondence.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementTitle rdf:type rdf:Property ;
    rdfs:label 'Requirement Title' ;
    rdfs:comment 'Short descriptive title of the compliance requirement for quick identification and reporting.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Url' ;
    rdfs:comment 'URL or file path to supporting documentation, templates, or guidance materials related to this compliance requirement.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Flag' ;
    rdfs:comment 'Indicates whether the donor has approved a waiver or exemption for this compliance requirement.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Requested Flag' ;
    rdfs:comment 'Indicates whether the organization has formally requested a waiver or exemption from this compliance requirement.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedCountryOfficeId rdf:type rdf:Property ;
    rdfs:label 'Affected Country Office Id' ;
    rdfs:comment 'Identifier of the country office or field location where the incident occurred.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CountryOffice .

ind:reportedConstituentId rdf:type rdf:Property ;
    rdfs:label 'Reported Constituent Id' ;
    rdfs:comment 'Foreign key linking to donor.constituent. Business justification: Compliance incidents can involve a donor/constituent as the subject (fraud, misrepresentation, safeguarding). Linking the incident to the constituent enables donor-risk reporting and relationship mana' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:allegationCategory rdf:type rdf:Property ;
    rdfs:label 'Allegation Category' ;
    rdfs:comment 'Specific category of the allegation within the broader incident type. Supports detailed classification for MEL and donor reporting. [ENUM-REF-CANDIDATE: corruption|theft|misappropriation|conflict_of_interest|harassment|discrimination|safeguarding_violation|data_breach|regulatory_noncompliance — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Summary of corrective actions, disciplinary measures, or process improvements implemented in response to the incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Notification Required Flag' ;
    rdfs:comment 'Indicates whether the incident meets donor notification thresholds per grant agreements. True if notification is required.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedFinancialImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact Usd' ;
    rdfs:comment 'Estimated financial loss or exposure in US Dollars resulting from the incident. Used for materiality assessment and donor reporting thresholds.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Externally-visible unique incident reference number used for tracking and donor reporting. Format: INC-YYYYMMDD.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationAssignedTo rdf:type rdf:Property ;
    rdfs:label 'Investigation Assigned To' ;
    rdfs:comment 'Name or identifier of the investigator or investigation team assigned to the case. Confidential to protect investigation integrity.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completion Date' ;
    rdfs:comment 'Date when the investigation was formally closed and findings documented.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationFinding rdf:type rdf:Property ;
    rdfs:label 'Investigation Finding' ;
    rdfs:comment 'Final determination of the investigation regarding the validity of the allegation. Confidential until disclosure obligations are met.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Internal notes and observations from the investigation process. Confidential working document.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date when formal investigation was initiated following triage and preliminary assessment.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when the incident was reported to the relevant regulatory authority.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Indicates whether the incident must be reported to regulatory authorities (Charity Commission, IRS, OCHA). True if reporting is required.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date when the incident was first reported to the organization through any channel.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reporterAnonymityFlag rdf:type rdf:Property ;
    rdfs:label 'Reporter Anonymity Flag' ;
    rdfs:comment 'Indicates whether the reporter requested anonymity or submitted the report anonymously. True if anonymous.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reporterContactInfo rdf:type rdf:Property ;
    rdfs:label 'Reporter Contact Info' ;
    rdfs:comment 'Contact information for the reporter if they provided it and did not request anonymity. Used for follow-up and feedback.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingChannel rdf:type rdf:Property ;
    rdfs:label 'Reporting Channel' ;
    rdfs:comment 'Channel or mechanism through which the incident was reported to the organization. [ENUM-REF-CANDIDATE: internal_detection|anonymous_hotline|whistleblower_portal|donor_notification|beneficiary_complaint|partner_report|audit_finding — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageOutcome rdf:type rdf:Property ;
    rdfs:label 'Triage Outcome' ;
    rdfs:comment 'Initial triage decision determining the handling pathway for the reported incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibilityCode rdf:type rdf:Property ;
    rdfs:label 'Deductibility Code' ;
    rdfs:comment 'IRS deductibility code indicating the extent to which contributions are tax-deductible (e.g., PC for public charity, PF for private foundation). Applicable primarily to US 501(c)(3) registrations.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinationLetterDate rdf:type rdf:Property ;
    rdfs:label 'Determination Letter Date' ;
    rdfs:comment 'Date of the official determination letter or registration certificate issued by the regulatory authority. Particularly relevant for US 501(c)(3) IRS determination letters.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:doingBusinessAsName rdf:type rdf:Property ;
    rdfs:label 'Doing Business As Name' ;
    rdfs:comment 'Alternative operating name or trade name used by the organization, if different from the registered legal name.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorEligibilityVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Eligibility Verified Flag' ;
    rdfs:comment 'Indicates whether this registration has been verified for donor eligibility purposes (e.g., eligible to receive grants from institutional donors, government agencies, or foundations). True if verified; False if not verified or verification pending.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foreignOperationsPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Foreign Operations Permitted Flag' ;
    rdfs:comment 'Indicates whether this registration permits the organization to conduct operations or provide services outside the jurisdiction of registration. True if foreign operations are permitted; False if restricted to domestic operations only.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foundationStatus rdf:type rdf:Property ;
    rdfs:label 'Foundation Status' ;
    rdfs:comment 'Classification of the organization as a public charity or type of private foundation. Relevant for US 501(c)(3) organizations.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Three-letter ISO country code representing the jurisdiction where the organization is registered (e.g., USA, GBR, KEN).' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFilingDate rdf:type rdf:Property ;
    rdfs:label 'Last Filing Date' ;
    rdfs:comment 'Date of the most recent regulatory filing or report submitted under this registration.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextFilingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Filing Due Date' ;
    rdfs:comment 'Date by which the next regulatory filing or report is due to maintain compliance with this registration.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Date' ;
    rdfs:comment 'Date by which the next renewal application or filing must be submitted to maintain active registration status.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingAuthorityGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Operating Authority Granted Flag' ;
    rdfs:comment 'Indicates whether this registration grants legal authority to operate programs and services in the jurisdiction. True if operating authority is granted; False if registration is for tax or reporting purposes only.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicCharityClassification rdf:type rdf:Property ;
    rdfs:label 'Public Charity Classification' ;
    rdfs:comment 'IRS public charity classification under Section 509(a). 509(a)(1) for publicly supported organizations; 509(a)(2) for organizations receiving substantial support from program service revenue; 509(a)(3) for supporting organizations; Private Foundation if not qualifying as public charity; Not Applicable for non-US registrations.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the official registered address on file with the statutory authority.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Second line of the official registered address (suite, floor, building name, etc.).' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'City or municipality of the official registered address.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registered Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the official registered address.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredLegalName rdf:type rdf:Property ;
    rdfs:label 'Registered Legal Name' ;
    rdfs:comment 'The official legal name of the organization as registered with the statutory authority. This is the name that appears on the determination letter or registration certificate.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'Postal code or ZIP code of the official registered address.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredStateProvince rdf:type rdf:Property ;
    rdfs:label 'Registered State Province' ;
    rdfs:comment 'State, province, or administrative region of the official registered address.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Registration Document Url' ;
    rdfs:comment 'URL or file path to the scanned copy of the official registration certificate, determination letter, or registration document.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Name of the government agency or regulatory body that issued and oversees this registration (e.g., Internal Revenue Service, Charity Commission for England and Wales, Ministry of Social Affairs).' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequency rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency' ;
    rdfs:comment 'Frequency at which the statutory registration must be renewed. Not applicable for registrations that do not require renewal.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether this registration requires periodic renewal. True if renewal is required; False if registration is indefinite or does not require renewal.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Status' ;
    rdfs:comment 'Tax exemption status granted under this registration. Exempt indicates full tax-exempt status; Non-exempt indicates no tax exemption; Conditional indicates exemption with specific conditions; Pending indicates exemption application under review.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Due Date' ;
    rdfs:comment 'Date by which management must submit a corrective action plan addressing the review findings. Nullable if no corrective action is required.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Boolean indicator of whether corrective action is required as a result of the review findings. True if management must implement remediation actions.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical-severity findings identified during the review. Critical findings represent significant control failures or compliance violations requiring immediate action.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalAuditorCoordinationFlag rdf:type rdf:Property ;
    rdfs:label 'External Auditor Coordination Flag' ;
    rdfs:comment 'Boolean indicator of whether this internal review was coordinated with or informed by external auditor activities (e.g., Single Audit). True if coordination occurred.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Review Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a follow-up review is required to verify implementation of corrective actions. True for reviews with significant findings requiring validation.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpReviewScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Review Scheduled Date' ;
    rdfs:comment 'Planned date for the follow-up review to verify corrective action implementation. Nullable if no follow-up is required.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:highFindingsCount rdf:type rdf:Property ;
    rdfs:label 'High Findings Count' ;
    rdfs:comment 'Number of high-severity findings identified during the review. High findings represent material weaknesses requiring prompt remediation.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lowFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Low Findings Count' ;
    rdfs:comment 'Number of low-severity findings identified during the review. Low findings represent minor control gaps or opportunities for improvement.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managementResponseReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Management Response Received Date' ;
    rdfs:comment 'Date when management formally responded to the review findings and submitted their corrective action plan.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mediumFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Medium Findings Count' ;
    rdfs:comment 'Number of medium-severity findings identified during the review. Medium findings represent control weaknesses that should be addressed in a reasonable timeframe.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Overall Compliance Rating' ;
    rdfs:comment 'Summary assessment of the overall compliance posture based on the review findings. Provides an executive-level view of compliance health (satisfactory, needs improvement, unsatisfactory, high risk).' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationSize rdf:type rdf:Property ;
    rdfs:label 'Population Size' ;
    rdfs:comment 'Total number of transactions, cases, or records in the population from which the sample was drawn. Provides context for sample representativeness.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Report Document Url' ;
    rdfs:comment 'File path or URL to the stored compliance review report document. Provides access to the full detailed report.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date when the final compliance review report was formally issued to management and stakeholders.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewEndDate rdf:type rdf:Property ;
    rdfs:label 'Review End Date' ;
    rdfs:comment 'Date when the compliance review fieldwork was completed and findings were finalized. Nullable for reviews still in progress.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewMethodology rdf:type rdf:Property ;
    rdfs:label 'Review Methodology' ;
    rdfs:comment 'Primary audit methodology or approach used to conduct the compliance review (risk-based, transaction testing, control testing, analytical review, walkthrough, observation).' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Free-text field for additional notes, observations, or context about the compliance review that do not fit structured fields. May include reviewer commentary or special circumstances.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Review Scope Description' ;
    rdfs:comment 'Detailed narrative describing the scope, objectives, and boundaries of the compliance review. Explains what was included and excluded from the review.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of findings across all severity levels identified during the compliance review.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rescreeningSanctionsScreeningId rdf:type rdf:Property ;
    rdfs:label 'Rescreening Sanctions Screening Id' ;
    rdfs:comment 'Self-referencing FK on sanctions_screening (rescreening_sanctions_screening_id)' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsScreening .

ind:screenedStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Screened Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: NGOs are required by OFAC, UN, and donor regulations to screen staff against sanctions lists pre-hire and periodically. When subject_type=\'staff\', the screening must reference the specific staff_membe' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:certificationStatement rdf:type rdf:Property ;
    rdfs:label 'Certification Statement' ;
    rdfs:comment 'Text of the anti-terrorism certification or compliance statement that this screening supports.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falsePositiveFlag rdf:type rdf:Property ;
    rdfs:label 'False Positive Flag' ;
    rdfs:comment 'Indicates whether a potential match was determined to be a false positive after investigation.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchDetails rdf:type rdf:Property ;
    rdfs:label 'Match Details' ;
    rdfs:comment 'Detailed information about the match, including list entry details, matching criteria, and any aliases or alternate spellings that triggered the match.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchResult rdf:type rdf:Property ;
    rdfs:label 'Match Result' ;
    rdfs:comment 'Outcome of the sanctions screening check indicating whether the subject was found on any sanctions list.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchScore rdf:type rdf:Property ;
    rdfs:label 'Match Score' ;
    rdfs:comment 'Numerical confidence score (0-100) indicating the likelihood of a true match when potential matches are identified. Higher scores indicate stronger matches.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScreeningDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Screening Due Date' ;
    rdfs:comment 'Date when the next periodic rescreening is due for this subject.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rescreeningFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Rescreening Frequency Days' ;
    rdfs:comment 'Number of days between required rescreening checks for this subject (e.g., 90, 180, 365).' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rescreeningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rescreening Required Flag' ;
    rdfs:comment 'Indicates whether periodic rescreening is required for this subject based on risk profile or donor requirements.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Action taken to resolve a potential or confirmed match (e.g., cleared after review, engagement blocked, escalated to legal, OFAC license requested, alternative vendor sourced).' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerEmail rdf:type rdf:Property ;
    rdfs:label 'Reviewer Email' ;
    rdfs:comment 'Email address of the reviewer who approved the resolution decision.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsListChecked rdf:type rdf:Property ;
    rdfs:label 'Sanctions List Checked' ;
    rdfs:comment 'Name of the sanctions or debarment list(s) checked during this screening. Pipe-separated list for multiple lists (e.g., OFAC SDN|UN Security Council|EU Sanctions|World Bank Debarment).' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenerEmail rdf:type rdf:Property ;
    rdfs:label 'Screener Email' ;
    rdfs:comment 'Email address of the staff member who performed the screening, for audit trail and follow-up purposes.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenerName rdf:type rdf:Property ;
    rdfs:label 'Screener Name' ;
    rdfs:comment 'Name of the staff member or compliance officer who performed or initiated the screening.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningDate rdf:type rdf:Property ;
    rdfs:label 'Screening Date' ;
    rdfs:comment 'Date when the sanctions screening check was performed.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningMethod rdf:type rdf:Property ;
    rdfs:label 'Screening Method' ;
    rdfs:comment 'Method used to perform the sanctions screening check.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Timestamp' ;
    rdfs:comment 'Precise timestamp when the sanctions screening check was initiated, including time zone information.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:screeningTool rdf:type rdf:Property ;
    rdfs:label 'Screening Tool' ;
    rdfs:comment 'Name of the software tool or service used to perform the screening (e.g., Dow Jones Risk & Compliance, LexisNexis Bridger, manual OFAC search).' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectAddress rdf:type rdf:Property ;
    rdfs:label 'Subject Address' ;
    rdfs:comment 'Known address or location of the subject being screened, used for geographic risk assessment.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectDateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Subject Date Of Birth' ;
    rdfs:comment 'Date of birth of the individual being screened, used for identity matching and disambiguation.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectIdentifier rdf:type rdf:Property ;
    rdfs:label 'Subject Identifier' ;
    rdfs:comment 'Unique identifier of the subject in the source system (e.g., vendor ID, staff ID, beneficiary registration number).' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectName rdf:type rdf:Property ;
    rdfs:label 'Subject Name' ;
    rdfs:comment 'Full name of the individual or organization being screened. May include legal name, aliases, or transliterations.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectNationality rdf:type rdf:Property ;
    rdfs:label 'Subject Nationality' ;
    rdfs:comment 'Nationality or country of citizenship of the individual or country of registration for organizations. Pipe-separated list for multiple nationalities.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectType rdf:type rdf:Property ;
    rdfs:label 'Subject Type' ;
    rdfs:comment 'Type of entity being screened against sanctions lists.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentation rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation' ;
    rdfs:comment 'References to supporting documents, evidence, or file paths for screening reports, investigation notes, and approval records.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Data Quality Assessment Id' ;
    rdfs:comment 'Unique identifier for the data quality assessment record. Primary key for the data quality assessment entity.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followupDataQualityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Followup Data Quality Assessment Id' ;
    rdfs:comment 'Self-referencing FK on data_quality_assessment (followup_data_quality_assessment_id)' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataQualityAssessment .

ind:reviewerStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Staff Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who reviewed or approved the data quality assessment findings.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accuracyScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Accuracy Score Percentage' ;
    rdfs:comment 'The percentage score representing the accuracy of the data assessed, calculated as the proportion of verified records that matched source documentation.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'The full name of the staff member or consultant who conducted the data quality assessment.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorOrganization rdf:type rdf:Property ;
    rdfs:label 'Assessor Organization' ;
    rdfs:comment 'The name of the organization or unit to which the assessor belongs (e.g., internal MEL team, external auditor, donor verification team).' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completenessScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Completeness Score Percentage' ;
    rdfs:comment 'The percentage score representing the completeness of the data assessed, calculated as the proportion of required fields that were populated.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consistencyScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Consistency Score Percentage' ;
    rdfs:comment 'The percentage score representing the consistency of the data assessed, calculated as the proportion of records that were internally consistent and aligned across systems.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'The actual date when corrective actions were completed.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSourceType rdf:type rdf:Property ;
    rdfs:label 'Data Source Type' ;
    rdfs:comment 'The type or category of the data source audited (e.g., DHIS2, KoboToolbox, CommCare, field register, paper form, Excel, ERP, CRM). [ENUM-REF-CANDIDATE: dhis2|kobo|commcare|field_register|paper_form|excel|erp|crm|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyCount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Count' ;
    rdfs:comment 'The total number of discrepancies or errors identified during the data quality assessment.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discrepancyFindings rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Findings' ;
    rdfs:comment 'Detailed narrative description of the discrepancies, errors, or data quality issues identified during the assessment.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallDqaScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Overall Dqa Score Percentage' ;
    rdfs:comment 'The overall composite data quality score, typically calculated as a weighted average of accuracy, completeness, timeliness, and consistency scores.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordsVerified rdf:type rdf:Property ;
    rdfs:label 'Records Verified' ;
    rdfs:comment 'The total number of records that were successfully verified during the assessment.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timelinessScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Timeliness Score Percentage' ;
    rdfs:comment 'The percentage score representing the timeliness of the data assessed, calculated as the proportion of records submitted or updated within required timeframes.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liaisonVolunteerId rdf:type rdf:Property ;
    rdfs:label 'Liaison Volunteer Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer. Business justification: Community engagement: NGOs assign a volunteer as the community liaison/focal point per community for mobilization and outreach. This link is essential for community-level volunteer coverage reporting ' ;
    rdfs:domain ind:Community ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:parentCommunityId rdf:type rdf:Property ;
    rdfs:label 'Parent Community Id' ;
    rdfs:comment 'Self-referencing FK on community (parent_community_id)' ;
    rdfs:domain ind:Community ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Community .

ind:accessConstraintLevel rdf:type rdf:Property ;
    rdfs:label 'Access Constraint Level' ;
    rdfs:comment 'Level of operational access constraints affecting the community due to security incidents, administrative restrictions, natural barriers, or conflict dynamics. No constraint: full access. Low: minor delays. Medium: significant restrictions. High: severely constrained. No access: inaccessible. Used for operational planning and risk management.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeProgramCount rdf:type rdf:Property ;
    rdfs:label 'Active Program Count' ;
    rdfs:comment 'Number of active humanitarian or development programs currently operating in the community. Used for coordination, gap analysis, and 3W (Who does What Where) reporting.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:admin1Code rdf:type rdf:Property ;
    rdfs:label 'Admin1 Code' ;
    rdfs:comment 'First-level administrative division code (province, state, governorate) where the community is located. Aligns with OCHA Common Operational Dataset Administrative Boundaries (COD-AB) P-codes for standardized geographic reporting.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admin2Code rdf:type rdf:Property ;
    rdfs:label 'Admin2 Code' ;
    rdfs:comment 'Second-level administrative division code (district, county, department) where the community is located. Aligns with OCHA COD-AB P-codes for standardized geographic reporting.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admin3Code rdf:type rdf:Property ;
    rdfs:label 'Admin3 Code' ;
    rdfs:comment 'Third-level administrative division code (sub-district, municipality) where the community is located. Aligns with OCHA COD-AB P-codes where available.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admin3Name rdf:type rdf:Property ;
    rdfs:label 'Admin3 Name' ;
    rdfs:comment 'Name of the third-level administrative division (sub-district, municipality) where the community is located. Human-readable complement to admin3_code.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admin4Code rdf:type rdf:Property ;
    rdfs:label 'Admin4 Code' ;
    rdfs:comment 'Fourth-level administrative division code (village, neighborhood, locality) where the community is located. Aligns with OCHA COD-AB P-codes where available.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admin4Name rdf:type rdf:Property ;
    rdfs:label 'Admin4 Name' ;
    rdfs:comment 'Name of the fourth-level administrative division (village, neighborhood, locality) where the community is located. Human-readable complement to admin4_code.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communityCode rdf:type rdf:Property ;
    rdfs:label 'Community Code' ;
    rdfs:comment 'Externally-known unique business identifier or code for the community, used in field operations, 3W (Who does What Where) reporting, and inter-agency coordination. May align with OCHA P-codes or agency-specific community identifiers.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communityName rdf:type rdf:Property ;
    rdfs:label 'Community Name' ;
    rdfs:comment 'Official or commonly-used name of the community, settlement, camp, or geographic area. This is the primary human-readable identifier used in field reports, SitReps (Situation Reports), and beneficiary communications.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communityStatus rdf:type rdf:Property ;
    rdfs:label 'Community Status' ;
    rdfs:comment 'Current lifecycle status of the community registration. Active: community is currently served by programs. Inactive: temporarily not served. Closed: community no longer exists or is no longer a target. Planned: community identified for future programming. Suspended: operations temporarily halted due to access constraints or security incidents.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedPopulation rdf:type rdf:Property ;
    rdfs:label 'Estimated Population' ;
    rdfs:comment 'Estimated total number of individuals residing in or associated with the community. This is the principal quantitative measurement for the community resource, used for needs calculations, resource allocation, and coverage reporting.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gbvRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Gbv Risk Level' ;
    rdfs:comment 'Assessment of GBV risk level in the community based on safety audits, incident reports, and vulnerability indicators. Used for GBV prevention programming, safe space establishment, and referral pathway planning.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthFacilityDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Health Facility Distance Km' ;
    rdfs:comment 'Distance in kilometers from the community to the nearest functional health facility. Used for health access analysis, referral planning, and mobile health outreach prioritization.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaderContact rdf:type rdf:Property ;
    rdfs:label 'Leader Contact' ;
    rdfs:comment 'Primary contact information (phone number or other communication channel) for the community leader or representative. Used for coordination, consultation, and feedback mechanisms. Classified as confidential PII.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaderName rdf:type rdf:Property ;
    rdfs:label 'Leader Name' ;
    rdfs:comment 'Name of the primary community leader, elder, or representative. Used for community engagement, consultation, and accountability mechanisms. Classified as confidential to protect community leadership in sensitive contexts.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationSource rdf:type rdf:Property ;
    rdfs:label 'Registration Source' ;
    rdfs:comment 'Source system or tool used to register the community (e.g., KoboToolbox, CommCare, DHIS2, manual field assessment). Used for data lineage tracking and quality assessment.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanitationCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Sanitation Coverage Percent' ;
    rdfs:comment 'Percentage of households in the community with access to adequate sanitation facilities (latrines, toilets) meeting Sphere minimum standards (1 toilet per 20 people). Used for WASH gap analysis and intervention planning.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementType rdf:type rdf:Property ;
    rdfs:label 'Settlement Type' ;
    rdfs:comment 'Classification of the community or settlement type. Formal camp: officially designated refugee or IDP (Internally Displaced Person) camp. Informal settlement: spontaneous or unplanned settlement. Host community: existing community hosting displaced populations. Collective center: shared facility (school, warehouse) used for temporary shelter. Transit site: temporary waypoint for displaced populations. Urban area: city or town neighborhood.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Water Access Flag' ;
    rdfs:comment 'Indicates whether the community has adequate access to safe water sources according to Sphere minimum standards (15 liters per person per day within 500 meters). True if adequate access exists, False otherwise. Used for WASH (Water Sanitation and Hygiene) needs prioritization.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current fulfillment status of this purchase order line (pending, approved, ordered, partially_received, fully_received, cancelled). Tracks line-level receipt progress.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Total amount for this line (quantity_ordered × unit_price). Contributes to purchase_order.subtotal_amount.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOutstanding rdf:type rdf:Property ;
    rdfs:label 'Quantity Outstanding' ;
    rdfs:comment 'Remaining quantity yet to be received (quantity_ordered - quantity_received). Drives open PO reporting and follow-up with vendors.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Agreed price per unit of measure for this commodity on this purchase order. Vendor-specific and time-specific pricing.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryPriorYearPeriodFiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Primary Prior Year Period Fiscal Period Id' ;
    rdfs:comment 'Reference to the corresponding fiscal period in the prior fiscal year. Enables year-over-year comparative analysis.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'The date when the fiscal period was officially closed. Nullable if period is still open or future.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysInPeriod rdf:type rdf:Property ;
    rdfs:label 'Days In Period' ;
    rdfs:comment 'Total number of calendar days in the fiscal period. Used for prorations, accruals, and time-weighted calculations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exchangeRateDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Date' ;
    rdfs:comment 'The date for which exchange rates are locked for multi-currency translation in this fiscal period. Nullable for single-currency organizations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalPeriodDescription rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Description' ;
    rdfs:comment 'Detailed description or notes about the fiscal period, including any special considerations, adjustments, or organizational context.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdjustmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment Period' ;
    rdfs:comment 'Indicates whether this is a special adjustment period (typically Period 13) used for year-end closing entries and corrections.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isYearEndPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Year End Period' ;
    rdfs:comment 'Indicates whether this is the final period of the fiscal year, requiring special year-end closing procedures and financial statement preparation.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockedDate rdf:type rdf:Property ;
    rdfs:label 'Locked Date' ;
    rdfs:comment 'The date when the fiscal period was permanently locked, preventing any further modifications. Nullable if not yet locked.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'The date when the fiscal period was officially opened for transaction posting. May differ from start_date due to administrative processes.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodCode rdf:type rdf:Property ;
    rdfs:label 'Period Code' ;
    rdfs:comment 'Short alphanumeric code representing the fiscal period (e.g., FY24-Q1, P01-2024). Used as a business identifier for reporting and reference.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name of the fiscal period (e.g., \'January 2024\', \'Q1 FY2024\', \'Period 1 - FY2024\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodNumber rdf:type rdf:Property ;
    rdfs:label 'Period Number' ;
    rdfs:comment 'Sequential number of the period within the fiscal year (e.g., 1 for January, 4 for Q1, 12 for December). Used for ordering and reporting.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Current lifecycle status of the fiscal period. Open allows transactions; closed prevents new entries but allows adjustments; locked is final and immutable; future indicates not yet active.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the fiscal period by duration and frequency (monthly, quarterly, semi-annual, annual, or custom).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarterNumber rdf:type rdf:Property ;
    rdfs:label 'Quarter Number' ;
    rdfs:comment 'The fiscal quarter number (1-4) to which this period belongs. Nullable for non-quarterly periods.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for financial reporting in this period (e.g., USD, EUR, GBP). Supports multi-currency nonprofit operations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workingDaysInPeriod rdf:type rdf:Property ;
    rdfs:label 'Working Days In Period' ;
    rdfs:comment 'Number of business working days in the fiscal period, excluding weekends and holidays. Used for operational metrics and staffing calculations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentCountryId rdf:type rdf:Property ;
    rdfs:label 'Parent Country Id' ;
    rdfs:comment 'Self-referencing FK on country (parent_country_id)' ;
    rdfs:domain ind:Country ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:accessConstraints rdf:type rdf:Property ;
    rdfs:label 'Access Constraints' ;
    rdfs:comment 'Primary type of access constraints affecting humanitarian operations in the country. Used for operational planning and risk mitigation.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeClusters rdf:type rdf:Property ;
    rdfs:label 'Active Clusters' ;
    rdfs:comment 'Comma-separated list of active humanitarian clusters in the country (e.g., WASH, Health, Nutrition, Shelter, Protection). Used for coordination and reporting alignment.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalCity rdf:type rdf:Property ;
    rdfs:label 'Capital City' ;
    rdfs:comment 'Name of the capital city of the country. Often the location of the country office headquarters.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterCoordinationActive rdf:type rdf:Property ;
    rdfs:label 'Cluster Coordination Active' ;
    rdfs:comment 'Indicates whether the OCHA cluster coordination system is active in this country. Affects reporting obligations and inter-agency coordination requirements.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codeAlpha2 rdf:type rdf:Property ;
    rdfs:label 'Code Alpha2' ;
    rdfs:comment 'Two-letter country code as defined by ISO 3166-1 alpha-2 standard. Used for international identification and data exchange.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeAlpha3 rdf:type rdf:Property ;
    rdfs:label 'Code Alpha3' ;
    rdfs:comment 'Three-letter country code as defined by ISO 3166-1 alpha-3 standard. Commonly used in humanitarian reporting and OCHA coordination.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeNumeric rdf:type rdf:Property ;
    rdfs:label 'Code Numeric' ;
    rdfs:comment 'Three-digit numeric country code as defined by ISO 3166-1 numeric standard.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryName rdf:type rdf:Property ;
    rdfs:label 'Country Name' ;
    rdfs:comment 'Official full name of the country as recognized by the United Nations.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsProcedures rdf:type rdf:Property ;
    rdfs:label 'Customs Procedures' ;
    rdfs:comment 'Summary of customs clearance procedures and requirements for importing humanitarian supplies. Critical for supply chain and logistics planning.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fragilityStatus rdf:type rdf:Property ;
    rdfs:label 'Fragility Status' ;
    rdfs:comment 'Classification of the countrys fragility and conflict status. Critical for risk assessment, security planning, and humanitarian response prioritization.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisDataAvailable rdf:type rdf:Property ;
    rdfs:label 'Gis Data Available' ;
    rdfs:comment 'Indicates whether comprehensive GIS data layers (administrative boundaries, roads, facilities) are available for this country to support location-based analysis.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governmentPartnershipStatus rdf:type rdf:Property ;
    rdfs:label 'Government Partnership Status' ;
    rdfs:comment 'Level of partnership and collaboration with the national government. Affects program implementation modalities and coordination mechanisms.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humanitarianResponsePlanActive rdf:type rdf:Property ;
    rdfs:label 'Humanitarian Response Plan Active' ;
    rdfs:comment 'Indicates whether an active Humanitarian Response Plan coordinated by OCHA exists for this country. Used to determine cluster coordination requirements and reporting obligations.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incomeClassification rdf:type rdf:Property ;
    rdfs:label 'Income Classification' ;
    rdfs:comment 'World Bank income classification category for the country. Used for program eligibility, funding allocation, and needs assessment.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:koboDeploymentActive rdf:type rdf:Property ;
    rdfs:label 'Kobo Deployment Active' ;
    rdfs:comment 'Indicates whether KoboToolbox mobile data collection is actively deployed for field assessments and monitoring in this country.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landAreaSqKm rdf:type rdf:Property ;
    rdfs:label 'Land Area Sq Km' ;
    rdfs:comment 'Total land area of the country in square kilometers. Used for logistics planning, geographic information system (GIS) analysis, and distribution coverage calculations.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landlocked rdf:type rdf:Property ;
    rdfs:label 'Landlocked' ;
    rdfs:comment 'Indicates whether the country is landlocked with no direct access to the sea. Critical for supply chain and logistics planning.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leastDevelopedCountry rdf:type rdf:Property ;
    rdfs:label 'Least Developed Country' ;
    rdfs:comment 'Indicates whether the country is classified as a Least Developed Country by the United Nations. Affects funding eligibility and program prioritization.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memorandumOfUnderstandingSigned rdf:type rdf:Property ;
    rdfs:label 'Memorandum Of Understanding Signed' ;
    rdfs:comment 'Indicates whether a formal Memorandum of Understanding has been signed with the national government for humanitarian operations.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ochaPresence rdf:type rdf:Property ;
    rdfs:label 'Ocha Presence' ;
    rdfs:comment 'Indicates whether OCHA has an active presence in the country. Determines cluster coordination mechanisms and humanitarian reporting requirements.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:officeEstablished rdf:type rdf:Property ;
    rdfs:label 'Office Established' ;
    rdfs:comment 'Indicates whether the organization has an established country office with permanent presence in this country.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:officeEstablishmentDate rdf:type rdf:Property ;
    rdfs:label 'Office Establishment Date' ;
    rdfs:comment 'Date when the country office was officially established. Null if no country office exists.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:officialLanguages rdf:type rdf:Property ;
    rdfs:label 'Official Languages' ;
    rdfs:comment 'Comma-separated list of official languages spoken in the country. Used for translation requirements, field staff recruitment, and beneficiary communication planning.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:population rdf:type rdf:Property ;
    rdfs:label 'Population' ;
    rdfs:comment 'Total population of the country based on the most recent census or UN estimate. Used for needs assessment and program scale planning.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:populationYear rdf:type rdf:Property ;
    rdfs:label 'Population Year' ;
    rdfs:comment 'Year of the population estimate or census data. Indicates the currency of population data.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDonorCountries rdf:type rdf:Property ;
    rdfs:label 'Primary Donor Countries' ;
    rdfs:comment 'Comma-separated list of primary donor countries or institutions funding operations in this country. Used for donor reporting and relationship management.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Security Risk Level' ;
    rdfs:comment 'Current security risk assessment level for the country. Determines staff travel restrictions, security protocols, and operational modalities.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smallIslandDevelopingState rdf:type rdf:Property ;
    rdfs:label 'Small Island Developing State' ;
    rdfs:comment 'Indicates whether the country is classified as a Small Island Developing State. Relevant for climate adaptation and disaster risk reduction programs.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subRegion rdf:type rdf:Property ;
    rdfs:label 'Sub Region' ;
    rdfs:comment 'Geographic sub-region classification providing more granular regional grouping for operational planning and analysis.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Status' ;
    rdfs:comment 'Tax exemption status granted to the organization by the national government. Affects financial planning and procurement.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visaRequirements rdf:type rdf:Property ;
    rdfs:label 'Visa Requirements' ;
    rdfs:comment 'Description of visa requirements and procedures for international staff deployment to this country. Used for staff travel planning and compliance.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinatorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Coordinator Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Every NGO emergency response has a designated emergency coordinator or incident commander. Donor reports, flash appeals, and emergency response plans all identify this responsible staff member. No sta' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:escalatedFromEmergencyId rdf:type rdf:Property ;
    rdfs:label 'Escalated From Emergency Id' ;
    rdfs:comment 'Self-referencing FK on emergency (escalated_from_emergency_id)' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Emergency .

ind:affectedPopulationCount rdf:type rdf:Property ;
    rdfs:label 'Affected Population Count' ;
    rdfs:comment 'Estimated total number of individuals directly affected by the emergency event.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedRegions rdf:type rdf:Property ;
    rdfs:label 'Affected Regions' ;
    rdfs:comment 'Comma-separated list of administrative regions, provinces, or districts affected by the emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cerfAllocationReceived rdf:type rdf:Property ;
    rdfs:label 'Cerf Allocation Received' ;
    rdfs:comment 'Indicates whether the organization received funding from the UN Central Emergency Response Fund for this emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clusterCoordinationMechanism rdf:type rdf:Property ;
    rdfs:label 'Cluster Coordination Mechanism' ;
    rdfs:comment 'Description of the OCHA cluster coordination structure activated for this emergency (e.g., \'Full cluster activation with 11 sectors\').' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationDate rdf:type rdf:Property ;
    rdfs:label 'Declaration Date' ;
    rdfs:comment 'Date when the emergency was officially declared by the organization or governing authority.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disasterCategory rdf:type rdf:Property ;
    rdfs:label 'Disaster Category' ;
    rdfs:comment 'Specific disaster category providing granular classification of the emergency event type.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displacedPopulationCount rdf:type rdf:Property ;
    rdfs:label 'Displaced Population Count' ;
    rdfs:comment 'Estimated number of individuals displaced or forced to leave their homes due to the emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emergencyCode rdf:type rdf:Property ;
    rdfs:label 'Emergency Code' ;
    rdfs:comment 'Externally-known unique business identifier for the emergency, following organizational coding standards (e.g., SYR-2023-EQKE01).' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyDescription rdf:type rdf:Property ;
    rdfs:label 'Emergency Description' ;
    rdfs:comment 'Detailed narrative description of the emergency context, impact, and response strategy.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyName rdf:type rdf:Property ;
    rdfs:label 'Emergency Name' ;
    rdfs:comment 'Human-readable name or title of the emergency event (e.g., \'Syria Earthquake Response 2023\', \'Bangladesh Flood Relief\').' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyStatus rdf:type rdf:Property ;
    rdfs:label 'Emergency Status' ;
    rdfs:comment 'Current lifecycle status of the emergency response operation.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyType rdf:type rdf:Property ;
    rdfs:label 'Emergency Type' ;
    rdfs:comment 'Classification of the emergency by its primary cause or nature.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fgdConductedCount rdf:type rdf:Property ;
    rdfs:label 'Fgd Conducted Count' ;
    rdfs:comment 'Number of Focus Group Discussions conducted as part of field assessments for this emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flashAppealIssued rdf:type rdf:Property ;
    rdfs:label 'Flash Appeal Issued' ;
    rdfs:comment 'Indicates whether an OCHA Flash Appeal was issued for this emergency to mobilize rapid funding.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundingReceivedUsd rdf:type rdf:Property ;
    rdfs:label 'Funding Received Usd' ;
    rdfs:comment 'Total funding received in US Dollars for the emergency response as of the last update.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingRequirementUsd rdf:type rdf:Property ;
    rdfs:label 'Funding Requirement Usd' ;
    rdfs:comment 'Total funding requirement in US Dollars for the organizations emergency response operations.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gisMappingCompleted rdf:type rdf:Property ;
    rdfs:label 'Gis Mapping Completed' ;
    rdfs:comment 'Indicates whether GIS-based location mapping and spatial analysis were completed for affected areas.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hrpIssued rdf:type rdf:Property ;
    rdfs:label 'Hrp Issued' ;
    rdfs:comment 'Indicates whether a formal Humanitarian Response Plan was developed and issued for this emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementingPartnersCount rdf:type rdf:Property ;
    rdfs:label 'Implementing Partners Count' ;
    rdfs:comment 'Number of local and international partner organizations collaborating in the emergency response.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kiiConductedCount rdf:type rdf:Property ;
    rdfs:label 'Kii Conducted Count' ;
    rdfs:comment 'Number of Key Informant Interviews conducted as part of field assessments for this emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:koboSurveyDeployed rdf:type rdf:Property ;
    rdfs:label 'Kobo Survey Deployed' ;
    rdfs:comment 'Indicates whether mobile data collection surveys via KoboToolbox were deployed for field assessments in this emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadClusters rdf:type rdf:Property ;
    rdfs:label 'Lead Clusters' ;
    rdfs:comment 'Comma-separated list of humanitarian clusters where the organization holds lead or co-lead responsibility (e.g., \'WASH, Shelter, Protection\').' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileHealthOutreachPlanned rdf:type rdf:Property ;
    rdfs:label 'Mobile Health Outreach Planned' ;
    rdfs:comment 'Indicates whether mobile health clinics or outreach services are planned as part of the health response.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nfiDistributionPlanned rdf:type rdf:Property ;
    rdfs:label 'Nfi Distribution Planned' ;
    rdfs:comment 'Indicates whether distribution of non-food items (shelter materials, hygiene kits, household items) is planned.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onsetDate rdf:type rdf:Property ;
    rdfs:label 'Onset Date' ;
    rdfs:comment 'Date when the emergency event first occurred or began impacting the affected population.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:protectionConcernsIdentified rdf:type rdf:Property ;
    rdfs:label 'Protection Concerns Identified' ;
    rdfs:comment 'Summary of key protection concerns identified during assessments (e.g., \'GBV risk, child protection, housing land property rights\').' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rapidAssessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Rapid Assessment Completed' ;
    rdfs:comment 'Indicates whether a rapid needs assessment was completed within the first 72 hours of the emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseEndDate rdf:type rdf:Property ;
    rdfs:label 'Response End Date' ;
    rdfs:comment 'Date when the emergency response operations were concluded or transitioned to recovery phase.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseModality rdf:type rdf:Property ;
    rdfs:label 'Response Modality' ;
    rdfs:comment 'Description of the primary response delivery mechanisms employed (e.g., \'In-kind distribution, Cash and Voucher Assistance (CVA), Service delivery\').' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseStartDate rdf:type rdf:Property ;
    rdfs:label 'Response Start Date' ;
    rdfs:comment 'Date when the organization initiated its emergency response operations.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sitrepFrequency rdf:type rdf:Property ;
    rdfs:label 'Sitrep Frequency' ;
    rdfs:comment 'Frequency at which situation reports are generated and disseminated for this emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetedBeneficiariesCount rdf:type rdf:Property ;
    rdfs:label 'Targeted Beneficiaries Count' ;
    rdfs:comment 'Number of beneficiaries the organization plans to reach through its emergency response interventions.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:washInterventionsPlanned rdf:type rdf:Property ;
    rdfs:label 'Wash Interventions Planned' ;
    rdfs:comment 'Indicates whether WASH sector interventions are included in the emergency response plan.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentPeriodReportingPeriodId rdf:type rdf:Property ;
    rdfs:label 'Parent Period Reporting Period Id' ;
    rdfs:comment 'Reference to a parent reporting period for hierarchical period structures (e.g., monthly periods rolling up to quarterly periods, quarterly to annual). Null for top-level periods.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingPeriod .

ind:primaryPriorReportingPeriodId rdf:type rdf:Property ;
    rdfs:label 'Primary Prior Reporting Period Id' ;
    rdfs:comment 'Self-referencing FK on reporting_period (prior_reporting_period_id)' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingPeriod .

ind:baselinePeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Period Flag' ;
    rdfs:comment 'Indicates whether this reporting period represents a baseline measurement period for program indicators (True) or not (False). Baseline periods establish the starting point for impact measurement.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'The calendar year in which the reporting period falls, used for temporal analysis and trend reporting.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dacCriteriaFocus rdf:type rdf:Property ;
    rdfs:label 'Dac Criteria Focus' ;
    rdfs:comment 'The primary DAC evaluation criteria focus for this period (e.g., \'Relevance\', \'Effectiveness\', \'Efficiency\', \'Impact\', \'Sustainability\', \'Coherence\'). Multiple criteria may be listed as comma-separated values.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionDeadline rdf:type rdf:Property ;
    rdfs:label 'Data Collection Deadline' ;
    rdfs:comment 'The deadline date by which all data collection activities for this reporting period must be completed. Used for MEL workflow management.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataQualityAuditFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Audit Flag' ;
    rdfs:comment 'Indicates whether a data quality audit or verification exercise is scheduled for this reporting period (True) or not (False). Ensures data integrity and reliability.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dhis2PeriodCode rdf:type rdf:Property ;
    rdfs:label 'Dhis2 Period Code' ;
    rdfs:comment 'The period identifier used in DHIS2 system for aggregate health data reporting. Enables integration with DHIS2 for health program monitoring.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorReportingCycle rdf:type rdf:Property ;
    rdfs:label 'Donor Reporting Cycle' ;
    rdfs:comment 'The specific donor reporting cycle or phase that this period supports (e.g., \'Year 1 Q2\', \'Mid-term Review\', \'Final Report\'). Used to align with donor contractual obligations.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endlinePeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Endline Period Flag' ;
    rdfs:comment 'Indicates whether this reporting period represents an endline measurement period for program indicators (True) or not (False). Endline periods capture final outcomes and impact.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fgdScheduledFlag rdf:type rdf:Property ;
    rdfs:label 'Fgd Scheduled Flag' ;
    rdfs:comment 'Indicates whether Focus Group Discussions (FGDs) are scheduled to be conducted during this reporting period (True) or not (False). Used for qualitative data collection planning.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kiiScheduledFlag rdf:type rdf:Property ;
    rdfs:label 'Kii Scheduled Flag' ;
    rdfs:comment 'Indicates whether Key Informant Interviews (KIIs) are scheduled to be conducted during this reporting period (True) or not (False). Used for qualitative data collection planning.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:midlinePeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Midline Period Flag' ;
    rdfs:comment 'Indicates whether this reporting period represents a midline measurement period for program indicators (True) or not (False). Midline periods assess progress at the program midpoint.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monthNumber rdf:type rdf:Property ;
    rdfs:label 'Month Number' ;
    rdfs:comment 'The month number (1-12) within the year, applicable for monthly reporting periods. Null for non-monthly periods.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pdmCycleFlag rdf:type rdf:Property ;
    rdfs:label 'Pdm Cycle Flag' ;
    rdfs:comment 'Indicates whether this reporting period includes a Post-Distribution Monitoring (PDM) cycle for assessing the effectiveness and impact of distributed aid (True) or not (False).' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodDescription rdf:type rdf:Property ;
    rdfs:label 'Period Description' ;
    rdfs:comment 'Detailed description of the reporting period, including any special characteristics, contextual information, or notes about data collection activities during this period.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Report Submission Deadline' ;
    rdfs:comment 'The deadline date by which the final report for this period must be submitted to donors or stakeholders. Critical for compliance with donor agreements.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:weekNumber rdf:type rdf:Property ;
    rdfs:label 'Week Number' ;
    rdfs:comment 'The ISO week number (1-53) within the year, applicable for weekly reporting periods. Null for non-weekly periods.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clusterCode rdf:type rdf:Property ;
    rdfs:label 'Cluster Code' ;
    rdfs:comment 'Code identifying the humanitarian cluster or sector coordination mechanism the program is aligned with (e.g., WASH, Health, Protection).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Number' ;
    rdfs:comment 'Unique grant or award number assigned by the donor for tracking and reporting purposes.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergency rdf:type rdf:Property ;
    rdfs:label 'Is Emergency' ;
    rdfs:comment 'Indicates whether the program is classified as an emergency response intervention requiring expedited procedures.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Comprehensive narrative describing the program\'s objectives, scope, target population, and expected outcomes.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Official name of the humanitarian or development program as registered with donors and governing bodies.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the program indicating its operational state.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the program based on its primary intervention approach and duration.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorCode rdf:type rdf:Property ;
    rdfs:label 'Sector Code' ;
    rdfs:comment 'Five-digit code identifying the primary humanitarian or development sector (WASH, Health, Nutrition, Education, Protection, Livelihood, Shelter, etc.).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorName rdf:type rdf:Property ;
    rdfs:label 'Sector Name' ;
    rdfs:comment 'Human-readable name of the primary sector in which the program operates.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsector rdf:type rdf:Property ;
    rdfs:label 'Subsector' ;
    rdfs:comment 'More granular classification within the primary sector (e.g., Water Supply, Sanitation, Hygiene Promotion under WASH).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoryOfChange rdf:type rdf:Property ;
    rdfs:label 'Theory Of Change' ;
    rdfs:comment 'Narrative or structured description of the causal pathway linking program inputs, activities, outputs, outcomes, and impact.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamMembershipId rdf:type rdf:Property ;
    rdfs:label 'Team Membership Id' ;
    rdfs:comment 'Primary key for the team_membership association' ;
    rdfs:domain ind:TeamMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hoursContributedToTeam rdf:type rdf:Property ;
    rdfs:label 'Hours Contributed To Team' ;
    rdfs:comment 'Cumulative number of hours this volunteer has contributed specifically to this team. Distinct from total volunteer hours, as a volunteer may contribute different hours to different teams. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:TeamMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:joinDate rdf:type rdf:Property ;
    rdfs:label 'Join Date' ;
    rdfs:comment 'The date on which the volunteer officially joined and became an active member of this team. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaveDate rdf:type rdf:Property ;
    rdfs:label 'Leave Date' ;
    rdfs:comment 'The date on which the volunteer exited or was removed from this team. Null if the volunteer is still an active member. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:TeamMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roleInTeam rdf:type rdf:Property ;
    rdfs:label 'Role In Team' ;
    rdfs:comment 'The functional role the volunteer holds within this specific team, such as team lead, health worker, logistics support, or data collector. A volunteer may hold different roles in different teams. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:TeamMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consortiumMembershipId rdf:type rdf:Property ;
    rdfs:label 'Consortium Membership Id' ;
    rdfs:comment 'Primary key for the consortium_membership association' ;
    rdfs:domain ind:ConsortiumMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exitDate rdf:type rdf:Property ;
    rdfs:label 'Exit Date' ;
    rdfs:comment 'The date on which this partner organization formally exited or withdrew from the consortium. Null if the member is currently active. Enables historical membership records and supports donor reporting on partner changes.' ;
    rdfs:domain ind:ConsortiumMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundingSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Funding Share Percentage' ;
    rdfs:comment 'The percentage of the total consortium funding envelope allocated to this specific member organization. This value belongs to the membership relationship — it varies per member per consortium and cannot reside on either the consortium or partner_org master record.' ;
    rdfs:domain ind:ConsortiumMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLeadMember rdf:type rdf:Property ;
    rdfs:label 'Is Lead Member' ;
    rdfs:comment 'Indicates whether this partner organization is the designated lead agency for the consortium. Replaces the lead_partner_org_id FK on the consortium master record, enabling the lead to be tracked as a membership attribute rather than a separate FK.' ;
    rdfs:domain ind:ConsortiumMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingObligations rdf:type rdf:Property ;
    rdfs:label 'Reporting Obligations' ;
    rdfs:comment 'Description of the specific reporting obligations assigned to this member organization within the consortium arrangement, such as narrative reports, financial reports, cluster reports, or IATI submissions. Obligations vary per member and per consortium.' ;
    rdfs:domain ind:ConsortiumMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Distribution Order Line Id' ;
    rdfs:comment 'Primary key for the distribution_order_line association' ;
    rdfs:domain ind:DistributionOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:donorRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Donor Restriction Code' ;
    rdfs:comment 'Code identifying the specific donor funding this commodity line on this distribution order. A single order may have different commodities funded by different donors, making this a line-level attribute rather than an order-header attribute.' ;
    rdfs:domain ind:DistributionOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitValueUsd rdf:type rdf:Property ;
    rdfs:label 'Unit Value Usd' ;
    rdfs:comment 'Monetary value per unit of this commodity at the time of dispatch on this order line, used for waybill valuation and donor reporting. Distinct from the standard_unit_cost on the commodity master, which is a catalog average.' ;
    rdfs:domain ind:DistributionOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Vendor Catalog Item Id' ;
    rdfs:comment 'Primary key for the vendor_catalog_item association' ;
    rdfs:domain ind:VendorCatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commodityCategories rdf:type rdf:Property ;
    rdfs:label 'Commodity Categories' ;
    rdfs:comment 'Comma-separated list of commodity categories that the vendor supplies, such as NFI (Non-Food Items), medical supplies, WASH (Water Sanitation and Hygiene) equipment, shelter materials, food commodities, or logistics services. [Moved from vendor: This denormalized comma-separated string on vendor attempts to capture which commodity categories a vendor supplies, but it cannot represent individual commodity-level agreements, negotiated prices, lead times, or prequalification statuses. The vendor_catalog_item association replaces this field with proper FK-based records per commodity, making commodity_categories redundant and structurally incorrect on the vendor entity.]' ;
    rdfs:domain ind:VendorCatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPlanLineId rdf:type rdf:Property ;
    rdfs:label 'Distribution Plan Line Id' ;
    rdfs:comment 'Primary key for the distribution_plan_line association' ;
    rdfs:domain ind:DistributionPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .
