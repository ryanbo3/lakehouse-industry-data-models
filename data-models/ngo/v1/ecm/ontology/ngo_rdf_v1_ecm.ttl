    rdfs:range xsd:boolean .

ind:notHelpfulCount rdf:type rdf:Property ;
    rdfs:label 'Not Helpful Count' ;
    rdfs:comment 'Number of users who have marked this knowledge article as not helpful, used for quality assessment and content improvement.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'Date on which this knowledge article was first published and made available to its intended audience.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relatedSystem rdf:type rdf:Property ;
    rdfs:label 'Related System' ;
    rdfs:comment 'Name or identifier of the IT system, platform, or application that this knowledge article primarily addresses, such as KoboToolbox, CommCare, DHIS2, Salesforce, or SAP.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retiredDate rdf:type rdf:Property ;
    rdfs:label 'Retired Date' ;
    rdfs:comment 'Date on which this knowledge article was permanently retired and removed from the knowledge base.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:viewCount rdf:type rdf:Property ;
    rdfs:label 'View Count' ;
    rdfs:comment 'Cumulative number of times this knowledge article has been viewed by users, used for usage analytics and popularity ranking.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visibility rdf:type rdf:Property ;
    rdfs:label 'Visibility' ;
    rdfs:comment 'Access control classification indicating who can view this knowledge article: public (external users), internal (all staff), restricted (specific teams), or confidential (named individuals).' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hiringManagerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Hiring Manager Staff Member Id' ;
    rdfs:comment 'Reference to the hiring manager responsible for the final hiring decision.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:jobRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Job Requisition Id' ;
    rdfs:comment 'Reference to the specific job requisition or opening the candidate applied for.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecruitmentRequisition .

ind:alternatePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Alternate Phone Number' ;
    rdfs:comment 'Secondary or alternate contact phone number for the candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableStartDate rdf:type rdf:Property ;
    rdfs:label 'Available Start Date' ;
    rdfs:comment 'The earliest date the candidate is available to begin employment.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:candidateStatus rdf:type rdf:Property ;
    rdfs:label 'Candidate Status' ;
    rdfs:comment 'Current stage of the candidate in the recruitment lifecycle.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverLetterFilePath rdf:type rdf:Property ;
    rdfs:label 'Cover Letter File Path' ;
    rdfs:comment 'Storage location or URI of the candidate\'s cover letter document.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentEmployer rdf:type rdf:Property ;
    rdfs:label 'Current Employer' ;
    rdfs:comment 'Name of the organization where the candidate is currently employed.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentJobTitle rdf:type rdf:Property ;
    rdfs:label 'Current Job Title' ;
    rdfs:comment 'The candidate\'s current job title or role at their present employer.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversitySelfIdentification rdf:type rdf:Property ;
    rdfs:label 'Diversity Self Identification' ;
    rdfs:comment 'Voluntary self-identification information for diversity and inclusion tracking, collected in compliance with equal opportunity regulations.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Salary Amount' ;
    rdfs:comment 'The salary amount the candidate expects or requests for the position.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedSalaryCurrency rdf:type rdf:Property ;
    rdfs:label 'Expected Salary Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the expected salary amount.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'URL to the candidate\'s LinkedIn professional profile.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionAppliedFor rdf:type rdf:Property ;
    rdfs:label 'Position Applied For' ;
    rdfs:comment 'The job title or position name that the candidate applied for.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resumeFilePath rdf:type rdf:Property ;
    rdfs:label 'Resume File Path' ;
    rdfs:comment 'Storage location or URI of the candidate\'s resume or curriculum vitae document.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veteranStatus rdf:type rdf:Property ;
    rdfs:label 'Veteran Status' ;
    rdfs:comment 'Indicates whether the candidate is a military veteran, collected for diversity reporting.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:willingToRelocate rdf:type rdf:Property ;
    rdfs:label 'Willing To Relocate' ;
    rdfs:comment 'Indicates whether the candidate is willing to relocate for the position.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Status' ;
    rdfs:comment 'The candidate\'s legal authorization to work in the target country or region.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Competency Framework Id' ;
    rdfs:comment 'Reference to the competency framework used in this review template for assessing staff capabilities and behaviors.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompetencyFramework .

ind:createdByEmployeeStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Staff Member Id' ;
    rdfs:comment 'Reference to the employee who created this review template record.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:lastModifiedByEmployeeStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By Employee Staff Member Id' ;
    rdfs:comment 'Reference to the employee who most recently modified this review template record.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:organizationUnitId rdf:type rdf:Property ;
    rdfs:label 'Organization Unit Id' ;
    rdfs:comment 'Reference to the organizational unit or department for which this review template is designed or restricted.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:ratingScaleId rdf:type rdf:Property ;
    rdfs:label 'Rating Scale Id' ;
    rdfs:comment 'Reference to the rating scale used in this review template for scoring performance dimensions (e.g., 1-5 scale, exceeds/meets/below expectations).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RatingScale .

ind:allowsCustomization rdf:type rdf:Property ;
    rdfs:label 'Allows Customization' ;
    rdfs:comment 'Indicates whether managers or HR can customize sections or questions when using this template for individual reviews.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalLevels rdf:type rdf:Property ;
    rdfs:label 'Approval Levels' ;
    rdfs:comment 'Number of approval levels required in the review workflow (e.g., 1 for manager only, 2 for manager and director, 3 for manager, director, and HR).' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalWorkflowRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Required' ;
    rdfs:comment 'Indicates whether reviews using this template require formal approval workflow through multiple organizational levels.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesDevelopmentPlan rdf:type rdf:Property ;
    rdfs:label 'Includes Development Plan' ;
    rdfs:comment 'Indicates whether the review template includes a development plan section for identifying learning and growth opportunities.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesGoalSetting rdf:type rdf:Property ;
    rdfs:label 'Includes Goal Setting' ;
    rdfs:comment 'Indicates whether the review template includes a goal-setting component for establishing future performance objectives.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesManagerAssessment rdf:type rdf:Property ;
    rdfs:label 'Includes Manager Assessment' ;
    rdfs:comment 'Indicates whether the review template includes a manager assessment component where the direct supervisor evaluates the employee.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesPeerFeedback rdf:type rdf:Property ;
    rdfs:label 'Includes Peer Feedback' ;
    rdfs:comment 'Indicates whether the review template includes peer feedback from colleagues at the same organizational level.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesSelfAssessment rdf:type rdf:Property ;
    rdfs:label 'Includes Self Assessment' ;
    rdfs:comment 'Indicates whether the review template includes a self-assessment component where the employee evaluates their own performance.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesUpwardFeedback rdf:type rdf:Property ;
    rdfs:label 'Includes Upward Feedback' ;
    rdfs:comment 'Indicates whether the review template includes upward feedback where subordinates evaluate their manager.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultTemplate rdf:type rdf:Property ;
    rdfs:label 'Is Default Template' ;
    rdfs:comment 'Indicates whether this is the default review template for its category or staff type.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMultilingual rdf:type rdf:Property ;
    rdfs:label 'Is Multilingual' ;
    rdfs:comment 'Indicates whether the review template is available in multiple languages to support diverse international staff.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Date when this review template was most recently used to initiate a performance review.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumReviewDurationDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Review Duration Days' ;
    rdfs:comment 'Maximum number of days allowed to complete a review using this template before it is considered overdue.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumReviewDurationDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Review Duration Days' ;
    rdfs:comment 'Minimum number of days required to complete a review using this template from initiation to finalization.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresCalibration rdf:type rdf:Property ;
    rdfs:label 'Requires Calibration' ;
    rdfs:comment 'Indicates whether reviews using this template require calibration sessions to ensure consistency and fairness across the organization.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sectionCount rdf:type rdf:Property ;
    rdfs:label 'Section Count' ;
    rdfs:comment 'Total number of sections or components in the review template structure.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetJobLevel rdf:type rdf:Property ;
    rdfs:label 'Target Job Level' ;
    rdfs:comment 'Job level or grade range for which this review template is designed (e.g., entry-level, mid-level, senior, executive, director). [ENUM-REF-CANDIDATE: entry_level|mid_level|senior|manager|director|executive|c_suite|individual_contributor — promote to reference product]' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStaffCategory rdf:type rdf:Property ;
    rdfs:label 'Target Staff Category' ;
    rdfs:comment 'Staff classification or category for which this review template is intended (e.g., national staff, international staff, field personnel, headquarters staff, volunteers, consultants). [ENUM-REF-CANDIDATE: national_staff|international_staff|field_personnel|headquarters_staff|volunteers|consultants|expatriates|local_hires — promote to reference product]' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Unique business identifier code for the review template used for external reference and system integration.' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the review template (e.g., Annual Performance Review, Probation Review, 360 Feedback).' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateType rdf:type rdf:Property ;
    rdfs:label 'Template Type' ;
    rdfs:comment 'Classification of the review template by purpose (performance, probation, 360 feedback, competency assessment, project review, exit interview, onboarding review).' ;
    rdfs:domain ind:ReviewTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Total number of times this review template has been used to create performance reviews.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceImprovementPlanId rdf:type rdf:Property ;
    rdfs:label 'Performance Improvement Plan Id' ;
    rdfs:comment 'Primary key for performance_improvement_plan' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hrBusinessPartnerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Hr Business Partner Staff Member Id' ;
    rdfs:comment 'Identifier of the HR business partner supporting the performance improvement plan process.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:previousPipId rdf:type rdf:Property ;
    rdfs:label 'Previous Pip Id' ;
    rdfs:comment 'Identifier of any prior performance improvement plan for the same employee, establishing historical context.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceImprovementPlan .

ind:relatedDisciplinaryActionDisciplinaryCaseId rdf:type rdf:Property ;
    rdfs:label 'Related Disciplinary Action Disciplinary Case Id' ;
    rdfs:comment 'Identifier linking to any formal disciplinary action record associated with this performance improvement plan.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisciplinaryCase .

ind:consequencesIfUnsuccessful rdf:type rdf:Property ;
    rdfs:label 'Consequences If Unsuccessful' ;
    rdfs:comment 'Description of the employment consequences if the employee fails to meet the plan objectives, such as demotion, reassignment, or termination.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Date' ;
    rdfs:comment 'Date when the employee formally acknowledged receipt and understanding of the performance improvement plan.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeAcknowledgementSignature rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Signature' ;
    rdfs:comment 'Digital signature or confirmation indicator that the employee has acknowledged the plan.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionCount rdf:type rdf:Property ;
    rdfs:label 'Extension Count' ;
    rdfs:comment 'Number of times the performance improvement plan period has been extended beyond the original end date.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hrApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Hr Approval Date' ;
    rdfs:comment 'Date when the HR department reviewed and approved the performance improvement plan.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:improvementObjectives rdf:type rdf:Property ;
    rdfs:label 'Improvement Objectives' ;
    rdfs:comment 'Specific, measurable objectives and goals the employee must achieve during the plan period.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDescription rdf:type rdf:Property ;
    rdfs:label 'Issue Description' ;
    rdfs:comment 'Detailed narrative description of the specific performance issues and deficiencies being addressed.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExtensionDate rdf:type rdf:Property ;
    rdfs:label 'Last Extension Date' ;
    rdfs:comment 'Date when the most recent extension to the plan period was granted.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'Date when the legal department completed their review of the performance improvement plan.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required' ;
    rdfs:comment 'Indicator of whether the plan requires legal department review due to potential employment law implications.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managerSignature rdf:type rdf:Property ;
    rdfs:label 'Manager Signature' ;
    rdfs:comment 'Digital signature or confirmation indicator from the manager approving and initiating the plan.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceIssueCategory rdf:type rdf:Property ;
    rdfs:label 'Performance Issue Category' ;
    rdfs:comment 'Primary category of performance deficiency that triggered the improvement plan.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known unique business identifier for the performance improvement plan, used for reference and tracking.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportResources rdf:type rdf:Property ;
    rdfs:label 'Support Resources' ;
    rdfs:comment 'Description of training, coaching, mentoring, or other resources provided to support the employee during the improvement period.' ;
    rdfs:domain ind:PerformanceImprovementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationalUnitId rdf:type rdf:Property ;
    rdfs:label 'Organizational Unit Id' ;
    rdfs:comment 'Reference to the organizational unit (department, division, program, or field office) for which this calibration session is conducted.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:reviewCycleId rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Id' ;
    rdfs:comment 'Reference to the performance review cycle to which this calibration session belongs.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReviewCycle .

ind:agenda rdf:type rdf:Property ;
    rdfs:label 'Agenda' ;
    rdfs:comment 'Detailed agenda outlining the topics, employees, and discussion points to be covered during the calibration session.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether the calibration session outcomes require formal approval from senior leadership or HR before finalization.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calibrationMethodology rdf:type rdf:Property ;
    rdfs:label 'Calibration Methodology' ;
    rdfs:comment 'The approach or methodology used to conduct the calibration session, determining how ratings are normalized and aligned across the organization.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consensusAchieved rdf:type rdf:Property ;
    rdfs:label 'Consensus Achieved' ;
    rdfs:comment 'Indicates whether full consensus was achieved among all participants regarding the final calibrated ratings and talent decisions.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionsSummary rdf:type rdf:Property ;
    rdfs:label 'Decisions Summary' ;
    rdfs:comment 'Summary of key decisions made during the calibration session, including rating changes, promotion recommendations, and development actions.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCountReviewed rdf:type rdf:Property ;
    rdfs:label 'Employee Count Reviewed' ;
    rdfs:comment 'Total number of employees whose performance ratings, compensation, or talent status are reviewed during this calibration session.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forcedDistributionApplied rdf:type rdf:Property ;
    rdfs:label 'Forced Distribution Applied' ;
    rdfs:comment 'Indicates whether a forced distribution curve (e.g., bell curve) was applied to performance ratings during this calibration session.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meetingLink rdf:type rdf:Property ;
    rdfs:label 'Meeting Link' ;
    rdfs:comment 'URL or access link for virtual calibration sessions conducted via video conferencing platforms.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingChangesCount rdf:type rdf:Property ;
    rdfs:label 'Rating Changes Count' ;
    rdfs:comment 'Total number of performance rating adjustments made during the calibration session to ensure consistency and fairness.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordingStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Recording Storage Location' ;
    rdfs:comment 'File path or storage location reference for the session recording, if available.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionName rdf:type rdf:Property ;
    rdfs:label 'Session Name' ;
    rdfs:comment 'Descriptive name of the calibration session, typically indicating the review cycle, department, or organizational unit being calibrated.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionRecordingAvailable rdf:type rdf:Property ;
    rdfs:label 'Session Recording Available' ;
    rdfs:comment 'Indicates whether an audio or video recording of the calibration session is available for reference or compliance purposes.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetDistributionPercentages rdf:type rdf:Property ;
    rdfs:label 'Target Distribution Percentages' ;
    rdfs:comment 'The target percentage distribution for each performance rating category (e.g., 10% exceeds, 70% meets, 20% below), stored as a structured string.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Expense Budget Amount' ;
    rdfs:comment 'The total budgeted expense amount for this version, including program, administrative, and fundraising costs.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grantId rdf:type rdf:Property ;
    rdfs:label 'Grant Id' ;
    rdfs:comment 'Reference to the specific grant or donor agreement if this budget version is grant-specific. Nullable for organization-wide budgets.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Baseline' ;
    rdfs:comment 'Indicates whether this version serves as the baseline budget for variance analysis and budget-versus-actual reporting.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether this budget version is locked from further modifications. Typically true for approved and active budgets.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockedBy rdf:type rdf:Property ;
    rdfs:label 'Locked By' ;
    rdfs:comment 'Name or identifier of the person who locked this budget version.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationId rdf:type rdf:Property ;
    rdfs:label 'Organization Id' ;
    rdfs:comment 'Reference to the organizational entity (e.g., headquarters, regional office, program unit) to which this budget version applies.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentVersionId rdf:type rdf:Property ;
    rdfs:label 'Parent Version Id' ;
    rdfs:comment 'Reference to the parent budget version from which this version was derived (e.g., revised budget referencing original budget). Nullable for original versions.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Reference to the program or service line to which this budget version applies. Nullable for organization-wide budgets.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Budget Amount' ;
    rdfs:comment 'The total budgeted revenue amount for this version, including grants, donations, and earned income.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submittedBy rdf:type rdf:Property ;
    rdfs:label 'Submitted By' ;
    rdfs:comment 'Name or identifier of the person who submitted this budget version for approval.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionCode rdf:type rdf:Property ;
    rdfs:label 'Version Code' ;
    rdfs:comment 'Business identifier code for the budget version (e.g., FY2024_V1, FY2024_REVISED, FY2024_FINAL). Used for external reference and reporting.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionName rdf:type rdf:Property ;
    rdfs:label 'Version Name' ;
    rdfs:comment 'Human-readable name of the budget version (e.g., \'FY2024 Original Budget\', \'Q2 Revised Budget\', \'Final Approved Budget\').' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionSequence rdf:type rdf:Property ;
    rdfs:label 'Version Sequence' ;
    rdfs:comment 'Sequential number indicating the order of this version within the fiscal year (e.g., 1 for original, 2 for first revision, 3 for second revision).' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionType rdf:type rdf:Property ;
    rdfs:label 'Version Type' ;
    rdfs:comment 'Classification of the budget version indicating its purpose and stage in the budget lifecycle.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the program budget.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorId rdf:type rdf:Property ;
    rdfs:label 'Donor Id' ;
    rdfs:comment 'Identifier of the primary donor or funding organization for this program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grantNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Number' ;
    rdfs:comment 'Unique grant or award number assigned by the donor for tracking and reporting purposes.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humanitarianResponsePlanId rdf:type rdf:Property ;
    rdfs:label 'Humanitarian Response Plan Id' ;
    rdfs:comment 'Identifier linking the program to a coordinated Humanitarian Response Plan or Flash Appeal.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementingPartnerId rdf:type rdf:Property ;
    rdfs:label 'Implementing Partner Id' ;
    rdfs:comment 'Identifier of the primary implementing partner organization responsible for program execution.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentProgramId rdf:type rdf:Property ;
    rdfs:label 'Parent Program Id' ;
    rdfs:comment 'Identifier of the parent program if this program is part of a larger program hierarchy or portfolio.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programManagerId rdf:type rdf:Property ;
    rdfs:label 'Program Manager Id' ;
    rdfs:comment 'Identifier of the staff member responsible for overall program management and accountability.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Official name of the humanitarian or development program as registered with donors and governing bodies.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the program based on its primary intervention approach and duration.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorCode rdf:type rdf:Property ;
    rdfs:label 'Sector Code' ;
    rdfs:comment 'Five-digit code identifying the primary humanitarian or development sector (WASH, Health, Nutrition, Education, Protection, Livelihood, Shelter, etc.).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorName rdf:type rdf:Property ;
    rdfs:label 'Sector Name' ;
    rdfs:comment 'Human-readable name of the primary sector in which the program operates.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsector rdf:type rdf:Property ;
    rdfs:label 'Subsector' ;
    rdfs:comment 'More granular classification within the primary sector (e.g., Water Supply, Sanitation, Hygiene Promotion under WASH).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoryOfChange rdf:type rdf:Property ;
    rdfs:label 'Theory Of Change' ;
    rdfs:comment 'Narrative or structured description of the causal pathway linking program inputs, activities, outputs, outcomes, and impact.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableTranslations rdf:type rdf:Property ;
    rdfs:label 'Available Translations' ;
    rdfs:comment 'Comma-separated list of ISO 639-3 language codes for which translated versions of this competency framework are available to support multilingual staff populations.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyCategoryCount rdf:type rdf:Property ;
    rdfs:label 'Competency Category Count' ;
    rdfs:comment 'The number of high-level competency categories or clusters used to organize competencies within this framework.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competencyCount rdf:type rdf:Property ;
    rdfs:label 'Competency Count' ;
    rdfs:comment 'The total number of distinct competencies defined within this framework.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentRepositoryPath rdf:type rdf:Property ;
    rdfs:label 'Document Repository Path' ;
    rdfs:comment 'File path or document management system location where the full competency framework documentation, guides, and supporting materials are stored.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkCode rdf:type rdf:Property ;
    rdfs:label 'Framework Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the competency framework for system integration and reporting purposes.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkName rdf:type rdf:Property ;
    rdfs:label 'Framework Name' ;
    rdfs:comment 'The official name of the competency framework used to define and assess staff capabilities and skills.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkScope rdf:type rdf:Property ;
    rdfs:label 'Framework Scope' ;
    rdfs:comment 'The organizational scope to which this competency framework applies: global across all operations, regional, country-specific, program-specific, department-level, or role-specific.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkStatus rdf:type rdf:Property ;
    rdfs:label 'Framework Status' ;
    rdfs:comment 'Current lifecycle status of the competency framework indicating whether it is in draft development, actively in use, under review for updates, deprecated and being phased out, or archived for historical reference.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkType rdf:type rdf:Property ;
    rdfs:label 'Framework Type' ;
    rdfs:comment 'Classification of the competency framework by its primary focus area: technical skills, behavioral competencies, leadership capabilities, functional expertise, core organizational competencies, or specialized domain knowledge.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkVersion rdf:type rdf:Property ;
    rdfs:label 'Framework Version' ;
    rdfs:comment 'Version number of the competency framework following semantic versioning to track revisions and updates over time.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryAlignment rdf:type rdf:Property ;
    rdfs:label 'Industry Alignment' ;
    rdfs:comment 'Description of how this competency framework aligns with nonprofit sector standards, humanitarian industry best practices, or international development competency models.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationWithHris rdf:type rdf:Property ;
    rdfs:label 'Integration With Hris' ;
    rdfs:comment 'Boolean flag indicating whether this competency framework is integrated with the organizations HRIS (e.g., Workday HCM) for automated competency tracking and reporting.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:integrationWithLms rdf:type rdf:Property ;
    rdfs:label 'Integration With Lms' ;
    rdfs:comment 'Boolean flag indicating whether this competency framework is integrated with the organizations Learning Management System for competency-based learning path assignment and tracking.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'The department or organizational unit responsible for maintaining and governing this competency framework (typically Human Resources, Learning and Development, or Talent Management).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerRole rdf:type rdf:Property ;
    rdfs:label 'Owner Role' ;
    rdfs:comment 'The job title or role of the individual accountable for this competency framework (e.g., Chief Human Resources Officer, Head of Talent Development).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyLevelsCount rdf:type rdf:Property ;
    rdfs:label 'Proficiency Levels Count' ;
    rdfs:comment 'The total number of proficiency or mastery levels defined within this competency framework (e.g., 3-level, 5-level, 7-level scale).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proficiencyScaleDescription rdf:type rdf:Property ;
    rdfs:label 'Proficiency Scale Description' ;
    rdfs:comment 'Textual description of the proficiency scale used in this framework, including level names and progression criteria (e.g., Beginner, Intermediate, Advanced, Expert, Master).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Notes on how this competency framework supports compliance with labor laws, professional certification requirements, or donor-mandated workforce standards.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceStandard rdf:type rdf:Property ;
    rdfs:label 'Source Standard' ;
    rdfs:comment 'The external competency standard, industry model, or professional body framework upon which this competency framework is based or adapted from (e.g., SHRM, ILO, CHS, sector-specific models).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsPerformanceManagement rdf:type rdf:Property ;
    rdfs:label 'Supports Performance Management' ;
    rdfs:comment 'Boolean flag indicating whether this competency framework is integrated into performance appraisal and performance management processes.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRecruitment rdf:type rdf:Property ;
    rdfs:label 'Supports Recruitment' ;
    rdfs:comment 'Boolean flag indicating whether this competency framework is used in talent acquisition processes for job profiling, candidate assessment, and selection decisions.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsSuccessionPlanning rdf:type rdf:Property ;
    rdfs:label 'Supports Succession Planning' ;
    rdfs:comment 'Boolean flag indicating whether this competency framework is used to support succession planning and talent pipeline development activities.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsDecimalPoints rdf:type rdf:Property ;
    rdfs:label 'Allows Decimal Points' ;
    rdfs:comment 'Indicates whether the rating scale permits decimal values (e.g., 3.75 on a 1-5 scale) for precise scoring.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsHalfPoints rdf:type rdf:Property ;
    rdfs:label 'Allows Half Points' ;
    rdfs:comment 'Indicates whether the rating scale permits half-point increments (e.g., 3.5 on a 1-5 scale) for more granular assessments.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableToJobLevels rdf:type rdf:Property ;
    rdfs:label 'Applicable To Job Levels' ;
    rdfs:comment 'Comma-separated list of job levels or grades this rating scale applies to (e.g., \'entry_level\', \'mid_level\', \'senior_level\', \'executive\').' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableToStaffTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable To Staff Types' ;
    rdfs:comment 'Comma-separated list of staff categories this rating scale applies to (e.g., \'national_staff\', \'international_staff\', \'field_personnel\', \'headquarters_staff\', \'volunteers\').' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Numeric value controlling the sort order when multiple rating scales are presented to users in the Human Resources Information System (HRIS).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionPercentages rdf:type rdf:Property ;
    rdfs:label 'Distribution Percentages' ;
    rdfs:comment 'If forced distribution applies, specifies the required percentage distribution across rating levels (e.g., \'10% top, 20% high, 40% middle, 20% low, 10% bottom\').' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incrementValue rdf:type rdf:Property ;
    rdfs:label 'Increment Value' ;
    rdfs:comment 'The step or increment between rating values (e.g., 1.0 for integer scales, 0.5 for half-point scales, 0.1 for decimal scales).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDefaultScale rdf:type rdf:Property ;
    rdfs:label 'Is Default Scale' ;
    rdfs:comment 'Indicates whether this is the default rating scale to be used when no specific scale is selected for a performance review or assessment.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isForcedDistribution rdf:type rdf:Property ;
    rdfs:label 'Is Forced Distribution' ;
    rdfs:comment 'Indicates whether this rating scale requires forced distribution (e.g., bell curve ranking where only a certain percentage of employees can receive top ratings).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManagerAssessmentEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Manager Assessment Enabled' ;
    rdfs:comment 'Indicates whether managers can use this rating scale to assess their direct reports.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPeerAssessmentEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Peer Assessment Enabled' ;
    rdfs:comment 'Indicates whether this rating scale can be used for peer-to-peer assessments in 360-degree feedback processes.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSelfAssessmentEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Self Assessment Enabled' ;
    rdfs:comment 'Indicates whether employees can use this rating scale to perform self-assessments as part of the performance review process.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Value' ;
    rdfs:comment 'The highest numeric value on the rating scale (e.g., 5 for a 1-5 scale, 100 for a 0-100 scale).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Value' ;
    rdfs:comment 'The lowest numeric value on the rating scale (e.g., 1 for a 1-5 scale, 0 for a 0-100 scale).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfLevels rdf:type rdf:Property ;
    rdfs:label 'Number Of Levels' ;
    rdfs:comment 'Total count of distinct rating levels or points on the scale (e.g., 5 for a 5-point scale, 4 for a 4-level competency scale).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scaleCode rdf:type rdf:Property ;
    rdfs:label 'Scale Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the rating scale for system integration and reporting (e.g., \'PERF-5PT\', \'COMP-4LVL\').' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleDescription rdf:type rdf:Property ;
    rdfs:label 'Scale Description' ;
    rdfs:comment 'Detailed explanation of the rating scale\'s purpose, usage context, and interpretation guidelines for managers and employees.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleInterpretationGuide rdf:type rdf:Property ;
    rdfs:label 'Scale Interpretation Guide' ;
    rdfs:comment 'Guidance text explaining how to interpret and apply each rating level, including behavioral anchors or performance indicators for each point on the scale.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleName rdf:type rdf:Property ;
    rdfs:label 'Scale Name' ;
    rdfs:comment 'The business name of the rating scale (e.g., \'5-Point Performance Scale\', \'Competency Assessment Scale\', \'360 Feedback Scale\').' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleStatus rdf:type rdf:Property ;
    rdfs:label 'Scale Status' ;
    rdfs:comment 'Current lifecycle status of the rating scale, indicating whether it is available for use in performance reviews and assessments.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleType rdf:type rdf:Property ;
    rdfs:label 'Scale Type' ;
    rdfs:comment 'The category or purpose of the rating scale, indicating what dimension of workforce performance or capability it measures.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUserId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Id' ;
    rdfs:comment 'Reference to the senior leader or Human Resources executive who approved this review cycle for launch.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'The date when leadership conducts calibration sessions to ensure consistency and fairness across performance ratings.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedByUserId rdf:type rdf:Property ;
    rdfs:label 'Closed By User Id' ;
    rdfs:comment 'Reference to the user or administrator who officially closed this review cycle in the system.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completedReviewCount rdf:type rdf:Property ;
    rdfs:label 'Completed Review Count' ;
    rdfs:comment 'The number of performance reviews that have been completed and finalized within this review cycle.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'The percentage of eligible employees who have completed their performance reviews within this cycle, calculated as (completed_review_count / eligible_employee_count) * 100.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUserId rdf:type rdf:Property ;
    rdfs:label 'Created By User Id' ;
    rdfs:comment 'Reference to the user or administrator who created this review cycle record in the system.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Externally-known unique code or identifier for the review cycle used in reporting and system integration (e.g., \'APR-2024\', \'MYR-Q2-2024\').' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Human-readable name or title of the review cycle (e.g., \'Annual Performance Review 2024\', \'Mid-Year Check-In Q2 2024\').' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleOwnerId rdf:type rdf:Property ;
    rdfs:label 'Cycle Owner Id' ;
    rdfs:comment 'Reference to the Human Resources staff member or administrator who is responsible for managing and overseeing this review cycle.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'Current lifecycle status of the review cycle indicating its operational state (draft, scheduled, active, in progress, completed, closed, cancelled).' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'Classification of the review cycle indicating its purpose and frequency (e.g., annual performance review, mid-year check-in, probationary review, project-based review, ad-hoc review, quarterly review).' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

