# --- Attribute Properties ---
ind:biometricRecordId rdf:type rdf:Property ;
    rdfs:label 'Biometric Record Id' ;
    rdfs:comment 'Unique identifier for the biometric enrollment record.' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentId rdf:type rdf:Property ;
    rdfs:label 'Component Id' ;
    rdfs:comment 'Reference to the humanitarian or development program under which this biometric enrollment was conducted.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Component .

ind:donorRequirementId rdf:type rdf:Property ;
    rdfs:label 'Donor Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.donor_requirement. Business justification: Biometric enrollment often required by specific donor compliance frameworks (WFP SCOPE, UNHCR ProGres). Links biometric records to the specific donor requirement they fulfill for audit verification an' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DonorRequirement .

ind:duplicateRecordBiometricRecordId rdf:type rdf:Property ;
    rdfs:label 'Duplicate Record Biometric Record Id' ;
    rdfs:comment 'Reference to another biometric record that was identified as a potential duplicate during deduplication processing.' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BiometricRecord .

ind:registrantId rdf:type rdf:Property ;
    rdfs:label 'Registrant Id' ;
    rdfs:comment 'Reference to the beneficiary individual or household whose biometric data was captured.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registrant .

ind:staffMemberId rdf:type rdf:Property ;
    rdfs:label 'Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or volunteer who performed the biometric enrollment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:biometricModality rdf:type rdf:Property ;
    rdfs:label 'Biometric Modality' ;
    rdfs:comment 'Type of biometric characteristic captured for identity verification (fingerprint, iris scan, facial recognition, palm vein, voice recognition, or multimodal combination).' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureMethod rdf:type rdf:Property ;
    rdfs:label 'Capture Method' ;
    rdfs:comment 'Technical method used to capture the biometric sample (optical, capacitive, ultrasonic, thermal, camera-based, or scanner-based).' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date when informed consent for biometric enrollment was obtained from the beneficiary.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'Method by which consent was obtained (written signature, verbal acknowledgment, digital acceptance, or witnessed consent).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentObtained rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained' ;
    rdfs:comment 'Boolean flag indicating whether informed consent was obtained from the beneficiary for biometric data collection and processing.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'System timestamp when this biometric record was first created in the database.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Days' ;
    rdfs:comment 'Number of days the biometric data will be retained before deletion, based on organizational policy and regulatory requirements.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deduplicationMatchFound rdf:type rdf:Property ;
    rdfs:label 'Deduplication Match Found' ;
    rdfs:comment 'Boolean flag indicating whether a potential duplicate match was found during deduplication processing.' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deduplicationMatchScore rdf:type rdf:Property ;
    rdfs:label 'Deduplication Match Score' ;
    rdfs:comment 'Numerical similarity score from deduplication matching, indicating the likelihood that this record matches an existing beneficiary record. Higher scores indicate stronger matches.' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deduplicationPerformed rdf:type rdf:Property ;
    rdfs:label 'Deduplication Performed' ;
    rdfs:comment 'Boolean flag indicating whether deduplication matching was performed against existing biometric records to prevent duplicate registrations.' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Device Identifier' ;
    rdfs:comment 'Unique identifier of the biometric capture device used for enrollment (serial number, MAC address, or device registration code).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceManufacturer rdf:type rdf:Property ;
    rdfs:label 'Device Manufacturer' ;
    rdfs:comment 'Name of the manufacturer of the biometric capture device.' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceModel rdf:type rdf:Property ;
    rdfs:label 'Device Model' ;
    rdfs:comment 'Model number or name of the biometric capture device.' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Encryption Algorithm' ;
    rdfs:comment 'Name of the encryption algorithm used to secure the biometric template (e.g., AES-256, RSA-2048).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionApplied rdf:type rdf:Property ;
    rdfs:label 'Encryption Applied' ;
    rdfs:comment 'Boolean flag indicating whether the biometric template is stored with encryption for enhanced security.' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date when the biometric data was captured and enrolled into the system.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentLatitude rdf:type rdf:Property ;
    rdfs:label 'Enrollment Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the enrollment location in decimal degrees.' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentLocation rdf:type rdf:Property ;
    rdfs:label 'Enrollment Location' ;
    rdfs:comment 'Name or description of the physical location where biometric enrollment took place (distribution site, registration center, field office).' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentLongitude rdf:type rdf:Property ;
    rdfs:label 'Enrollment Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the enrollment location in decimal degrees.' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Externally-known unique enrollment identifier assigned during biometric capture session.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentPurpose rdf:type rdf:Property ;
    rdfs:label 'Enrollment Purpose' ;
    rdfs:comment 'Business purpose or use case for which the biometric data was collected (e.g., cash distribution, NFI distribution, health service access, education enrollment).' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Timestamp' ;
    rdfs:comment 'Precise date and time when the biometric enrollment was completed, including timezone information.' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date when the biometric enrollment expires and requires re-enrollment, based on organizational policy or data retention requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Boolean flag indicating whether this biometric record is currently active and available for verification. Inactive records are retained for audit but not used for matching.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'System timestamp when this biometric record was last updated or modified.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the enrollment operator regarding special circumstances, quality issues, or beneficiary concerns during enrollment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Numerical quality assessment score of the captured biometric sample, typically ranging from 0 to 100, indicating suitability for matching and verification.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityThresholdMet rdf:type rdf:Property ;
    rdfs:label 'Quality Threshold Met' ;
    rdfs:comment 'Boolean flag indicating whether the captured biometric sample met the minimum quality threshold required for enrollment and verification.' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:templateFormat rdf:type rdf:Property ;
    rdfs:label 'Template Format' ;
    rdfs:comment 'Standard format specification used for storing the biometric template (e.g., ISO/IEC 19794-2 for fingerprint, ISO/IEC 19794-6 for iris).' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateReference rdf:type rdf:Property ;
    rdfs:label 'Template Reference' ;
    rdfs:comment 'Secure reference identifier or pointer to the stored biometric template in the biometric database. Does not contain the actual biometric data but links to it.' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Template Size Bytes' ;
    rdfs:comment 'Size of the biometric template in bytes, indicating storage requirements.' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationCount rdf:type rdf:Property ;
    rdfs:label 'Verification Count' ;
    rdfs:comment 'Total number of times this biometric record has been successfully used for identity verification.' ;
    rdfs:domain ind:BiometricRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when the biometric record was last successfully verified during a distribution or service access event.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Current status of the biometric record in the verification lifecycle (enrolled, verified, failed, pending review, expired, or revoked).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseActionId rdf:type rdf:Property ;
    rdfs:label 'Case Action Id' ;
    rdfs:comment 'Unique system-generated identifier for each case action record within the beneficiary case management system. Primary key for the case_action data product.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseRecordId rdf:type rdf:Property ;
    rdfs:label 'Case Record Id' ;
    rdfs:comment 'Reference to the parent beneficiary case to which this action belongs. Links the action to the overarching case record for the individual, household, or community being served.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CaseRecord .

ind:commodityId rdf:type rdf:Property ;
    rdfs:label 'Commodity Id' ;
    rdfs:comment 'Foreign key linking to supply.commodity. Business justification: Case actions document specific items provided during interventions (dignity kits for GBV survivors, hygiene supplies, emergency NFI). Critical for case management audit trails, protection monitoring, ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Commodity .

ind:constituentMessageId rdf:type rdf:Property ;
    rdfs:label 'Constituent Message Id' ;
    rdfs:comment 'Foreign key linking to communication.constituent_message. Business justification: Case workers send SMS/email confirmations, appointment reminders, and follow-up messages during case actions (home visits, counseling). Tracking which message was sent during which action is essential' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstituentMessage .

ind:feedbackSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Feedback Submission Id' ;
    rdfs:comment 'Foreign key linking to communication.feedback_submission. Business justification: Post-service satisfaction surveys and feedback collection are triggered by case actions (service delivery, counseling sessions). Links feedback to the specific action being evaluated, enabling service' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeedbackSubmission .

ind:partnerOrgId rdf:type rdf:Property ;
    rdfs:label 'Partner Org Id' ;
    rdfs:comment 'Foreign key linking to partnership.partner_org. Business justification: Individual case actions (counseling sessions, referrals, service delivery) are often executed by partner staff. Tracking the implementing partner per action enables activity-based costing, partner per' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerOrg .

ind:projectSiteId rdf:type rdf:Property ;
    rdfs:label 'Project Site Id' ;
    rdfs:comment 'Foreign key linking to field.project_site. Business justification: Individual case actions (counseling sessions, health consultations, legal aid) occur at field sites. Essential for activity-based reporting, service utilization analysis, and site performance monitori' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectSite .

ind:volunteerId rdf:type rdf:Property ;
    rdfs:label 'Volunteer Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer. Business justification: Case management actions are frequently performed by trained volunteers (community health workers, protection monitors, PSS facilitators). Essential for tracking who delivered services, accountability,' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:actionCategory rdf:type rdf:Property ;
    rdfs:label 'Action Category' ;
    rdfs:comment 'Humanitarian sector or thematic category under which this action falls, aligned with OCHA cluster system and IATI sector codes. Enables cross-sector analysis and cluster reporting. [ENUM-REF-CANDIDATE: protection|health|nutrition|wash|shelter|education|livelihoods|psychosocial|food_security|cash_and_voucher — promote to reference product]' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionDate rdf:type rdf:Property ;
    rdfs:label 'Action Date' ;
    rdfs:comment 'The actual calendar date on which the case action was performed or delivered in the field. This is the principal real-world event date used for MEL reporting, PDM analysis, and donor reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionOutcome rdf:type rdf:Property ;
    rdfs:label 'Action Outcome' ;
    rdfs:comment 'The result or outcome of the case action as assessed by the case worker at the time of completion. Used for MEL indicator tracking, Results-Based Management (RBM) reporting, and LogFrame output measurement.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Action Reference Number' ;
    rdfs:comment 'Externally visible, human-readable reference number assigned to this case action for use in field reports, SitReps, and donor reporting. Follows the format CA-YYYY-NNNNNN.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle status of the case action, tracking progression from planning through completion or cancellation. Used for workload management and case progress monitoring.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Timestamp' ;
    rdfs:comment 'Precise date and time at which the case action was recorded or submitted in the system, including timezone offset. Used for audit trails, data quality checks, and real-time field monitoring.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the type of intervention or activity performed during this case action. Drives workflow routing, reporting disaggregation, and MEL indicator tracking. [ENUM-REF-CANDIDATE: home_visit|counseling_session|referral|service_provision|follow_up_call|group_session|needs_assessment|distribution|medical_consultation|legal_aid|psychosocial_support|community_mobilization — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adminLevel1Code rdf:type rdf:Property ;
    rdfs:label 'Admin Level1 Code' ;
    rdfs:comment 'ISO 3166-2 or OCHA P-Code for the first administrative division (e.g., state, province, region) where the action was conducted. Used for geographic disaggregation in donor and cluster reports.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adminLevel2Code rdf:type rdf:Property ;
    rdfs:label 'Admin Level2 Code' ;
    rdfs:comment 'OCHA P-Code for the second administrative division (e.g., district, county, woreda) where the action was conducted. Enables sub-national geographic disaggregation for MEL and cluster reporting.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Method by which informed consent was obtained from the beneficiary for this case action. Supports accountability and protection mainstreaming requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the country where the case action was conducted. Required for multi-country INGO operations and IATI reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Method used to collect data for this case action. FGD = Focus Group Discussion, KII = Key Informant Interview. Supports data quality assessment and ICT4D (Information and Communication Technology for Development) tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Duration in minutes of the case action or intervention session. Used for workload analysis, staff time tracking, and service intensity measurement in MEL frameworks.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Free-text description of the reason this case action was escalated to a higher authority or inter-agency body. Confidential case management information.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequired rdf:type rdf:Property ;
    rdfs:label 'Escalation Required' ;
    rdfs:comment 'Indicates whether this case action has triggered an escalation to a supervisor, protection officer, or inter-agency coordination body due to severity, risk, or unresolved needs.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether a follow-up action is required after this case action. When true, next_action_due_date must be populated. Drives automated task creation in CommCare and Dynamics 365.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpType rdf:type rdf:Property ;
    rdfs:label 'Follow Up Type' ;
    rdfs:comment 'Type of follow-up action planned for this case after the current action is completed. Used to pre-populate the next case action record and support case worker scheduling.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSensitiveCase rdf:type rdf:Property ;
    rdfs:label 'Is Sensitive Case' ;
    rdfs:comment 'Indicates whether this case action relates to a sensitive protection case such as GBV, child protection, or trafficking. Triggers enhanced data access controls and confidentiality protocols.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (WGS84 decimal degrees) of the location where the case action was conducted, captured via mobile device GPS. Enables GIS mapping and geographic analysis of service delivery.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (WGS84 decimal degrees) of the location where the case action was conducted, captured via mobile device GPS. Enables GIS mapping and geographic analysis of service delivery.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:muacMeasurementMm rdf:type rdf:Property ;
    rdfs:label 'Muac Measurement Mm' ;
    rdfs:comment 'Mid-Upper Arm Circumference (MUAC) measurement in millimetres recorded during a nutrition screening action. Used to classify Global Acute Malnutrition (GAM) and Severe Acute Malnutrition (SAM) status per SPHERE standards.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Due Date' ;
    rdfs:comment 'The date by which the next follow-up action or intervention for this case must be completed. Drives case worker task queues and escalation alerts in CommCare and Dynamics 365.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nutritionStatus rdf:type rdf:Property ;
    rdfs:label 'Nutrition Status' ;
    rdfs:comment 'Nutritional status classification of the beneficiary as assessed during this action, based on MUAC or weight-for-height z-score. SAM = Severe Acute Malnutrition, MAM = Moderate Acute Malnutrition, per SPHERE and WHO standards.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeNotes rdf:type rdf:Property ;
    rdfs:label 'Outcome Notes' ;
    rdfs:comment 'Free-text narrative describing the outcome of the case action, observations made during the visit or session, and any contextual information relevant to case progress. Confidential case management information.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionConcernType rdf:type rdf:Property ;
    rdfs:label 'Protection Concern Type' ;
    rdfs:comment 'Specific protection concern category associated with this case action, used for disaggregated protection cluster reporting. Confidential and access-restricted. [ENUM-REF-CANDIDATE: gbv|child_protection|trafficking|idp_displacement|statelessness|forced_recruitment|detention|none — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pssSessionNumber rdf:type rdf:Property ;
    rdfs:label 'Pss Session Number' ;
    rdfs:comment 'Sequential session number for Psychosocial Support (PSS) interventions, tracking the beneficiary\'s progression through a structured PSS program. Applicable when action_type is \'counseling_session\'.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referralDestination rdf:type rdf:Property ;
    rdfs:label 'Referral Destination' ;
    rdfs:comment 'Name or identifier of the organization, facility, or service to which the beneficiary was referred during this action. Applicable when action_type is \'referral\'. Supports referral pathway tracking and inter-agency coordination.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralReason rdf:type rdf:Property ;
    rdfs:label 'Referral Reason' ;
    rdfs:comment 'Description of the reason the beneficiary was referred to another service or organization. Confidential case management information used for inter-agency coordination and case continuity.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The originally planned date on which this case action was scheduled to occur. Compared against action_date to measure timeliness and adherence to case plans.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceItemsProvided rdf:type rdf:Property ;
    rdfs:label 'Service Items Provided' ;
    rdfs:comment 'Description of specific Non-Food Items (NFIs), services, or assistance items provided to the beneficiary during this action (e.g., hygiene kit, food ration, cash transfer amount). Used for distribution tracking and PDM.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The native record identifier from the originating operational system (CommCare case_id, KoboToolbox submission_id, or Dynamics 365 activityid). Enables traceability back to the source system for reconciliation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Operational system of record from which this case action record originated. Supports data lineage, deduplication, and integration quality monitoring in the Databricks Silver Layer.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorReviewDate rdf:type rdf:Property ;
    rdfs:label 'Supervisor Review Date' ;
    rdfs:comment 'Date on which a supervisor reviewed and validated this case action record. Populated when supervisor_reviewed is true.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisorReviewed rdf:type rdf:Property ;
    rdfs:label 'Supervisor Reviewed' ;
    rdfs:comment 'Indicates whether a supervisor or team leader has reviewed and validated this case action record. Supports quality assurance, accountability, and CHS compliance verification.' ;
    rdfs:domain ind:CaseAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp when this case action record was last modified in the system. Used for change data capture, audit trails, and incremental Silver Layer processing.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:awardId rdf:type rdf:Property ;
    rdfs:label 'Award Id' ;
    rdfs:comment 'Reference to the donor grant funding the program under which this case is managed. Required for donor accountability reporting, BvA tracking, and compliance with grant conditions (e.g., USAID BHA, CERF, DFID).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Award .

ind:complianceIncidentId rdf:type rdf:Property ;
    rdfs:label 'Compliance Incident Id' ;
    rdfs:comment 'Foreign key linking to compliance.incident. Business justification: Case management systems track compliance incidents (fraud, safeguarding, misconduct allegations) that trigger beneficiary case records. Essential for safeguarding workflows and incident response docum' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceIncident .

ind:correctiveActionPlanId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Id' ;
    rdfs:comment 'Foreign key linking to compliance.corrective_action_plan. Business justification: Case management reviews identify quality issues (incomplete documentation, missed follow-ups, protocol violations). CAPs reference specific cases as examples and track remediation. Required for intern' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveActionPlan .

ind:countryOfficeId rdf:type rdf:Property ;
    rdfs:label 'Country Office Id' ;
    rdfs:comment 'Reference to the geographic location (camp, settlement, district, or facility) where the case is being managed. Supports GIS-based field operations mapping and geographic disaggregation in MEL reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CountryOffice .

ind:interventionId rdf:type rdf:Property ;
    rdfs:label 'Intervention Id' ;
    rdfs:comment 'Reference to the humanitarian or development program under which this case is managed (e.g., GBV response, child protection, nutrition, PSS, livelihoods).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Intervention .

ind:caseNarrative rdf:type rdf:Property ;
    rdfs:label 'Case Narrative' ;
    rdfs:comment 'Free-text longitudinal narrative documenting the beneficiary\'s situation, interventions provided, progress notes, and caseworker observations. Contains sensitive personal and protection information. Restricted access per data protection protocols.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Human-readable, externally-known unique case reference code assigned at registration. Used in field communications, referral letters, and donor/compliance reporting. Format: CASE-{PROGRAM_CODE}-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casePlanDeveloped rdf:type rdf:Property ;
    rdfs:label 'Case Plan Developed' ;
    rdfs:comment 'Indicates whether a formal individualized case plan has been developed and documented for this beneficiary. A case plan is a mandatory element of structured case management per IASC standards.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseStage rdf:type rdf:Property ;
    rdfs:label 'Case Stage' ;
    rdfs:comment 'Current stage within the structured case management workflow cycle (intake → assessment → planning → intervention → monitoring → closure). Distinct from case_status; represents the process phase rather than the operational state.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle state of the case record within the CommCare case management workflow. Drives operational dashboards, caseload reporting, and MEL tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the case by humanitarian sector or service modality. Drives workflow routing, referral pathways, and MEL indicator disaggregation. [ENUM-REF-CANDIDATE: protection|gbv|child_protection|pss|nutrition|health|livelihoods — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Calendar date on which the case was formally closed. Null if the case remains open or in-progress. Used to calculate case duration and throughput metrics.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Standardized reason for case closure. Used for caseload quality analysis, MEL outcome disaggregation, and donor accountability reporting. [ENUM-REF-CANDIDATE: services_completed|voluntary_withdrawal|lost_to_followup|transferred|deceased|duplicate|other — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commcareCaseReference rdf:type rdf:Property ;
    rdfs:label 'Commcare Case Reference' ;
    rdfs:comment 'Source system case identifier from CommCare mobile case management platform. Used for data lineage, reconciliation, and integration with field data collection workflows.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isChildCase rdf:type rdf:Property ;
    rdfs:label 'Is Child Case' ;
    rdfs:comment 'Indicates whether the beneficiary is a child (under 18 years of age). Triggers child protection protocols, guardian consent requirements, and UNICEF/child protection cluster reporting obligations.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGbvCase rdf:type rdf:Property ;
    rdfs:label 'Is Gbv Case' ;
    rdfs:comment 'Indicates whether this case involves Gender-Based Violence (GBV). Enables secure, disaggregated GBV caseload reporting while maintaining strict data protection protocols per IASC GBV guidelines.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIdpCase rdf:type rdf:Property ;
    rdfs:label 'Is Idp Case' ;
    rdfs:comment 'Indicates whether the beneficiary is an Internally Displaced Person (IDP). Used for OCHA displacement tracking, Cluster reporting, and disaggregated humanitarian response analysis.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastFollowupDate rdf:type rdf:Property ;
    rdfs:label 'Last Followup Date' ;
    rdfs:comment 'Date of the most recent caseworker interaction or follow-up visit recorded for this case. Used to identify inactive cases and trigger escalation workflows.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalAidRequired rdf:type rdf:Property ;
    rdfs:label 'Legal Aid Required' ;
    rdfs:comment 'Indicates whether the beneficiary requires legal aid services as part of the case management plan (e.g., documentation, asylum claims, GBV legal redress). Triggers referral to legal service providers.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:muacCm rdf:type rdf:Property ;
    rdfs:label 'Muac Cm' ;
    rdfs:comment 'Mid-Upper Arm Circumference (MUAC) measurement in centimetres recorded at case intake for nutrition cases. Used to classify Severe Acute Malnutrition (SAM) and Global Acute Malnutrition (GAM) per SPHERE/WHO thresholds. Applicable to nutrition case types only.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextFollowupDate rdf:type rdf:Property ;
    rdfs:label 'Next Followup Date' ;
    rdfs:comment 'Scheduled date for the next planned caseworker interaction or home visit. Drives field scheduling and caseload management in CommCare.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onHoldReason rdf:type rdf:Property ;
    rdfs:label 'On Hold Reason' ;
    rdfs:comment 'Free-text or coded reason explaining why the case has been placed on hold (e.g., beneficiary unreachable, security access constraints, awaiting referral response). Populated only when case_status = on_hold.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Calendar date on which the case was formally opened and registered in the case management system. Used for caseload aging analysis and response time measurement.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcomeClassification rdf:type rdf:Property ;
    rdfs:label 'Outcome Classification' ;
    rdfs:comment 'Standardized classification of the case result at closure. Used for MEL outcome reporting, donor accountability, and Theory of Change (ToC) validation. [ENUM-REF-CANDIDATE: goal_achieved|partially_achieved|not_achieved|lost_to_followup|referred_out|deceased — promote to reference product]' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentingIssue rdf:type rdf:Property ;
    rdfs:label 'Presenting Issue' ;
    rdfs:comment 'Primary issue or need presented by the beneficiary at case intake, as documented by the caseworker (e.g., acute malnutrition, GBV incident, displacement, lack of shelter, psychosocial distress).' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Urgency classification assigned to the case based on vulnerability assessment, protection risk, or medical severity. Determines response time SLAs and caseworker allocation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Protection Risk Level' ;
    rdfs:comment 'Assessed level of protection risk for the beneficiary at the time of case opening, based on IASC protection risk analysis. Drives escalation protocols and inter-agency coordination.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pssSessionCount rdf:type rdf:Property ;
    rdfs:label 'Pss Session Count' ;
    rdfs:comment 'Number of Psychosocial Support (PSS) sessions attended by the beneficiary under this case. Used for MEL output tracking, minimum dose compliance, and donor reporting on PSS program reach.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referralDate rdf:type rdf:Property ;
    rdfs:label 'Referral Date' ;
    rdfs:comment 'Date on which the beneficiary was referred to an external service or organization. Used to measure referral response time and inter-agency coordination effectiveness.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Channel or entity through which the beneficiary was referred into this case. Used for referral pathway analysis and community outreach effectiveness reporting. [ENUM-REF-CANDIDATE: self_referral|community_referral|health_facility|partner_org|government|hotline|other — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPlanInPlace rdf:type rdf:Property ;
    rdfs:label 'Safety Plan In Place' ;
    rdfs:comment 'Indicates whether a formal safety plan has been developed and agreed with the beneficiary, particularly for GBV and protection cases. Required element of minimum case management standards.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceModality rdf:type rdf:Property ;
    rdfs:label 'Service Modality' ;
    rdfs:comment 'Mode of service delivery used for this case (e.g., in-person clinic visit, remote counselling, mobile outreach, group PSS session, home visit). Used for operational planning and cost analysis.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Supervisor Review Required' ;
    rdfs:comment 'Indicates whether this case has been flagged for mandatory supervisory review, typically due to critical priority, complex protection risk, or escalation trigger. Supports quality assurance and safeguarding protocols.' ;
    rdfs:domain ind:CaseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vulnerabilityScore rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Score' ;
    rdfs:comment 'Composite numeric score derived from the beneficiary needs assessment, reflecting overall vulnerability level (e.g., 0–100 scale). Used for prioritization, targeting, and MEL disaggregation. Higher scores indicate greater vulnerability.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communityId rdf:type rdf:Property ;
    rdfs:label 'Community Id' ;
    rdfs:comment 'Unique identifier for the community, settlement, camp, or geographic area registered as a collective beneficiary unit. Primary key for the community entity.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Community .

ind:accessConstraintLevel rdf:type rdf:Property ;
    rdfs:label 'Access Constraint Level' ;
    rdfs:comment 'Level of operational access constraints affecting the community due to security incidents, administrative restrictions, natural barriers, or conflict dynamics. No constraint: full access. Low: minor delays. Medium: significant restrictions. High: severely constrained. No access: inaccessible. Used for operational planning and risk management.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeProgramCount rdf:type rdf:Property ;
    rdfs:label 'Active Program Count' ;
    rdfs:comment 'Number of active humanitarian or development programs currently operating in the community. Used for coordination, gap analysis, and 3W (Who does What Where) reporting.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:admin1Code rdf:type rdf:Property ;
    rdfs:label 'Admin1 Code' ;
    rdfs:comment 'First-level administrative division code (province, state, governorate) where the community is located. Aligns with OCHA Common Operational Dataset Administrative Boundaries (COD-AB) P-codes for standardized geographic reporting.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admin1Name rdf:type rdf:Property ;
    rdfs:label 'Admin1 Name' ;
    rdfs:comment 'Name of the first-level administrative division (province, state, governorate) where the community is located. Human-readable complement to admin1_code.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admin2Code rdf:type rdf:Property ;
    rdfs:label 'Admin2 Code' ;
    rdfs:comment 'Second-level administrative division code (district, county, department) where the community is located. Aligns with OCHA COD-AB P-codes for standardized geographic reporting.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admin2Name rdf:type rdf:Property ;
    rdfs:label 'Admin2 Name' ;
    rdfs:comment 'Name of the second-level administrative division (district, county, department) where the community is located. Human-readable complement to admin2_code.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admin3Code rdf:type rdf:Property ;
    rdfs:label 'Admin3 Code' ;
    rdfs:comment 'Third-level administrative division code (sub-district, municipality) where the community is located. Aligns with OCHA COD-AB P-codes where available.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admin3Name rdf:type rdf:Property ;
    rdfs:label 'Admin3 Name' ;
    rdfs:comment 'Name of the third-level administrative division (sub-district, municipality) where the community is located. Human-readable complement to admin3_code.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admin4Code rdf:type rdf:Property ;
    rdfs:label 'Admin4 Code' ;
    rdfs:comment 'Fourth-level administrative division code (village, neighborhood, locality) where the community is located. Aligns with OCHA COD-AB P-codes where available.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admin4Name rdf:type rdf:Property ;
    rdfs:label 'Admin4 Name' ;
    rdfs:comment 'Name of the fourth-level administrative division (village, neighborhood, locality) where the community is located. Human-readable complement to admin4_code.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communityCode rdf:type rdf:Property ;
    rdfs:label 'Community Code' ;
    rdfs:comment 'Externally-known unique business identifier or code for the community, used in field operations, 3W (Who does What Where) reporting, and inter-agency coordination. May align with OCHA P-codes or agency-specific community identifiers.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communityName rdf:type rdf:Property ;
    rdfs:label 'Community Name' ;
    rdfs:comment 'Official or commonly-used name of the community, settlement, camp, or geographic area. This is the primary human-readable identifier used in field reports, SitReps (Situation Reports), and beneficiary communications.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communityStatus rdf:type rdf:Property ;
    rdfs:label 'Community Status' ;
    rdfs:comment 'Current lifecycle status of the community registration. Active: community is currently served by programs. Inactive: temporarily not served. Closed: community no longer exists or is no longer a target. Planned: community identified for future programming. Suspended: operations temporarily halted due to access constraints or security incidents.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Flag' ;
    rdfs:comment 'Indicates whether informed consent was obtained from community leadership or representatives for data collection, program implementation, and data sharing. True if consent obtained, False otherwise. Supports CHS (Core Humanitarian Standard) accountability commitments and GDPR compliance where applicable.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Flag' ;
    rdfs:comment 'Indicates whether the community has consented to sharing of community-level data with partner organizations, clusters, or coordination bodies. True if data sharing permitted, False otherwise. Supports inter-agency coordination while respecting community preferences.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displacementStatus rdf:type rdf:Property ;
    rdfs:label 'Displacement Status' ;
    rdfs:comment 'Classification of the community based on displacement dynamics. Host community: existing community hosting displaced populations. IDP settlement: community primarily composed of Internally Displaced Persons. Refugee camp: formal refugee settlement. Returnee community: community of returned displaced persons. Mixed: combination of host and displaced populations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedPopulation rdf:type rdf:Property ;
    rdfs:label 'Estimated Population' ;
    rdfs:comment 'Estimated total number of individuals residing in or associated with the community. This is the principal quantitative measurement for the community resource, used for needs calculations, resource allocation, and coverage reporting.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gbvRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Gbv Risk Level' ;
    rdfs:comment 'Assessment of GBV risk level in the community based on safety audits, incident reports, and vulnerability indicators. Used for GBV prevention programming, safe space establishment, and referral pathway planning.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Gps Accuracy Meters' ;
    rdfs:comment 'Accuracy of the GPS coordinates in meters. Indicates the precision of the latitude and longitude measurements, important for field data quality assessment and spatial analysis reliability.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthFacilityDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Health Facility Distance Km' ;
    rdfs:comment 'Distance in kilometers from the community to the nearest functional health facility. Used for health access analysis, referral planning, and mobile health outreach prioritization.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdCount rdf:type rdf:Property ;
    rdfs:label 'Household Count' ;
    rdfs:comment 'Estimated or verified number of households within the community. Used for household-level targeting and distribution planning in WASH, shelter, and NFI (Non-Food Item) programs.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipcPhase rdf:type rdf:Property ;
    rdfs:label 'Ipc Phase' ;
    rdfs:comment 'IPC acute food insecurity phase classification for the community. Phase 1: Minimal/None. Phase 2: Stressed. Phase 3: Crisis. Phase 4: Emergency. Phase 5: Catastrophe/Famine. Used for food security targeting and early warning.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'Date of the most recent needs assessment or monitoring visit conducted in the community. Used to track data currency and schedule follow-up assessments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaderContact rdf:type rdf:Property ;
    rdfs:label 'Leader Contact' ;
    rdfs:comment 'Primary contact information (phone number or other communication channel) for the community leader or representative. Used for coordination, consultation, and feedback mechanisms. Classified as confidential PII.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaderName rdf:type rdf:Property ;
    rdfs:label 'Leader Name' ;
    rdfs:comment 'Name of the primary community leader, elder, or representative. Used for community engagement, consultation, and accountability mechanisms. Classified as confidential to protect community leadership in sensitive contexts.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Primary Language Code' ;
    rdfs:comment 'ISO 639-3 three-letter code for the primary language spoken in the community. Used for communication planning, translation needs, and culturally appropriate programming.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionConcernFlag rdf:type rdf:Property ;
    rdfs:label 'Protection Concern Flag' ;
    rdfs:comment 'Indicates whether the community has been flagged for protection concerns such as GBV (Gender-Based Violence) risk, child protection issues, or other safety and security threats. True if protection concerns exist, False otherwise. Used for protection mainstreaming and specialized protection interventions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date when the community was first registered in the system as a collective beneficiary unit for area-based programming. This is the principal business event timestamp for the community entity.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationSource rdf:type rdf:Property ;
    rdfs:label 'Registration Source' ;
    rdfs:comment 'Source system or tool used to register the community (e.g., KoboToolbox, CommCare, DHIS2, manual field assessment). Used for data lineage tracking and quality assessment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanitationCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Sanitation Coverage Percent' ;
    rdfs:comment 'Percentage of households in the community with access to adequate sanitation facilities (latrines, toilets) meeting Sphere minimum standards (1 toilet per 20 people). Used for WASH gap analysis and intervention planning.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementType rdf:type rdf:Property ;
    rdfs:label 'Settlement Type' ;
    rdfs:comment 'Classification of the community or settlement type. Formal camp: officially designated refugee or IDP (Internally Displaced Person) camp. Informal settlement: spontaneous or unplanned settlement. Host community: existing community hosting displaced populations. Collective center: shared facility (school, warehouse) used for temporary shelter. Transit site: temporary waypoint for displaced populations. Urban area: city or town neighborhood.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerabilityCategory rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Category' ;
    rdfs:comment 'Categorical classification of community vulnerability level derived from vulnerability_score. Critical: immediate life-saving assistance required. High: urgent multi-sectoral needs. Medium: moderate needs requiring monitoring. Low: stable with minimal humanitarian needs. Used for targeting and resource allocation decisions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Water Access Flag' ;
    rdfs:comment 'Indicates whether the community has adequate access to safe water sources according to Sphere minimum standards (15 liters per person per day within 500 meters). True if adequate access exists, False otherwise. Used for WASH (Water Sanitation and Hygiene) needs prioritization.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'Unique system-generated identifier for each consent record. Primary key for the consent_record data product within the beneficiary domain.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryConsentStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Consent Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or field worker who witnessed the consent process. Links to the workforce staff_member record for accountability and audit trail purposes.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:biometricEnrollmentPermitted rdf:type rdf:Property ;
    rdfs:label 'Biometric Enrollment Permitted' ;
    rdfs:comment 'Indicates whether the beneficiary has consented to biometric data enrollment (fingerprint, iris scan, facial recognition) for identity verification and deduplication purposes. True = biometric enrollment permitted; False = not permitted.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chsComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Chs Compliance Flag' ;
    rdfs:comment 'Indicates whether this consent record meets all requirements of the Core Humanitarian Standard (CHS) Commitment 4 on accountability to affected populations. True = CHS compliant; False = non-compliant or pending review. Used in CHS certification audits.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Collection Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the country where consent was collected (e.g., \'SOM\' for Somalia, \'SSD\' for South Sudan). Supports multi-country program reporting and regulatory compliance.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionLocation rdf:type rdf:Property ;
    rdfs:label 'Collection Location' ;
    rdfs:comment 'Name or description of the physical location where consent was collected (e.g., registration site name, health facility, IDP camp name, community center). Supports geographic analysis and field operations reporting.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentFormVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Form Version' ;
    rdfs:comment 'Version identifier of the consent form template used at the time of consent collection (e.g., v1.0, v2.3). Enables tracking of which version of the consent language and terms the beneficiary agreed to, critical for compliance audits.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLanguage rdf:type rdf:Property ;
    rdfs:label 'Consent Language' ;
    rdfs:comment 'ISO 639-1 or ISO 639-3 language code representing the language in which consent was communicated and obtained. Ensures accountability that consent was given in the beneficiary\'s understood language (e.g., \'ar\' for Arabic, \'fr\' for French, \'so\' for Somali). Critical for CHS accountability compliance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Consent Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference code assigned to this consent record, used in field operations, case referrals, and compliance reporting. Format: CNS-[COUNTRY]-[YEAR]-[SEQUENCE].' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle status of the consent record. \'given\' indicates active informed consent; \'withdrawn\' indicates the beneficiary has revoked consent; \'pending\' indicates consent is awaited; \'expired\' indicates the consent period has lapsed; \'refused\' indicates explicit refusal.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataScope rdf:type rdf:Property ;
    rdfs:label 'Data Scope' ;
    rdfs:comment 'Description of the specific data elements, activities, or purposes covered by this consent record (e.g., \'collection and storage of household survey data\', \'sharing of case data with UNHCR for referral\'). Defines the boundaries of what the beneficiary has consented to.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureReference rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Reference' ;
    rdfs:comment 'Reference identifier or hash of the digital signature captured when consent_method is \'digital\'. Links to the secure digital signature storage system. Not the signature itself — a reference token for audit trail purposes.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'The date from which the consent becomes legally and operationally binding. May differ from consent_date if there is a processing delay or a future-dated consent arrangement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formAttachmentReference rdf:type rdf:Property ;
    rdfs:label 'Form Attachment Reference' ;
    rdfs:comment 'File path, URL, or document management system reference to the scanned or digital copy of the signed consent form. Enables retrieval of the original consent document for audit and legal purposes.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether the EU General Data Protection Regulation (GDPR) applies to this consent record based on the beneficiary\'s location, the organization\'s jurisdiction, or the data controller\'s domicile. True = GDPR applies; False = GDPR does not apply.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:informedConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Verified' ;
    rdfs:comment 'Indicates whether a supervisor or quality assurance officer has verified that the consent was truly informed (i.e., the beneficiary understood the purpose, scope, and their rights before consenting). True = verified; False = pending verification.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProxyConsent rdf:type rdf:Property ;
    rdfs:label 'Is Proxy Consent' ;
    rdfs:comment 'Indicates whether consent was given by a proxy (guardian, parent, or authorized representative) on behalf of a minor, elderly, or incapacitated beneficiary. True = proxy consent; False = direct consent from the beneficiary.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photographyPermitted rdf:type rdf:Property ;
    rdfs:label 'Photography Permitted' ;
    rdfs:comment 'Indicates whether the beneficiary has consented to being photographed or filmed for organizational communications, donor reporting, or advocacy purposes. True = photography/media use permitted; False = not permitted.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proxyName rdf:type rdf:Property ;
    rdfs:label 'Proxy Name' ;
    rdfs:comment 'Full name of the proxy individual (guardian, parent, or authorized representative) who provided consent on behalf of the beneficiary. Populated only when is_proxy_consent is True.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proxyRelationship rdf:type rdf:Property ;
    rdfs:label 'Proxy Relationship' ;
    rdfs:comment 'The relationship of the proxy consent giver to the beneficiary (e.g., parent, guardian, legal representative). Populated only when is_proxy_consent is True. [ENUM-REF-CANDIDATE: parent|guardian|spouse|sibling|community_leader|legal_representative|other — promote to reference product]' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sharingPermitted rdf:type rdf:Property ;
    rdfs:label 'Sharing Permitted' ;
    rdfs:comment 'Indicates whether the beneficiary has consented to their data being shared with third-party organizations (e.g., partner NGOs, UN agencies, government bodies). True = sharing permitted; False = sharing not permitted. Critical for inter-agency data sharing compliance.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sharingRestrictions rdf:type rdf:Property ;
    rdfs:label 'Sharing Restrictions' ;
    rdfs:comment 'Free-text description of any specific restrictions or conditions placed by the beneficiary on data sharing (e.g., \'not to be shared with government authorities\', \'only for health program purposes\'). Populated when sharing_permitted is True but with conditions.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'The date on which the beneficiary formally withdrew their previously given consent. Populated only when consent_status is \'withdrawn\'. Triggers downstream data deletion or anonymization workflows per GDPR right to erasure.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Free-text description of the reason provided by the beneficiary or their representative for withdrawing consent. Populated only when consent_status is \'withdrawn\'. Used for accountability reporting and program improvement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessName rdf:type rdf:Property ;
    rdfs:label 'Witness Name' ;
    rdfs:comment 'Full name of the field staff member or community witness who witnessed the consent process. Required for verbal and thumbprint consent methods to ensure accountability and legal validity.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displacementHistoryId rdf:type rdf:Property ;
    rdfs:label 'Displacement History Id' ;
    rdfs:comment 'Unique identifier for each displacement episode record. Primary key for the displacement history tracking system.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentAdmin1Code rdf:type rdf:Property ;
    rdfs:label 'Current Admin1 Code' ;
    rdfs:comment 'First-level administrative division code of current displacement location. Supports sub-national operational planning and resource allocation.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentAdmin2Code rdf:type rdf:Property ;
    rdfs:label 'Current Admin2 Code' ;
    rdfs:comment 'Second-level administrative division code of current displacement location. Enables district-level service delivery planning.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCountryCode rdf:type rdf:Property ;
    rdfs:label 'Current Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the current displacement location. Used for asylum country statistics and cross-border displacement tracking.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentLatitude rdf:type rdf:Property ;
    rdfs:label 'Current Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the current displacement location. Enables real-time displacement mapping and proximity analysis to services.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentLongitude rdf:type rdf:Property ;
    rdfs:label 'Current Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the current displacement location. Enables real-time displacement mapping and proximity analysis to services.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentSettlementName rdf:type rdf:Property ;
    rdfs:label 'Current Settlement Name' ;
    rdfs:comment 'Name of the camp, collective center, or settlement where the beneficiary currently resides. Links to site-level service provision and infrastructure data.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentSettlementType rdf:type rdf:Property ;
    rdfs:label 'Current Settlement Type' ;
    rdfs:comment 'Type of settlement where the displaced person currently resides. Determines applicable assistance modalities and service delivery approaches.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Data Collection Date' ;
    rdfs:comment 'Date when this displacement history record was collected in the field. Distinct from displacement date; used for data currency assessment.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataCollectionTool rdf:type rdf:Property ;
    rdfs:label 'Data Collection Tool' ;
    rdfs:comment 'Digital or manual tool used to collect this displacement history record. Supports data quality assessment and system interoperability.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displacementDate rdf:type rdf:Property ;
    rdfs:label 'Displacement Date' ;
    rdfs:comment 'Date when the beneficiary was displaced from their origin location. Key timestamp for calculating displacement duration and eligibility for time-bound assistance programs.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:displacementDurationDays rdf:type rdf:Property ;
    rdfs:label 'Displacement Duration Days' ;
    rdfs:comment 'Number of days since the displacement date. Calculated field used to classify protracted vs. acute displacement and determine eligibility for durable solutions programs.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displacementEpisodeNumber rdf:type rdf:Property ;
    rdfs:label 'Displacement Episode Number' ;
    rdfs:comment 'Sequential number of this displacement episode for the registrant. Enables tracking of multiple displacement events over time (1st displacement, 2nd displacement, etc.).' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displacementTrigger rdf:type rdf:Property ;
    rdfs:label 'Displacement Trigger' ;
    rdfs:comment 'Primary cause or trigger event that forced the displacement. Critical for root cause analysis, advocacy, and targeted intervention design.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displacementVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Displacement Verification Status' ;
    rdfs:comment 'Status of field verification of the displacement claim. Verified status is required for eligibility determination in most assistance programs.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdxDatasetReference rdf:type rdf:Property ;
    rdfs:label 'Hdx Dataset Reference' ;
    rdfs:comment 'Reference to the OCHA HDX dataset from which this displacement record was sourced or to which it was contributed. Supports open data sharing and interoperability.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCrossBorder rdf:type rdf:Property ;
    rdfs:label 'Is Cross Border' ;
    rdfs:comment 'Flag indicating whether the displacement crossed an international border (refugee) or remained within the country of origin (IDP). Determines applicable legal frameworks and assistance mandates.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProtracted rdf:type rdf:Property ;
    rdfs:label 'Is Protracted' ;
    rdfs:comment 'Flag indicating whether the displacement has lasted 5 or more years, meeting UNHCR definition of protracted displacement. Triggers eligibility for long-term development programming.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Local Integration Status' ;
    rdfs:comment 'Status of local integration as a durable solution. Tracks progress toward legal, economic, and social integration in the host community.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originAdmin1Code rdf:type rdf:Property ;
    rdfs:label 'Origin Admin1 Code' ;
    rdfs:comment 'First-level administrative division code (state/province/region) of origin location. Enables sub-national displacement pattern analysis.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originAdmin2Code rdf:type rdf:Property ;
    rdfs:label 'Origin Admin2 Code' ;
    rdfs:comment 'Second-level administrative division code (district/county) of origin location. Provides granular displacement origin tracking for targeted return programming.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country from which the beneficiary was displaced. Used for population statistics and country-of-origin analysis.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLatitude rdf:type rdf:Property ;
    rdfs:label 'Origin Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the origin location. Enables GIS mapping of displacement flows and spatial analysis.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originLongitude rdf:type rdf:Property ;
    rdfs:label 'Origin Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the origin location. Enables GIS mapping of displacement flows and spatial analysis.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originSettlementName rdf:type rdf:Property ;
    rdfs:label 'Origin Settlement Name' ;
    rdfs:comment 'Name of the village, town, or settlement from which the beneficiary was displaced. Supports community-level return and reintegration planning.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pocCategory rdf:type rdf:Property ;
    rdfs:label 'Poc Category' ;
    rdfs:comment 'UNHCR Person of Concern category classification. Determines eligibility for specific protection and assistance programs.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this displacement history record was first created in the lakehouse. System audit field for data lineage.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this displacement history record was last updated in the lakehouse. System audit field for change tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resettlementCountryCode rdf:type rdf:Property ;
    rdfs:label 'Resettlement Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the third country to which the beneficiary was resettled, if applicable. Null for non-resettlement cases.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resettlementDate rdf:type rdf:Property ;
    rdfs:label 'Resettlement Date' ;
    rdfs:comment 'Date when the beneficiary was resettled to a third country. Null for non-resettlement cases. Marks the end of the displacement episode.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Date when the beneficiary returned to their origin location, if applicable. Null for ongoing displacement. Used to calculate return rates and monitor return sustainability.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnIntention rdf:type rdf:Property ;
    rdfs:label 'Return Intention' ;
    rdfs:comment 'Beneficiary stated intention regarding return to origin location. Informs durable solutions planning and return program design.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnType rdf:type rdf:Property ;
    rdfs:label 'Return Type' ;
    rdfs:comment 'Classification of the return modality. Voluntary return is the preferred durable solution per international humanitarian standards.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'Unique identifier of this record in the originating operational system (proGres, DTM, KoboToolbox). Enables traceability and data lineage tracking.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitLocations rdf:type rdf:Property ;
    rdfs:label 'Transit Locations' ;
    rdfs:comment 'Comma-separated list of intermediate locations or waypoints during the displacement journey. Documents the full displacement route for protection risk analysis.' ;
    rdfs:domain ind:DisplacementHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify the displacement episode. Field visit and document review are considered most reliable.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRecordId rdf:type rdf:Property ;
    rdfs:label 'Document Record Id' ;
    rdfs:comment 'Unique identifier for the document record. Primary key for the document_record product.' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDocumentUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Document User Account Id' ;
    rdfs:comment 'Reference to the user or staff member who created this document record in the system. Supports accountability and audit trail.' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:captureDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Capture Device Code' ;
    rdfs:comment 'Unique identifier of the mobile device, scanner, or workstation used to capture the document. Supports audit trail and data quality tracking.' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level indicating the sensitivity of the document and the access controls required. Aligns with organizational data governance policies.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Boolean flag indicating whether the beneficiary consented to sharing this document with partner organizations or coordination bodies. True if sharing consent was obtained.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentCondition rdf:type rdf:Property ;
    rdfs:label 'Document Condition' ;
    rdfs:comment 'Physical condition of the document at the time of registration or verification. Impacts reliability for identity verification.' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentImageReference rdf:type rdf:Property ;
    rdfs:label 'Document Image Reference' ;
    rdfs:comment 'File path, URL, or storage reference to the scanned or photographed image of the document. Used for audit and verification purposes.' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Document Language Code' ;
    rdfs:comment 'ISO 639-1 or ISO 639-2 language code indicating the primary language in which the document is written.' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The unique alphanumeric identifier printed on the document by the issuing authority. Used for identity verification and legal status determination.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the identity or legal document. Common types include UNHCR registration certificates, national ID cards, birth certificates, marriage certificates, asylum seeker cards, and travel documents.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'Identifier used by external systems, partner organizations, or coordination platforms (e.g., UNHCR proGres ID, OCHA reference number) to cross-reference this document.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryIdentityDocument rdf:type rdf:Property ;
    rdfs:label 'Is Primary Identity Document' ;
    rdfs:comment 'Boolean flag indicating whether this document is the primary identity document for the beneficiary. True if this is the main document used for identity verification.' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which the document was officially issued by the authority. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'The government agency, international organization, or official body that issued the document (e.g., Ministry of Interior, UNHCR, National Registration Bureau).' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the country or territory where the document was issued.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalStatusIndicator rdf:type rdf:Property ;
    rdfs:label 'Legal Status Indicator' ;
    rdfs:comment 'The legal status of the beneficiary as evidenced by this document. Supports protection case management and eligibility determination for humanitarian assistance. [ENUM-REF-CANDIDATE: refugee|asylum_seeker|idp|stateless|citizen|resident|undocumented — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DocumentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Registration Location Code' ;
    rdfs:comment 'Code or identifier of the field location, camp, or registration center where the document was recorded into the system.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'The number of days for which this document record must be retained according to organizational policy, donor requirements, or legal obligations. After this period, the record may be archived or deleted.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exitRecordId rdf:type rdf:Property ;
    rdfs:label 'Exit Record Id' ;
    rdfs:comment 'Unique identifier for the beneficiary exit record. Primary key for the exit_record product.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:householdId rdf:type rdf:Property ;
    rdfs:label 'Household Id' ;
    rdfs:comment 'Reference to the household unit to which the exiting beneficiary belonged at time of exit. Used for household-level impact analysis and to track whether entire household exited or only individual members.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:primaryExitRegistrantId rdf:type rdf:Property ;
    rdfs:label 'Primary Exit Registrant Id' ;
    rdfs:comment 'Reference to the beneficiary who is exiting the registry. Links to the registrant product in the beneficiary domain.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registrant .

ind:primaryExitStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Exit Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who processed and approved the beneficiary exit. Links to the staff_member product in the workforce domain for accountability and audit purposes.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:dataDeletionScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Data Deletion Scheduled Date' ;
    rdfs:comment 'Calculated date when beneficiary data is scheduled for deletion or anonymization based on exit date and retention period. Used by data governance processes to enforce retention policies.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataRetentionClassification rdf:type rdf:Property ;
    rdfs:label 'Data Retention Classification' ;
    rdfs:comment 'Classification determining how beneficiary data should be handled post-exit per data minimization and privacy requirements. Retain full means keep all data for ongoing monitoring; retain anonymized means remove PII but keep aggregated data; archive means move to long-term storage; delete means purge per right to be forgotten.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Months' ;
    rdfs:comment 'Number of months that beneficiary data will be retained post-exit before archival or deletion. Determined by donor requirements, legal obligations, and organizational data retention policies.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deathCertificateVerified rdf:type rdf:Property ;
    rdfs:label 'Death Certificate Verified' ;
    rdfs:comment 'Boolean flag indicating whether a death certificate or official mortality documentation was verified for exits due to death. Required for audit and fraud prevention.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deathDate rdf:type rdf:Property ;
    rdfs:label 'Death Date' ;
    rdfs:comment 'Date of death as documented in official records or reported by family members. Populated only for exits with exit_reason_category of death.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitAssessmentConducted rdf:type rdf:Property ;
    rdfs:label 'Exit Assessment Conducted' ;
    rdfs:comment 'Boolean flag indicating whether a formal exit assessment or interview was conducted with the beneficiary prior to exit. Required for program graduation and voluntary withdrawal cases per Core Humanitarian Standard (CHS) accountability requirements.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exitAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Exit Assessment Date' ;
    rdfs:comment 'Date when the exit assessment or final interview was conducted with the beneficiary. Used for Monitoring Evaluation and Learning (MEL) tracking and accountability reporting.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitAssessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Exit Assessment Notes' ;
    rdfs:comment 'Detailed notes and observations from the exit assessment interview. Captures beneficiary feedback, lessons learned, and recommendations for program improvement per Monitoring Evaluation Accountability and Learning (MEAL) requirements.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitAssessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Exit Assessment Outcome' ;
    rdfs:comment 'Overall outcome classification from the exit assessment. Positive indicates beneficiary achieved program objectives; neutral indicates partial achievement; negative indicates unmet objectives; not applicable for exits without assessment (death, loss of contact).' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitConsentDate rdf:type rdf:Property ;
    rdfs:label 'Exit Consent Date' ;
    rdfs:comment 'Date when beneficiary consent for exit was obtained. Used for legal compliance and audit trail of consent management.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitConsentMethod rdf:type rdf:Property ;
    rdfs:label 'Exit Consent Method' ;
    rdfs:comment 'Method by which exit consent was obtained from the beneficiary. Verbal for in-person oral consent; written for signed paper forms; digital for electronic signature; proxy for consent obtained through authorized representative.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitConsentObtained rdf:type rdf:Property ;
    rdfs:label 'Exit Consent Obtained' ;
    rdfs:comment 'Boolean flag indicating whether explicit consent was obtained from the beneficiary for the exit and associated data handling. Required for voluntary withdrawals and data deletion per GDPR and CHS standards.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exitDate rdf:type rdf:Property ;
    rdfs:label 'Exit Date' ;
    rdfs:comment 'The date on which the beneficiary formally exited the beneficiary registry. Represents the effective date of deactivation from active registrant status.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitFacilityName rdf:type rdf:Property ;
    rdfs:label 'Exit Facility Name' ;
    rdfs:comment 'Name of the field office, distribution center, or facility where the exit was processed. Used for operational tracking and geographic analysis of exit patterns.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitLocationCode rdf:type rdf:Property ;
    rdfs:label 'Exit Location Code' ;
    rdfs:comment 'Three-letter code representing the geographic location where the exit was processed. Follows ISO 3166-1 alpha-3 country code standard or internal location coding scheme.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitNumber rdf:type rdf:Property ;
    rdfs:label 'Exit Number' ;
    rdfs:comment 'Human-readable business identifier for the exit record, formatted as EXT- followed by 8 digits. Used for tracking and reference in case management systems.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Exit Reason Category' ;
    rdfs:comment 'Primary category describing why the beneficiary is exiting the registry. Program graduation indicates successful completion of assistance; voluntary withdrawal is beneficiary-initiated; relocation means moved out of service area; death is confirmed mortality; loss of contact means unable to reach beneficiary; loss of eligibility means no longer meets program criteria.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Exit Reason Detail' ;
    rdfs:comment 'Detailed narrative explanation of the specific circumstances surrounding the beneficiary exit. Provides context beyond the category for case management and Monitoring Evaluation and Learning (MEL) purposes.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitStatus rdf:type rdf:Property ;
    rdfs:label 'Exit Status' ;
    rdfs:comment 'Current workflow status of the exit record. Pending indicates awaiting supervisor approval; approved means exit authorized but not yet finalized; completed means exit fully processed and beneficiary deactivated; reversed means exit was cancelled and beneficiary reactivated.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exit Timestamp' ;
    rdfs:comment 'Precise timestamp when the exit record was created in the system, capturing the exact moment of registry deactivation.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isDuplicateMerge rdf:type rdf:Property ;
    rdfs:label 'Is Duplicate Merge' ;
    rdfs:comment 'Boolean flag indicating whether this exit was triggered by a duplicate record merge operation. True means this record was identified as a duplicate and merged into another master record; false means exit was for other reasons.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postExitFollowupDate rdf:type rdf:Property ;
    rdfs:label 'Post Exit Followup Date' ;
    rdfs:comment 'Scheduled date for the next post-exit follow-up contact or assessment. Used to track ongoing monitoring obligations for graduated beneficiaries.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postExitFollowupPlan rdf:type rdf:Property ;
    rdfs:label 'Post Exit Followup Plan' ;
    rdfs:comment 'Detailed plan for post-exit monitoring activities including timeline, methods, and Key Performance Indicators (KPIs) to be tracked. Used for Post-Distribution Monitoring (PDM) and impact assessment.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postExitFollowupRequired rdf:type rdf:Property ;
    rdfs:label 'Post Exit Followup Required' ;
    rdfs:comment 'Boolean flag indicating whether post-exit follow-up monitoring is required for this beneficiary. Typically true for program graduation cases to assess sustainability of outcomes per Results-Based Management (RBM) frameworks.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reactivationConditions rdf:type rdf:Property ;
    rdfs:label 'Reactivation Conditions' ;
    rdfs:comment 'Description of the conditions or criteria under which the beneficiary could be reactivated in the registry. Used for case management decision-making if beneficiary returns to service area.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactivationEligible rdf:type rdf:Property ;
    rdfs:label 'Reactivation Eligible' ;
    rdfs:comment 'Boolean flag indicating whether the beneficiary is eligible for reactivation in the registry if circumstances change. True for voluntary withdrawals and relocations; false for deaths and duplicate merges.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Referral Organization Name' ;
    rdfs:comment 'Name of the organization or service provider to which the beneficiary was referred at exit. Supports coordination and continuity of care in the humanitarian ecosystem.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralProvided rdf:type rdf:Property ;
    rdfs:label 'Referral Provided' ;
    rdfs:comment 'Boolean flag indicating whether the beneficiary was provided with referrals to other services or organizations at exit. Part of responsible exit protocol per Core Humanitarian Standard (CHS) commitment to do no harm.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralServiceType rdf:type rdf:Property ;
    rdfs:label 'Referral Service Type' ;
    rdfs:comment 'Type of service or assistance the beneficiary was referred to (e.g., health, education, livelihood, protection, legal aid). Enables tracking of referral pathways and inter-agency collaboration. [ENUM-REF-CANDIDATE: health|education|livelihood|protection|legal_aid|psychosocial_support|shelter|wash|nutrition — promote to reference product]' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relocationDestinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Relocation Destination Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country to which the beneficiary relocated. Populated for exits due to relocation out of service area.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relocationDestinationLocation rdf:type rdf:Property ;
    rdfs:label 'Relocation Destination Location' ;
    rdfs:comment 'Detailed location information (city, district, camp name) where the beneficiary relocated. Used for potential referrals and inter-agency coordination.' ;
    rdfs:domain ind:ExitRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningId rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Id' ;
    rdfs:comment 'Foreign key linking to compliance.sanctions_screening. Business justification: Household-level sanctions screening is standard practice for family-based assistance programs. Required by major donors (USAID, DFID, EU) to ensure no assistance reaches sanctioned entities or individ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsScreening .

ind:warehouseId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Id' ;
    rdfs:comment 'Foreign key linking to supply.warehouse. Business justification: Households are assigned to specific warehouses/distribution points for assistance collection based on geographic proximity. Essential for last-mile distribution planning, beneficiary mobilization, and' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:childrenUnder5Count rdf:type rdf:Property ;
    rdfs:label 'Children Under5 Count' ;
    rdfs:comment 'Number of children aged 0–4 years in the household. Critical for nutrition programme targeting (Global Acute Malnutrition / Severe Acute Malnutrition screening), UNICEF child protection reporting, and SPHERE minimum standards for child-specific NFI distributions.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the household\'s country of origin or habitual residence prior to displacement. Required for UNHCR refugee population statistics, OCHA Humanitarian Response Plan disaggregation, and IATI geographic coding.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCountry rdf:type rdf:Property ;
    rdfs:label 'Current Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the household is currently residing. Used for cross-border programme coordination, OCHA SitRep geographic disaggregation, and IATI location reporting.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deregistrationDate rdf:type rdf:Property ;
    rdfs:label 'Deregistration Date' ;
    rdfs:comment 'Calendar date on which the household exited or was closed from the programme. Nullable for active households. Used to calculate programme duration, exit analysis, and MEL outcome tracking. Corresponds to the effective-until date of the household registration agreement.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:elderlyCount rdf:type rdf:Property ;
    rdfs:label 'Elderly Count' ;
    rdfs:comment 'Number of household members aged 60 years or older. Used for vulnerability scoring, priority targeting in food security and health programmes, and age-disaggregated donor reporting per OCHA and IASC standards.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exitReason rdf:type rdf:Property ;
    rdfs:label 'Exit Reason' ;
    rdfs:comment 'Reason for the household\'s exit or closure from the programme. Used for MEL outcome analysis, durable solutions tracking, and donor reporting on programme completion rates. Nullable for active households. [ENUM-REF-CANDIDATE: graduated|relocated|deceased|voluntary_withdrawal|ineligible|duplicate|lost_to_followup — promote to reference product]' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:femaleCount rdf:type rdf:Property ;
    rdfs:label 'Female Count' ;
    rdfs:comment 'Number of female individuals in the household. Required for sex-disaggregated reporting to OCHA, USAID, and DFID donors. Supports gender analysis in MEL frameworks and IASC gender marker compliance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:foodSecurityStatus rdf:type rdf:Property ;
    rdfs:label 'Food Security Status' ;
    rdfs:comment 'Household-level food security classification based on the Integrated Food Security Phase Classification (IPC) or Household Food Insecurity Access Scale (HFIAS). Drives WFP food assistance targeting, cash transfer programme eligibility, and OCHA food security cluster reporting.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gbvRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Gbv Risk Flag' ;
    rdfs:comment 'Indicates whether the household has been identified as at elevated risk of or affected by Gender-Based Violence (GBV). Classified restricted due to sensitivity. Triggers referral to GBV case management, PSS (Psychosocial Support) services, and safe space programming. Access strictly controlled per GBV information management protocols.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the household\'s physical location in decimal degrees (WGS84). Captured via KoboToolbox GPS widget during field registration. Used for GIS mapping, proximity analysis, and Humanitarian OpenStreetMap integration. Classified confidential as precise location of vulnerable individuals.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the household\'s physical location in decimal degrees (WGS84). Captured via KoboToolbox GPS widget during field registration. Used for GIS mapping, proximity analysis, and Humanitarian OpenStreetMap integration. Classified confidential as precise location of vulnerable individuals.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hasPregnantLactating rdf:type rdf:Property ;
    rdfs:label 'Has Pregnant Lactating' ;
    rdfs:comment 'Indicates whether the household includes at least one pregnant or lactating woman (PLW). Critical flag for nutrition programme targeting (supplementary feeding, micronutrient supplementation), SPHERE nutrition standards compliance, and UNICEF/WFP PLW-specific assistance eligibility.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasUnaccompaniedMinor rdf:type rdf:Property ;
    rdfs:label 'Has Unaccompanied Minor' ;
    rdfs:comment 'Indicates whether the household includes an unaccompanied or separated child (UASC). Triggers child protection case management protocols in CommCare, UNHCR UASC registration procedures, and UNICEF child protection programme referrals.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFemaleHeaded rdf:type rdf:Property ;
    rdfs:label 'Is Female Headed' ;
    rdfs:comment 'Indicates whether the household is headed by a woman. Key targeting criterion for GBV (Gender-Based Violence) prevention programmes, women\'s economic empowerment initiatives, and IASC gender marker reporting. Required for USAID gender equality disaggregation.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:koboSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Kobo Submission Reference' ;
    rdfs:comment 'Unique identifier of the KoboToolbox form submission that created or last updated this household record. Enables traceability back to the original field data collection form for data quality audits, MEAL verification, and source system reconciliation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maleCount rdf:type rdf:Property ;
    rdfs:label 'Male Count' ;
    rdfs:comment 'Number of male individuals in the household. Required for sex-disaggregated reporting to OCHA, USAID, and DFID donors. Supports gender analysis in MEL frameworks and IASC gender marker compliance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pwdCount rdf:type rdf:Property ;
    rdfs:label 'Pwd Count' ;
    rdfs:comment 'Number of household members with a physical, sensory, intellectual, or psychosocial disability. Required for IASC disability inclusion reporting, Washington Group Short Set disaggregation, and inclusive programming compliance under the CRPD.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the household at point of registration. Used across field operations, NFI distribution lists, WASH assessments, and food security programming as the primary cross-system reference. Corresponds to the SCOPE household token or proGres case number.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle state of the household registration. Active indicates the household is enrolled and eligible for services. Suspended indicates a temporary hold pending verification. Closed indicates the household has exited programming. Drives eligibility checks in CommCare and Microsoft Dynamics 365 case management.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationType rdf:type rdf:Property ;
    rdfs:label 'Registration Type' ;
    rdfs:comment 'Classification of the registration event that created or last updated this household record. Distinguishes initial intake from periodic re-verification exercises required by UNHCR and WFP programme cycles.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanitationFacilityType rdf:type rdf:Property ;
    rdfs:label 'Sanitation Facility Type' ;
    rdfs:comment 'Classification of the household\'s primary sanitation facility. Core WASH indicator for SPHERE minimum standards, OCHA WASH cluster reporting, and WHO/UNICEF Joint Monitoring Programme (JMP) SDG 6 tracking. [ENUM-REF-CANDIDATE: flush_toilet|pit_latrine|ventilated_pit|open_defecation|communal_latrine|none — promote to reference product]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelterOwnership rdf:type rdf:Property ;
    rdfs:label 'Shelter Ownership' ;
    rdfs:comment 'Tenure status of the household\'s current shelter. Distinguishes owned, rented, informal/squatter, organisation-provided, or communal arrangements. Used for durable solutions planning, land rights programming, and UNHCR shelter vulnerability assessments.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelterType rdf:type rdf:Property ;
    rdfs:label 'Shelter Type' ;
    rdfs:comment 'Classification of the household\'s current shelter situation. Used for SPHERE shelter standard compliance assessments, NFI kit targeting (shelter kits vs. core relief items), and OCHA shelter cluster reporting. [ENUM-REF-CANDIDATE: permanent|semi-permanent|temporary|makeshift|collective_centre|host_family|none — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Total count of individuals residing in the household at the time of last registration or update. Used for NFI distribution quantity calculations, food ration sizing, WASH facility planning, and WFP SCOPE entitlement computation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waterSourceType rdf:type rdf:Property ;
    rdfs:label 'Water Source Type' ;
    rdfs:comment 'Classification of the household\'s primary drinking water source. Core WASH (Water, Sanitation and Hygiene) indicator required for SPHERE minimum standards compliance, OCHA WASH cluster reporting, and DHIS2 WASH indicator tracking. [ENUM-REF-CANDIDATE: piped|borehole|protected_spring|unprotected_spring|surface_water|trucked|rainwater — promote to reference product]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdMemberId rdf:type rdf:Property ;
    rdfs:label 'Household Member Id' ;
    rdfs:comment 'Unique surrogate identifier for each household member association record in the beneficiary domain. Primary key for this entity.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageEstimated rdf:type rdf:Property ;
    rdfs:label 'Age Estimated' ;
    rdfs:comment 'Indicates whether the recorded age or date of birth is an estimate rather than a verified value. Common in humanitarian field contexts where documentation is unavailable. Affects data quality scoring for MEL reporting.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ageYears rdf:type rdf:Property ;
    rdfs:label 'Age Years' ;
    rdfs:comment 'Recorded or estimated age of the household member in years at time of registration. Used when exact date of birth is unknown, which is common in humanitarian contexts. Supports age-band disaggregation for NFI sizing and program targeting.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentGiven rdf:type rdf:Property ;
    rdfs:label 'Consent Given' ;
    rdfs:comment 'Indicates whether this household member (or their guardian) has provided informed consent for data collection, storage, and use in program delivery. Mandatory per CHS (Core Humanitarian Standard) and GDPR data protection requirements.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentWithdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawal Date' ;
    rdfs:comment 'Date on which this household member or their guardian withdrew consent for data processing. Triggers data anonymisation or deletion workflows per GDPR Article 17 right to erasure.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryOfOriginCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 code for the country from which the household member originates. Distinct from nationality; used for refugee and IDP classification, UNHCR PoC (Person of Concern) reporting, and cross-border displacement analysis.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth of the household member. Used to calculate age for program eligibility (e.g., child nutrition programs, elderly support), dependency ratio, and demographic disaggregation in MEL reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Disability Status' ;
    rdfs:comment 'Recorded disability classification for the household member using the Washington Group Short Set framework. Used for inclusive programming, NFI adaptation, and SPHERE accessibility compliance reporting. [ENUM-REF-CANDIDATE: none|physical|sensory|cognitive|psychosocial|multiple|prefer_not_to_say — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationLevel rdf:type rdf:Property ;
    rdfs:label 'Education Level' ;
    rdfs:comment 'Highest level of education attained by this household member. Used for livelihood program targeting, literacy-based service adaptation, and SDG (Sustainable Development Goal) 4 education indicator reporting. [ENUM-REF-CANDIDATE: none|primary_incomplete|primary_complete|secondary_incomplete|secondary_complete|tertiary|vocational|other — promote to reference product]' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'Surname or family name of the household member as recorded during beneficiary registration. Combined with given_name for full identity verification.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderIdentity rdf:type rdf:Property ;
    rdfs:label 'Gender Identity' ;
    rdfs:comment 'Self-identified gender of the household member, captured where programmatically relevant (e.g., GBV programs, PSS (Psychosocial Support) services). Distinct from biological sex. Collected only with informed consent per data protection standards.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:givenName rdf:type rdf:Property ;
    rdfs:label 'Given Name' ;
    rdfs:comment 'First or given name of the household member as recorded during beneficiary registration. Used for identity verification during distributions and case management follow-up.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHeadOfHousehold rdf:type rdf:Property ;
    rdfs:label 'Is Head Of Household' ;
    rdfs:comment 'Indicates whether this member is the designated head of household. Only one member per household should have this flag set to true. Used for primary contact identification, distribution authorization, and household-level reporting.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:livelihoodStatus rdf:type rdf:Property ;
    rdfs:label 'Livelihood Status' ;
    rdfs:comment 'Current livelihood or employment status of the household member. Used for economic vulnerability assessment, cash transfer program eligibility, and livelihoods program targeting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberCode rdf:type rdf:Property ;
    rdfs:label 'Member Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this household member association, used in field operations, PDM (Post-Distribution Monitoring) forms, and inter-agency data sharing.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberRole rdf:type rdf:Property ;
    rdfs:label 'Member Role' ;
    rdfs:comment 'Functional role of this individual within the household structure, used for program targeting, NFI kit sizing, and household vulnerability profiling. Distinct from relationship_to_head which captures kinship; this captures programmatic classification.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipEndDate rdf:type rdf:Property ;
    rdfs:label 'Membership End Date' ;
    rdfs:comment 'Date on which this individual\'s membership in the household ended, due to departure, transfer, death, or administrative closure. Null if membership is currently active.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipEndReason rdf:type rdf:Property ;
    rdfs:label 'Membership End Reason' ;
    rdfs:comment 'Reason code explaining why this individual\'s household membership ended. Required for attrition analysis, household composition tracking, and MEL (Monitoring Evaluation and Learning) reporting.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStartDate rdf:type rdf:Property ;
    rdfs:label 'Membership Start Date' ;
    rdfs:comment 'Date on which this individual formally joined or was registered as a member of the household. Used to determine eligibility windows for program benefits and historical household composition analysis.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of this individual\'s membership in the household. Drives eligibility for household-level distributions and services. \'transferred\' indicates movement to another household; \'departed\' indicates voluntary exit.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:muacAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Muac Assessment Date' ;
    rdfs:comment 'Date on which the MUAC (Mid-Upper Arm Circumference) measurement was recorded for this household member. Used to determine recency of nutritional screening and trigger follow-up assessments per SPHERE protocols.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nationalityCode rdf:type rdf:Property ;
    rdfs:label 'Nationality Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the nationality of the household member. Used for IDP (Internally Displaced Person) and PoC (Person of Concern) classification, cross-border program eligibility, and UNHCR reporting.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pregnantOrLactating rdf:type rdf:Property ;
    rdfs:label 'Pregnant Or Lactating' ;
    rdfs:comment 'Indicates whether this household member is currently pregnant or lactating. Used for nutrition program targeting (e.g., SAM/GAM treatment), supplementary feeding eligibility, and SPHERE maternal health standards compliance.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipToHead rdf:type rdf:Property ;
    rdfs:label 'Relationship To Head' ;
    rdfs:comment 'Describes the kinship or social relationship of this member to the designated head of household. Used for dependency ratio calculations, vulnerability scoring, and NFI distribution entitlement. [ENUM-REF-CANDIDATE: head|spouse|child|parent|sibling|dependent|other_relative|non_relative — promote to reference product]' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schoolEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'School Enrollment Status' ;
    rdfs:comment 'Current school enrollment status for household members of school age. Used for education program targeting, out-of-school children identification, and SDG 4 indicator tracking in DHIS2.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sex rdf:type rdf:Property ;
    rdfs:label 'Sex' ;
    rdfs:comment 'Biological sex of the household member as recorded at registration. Used for gender disaggregation in MEL reporting, GBV (Gender-Based Violence) program targeting, and SPHERE/DAC (Development Assistance Committee) compliance reporting.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unaccompaniedMinor rdf:type rdf:Property ;
    rdfs:label 'Unaccompanied Minor' ;
    rdfs:comment 'Indicates whether this household member is an unaccompanied or separated child (UASC). Triggers child protection protocols, case management escalation in CommCare, and mandatory reporting to child protection clusters.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficiaryNeedsAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Needs Assessment Id' ;
    rdfs:comment 'Unique system-generated identifier for each needs assessment record. Primary key for the needs_assessment data product within the beneficiary domain.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BeneficiaryNeedsAssessment .

ind:communityEngagementEventId rdf:type rdf:Property ;
    rdfs:label 'Community Engagement Event Id' ;
    rdfs:comment 'Foreign key linking to communication.community_engagement_event. Business justification: Needs assessments are frequently conducted during community engagement events (focus group discussions, community consultations, participatory assessments). Links assessment data to the event context,' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommunityEngagementEvent .

ind:dataCollectionToolId rdf:type rdf:Property ;
    rdfs:label 'Data Collection Tool Id' ;
    rdfs:comment 'The unique identifier of the data collection instrument used to conduct this assessment. For KoboToolbox, this is the form UID (e.g., \'aXmK3p9QrT\'). For CommCare, this is the module ID. Enables traceability back to the specific questionnaire version and supports data quality audits.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataCollectionTool .

ind:enumeratorVolunteerId rdf:type rdf:Property ;
    rdfs:label 'Enumerator Volunteer Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer. Business justification: Volunteers conduct needs assessments in many NGO operations (household surveys, vulnerability assessments, rapid assessments). Standard practice for community-based data collection. Required for track' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:primaryBeneficiaryStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Beneficiary Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or volunteer who conducted the field assessment. Used for quality assurance, inter-rater reliability checks, and enumerator performance monitoring.' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The calendar date on which the needs assessment was physically conducted in the field. This is the principal real-world event date, distinct from the record submission or validation timestamps. Used for temporal targeting analysis and periodic reassessment scheduling.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentLevel rdf:type rdf:Property ;
    rdfs:label 'Assessment Level' ;
    rdfs:comment 'The unit of analysis at which this needs assessment was conducted. \'individual\' targets a single beneficiary (e.g., GBV survivor, SAM case); \'household\' targets a family unit; \'community\' targets a settlement or geographic cluster. Determines which of beneficiary_id, household_id, or community_id is populated.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Assessment Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this needs assessment, used in field reports, SitReps, and donor communications. Format: NA-{COUNTRY}-{YEAR}-{SEQUENCE}. Sourced from KoboToolbox or CommCare submission ID.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current workflow lifecycle state of the needs assessment record. \'draft\' indicates field data entry in progress; \'submitted\' indicates enumerator submission pending review; \'validated\' indicates supervisor-approved and usable for targeting; \'rejected\' indicates data quality failure requiring re-assessment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentToolVersion rdf:type rdf:Property ;
    rdfs:label 'Assessment Tool Version' ;
    rdfs:comment 'Version number or deployment date of the assessment tool/form used. Critical for longitudinal comparability — when a KoboToolbox form or CommCare module is updated, findings from different versions may not be directly comparable without version-aware analysis.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of the assessment\'s purpose and methodology. \'initial_registration\' is conducted at first beneficiary contact; \'periodic_reassessment\' is a scheduled follow-up to update vulnerability status; \'post_crisis_rapid\' is an emergency rapid assessment following a shock event; \'sector_specific_deep\' is an in-depth assessment for a single sector (e.g., nutrition MUAC screening, WASH facility survey).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationScore rdf:type rdf:Property ;
    rdfs:label 'Education Score' ;
    rdfs:comment 'Numeric score for the education sector assessment findings. Null if education was not included in sectors_assessed. Covers school access, enrollment barriers, learning environment safety, and teacher availability against SPHERE/INEE minimum standards.' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enumeratorNotes rdf:type rdf:Property ;
    rdfs:label 'Enumerator Notes' ;
    rdfs:comment 'Free-text qualitative observations recorded by the field enumerator during the assessment. Captures contextual information not covered by structured questions (e.g., security constraints, access limitations, observed conditions). Used by supervisors during validation review.' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:femaleHeadedHousehold rdf:type rdf:Property ;
    rdfs:label 'Female Headed Household' ;
    rdfs:comment 'Indicates whether the assessed household is headed by a female. Female-headed households are a standard vulnerability marker in humanitarian targeting criteria and are required for gender disaggregation in donor reports (USAID, DFID/FCDO, UN Women standards).' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:livelihoodsScore rdf:type rdf:Property ;
    rdfs:label 'Livelihoods Score' ;
    rdfs:comment 'Numeric score for the livelihoods sector assessment findings. Null if livelihoods was not included in sectors_assessed. Covers income sources, asset ownership, market access, and economic vulnerability indicators.' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:muacMm rdf:type rdf:Property ;
    rdfs:label 'Muac Mm' ;
    rdfs:comment 'Mid-Upper Arm Circumference (MUAC) measurement in millimetres for children under 5 or pregnant/lactating women, used to screen for acute malnutrition. MUAC < 115mm indicates SAM; 115–125mm indicates MAM. Classified as PHI as it is a direct health measurement linked to an individual. Null if not applicable to assessment subject.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nutritionScore rdf:type rdf:Property ;
    rdfs:label 'Nutrition Score' ;
    rdfs:comment 'Numeric score for the nutrition sector assessment findings. Null if nutrition was not included in sectors_assessed. Incorporates Global Acute Malnutrition (GAM) and Severe Acute Malnutrition (SAM) indicators where applicable. Feeds into DHIS2 nutrition indicator tracking.' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallVulnerabilityScore rdf:type rdf:Property ;
    rdfs:label 'Overall Vulnerability Score' ;
    rdfs:comment 'Composite numeric score representing the assessed subject\'s overall vulnerability level, calculated from sector-specific findings using the program\'s scoring methodology (e.g., 0–100 scale). Feeds into vulnerability_profile updates when the score materially changes vulnerability classification. This is a raw assessment output, not a derived KPI.' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:personsWithDisabilityCount rdf:type rdf:Property ;
    rdfs:label 'Persons With Disability Count' ;
    rdfs:comment 'Number of household members with a physical, sensory, intellectual, or psychosocial disability. Required for disability-inclusive programming per IASC Guidelines on Inclusion of Persons with Disabilities in Humanitarian Action and CRPD compliance reporting.' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protectionScore rdf:type rdf:Property ;
    rdfs:label 'Protection Score' ;
    rdfs:comment 'Numeric score for the protection sector assessment findings. Null if protection was not included in sectors_assessed. Covers GBV risk, child protection, housing land and property rights, and documentation status. Sensitive findings are handled per GBV information management protocols.' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referralRecommended rdf:type rdf:Property ;
    rdfs:label 'Referral Recommended' ;
    rdfs:comment 'Indicates whether the assessment findings recommend referral of the beneficiary or household to one or more service providers or program interventions. When TRUE, a referral pathway is initiated in CommCare case management. Drives downstream case management workflow.' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralSectors rdf:type rdf:Property ;
    rdfs:label 'Referral Sectors' ;
    rdfs:comment 'Pipe-delimited list of sectors to which the beneficiary or household is being referred based on assessment findings (e.g., \'nutrition|PSS|WASH\'). Populated only when referral_recommended is TRUE. Drives service pathway activation in CommCare and Microsoft Dynamics 365 case management.' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorsAssessed rdf:type rdf:Property ;
    rdfs:label 'Sectors Assessed' ;
    rdfs:comment 'Pipe-delimited list of humanitarian/development sectors covered in this assessment (e.g., \'WASH|nutrition|shelter|protection|livelihoods|education\'). Sectors align with IASC cluster system. Determines which sector-specific scored findings fields are populated. [ENUM-REF-CANDIDATE: WASH|nutrition|shelter|protection|livelihoods|education|health|food_security|NFI|PSS — promote to reference product]' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelterScore rdf:type rdf:Property ;
    rdfs:label 'Shelter Score' ;
    rdfs:comment 'Numeric score for the shelter sector assessment findings. Null if shelter was not included in sectors_assessed. Assessed against SPHERE minimum standards for covered living space, structural safety, and thermal comfort.' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Source Submission Reference' ;
    rdfs:comment 'The native submission or case ID from the originating source system (KoboToolbox submission UUID or CommCare case ID). Enables exact record traceability back to the source system for data reconciliation, duplicate detection, and audit purposes.' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorValidationNotes rdf:type rdf:Property ;
    rdfs:label 'Supervisor Validation Notes' ;
    rdfs:comment 'Free-text notes entered by the supervising data manager or MEL officer during the assessment review and validation process. Documents reasons for rejection, data quality concerns, or approval rationale. Populated when assessment_status transitions to \'validated\' or \'rejected\'.' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'The date and time when the assessment record was validated or rejected by the supervising staff member. Distinct from assessment_date (field event) and created_timestamp (record creation). Used for SLA monitoring of data quality review turnaround.' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:washScore rdf:type rdf:Property ;
    rdfs:label 'Wash Score' ;
    rdfs:comment 'Numeric score for the Water, Sanitation and Hygiene (WASH) sector assessment findings. Null if WASH was not included in sectors_assessed. Scored against SPHERE minimum standards for water access, sanitation facilities, and hygiene promotion.' ;
    rdfs:domain ind:BeneficiaryNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:protectionFlagId rdf:type rdf:Property ;
    rdfs:label 'Protection Flag Id' ;
    rdfs:comment 'Unique identifier for the protection flag record. Primary key.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAssignedProtectionOfficerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Assigned Protection Officer Staff Member Id' ;
    rdfs:comment 'Reference to the protection officer or case worker currently responsible for managing this protection flag and coordinating response.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:primaryProtectionUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Protection User Account Id' ;
    rdfs:comment 'Reference to the user account that created this protection flag record. Used for audit trail and accountability.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Name of the operational system from which this protection flag record originated. Typically CommCare, KoboToolbox, or partner case management systems.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date when the protection flag was escalated to higher authority or specialized protection services.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flagCode rdf:type rdf:Property ;
    rdfs:label 'Flag Code' ;
    rdfs:comment 'Standardized code identifying the protection flag type. Used for system integration and reporting aggregation.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagDate rdf:type rdf:Property ;
    rdfs:label 'Flag Date' ;
    rdfs:comment 'Date when the protection concern was first identified or flagged. Represents the business event timestamp for this protection record.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flagSeverity rdf:type rdf:Property ;
    rdfs:label 'Flag Severity' ;
    rdfs:comment 'Severity level of the protection concern indicating urgency of response and level of risk to the beneficiary.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagStatus rdf:type rdf:Property ;
    rdfs:label 'Flag Status' ;
    rdfs:comment 'Current lifecycle status of the protection flag indicating whether it requires active intervention, ongoing monitoring, or has been resolved.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagType rdf:type rdf:Property ;
    rdfs:label 'Flag Type' ;
    rdfs:comment 'Category of protection concern. GBV (Gender-Based Violence), SGBV (Sexual and Gender-Based Violence), UASC (Unaccompanied and Separated Children). [ENUM-REF-CANDIDATE: GBV Risk|Child Protection|SGBV Survivor|Unaccompanied Minor|UASC|Trafficking Risk|Forced Recruitment|Disability Protection|Elderly at Risk|Medical Vulnerability — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flaggingSource rdf:type rdf:Property ;
    rdfs:label 'Flagging Source' ;
    rdfs:comment 'Name of the organization, program, or system that originally flagged this protection concern. May reference partner organizations or internal programs.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identification Method' ;
    rdfs:comment 'Method or channel through which the protection concern was identified. FGD (Focus Group Discussion), KII (Key Informant Interview). [ENUM-REF-CANDIDATE: Field Assessment|Community Referral|Self-Reported|Partner Organization|Health Screening|Household Survey|Focus Group Discussion|Key Informant Interview — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateNeeds rdf:type rdf:Property ;
    rdfs:label 'Immediate Needs' ;
    rdfs:comment 'Description of immediate protection needs or interventions required to address the flagged concern. Used for rapid response planning.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Last Follow Up Date' ;
    rdfs:comment 'Date of the most recent follow-up visit or assessment conducted for this protection flag.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalActionRequired rdf:type rdf:Property ;
    rdfs:label 'Legal Action Required' ;
    rdfs:comment 'Indicates whether the protection concern requires legal intervention, law enforcement involvement, or judicial proceedings.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Next Follow Up Date' ;
    rdfs:comment 'Scheduled date for the next follow-up visit or assessment to monitor the protection concern and beneficiary status.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pssProvided rdf:type rdf:Property ;
    rdfs:label 'Pss Provided' ;
    rdfs:comment 'Indicates whether Psychosocial Support (PSS) services have been provided to the beneficiary as part of protection response.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralMade rdf:type rdf:Property ;
    rdfs:label 'Referral Made' ;
    rdfs:comment 'Indicates whether the beneficiary has been referred to specialized protection services or partner organizations for support.' ;
    rdfs:domain ind:ProtectionFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralOrganization rdf:type rdf:Property ;
    rdfs:label 'Referral Organization' ;
    rdfs:comment 'Name of the organization or service provider to which the beneficiary was referred for specialized protection support.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'Reporting period during which this protection flag was active or recorded. Format: YYYY-QN for quarterly or YYYY-MM for monthly reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date when the protection concern was resolved or the flag was closed. Null if the flag is still active or under monitoring.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Narrative description of how the protection concern was resolved, interventions provided, and outcomes achieved.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed narrative description of the specific protection risk or concern. Contains sensitive information about the nature of the threat or vulnerability.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralId rdf:type rdf:Property ;
    rdfs:label 'Referral Id' ;
    rdfs:comment 'Unique identifier for the referral transaction. Primary key for the referral data product.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivingOrganizationPartnerOrgId rdf:type rdf:Property ;
    rdfs:label 'Receiving Organization Partner Org Id' ;
    rdfs:comment 'Identifier of the organization or service provider that is receiving and expected to act on the referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerOrg .

ind:receivingStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Receiving Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member at the receiving organization who is assigned to handle this referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:referralPartnerOrgId rdf:type rdf:Property ;
    rdfs:label 'Referral Partner Org Id' ;
    rdfs:comment 'Identifier of the organization or partner that is initiating and submitting the referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerOrg .

ind:referralStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Referral Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member or case worker who initiated the referral on behalf of the beneficiary.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:referringVolunteerId rdf:type rdf:Property ;
    rdfs:label 'Referring Volunteer Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer. Business justification: Community volunteers identify and refer beneficiaries to specialized services (health, protection, legal aid). Critical for community-based protection, health outreach, and early identification progra' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date when the receiving organization formally accepted the referral and committed to providing services.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiarySatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Satisfaction Rating' ;
    rdfs:comment 'Numeric rating provided by the beneficiary indicating their satisfaction with the referral process and services received, typically on a scale of 1-5.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Explanation for why the referral was cancelled before completion, including beneficiary circumstances or organizational constraints.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date when the referral was marked as completed, indicating that all required services have been delivered and documented.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'Explanation provided when a referral is declined by the receiving organization or rejected by the beneficiary.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedResponseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Response Date' ;
    rdfs:comment 'Target date by which the receiving organization is expected to acknowledge or respond to the referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feedbackReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Feedback Received Flag' ;
    rdfs:comment 'Indicates whether feedback was received from the beneficiary regarding their satisfaction with the referral process and services received.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed Flag' ;
    rdfs:comment 'Indicates whether the scheduled follow-up with the beneficiary or receiving organization has been completed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Scheduled date for follow-up contact with the beneficiary or receiving organization to verify service delivery and outcome.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gbvCaseFlag rdf:type rdf:Property ;
    rdfs:label 'Gbv Case Flag' ;
    rdfs:comment 'Indicates whether this referral is related to a Gender-Based Violence (GBV) case, requiring adherence to specialized GBV referral pathways and confidentiality protocols.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp when this referral record was last updated or modified in the system.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Detailed description of the outcome of the referral, including services provided, beneficiary response, and any follow-up actions required.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeCategory rdf:type rdf:Property ;
    rdfs:label 'Outcome Category' ;
    rdfs:comment 'Standardized classification of the referral outcome for reporting and analysis purposes.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Detailed explanation of why the beneficiary is being referred, including specific needs, conditions, or circumstances that necessitate the referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Receiving Organization Name' ;
    rdfs:comment 'Name of the organization or service provider receiving the referral, for tracking and reporting purposes.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingServiceType rdf:type rdf:Property ;
    rdfs:label 'Receiving Service Type' ;
    rdfs:comment 'Specific type of service or program that the beneficiary is being referred to at the receiving organization.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingStaffName rdf:type rdf:Property ;
    rdfs:label 'Receiving Staff Name' ;
    rdfs:comment 'Full name of the staff member at the receiving organization who accepted or is processing the referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralCategory rdf:type rdf:Property ;
    rdfs:label 'Referral Category' ;
    rdfs:comment 'Primary service category or sector for which the beneficiary is being referred. Aligned with humanitarian cluster system and Sphere standards. [ENUM-REF-CANDIDATE: health|protection|shelter|wash|nutrition|education|livelihoods|psychosocial|legal|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralNumber rdf:type rdf:Property ;
    rdfs:label 'Referral Number' ;
    rdfs:comment 'Human-readable business identifier for the referral, used for tracking and communication across organizations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralStatus rdf:type rdf:Property ;
    rdfs:label 'Referral Status' ;
    rdfs:comment 'Current lifecycle status of the referral indicating whether it has been accepted, is being processed, completed, or declined by the receiving organization.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralType rdf:type rdf:Property ;
    rdfs:label 'Referral Type' ;
    rdfs:comment 'Classification of the referral based on organizational scope and urgency. Internal referrals are within the same organization, external are to partner organizations, emergency referrals require immediate action.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referringStaffContact rdf:type rdf:Property ;
    rdfs:label 'Referring Staff Contact' ;
    rdfs:comment 'Phone number or email address of the referring staff member for coordination and follow-up communication.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referringStaffName rdf:type rdf:Property ;
    rdfs:label 'Referring Staff Name' ;
    rdfs:comment 'Full name of the staff member who initiated the referral, for contact and follow-up purposes.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Date' ;
    rdfs:comment 'Date when the service was actually delivered to the beneficiary by the receiving organization.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deduplicationMasterRegistrantId rdf:type rdf:Property ;
    rdfs:label 'Deduplication Master Registrant Id' ;
    rdfs:comment 'The beneficiary_id of the authoritative master record when this registrant has been identified as a duplicate. Null for unique records. Enables lineage tracing from duplicate to canonical record for audit and reporting.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registrant .

ind:completenessScore rdf:type rdf:Property ;
    rdfs:label 'Completeness Score' ;
    rdfs:comment 'Percentage score (0–100) reflecting the completeness of the registrant\'s registration profile based on mandatory and recommended fields populated. Used for data quality monitoring, field staff performance tracking, and MEL data quality assessments.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deduplicationStatus rdf:type rdf:Property ;
    rdfs:label 'Deduplication Status' ;
    rdfs:comment 'Current status of the deduplication check for this registrant record. \'Duplicate\' records are suppressed from active program counts. \'Merged\' indicates the record was consolidated with a master record. Supports USAID and DFID double-counting prevention requirements.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disabilityType rdf:type rdf:Property ;
    rdfs:label 'Disability Type' ;
    rdfs:comment 'Classification of the registrant\'s disability type per Washington Group Short Set categories. Used for targeted accommodation planning, assistive device provision, and inclusive program design. Only populated when has_disability is True. [ENUM-REF-CANDIDATE: mobility|vision|hearing|cognitive|psychosocial|multiple|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasDisability rdf:type rdf:Property ;
    rdfs:label 'Has Disability' ;
    rdfs:comment 'Indicates whether the registrant has a reported disability. Used for inclusive programming, accessibility accommodations, and Washington Group Short Set disaggregation in MEL reporting per IASC disability inclusion guidelines.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGbvSurvivor rdf:type rdf:Property ;
    rdfs:label 'Is Gbv Survivor' ;
    rdfs:comment 'Indicates whether the registrant has been identified as a Gender-Based Violence (GBV) survivor. Triggers GBV case management referral, PSS services, and safe space access. Stored with highest data protection classification per GBV information management principles.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPregnantOrLactating rdf:type rdf:Property ;
    rdfs:label 'Is Pregnant Or Lactating' ;
    rdfs:comment 'Indicates whether the registrant is a pregnant or lactating woman (PLW). Triggers priority access to nutrition programs (SAM/GAM treatment, supplementary feeding), antenatal care referrals, and PLW-specific NFI kits.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnaccompaniedMinor rdf:type rdf:Property ;
    rdfs:label 'Is Unaccompanied Minor' ;
    rdfs:comment 'Indicates whether the registrant is an unaccompanied or separated child (UASC). Triggers child protection protocols, best-interest assessments, and mandatory referral to child protection case management per UNHCR/UNICEF UASC guidelines.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Verification Date' ;
    rdfs:comment 'Date of the most recent identity or liveness verification for this registrant. Used to flag records requiring re-verification per program cycle requirements and to support active beneficiary count accuracy for donor reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Language Code' ;
    rdfs:comment 'ISO 639 language code for the registrant\'s preferred communication language. Used to assign appropriate interpreters, translated materials, and language-appropriate PSS services. Supports CHS Commitment 4 on accessible communication.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionFlag rdf:type rdf:Property ;
    rdfs:label 'Protection Flag' ;
    rdfs:comment 'Master protection concern flag indicating the registrant has one or more active protection risks (GBV, UASC, trafficking, detention risk, etc.). Triggers protection case management workflow and restricts data sharing per CHS data protection principles.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reRegistrationCount rdf:type rdf:Property ;
    rdfs:label 'Re Registration Count' ;
    rdfs:comment 'Number of times this registrant has been re-registered in the system (e.g., after displacement, camp relocation, or annual verification cycles). Supports re-registration tracking and historical registration event analysis.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registrationModality rdf:type rdf:Property ;
    rdfs:label 'Registration Modality' ;
    rdfs:comment 'The channel or method through which the registrant was enrolled. Distinguishes in-person field registration, mobile data collection (KoboToolbox/CommCare), remote registration (phone/online), and self-registration kiosks. Informs data quality scoring and verification requirements.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Registration Source System' ;
    rdfs:comment 'The operational system of record from which this registrant record originated. Supports data lineage, deduplication across systems, and interoperability mapping to UNHCR proGres v4, WFP SCOPE, and RAIS.' ;
    rdfs:domain ind:Registrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationTool rdf:type rdf:Property ;
    rdfs:label 'Registration Tool' ;
    rdfs:comment 'The specific data collection tool or form used to capture the registration. Distinguishes KoboToolbox survey forms, CommCare mobile case forms, paper-based forms, and direct system entry. Informs data quality and field validation rules.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Verification Document Number' ;
    rdfs:comment 'The document number from the identity verification document presented at registration (e.g., national ID number, passport number, UNHCR card number). Stored encrypted; used for deduplication and re-registration identity matching.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDocumentType rdf:type rdf:Property ;
    rdfs:label 'Verification Document Type' ;
    rdfs:comment 'Type of identity verification document presented at registration. Used for identity assurance scoring, fraud prevention, and compliance with donor KYB (Know Your Beneficiary) requirements. \'Community attestation\' applies where formal documents are unavailable.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationEventId rdf:type rdf:Property ;
    rdfs:label 'Registration Event Id' ;
    rdfs:comment 'Unique identifier for the beneficiary registration event. Primary key for the registration event record.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biometricCaptured rdf:type rdf:Property ;
    rdfs:label 'Biometric Captured' ;
    rdfs:comment 'Indicates whether biometric data (fingerprint, iris scan, facial recognition) was captured during this registration event.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biometricType rdf:type rdf:Property ;
    rdfs:label 'Biometric Type' ;
    rdfs:comment 'Type of biometric data captured during registration: fingerprint, iris scan, facial recognition, or none.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Assessment of the overall data quality for this registration event: high, medium, low, or needs review.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deduplicationCheckPerformed rdf:type rdf:Property ;
    rdfs:label 'Deduplication Check Performed' ;
    rdfs:comment 'Indicates whether a deduplication check was performed during registration to prevent duplicate beneficiary records.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deduplicationMethod rdf:type rdf:Property ;
    rdfs:label 'Deduplication Method' ;
    rdfs:comment 'Method used for deduplication check: biometric matching, demographic matching, document number verification, manual review, or none.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duplicateFound rdf:type rdf:Property ;
    rdfs:label 'Duplicate Found' ;
    rdfs:comment 'Indicates whether a potential duplicate beneficiary record was identified during the deduplication check.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:duplicateResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Duplicate Resolution Status' ;
    rdfs:comment 'Status of duplicate resolution: no duplicate found, duplicate confirmed and merged, duplicate resolved, or pending manual review.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdHead rdf:type rdf:Property ;
    rdfs:label 'Household Head' ;
    rdfs:comment 'Indicates whether the registered beneficiary is designated as the head of household for program purposes.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:householdRegistration rdf:type rdf:Property ;
    rdfs:label 'Household Registration' ;
    rdfs:comment 'Indicates whether this registration event was part of a household-level registration (true) or individual-only registration (false).' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interpreterUsed rdf:type rdf:Property ;
    rdfs:label 'Interpreter Used' ;
    rdfs:comment 'Indicates whether an interpreter was used during the registration session due to language barriers.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralRequired rdf:type rdf:Property ;
    rdfs:label 'Referral Required' ;
    rdfs:comment 'Indicates whether the beneficiary requires referral to specialized services (protection, health, psychosocial support) based on registration screening.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registeringOrganization rdf:type rdf:Property ;
    rdfs:label 'Registering Organization' ;
    rdfs:comment 'Name of the organization (INGO, CBO, CSO) that conducted the registration, relevant for consortium or partnership programs.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeringStaffName rdf:type rdf:Property ;
    rdfs:label 'Registering Staff Name' ;
    rdfs:comment 'Full name of the staff member or field worker who conducted the registration for audit and accountability purposes.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCompletenessScore rdf:type rdf:Property ;
    rdfs:label 'Registration Completeness Score' ;
    rdfs:comment 'Percentage score (0-100) indicating the completeness of data captured during registration based on required and optional fields.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationLanguage rdf:type rdf:Property ;
    rdfs:label 'Registration Language' ;
    rdfs:comment 'ISO 639-3 three-letter language code indicating the language used during the registration interview or data collection.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationLatitude rdf:type rdf:Property ;
    rdfs:label 'Registration Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the registration location in decimal degrees format.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationLongitude rdf:type rdf:Property ;
    rdfs:label 'Registration Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the registration location in decimal degrees format.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationNotes rdf:type rdf:Property ;
    rdfs:label 'Registration Notes' ;
    rdfs:comment 'Free-text field for registering staff to capture additional observations, special circumstances, or contextual information about the registration event.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Timestamp' ;
    rdfs:comment 'Precise timestamp when the registration session was initiated, including time zone information.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vulnerabilityAssessmentConducted rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Assessment Conducted' ;
    rdfs:comment 'Indicates whether a vulnerability or needs assessment was conducted as part of this registration event.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vulnerabilityProfileId rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Profile Id' ;
    rdfs:comment 'Unique system-generated identifier for the vulnerability profile record. Primary key for this entity.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousProfileVulnerabilityProfileId rdf:type rdf:Property ;
    rdfs:label 'Previous Profile Vulnerability Profile Id' ;
    rdfs:comment 'Reference to the immediately preceding vulnerability profile record for this registrant, enabling longitudinal tracking of vulnerability changes over time. Populated when profile_status is \'superseded\' or when a new profile replaces an existing one.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VulnerabilityProfile .

ind:assessmentTool rdf:type rdf:Property ;
    rdfs:label 'Assessment Tool' ;
    rdfs:comment 'Data collection tool or platform used to conduct the vulnerability assessment that generated this profile. Supports data quality tracking and source system lineage. Aligned with operational systems including KoboToolbox and CommCare.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chronicIllnessFlag rdf:type rdf:Property ;
    rdfs:label 'Chronic Illness Flag' ;
    rdfs:comment 'Indicates whether the beneficiary has one or more documented chronic illnesses (e.g., HIV/AIDS, tuberculosis, diabetes, hypertension) that increase vulnerability and require sustained health service access. Drives health program targeting and DHIS2 health indicator reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chronicIllnessType rdf:type rdf:Property ;
    rdfs:label 'Chronic Illness Type' ;
    rdfs:comment 'Coded description of the primary chronic illness condition affecting the beneficiary (e.g., HIV_AIDS, tuberculosis, diabetes, hypertension, malnutrition_chronic). Populated only when chronic_illness_flag is True. Aligned with ICD-11 coding where applicable.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositeVulnerabilityScore rdf:type rdf:Property ;
    rdfs:label 'Composite Vulnerability Score' ;
    rdfs:comment 'Aggregated multi-dimensional vulnerability score derived from weighted combination of food insecurity (IPC phase), protection risk, disability, nutritional status, displacement category, and other assessed indicators. Used for program targeting, beneficiary prioritization, and Results-Based Management (RBM) reporting. Score range typically 0.00–100.00.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disabilityClassification rdf:type rdf:Property ;
    rdfs:label 'Disability Classification' ;
    rdfs:comment 'Functional difficulty domain identified using the Washington Group Short Set on Functioning (WG-SS) questions. Captures the primary domain of disability: seeing, hearing, mobility, cognition, self-care, or communication. Used for inclusive programming and disability-disaggregated reporting per CRPD. [ENUM-REF-CANDIDATE: none|seeing|hearing|mobility|cognition|self_care|communication|multiple — promote to reference product]' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disabilitySeverity rdf:type rdf:Property ;
    rdfs:label 'Disability Severity' ;
    rdfs:comment 'Severity of functional difficulty as measured by the Washington Group Short Set (WG-SS) response scale: no difficulty, some difficulty, a lot of difficulty, or cannot do at all. Used alongside disability_classification for disaggregated disability reporting.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displacementCategory rdf:type rdf:Property ;
    rdfs:label 'Displacement Category' ;
    rdfs:comment 'Classification of the beneficiary\'s displacement status per UNHCR definitions. Internally Displaced Person (IDP) refers to those displaced within their country; refugee refers to those who have crossed international borders; returnee refers to those who have returned to their place of origin. Drives program eligibility and UNHCR/OCHA reporting.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elderlyMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Elderly Member Flag' ;
    rdfs:comment 'Indicates whether the household includes one or more elderly members (typically aged 60+). Elderly individuals are a recognized vulnerable group requiring targeted assistance per SPHERE and IASC age and disability inclusion guidelines.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:femaleHeadedHouseholdFlag rdf:type rdf:Property ;
    rdfs:label 'Female Headed Household Flag' ;
    rdfs:comment 'Indicates whether the household is headed by a woman. Female-headed households are recognized as a priority vulnerability category in humanitarian programming due to heightened protection risks and reduced access to resources. Used for gender-disaggregated reporting.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gbvExposureFlag rdf:type rdf:Property ;
    rdfs:label 'Gbv Exposure Flag' ;
    rdfs:comment 'Indicates whether the beneficiary has been identified as a survivor or at-risk individual for Gender-Based Violence (GBV). Triggers referral to GBV case management services and specialized support programs. Handled with strict confidentiality per GBV information management protocols.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicAreaCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Area Code' ;
    rdfs:comment 'Standardized code identifying the geographic area (admin level 2 or 3) where the beneficiary is located at the time of assessment. Used for geographic targeting, GIS mapping, and OCHA cluster reporting. Aligned with OCHA Common Operational Datasets (COD) administrative boundary codes.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReassessmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Reassessment Date' ;
    rdfs:comment 'Scheduled date for the next vulnerability reassessment to ensure the profile reflects the beneficiary\'s current vulnerability state. Drives field operations scheduling and MEL monitoring cycles. Typically set based on program-specific reassessment frequency protocols.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nutritionalStatus rdf:type rdf:Property ;
    rdfs:label 'Nutritional Status' ;
    rdfs:comment 'Nutritional status classification based on anthropometric screening. Severe Acute Malnutrition (SAM) indicates MUAC < 115mm or WHZ < -3; Moderate Acute Malnutrition (MAM) indicates MUAC 115–124mm or WHZ -2 to -3; normal indicates adequate nutritional status. Used for therapeutic feeding program targeting and Global Acute Malnutrition (GAM) rate reporting.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pregnantLactatingFlag rdf:type rdf:Property ;
    rdfs:label 'Pregnant Lactating Flag' ;
    rdfs:comment 'Indicates whether the household includes a pregnant or lactating woman (PLW). PLWs are a priority group for nutrition programming (supplementary feeding), antenatal care, and maternal health services. Used for CMAM and nutrition program targeting.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this vulnerability profile record, used in field operations, donor reporting, and inter-agency data sharing (e.g., VP-SOM-000123456).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Created Timestamp' ;
    rdfs:comment 'Timestamp when this vulnerability profile record was first created in the system. Used for audit trail and data lineage tracking.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profileSource rdf:type rdf:Property ;
    rdfs:label 'Profile Source' ;
    rdfs:comment 'Indicates the operational process or event that triggered the creation or update of this vulnerability profile. \'post_distribution_monitoring\' refers to Post-Distribution Monitoring (PDM) assessments; \'emergency_screening\' refers to rapid assessments during acute crises. Used for MEL data quality analysis.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle state of the vulnerability profile record. \'active\' indicates the current consolidated vulnerability state; \'superseded\' indicates a newer profile has replaced this one; \'pending_review\' indicates awaiting validation by a protection or MEL officer.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Updated Timestamp' ;
    rdfs:comment 'Timestamp when this vulnerability profile was last modified, reflecting the most recent update to any vulnerability indicator. Triggers downstream re-targeting and prioritization workflows.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pssNeedFlag rdf:type rdf:Property ;
    rdfs:label 'Pss Need Flag' ;
    rdfs:comment 'Indicates whether the beneficiary has been assessed as requiring Psychosocial Support (PSS) services, including mental health support, trauma counselling, or community-based psychosocial activities. Triggers referral to PSS programming.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelterAdequacy rdf:type rdf:Property ;
    rdfs:label 'Shelter Adequacy' ;
    rdfs:comment 'Assessment of the beneficiary\'s shelter situation against SPHERE minimum standards. \'none\' indicates no shelter; \'inadequate\' indicates shelter below minimum standards; \'transitional\' indicates temporary/emergency shelter; \'adequate\' indicates shelter meeting minimum standards. Drives NFI and shelter program targeting.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unaccompaniedMinorFlag rdf:type rdf:Property ;
    rdfs:label 'Unaccompanied Minor Flag' ;
    rdfs:comment 'Indicates whether the beneficiary is an unaccompanied or separated child (UASC) — a child under 18 separated from both parents and other relatives and not being cared for by a responsible adult. Triggers child protection case management and family tracing and reunification (FTR) services.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vulnerabilityTier rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Tier' ;
    rdfs:comment 'Categorical tier derived from the composite vulnerability score, used for operational targeting and prioritization decisions. \'critical\' indicates immediate life-saving intervention required; \'high\' indicates priority program enrollment; \'medium\' and \'low\' indicate standard program eligibility. Distinct from composite_vulnerability_score which is the numeric value.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:washAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Wash Access Flag' ;
    rdfs:comment 'Indicates whether the beneficiary household has adequate access to safe water, sanitation, and hygiene (WASH) facilities meeting SPHERE minimum standards. False indicates a WASH vulnerability requiring intervention. Used for WASH sector targeting and OCHA cluster reporting.' ;
    rdfs:domain ind:VulnerabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:advocacyCampaignId rdf:type rdf:Property ;
    rdfs:label 'Advocacy Campaign Id' ;
    rdfs:comment 'Unique identifier for the advocacy campaign. Primary key.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdvocacyCampaign .

ind:mediaContactId rdf:type rdf:Property ;
    rdfs:label 'Media Contact Id' ;
    rdfs:comment 'Foreign key linking to communication.media_contact. Business justification: advocacy_campaign currently duplicates media contact details (media_contact_name, media_contact_email, media_contact_phone). The media_contact master product exists with PK media_contact_id. This FK n' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaContact .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Advocacy campaigns are typically owned and budgeted at organizational unit level (country office, regional department) for accountability, budget tracking, and performance reporting. Nonprofit domain ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Foreign key linking to communication.communication_plan. Business justification: Advocacy campaigns are typically executed as part of broader communication plans. This link enables tracking campaign deliverables against plan objectives, budget allocation from plan to campaign, and' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:actualEngagementCount rdf:type rdf:Property ;
    rdfs:label 'Actual Engagement Count' ;
    rdfs:comment 'The actual number of meaningful engagements (clicks, shares, responses, sign-ups) generated by the campaign.' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualFundraisingAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Fundraising Amount' ;
    rdfs:comment 'The actual fundraising revenue generated by the campaign to date, tracked through gift processing and donor management systems.' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualReachCount rdf:type rdf:Property ;
    rdfs:label 'Actual Reach Count' ;
    rdfs:comment 'The actual number of individuals or households reached or engaged by the campaign, measured through analytics and tracking systems.' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'Total amount actually spent on the campaign to date, tracked for budget versus actual (BvA) reporting and financial stewardship.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date when the campaign was formally approved by leadership or compliance team to proceed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Total budget allocated to the campaign for all activities, including creative development, media buys, event costs, and staff time.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget allocated amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callToAction rdf:type rdf:Property ;
    rdfs:label 'Call To Action' ;
    rdfs:comment 'The specific action the campaign asks constituents to take, such as donate, sign a petition, attend an event, share content, or contact a legislator.' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Short alphanumeric code used for internal tracking, reporting, and integration with donor management and financial systems.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Detailed narrative description of the campaign purpose, strategy, key messages, and expected impact.' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignGoal rdf:type rdf:Property ;
    rdfs:label 'Campaign Goal' ;
    rdfs:comment 'Primary objective or intended outcome of the campaign, such as raising awareness for a specific issue, mobilizing advocacy actions, generating donations, or influencing policy change.' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'The official name of the advocacy, awareness, or fundraising campaign as recognized by the communications team and stakeholders.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignOwnerName rdf:type rdf:Property ;
    rdfs:label 'Campaign Owner Name' ;
    rdfs:comment 'Name of the staff member or team responsible for managing and executing the campaign.' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the campaign: planned (in design phase), active (currently running), paused (temporarily suspended), completed (finished and closed), cancelled (terminated before completion), or archived (historical record).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign delivery method: digital (social media, email, web), direct mail (postal outreach), event-based (conferences, rallies), media (TV, radio, press), grassroots (community organizing), or hybrid (multi-channel).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeoutDate rdf:type rdf:Property ;
    rdfs:label 'Closeout Date' ;
    rdfs:comment 'The date when the campaign was formally closed out, including final reporting, financial reconciliation, and archival of materials.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Status' ;
    rdfs:comment 'Status of internal compliance and legal review for campaign messaging and materials: pending (under review), approved (cleared for launch), rejected (requires revision), or not_required (no review needed).' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The planned or actual date when the campaign concludes. Null for ongoing campaigns without a defined end.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicFocus rdf:type rdf:Property ;
    rdfs:label 'Geographic Focus' ;
    rdfs:comment 'Geographic scope or target region for the campaign, such as global, regional (e.g., Sub-Saharan Africa), national, or local (e.g., specific city or community).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hashtagPrimary rdf:type rdf:Property ;
    rdfs:label 'Hashtag Primary' ;
    rdfs:comment 'The primary social media hashtag used to promote and track the campaign on digital platforms.' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hashtagSecondary rdf:type rdf:Property ;
    rdfs:label 'Hashtag Secondary' ;
    rdfs:comment 'Additional social media hashtags used in the campaign. Comma-separated list.' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDonorRestricted rdf:type rdf:Property ;
    rdfs:label 'Is Donor Restricted' ;
    rdfs:comment 'Indicates whether the campaign is funded by donor-restricted grants or contributions that limit how funds can be used. True if restricted, False if unrestricted.' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePrimary rdf:type rdf:Property ;
    rdfs:label 'Language Primary' ;
    rdfs:comment 'The primary language in which campaign materials and messaging are delivered (e.g., English, Spanish, French, Arabic).' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageSecondary rdf:type rdf:Property ;
    rdfs:label 'Language Secondary' ;
    rdfs:comment 'Additional languages in which campaign materials are available, if applicable. Comma-separated list.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The date when the campaign was officially launched to the public or target audience. May differ from start_date if there was a soft launch or pilot phase.' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerOrganizationNames rdf:type rdf:Property ;
    rdfs:label 'Partner Organization Names' ;
    rdfs:comment 'Comma-separated list of partner organizations, Civil Society Organizations (CSO), Community-Based Organizations (CBO), or International Non-Governmental Organizations (INGO) collaborating on the campaign.' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryChannelMix rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Mix' ;
    rdfs:comment 'Comma-separated list or description of the primary communication channels used in the campaign (e.g., social media, email, direct mail, events, media relations).' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgAlignmentTags rdf:type rdf:Property ;
    rdfs:label 'Sdg Alignment Tags' ;
    rdfs:comment 'Comma-separated list of United Nations Sustainable Development Goal (SDG) numbers or names that this campaign supports or aligns with (e.g., SDG 1: No Poverty, SDG 3: Good Health and Well-being).' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The date when the campaign officially begins or launched to the public.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetAudienceSegment rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segment' ;
    rdfs:comment 'Description of the primary audience or constituent segment the campaign is designed to reach, such as major donors, youth advocates, policy makers, or general public.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEngagementCount rdf:type rdf:Property ;
    rdfs:label 'Target Engagement Count' ;
    rdfs:comment 'The planned number of meaningful engagements (clicks, shares, responses, sign-ups) the campaign aims to generate.' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetFundraisingAmount rdf:type rdf:Property ;
    rdfs:label 'Target Fundraising Amount' ;
    rdfs:comment 'The fundraising revenue goal for the campaign, if applicable. Null for non-fundraising campaigns.' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetReachCount rdf:type rdf:Property ;
    rdfs:label 'Target Reach Count' ;
    rdfs:comment 'The planned number of individuals or households the campaign aims to reach or engage.' ;
    rdfs:domain ind:AdvocacyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:theme rdf:type rdf:Property ;
    rdfs:label 'Theme' ;
    rdfs:comment 'The overarching theme or narrative of the campaign, such as humanitarian response, climate action, gender equality, or education access.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'The URL of the dedicated campaign landing page or microsite where constituents can learn more and take action.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignTouchpointId rdf:type rdf:Property ;
    rdfs:label 'Campaign Touchpoint Id' ;
    rdfs:comment 'Unique identifier for the campaign touchpoint record. Primary key.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Identifier of the advocacy or fundraising campaign associated with this touchpoint. Links to the campaign master record.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:constituentId rdf:type rdf:Property ;
    rdfs:label 'Constituent Id' ;
    rdfs:comment 'Identifier of the constituent (donor, volunteer, advocate, or beneficiary) who interacted with the campaign. Links to the constituent master record in Salesforce Nonprofit Cloud.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:appealCode rdf:type rdf:Property ;
    rdfs:label 'Appeal Code' ;
    rdfs:comment 'The specific appeal or sub-campaign code associated with this touchpoint. Enables granular tracking of campaign variants and A/B testing results.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionSource rdf:type rdf:Property ;
    rdfs:label 'Attribution Source' ;
    rdfs:comment 'The marketing source or referral channel that led the constituent to this touchpoint (e.g., \'Google Ads\', \'Facebook Campaign\', \'Email Newsletter\', \'Partner Organization Referral\'). Supports multi-touch attribution modeling.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignMemberStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Member Status' ;
    rdfs:comment 'The current status of the constituent\'s membership in the campaign (e.g., \'Sent\', \'Responded\', \'Converted\', \'Opted Out\'). Reflects the constituent\'s position in the campaign lifecycle.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The communication channel through which the constituent interacted with the campaign. Supports multi-channel attribution analysis. [ENUM-REF-CANDIDATE: email|web|mobile_app|social_media|sms|direct_mail|phone|in_person — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionFlag rdf:type rdf:Property ;
    rdfs:label 'Conversion Flag' ;
    rdfs:comment 'Indicates whether this touchpoint resulted in a conversion event (e.g., donation made, petition signed, event registration completed). True if converted, False otherwise.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conversionType rdf:type rdf:Property ;
    rdfs:label 'Conversion Type' ;
    rdfs:comment 'The type of conversion achieved through this touchpoint, if any. Null or \'none\' if no conversion occurred.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionValueUsd rdf:type rdf:Property ;
    rdfs:label 'Conversion Value Usd' ;
    rdfs:comment 'The monetary value associated with the conversion, if applicable (e.g., donation amount). Expressed in US Dollars for standardized Return on Investment (ROI) analysis. Null for non-monetary conversions.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerTouchpointUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Touchpoint Usd' ;
    rdfs:comment 'The allocated marketing cost associated with generating this specific touchpoint, expressed in US Dollars. Used for campaign Return on Investment (ROI) and cost-effectiveness analysis.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'The type of device used by the constituent to interact with the campaign. Informs mobile-first design decisions and channel optimization.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementScore rdf:type rdf:Property ;
    rdfs:label 'Engagement Score' ;
    rdfs:comment 'A calculated score representing the depth and quality of constituent engagement with this touchpoint. Higher scores indicate more meaningful interactions. Used for constituent segmentation and predictive modeling.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feedbackProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Feedback Provided Flag' ;
    rdfs:comment 'Indicates whether the constituent provided feedback or comments as part of this touchpoint interaction. Aligns with Core Humanitarian Standard (CHS) Commitment 5 on feedback and complaints mechanisms.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feedbackText rdf:type rdf:Property ;
    rdfs:label 'Feedback Text' ;
    rdfs:comment 'The verbatim feedback or comment provided by the constituent during this touchpoint interaction. Supports qualitative analysis and constituent sentiment tracking.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicLocation rdf:type rdf:Property ;
    rdfs:label 'Geographic Location' ;
    rdfs:comment 'The geographic location (city, region, or country) from which the constituent engaged with the campaign. Supports geographic segmentation and localized campaign strategies.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO 639-1 language code representing the language in which the campaign communication was delivered. Supports multilingual campaign management.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageSubject rdf:type rdf:Property ;
    rdfs:label 'Message Subject' ;
    rdfs:comment 'The subject line or headline of the communication that generated this touchpoint (e.g., email subject, social media post headline). Used for content performance analysis.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageVariant rdf:type rdf:Property ;
    rdfs:label 'Message Variant' ;
    rdfs:comment 'The specific variant or version of the campaign message (e.g., \'Version A\', \'Version B\', \'Control Group\'). Supports A/B testing and multivariate campaign analysis.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Indicates whether the constituent opted out of future campaign communications as a result of this touchpoint. True if opted out, False otherwise.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerOrganization rdf:type rdf:Property ;
    rdfs:label 'Partner Organization' ;
    rdfs:comment 'The name of the partner Civil Society Organization (CSO), Community-Based Organization (CBO), or International Non-Governmental Organization (INGO) that facilitated or co-sponsored this touchpoint, if applicable.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseAction rdf:type rdf:Property ;
    rdfs:label 'Response Action' ;
    rdfs:comment 'Detailed description of the specific action taken by the constituent (e.g., \'Signed petition for clean water access\', \'Donated $50 to emergency relief fund\', \'Registered for virtual advocacy training\').' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'The date on which the constituent responded to or interacted with the campaign. Used for time-series analysis and campaign velocity tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'The precise timestamp when the constituent interaction occurred. Enables granular engagement timing analysis and real-time campaign monitoring.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sdgAlignment rdf:type rdf:Property ;
    rdfs:label 'Sdg Alignment' ;
    rdfs:comment 'The United Nations Sustainable Development Goal(s) that this campaign touchpoint supports (e.g., \'SDG 1: No Poverty\', \'SDG 6: Clean Water and Sanitation\'). Enables impact reporting aligned with global development frameworks.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'A sentiment analysis score ranging from -1.00 (very negative) to +1.00 (very positive) derived from feedback text or interaction behavior. Used for constituent satisfaction monitoring.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeToConversionHours rdf:type rdf:Property ;
    rdfs:label 'Time To Conversion Hours' ;
    rdfs:comment 'The number of hours elapsed between the initial campaign exposure and this touchpoint conversion. Null if no conversion occurred. Used for campaign velocity and urgency analysis.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:touchpointSequence rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Sequence' ;
    rdfs:comment 'The sequential order of this touchpoint within the constituent\'s overall campaign journey. Enables path analysis and multi-touch attribution modeling.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:touchpointType rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Type' ;
    rdfs:comment 'The type of interaction or engagement action taken by the constituent in response to the campaign. Examples include email opened, petition signed, event attended, donation made, social media share.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unsubscribeReason rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Reason' ;
    rdfs:comment 'The reason provided by the constituent for opting out or unsubscribing from campaign communications. Null if no opt-out occurred.' ;
    rdfs:domain ind:CampaignTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.obligation. Business justification: Communication plans fulfill compliance obligations (donor reporting schedules, IATI publication requirements, CHS disclosure commitments). Real process: obligation-driven planning where compliance req' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:planApprovedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Plan Approved By Staff Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who approved this communication plan. Captures accountability for plan authorization.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:planStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Plan Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who owns and is accountable for this communication plan. Primary point of contact for plan execution and reporting.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:systemPlatformId rdf:type rdf:Property ;
    rdfs:label 'System Platform Id' ;
    rdfs:comment 'Reference to the emergency or crisis response this communication plan supports, if applicable. Used for humanitarian coordination and SitRep (Situation Report) generation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:adminLevel1 rdf:type rdf:Property ;
    rdfs:label 'Admin Level 1' ;
    rdfs:comment 'First-level administrative division (e.g., state, province, region) where the communication plan is focused, if applicable. Supports subnational targeting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adminLevel2 rdf:type rdf:Property ;
    rdfs:label 'Admin Level 2' ;
    rdfs:comment 'Second-level administrative division (e.g., district, county, municipality) where the communication plan is focused, if applicable. Supports local targeting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'The approval status of the communication plan: pending (awaiting review), approved (cleared for execution), rejected (not approved), or conditional (approved with modifications required).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelMix rdf:type rdf:Property ;
    rdfs:label 'Channel Mix' ;
    rdfs:comment 'The combination of communication channels to be used (e.g., social media, email, website, print, radio, community meetings, SMS, WhatsApp). Reflects ICT4D (Information and Communication Technology for Development) strategy.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Required' ;
    rdfs:comment 'Indicates whether this communication plan requires compliance or legal review before execution (e.g., for donor restrictions, brand guidelines, regulatory requirements).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crisisContext rdf:type rdf:Property ;
    rdfs:label 'Crisis Context' ;
    rdfs:comment 'Description of the humanitarian crisis or emergency context this communication plan addresses, if applicable (e.g., earthquake response, refugee crisis, disease outbreak). Used for SitRep (Situation Report) generation and OCHA coordination.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableType rdf:type rdf:Property ;
    rdfs:label 'Deliverable Type' ;
    rdfs:comment 'The primary type of communication deliverable this plan produces: strategy document (comprehensive plan), SitRep (Situation Report for OCHA/cluster coordination), briefing note (executive summary), donor report (accountability document), impact story (narrative), press release (media announcement), or social media content (digital engagement). [ENUM-REF-CANDIDATE: strategy_document|sitrep|briefing_note|donor_report|impact_story|press_release|social_media_content — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionList rdf:type rdf:Property ;
    rdfs:label 'Distribution List' ;
    rdfs:comment 'The list of recipients or distribution channels for communication deliverables (e.g., donor email list, media contacts, cluster coordination groups, internal staff). May reference external distribution list IDs.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic coverage level of the communication plan: global (worldwide), regional (multi-country), national (single country), subnational (province/state), or local (community/district).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyMessages rdf:type rdf:Property ;
    rdfs:label 'Key Messages' ;
    rdfs:comment 'Core messages and narratives to be communicated through this plan. Captures the strategic messaging framework aligned with Theory of Change (ToC) and organizational mission.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logframeReference rdf:type rdf:Property ;
    rdfs:label 'Logframe Reference' ;
    rdfs:comment 'Reference to the Logical Framework (LogFrame) indicators or outputs this communication plan supports, if applicable. Used for MEL (Monitoring Evaluation and Learning) alignment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerOrganizations rdf:type rdf:Property ;
    rdfs:label 'Partner Organizations' ;
    rdfs:comment 'Names of partner organizations (CSOs, INGOs, CBOs) collaborating on this communication plan, if applicable. Supports joint messaging and coordination.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Unique business identifier or reference code for the communication plan, used for external reporting and coordination.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'The official name or title of the communication plan, used for identification and reference across the organization.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the communication plan: draft (initial development), under review (pending approval), approved (ready for execution), active (currently being implemented), on hold (temporarily suspended), completed (execution finished), or archived (historical record). [ENUM-REF-CANDIDATE: draft|under_review|approved|active|on_hold|completed|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the communication plan by its primary purpose: strategic (long-term organizational), operational (program-specific), emergency response (crisis/humanitarian), campaign (fundraising/awareness), donor engagement (stewardship), or advocacy (policy influence).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'End date of the reporting period for recurring deliverables such as SitReps (Situation Reports), donor updates, or MEL (Monitoring Evaluation and Learning) communications.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'Start date of the reporting period for recurring deliverables such as SitReps (Situation Reports), donor updates, or MEL (Monitoring Evaluation and Learning) communications.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Team' ;
    rdfs:comment 'The team, department, or unit responsible for developing and executing this communication plan (e.g., Communications, Advocacy, MEL, Field Operations).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'The operational scope or coverage level of the communication plan: organizational (enterprise-wide), program (multi-project initiative), project (single intervention), emergency (crisis response), campaign (time-bound initiative), or thematic (issue-specific).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Description of the primary audience segments this communication plan is designed to reach (e.g., donors, beneficiaries, media, government, partners, internal staff, general public). May include multiple segments separated by semicolons.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tocLinkage rdf:type rdf:Property ;
    rdfs:label 'Toc Linkage' ;
    rdfs:comment 'Description of how this communication plan links to the organizations or programs Theory of Change (ToC), including which outcomes or impact pathways it supports.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communityAwarenessSessionId rdf:type rdf:Property ;
    rdfs:label 'Community Awareness Session Id' ;
    rdfs:comment 'Foreign key linking to safeguarding.community_awareness_session. Business justification: Community engagement events may BE safeguarding awareness sessions. Links community mobilization activities to protection programming, enabling tracking of awareness-raising efforts, participant reach' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommunityAwarenessSession .

ind:linkedFeedbackCaseId rdf:type rdf:Property ;
    rdfs:label 'Linked Feedback Case Id' ;
    rdfs:comment 'Identifier of a formal feedback or complaint case that was raised or discussed during this engagement event.' ;
    rdfs:domain ind:CommunityEngagementEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeedbackCase .

ind:linkedProgramActivityImplementationPlanId rdf:type rdf:Property ;
    rdfs:label 'Linked Program Activity Implementation Plan Id' ;
    rdfs:comment 'Identifier of a program activity or intervention that this engagement event is linked to or supports.' ;
    rdfs:domain ind:CommunityEngagementEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ImplementationPlan .

ind:volunteerDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Volunteer Deployment Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer_deployment. Business justification: Volunteer deployments frequently include facilitation of community engagement events (focus groups, consultations, feedback sessions). Linking deployment to event supports volunteer hour attribution, ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VolunteerDeployment .

ind:actionPoints rdf:type rdf:Property ;
    rdfs:label 'Action Points' ;
    rdfs:comment 'List of follow-up actions, commitments, or next steps agreed upon during the community engagement event.' ;
    rdfs:domain ind:CommunityEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communityActionPlanOutput rdf:type rdf:Property ;
    rdfs:label 'Community Action Plan Output' ;
    rdfs:comment 'Summary of the community action plan or participatory assessment outputs generated during the event.' ;
    rdfs:domain ind:CommunityEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The calendar date on which the community engagement event took place or is scheduled to take place. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event End Timestamp' ;
    rdfs:comment 'Precise date and time when the community engagement event concluded. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CommunityEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Reference Number' ;
    rdfs:comment 'Externally-known business identifier for the community engagement event, used for tracking and reporting purposes.' ;
    rdfs:domain ind:CommunityEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Start Timestamp' ;
    rdfs:comment 'Precise date and time when the community engagement event started. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CommunityEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the community engagement event.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the community engagement activity. FGD = Focus Group Discussion; IVR = Interactive Voice Response; U-Report = UNICEF digital engagement platform. [ENUM-REF-CANDIDATE: town_hall|fgd|community_radio|beneficiary_forum|participatory_assessment|ivr_survey|chatbot_interaction|u_report_poll|community_meeting|listening_session — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitatorName rdf:type rdf:Property ;
    rdfs:label 'Facilitator Name' ;
    rdfs:comment 'Full name of the facilitator who led the community engagement event.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackReceived rdf:type rdf:Property ;
    rdfs:label 'Feedback Received' ;
    rdfs:comment 'Detailed feedback, suggestions, or complaints received from participants during the event.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyThemesRaised rdf:type rdf:Property ;
    rdfs:label 'Key Themes Raised' ;
    rdfs:comment 'Summary of the main themes, concerns, or topics raised by community members during the engagement event.' ;
    rdfs:domain ind:CommunityEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantsAdults rdf:type rdf:Property ;
    rdfs:label 'Participants Adults' ;
    rdfs:comment 'Number of adult participants (typically 25-59 years), supporting age-disaggregated reporting.' ;
    rdfs:domain ind:CommunityEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantsChildren rdf:type rdf:Property ;
    rdfs:label 'Participants Children' ;
    rdfs:comment 'Number of child participants (typically under 18 years), supporting age-disaggregated reporting.' ;
    rdfs:domain ind:CommunityEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantsElderly rdf:type rdf:Property ;
    rdfs:label 'Participants Elderly' ;
    rdfs:comment 'Number of elderly participants (typically 60+ years), supporting age-disaggregated reporting.' ;
    rdfs:domain ind:CommunityEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantsFemale rdf:type rdf:Property ;
    rdfs:label 'Participants Female' ;
    rdfs:comment 'Number of female participants, supporting gender-disaggregated reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantsMale rdf:type rdf:Property ;
    rdfs:label 'Participants Male' ;
    rdfs:comment 'Number of male participants, supporting gender-disaggregated reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantsOtherGender rdf:type rdf:Property ;
    rdfs:label 'Participants Other Gender' ;
    rdfs:comment 'Number of participants identifying as other or non-binary gender, supporting inclusive gender-disaggregated reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantsWithDisability rdf:type rdf:Property ;
    rdfs:label 'Participants With Disability' ;
    rdfs:comment 'Number of participants with disabilities, supporting inclusive programming and disability-disaggregated reporting.' ;
    rdfs:domain ind:CommunityEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantsYouth rdf:type rdf:Property ;
    rdfs:label 'Participants Youth' ;
    rdfs:comment 'Number of youth participants (typically 18-24 years), supporting age-disaggregated reporting.' ;
    rdfs:domain ind:CommunityEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'Primary language used during the community engagement event.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Modified Timestamp' ;
    rdfs:comment 'Timestamp when this community engagement event record was last modified. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CommunityEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalParticipants rdf:type rdf:Property ;
    rdfs:label 'Total Participants' ;
    rdfs:comment 'Total number of community members who participated in the engagement event.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:translationProvided rdf:type rdf:Property ;
    rdfs:label 'Translation Provided' ;
    rdfs:comment 'Indicates whether translation or interpretation services were provided during the event.' ;
    rdfs:domain ind:CommunityEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:venueName rdf:type rdf:Property ;
    rdfs:label 'Venue Name' ;
    rdfs:comment 'Name or description of the physical or virtual venue where the event was held (e.g., community center, school, online platform).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constituentConsentId rdf:type rdf:Property ;
    rdfs:label 'Constituent Consent Id' ;
    rdfs:comment 'Unique identifier for the constituent consent record. Primary key.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentSourceCampaignId rdf:type rdf:Property ;
    rdfs:label 'Consent Source Campaign Id' ;
    rdfs:comment 'Reference to the marketing or fundraising campaign that prompted or collected this consent, enabling attribution and campaign effectiveness analysis.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:primaryConstituentStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Constituent Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or system user who created this consent record in the system.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: Consent records support privacy regulatory filings (GDPR Article 30 records, CCPA disclosures). Real process: annual privacy compliance reporting aggregates consent data, filing references supporting ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:applicableRegulation rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulation' ;
    rdfs:comment 'The primary data protection regulation governing this consent record based on the constituent\'s jurisdiction: GDPR (EU General Data Protection Regulation), CCPA (California Consumer Privacy Act), POPIA (South Africa Protection of Personal Information Act), LGPD (Brazil Lei Geral de Proteção de Dados), PIPEDA (Canada Personal Information Protection and Electronic Documents Act), DPA_2018 (UK Data Protection Act 2018), or other jurisdiction-specific law. [ENUM-REF-CANDIDATE: GDPR|CCPA|POPIA|LGPD|PIPEDA|DPA_2018|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelEmail rdf:type rdf:Property ;
    rdfs:label 'Channel Email' ;
    rdfs:comment 'Boolean flag indicating whether the constituent has consented to receive communications via email for this consent type. True = opted in, False = opted out.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelInPerson rdf:type rdf:Property ;
    rdfs:label 'Channel In Person' ;
    rdfs:comment 'Boolean flag indicating whether the constituent has consented to in-person contact (e.g., field visits, community meetings, door-to-door outreach) for this consent type.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelPhone rdf:type rdf:Property ;
    rdfs:label 'Channel Phone' ;
    rdfs:comment 'Boolean flag indicating whether the constituent has consented to receive voice calls for this consent type.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelPostalMail rdf:type rdf:Property ;
    rdfs:label 'Channel Postal Mail' ;
    rdfs:comment 'Boolean flag indicating whether the constituent has consented to receive physical mail communications for this consent type.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelSms rdf:type rdf:Property ;
    rdfs:label 'Channel Sms' ;
    rdfs:comment 'Boolean flag indicating whether the constituent has consented to receive communications via SMS/text message for this consent type.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelSocialMedia rdf:type rdf:Property ;
    rdfs:label 'Channel Social Media' ;
    rdfs:comment 'Boolean flag indicating whether the constituent has consented to receive communications via social media platforms (Facebook, Twitter, LinkedIn, etc.) for this consent type.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelWhatsapp rdf:type rdf:Property ;
    rdfs:label 'Channel Whatsapp' ;
    rdfs:comment 'Boolean flag indicating whether the constituent has consented to receive communications via WhatsApp messaging for this consent type. Particularly relevant for ICT4D (Information and Communication Technology for Development) community engagement.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentBasis rdf:type rdf:Property ;
    rdfs:label 'Consent Basis' ;
    rdfs:comment 'The lawful basis under data protection regulations for processing this constituent\'s data: explicit_consent (affirmative opt-in), legitimate_interest (business interest balanced against rights), contractual (necessary for service delivery), legal_obligation, vital_interest (life-or-death), public_task.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'The date on which this consent expires and must be re-confirmed. Null for consents with no expiration. Used for time-limited consent models required by some jurisdictions.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentGrantedDate rdf:type rdf:Property ;
    rdfs:label 'Consent Granted Date' ;
    rdfs:comment 'The date on which the constituent provided their consent or opt-in for this communication type and channel.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentGrantedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Granted Timestamp' ;
    rdfs:comment 'Precise timestamp (including time zone) when the constituent granted consent, used for audit and compliance verification.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentProofDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Consent Proof Document Url' ;
    rdfs:comment 'URL or file path to a stored copy of the signed consent form, email confirmation, or other documentary evidence of consent. Critical for audit and regulatory compliance.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Consent Source Url' ;
    rdfs:comment 'The full URL of the web page or form where the consent was collected, used for audit and user experience analysis.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the consent policy or privacy notice that was in effect when this consent was granted (e.g., v1.0, v2.3). Enables tracking of consent under different policy iterations.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentWithdrawnDate rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawn Date' ;
    rdfs:comment 'The date on which the constituent withdrew their previously granted consent or opted out. Null if consent has not been withdrawn.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentWithdrawnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawn Timestamp' ;
    rdfs:comment 'Precise timestamp when the constituent withdrew consent, critical for ensuring no further processing occurs after this moment.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:constituentCountryCode rdf:type rdf:Property ;
    rdfs:label 'Constituent Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the constituent\'s primary country of residence or jurisdiction, used to determine applicable data protection regulations.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmation Date' ;
    rdfs:comment 'The date on which the constituent confirmed their consent via double opt-in process. Null if double opt-in was not used or not yet confirmed.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:doubleOptInConfirmed rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmed' ;
    rdfs:comment 'Boolean flag indicating whether the constituent has completed a double opt-in process (e.g., clicked a confirmation link sent via email). True = confirmed, False = pending confirmation or single opt-in only.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'The IP address from which the consent was submitted, captured for audit and fraud prevention purposes. May be considered PII in some jurisdictions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMinor rdf:type rdf:Property ;
    rdfs:label 'Is Minor' ;
    rdfs:comment 'Boolean flag indicating whether the constituent was a minor (under age of consent, typically under 16 or 18 depending on jurisdiction) at the time consent was granted. Triggers additional parental/guardian consent requirements under GDPR and COPPA.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentDate rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Date' ;
    rdfs:comment 'The date on which parental or guardian consent was obtained for a minor constituent. Null if not applicable or not obtained.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentalConsentObtained rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Obtained' ;
    rdfs:comment 'Boolean flag indicating whether parental or guardian consent was obtained for a minor constituent. True = parental consent obtained, False = not obtained or not applicable (constituent is not a minor).' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceContentTopics rdf:type rdf:Property ;
    rdfs:label 'Preference Content Topics' ;
    rdfs:comment 'Comma-separated list or free-text description of specific content topics or program areas the constituent is interested in receiving communications about (e.g., WASH, education, health, emergency response, SDG alignment). Supports targeted, relevant constituent engagement.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceFrequency rdf:type rdf:Property ;
    rdfs:label 'Preference Frequency' ;
    rdfs:comment 'The constituent\'s preferred frequency for receiving communications of this type: daily, weekly, monthly, quarterly, as_needed (event-driven), or never (opted out).' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySource rdf:type rdf:Property ;
    rdfs:label 'Third Party Source' ;
    rdfs:comment 'Name of the third-party platform or partner organization through which this consent was collected (e.g., Facebook Lead Ads, partner NGO, event registration platform). Null if collected directly.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'The browser or application user agent string captured at the time of consent submission, used for audit and device/platform analytics.' ;
    rdfs:domain ind:ConstituentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisisCommunicationId rdf:type rdf:Property ;
    rdfs:label 'Crisis Communication Id' ;
    rdfs:comment 'Foreign key linking to communication.crisis_communication. Business justification: During crisis events, the organization sends messages to constituents (donors, partners, media) as part of crisis response. This optional FK links individual messages to the crisis communication event' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrisisCommunication .

ind:emailBroadcastId rdf:type rdf:Property ;
    rdfs:label 'Email Broadcast Id' ;
    rdfs:comment 'Foreign key linking to communication.email_broadcast. Business justification: Individual constituent messages are often generated from bulk email broadcasts. This link enables attribution tracking (which broadcast generated this message), delivery analytics, and response tracki' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmailBroadcast .

ind:feedbackCaseId rdf:type rdf:Property ;
    rdfs:label 'Feedback Case Id' ;
    rdfs:comment 'Foreign key linking to communication.feedback_case. Business justification: Constituent messages can be part of feedback case communication threads (e.g., case updates, resolution notifications, follow-up inquiries). This link enables tracking all communications related to a ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeedbackCase .

ind:safeguardingIncidentId rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Incident Id' ;
    rdfs:comment 'Foreign key linking to safeguarding.safeguarding_incident. Business justification: Constituent messages may report or reference safeguarding incidents requiring investigation. Supports communication monitoring, incident reporting workflows, and audit trails for donor accountability ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafeguardingIncident .

ind:stewardshipActivityId rdf:type rdf:Property ;
    rdfs:label 'Stewardship Activity Id' ;
    rdfs:comment 'Identifier of the stewardship activity if this message is part of donor cultivation or acknowledgment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StewardshipActivity .

ind:threadId rdf:type rdf:Property ;
    rdfs:label 'Thread Id' ;
    rdfs:comment 'Identifier linking this message to a conversation thread or email chain.' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MessageThread .

ind:userAccountId rdf:type rdf:Property ;
    rdfs:label 'User Account Id' ;
    rdfs:comment 'Identifier of the staff member or user assigned to respond to or follow up on this message.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of attachments included with this message.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bodyExcerpt rdf:type rdf:Property ;
    rdfs:label 'Body Excerpt' ;
    rdfs:comment 'Excerpt or summary of the message body content. Full body may be stored in a separate content management system.' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bounceReason rdf:type rdf:Property ;
    rdfs:label 'Bounce Reason' ;
    rdfs:comment 'Reason code or description if the message bounced or failed delivery (e.g., invalid address, mailbox full, spam filter).' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickedFlag rdf:type rdf:Property ;
    rdfs:label 'Clicked Flag' ;
    rdfs:comment 'Boolean flag indicating whether the recipient clicked any link within the message.' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clickedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clicked Timestamp' ;
    rdfs:comment 'Date and time when the recipient first clicked a link in the message, in ISO 8601 format.' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complaintFlag rdf:type rdf:Property ;
    rdfs:label 'Complaint Flag' ;
    rdfs:comment 'Boolean flag indicating whether this message is a complaint or feedback requiring follow-up per CHS Commitment 5.' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentReference rdf:type rdf:Property ;
    rdfs:label 'Consent Reference' ;
    rdfs:comment 'Reference to the consent record or consent ID that authorized this communication.' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current delivery status of the message (sent, delivered, failed, bounced, pending, queued).' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Date and time when the message was successfully delivered to the recipient, in ISO 8601 format.' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalMessageCode rdf:type rdf:Property ;
    rdfs:label 'External Message Code' ;
    rdfs:comment 'Unique identifier from the external communication platform or email service provider (e.g., Salesforce Marketing Cloud message ID, Twilio SMS ID).' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-3 three-letter language code indicating the language of the message content.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageDirection rdf:type rdf:Property ;
    rdfs:label 'Message Direction' ;
    rdfs:comment 'Direction of the message flow: inbound (received from constituent) or outbound (sent to constituent).' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageType rdf:type rdf:Property ;
    rdfs:label 'Message Type' ;
    rdfs:comment 'Type or category of the message (acknowledgment, appeal, newsletter, survey, complaint, feedback, inquiry, program update, alert, event invitation). [ENUM-REF-CANDIDATE: acknowledgment|appeal|newsletter|survey|complaint|feedback|inquiry|update|alert|invitation — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openedFlag rdf:type rdf:Property ;
    rdfs:label 'Opened Flag' ;
    rdfs:comment 'Boolean flag indicating whether the recipient opened the message (tracked via pixel or read receipt).' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'Date and time when the message was first opened by the recipient, in ISO 8601 format.' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opt Out Timestamp' ;
    rdfs:comment 'Date and time when the recipient opted out or unsubscribed, in ISO 8601 format.' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level of the message (low, normal, high, urgent).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientEmail rdf:type rdf:Property ;
    rdfs:label 'Recipient Email' ;
    rdfs:comment 'Email address of the recipient (for outbound, constituent email; for inbound, organizational email).' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Name of the recipient (for outbound messages, the constituent name; for inbound, the organizational recipient).' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPhone rdf:type rdf:Property ;
    rdfs:label 'Recipient Phone' ;
    rdfs:comment 'Phone number of the recipient (for SMS, WhatsApp, phone, or IVR channels).' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repliedFlag rdf:type rdf:Property ;
    rdfs:label 'Replied Flag' ;
    rdfs:comment 'Boolean flag indicating whether the recipient replied to this message.' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Replied Timestamp' ;
    rdfs:comment 'Date and time when the recipient replied to the message, in ISO 8601 format.' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Target date by which a response to this message is due, in yyyy-MM-dd format.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Response Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether this message requires a response or follow-up action.' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:senderEmail rdf:type rdf:Property ;
    rdfs:label 'Sender Email' ;
    rdfs:comment 'Email address of the sender (for outbound, organizational email; for inbound, constituent email).' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderName rdf:type rdf:Property ;
    rdfs:label 'Sender Name' ;
    rdfs:comment 'Name of the sender (for outbound messages, typically the organization or staff member; for inbound, the constituent name).' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent Timestamp' ;
    rdfs:comment 'Date and time when the message was sent (for outbound) or received (for inbound), in ISO 8601 format.' ;
    rdfs:domain ind:ConstituentMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Subject line or title of the message.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCrisisManagerStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Crisis Manager Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member serving as the overall crisis manager coordinating the response across all functions.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:sitrepId rdf:type rdf:Property ;
    rdfs:label 'Sitrep Id' ;
    rdfs:comment 'Identifier linking this crisis communication event to the corresponding Situation Report (SitRep) in the field operations system.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sitrep .

ind:tertiaryCrisisCommunicationsLeadStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Crisis Communications Lead Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the communications team lead responsible for managing all communications activities during the crisis.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'The date when the crisis communication response was officially activated and the crisis management protocol was triggered.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activation Timestamp' ;
    rdfs:comment 'The precise date and time when the crisis communication response was activated, including timezone information.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affectedBeneficiariesEstimatedCount rdf:type rdf:Property ;
    rdfs:label 'Affected Beneficiaries Estimated Count' ;
    rdfs:comment 'Estimated number of beneficiaries (Persons of Concern, Internally Displaced Persons, program participants) affected by this crisis event.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedCountries rdf:type rdf:Property ;
    rdfs:label 'Affected Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3-letter country codes for countries affected by this crisis (e.g., \'HTI,DOM\' for Haiti and Dominican Republic).' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProgramsCount rdf:type rdf:Property ;
    rdfs:label 'Affected Programs Count' ;
    rdfs:comment 'Number of organizational programs impacted by this crisis event.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crisisCode rdf:type rdf:Property ;
    rdfs:label 'Crisis Code' ;
    rdfs:comment 'Short alphanumeric code used to reference the crisis internally and in communications systems (e.g., \'CRS-2024-001\').' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisisCommunicationStatus rdf:type rdf:Property ;
    rdfs:label 'Crisis Communication Status' ;
    rdfs:comment 'Current lifecycle status of the crisis communication response: monitoring (potential crisis being watched), activated (crisis response initiated), active (ongoing response), deactivating (winding down), closed (response complete), archived (historical record).' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisisDescription rdf:type rdf:Property ;
    rdfs:label 'Crisis Description' ;
    rdfs:comment 'Detailed narrative description of the crisis event, including background, context, timeline of events, and impact on organizational operations and beneficiaries.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisisName rdf:type rdf:Property ;
    rdfs:label 'Crisis Name' ;
    rdfs:comment 'The official name or title assigned to the crisis communication event (e.g., \'Hurricane Maria Response 2023\', \'Data Breach Incident Q2 2024\').' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisisType rdf:type rdf:Property ;
    rdfs:label 'Crisis Type' ;
    rdfs:comment 'Classification of the crisis event: natural disaster (earthquake, flood, hurricane), security incident (armed conflict, kidnapping), reputational risk (media scandal, donor complaint), health emergency (disease outbreak, pandemic), operational disruption (system failure, supply chain breakdown), or safeguarding incident (Gender-Based Violence allegation, child protection concern).' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'The date when the crisis communication response was officially deactivated and normal operations resumed. Null if crisis is still active.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deactivationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivation Timestamp' ;
    rdfs:comment 'The precise date and time when the crisis communication response was deactivated, including timezone information. Null if crisis is still active.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:donorNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Notification Required Flag' ;
    rdfs:comment 'Indicates whether formal notification to donors was required for this crisis event due to program impact, fund restrictions, or contractual obligations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:donorNotificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Donor Notification Sent Date' ;
    rdfs:comment 'The date when formal notification was sent to affected donors regarding the crisis and its impact on programs or operations.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalCommunicationsChannelMix rdf:type rdf:Property ;
    rdfs:label 'External Communications Channel Mix' ;
    rdfs:comment 'Comma-separated list of external communication channels used during the crisis response (e.g., \'press_release,social_media,website,email,radio,community_meetings\').' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalCommunicationsChannelMix rdf:type rdf:Property ;
    rdfs:label 'Internal Communications Channel Mix' ;
    rdfs:comment 'Comma-separated list of internal communication channels used to keep staff and volunteers informed during the crisis (e.g., \'email,intranet,town_hall,team_meetings,instant_messaging\').' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyMessagesApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Key Messages Approval Date' ;
    rdfs:comment 'The date when the key messages were officially approved by leadership for use in crisis communications.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:keyMessagesApproved rdf:type rdf:Property ;
    rdfs:label 'Key Messages Approved' ;
    rdfs:comment 'The official approved key messages and talking points for use in all crisis communications. These messages are vetted by leadership and legal counsel.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
    rdfs:comment 'Key lessons learned from the crisis response, including what worked well, what could be improved, and recommendations for future crisis communications.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaInquiriesReceivedCount rdf:type rdf:Property ;
    rdfs:label 'Media Inquiries Received Count' ;
    rdfs:comment 'Total number of media inquiries received from journalists, news outlets, and media organizations during this crisis event.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mediaInquiriesRespondedCount rdf:type rdf:Property ;
    rdfs:label 'Media Inquiries Responded Count' ;
    rdfs:comment 'Total number of media inquiries that received an official response from the organization during this crisis event.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postCrisisReviewDate rdf:type rdf:Property ;
    rdfs:label 'Post Crisis Review Date' ;
    rdfs:comment 'The date when the post-crisis review meeting or assessment was conducted.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postCrisisReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Post Crisis Review Status' ;
    rdfs:comment 'Status of the post-crisis review and lessons learned process: not started, scheduled, in progress, completed (review done), published (findings shared).' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressReleasesIssuedCount rdf:type rdf:Property ;
    rdfs:label 'Press Releases Issued Count' ;
    rdfs:comment 'Total number of official press releases issued to media during this crisis event.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryReportSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted Date' ;
    rdfs:comment 'The date when required regulatory reports were submitted to relevant authorities regarding the crisis event.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Indicates whether regulatory reporting to government agencies, charity commissions, or oversight bodies was required for this crisis event.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Response Actions Taken' ;
    rdfs:comment 'Detailed narrative of the communications response actions taken during the crisis, including press releases issued, social media posts, stakeholder briefings, town halls, and other communication activities.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Analysis of the underlying root causes that led to or exacerbated the crisis, used for organizational learning and prevention of future incidents.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'The assessed severity of the crisis event: low (minimal impact, localized), medium (moderate impact, regional), high (significant impact, multi-country), critical (catastrophic impact, organization-wide threat).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaPostsCount rdf:type rdf:Property ;
    rdfs:label 'Social Media Posts Count' ;
    rdfs:comment 'Total number of social media posts published across all organizational channels during this crisis event.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spokespersonName rdf:type rdf:Property ;
    rdfs:label 'Spokesperson Name' ;
    rdfs:comment 'Full name of the designated spokesperson for quick reference in communications materials and media coordination.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderBriefingsCount rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Briefings Count' ;
    rdfs:comment 'Total number of stakeholder briefings conducted with donors, partners, board members, and other key stakeholders during this crisis event.' ;
    rdfs:domain ind:CrisisCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:digitalContentId rdf:type rdf:Property ;
    rdfs:label 'Digital Content Id' ;
    rdfs:comment 'Unique identifier for the digital content asset. Primary key for the digital content product.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactStoryId rdf:type rdf:Property ;
    rdfs:label 'Impact Story Id' ;
    rdfs:comment 'Foreign key linking to communication.impact_story. Business justification: Digital content pieces are often based on or feature impact stories. This link enables tracking which stories are being amplified through digital channels, measuring story reach, and ensuring proper c' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ImpactStory .

ind:primaryDigitalStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Digital Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who authored or created the digital content asset.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:tertiaryDigitalAuthorStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Digital Author Staff Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accountHandle rdf:type rdf:Property ;
    rdfs:label 'Account Handle' ;
    rdfs:comment 'The specific social media account handle or username from which the content was published (e.g., @OrganizationName).' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Publish Timestamp' ;
    rdfs:comment 'The actual date and time when the content was published or went live on the platform.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'The date and time when the content was approved for publication by the designated reviewer.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bodyText rdf:type rdf:Property ;
    rdfs:label 'Body Text' ;
    rdfs:comment 'The main textual content or narrative of the digital asset, including article body, post caption, or email message content.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickThroughCount rdf:type rdf:Property ;
    rdfs:label 'Click Through Count' ;
    rdfs:comment 'Total number of clicks on links embedded within the content, driving traffic to external pages or donation forms.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Content Reference Number' ;
    rdfs:comment 'Externally-visible unique reference number for the digital content asset, used for tracking and citation purposes across communications channels.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentStatus rdf:type rdf:Property ;
    rdfs:label 'Content Status' ;
    rdfs:comment 'Current lifecycle status of the digital content asset in the publication workflow (draft, scheduled, published, archived, expired, withdrawn).' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentType rdf:type rdf:Property ;
    rdfs:label 'Content Type' ;
    rdfs:comment 'Classification of the digital content asset by format and medium (website page, blog post, social media post, email newsletter, infographic, video, podcast). [ENUM-REF-CANDIDATE: website_page|blog_post|social_media_post|email_newsletter|infographic|video|podcast — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementCommentsCount rdf:type rdf:Property ;
    rdfs:label 'Engagement Comments Count' ;
    rdfs:comment 'Total number of comments, replies, or direct responses received on the content.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementLikesCount rdf:type rdf:Property ;
    rdfs:label 'Engagement Likes Count' ;
    rdfs:comment 'Total number of likes, favorites, or positive reactions received on the content across the publication platform.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementSharesCount rdf:type rdf:Property ;
    rdfs:label 'Engagement Shares Count' ;
    rdfs:comment 'Total number of shares, retweets, or forwards of the content by users on the platform.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hashtags rdf:type rdf:Property ;
    rdfs:label 'Hashtags' ;
    rdfs:comment 'Comma-separated list of hashtags used with the content for social media discoverability and campaign tracking (e.g., #SDG, #WASH, #HumanitarianAid).' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionsCount rdf:type rdf:Property ;
    rdfs:label 'Impressions Count' ;
    rdfs:comment 'Total number of times the content was displayed or viewed, including multiple views by the same user.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAccessibilityCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Accessibility Compliant' ;
    rdfs:comment 'Indicates whether the content meets accessibility standards (WCAG 2.1 AA) for users with disabilities, including alt text, captions, and screen reader compatibility.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBrandCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Brand Compliant' ;
    rdfs:comment 'Indicates whether the content adheres to organizational brand guidelines including logo usage, color palette, tone of voice, and messaging standards.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The date and time when the content was last modified or updated after initial publication.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mediaFileUrl rdf:type rdf:Property ;
    rdfs:label 'Media File Url' ;
    rdfs:comment 'The URL of the primary media file (video, audio, PDF) associated with the content, if applicable.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moderationStatus rdf:type rdf:Property ;
    rdfs:label 'Moderation Status' ;
    rdfs:comment 'Status of content review and approval process (pending review, approved, rejected, flagged for revision).' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platform rdf:type rdf:Property ;
    rdfs:label 'Platform' ;
    rdfs:comment 'The digital platform or channel where the content is published (website, Facebook, Twitter/X, Instagram, LinkedIn, YouTube, TikTok, email). [ENUM-REF-CANDIDATE: website|facebook|twitter|instagram|linkedin|youtube|tiktok|email — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachCount rdf:type rdf:Property ;
    rdfs:label 'Reach Count' ;
    rdfs:comment 'Total number of unique users who saw the content at least once, as reported by the platform analytics.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Publish Timestamp' ;
    rdfs:comment 'The date and time when the content was scheduled to be published, as planned in the content calendar.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:seoKeywords rdf:type rdf:Property ;
    rdfs:label 'Seo Keywords' ;
    rdfs:comment 'Comma-separated list of keywords targeted for search engine optimization and content discoverability.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoMetaDescription rdf:type rdf:Property ;
    rdfs:label 'Seo Meta Description' ;
    rdfs:comment 'The meta description tag providing a concise summary for search engine results pages.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoMetaTitle rdf:type rdf:Property ;
    rdfs:label 'Seo Meta Title' ;
    rdfs:comment 'The meta title tag optimized for search engine indexing and display in search results.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitle rdf:type rdf:Property ;
    rdfs:label 'Subtitle' ;
    rdfs:comment 'Secondary headline or subtitle providing additional context for the digital content asset.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Brief summary or excerpt of the content used for previews, social sharing, and search engine descriptions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated list of topical or thematic tags for content categorization and search (e.g., health, education, emergency response).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'The URL of the thumbnail or preview image associated with the content for display in feeds and previews.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'The headline or title of the digital content asset as displayed to the audience.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:url rdf:type rdf:Property ;
    rdfs:label 'Url' ;
    rdfs:comment 'The full web address (URL) where the content is published and accessible online.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoViewsCount rdf:type rdf:Property ;
    rdfs:label 'Video Views Count' ;
    rdfs:comment 'Total number of video views or plays for video content assets, as reported by the hosting platform.' ;
    rdfs:domain ind:DigitalContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:donorStewardshipTouchpointId rdf:type rdf:Property ;
    rdfs:label 'Donor Stewardship Touchpoint Id' ;
    rdfs:comment 'Unique identifier for each donor stewardship touchpoint interaction record.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DonorStewardshipTouchpoint .

ind:linkedGiftId rdf:type rdf:Property ;
    rdfs:label 'Linked Gift Id' ;
    rdfs:comment 'Reference to the specific gift or donation that this stewardship touchpoint is acknowledging or reporting on. Links to gift transaction records.' ;
    rdfs:domain ind:DonorStewardshipTouchpoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gift .

ind:linkedGrantAwardId rdf:type rdf:Property ;
    rdfs:label 'Linked Grant Award Id' ;
    rdfs:comment 'Reference to the grant or award that this stewardship touchpoint is related to, for institutional funders. Links to grant award records.' ;
    rdfs:domain ind:DonorStewardshipTouchpoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Award .

ind:primaryDonorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Donor Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or relationship manager responsible for executing this stewardship touchpoint. Links to workforce or staff master data.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:contentUsed rdf:type rdf:Property ;
    rdfs:label 'Content Used' ;
    rdfs:comment 'Description or identifier of the content asset used in this touchpoint, such as impact story title, annual report edition, or presentation deck name.' ;
    rdfs:domain ind:DonorStewardshipTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Direct cost incurred for executing this stewardship touchpoint, including materials, postage, event costs, or staff time allocation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cost amount associated with this touchpoint.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Computed data quality score ranging from 0.00 to 1.00, reflecting the completeness and accuracy of this touchpoint record based on validation rules.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorFeedbackText rdf:type rdf:Property ;
    rdfs:label 'Donor Feedback Text' ;
    rdfs:comment 'Free-text notes capturing any verbal or written feedback provided by the donor during or after this stewardship touchpoint.' ;
    rdfs:domain ind:DonorStewardshipTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorResponse rdf:type rdf:Property ;
    rdfs:label 'Donor Response' ;
    rdfs:comment 'Categorical assessment of the donors response or reaction to this stewardship touchpoint, captured by the staff owner.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorTier rdf:type rdf:Property ;
    rdfs:label 'Donor Tier' ;
    rdfs:comment 'Segmentation tier of the donor at the time of this touchpoint, indicating their giving level and stewardship priority. [ENUM-REF-CANDIDATE: major|principal|leadership|mid_level|annual|planned_giving|corporate|foundation — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DonorStewardshipTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which the follow-up action should be completed, if follow-up is required.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpNotes rdf:type rdf:Property ;
    rdfs:label 'Follow Up Notes' ;
    rdfs:comment 'Detailed notes describing the nature of the required follow-up action and any specific donor requests or commitments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this touchpoint requires a subsequent follow-up action or additional stewardship engagement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRestrictedCommunication rdf:type rdf:Property ;
    rdfs:label 'Is Restricted Communication' ;
    rdfs:comment 'Boolean flag indicating whether this touchpoint involves donor-restricted funds or confidential program information requiring special handling.' ;
    rdfs:domain ind:DonorStewardshipTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current status of this touchpoint record in the data warehouse, indicating whether it is active, archived, or logically deleted.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointDate rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Date' ;
    rdfs:comment 'The date on which the stewardship touchpoint occurred or is scheduled to occur. Primary business event date for this interaction.' ;
    rdfs:domain ind:DonorStewardshipTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:touchpointReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Reference Number' ;
    rdfs:comment 'Business-facing unique reference number or code for this stewardship touchpoint, used for tracking and reporting purposes.' ;
    rdfs:domain ind:DonorStewardshipTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointStatus rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Status' ;
    rdfs:comment 'Current lifecycle status of the stewardship touchpoint, tracking whether it has been executed or is still pending.' ;
    rdfs:domain ind:DonorStewardshipTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointTimestamp rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Timestamp' ;
    rdfs:comment 'Precise timestamp of when the stewardship touchpoint was executed, including time-of-day for scheduled calls or meetings.' ;
    rdfs:domain ind:DonorStewardshipTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryEmailCampaignId rdf:type rdf:Property ;
    rdfs:label 'Primary Email Campaign Id' ;
    rdfs:comment 'Reference to the parent fundraising or advocacy campaign this email broadcast supports.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:primaryEmailStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Email Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who created or authored the email broadcast.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to donor.donor_segment. Business justification: Email broadcasts target specific donor segments (major donors, lapsed donors, monthly givers). Segment-based email campaign reporting requires direct segment linkage to analyze segment response rates,' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:abTestVariant rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant' ;
    rdfs:comment 'Identifier for the A/B test variant if this broadcast is part of a split test (e.g., \'A\', \'B\', \'Control\', \'Variant 1\').' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bounceCount rdf:type rdf:Property ;
    rdfs:label 'Bounce Count' ;
    rdfs:comment 'Number of emails that bounced (hard or soft bounce) and were not delivered.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcastName rdf:type rdf:Property ;
    rdfs:label 'Broadcast Name' ;
    rdfs:comment 'Internal name or title of the email broadcast for identification and reporting purposes.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastStatus rdf:type rdf:Property ;
    rdfs:label 'Broadcast Status' ;
    rdfs:comment 'Current lifecycle status of the email broadcast: draft (being prepared), scheduled (queued for future send), sending (in progress), sent (completed), cancelled (aborted before send), or failed (technical error prevented send).' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastType rdf:type rdf:Property ;
    rdfs:label 'Broadcast Type' ;
    rdfs:comment 'Classification of the email broadcast purpose: newsletter (regular updates), appeal (fundraising ask), update (program progress), stewardship (donor thank you and engagement), emergency alert (urgent humanitarian response), advocacy (policy campaign), or event invitation. [ENUM-REF-CANDIDATE: newsletter|appeal|update|stewardship|emergency_alert|advocacy|event_invitation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickCount rdf:type rdf:Property ;
    rdfs:label 'Click Count' ;
    rdfs:comment 'Total number of clicks on links within the email (includes multiple clicks by same recipient).' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Status' ;
    rdfs:comment 'Status of pre-send compliance verification for CAN-SPAM, GDPR consent, and organizational communication policies.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting compliance review findings, exceptions, or special handling requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVerified rdf:type rdf:Property ;
    rdfs:label 'Consent Verified' ;
    rdfs:comment 'Indicates whether all recipients on the list have verified opt-in consent to receive this type of communication, per GDPR and CAN-SPAM requirements.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveredCount rdf:type rdf:Property ;
    rdfs:label 'Delivered Count' ;
    rdfs:comment 'Number of emails successfully delivered to recipient inboxes.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:espPlatform rdf:type rdf:Property ;
    rdfs:label 'Esp Platform' ;
    rdfs:comment 'Name of the email service provider platform used to send the broadcast (e.g., Mailchimp, SendGrid, Salesforce Marketing Cloud).' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardBounceCount rdf:type rdf:Property ;
    rdfs:label 'Hard Bounce Count' ;
    rdfs:comment 'Number of emails that hard bounced due to invalid or non-existent email addresses.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAbTest rdf:type rdf:Property ;
    rdfs:label 'Is Ab Test' ;
    rdfs:comment 'Indicates whether this broadcast is part of an A/B testing experiment.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openCount rdf:type rdf:Property ;
    rdfs:label 'Open Count' ;
    rdfs:comment 'Total number of times the email was opened by recipients (includes multiple opens by same recipient).' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replyToEmail rdf:type rdf:Property ;
    rdfs:label 'Reply To Email' ;
    rdfs:comment 'Email address where recipient replies will be directed, may differ from sender email.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendDate rdf:type rdf:Property ;
    rdfs:label 'Send Date' ;
    rdfs:comment 'The date the email broadcast was sent or scheduled to be sent.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Send Timestamp' ;
    rdfs:comment 'The precise date and time the email broadcast was sent or scheduled to be sent.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:softBounceCount rdf:type rdf:Property ;
    rdfs:label 'Soft Bounce Count' ;
    rdfs:comment 'Number of emails that soft bounced due to temporary issues such as full inbox or server problems.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spamComplaintCount rdf:type rdf:Property ;
    rdfs:label 'Spam Complaint Count' ;
    rdfs:comment 'Number of recipients who marked the email as spam or junk.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectLine rdf:type rdf:Property ;
    rdfs:label 'Subject Line' ;
    rdfs:comment 'The email subject line text displayed to recipients in their inbox.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRecipients rdf:type rdf:Property ;
    rdfs:label 'Total Recipients' ;
    rdfs:comment 'Total number of constituent email addresses targeted for this broadcast.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uniqueClickCount rdf:type rdf:Property ;
    rdfs:label 'Unique Click Count' ;
    rdfs:comment 'Number of unique recipients who clicked at least one link in the email.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uniqueOpenCount rdf:type rdf:Property ;
    rdfs:label 'Unique Open Count' ;
    rdfs:comment 'Number of unique recipients who opened the email at least once.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unsubscribeCount rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Count' ;
    rdfs:comment 'Number of recipients who unsubscribed from the mailing list as a result of this broadcast.' ;
    rdfs:domain ind:EmailBroadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'Date when the case was assigned to a case owner for investigation and resolution.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseCategory rdf:type rdf:Property ;
    rdfs:label 'Case Category' ;
    rdfs:comment 'Primary thematic category of the feedback or complaint. Enables aggregation and trend analysis by subject area. [ENUM-REF-CANDIDATE: program_quality|staff_conduct|access_barriers|communication|safeguarding|protection|service_delivery|accountability — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FeedbackCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseSubcategory rdf:type rdf:Property ;
    rdfs:label 'Case Subcategory' ;
    rdfs:comment 'Detailed subcategory providing additional granularity within the primary case category. Supports root cause analysis and targeted improvement actions.' ;
    rdfs:domain ind:FeedbackCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseSummary rdf:type rdf:Property ;
    rdfs:label 'Case Summary' ;
    rdfs:comment 'Concise summary of the feedback or complaint content, capturing the key issue or concern raised by the submitter.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the case was formally closed after resolution confirmation and any follow-up activities completed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationTier rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier' ;
    rdfs:comment 'Current escalation level of the case. L1 represents frontline resolution, L2 represents supervisory escalation, L3 represents senior management or specialized team escalation.' ;
    rdfs:domain ind:FeedbackCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Detailed notes documenting the investigation process, findings, and evidence gathered during case resolution.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAnonymous rdf:type rdf:Property ;
    rdfs:label 'Is Anonymous' ;
    rdfs:comment 'Indicates whether the feedback or complaint was submitted anonymously without identifying information. True if anonymous, False if identified.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSensitive rdf:type rdf:Property ;
    rdfs:label 'Is Sensitive' ;
    rdfs:comment 'Indicates whether the case involves sensitive subject matter such as safeguarding, protection, Gender-Based Violence (GBV), or Sexual Exploitation and Abuse (SEA). Triggers restricted access and specialized handling protocols.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageOfSubmission rdf:type rdf:Property ;
    rdfs:label 'Language Of Submission' ;
    rdfs:comment 'Language in which the feedback or complaint was originally submitted. Supports accessibility monitoring and language service planning.' ;
    rdfs:domain ind:FeedbackCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date when the feedback or complaint was first received by the organization through any channel. Serves as the baseline for SLA tracking.' ;
    rdfs:domain ind:FeedbackCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Precise date and time when the feedback or complaint was first received. Provides granular tracking for time-sensitive cases.' ;
    rdfs:domain ind:FeedbackCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referralPathway rdf:type rdf:Property ;
    rdfs:label 'Referral Pathway' ;
    rdfs:comment 'Specialized service pathway to which the case was referred for expert handling. Critical for protection and safeguarding cases requiring multi-agency coordination. [ENUM-REF-CANDIDATE: none|protection|safeguarding|gbv|sea|health|legal|psychosocial|programmatic — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FeedbackCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresTranslation rdf:type rdf:Property ;
    rdfs:label 'Requires Translation' ;
    rdfs:comment 'Indicates whether the case requires translation services for processing or response. True if translation needed, False otherwise.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionActionTaken rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Taken' ;
    rdfs:comment 'Primary action taken to resolve the case. Supports accountability reporting on organizational responsiveness and corrective measures. [ENUM-REF-CANDIDATE: no_action|information_provided|apology_issued|service_corrected|staff_counseled|policy_changed|referral_made|compensation_provided — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FeedbackCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedDate rdf:type rdf:Property ;
    rdfs:label 'Resolved Date' ;
    rdfs:comment 'Date when the case was marked as resolved with actions completed and response provided to the submitter.' ;
    rdfs:domain ind:FeedbackCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseLanguage rdf:type rdf:Property ;
    rdfs:label 'Response Language' ;
    rdfs:comment 'Language in which the response was provided to the submitter. May differ from submission language based on submitter preference.' ;
    rdfs:domain ind:FeedbackCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseMethod rdf:type rdf:Property ;
    rdfs:label 'Response Method' ;
    rdfs:comment 'Method used to communicate the resolution response to the submitter. Aligns with submitter communication preferences.' ;
    rdfs:domain ind:FeedbackCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSentDate rdf:type rdf:Property ;
    rdfs:label 'Response Sent Date' ;
    rdfs:comment 'Date when the formal response was sent to the submitter communicating the investigation findings and resolution actions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:satisfactionFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Follow Up Date' ;
    rdfs:comment 'Date when satisfaction follow-up was conducted with the submitter to assess their satisfaction with the resolution.' ;
    rdfs:domain ind:FeedbackCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:satisfactionFollowUpOutcome rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Follow Up Outcome' ;
    rdfs:comment 'Result of follow-up contact with the submitter to assess satisfaction with the case resolution. Measures effectiveness of the feedback response mechanism.' ;
    rdfs:domain ind:FeedbackCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Due Date' ;
    rdfs:comment 'Target date by which the case must be resolved to meet SLA commitments. Calculated from receipt date plus SLA target days.' ;
    rdfs:domain ind:FeedbackCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaTargetDays rdf:type rdf:Property ;
    rdfs:label 'Sla Target Days' ;
    rdfs:comment 'Number of calendar days within which the case must be resolved according to organizational service level agreement commitments. Varies by case type and priority.' ;
    rdfs:domain ind:FeedbackCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Channel or mechanism through which the feedback or complaint was received. Supports channel effectiveness analysis and accessibility monitoring. [ENUM-REF-CANDIDATE: hotline|sms|email|web_form|mobile_app|in_person|suggestion_box|community_meeting|focus_group — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryFeedbackStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Feedback Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or case worker assigned to investigate and resolve the feedback.' ;
    rdfs:domain ind:FeedbackSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:actionTaken rdf:type rdf:Property ;
    rdfs:label 'Action Taken' ;
    rdfs:comment 'Summary of the corrective or responsive action taken to address the feedback or complaint.' ;
    rdfs:domain ind:FeedbackSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'Actual date when the feedback was resolved and closed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feedbackCategory rdf:type rdf:Property ;
    rdfs:label 'Feedback Category' ;
    rdfs:comment 'Primary classification of the feedback type: complaint, suggestion, appreciation, query, concern, or request.' ;
    rdfs:domain ind:FeedbackSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackSubcategory rdf:type rdf:Property ;
    rdfs:label 'Feedback Subcategory' ;
    rdfs:comment 'Detailed subcategory or topic area of the feedback (e.g., service quality, staff behavior, distribution timing, program eligibility, safety concern).' ;
    rdfs:domain ind:FeedbackSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresEscalation rdf:type rdf:Property ;
    rdfs:label 'Requires Escalation' ;
    rdfs:comment 'Indicates whether the feedback requires escalation to senior management, protection specialists, or external authorities.' ;
    rdfs:domain ind:FeedbackSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current status of the feedback resolution workflow: received, under review, investigating, action taken, resolved, closed, or escalated. [ENUM-REF-CANDIDATE: received|under_review|investigating|action_taken|resolved|closed|escalated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FeedbackSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date when the feedback or complaint was submitted by the beneficiary or community member.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Reference Number' ;
    rdfs:comment 'Externally-visible unique reference number for tracking and follow-up. Format: FB-YYYYMMDD-XXXXXX.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Precise date and time when the feedback was received, including timezone information.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submitterEmail rdf:type rdf:Property ;
    rdfs:label 'Submitter Email' ;
    rdfs:comment 'Email address of the submitter for follow-up communication. May be null if submission is anonymous.' ;
    rdfs:domain ind:FeedbackSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submitterName rdf:type rdf:Property ;
    rdfs:label 'Submitter Name' ;
    rdfs:comment 'Name of the person submitting the feedback. May be null if submission is anonymous.' ;
    rdfs:domain ind:FeedbackSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submitterPhone rdf:type rdf:Property ;
    rdfs:label 'Submitter Phone' ;
    rdfs:comment 'Contact phone number of the submitter for follow-up. May be null if submission is anonymous.' ;
    rdfs:domain ind:FeedbackSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submitterSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Submitter Satisfaction Rating' ;
    rdfs:comment 'Satisfaction rating provided by the submitter regarding the resolution process and outcome, typically on a scale of 1-5.' ;
    rdfs:domain ind:FeedbackSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'Target date by which the feedback should be resolved, based on severity and organizational Service Level Agreement (SLA).' ;
    rdfs:domain ind:FeedbackSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:translatedFeedbackText rdf:type rdf:Property ;
    rdfs:label 'Translated Feedback Text' ;
    rdfs:comment 'Translation of the feedback text into the organization\'s primary working language, if translation was performed.' ;
    rdfs:domain ind:FeedbackSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorFundId rdf:type rdf:Property ;
    rdfs:label 'Donor Fund Id' ;
    rdfs:comment 'Foreign key linking to donor.fund. Business justification: Impact stories are often fund-specific for restricted fund stewardship ("Your Water Fund donation built this well"). Donor reporting workflows require direct fund-to-story linkage to show fund-specifi' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DonorFund .

ind:anonymizationRequired rdf:type rdf:Property ;
    rdfs:label 'Anonymization Required' ;
    rdfs:comment 'Indicates whether the story must use anonymized or pseudonymized identifiers to protect the storyteller.' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the staff member who approved the story for publication.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveDate rdf:type rdf:Property ;
    rdfs:label 'Archive Date' ;
    rdfs:comment 'The date on which the story was archived and removed from active publication channels.' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorName rdf:type rdf:Property ;
    rdfs:label 'Author Name' ;
    rdfs:comment 'Name of the staff member, journalist, or content creator who authored or compiled the story.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentFormat rdf:type rdf:Property ;
    rdfs:label 'Content Format' ;
    rdfs:comment 'The primary media format in which the impact story is captured and presented.' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorVisibility rdf:type rdf:Property ;
    rdfs:label 'Donor Visibility' ;
    rdfs:comment 'Classification indicating which donor audiences are permitted to view this story.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embargoFlag rdf:type rdf:Property ;
    rdfs:label 'Embargo Flag' ;
    rdfs:comment 'Indicates whether the story is under embargo and should not be published until a specified date.' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:embargoUntilDate rdf:type rdf:Property ;
    rdfs:label 'Embargo Until Date' ;
    rdfs:comment 'The date until which the story is embargoed and must not be published.' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactMetric rdf:type rdf:Property ;
    rdfs:label 'Impact Metric' ;
    rdfs:comment 'Quantitative or qualitative metric that the story illustrates (e.g., lives saved, children educated, wells constructed).' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords or tags for search and categorization of the story.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaAssetUrl rdf:type rdf:Property ;
    rdfs:label 'Media Asset Url' ;
    rdfs:comment 'URL or file path to the primary media asset (photo, video, audio) associated with this story.' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photographerName rdf:type rdf:Property ;
    rdfs:label 'Photographer Name' ;
    rdfs:comment 'Name of the photographer or videographer who captured visual content for the story.' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationChannels rdf:type rdf:Property ;
    rdfs:label 'Publication Channels' ;
    rdfs:comment 'Comma-separated list of channels where this story is approved for publication (e.g., website, annual report, social media, donor newsletter).' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'The date on which the story was first published or made publicly available.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Level' ;
    rdfs:comment 'Classification of the story based on the sensitivity of the content, particularly for protection concerns such as Gender-Based Violence (GBV) or child protection.' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storyNarrative rdf:type rdf:Property ;
    rdfs:label 'Story Narrative' ;
    rdfs:comment 'The full narrative text of the impact story, including quotes, context, and outcomes.' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storySummary rdf:type rdf:Property ;
    rdfs:label 'Story Summary' ;
    rdfs:comment 'A brief executive summary or abstract of the impact story for quick reference and indexing.' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storyTitle rdf:type rdf:Property ;
    rdfs:label 'Story Title' ;
    rdfs:comment 'The headline or title of the impact story used for identification and indexing.' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storyType rdf:type rdf:Property ;
    rdfs:label 'Story Type' ;
    rdfs:comment 'Classification of the impact story format and purpose.' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storytellerType rdf:type rdf:Property ;
    rdfs:label 'Storyteller Type' ;
    rdfs:comment 'The role or relationship of the person telling or featured in the story.' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thematicArea rdf:type rdf:Property ;
    rdfs:label 'Thematic Area' ;
    rdfs:comment 'The primary programmatic or sectoral theme that the story addresses. [ENUM-REF-CANDIDATE: health|education|wash|nutrition|protection|livelihoods|shelter|emergency_response — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationAvailable rdf:type rdf:Property ;
    rdfs:label 'Translation Available' ;
    rdfs:comment 'Indicates whether translations of this story are available in other languages.' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageRights rdf:type rdf:Property ;
    rdfs:label 'Usage Rights' ;
    rdfs:comment 'Legal usage rights and restrictions for the story and associated media assets.' ;
    rdfs:domain ind:ImpactStory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaActivityId rdf:type rdf:Property ;
    rdfs:label 'Media Activity Id' ;
    rdfs:comment 'Unique identifier for the media activity record. Primary key for tracking all media relations activities including outbound press releases and earned media coverage.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Classification of the media activity distinguishing between organization-initiated communications (outbound press releases, statements, announcements) and third-party coverage (earned media, mentions, broadcast segments). [ENUM-REF-CANDIDATE: outbound_press_release|outbound_statement|outbound_announcement|earned_coverage|media_mention|broadcast_segment|podcast_feature — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Name of the senior leader or communications director who provided final approval for release. Supports governance and accountability tracking. Null for earned media.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryFeedbackFlag rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Feedback Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this media activity includes or responds to beneficiary feedback, complaints, or community voices. Supports CHS Commitment 5 compliance and participatory communications tracking.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chsCommitmentReference rdf:type rdf:Property ;
    rdfs:label 'Chs Commitment Reference' ;
    rdfs:comment 'Reference to the specific Core Humanitarian Standard commitment(s) addressed by the media activity, particularly CHS Commitment 5 on complaints and feedback mechanisms. Supports accountability and transparency reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circulationEstimate rdf:type rdf:Property ;
    rdfs:label 'Circulation Estimate' ;
    rdfs:comment 'Verified or estimated circulation, subscriber count, or audience size of the media outlet. Provides baseline for reach calculations and media value assessment.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clippingUrl rdf:type rdf:Property ;
    rdfs:label 'Clipping Url' ;
    rdfs:comment 'Web address or digital link to the published media coverage, press release archive, or media monitoring service clipping. Enables direct access to source content for verification and analysis.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentSummary rdf:type rdf:Property ;
    rdfs:label 'Content Summary' ;
    rdfs:comment 'Brief summary or abstract of the media content highlighting key messages, organizational mentions, and thematic focus. Supports content analysis and message tracking.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Primary channel or mechanism used to distribute the press release or statement to media contacts. Supports channel effectiveness analysis. Null for earned media. [ENUM-REF-CANDIDATE: wire_service|email_direct|website|social_media|media_portal|press_conference|multiple_channels — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embargoDate rdf:type rdf:Property ;
    rdfs:label 'Embargo Date' ;
    rdfs:comment 'Date and time before which the media content must not be published or disclosed. Used for coordinated release timing with media partners and stakeholders. Null if no embargo applies.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'Primary geographic market or region served by the media outlet or targeted by the release. Supports geographic segmentation and regional communications strategy. Uses country codes or regional identifiers.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'Primary language of the media content. Supports multilingual communications tracking and localization analysis. Uses ISO 639-1 two-letter language codes.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageVersions rdf:type rdf:Property ;
    rdfs:label 'Language Versions' ;
    rdfs:comment 'Comma-separated list of additional language versions produced for this media activity. Supports multilingual outreach tracking and localization coverage analysis.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaActivityStatus rdf:type rdf:Property ;
    rdfs:label 'Media Activity Status' ;
    rdfs:comment 'Current lifecycle state of the media activity from initial draft through approval workflow to final release or publication. Tracks progression through communications governance process. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|embargoed|released|published|archived|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaValueUsd rdf:type rdf:Property ;
    rdfs:label 'Media Value Usd' ;
    rdfs:comment 'Estimated advertising equivalency value of the earned media coverage in US dollars. Calculated based on outlet rates, placement prominence, and reach. Used for communications return on investment (ROI) analysis.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outletName rdf:type rdf:Property ;
    rdfs:label 'Outlet Name' ;
    rdfs:comment 'Name of the media organization, publication, broadcast network, podcast, or digital platform that published the earned coverage or received the outbound release. Key dimension for share-of-voice analysis.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outletType rdf:type rdf:Property ;
    rdfs:label 'Outlet Type' ;
    rdfs:comment 'Classification of the media outlet by format and delivery mechanism. Enables media mix analysis and channel strategy optimization. [ENUM-REF-CANDIDATE: newspaper|magazine|television|radio|podcast|online_news|blog|social_media|wire_service — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupCount rdf:type rdf:Property ;
    rdfs:label 'Pickup Count' ;
    rdfs:comment 'Number of additional media outlets or platforms that republished, syndicated, or referenced the original press release or coverage. Measures amplification and viral reach.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prominenceScore rdf:type rdf:Property ;
    rdfs:label 'Prominence Score' ;
    rdfs:comment 'Numeric score (1-10 scale) rating the visibility and prominence of the organizational mention within the media coverage. Considers placement (headline vs buried), length of mention, and inclusion of key messages.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reachEstimate rdf:type rdf:Property ;
    rdfs:label 'Reach Estimate' ;
    rdfs:comment 'Estimated number of individuals who were exposed to the media coverage based on outlet circulation, viewership, listenership, or digital analytics. Used for media value calculation and impact assessment.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Official date and time when the press release or statement was issued by the organization or when earned media coverage was published. Primary temporal reference for media tracking and analysis.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sentiment rdf:type rdf:Property ;
    rdfs:label 'Sentiment' ;
    rdfs:comment 'Qualitative assessment of the tone and framing of the earned media coverage toward the organization. Supports reputation monitoring and brand perception analysis aligned to Core Humanitarian Standard (CHS) accountability principles.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialShares rdf:type rdf:Property ;
    rdfs:label 'Social Shares' ;
    rdfs:comment 'Total count of social media shares, retweets, and reposts of the media content across digital platforms. Measures digital engagement and content virality aligned to Information and Communication Technology for Development (ICT4D) principles.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetMediaList rdf:type rdf:Property ;
    rdfs:label 'Target Media List' ;
    rdfs:comment 'Comma-separated list or identifier of the media contact lists or distribution groups targeted for this release. Supports segmentation analysis and outreach effectiveness tracking. Null for earned media.' ;
    rdfs:domain ind:MediaActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beatFocus rdf:type rdf:Property ;
    rdfs:label 'Beat Focus' ;
    rdfs:comment 'Primary subject area or beat covered by the journalist (e.g., humanitarian affairs, international development, health, education, disaster relief, SDGs, refugee crisis, WASH, GBV).' ;
    rdfs:domain ind:MediaContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blacklistReason rdf:type rdf:Property ;
    rdfs:label 'Blacklist Reason' ;
    rdfs:comment 'Explanation or justification for blacklisting the media contact, including date and nature of the incident.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blacklistStatus rdf:type rdf:Property ;
    rdfs:label 'Blacklist Status' ;
    rdfs:comment 'Indicates whether the media contact is blacklisted or restricted from receiving organizational communications due to past misrepresentation, breach of embargo, or other policy violations (True if blacklisted, False otherwise).' ;
    rdfs:domain ind:MediaContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:circulationReach rdf:type rdf:Property ;
    rdfs:label 'Circulation Reach' ;
    rdfs:comment 'Estimated audience size, circulation, or follower count of the media outlet or the individual media contact\'s platform.' ;
    rdfs:domain ind:MediaContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:embargoAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Embargo Agreement Date' ;
    rdfs:comment 'Date on which the media contact signed or verbally agreed to embargo terms.' ;
    rdfs:domain ind:MediaContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:embargoAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Embargo Agreement Flag' ;
    rdfs:comment 'Indicates whether the media contact has signed or agreed to honor embargo terms for sensitive or time-restricted information releases (True if agreement exists, False otherwise).' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'First name or given name of the journalist, editor, broadcaster, blogger, or media influencer.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete display name of the media contact, typically concatenation of first and last name or preferred professional name.' ;
    rdfs:domain ind:MediaContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Geographic region or countries covered by the media contact (e.g., Sub-Saharan Africa, Middle East, Global, specific country ISO codes).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:influenceScore rdf:type rdf:Property ;
    rdfs:label 'Influence Score' ;
    rdfs:comment 'Quantitative score representing the media contact\'s influence, reach, and impact in their coverage area, typically on a scale of 0.00 to 100.00.' ;
    rdfs:domain ind:MediaContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Professional title or role of the media contact (e.g., Senior Reporter, News Editor, Broadcast Producer, Freelance Journalist).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEngagementDate rdf:type rdf:Property ;
    rdfs:label 'Last Engagement Date' ;
    rdfs:comment 'Date of the most recent interaction, outreach, or engagement activity with the media contact (e.g., press release sent, interview conducted, event attendance).' ;
    rdfs:domain ind:MediaContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastEngagementType rdf:type rdf:Property ;
    rdfs:label 'Last Engagement Type' ;
    rdfs:comment 'Type of the most recent engagement activity (press release, interview, briefing, event, email, phone call).' ;
    rdfs:domain ind:MediaContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Last name or family name of the media contact.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile or cellular phone number for urgent or field-based contact.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInDate rdf:type rdf:Property ;
    rdfs:label 'Opt In Date' ;
    rdfs:comment 'Date on which the media contact provided consent to receive communications.' ;
    rdfs:domain ind:MediaContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInStatus rdf:type rdf:Property ;
    rdfs:label 'Opt In Status' ;
    rdfs:comment 'Indicates whether the media contact has explicitly opted in to receive press releases, media alerts, and organizational communications (True if opted in, False otherwise).' ;
    rdfs:domain ind:MediaContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary telephone number for voice contact with the media professional.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Channel' ;
    rdfs:comment 'The media contact\'s preferred method of communication (email, phone, mobile, social media, messaging app such as WhatsApp or Signal).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary email address for reaching the media contact for press releases, story pitches, and media inquiries.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipTier rdf:type rdf:Property ;
    rdfs:label 'Relationship Tier' ;
    rdfs:comment 'Classification of the strength and strategic importance of the relationship with the media contact (tier 1 strategic, tier 2 active, tier 3 occasional, tier 4 prospect).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEmail rdf:type rdf:Property ;
    rdfs:label 'Secondary Email' ;
    rdfs:comment 'Alternative or backup email address for the media contact.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryLanguages rdf:type rdf:Property ;
    rdfs:label 'Secondary Languages' ;
    rdfs:comment 'Additional languages the media contact works in, stored as comma-separated ISO 639-1 codes.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaLinkedin rdf:type rdf:Property ;
    rdfs:label 'Social Media Linkedin' ;
    rdfs:comment 'LinkedIn profile URL for professional networking and relationship building.' ;
    rdfs:domain ind:MediaContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaTwitter rdf:type rdf:Property ;
    rdfs:label 'Social Media Twitter' ;
    rdfs:comment 'Twitter (X) username or handle of the media contact for social media engagement and monitoring.' ;
    rdfs:domain ind:MediaContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Unique identifier of the media contact record in the source system, used for data lineage and reconciliation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEngagementCount rdf:type rdf:Property ;
    rdfs:label 'Total Engagement Count' ;
    rdfs:comment 'Cumulative number of documented engagements or interactions with this media contact since record creation.' ;
    rdfs:domain ind:MediaContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Primary key for audit_finding' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Reference to the parent audit engagement or Single Audit under which this finding was identified.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:singleAuditId rdf:type rdf:Property ;
    rdfs:label 'Single Audit Id' ;
    rdfs:comment 'Foreign key linking to compliance.single_audit. Business justification: Audit findings discovered during Single Audit engagements (OMB Uniform Guidance 2 CFR 200) should reference the specific Single Audit. The existing audit_id points to safeguarding.audit (cross-domain)' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SingleAudit .

ind:vulnerabilityId rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Id' ;
    rdfs:comment 'Foreign key linking to technology.vulnerability. Business justification: Compliance audit findings may identify technical vulnerabilities (weak access controls, unpatched systems, data exposure). Nonprofits must link findings to vulnerabilities for integrated risk manageme' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vulnerability .

ind:auditPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit Period End Date' ;
    rdfs:comment 'The end date of the audit period during which this finding was identified. Typically the end of the organization\'s fiscal year under audit.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Audit Period Start Date' ;
    rdfs:comment 'The start date of the audit period during which this finding was identified. Typically the beginning of the organization\'s fiscal year under audit.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Name of the external audit firm or auditor who identified this finding during the audit engagement.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causeDescription rdf:type rdf:Property ;
    rdfs:label 'Cause Description' ;
    rdfs:comment 'Explanation of the underlying reason or root cause that led to the condition. This identifies why the deficiency occurred (e.g., lack of training, inadequate controls, resource constraints).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cfdaNumber rdf:type rdf:Property ;
    rdfs:label 'Cfda Number' ;
    rdfs:comment 'The five-digit CFDA number (now known as Assistance Listings number) identifying the federal program under which the finding was identified. Format is XX.XXX where the first two digits represent the federal agency and the last three represent the specific program.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirementType rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Type' ;
    rdfs:comment 'The specific type of compliance requirement that was violated or not met, as defined in the OMB Compliance Supplement (e.g., Activities Allowed or Unallowed, Allowable Costs/Cost Principles, Cash Management, Eligibility, Equipment and Real Property Management, Matching, Period of Performance, Procurement, Program Income, Reporting, Subrecipient Monitoring, Special Tests and Provisions).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionDescription rdf:type rdf:Property ;
    rdfs:label 'Condition Description' ;
    rdfs:comment 'Detailed description of the actual condition or deficiency found during the audit. This describes what the auditor observed or identified as problematic.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Criteria Description' ;
    rdfs:comment 'Description of the required standard, regulation, policy, or grant provision that was not met. This establishes the benchmark against which the condition is measured.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectDescription rdf:type rdf:Property ;
    rdfs:label 'Effect Description' ;
    rdfs:comment 'Description of the actual or potential impact or consequence of the finding. This explains what harm or risk resulted from the condition (e.g., misstated financial statements, unallowable costs charged to grant, noncompliance with donor restrictions).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Resolution Date' ;
    rdfs:comment 'The target date by which the organization expects to fully resolve and remediate this finding based on the corrective action plan.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Fac Submission Date' ;
    rdfs:comment 'The date on which the audit report containing this finding was submitted to the Federal Audit Clearinghouse. Null if not yet submitted.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:federalAgencyName rdf:type rdf:Property ;
    rdfs:label 'Federal Agency Name' ;
    rdfs:comment 'Name of the federal agency that provided the funding for the program under which this finding was identified (e.g., USAID, BHA, Department of State, HHS).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:federalAwardIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Federal Award Identification Number' ;
    rdfs:comment 'The unique Federal Award Identification Number assigned by the federal agency to the specific award under which this finding was identified.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingIdentifiedDate rdf:type rdf:Property ;
    rdfs:label 'Finding Identified Date' ;
    rdfs:comment 'The date on which the auditor formally identified and documented this finding during the audit fieldwork or reporting process.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Reference Number' ;
    rdfs:comment 'The externally-known unique reference number assigned to this audit finding by the auditor, typically following the format YYYY-NNN or similar audit-specific numbering convention.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the audit finding. Open indicates newly identified and not yet addressed. In remediation indicates corrective action plan is being implemented. Resolved indicates corrective actions completed and pending verification. Closed indicates finding fully remediated and verified. Repeat finding indicates this issue was identified in a prior audit period.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingTitle rdf:type rdf:Property ;
    rdfs:label 'Finding Title' ;
    rdfs:comment 'Brief descriptive title or summary of the audit finding, providing a high-level overview of the issue identified.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Classification of the audit finding based on severity and nature. Material weakness indicates a deficiency or combination of deficiencies in internal control such that there is a reasonable possibility that a material misstatement will not be prevented or detected. Significant deficiency is less severe than a material weakness but important enough to merit attention. Questioned cost represents costs that do not comply with grant terms. Noncompliance indicates violation of laws, regulations, or grant provisions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFraudIndicator rdf:type rdf:Property ;
    rdfs:label 'Is Fraud Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this finding includes indicators of potential fraud, waste, or abuse. True if fraud indicators are present and require further investigation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMaterialWeakness rdf:type rdf:Property ;
    rdfs:label 'Is Material Weakness' ;
    rdfs:comment 'Boolean flag indicating whether this finding represents a material weakness in internal control over financial reporting or compliance. True if the finding is classified as a material weakness.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeatFinding rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Finding' ;
    rdfs:comment 'Boolean flag indicating whether this finding was previously identified in a prior audit period and has not been fully resolved. True if this is a repeat finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSignificantDeficiency rdf:type rdf:Property ;
    rdfs:label 'Is Significant Deficiency' ;
    rdfs:comment 'Boolean flag indicating whether this finding represents a significant deficiency in internal control. True if the finding is classified as a significant deficiency.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managementResponse rdf:type rdf:Property ;
    rdfs:label 'Management Response' ;
    rdfs:comment 'The organization\'s management response to the audit finding, including agreement or disagreement with the finding and planned corrective actions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorFindingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Prior Finding Reference Number' ;
    rdfs:comment 'Reference number of the prior audit finding if this is a repeat finding. Links to the original finding from a previous audit period.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:questionedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Questioned Cost Amount' ;
    rdfs:comment 'The monetary amount of costs questioned by the auditor due to noncompliance with grant terms, unallowable costs, or lack of supporting documentation. Null if the finding does not involve questioned costs.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:questionedCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Questioned Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the questioned cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationDescription rdf:type rdf:Property ;
    rdfs:label 'Recommendation Description' ;
    rdfs:comment 'Auditor\'s recommendation for corrective action to address the finding. This provides guidance on steps the organization should take to remediate the deficiency.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedToFederalAuditClearinghouse rdf:type rdf:Property ;
    rdfs:label 'Reported To Federal Audit Clearinghouse' ;
    rdfs:comment 'Boolean flag indicating whether this finding has been reported to the Federal Audit Clearinghouse as part of the Single Audit submission. True if reported to FAC.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'The internal department or functional area responsible for addressing and remediating this finding (e.g., Finance, Program Operations, Grants Management, Human Resources).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the individual assigned primary responsibility for implementing the corrective action plan and resolving this finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Classification of the type of risk this finding represents (e.g., Financial Risk, Compliance Risk, Operational Risk, Reputational Risk, Fraud Risk).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chsSelfAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Chs Self Assessment Id' ;
    rdfs:comment 'Unique identifier for the CHS self-assessment cycle record.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChsSelfAssessment .

ind:assessmentSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Assessment System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: CHS self-assessments use specific platforms for data collection, evidence management, and verification (quality management systems, survey tools). Nonprofits must track which platform houses assessmen' ;
    rdfs:domain ind:ChsSelfAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.obligation. Business justification: CHS (Core Humanitarian Standard) self-assessments satisfy CHS compliance obligations. The obligation table tracks chs_self_assessment_required flag. One assessment satisfies one obligation instance; o' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:pseaPolicyId rdf:type rdf:Property ;
    rdfs:label 'Psea Policy Id' ;
    rdfs:comment 'Foreign key linking to safeguarding.psea_policy. Business justification: CHS Commitment 5 requires PSEA policy implementation and assessment. Real business process: humanitarian standards compliance verification where CHS self-assessments evaluate organizational PSEA polic' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PseaPolicy .

ind:assessmentCode rdf:type rdf:Property ;
    rdfs:label 'Assessment Code' ;
    rdfs:comment 'Business identifier for the self-assessment cycle, typically formatted as CHS-[Country]-[Year]-[Sequence].' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Assessment Methodology' ;
    rdfs:comment 'The methodology used to conduct the CHS self-assessment: internal self-assessment (staff-led), peer review (peer organization review), independent verification (third-party auditor), hybrid (combination of methods).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'General notes, observations, and contextual information about the self-assessment process and findings.' ;
    rdfs:domain ind:ChsSelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period End Date' ;
    rdfs:comment 'The end date of the period being assessed for CHS conformity.' ;
    rdfs:domain ind:ChsSelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period Start Date' ;
    rdfs:comment 'The start date of the period being assessed for CHS conformity.' ;
    rdfs:domain ind:ChsSelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Assessment Team Members' ;
    rdfs:comment 'Comma-separated list of names of team members who participated in the self-assessment process.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationTargetFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Target Flag' ;
    rdfs:comment 'Indicates whether this self-assessment is being conducted as part of a formal CHS certification process (True) or for internal improvement purposes only (False).' ;
    rdfs:domain ind:ChsSelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

