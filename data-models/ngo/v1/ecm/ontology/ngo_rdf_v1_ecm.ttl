    rdfs:domain ind:ChsSelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAssessorName rdf:type rdf:Property ;
    rdfs:label 'Lead Assessor Name' ;
    rdfs:comment 'Full name of the lead assessor responsible for coordinating the CHS self-assessment process.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'Scheduled date for the next CHS self-assessment cycle, typically 12-24 months after the current assessment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallConformityRating rdf:type rdf:Property ;
    rdfs:label 'Overall Conformity Rating' ;
    rdfs:comment 'Aggregate conformity rating across all nine CHS commitments: non-conforming (significant gaps), partially conforming (some evidence), largely conforming (most requirements met), fully conforming (all requirements met), not assessed (assessment incomplete).' ;
    rdfs:domain ind:ChsSelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallConformityScore rdf:type rdf:Property ;
    rdfs:label 'Overall Conformity Score' ;
    rdfs:comment 'Numeric overall conformity score calculated as the average of all commitment ratings, typically on a scale of 1.00 to 5.00.' ;
    rdfs:domain ind:ChsSelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationBody rdf:type rdf:Property ;
    rdfs:label 'Verification Body' ;
    rdfs:comment 'Name of the CHS Alliance-approved verification body or independent auditor that conducted third-party verification, if applicable.' ;
    rdfs:domain ind:ChsSelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementingChangeRequestId rdf:type rdf:Property ;
    rdfs:label 'Implementing Change Request Id' ;
    rdfs:comment 'Foreign key linking to technology.change_request. Business justification: Corrective actions for compliance findings often require system changes (access controls, workflow modifications, reporting enhancements). Nonprofits must link CAPs to change requests for implementati' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeRequest .

ind:internalReviewId rdf:type rdf:Property ;
    rdfs:label 'Internal Review Id' ;
    rdfs:comment 'Foreign key linking to compliance.internal_review. Business justification: Internal compliance reviews generate findings that require corrective action plans. One CAP addresses one internal review finding; one review may generate multiple CAPs (one per finding). This paralle' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalReview .

ind:modifiedByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Modified By Staff Member Id' ;
    rdfs:comment 'Identifier of the user who last modified the corrective action plan record.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:primaryCorrectiveStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Corrective Staff Member Id' ;
    rdfs:comment 'Identifier of the manager or staff member accountable for implementing the corrective action plan.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:tertiaryCorrectiveResponsibleManagerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Corrective Responsible Manager Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when the corrective action plan was fully implemented and verified as complete. Null if still in progress.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual financial cost incurred to implement the corrective action plan. Null if not yet completed or cost not tracked.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditReportReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Reference' ;
    rdfs:comment 'Reference to the audit report document that contains the original finding, including report number and page reference.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capNumber rdf:type rdf:Property ;
    rdfs:label 'Cap Number' ;
    rdfs:comment 'Business identifier for the corrective action plan, typically formatted as CAP-YYYY-NNN or similar organizational convention.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capStatus rdf:type rdf:Property ;
    rdfs:label 'Cap Status' ;
    rdfs:comment 'Current lifecycle status of the corrective action plan, tracking progress from initiation through closure. [ENUM-REF-CANDIDATE: draft|open|in_progress|pending_verification|closed|overdue|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed narrative describing the specific corrective actions to be taken to address the finding, including process changes, policy updates, training, or system enhancements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for estimated and actual costs.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Donor Notification Date' ;
    rdfs:comment 'Date when the donor or funding agency was notified of the finding and corrective action plan. Null if notification not required or not yet sent.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Donor Notification Required' ;
    rdfs:comment 'Indicates whether the donor or funding agency must be notified of the finding and corrective action plan per grant agreement terms.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated financial cost to implement the corrective action plan, including staff time, system changes, training, and other resources.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findingId rdf:type rdf:Property ;
    rdfs:label 'Finding Id' ;
    rdfs:comment 'Reference to the audit finding, CHS non-conformity, or compliance issue that triggered this corrective action plan.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingSeverity rdf:type rdf:Property ;
    rdfs:label 'Finding Severity' ;
    rdfs:comment 'Severity level of the finding as assessed by auditors or compliance reviewers, indicating urgency and risk exposure.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveMeasures rdf:type rdf:Property ;
    rdfs:label 'Preventive Measures' ;
    rdfs:comment 'Description of preventive measures implemented to reduce the risk of recurrence, such as policy changes, training programs, or system controls.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceRisk rdf:type rdf:Property ;
    rdfs:label 'Recurrence Risk' ;
    rdfs:comment 'Assessment of the risk that the finding could recur if corrective actions are not sustained or are inadequately implemented.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Date' ;
    rdfs:comment 'Date when the finding and corrective action plan were reported to regulatory authorities. Null if reporting not required or not yet submitted.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether the finding and corrective action plan must be reported to regulatory authorities such as IRS, Charity Commission, or OCHA.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sphereStandardReference rdf:type rdf:Property ;
    rdfs:label 'Sphere Standard Reference' ;
    rdfs:comment 'Reference to the specific Sphere Humanitarian Charter or Minimum Standard that was not met, if the finding relates to humanitarian quality standards.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the corrective action plan is expected to be fully implemented and closed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationNotes rdf:type rdf:Property ;
    rdfs:label 'Verification Notes' ;
    rdfs:comment 'Detailed notes from the verification process, documenting evidence reviewed and conclusions reached regarding corrective action effectiveness.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Donor reporting requirements are fulfilled through specific platforms (grants management systems, donor portals, reporting tools). Nonprofits must track which system fulfills each requirement for work' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:modifiedByUserStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Staff Member Id' ;
    rdfs:comment 'Reference to the user who last modified this compliance requirement record, used for audit trail and accountability.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:actualEffortHours rdf:type rdf:Property ;
    rdfs:label 'Actual Effort Hours' ;
    rdfs:comment 'The actual number of staff hours expended in fulfilling this compliance requirement, used for future planning and cost analysis.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:associatedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Associated Cost Amount' ;
    rdfs:comment 'The direct financial cost incurred to fulfill this compliance requirement, including consultant fees, audit costs, or system expenses.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current status of the organization\'s compliance with this requirement, tracking progress from initiation through approval or waiver. [ENUM-REF-CANDIDATE: not_started|in_progress|submitted|under_review|approved|overdue|waived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableFormat rdf:type rdf:Property ;
    rdfs:label 'Deliverable Format' ;
    rdfs:comment 'The required format or medium for the compliance deliverable, such as PDF report, online portal submission, or physical document.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Donor Contact Email' ;
    rdfs:comment 'The email address of the donor representative responsible for receiving and reviewing compliance submissions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorContactName rdf:type rdf:Property ;
    rdfs:label 'Donor Contact Name' ;
    rdfs:comment 'The name of the donor representative or point of contact for questions and submissions related to this compliance requirement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The date by which the compliance requirement must be fulfilled and submitted to the donor.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date on which this compliance requirement expires or is no longer applicable, typically aligned with grant closure.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date from which this compliance requirement becomes active and applicable to the grant.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Effort Hours' ;
    rdfs:comment 'The estimated number of staff hours required to complete and submit this compliance requirement.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Internal Policy Reference' ;
    rdfs:comment 'Reference to the organization\'s internal policy or procedure document that governs how this compliance requirement is fulfilled.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceConsequence rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Consequence' ;
    rdfs:comment 'Description of the potential consequences or penalties for failing to meet this compliance requirement, such as grant suspension, fund recovery, or donor relationship damage.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Risk Level' ;
    rdfs:comment 'The assessed risk level to the organization if this compliance requirement is not met, considering financial, reputational, and operational impacts.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedRegulationReference rdf:type rdf:Property ;
    rdfs:label 'Related Regulation Reference' ;
    rdfs:comment 'Reference to the specific regulatory framework, law, or standard that underpins this donor requirement, such as OMB 2 CFR 200, IATI, or CHS.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementDescription rdf:type rdf:Property ;
    rdfs:label 'Requirement Description' ;
    rdfs:comment 'Detailed narrative description of the compliance requirement, including specific obligations, deliverables, and conditions imposed by the donor.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Requirement Reference Number' ;
    rdfs:comment 'External reference number or code assigned by the donor to this compliance requirement, used for tracking and correspondence.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementTitle rdf:type rdf:Property ;
    rdfs:label 'Requirement Title' ;
    rdfs:comment 'Short descriptive title of the compliance requirement for quick identification and reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'The channel or mechanism through which the compliance deliverable must be submitted to the donor.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Url' ;
    rdfs:comment 'URL or file path to supporting documentation, templates, or guidance materials related to this compliance requirement.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Flag' ;
    rdfs:comment 'Indicates whether the donor has approved a waiver or exemption for this compliance requirement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverJustification rdf:type rdf:Property ;
    rdfs:label 'Waiver Justification' ;
    rdfs:comment 'The rationale or explanation provided for requesting a waiver from this compliance requirement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Requested Flag' ;
    rdfs:comment 'Indicates whether the organization has formally requested a waiver or exemption from this compliance requirement.' ;
    rdfs:domain ind:DonorRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governancePolicyId rdf:type rdf:Property ;
    rdfs:label 'Governance Policy Id' ;
    rdfs:comment 'Unique identifier for the governance policy record. Primary key.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GovernancePolicy .

ind:documentSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Document System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Governance policies are managed in document management or governance platforms for version control, approval workflow, and access management. Nonprofits track which system houses each policy for board' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:supersededByPolicyGovernancePolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Policy Governance Policy Id' ;
    rdfs:comment 'Reference to the governance policy that supersedes this document. Used to track policy version lineage when a new version replaces an older one. Null if this is the current active version.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GovernancePolicy .

ind:annualCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Annual Certification Status' ;
    rdfs:comment 'For conflict-of-interest (COI) disclosures: the status of the annual COI certification requirement for the disclosing party. Indicates whether the annual disclosure has been completed, is pending, is overdue, or is not required for this document type.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'The governing body or individual who formally approved the policy. Typically the Board of Directors, Executive Director, or designated committee.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'For conflict-of-interest (COI) disclosures: the date on which the disclosing party signed the annual COI certification. Null for non-COI documents or uncertified disclosures.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'The external regulatory or industry standard framework that the governance policy is designed to satisfy (e.g., IRS 501(c)(3), Charity Commission, Core Humanitarian Standard, GDPR, OMB Uniform Guidance 2 CFR 200).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosingParty rdf:type rdf:Property ;
    rdfs:label 'Disclosing Party' ;
    rdfs:comment 'For conflict-of-interest (COI) disclosures: the name of the board member, officer, or key employee making the disclosure. Null for non-COI documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentOwner rdf:type rdf:Property ;
    rdfs:label 'Document Owner' ;
    rdfs:comment 'The department, role, or individual responsible for maintaining, updating, and ensuring compliance with the governance policy.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'The file path or URL where the full governance policy document is stored in the organization\'s document management system or cloud storage.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date on which the governance policy becomes binding and enforceable within the organization.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governancePolicyCategory rdf:type rdf:Property ;
    rdfs:label 'Governance Policy Category' ;
    rdfs:comment 'The functional category or domain of the governance policy. Includes financial management, human resources (HR), safeguarding, anti-fraud, data protection, and conflict-of-interest (COI) policies.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governancePolicyDescription rdf:type rdf:Property ;
    rdfs:label 'Governance Policy Description' ;
    rdfs:comment 'A detailed narrative description of the governance policy\'s purpose, scope, and key provisions.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governancePolicyStatus rdf:type rdf:Property ;
    rdfs:label 'Governance Policy Status' ;
    rdfs:comment 'Current lifecycle status of the governance policy. Indicates whether the document is in draft, active and enforceable, under review for revision, superseded by a newer version, or archived.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irs990DisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Irs 990 Disclosure Required' ;
    rdfs:comment 'Boolean flag indicating whether this governance policy or resolution must be disclosed on the organization\'s IRS Form 990 (Schedule O or Part VI).' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'The date on which the governance policy was most recently reviewed by the responsible authority.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingDate rdf:type rdf:Property ;
    rdfs:label 'Meeting Date' ;
    rdfs:comment 'For board resolutions: the date of the board or committee meeting at which the resolution was passed. Null for non-resolution documents.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingType rdf:type rdf:Property ;
    rdfs:label 'Meeting Type' ;
    rdfs:comment 'For board resolutions: the type of meeting at which the resolution was passed (regular, special, annual, or emergency). Null for non-resolution documents.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:natureOfConflict rdf:type rdf:Property ;
    rdfs:label 'Nature Of Conflict' ;
    rdfs:comment 'For conflict-of-interest (COI) disclosures: a description of the nature and circumstances of the potential or actual conflict of interest. Null for non-COI documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'The scheduled date for the next mandatory review of the governance policy.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'The official name or title of the governance policy, resolution, bylaw, or charter document.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'The unique business identifier or reference number assigned to the governance document for tracking and citation purposes.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Boolean flag indicating whether this governance policy is publicly available or must be disclosed to donors, regulators, or the public under transparency requirements.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recusalDecision rdf:type rdf:Property ;
    rdfs:label 'Recusal Decision' ;
    rdfs:comment 'For conflict-of-interest (COI) disclosures: whether the disclosing party recused themselves from decision-making related to the conflict. Null for non-COI documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedParty rdf:type rdf:Property ;
    rdfs:label 'Related Party' ;
    rdfs:comment 'For conflict-of-interest (COI) disclosures: the name of the related party (individual, organization, or entity) involved in the conflict. Null for non-COI documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNumber rdf:type rdf:Property ;
    rdfs:label 'Resolution Number' ;
    rdfs:comment 'For board resolutions: the unique sequential identifier assigned to the resolution for tracking and reference. Null for non-resolution documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionText rdf:type rdf:Property ;
    rdfs:label 'Resolution Text' ;
    rdfs:comment 'For board resolutions: the full text of the resolution as recorded in the meeting minutes. Null for non-resolution documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'The frequency in months at which the governance policy is scheduled for mandatory review and potential revision.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Review Outcome' ;
    rdfs:comment 'For conflict-of-interest (COI) disclosures: the outcome of the board or committee review of the disclosed conflict (approved with safeguards, mitigated through controls, prohibited transaction, or still under review). Null for non-COI documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'The version number or identifier of the governance document, tracking revisions and updates over time.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voteOutcome rdf:type rdf:Property ;
    rdfs:label 'Vote Outcome' ;
    rdfs:comment 'For board resolutions: the outcome of the vote on the resolution (passed, failed, tabled for future consideration, or withdrawn). Null for non-resolution documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votesAbstained rdf:type rdf:Property ;
    rdfs:label 'Votes Abstained' ;
    rdfs:comment 'For board resolutions: the number of board members who abstained from voting on the resolution. Null for non-resolution documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:votesAgainst rdf:type rdf:Property ;
    rdfs:label 'Votes Against' ;
    rdfs:comment 'For board resolutions: the number of votes cast against the resolution. Null for non-resolution documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:votesFor rdf:type rdf:Property ;
    rdfs:label 'Votes For' ;
    rdfs:comment 'For board resolutions: the number of votes cast in favor of the resolution. Null for non-resolution documents.' ;
    rdfs:domain ind:GovernancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iatiPublicationId rdf:type rdf:Property ;
    rdfs:label 'Iati Publication Id' ;
    rdfs:comment 'Unique identifier for the IATI publication record. Primary key for tracking individual publication events to the IATI Registry.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publishingSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Publishing System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: IATI publications are generated from and published through specific platforms (grants management system, IATI publisher tool). Nonprofits track which system produced each publication for data quality ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:supersededByPublicationIatiPublicationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Publication Iati Publication Id' ;
    rdfs:comment 'Reference to the newer IATI publication that replaces this record. Null if this is the current active publication.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IatiPublication .

ind:activityCount rdf:type rdf:Property ;
    rdfs:label 'Activity Count' ;
    rdfs:comment 'Total number of IATI activity records included in this publication. Used for completeness validation and registry statistics.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Completeness Percentage' ;
    rdfs:comment 'Percentage of recommended IATI fields populated across all activities in this publication. Measures adherence to IATI best practices for comprehensive reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'Username or identifier of the staff member who initiated this IATI publication. Used for accountability and change management.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorRequirementCompliance rdf:type rdf:Property ;
    rdfs:label 'Donor Requirement Compliance' ;
    rdfs:comment 'Assessment of whether this publication meets specific IATI transparency requirements mandated by major donors (USAID, FCDO, DAC members). Used for grant compliance reporting.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the published IATI XML file in bytes. Used for technical monitoring and registry performance optimization.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iatiOrganizationIdentifier rdf:type rdf:Property ;
    rdfs:label 'Iati Organization Identifier' ;
    rdfs:comment 'The globally unique IATI organization identifier assigned by the IATI Registry. Format follows IATI standard: country code, registration agency, and registration number (e.g., US-EIN-123456789).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatiVersion rdf:type rdf:Property ;
    rdfs:label 'Iati Version' ;
    rdfs:comment 'The version of the IATI Standard used for this publication (e.g., 2.03, 2.02, 1.05). Determines schema validation rules and available fields.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current lifecycle status of this IATI publication. Published indicates active availability on the registry; superseded indicates replacement by a newer version.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationType rdf:type rdf:Property ;
    rdfs:label 'Publication Type' ;
    rdfs:comment 'Type of IATI file published: organization-level file containing organizational metadata, or activity-level file containing individual project/program records.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publisherContactEmail rdf:type rdf:Property ;
    rdfs:label 'Publisher Contact Email' ;
    rdfs:comment 'Email address of the organizational contact responsible for this IATI publication. Used for data quality inquiries and registry communications.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientCountryCount rdf:type rdf:Property ;
    rdfs:label 'Recipient Country Count' ;
    rdfs:comment 'Number of distinct recipient countries covered by activities in this publication. Indicates geographic scope of transparency reporting.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registryDatasetCode rdf:type rdf:Property ;
    rdfs:label 'Registry Dataset Code' ;
    rdfs:comment 'Unique dataset identifier assigned by the IATI Registry system. Used for programmatic access via IATI Registry API.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code used for financial values in this publication (e.g., USD, EUR, GBP). All monetary amounts are expressed in this currency.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'The end date of the reporting period covered by this IATI publication. Used to assess data currency and timeliness compliance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'The start date of the reporting period covered by this IATI publication. Defines the temporal scope of activities and financial data included.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sectorCount rdf:type rdf:Property ;
    rdfs:label 'Sector Count' ;
    rdfs:comment 'Number of distinct Development Assistance Committee (DAC) sector codes represented in this publication. Indicates thematic diversity of reported activities.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timelinessCategory rdf:type rdf:Property ;
    rdfs:label 'Timeliness Category' ;
    rdfs:comment 'Qualitative assessment of publication timeliness based on the timeliness score. Used for donor reporting and transparency benchmarking.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timelinessScore rdf:type rdf:Property ;
    rdfs:label 'Timeliness Score' ;
    rdfs:comment 'Calculated score (0-100) measuring how current the published data is relative to the reporting period end date. Higher scores indicate more timely transparency reporting.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBudgetValue rdf:type rdf:Property ;
    rdfs:label 'Total Budget Value' ;
    rdfs:comment 'Aggregate budget value across all activities included in this publication, in the organization\'s reporting currency. Provides summary financial transparency metric.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDisbursementValue rdf:type rdf:Property ;
    rdfs:label 'Total Disbursement Value' ;
    rdfs:comment 'Aggregate actual disbursement value across all activities in this publication, in the organization\'s reporting currency. Represents total funds deployed during the reporting period.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationErrorCount rdf:type rdf:Property ;
    rdfs:label 'Validation Error Count' ;
    rdfs:comment 'Number of schema validation errors detected in the published IATI file. Zero indicates full technical compliance with the IATI Standard.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationWarningCount rdf:type rdf:Property ;
    rdfs:label 'Validation Warning Count' ;
    rdfs:comment 'Number of non-critical warnings identified during IATI validation. Warnings indicate recommended improvements but do not prevent publication.' ;
    rdfs:domain ind:IatiPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedCountryOfficeId rdf:type rdf:Property ;
    rdfs:label 'Affected Country Office Id' ;
    rdfs:comment 'Identifier of the country office or field location where the incident occurred.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CountryOffice .

ind:itIncidentId rdf:type rdf:Property ;
    rdfs:label 'It Incident Id' ;
    rdfs:comment 'Foreign key linking to technology.it_incident. Business justification: Compliance incidents (fraud, data breach, misconduct) often trigger or relate to IT security incidents. Nonprofits must link these for coordinated investigation, root cause analysis, and integrated co' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItIncident .

ind:allegationCategory rdf:type rdf:Property ;
    rdfs:label 'Allegation Category' ;
    rdfs:comment 'Specific category of the allegation within the broader incident type. Supports detailed classification for MEL and donor reporting. [ENUM-REF-CANDIDATE: corruption|theft|misappropriation|conflict_of_interest|harassment|discrimination|safeguarding_violation|data_breach|regulatory_noncompliance — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Summary of corrective actions, disciplinary measures, or process improvements implemented in response to the incident.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFinancialImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact Usd' ;
    rdfs:comment 'Estimated financial loss or exposure in US Dollars resulting from the incident. Used for materiality assessment and donor reporting thresholds.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Date when the alleged incident or violation occurred. May be approximate if exact date is unknown.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Detailed narrative description of the incident, allegations, and circumstances. Confidential to protect investigation and individuals.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Externally-visible unique incident reference number used for tracking and donor reporting. Format: INC-YYYYMMDD.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle status of the incident in the investigation and resolution workflow.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Primary classification of the compliance incident. Determines investigation protocol and reporting obligations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationAssignedTo rdf:type rdf:Property ;
    rdfs:label 'Investigation Assigned To' ;
    rdfs:comment 'Name or identifier of the investigator or investigation team assigned to the case. Confidential to protect investigation integrity.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completion Date' ;
    rdfs:comment 'Date when the investigation was formally closed and findings documented.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationFinding rdf:type rdf:Property ;
    rdfs:label 'Investigation Finding' ;
    rdfs:comment 'Final determination of the investigation regarding the validity of the allegation. Confidential until disclosure obligations are met.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date when formal investigation was initiated following triage and preliminary assessment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User or system identifier of the person who last modified this incident record.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when the incident was reported to the relevant regulatory authority.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relatedIncidentIds rdf:type rdf:Property ;
    rdfs:label 'Related Incident Ids' ;
    rdfs:comment 'Comma-separated list of related or linked incident IDs if this incident is part of a pattern or connected to other cases.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date when the incident was first reported to the organization through any channel.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reporterAnonymityFlag rdf:type rdf:Property ;
    rdfs:label 'Reporter Anonymity Flag' ;
    rdfs:comment 'Indicates whether the reporter requested anonymity or submitted the report anonymously. True if anonymous.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reporterContactInfo rdf:type rdf:Property ;
    rdfs:label 'Reporter Contact Info' ;
    rdfs:comment 'Contact information for the reporter if they provided it and did not request anonymity. Used for follow-up and feedback.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingChannel rdf:type rdf:Property ;
    rdfs:label 'Reporting Channel' ;
    rdfs:comment 'Channel or mechanism through which the incident was reported to the organization. [ENUM-REF-CANDIDATE: internal_detection|anonymous_hotline|whistleblower_portal|donor_notification|beneficiary_complaint|partner_report|audit_finding — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageOutcome rdf:type rdf:Property ;
    rdfs:label 'Triage Outcome' ;
    rdfs:comment 'Initial triage decision determining the handling pathway for the reported incident.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User or system identifier of the person who created this incident record.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryInternalUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Internal User Account Id' ;
    rdfs:comment 'Identifier of the system user who created this compliance review record. Audit trail for accountability.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:reviewedSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Reviewed System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Internal compliance reviews examine specific systems for regulatory compliance, data quality, and control effectiveness. Nonprofits must link reviews to systems for finding attribution, remediation tr' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:securityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Security Assessment Id' ;
    rdfs:comment 'Foreign key linking to technology.security_assessment. Business justification: Internal compliance reviews often trigger or reference security assessments for systems handling sensitive data (beneficiary PII, financial data). Nonprofits coordinate these for integrated assurance,' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SecurityAssessment .

ind:complianceFrameworkReference rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework Reference' ;
    rdfs:comment 'Reference to the specific compliance framework, policy, or regulation against which the review was conducted (e.g., OMB 2 CFR 200, CHS, organizational policy number).' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Due Date' ;
    rdfs:comment 'Date by which management must submit a corrective action plan addressing the review findings. Nullable if no corrective action is required.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Boolean indicator of whether corrective action is required as a result of the review findings. True if management must implement remediation actions.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical-severity findings identified during the review. Critical findings represent significant control failures or compliance violations requiring immediate action.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalAuditorCoordinationFlag rdf:type rdf:Property ;
    rdfs:label 'External Auditor Coordination Flag' ;
    rdfs:comment 'Boolean indicator of whether this internal review was coordinated with or informed by external auditor activities (e.g., Single Audit). True if coordination occurred.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Review Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a follow-up review is required to verify implementation of corrective actions. True for reviews with significant findings requiring validation.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpReviewScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Review Scheduled Date' ;
    rdfs:comment 'Planned date for the follow-up review to verify corrective action implementation. Nullable if no follow-up is required.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:highFindingsCount rdf:type rdf:Property ;
    rdfs:label 'High Findings Count' ;
    rdfs:comment 'Number of high-severity findings identified during the review. High findings represent material weaknesses requiring prompt remediation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lowFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Low Findings Count' ;
    rdfs:comment 'Number of low-severity findings identified during the review. Low findings represent minor control gaps or opportunities for improvement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managementResponseReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Management Response Received Date' ;
    rdfs:comment 'Date when management formally responded to the review findings and submitted their corrective action plan.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mediumFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Medium Findings Count' ;
    rdfs:comment 'Number of medium-severity findings identified during the review. Medium findings represent control weaknesses that should be addressed in a reasonable timeframe.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Overall Compliance Rating' ;
    rdfs:comment 'Summary assessment of the overall compliance posture based on the review findings. Provides an executive-level view of compliance health (satisfactory, needs improvement, unsatisfactory, high risk).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationSize rdf:type rdf:Property ;
    rdfs:label 'Population Size' ;
    rdfs:comment 'Total number of transactions, cases, or records in the population from which the sample was drawn. Provides context for sample representativeness.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Report Document Url' ;
    rdfs:comment 'File path or URL to the stored compliance review report document. Provides access to the full detailed report.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date when the final compliance review report was formally issued to management and stakeholders.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewEndDate rdf:type rdf:Property ;
    rdfs:label 'Review End Date' ;
    rdfs:comment 'Date when the compliance review fieldwork was completed and findings were finalized. Nullable for reviews still in progress.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewMethodology rdf:type rdf:Property ;
    rdfs:label 'Review Methodology' ;
    rdfs:comment 'Primary audit methodology or approach used to conduct the compliance review (risk-based, transaction testing, control testing, analytical review, walkthrough, observation).' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Free-text field for additional notes, observations, or context about the compliance review that do not fit structured fields. May include reviewer commentary or special circumstances.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Externally-known business identifier for the compliance review, typically formatted as prefix-year-sequence (e.g., ICR-2024-00123).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'End date of the operational period being reviewed. Defines the end of the time window under examination.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'Start date of the operational period being reviewed. Defines the beginning of the time window under examination (distinct from when the review itself started).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Review Scope Description' ;
    rdfs:comment 'Detailed narrative describing the scope, objectives, and boundaries of the compliance review. Explains what was included and excluded from the review.' ;
    rdfs:domain ind:InternalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'Date when the compliance review fieldwork commenced. Represents the beginning of the review period for audit trail purposes.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle state of the compliance review (planned, fieldwork in progress, draft report, management response pending, final report issued, closed with follow-up complete).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Review Team Members' ;
    rdfs:comment 'Comma-separated list of staff names or identifiers who participated in the review team. Captures the full review team composition.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Classification of the internal compliance review activity. Defines the focus area and scope of the review (financial spot check, procurement review, programmatic compliance, data protection audit, conflict of interest certification review, grant compliance review).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Quantitative risk score assigned to the reviewed entity based on findings severity and control environment. Typically on a scale of 0-100 where higher scores indicate greater risk.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of transactions, cases, or records sampled during the compliance review. Represents the statistical sample used for testing.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of findings across all severity levels identified during the compliance review.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nicraAgreementId rdf:type rdf:Property ;
    rdfs:label 'Nicra Agreement Id' ;
    rdfs:comment 'Unique identifier for the NICRA agreement record. Primary key.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NicraAgreement .

ind:cognizantAgencyId rdf:type rdf:Property ;
    rdfs:label 'Cognizant Agency Id' ;
    rdfs:comment 'Reference to the federal agency responsible for negotiating and approving this NICRA (typically USAID, DHHS, or other federal agency).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CognizantAgency .

ind:primaryPredecessorAgreementNicraAgreementId rdf:type rdf:Property ;
    rdfs:label 'Primary Predecessor Agreement Nicra Agreement Id' ;
    rdfs:comment 'Reference to the previous NICRA agreement that this agreement supersedes or replaces. Enables tracking of NICRA history and rate evolution over time.' ;
    rdfs:domain ind:NicraAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NicraAgreement .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'The official agreement number assigned by the cognizant agency to this NICRA. This is the externally-known identifier used in grant reporting and audit documentation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicablePrograms rdf:type rdf:Property ;
    rdfs:label 'Applicable Programs' ;
    rdfs:comment 'Description of the federal programs, grants, or awards to which this NICRA applies. May specify all federal awards or list specific programs, agencies, or award types covered by this agreement.' ;
    rdfs:domain ind:NicraAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingsReference rdf:type rdf:Property ;
    rdfs:label 'Audit Findings Reference' ;
    rdfs:comment 'Reference to any Single Audit or A-133 audit findings related to indirect cost rate compliance that informed this NICRA negotiation or require corrective action.' ;
    rdfs:domain ind:NicraAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cognizantAgencyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Cognizant Agency Contact Email' ;
    rdfs:comment 'Email address of the cognizant agency contact for correspondence regarding this NICRA.' ;
    rdfs:domain ind:NicraAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cognizantAgencyContactName rdf:type rdf:Property ;
    rdfs:label 'Cognizant Agency Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the cognizant agency responsible for this NICRA negotiation and oversight.' ;
    rdfs:domain ind:NicraAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cognizantAgencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Cognizant Agency Contact Phone' ;
    rdfs:comment 'Phone number of the cognizant agency contact for inquiries regarding this NICRA.' ;
    rdfs:domain ind:NicraAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costBaseType rdf:type rdf:Property ;
    rdfs:label 'Cost Base Type' ;
    rdfs:comment 'The cost base to which the indirect cost rate is applied: MTDC (Modified Total Direct Costs, excluding capital expenditures, equipment, subawards over $25K, and other exclusions per 2 CFR 200.68), TDC (Total Direct Costs), salaries_and_wages, or direct_salaries.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPoolDefinition rdf:type rdf:Property ;
    rdfs:label 'Cost Pool Definition' ;
    rdfs:comment 'Detailed description of the Facilities and Administration (F&A) cost pools included in the indirect cost rate calculation, such as general administration, facilities operation and maintenance, depreciation, and other allowable indirect costs per 2 CFR 200 Appendix IV.' ;
    rdfs:domain ind:NicraAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deMinimisRateElected rdf:type rdf:Property ;
    rdfs:label 'De Minimis Rate Elected' ;
    rdfs:comment 'Indicates whether the organization elected to use the de minimis indirect cost rate of 10% of MTDC as permitted under 2 CFR 200.414(f) for organizations that have never received a negotiated indirect cost rate. True if de minimis rate is elected, False otherwise.' ;
    rdfs:domain ind:NicraAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusionsAndLimitations rdf:type rdf:Property ;
    rdfs:label 'Exclusions And Limitations' ;
    rdfs:comment 'Any exclusions, limitations, or special conditions imposed by the cognizant agency on the use of this NICRA, such as caps on specific cost categories, excluded programs, or required cost allocation adjustments.' ;
    rdfs:domain ind:NicraAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearBasis rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Basis' ;
    rdfs:comment 'The organization\'s fiscal year period on which the indirect cost rate calculation is based (e.g., \'July 1 - June 30\', \'January 1 - December 31\'). Critical for aligning rate application with organizational accounting periods.' ;
    rdfs:domain ind:NicraAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fringeBenefitRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Fringe Benefit Rate Percentage' ;
    rdfs:comment 'The negotiated fringe benefit rate percentage applied to salaries and wages to calculate employee benefits costs. May be included in the NICRA if fringe is treated as an indirect cost pool.' ;
    rdfs:domain ind:NicraAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indirectCostRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Rate Percentage' ;
    rdfs:comment 'The negotiated indirect cost rate expressed as a percentage (e.g., 15.50 for 15.50%). This is the primary rate applied to the cost base to calculate Facilities and Administration (F&A) costs recoverable from federal awards.' ;
    rdfs:domain ind:NicraAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiationDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Date' ;
    rdfs:comment 'The date on which the indirect cost rate negotiation with the cognizant agency was completed and the NICRA was formally executed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nicraAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Nicra Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the NICRA: draft (being prepared), pending_approval (submitted to cognizant agency), active (in effect), expired (past effective period), superseded (replaced by newer NICRA), or terminated (cancelled before expiry).' ;
    rdfs:domain ind:NicraAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationalUnitApplicability rdf:type rdf:Property ;
    rdfs:label 'Organizational Unit Applicability' ;
    rdfs:comment 'Specifies which organizational units, divisions, or legal entities within the nonprofit organization this NICRA applies to. Important for multi-entity organizations with separate NICRAs for different subsidiaries or country offices.' ;
    rdfs:domain ind:NicraAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAdjustmentProvision rdf:type rdf:Property ;
    rdfs:label 'Rate Adjustment Provision' ;
    rdfs:comment 'Description of any provisions for rate adjustments, carry-forward of under/over-recoveries, or reconciliation requirements specified in the NICRA.' ;
    rdfs:domain ind:NicraAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Reference' ;
    rdfs:comment 'Reference to the supporting documentation submitted with the indirect cost rate proposal, including cost allocation plans, financial statements, audit reports, and other materials required by the cognizant agency.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Required System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Compliance obligations often mandate specific technology platforms (IATI publication requires IATI registry, 990 filing requires e-file system, grant reporting requires donor portals). Nonprofits must' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:chsSelfAssessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Chs Self Assessment Required' ;
    rdfs:comment 'Indicates whether this obligation requires a self-assessment against the Core Humanitarian Standard (CHS) commitments.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationRequired rdf:type rdf:Property ;
    rdfs:label 'Documentation Required' ;
    rdfs:comment 'Description of the documents, reports, or evidence that must be prepared or submitted to fulfill this obligation (e.g., \'Audited financial statements\', \'Program impact report\', \'Beneficiary data summary\', \'Board meeting minutes\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorFunderName rdf:type rdf:Property ;
    rdfs:label 'Donor Funder Name' ;
    rdfs:comment 'The name of the donor, funder, or granting organization that requires this obligation, if applicable (e.g., \'USAID\', \'DFID\', \'Bill & Melinda Gates Foundation\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Days' ;
    rdfs:comment 'The number of days before the due date when an alert or escalation should be triggered to ensure timely completion.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date when this obligation ceases to be applicable or enforceable, if applicable. Null for ongoing obligations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalYearApplicable rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Applicable' ;
    rdfs:comment 'The fiscal year or reporting period to which this obligation applies (e.g., \'FY2024\', \'2024\', \'Q1-2024\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'How often the obligation must be fulfilled: annual, quarterly, monthly, semi-annual, biennial, one-time (single occurrence), ad-hoc (irregular), event-driven (triggered by specific events). [ENUM-REF-CANDIDATE: annual|quarterly|monthly|semi-annual|biennial|one-time|ad-hoc|event-driven — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'The regulatory authority, oversight body, or standard-setting organization that mandates or oversees this obligation (e.g., \'Internal Revenue Service\', \'Charity Commission\', \'OCHA\', \'CHS Alliance\', \'USAID\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Grant Agreement Reference' ;
    rdfs:comment 'Reference number or identifier of the grant agreement, contract, or Memorandum of Understanding (MoU) that establishes this obligation, if applicable.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatiPublicationRequired rdf:type rdf:Property ;
    rdfs:label 'Iati Publication Required' ;
    rdfs:comment 'Indicates whether this obligation requires publication of data to the IATI Registry for transparency and accountability.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'The geographic or organizational scope where this obligation applies (e.g., \'United States\', \'United Kingdom\', \'European Union\', \'Global\', \'State of California\', \'Country Office Kenya\').' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Last Completed Date' ;
    rdfs:comment 'The date when this obligation was most recently fulfilled or submitted successfully.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'The number of days in advance that preparation or submission must begin to meet the obligation deadline.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The specific law, regulation, standard, or contractual clause that establishes this obligation (e.g., \'IRC Section 501(c)(3)\', \'2 CFR 200.501\', \'CHS Commitment 1\', \'Grant Agreement Clause 12.3\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'The next scheduled date by which this obligation must be fulfilled or submitted.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Internal or external reference code for the obligation (e.g., \'IRS-990\', \'CC-AR\', \'IATI-PUB\', \'CHS-SA\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'The official name or title of the compliance obligation (e.g., \'IRS Form 990 Annual Return\', \'Charity Commission Annual Return\', \'IATI Publication\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Status' ;
    rdfs:comment 'Current lifecycle status of the obligation: active (in force and must be fulfilled), pending (upcoming or not yet effective), completed (fulfilled for current period), overdue (past due date and not fulfilled), waived (exempted or not applicable), suspended (temporarily not enforced).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the obligation by its source or nature: regulatory (government-mandated), donor (funder-specific requirement), voluntary (self-imposed accountability framework), contractual (grant or partnership agreement condition), statutory (legal requirement).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Description of the consequences, penalties, or sanctions that may result from non-compliance (e.g., \'Loss of tax-exempt status\', \'Fines up to $50,000\', \'Grant suspension\', \'Reputational damage\').' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePerson rdf:type rdf:Property ;
    rdfs:label 'Responsible Person' ;
    rdfs:comment 'The name or identifier of the individual accountable for ensuring this obligation is fulfilled (e.g., \'Chief Financial Officer\', \'Compliance Manager\', \'MEL Director\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleUnit rdf:type rdf:Property ;
    rdfs:label 'Responsible Unit' ;
    rdfs:comment 'The department, team, or organizational unit responsible for fulfilling this obligation (e.g., \'Finance Department\', \'Compliance Office\', \'MEL Team\', \'Legal Affairs\', \'Country Office\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'The severity of risk to the organization if this obligation is not fulfilled: critical (severe legal or reputational consequences), high (significant impact), medium (moderate impact), low (minimal impact).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:singleAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Single Audit Required' ;
    rdfs:comment 'Indicates whether this obligation requires a Single Audit under 2 CFR 200 Subpart F for US federal awards exceeding the threshold.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionUrl rdf:type rdf:Property ;
    rdfs:label 'Submission Url' ;
    rdfs:comment 'The web address or portal URL where the obligation must be submitted, if applicable.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationScheduleId rdf:type rdf:Property ;
    rdfs:label 'Obligation Schedule Id' ;
    rdfs:comment 'Unique identifier for the compliance obligation schedule entry. Primary key for the obligation schedule product.' ;
    rdfs:domain ind:ObligationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Execution System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Scheduled compliance tasks are executed through specific platforms (e.g., filing system, reporting portal). Nonprofits need this link for workflow automation, access provisioning before due dates, and' ;
    rdfs:domain ind:ObligationSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:fiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Id' ;
    rdfs:comment 'Reference to the fiscal period (month, quarter, year) to which this obligation schedule applies. Enables period-based compliance tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:primaryObligationStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Obligation Staff Member Id' ;
    rdfs:comment 'Reference to the staff member (compliance officer, finance manager, or program director) assigned primary responsibility for completing this obligation.' ;
    rdfs:domain ind:ObligationSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:tertiaryObligationAssignedOfficerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Obligation Assigned Officer Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:ObligationSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Overall completion status of the scheduled obligation. Indicates whether the obligation is pending, actively being worked, completed on time, overdue, waived by authority, or deferred to a future period.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDueDate rdf:type rdf:Property ;
    rdfs:label 'Effective Due Date' ;
    rdfs:comment 'The actual due date in effect for this obligation, taking into account any approved extensions. Equals extended_due_date if extension granted, otherwise equals planned_due_date.' ;
    rdfs:domain ind:ObligationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Triggered Flag' ;
    rdfs:comment 'Boolean indicator of whether this obligation has triggered an escalation alert due to approaching deadline or overdue status. True if escalation has been triggered, False otherwise.' ;
    rdfs:domain ind:ObligationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extendedDueDate rdf:type rdf:Property ;
    rdfs:label 'Extended Due Date' ;
    rdfs:comment 'Revised due date if an extension has been granted by the regulatory authority or approved internally. Null if no extension applies.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Granted Flag' ;
    rdfs:comment 'Boolean indicator of whether the requested extension was approved by the regulatory authority. True if extension granted, False if denied or not applicable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionReason rdf:type rdf:Property ;
    rdfs:label 'Extension Reason' ;
    rdfs:comment 'Business justification or reason provided when requesting an extension (e.g., \'Awaiting final audit report\', \'Staff transition\', \'System migration delay\').' ;
    rdfs:domain ind:ObligationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Requested Flag' ;
    rdfs:comment 'Boolean indicator of whether an extension has been formally requested from the regulatory authority. True if extension requested, False otherwise.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonComplianceRisk rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Risk' ;
    rdfs:comment 'Assessment of the organizational risk if this obligation is not met on time. Severe risk includes loss of tax-exempt status, funding restrictions, or legal penalties.' ;
    rdfs:domain ind:ObligationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary penalty or fine amount assessed for late or non-compliant submission. Null if no penalty applies or obligation completed on time.' ;
    rdfs:domain ind:ObligationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the penalty amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:ObligationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDueDate rdf:type rdf:Property ;
    rdfs:label 'Planned Due Date' ;
    rdfs:comment 'Original scheduled due date for the compliance obligation as defined by the regulatory authority or internal policy.' ;
    rdfs:domain ind:ObligationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recurrencePattern rdf:type rdf:Property ;
    rdfs:label 'Recurrence Pattern' ;
    rdfs:comment 'Frequency pattern for this obligation. Indicates whether it is a one-time requirement, recurring annually, quarterly, monthly, biennially, or triggered by specific events.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Specific regulatory framework or standard governing this obligation (e.g., \'IRS 501(c)(3)\', \'OMB Uniform Guidance 2 CFR 200\', \'IATI Standard\', \'CHS\', \'Sphere Standards\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerNotes rdf:type rdf:Property ;
    rdfs:label 'Reviewer Notes' ;
    rdfs:comment 'Internal notes and comments from compliance reviewers, auditors, or executive leadership regarding this obligation schedule entry. Used for quality assurance and process improvement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Count' ;
    rdfs:comment 'Number of supporting documents, attachments, or exhibits required or submitted with this obligation (e.g., financial statements, audit reports, program narratives).' ;
    rdfs:domain ind:ObligationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Explanation for why this obligation was waived or exempted by the regulatory authority or internal policy (e.g., \'Below revenue threshold\', \'Disaster relief exemption\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStage rdf:type rdf:Property ;
    rdfs:label 'Workflow Stage' ;
    rdfs:comment 'Current stage in the compliance workflow process. Tracks progression from initial data collection through final submission and acknowledgment. [ENUM-REF-CANDIDATE: not_started|data_collection|draft_preparation|internal_review|executive_review|final_approval|submission_ready|submitted|acknowledged — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ObligationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Filing System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Regulatory filings are submitted through specific platforms (IRS e-file, state charity portals, IATI registry). Nonprofits must track which system was used for each filing for audit trail, troubleshoo' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:originalFilingRegulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Original Filing Regulatory Filing Id' ;
    rdfs:comment 'Reference to the original regulatory filing record that this amendment corrects or supersedes. Null if this is an original filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:statutoryRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Statutory Registration Id' ;
    rdfs:comment 'Foreign key linking to compliance.statutory_registration. Business justification: Regulatory filings are often associated with specific statutory registrations (e.g., annual charity returns for a registration, IRS 990 for a 501(c)(3) registration). One filing is for one registratio' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StatutoryRegistration .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date on which the regulatory authority acknowledged receipt of the filing. Confirms that the submission was received and entered into the processing queue.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Flag' ;
    rdfs:comment 'Indicates whether this filing is an amendment or correction of a previously submitted filing. True if this is an amended return, false if original filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'Full name of the individual authorized to sign and submit the regulatory filing on behalf of the organization. Typically an officer or director with legal authority.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Title' ;
    rdfs:comment 'Official title or position of the authorized signatory. Examples include Executive Director, Board Chair, President, or Chief Executive Officer (CEO).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Amount' ;
    rdfs:comment 'Monetary fee charged by the regulatory authority for processing the filing. Amount in the organizations functional currency.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the filing fee amount. Examples include USD, GBP, EUR.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFeePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Payment Date' ;
    rdfs:comment 'Date on which the filing fee was paid to the regulatory authority. Used to confirm payment and avoid processing delays.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingNotes rdf:type rdf:Property ;
    rdfs:label 'Filing Notes' ;
    rdfs:comment 'Free-text field for internal notes, comments, or special circumstances related to the filing. Used to document unusual situations, preparer communications, or follow-up actions required.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Number' ;
    rdfs:comment 'Externally-known unique identifier or confirmation number assigned by the regulatory authority or filing system upon submission. Examples include IRS e-file confirmation number, Charity Commission submission reference, or state registration number.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period End Date' ;
    rdfs:comment 'End date of the fiscal or reporting period covered by this regulatory filing. Defines the conclusion of the time span for which financial and operational data are reported.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period Start Date' ;
    rdfs:comment 'Start date of the fiscal or reporting period covered by this regulatory filing. Defines the beginning of the time span for which financial and operational data are reported.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory filing. Tracks progression from initial draft through submission, acknowledgment, and final acceptance or rejection by the regulatory authority. [ENUM-REF-CANDIDATE: draft|submitted|acknowledged|accepted|rejected|resubmitted|withdrawn|pending_review — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerName rdf:type rdf:Property ;
    rdfs:label 'Preparer Name' ;
    rdfs:comment 'Full name of the individual or firm responsible for preparing the regulatory filing. May be internal staff or external consultant/accountant.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerOrganization rdf:type rdf:Property ;
    rdfs:label 'Preparer Organization' ;
    rdfs:comment 'Name of the organization or firm employing the preparer, if applicable. Identifies external accounting firms, consultancies, or legal advisors engaged to prepare the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerPtin rdf:type rdf:Property ;
    rdfs:label 'Preparer Ptin' ;
    rdfs:comment 'IRS-issued Preparer Tax Identification Number for the individual who prepared the filing. Required for paid tax return preparers in the United States.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date on which the regulatory authority rejected the filing due to errors, omissions, or non-compliance. Triggers resubmission workflow.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code assigned by the regulatory authority indicating the specific reason for filing rejection. Used to identify and correct errors for resubmission. [ENUM-REF-CANDIDATE: IRS Reject Code 0001|0002|0003|0004|0005|0006|... — promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of why the filing was rejected by the regulatory authority. Provides context and guidance for corrective action.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionCount rdf:type rdf:Property ;
    rdfs:label 'Resubmission Count' ;
    rdfs:comment 'Number of times this filing has been resubmitted after rejection. Tracks the iteration history for audit and quality improvement purposes.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date on which the internal review and approval of the filing was completed. Marks the point at which the filing was deemed ready for submission.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Full name of the individual responsible for reviewing and approving the regulatory filing before submission. Typically a senior finance officer, legal counsel, or executive director.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerTitle rdf:type rdf:Property ;
    rdfs:label 'Reviewer Title' ;
    rdfs:comment 'Job title or role of the individual who reviewed and approved the filing. Examples include Chief Financial Officer (CFO), Executive Director, or Board Treasurer.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Screening System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Sanctions screening is performed through dedicated platforms (Dow Jones, World-Check, OFAC screening tools). Nonprofits must document which system performed each screening for audit trail, donor compl' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:certificationStatement rdf:type rdf:Property ;
    rdfs:label 'Certification Statement' ;
    rdfs:comment 'Text of the anti-terrorism certification or compliance statement that this screening supports.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falsePositiveFlag rdf:type rdf:Property ;
    rdfs:label 'False Positive Flag' ;
    rdfs:comment 'Indicates whether a potential match was determined to be a false positive after investigation.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchDetails rdf:type rdf:Property ;
    rdfs:label 'Match Details' ;
    rdfs:comment 'Detailed information about the match, including list entry details, matching criteria, and any aliases or alternate spellings that triggered the match.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchResult rdf:type rdf:Property ;
    rdfs:label 'Match Result' ;
    rdfs:comment 'Outcome of the sanctions screening check indicating whether the subject was found on any sanctions list.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchScore rdf:type rdf:Property ;
    rdfs:label 'Match Score' ;
    rdfs:comment 'Numerical confidence score (0-100) indicating the likelihood of a true match when potential matches are identified. Higher scores indicate stronger matches.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScreeningDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Screening Due Date' ;
    rdfs:comment 'Date when the next periodic rescreening is due for this subject.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rescreeningFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Rescreening Frequency Days' ;
    rdfs:comment 'Number of days between required rescreening checks for this subject (e.g., 90, 180, 365).' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rescreeningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rescreening Required Flag' ;
    rdfs:comment 'Indicates whether periodic rescreening is required for this subject based on risk profile or donor requirements.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Action taken to resolve a potential or confirmed match (e.g., cleared after review, engagement blocked, escalated to legal, OFAC license requested, alternative vendor sourced).' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerEmail rdf:type rdf:Property ;
    rdfs:label 'Reviewer Email' ;
    rdfs:comment 'Email address of the reviewer who approved the resolution decision.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsListChecked rdf:type rdf:Property ;
    rdfs:label 'Sanctions List Checked' ;
    rdfs:comment 'Name of the sanctions or debarment list(s) checked during this screening. Pipe-separated list for multiple lists (e.g., OFAC SDN|UN Security Council|EU Sanctions|World Bank Debarment).' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenerEmail rdf:type rdf:Property ;
    rdfs:label 'Screener Email' ;
    rdfs:comment 'Email address of the staff member who performed the screening, for audit trail and follow-up purposes.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenerName rdf:type rdf:Property ;
    rdfs:label 'Screener Name' ;
    rdfs:comment 'Name of the staff member or compliance officer who performed or initiated the screening.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningDate rdf:type rdf:Property ;
    rdfs:label 'Screening Date' ;
    rdfs:comment 'Date when the sanctions screening check was performed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningMethod rdf:type rdf:Property ;
    rdfs:label 'Screening Method' ;
    rdfs:comment 'Method used to perform the sanctions screening check.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningStatus rdf:type rdf:Property ;
    rdfs:label 'Screening Status' ;
    rdfs:comment 'Current status of the sanctions screening record in the compliance workflow.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Timestamp' ;
    rdfs:comment 'Precise timestamp when the sanctions screening check was initiated, including time zone information.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:screeningTool rdf:type rdf:Property ;
    rdfs:label 'Screening Tool' ;
    rdfs:comment 'Name of the software tool or service used to perform the screening (e.g., Dow Jones Risk & Compliance, LexisNexis Bridger, manual OFAC search).' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectAddress rdf:type rdf:Property ;
    rdfs:label 'Subject Address' ;
    rdfs:comment 'Known address or location of the subject being screened, used for geographic risk assessment.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectDateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Subject Date Of Birth' ;
    rdfs:comment 'Date of birth of the individual being screened, used for identity matching and disambiguation.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectIdentifier rdf:type rdf:Property ;
    rdfs:label 'Subject Identifier' ;
    rdfs:comment 'Unique identifier of the subject in the source system (e.g., vendor ID, staff ID, beneficiary registration number).' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectName rdf:type rdf:Property ;
    rdfs:label 'Subject Name' ;
    rdfs:comment 'Full name of the individual or organization being screened. May include legal name, aliases, or transliterations.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectNationality rdf:type rdf:Property ;
    rdfs:label 'Subject Nationality' ;
    rdfs:comment 'Nationality or country of citizenship of the individual or country of registration for organizations. Pipe-separated list for multiple nationalities.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectType rdf:type rdf:Property ;
    rdfs:label 'Subject Type' ;
    rdfs:comment 'Type of entity being screened against sanctions lists.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentation rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation' ;
    rdfs:comment 'References to supporting documents, evidence, or file paths for screening reports, investigation notes, and approval records.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Source System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Single audit data is extracted from financial and grants management systems (ERP, grants platforms). Nonprofits must document which system provided audit data for SEFA preparation, auditor data reques' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:auditCostAmount rdf:type rdf:Property ;
    rdfs:label 'Audit Cost Amount' ;
    rdfs:comment 'Total cost paid or payable to the auditor firm for conducting the Single Audit engagement.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditFindingCount rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Count' ;
    rdfs:comment 'Total number of audit findings reported in the Schedule of Findings and Questioned Costs.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditReportDate rdf:type rdf:Property ;
    rdfs:label 'Audit Report Date' ;
    rdfs:comment 'Date when the auditor issued the final Single Audit report package.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the Single Audit engagement: planned, in_progress, fieldwork_complete, report_draft, report_final, submitted_to_fac, or closed. [ENUM-REF-CANDIDATE: planned|in_progress|fieldwork_complete|report_draft|report_final|submitted_to_fac|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditYear rdf:type rdf:Property ;
    rdfs:label 'Audit Year' ;
    rdfs:comment 'The fiscal year for which the Single Audit is being conducted, typically a four-digit year (e.g., 2023).' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Auditor Contact Email' ;
    rdfs:comment 'Email address of the primary auditor contact for this Single Audit engagement.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorContactName rdf:type rdf:Property ;
    rdfs:label 'Auditor Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the auditor firm responsible for this engagement.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Auditor Contact Phone' ;
    rdfs:comment 'Phone number of the primary auditor contact for this Single Audit engagement.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorEin rdf:type rdf:Property ;
    rdfs:label 'Auditor Ein' ;
    rdfs:comment 'Federal Employer Identification Number of the auditor firm conducting the Single Audit.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorFirmName rdf:type rdf:Property ;
    rdfs:label 'Auditor Firm Name' ;
    rdfs:comment 'Name of the independent certified public accounting firm or auditor conducting the Single Audit.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOpinionType rdf:type rdf:Property ;
    rdfs:label 'Compliance Opinion Type' ;
    rdfs:comment 'Type of audit opinion issued on compliance with federal award requirements: unmodified (clean), qualified, adverse, or disclaimer of opinion.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Date' ;
    rdfs:comment 'Date when the organization submitted its corrective action plan to address audit findings.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlanSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Submitted Flag' ;
    rdfs:comment 'Indicates whether the organization submitted a corrective action plan addressing audit findings as required.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engagementLetterDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Letter Date' ;
    rdfs:comment 'Date when the audit engagement letter was signed between the organization and the auditor firm.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:federalExpenditureAmount rdf:type rdf:Property ;
    rdfs:label 'Federal Expenditure Amount' ;
    rdfs:comment 'Total amount of federal awards expended by the organization during the audit period, triggering Single Audit requirement if $750,000 or more.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldworkEndDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork End Date' ;
    rdfs:comment 'Date when the auditor completed fieldwork for the Single Audit.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkStartDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Start Date' ;
    rdfs:comment 'Date when the auditor began on-site or remote fieldwork for the Single Audit.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialStatementOpinionType rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Opinion Type' ;
    rdfs:comment 'Type of audit opinion issued on the organization\'s financial statements: unmodified (clean), qualified, adverse, or disclaimer of opinion.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goingConcernIssueFlag rdf:type rdf:Property ;
    rdfs:label 'Going Concern Issue Flag' ;
    rdfs:comment 'Indicates whether the auditor raised substantial doubt about the organization\'s ability to continue as a going concern.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalControlOpinionType rdf:type rdf:Property ;
    rdfs:label 'Internal Control Opinion Type' ;
    rdfs:comment 'Type of audit opinion issued on internal control over financial reporting and compliance: unmodified, qualified, adverse, or disclaimer.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowRiskAuditeeFlag rdf:type rdf:Property ;
    rdfs:label 'Low Risk Auditee Flag' ;
    rdfs:comment 'Indicates whether the organization qualifies as a low-risk auditee under OMB Uniform Guidance criteria, which may reduce the number of major programs tested.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorProgramCount rdf:type rdf:Property ;
    rdfs:label 'Major Program Count' ;
    rdfs:comment 'Number of federal programs identified as major programs requiring detailed compliance testing under the risk-based approach.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialWeaknessIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Material Weakness Identified Flag' ;
    rdfs:comment 'Indicates whether the auditor identified any material weaknesses in internal control over financial reporting or compliance.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sefaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sefa Reference Number' ;
    rdfs:comment 'Reference number or identifier for the Schedule of Expenditures of Federal Awards (SEFA) prepared as part of the Single Audit package.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significantDeficiencyIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Significant Deficiency Identified Flag' ;
    rdfs:comment 'Indicates whether the auditor identified any significant deficiencies in internal control over financial reporting or compliance.' ;
    rdfs:domain ind:SingleAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Registration System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Statutory registration data (legal entity information, tax status, operating authority) is maintained in legal entity management or ERP systems. Nonprofits track which system is the source of truth fo' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:deductibilityCode rdf:type rdf:Property ;
    rdfs:label 'Deductibility Code' ;
    rdfs:comment 'IRS deductibility code indicating the extent to which contributions are tax-deductible (e.g., PC for public charity, PF for private foundation). Applicable primarily to US 501(c)(3) registrations.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinationLetterDate rdf:type rdf:Property ;
    rdfs:label 'Determination Letter Date' ;
    rdfs:comment 'Date of the official determination letter or registration certificate issued by the regulatory authority. Particularly relevant for US 501(c)(3) IRS determination letters.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:doingBusinessAsName rdf:type rdf:Property ;
    rdfs:label 'Doing Business As Name' ;
    rdfs:comment 'Alternative operating name or trade name used by the organization, if different from the registered legal name.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorEligibilityVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Eligibility Verified Flag' ;
    rdfs:comment 'Indicates whether this registration has been verified for donor eligibility purposes (e.g., eligible to receive grants from institutional donors, government agencies, or foundations). True if verified; False if not verified or verification pending.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foreignOperationsPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Foreign Operations Permitted Flag' ;
    rdfs:comment 'Indicates whether this registration permits the organization to conduct operations or provide services outside the jurisdiction of registration. True if foreign operations are permitted; False if restricted to domestic operations only.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foundationStatus rdf:type rdf:Property ;
    rdfs:label 'Foundation Status' ;
    rdfs:comment 'Classification of the organization as a public charity or type of private foundation. Relevant for US 501(c)(3) organizations.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Three-letter ISO country code representing the jurisdiction where the organization is registered (e.g., USA, GBR, KEN).' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFilingDate rdf:type rdf:Property ;
    rdfs:label 'Last Filing Date' ;
    rdfs:comment 'Date of the most recent regulatory filing or report submitted under this registration.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextFilingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Filing Due Date' ;
    rdfs:comment 'Date by which the next regulatory filing or report is due to maintain compliance with this registration.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Date' ;
    rdfs:comment 'Date by which the next renewal application or filing must be submitted to maintain active registration status.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingAuthorityGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Operating Authority Granted Flag' ;
    rdfs:comment 'Indicates whether this registration grants legal authority to operate programs and services in the jurisdiction. True if operating authority is granted; False if registration is for tax or reporting purposes only.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicCharityClassification rdf:type rdf:Property ;
    rdfs:label 'Public Charity Classification' ;
    rdfs:comment 'IRS public charity classification under Section 509(a). 509(a)(1) for publicly supported organizations; 509(a)(2) for organizations receiving substantial support from program service revenue; 509(a)(3) for supporting organizations; Private Foundation if not qualifying as public charity; Not Applicable for non-US registrations.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the official registered address on file with the statutory authority.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Second line of the official registered address (suite, floor, building name, etc.).' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'City or municipality of the official registered address.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registered Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the official registered address.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredLegalName rdf:type rdf:Property ;
    rdfs:label 'Registered Legal Name' ;
    rdfs:comment 'The official legal name of the organization as registered with the statutory authority. This is the name that appears on the determination letter or registration certificate.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'Postal code or ZIP code of the official registered address.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredStateProvince rdf:type rdf:Property ;
    rdfs:label 'Registered State Province' ;
    rdfs:comment 'State, province, or administrative region of the official registered address.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Registration Document Url' ;
    rdfs:comment 'URL or file path to the scanned copy of the official registration certificate, determination letter, or registration document.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Name of the government agency or regulatory body that issued and oversees this registration (e.g., Internal Revenue Service, Charity Commission for England and Wales, Ministry of Social Affairs).' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequency rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency' ;
    rdfs:comment 'Frequency at which the statutory registration must be renewed. Not applicable for registrations that do not require renewal.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether this registration requires periodic renewal. True if renewal is required; False if registration is indefinite or does not require renewal.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingRequirementDescription rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirement Description' ;
    rdfs:comment 'Description of the periodic reporting obligations associated with this registration (e.g., annual Form 990 filing, Charity Commission annual return, quarterly financial reports).' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Status' ;
    rdfs:comment 'Tax exemption status granted under this registration. Exempt indicates full tax-exempt status; Non-exempt indicates no tax exemption; Conditional indicates exemption with specific conditions; Pending indicates exemption application under review.' ;
    rdfs:domain ind:StatutoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealId rdf:type rdf:Property ;
    rdfs:label 'Appeal Id' ;
    rdfs:comment 'Unique identifier for the fundraising appeal. Primary key.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appeal .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Appeals are marketing campaigns with budgets and expenses (printing, postage, digital ads) tracked in cost centers. Standard nonprofit fundraising accounting—enables ROI calculation by comparing appea' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:acknowledgmentTemplate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Template' ;
    rdfs:comment 'Name or identifier of the gift acknowledgment letter template used for donors responding to this appeal.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealName rdf:type rdf:Property ;
    rdfs:label 'Appeal Name' ;
    rdfs:comment 'Human-readable name of the appeal (e.g., Spring Direct Mail Appeal, Year-End Email Solicitation).' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Current lifecycle status of the appeal.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealType rdf:type rdf:Property ;
    rdfs:label 'Appeal Type' ;
    rdfs:comment 'Classification of the appeal based on donor lifecycle stage and solicitation strategy.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:askAmount rdf:type rdf:Property ;
    rdfs:label 'Ask Amount' ;
    rdfs:comment 'Suggested or recommended gift amount presented to constituents in the appeal solicitation.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:askString rdf:type rdf:Property ;
    rdfs:label 'Ask String' ;
    rdfs:comment 'Formatted ask string presented to constituents showing multiple giving levels (e.g., $50, $100, $250, $500, Other).' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageGiftAmount rdf:type rdf:Property ;
    rdfs:label 'Average Gift Amount' ;
    rdfs:comment 'Average gift size for responses to this appeal calculated as total_revenue_amount / response_count.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlGroupFlag rdf:type rdf:Property ;
    rdfs:label 'Control Group Flag' ;
    rdfs:comment 'Indicates whether this appeal represents the control group in an A/B test (true) or a test variant (false).' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailingDate rdf:type rdf:Property ;
    rdfs:label 'Mailing Date' ;
    rdfs:comment 'Date the appeal solicitation was sent or deployed to the target segment.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Name of the staff member responsible for managing and executing this appeal.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Username or identifier of the system user who last modified the appeal record.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageDescription rdf:type rdf:Property ;
    rdfs:label 'Package Description' ;
    rdfs:comment 'Detailed description of the solicitation package contents including letter, brochure, reply device, premium, and other components.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piecesSent rdf:type rdf:Property ;
    rdfs:label 'Pieces Sent' ;
    rdfs:comment 'Total count of solicitation pieces (letters, emails, calls) sent to constituents for this appeal.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:premiumOffered rdf:type rdf:Property ;
    rdfs:label 'Premium Offered' ;
    rdfs:comment 'Description of any premium or thank-you gift offered to donors responding to this appeal (e.g., tote bag, calendar, recognition pin).' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseCount rdf:type rdf:Property ;
    rdfs:label 'Response Count' ;
    rdfs:comment 'Total number of constituents who responded to the appeal with a gift or pledge.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseRatePercent rdf:type rdf:Property ;
    rdfs:label 'Response Rate Percent' ;
    rdfs:comment 'Percentage of constituents who responded to the appeal calculated as (response_count / pieces_sent) * 100.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the total revenue amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiRatio rdf:type rdf:Property ;
    rdfs:label 'Roi Ratio' ;
    rdfs:comment 'Return on investment ratio for the appeal calculated as total_revenue_amount / cost_amount. Values greater than 1.0 indicate positive ROI.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solicitorName rdf:type rdf:Property ;
    rdfs:label 'Solicitor Name' ;
    rdfs:comment 'Name of the primary solicitor or fundraiser credited with this appeal (may be staff, volunteer, or board member).' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSegmentFlag rdf:type rdf:Property ;
    rdfs:label 'Test Segment Flag' ;
    rdfs:comment 'Indicates whether this appeal is part of an A/B test or experimental segment for testing messaging, package, or channel effectiveness.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Amount' ;
    rdfs:comment 'Total gross revenue generated by gifts and pledges attributed to this appeal.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignModifiedByUserUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Campaign Modified By User User Account Id' ;
    rdfs:comment 'Reference to the user who last modified the campaign record.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:campaignUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Campaign User Account Id' ;
    rdfs:comment 'Reference to the user who created the campaign record.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:financeFundId rdf:type rdf:Property ;
    rdfs:label 'Finance Fund Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_fund. Business justification: Campaigns often have dedicated finance funds for revenue tracking, expense allocation, and donor reporting. Standard nonprofit practice for capital campaigns, annual funds, and restricted initiatives.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceFund .

ind:parentCampaignId rdf:type rdf:Property ;
    rdfs:label 'Parent Campaign Id' ;
    rdfs:comment 'Reference to a parent campaign if this campaign is part of a larger multi-phase or hierarchical campaign structure.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:appealChannel rdf:type rdf:Property ;
    rdfs:label 'Appeal Channel' ;
    rdfs:comment 'Primary communication channel used to solicit donations for this campaign. [ENUM-REF-CANDIDATE: direct_mail|email|social_media|website|event|phone|peer_to_peer — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealDescription rdf:type rdf:Property ;
    rdfs:label 'Appeal Description' ;
    rdfs:comment 'Detailed narrative describing the campaign\'s mission, beneficiaries, and impact story used in donor communications.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfFundraising rdf:type rdf:Property ;
    rdfs:label 'Cost Of Fundraising' ;
    rdfs:comment 'Total expenses incurred to execute the campaign, including marketing, events, staff time, and materials.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorCount rdf:type rdf:Property ;
    rdfs:label 'Donor Count' ;
    rdfs:comment 'Total number of unique donors who have contributed to this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:giftCount rdf:type rdf:Property ;
    rdfs:label 'Gift Count' ;
    rdfs:comment 'Total number of individual gift transactions attributed to this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goalAmount rdf:type rdf:Property ;
    rdfs:label 'Goal Amount' ;
    rdfs:comment 'The target fundraising amount the campaign aims to raise, expressed in the organization\'s base currency.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactReportUrl rdf:type rdf:Property ;
    rdfs:label 'Impact Report Url' ;
    rdfs:comment 'Web address of the campaign impact report or results summary shared with donors.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPublic rdf:type rdf:Property ;
    rdfs:label 'Is Public' ;
    rdfs:comment 'Boolean flag indicating whether the campaign is publicly visible on the organization\'s website and donation pages.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchingGiftEligible rdf:type rdf:Property ;
    rdfs:label 'Matching Gift Eligible' ;
    rdfs:comment 'Boolean flag indicating whether donations to this campaign are eligible for corporate matching gift programs.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roiPercentage rdf:type rdf:Property ;
    rdfs:label 'Roi Percentage' ;
    rdfs:comment 'Calculated return on investment for the campaign, expressed as a percentage of net revenue over cost.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stewardshipPlan rdf:type rdf:Property ;
    rdfs:label 'Stewardship Plan' ;
    rdfs:comment 'Description of the donor stewardship and engagement activities planned for campaign contributors.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDeductible rdf:type rdf:Property ;
    rdfs:label 'Tax Deductible' ;
    rdfs:comment 'Boolean flag indicating whether donations to this campaign are tax-deductible under IRS 501(c)(3) regulations or equivalent.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalRaisedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Raised Amount' ;
    rdfs:comment 'Cumulative amount of gifts and pledges received to date for this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'The constituent\'s preferred method of communication for stewardship, acknowledgment, and cultivation activities.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constituentType rdf:type rdf:Property ;
    rdfs:label 'Constituent Type' ;
    rdfs:comment 'The classification of the constituent entity. Individual = private person major gift donor; Institutional = government agency or public sector donor (USAID, DFID/FCDO); Foundation = private or family foundation; Corporate = business or corporate sponsor; Bilateral = government-to-government donor (DAC member); Multilateral = international organization (UN agencies, World Bank); Household = family unit for joint giving. [ENUM-REF-CANDIDATE: individual|institutional|foundation|corporate|bilateral|multilateral|household — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Crm Source Record Code' ;
    rdfs:comment 'The unique identifier of this constituent record in the source CRM system. Used for data lineage, reconciliation, and bi-directional sync.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Crm Source System' ;
    rdfs:comment 'The source CRM system from which this constituent record originated. Salesforce Nonprofit Cloud = Salesforce NPSP or Nonprofit Cloud; Raisers Edge NXT = Blackbaud Raisers Edge NXT; Other = other donor management system.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dacMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Dac Member Flag' ;
    rdfs:comment 'Indicates whether this constituent is a member of the OECD Development Assistance Committee. True = DAC member; False = not a DAC member. Used for ODA reporting and donor classification.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deceasedDate rdf:type rdf:Property ;
    rdfs:label 'Deceased Date' ;
    rdfs:comment 'The date on which the constituent passed away. Used for planned giving, estate gift tracking, and memorial acknowledgment.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deceasedFlag rdf:type rdf:Property ;
    rdfs:label 'Deceased Flag' ;
    rdfs:comment 'Indicates whether the constituent is deceased. True = deceased; False = living. Used to prevent inappropriate communications and for planned giving tracking.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Email Opt In Flag' ;
    rdfs:comment 'Indicates whether the constituent has explicitly consented to receive email communications. True = opted in; False = opted out or consent not given.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedGivingCapacity rdf:type rdf:Property ;
    rdfs:label 'Estimated Giving Capacity' ;
    rdfs:comment 'The estimated total giving capacity of the constituent based on wealth screening, prospect research, and capacity analysis. Expressed in USD. Used for major gift solicitation strategy and campaign goal setting.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstGiftDate rdf:type rdf:Property ;
    rdfs:label 'First Gift Date' ;
    rdfs:comment 'The date of the first gift or grant received from this constituent. Used for donor tenure analysis, anniversary recognition, and retention metrics.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:funderClassification rdf:type rdf:Property ;
    rdfs:label 'Funder Classification' ;
    rdfs:comment 'The classification of the funder based on international development and humanitarian standards. Bilateral = government-to-government donor; Multilateral = international organization (UN, World Bank); DAC Member = OECD Development Assistance Committee member country; Foundation = private or family foundation; Corporate = business or corporate sponsor; Individual = private individual donor; Other = other funder type. [ENUM-REF-CANDIDATE: bilateral|multilateral|dac_member|foundation|corporate|individual|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'The date on which the constituent provided GDPR consent for data processing. Used for audit and compliance tracking.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the constituent has provided explicit consent for data processing under GDPR requirements. True = consent given; False = consent not given or withdrawn.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indirectCostRate rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Rate' ;
    rdfs:comment 'The negotiated indirect cost rate (also known as NICRA - Negotiated Indirect Cost Rate Agreement) that this donor allows for F&A (Facilities and Administration) costs. Expressed as a decimal (e.g., 0.1500 for 15%). Used for grant budgeting and financial planning.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:largestGiftAmount rdf:type rdf:Property ;
    rdfs:label 'Largest Gift Amount' ;
    rdfs:comment 'The amount of the largest single gift or grant received from this constituent. Expressed in USD. Used for major gift benchmarking and solicitation strategy.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastGiftDate rdf:type rdf:Property ;
    rdfs:label 'Last Gift Date' ;
    rdfs:comment 'The date of the most recent gift or grant received from this constituent. Used for lapsed donor identification, recency-frequency-monetary (RFM) analysis, and re-engagement campaigns.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The full legal name of the constituent as registered with government authorities or as appears on official documents. For individuals, this is the full legal name; for organizations, this is the registered entity name.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifetimeGivingTotal rdf:type rdf:Property ;
    rdfs:label 'Lifetime Giving Total' ;
    rdfs:comment 'The cumulative total of all gifts and grants received from this constituent since the first gift date. Expressed in USD. Used for donor recognition, stewardship segmentation, and major gift qualification.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mailingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line1' ;
    rdfs:comment 'The first line of the constituent\'s mailing address, typically containing street number and street name or PO Box.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line2' ;
    rdfs:comment 'The second line of the constituent\'s mailing address, typically containing apartment, suite, or building information.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'The city or municipality of the constituent\'s mailing address.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Country Code' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country code of the constituent\'s mailing address (e.g., USA, GBR, CHE).' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'The postal code or ZIP code of the constituent\'s mailing address.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Mailing State Province' ;
    rdfs:comment 'The state, province, or administrative region of the constituent\'s mailing address.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odaEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Oda Eligibility Flag' ;
    rdfs:comment 'Indicates whether gifts from this constituent qualify as ODA under DAC (Development Assistance Committee) criteria. True = ODA-eligible; False = not ODA-eligible. Used for IATI reporting and donor transparency.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organizationAffiliation rdf:type rdf:Property ;
    rdfs:label 'Organization Affiliation' ;
    rdfs:comment 'The name of the organization or institution the constituent is affiliated with. For individual donors, this may be their employer or foundation board membership; for institutional contacts, this is the parent agency or department.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredGrantModality rdf:type rdf:Property ;
    rdfs:label 'Preferred Grant Modality' ;
    rdfs:comment 'The type of grant funding this donor typically provides. Restricted = tied to specific projects or activities; Unrestricted = general operating support; Project = specific project funding; Program = program-level funding; Core = institutional core support; Capital = infrastructure or capital expenditure; Endowment = long-term endowment funding. [ENUM-REF-CANDIDATE: restricted|unrestricted|project|program|core|capital|endowment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'The name the constituent prefers to be addressed by in communications and correspondence. May differ from legal name for individuals (e.g., nickname, shortened name) or organizations (e.g., brand name, acronym).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'The primary telephone number for constituent contact. May include country code, area code, and extension for institutional donors.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectResearchRating rdf:type rdf:Property ;
    rdfs:label 'Prospect Research Rating' ;
    rdfs:comment 'The wealth screening and prospect research rating assigned to this constituent. A = highest capacity and propensity; B = high capacity; C = moderate capacity; D = lower capacity; Unrated = not yet screened. Used for major gift cultivation and campaign planning.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'The formal greeting or title used when addressing the constituent in written or verbal communication (e.g., Mr., Ms., Dr., His Excellency, The Honorable).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Owner Staff Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:segmentCreatedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Segment Created By Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who created this segment record.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:segmentLastModifiedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Segment Last Modified By Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who last modified this segment record.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:segmentStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Segment Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member (fundraiser, development officer, or marketing manager) responsible for managing and stewarding this segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'Primary channel through which donors in this segment were acquired (e.g., \'Direct Mail\', \'Online Campaign\', \'Event\', \'Peer-to-Peer\', \'Major Gift Officer\'). Null if not channel-specific.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteria rdf:type rdf:Property ;
    rdfs:label 'Criteria' ;
    rdfs:comment 'Business rules or filter logic defining segment membership (e.g., \'Total giving >= $10,000 in last 12 months\', \'RFM score >= 400\', \'Geographic region = East Africa\').' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'System or process that created this segment: salesforce (Salesforce Nonprofit Cloud), raisers_edge (Raisers Edge NXT), manual (user-created), rfm_engine (automated RFM scoring), wealth_screening (external screening import), import (bulk data load).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion Flag' ;
    rdfs:comment 'Flag indicating whether this segment represents an exclusion list (true) or an inclusion list (false). Exclusion segments are used to suppress communications.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:givingLevelMax rdf:type rdf:Property ;
    rdfs:label 'Giving Level Max' ;
    rdfs:comment 'Maximum cumulative giving amount threshold for inclusion in this segment (e.g., $49,999 for mid-level segment). Null if no upper bound.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:givingLevelMin rdf:type rdf:Property ;
    rdfs:label 'Giving Level Min' ;
    rdfs:comment 'Minimum cumulative giving amount threshold for inclusion in this segment (e.g., $10,000 for major donor segment). Null if not applicable.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDynamic rdf:type rdf:Property ;
    rdfs:label 'Is Dynamic' ;
    rdfs:comment 'Flag indicating whether segment membership is dynamically recalculated based on criteria (true) or manually managed (false).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Date' ;
    rdfs:comment 'Date when the segment membership was last recalculated or updated.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Donor lifecycle stage this segment represents: prospect (not yet donated), first_time (new donor), repeat (multi-year donor), lapsed (inactive), lybunt (Last Year But Unfortunately Not This Year), sybunt (Some Years But Unfortunately Not This Year), major (major gift donor), planned_giving (legacy/bequest donor). [ENUM-REF-CANDIDATE: prospect|first_time|repeat|lapsed|lybunt|sybunt|major|planned_giving — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Current number of active constituent members assigned to this segment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programmaticFocus rdf:type rdf:Property ;
    rdfs:label 'Programmatic Focus' ;
    rdfs:comment 'Thematic program area or SDG (Sustainable Development Goal) focus that defines this segment (e.g., \'WASH (Water Sanitation and Hygiene)\', \'Education\', \'Health\', \'Emergency Response\'). Null if not program-specific.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'Frequency at which dynamic segment membership is recalculated: daily, weekly, monthly, quarterly, on_demand (triggered by user), manual (no automatic refresh).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfmScoreMax rdf:type rdf:Property ;
    rdfs:label 'Rfm Score Max' ;
    rdfs:comment 'Maximum RFM (Recency-Frequency-Monetary) composite score for inclusion in this segment. Null if no upper bound.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfmScoreMin rdf:type rdf:Property ;
    rdfs:label 'Rfm Score Min' ;
    rdfs:comment 'Minimum RFM (Recency-Frequency-Monetary) composite score for inclusion in this segment. Null if RFM scoring not used.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Short alphanumeric code or abbreviation for the segment used in reporting and campaign tagging (e.g., MAJ-2024, LYBUNT-Q1, MID-ANN).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the segment purpose, target audience, and business rationale (e.g., \'Donors who gave last year but not this year, targeted for re-engagement\').' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the donor segment (e.g., Major Donors 2024, LYBUNT Q1, Mid-Level Annual Givers).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment: active (in use for campaigns), inactive (temporarily disabled), archived (historical, no longer used), draft (under development).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segment by its primary segmentation dimension: giving_level (major, mid-level, annual), rfm_tier (recency-frequency-monetary scoring), donor_type (individual, institutional, foundation, corporate), geographic (region-based), programmatic_interest (thematic focus area), acquisition_channel (source of donor acquisition).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stewardshipTier rdf:type rdf:Property ;
    rdfs:label 'Stewardship Tier' ;
    rdfs:comment 'Level of stewardship and engagement this segment receives: standard (basic acknowledgment), enhanced (personalized updates), premium (quarterly reports and calls), vip (executive engagement and site visits).' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'Reason for exclusion if this is a suppression segment (e.g., \'Do Not Contact\', \'Deceased\', \'Unsubscribed\', \'Litigation Hold\'). Null if not an exclusion segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMemberCount rdf:type rdf:Property ;
    rdfs:label 'Target Member Count' ;
    rdfs:comment 'Planned or target number of members for this segment, used for capacity planning and campaign sizing.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wealthScreeningTier rdf:type rdf:Property ;
    rdfs:label 'Wealth Screening Tier' ;
    rdfs:comment 'Wealth capacity rating tier from prospect research or wealth screening services (e.g., \'High Net Worth\', \'Ultra High Net Worth\', \'Mid-Level Capacity\'). Null if wealth screening not applied.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when the donor segment was first created in the CRM (Constituent Relationship Management) system.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorConstituentId rdf:type rdf:Property ;
    rdfs:label 'Donor Constituent Id' ;
    rdfs:comment 'Reference to the staff member or partner contact responsible for fund stewardship, donor reporting, and compliance oversight for this fund.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:primaryDonorConstituentId rdf:type rdf:Property ;
    rdfs:label 'Primary Donor Constituent Id' ;
    rdfs:comment 'Reference to the primary donor or institutional funder who established or designated this fund. Links fund to donor cultivation and stewardship records in Salesforce Nonprofit Cloud or Raisers Edge NXT.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:auditRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Required' ;
    rdfs:comment 'Indicates whether the fund is subject to separate audit requirements beyond organizational annual audit, such as single audit or donor-specific financial audit per OMB Uniform Guidance or grant terms.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balance rdf:type rdf:Property ;
    rdfs:label 'Balance' ;
    rdfs:comment 'Current available balance in the fund representing cumulative gifts received minus disbursements and allocations. Updated through integration with SAP S/4HANA or Unit4 ERP fund accounting modules.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryPopulation rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Population' ;
    rdfs:comment 'Description of the target beneficiary population or vulnerable group that this fund is designated to serve (e.g., IDPs, refugees, children under 5, women survivors of GBV).' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date when the fund was formally closed and ceased accepting new gifts. Nullable for active funds. Used for endowment spend-down tracking and restricted fund completion.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Share Percentage' ;
    rdfs:comment 'Required percentage of organizational cost-sharing or matching funds relative to total project budget. Nullable if cost share is not required.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costShareRequired rdf:type rdf:Property ;
    rdfs:label 'Cost Share Required' ;
    rdfs:comment 'Indicates whether the fund requires organizational cost-sharing or matching contributions per donor agreement terms. True if cost share is mandatory.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dacSectorCode rdf:type rdf:Property ;
    rdfs:label 'Dac Sector Code' ;
    rdfs:comment 'Five-digit OECD DAC sector classification code indicating the primary sector focus of the fund (e.g., health, education, WASH, humanitarian aid). Required for DAC reporting by institutional donors.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endowmentSpendingPolicy rdf:type rdf:Property ;
    rdfs:label 'Endowment Spending Policy' ;
    rdfs:comment 'Description of the board-approved spending policy for endowment funds, including annual distribution rate, calculation methodology, and underwater endowment provisions per ASC 958.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundCategory rdf:type rdf:Property ;
    rdfs:label 'Fund Category' ;
    rdfs:comment 'High-level classification of the fund\'s purpose for portfolio management and strategic planning. Distinguishes operating funds from capital campaigns, emergency response funds, and endowments. [ENUM-REF-CANDIDATE: operating|capital|program|emergency_response|endowment|scholarship|research — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundCode rdf:type rdf:Property ;
    rdfs:label 'Fund Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the fund in donor communications, grant agreements, and financial reports. Used as the business identifier for fund accounting and stewardship.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundDescription rdf:type rdf:Property ;
    rdfs:label 'Fund Description' ;
    rdfs:comment 'Detailed narrative describing the purpose, scope, and intended use of the fund. Captures donor intent and programmatic objectives for stewardship and compliance reporting.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundName rdf:type rdf:Property ;
    rdfs:label 'Fund Name' ;
    rdfs:comment 'Full descriptive name of the fund as presented to donors and in financial statements. Human-readable identity label for the fund.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundStatus rdf:type rdf:Property ;
    rdfs:label 'Fund Status' ;
    rdfs:comment 'Current lifecycle state of the fund indicating whether it is actively accepting gifts and disbursing funds, or has been closed or temporarily suspended.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundType rdf:type rdf:Property ;
    rdfs:label 'Fund Type' ;
    rdfs:comment 'Classification of the fund based on donor restrictions and organizational policy. Determines accounting treatment per ASC 958 net asset classification requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'Chart of Accounts (CoA) code in SAP S/4HANA or Unit4 ERP to which this fund maps for financial accounting and fund accounting purposes. Enables reconciliation between donor-facing fund designations and GL postings.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatiIdentifier rdf:type rdf:Property ;
    rdfs:label 'Iati Identifier' ;
    rdfs:comment 'Unique IATI activity identifier for this fund if reported under IATI transparency standards. Enables public disclosure and donor coordination.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inceptionDate rdf:type rdf:Property ;
    rdfs:label 'Inception Date' ;
    rdfs:comment 'Date when the fund was established and opened for gift acceptance. Marks the beginning of the fund\'s lifecycle.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investmentPolicy rdf:type rdf:Property ;
    rdfs:label 'Investment Policy' ;
    rdfs:comment 'Summary of investment strategy and asset allocation policy for endowment or quasi-endowment funds. References board-approved investment policy statement.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGiftAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Gift Amount' ;
    rdfs:comment 'Minimum contribution threshold required to designate a gift to this fund. Used for major gift funds, endowments, and named funds with donor-established minimums.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Required frequency of stewardship and financial reporting to the donor or funding agency for this fund per grant agreement or donor stewardship plan.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionDescription rdf:type rdf:Property ;
    rdfs:label 'Restriction Description' ;
    rdfs:comment 'Detailed explanation of donor-imposed restrictions, including specific programmatic purposes, geographic limitations, beneficiary populations, or time-bound conditions that govern fund usage.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Restriction Expiration Date' ;
    rdfs:comment 'Date when time-based donor restrictions expire and temporarily restricted funds are released to unrestricted net assets. Nullable for perpetual or purpose-only restrictions.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Nature of donor-imposed restrictions on the fund. Purpose-restricted funds must be used for specific programs or activities; time-restricted funds have temporal constraints; perpetual restrictions apply to endowments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCountries rdf:type rdf:Property ;
    rdfs:label 'Target Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where the fund\'s resources are designated to be used. Supports geographic restriction tracking and field operations planning.' ;
    rdfs:domain ind:DonorFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundraisingEventId rdf:type rdf:Property ;
    rdfs:label 'Fundraising Event Id' ;
    rdfs:comment 'Unique identifier for the fundraising event record. Primary key.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundraisingEvent .

ind:primaryDigitalContentId rdf:type rdf:Property ;
    rdfs:label 'Primary Digital Content Id' ;
    rdfs:comment 'Foreign key linking to communication.digital_content. Business justification: Events generate dedicated digital content (event landing pages, social media posts with event hashtags, photo galleries, promotional videos). Event marketing teams need direct event-to-content linkage' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalContent .

ind:acknowledgmentSentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Sent Date' ;
    rdfs:comment 'The date when thank-you acknowledgments or tax receipts were sent to event participants and donors.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityTotal rdf:type rdf:Property ;
    rdfs:label 'Capacity Total' ;
    rdfs:comment 'The maximum number of attendees the event can accommodate based on venue or platform constraints.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Short alphanumeric code or identifier used for internal tracking and reporting of the event.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed narrative description of the fundraising event, including purpose, activities, and beneficiary impact.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventEndTime rdf:type rdf:Property ;
    rdfs:label 'Event End Time' ;
    rdfs:comment 'The precise date and time when the fundraising event is scheduled to conclude.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Event Manager Email' ;
    rdfs:comment 'The email address of the event manager for coordination and communication purposes.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventManagerName rdf:type rdf:Property ;
    rdfs:label 'Event Manager Name' ;
    rdfs:comment 'The name of the staff member or volunteer responsible for managing and coordinating the fundraising event.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventManagerPhone rdf:type rdf:Property ;
    rdfs:label 'Event Manager Phone' ;
    rdfs:comment 'The phone number of the event manager for coordination and communication purposes.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventName rdf:type rdf:Property ;
    rdfs:label 'Event Name' ;
    rdfs:comment 'The official name or title of the fundraising event (e.g., Annual Gala, Spring Golf Tournament, Virtual Benefit Concert).' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStartTime rdf:type rdf:Property ;
    rdfs:label 'Event Start Time' ;
    rdfs:comment 'The precise date and time when the fundraising event is scheduled to begin.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fundraisingGoalAmount rdf:type rdf:Property ;
    rdfs:label 'Fundraising Goal Amount' ;
    rdfs:comment 'The target revenue amount the organization aims to raise from this event.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isTaxDeductible rdf:type rdf:Property ;
    rdfs:label 'Is Tax Deductible' ;
    rdfs:comment 'Indicates whether contributions made to this event qualify for tax deduction under IRS 501(c)(3) regulations or equivalent.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVirtualEvent rdf:type rdf:Property ;
    rdfs:label 'Is Virtual Event' ;
    rdfs:comment 'Indicates whether the fundraising event is conducted virtually (online) rather than at a physical venue.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The username or identifier of the system user who last modified this fundraising event record.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netRevenue rdf:type rdf:Property ;
    rdfs:label 'Net Revenue' ;
    rdfs:comment 'The net proceeds from the event, calculated as total revenue raised minus total event cost.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationCloseDate rdf:type rdf:Property ;
    rdfs:label 'Registration Close Date' ;
    rdfs:comment 'The date when registration for the event closes and no further registrations are accepted.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationOpenDate rdf:type rdf:Property ;
    rdfs:label 'Registration Open Date' ;
    rdfs:comment 'The date when registration for the event opens to constituents.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorshipLevelsAvailable rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Levels Available' ;
    rdfs:comment 'Comma-separated list or description of sponsorship tiers offered for the event (e.g., Platinum, Gold, Silver, Bronze).' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDeductiblePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Deductible Percentage' ;
    rdfs:comment 'The percentage of ticket price or contribution that qualifies as a tax-deductible charitable donation (e.g., 70% if 30% represents fair market value of goods/services received).' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ticketPriceTiers rdf:type rdf:Property ;
    rdfs:label 'Ticket Price Tiers' ;
    rdfs:comment 'Description or list of ticket pricing options available for attendees (e.g., General Admission, VIP, Student, Early Bird).' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAttendance rdf:type rdf:Property ;
    rdfs:label 'Total Attendance' ;
    rdfs:comment 'The actual number of individuals who attended the fundraising event, confirmed via check-in or participation tracking.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalEventCost rdf:type rdf:Property ;
    rdfs:label 'Total Event Cost' ;
    rdfs:comment 'The total expenses incurred to plan, organize, and execute the fundraising event (venue, catering, marketing, staff, etc.).' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRegistrations rdf:type rdf:Property ;
    rdfs:label 'Total Registrations' ;
    rdfs:comment 'The total number of individuals who registered for the fundraising event.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRevenueRaised rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Raised' ;
    rdfs:comment 'The actual total revenue generated from the fundraising event, including ticket sales, sponsorships, donations, and auction proceeds.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:venueAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Venue Address Line1' ;
    rdfs:comment 'First line of the street address for the event venue.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Venue Address Line2' ;
    rdfs:comment 'Second line of the street address for the event venue (suite, floor, building).' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueCity rdf:type rdf:Property ;
    rdfs:label 'Venue City' ;
    rdfs:comment 'City where the event venue is located.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueCountryCode rdf:type rdf:Property ;
    rdfs:label 'Venue Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the event venue location.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venuePostalCode rdf:type rdf:Property ;
    rdfs:label 'Venue Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the event venue location.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueStateProvince rdf:type rdf:Property ;
    rdfs:label 'Venue State Province' ;
    rdfs:comment 'State or province where the event venue is located.' ;
    rdfs:domain ind:FundraisingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualPlatform rdf:type rdf:Property ;
    rdfs:label 'Virtual Platform' ;
    rdfs:comment 'Name of the online platform or service used to host the virtual fundraising event (e.g., Zoom, Microsoft Teams, custom web portal).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftId rdf:type rdf:Property ;
    rdfs:label 'Gift Id' ;
    rdfs:comment 'Unique identifier for the gift transaction. Primary key for the gift data product.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gift .

ind:evaluationId rdf:type rdf:Property ;
    rdfs:label 'Evaluation Id' ;
    rdfs:comment 'Foreign key linking to mel.evaluation. Business justification: Major gifts may trigger or fund specific evaluations as a donor requirement. Tracking which gifts funded which evaluations is essential for donor reporting, acknowledgment, and demonstrating how donor' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Evaluation .

ind:giftConstituentId rdf:type rdf:Property ;
    rdfs:label 'Gift Constituent Id' ;
    rdfs:comment 'Reference to the donor who made this gift. Links to the donor master record in the donor domain.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:giftMatchingEmployerConstituentId rdf:type rdf:Property ;
    rdfs:label 'Gift Matching Employer Constituent Id' ;
    rdfs:comment 'Reference to the corporate donor or employer providing the matching gift. Populated only when matching_gift_flag is true.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:indicatorId rdf:type rdf:Property ;
    rdfs:label 'Indicator Id' ;
    rdfs:comment 'Foreign key linking to mel.indicator. Business justification: Restricted gifts often fund specific programmatic outcomes tracked by indicators. Linking gift to indicator enables outcomes-based donor reporting, showing donors the specific results their contributi' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Indicator .

ind:indicatorResultId rdf:type rdf:Property ;
    rdfs:label 'Indicator Result Id' ;
    rdfs:comment 'Foreign key linking to mel.indicator_result. Business justification: Gifts restricted to specific outcomes need linkage to actual results achieved. This is the core of outcomes-based donor reporting, enabling nonprofits to show donors the specific results their contrib' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndicatorResult .

ind:majorGiftOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Major Gift Opportunity Id' ;
    rdfs:comment 'Foreign key linking to donor.major_gift_opportunity. Business justification: Gifts can close major gift opportunities. Linking closed opportunities to realized gifts enables pipeline conversion tracking, forecasting accuracy analysis, and gift officer performance measurement. ' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MajorGiftOpportunity .

ind:originalGiftId rdf:type rdf:Property ;
    rdfs:label 'Original Gift Id' ;
    rdfs:comment 'Reference to the original employee gift that this matching gift is matching. Populated only for matching gifts.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gift .

ind:pledgeId rdf:type rdf:Property ;
    rdfs:label 'Pledge Id' ;
    rdfs:comment 'Foreign key linking to donor.pledge. Business justification: Gifts can be payments against pledges. This FK is CRITICAL for pledge fulfillment tracking, balance calculation, and installment schedule management. Nullable (not all gifts are pledge payments; some ' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pledge .

ind:acknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Date' ;
    rdfs:comment 'Date the donor acknowledgement or thank-you letter was sent for this gift.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgementType rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Type' ;
    rdfs:comment 'Classification of the donor acknowledgement or thank-you communication sent for this gift. [ENUM-REF-CANDIDATE: standard|personalized|major-gift|planned-giving|corporate|foundation|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The gross monetary value of the gift in the transaction currency before any adjustments or fees.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:anonymousFlag rdf:type rdf:Property ;
    rdfs:label 'Anonymous Flag' ;
    rdfs:comment 'Indicates whether the donor requested anonymity for this gift in public recognition and donor lists.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Gift processing batch identifier for grouping gifts deposited or processed together for reconciliation and audit purposes.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Transaction processing fees or costs deducted from the gross gift amount (e.g., credit card fees, wire transfer fees).' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftDate rdf:type rdf:Property ;
    rdfs:label 'Gift Date' ;
    rdfs:comment 'The date the gift was received or pledged. This is the principal business event timestamp for revenue recognition per FASB ASC 958.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:giftNumber rdf:type rdf:Property ;
    rdfs:label 'Gift Number' ;
    rdfs:comment 'Externally-known unique business identifier for this gift transaction, used for donor communication and receipt references.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftStatus rdf:type rdf:Property ;
    rdfs:label 'Gift Status' ;
    rdfs:comment 'Current lifecycle status of the gift transaction in the processing workflow.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftType rdf:type rdf:Property ;
    rdfs:label 'Gift Type' ;
    rdfs:comment 'Discriminator indicating the nature and form of the gift. Determines processing rules, revenue recognition treatment, and IRS substantiation requirements. [ENUM-REF-CANDIDATE: cash|check|wire|in-kind|stock|cryptocurrency|matching|tribute|pledge|recurring|refund|adjustment — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date this gift transaction was posted to the general ledger for financial reporting.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsServicesValue rdf:type rdf:Property ;
    rdfs:label 'Goods Services Value' ;
    rdfs:comment 'Fair market value of any goods or services provided to the donor in exchange for the gift, required for IRS substantiation and deductibility calculation.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:honoreeName rdf:type rdf:Property ;
    rdfs:label 'Honoree Name' ;
    rdfs:comment 'Full name of the person being honored or memorialized by this tribute gift. Populated only when tribute_flag is true.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Irs Compliant Flag' ;
    rdfs:comment 'Indicates whether the gift acknowledgement includes IRS-required substantiation language for charitable contribution deductions per IRS Publication 1771.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Match Approval Status' ;
    rdfs:comment 'Current status of the matching gift request with the employer. Populated only for matching gifts.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchRatio rdf:type rdf:Property ;
    rdfs:label 'Match Ratio' ;
    rdfs:comment 'The employer matching ratio (e.g., 1.00 for 1:1, 2.00 for 2:1, 0.50 for 1:2). Populated only for matching gifts.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchRequestDate rdf:type rdf:Property ;
    rdfs:label 'Match Request Date' ;
    rdfs:comment 'Date the matching gift request was submitted to the employer. Populated only for matching gifts.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchingGiftFlag rdf:type rdf:Property ;
    rdfs:label 'Matching Gift Flag' ;
    rdfs:comment 'Indicates whether this gift is a corporate matching gift from an employer matching an employees donation.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The net amount received after deducting processing fees, transaction costs, or goods-and-services fair market value per IRS requirements.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationRecipientAddress rdf:type rdf:Property ;
    rdfs:label 'Notification Recipient Address' ;
    rdfs:comment 'Mailing address for sending tribute gift notification to the honorees family or designated recipient.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRecipientName rdf:type rdf:Property ;
    rdfs:label 'Notification Recipient Name' ;
    rdfs:comment 'Name of the person who should be notified about this tribute gift (typically a family member of the honoree).' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the tribute gift notification has been sent to the designated recipient.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'The interface or touchpoint through which the donor made the gift, used for campaign attribution and channel effectiveness analysis. [ENUM-REF-CANDIDATE: online|mobile-app|direct-mail|phone|in-person|event|major-gift-officer|peer-to-peer|text-to-give|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The financial instrument or mechanism used to make the gift payment. [ENUM-REF-CANDIDATE: credit-card|debit-card|ach|wire-transfer|check|cash|paypal|stock-transfer|cryptocurrency|mobile-payment|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Unique receipt number issued for this gift for IRS substantiation and donor tax deduction purposes.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Flag' ;
    rdfs:comment 'Indicates whether this record represents a gift refund or reversal transaction.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundReason rdf:type rdf:Property ;
    rdfs:label 'Refund Reason' ;
    rdfs:comment 'Explanation or business reason for refunding or reversing this gift. Populated only when refund_flag is true.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tributeFlag rdf:type rdf:Property ;
    rdfs:label 'Tribute Flag' ;
    rdfs:comment 'Indicates whether this gift is made in honor or memory of another person (tribute gift).' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tributeType rdf:type rdf:Property ;
    rdfs:label 'Tribute Type' ;
    rdfs:comment 'Classification of the tribute gift as either in honor of a living person or in memory of a deceased person. Populated only when tribute_flag is true.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'Actual date when the opportunity was closed (won or lost). Populated when solicitation_stage reaches closed_won or closed_lost.' ;
    rdfs:domain ind:MajorGiftOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:askStrategy rdf:type rdf:Property ;
    rdfs:label 'Ask Strategy' ;
    rdfs:comment 'Narrative description of the solicitation approach, cultivation plan, and key messaging tailored to this donor\'s interests and capacity.' ;
    rdfs:domain ind:MajorGiftOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Timestamp when this major gift opportunity record was first created in the system.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorRecognitionLevel rdf:type rdf:Property ;
    rdfs:label 'Donor Recognition Level' ;
    rdfs:comment 'Anticipated recognition tier or giving society membership the donor will qualify for if the gift is secured (e.g., Leadership Circle, Legacy Society).' ;
    rdfs:domain ind:MajorGiftOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Anticipated date when the donor is expected to make a commitment decision or when the gift will be secured.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedGiftAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Gift Amount' ;
    rdfs:comment 'The anticipated or forecasted gift amount based on donor capacity, engagement level, and cultivation progress. May differ from ask amount.' ;
    rdfs:domain ind:MajorGiftOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The organization\'s fiscal year in which this opportunity is expected to close, used for annual fundraising goal tracking and reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftPurpose rdf:type rdf:Property ;
    rdfs:label 'Gift Purpose' ;
    rdfs:comment 'Detailed description of the intended use or program impact of the gift, aligned with donor interests and organizational priorities.' ;
    rdfs:domain ind:MajorGiftOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMatchingGiftEligible rdf:type rdf:Property ;
    rdfs:label 'Is Matching Gift Eligible' ;
    rdfs:comment 'Flag indicating whether this gift is eligible for corporate matching gift programs through the donor\'s employer.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the most recent substantive interaction or touchpoint with the donor regarding this opportunity.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Timestamp when this opportunity record was last updated or modified.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Explanation or categorization of why the opportunity was closed-lost, if applicable. Used for pipeline analysis and strategy refinement.' ;
    rdfs:domain ind:MajorGiftOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStepAction rdf:type rdf:Property ;
    rdfs:label 'Next Step Action' ;
    rdfs:comment 'Description of the next planned cultivation or solicitation activity (e.g., site visit, proposal submission, follow-up meeting).' ;
    rdfs:domain ind:MajorGiftOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStepDate rdf:type rdf:Property ;
    rdfs:label 'Next Step Date' ;
    rdfs:comment 'Scheduled date for the next cultivation or solicitation activity with this prospect.' ;
    rdfs:domain ind:MajorGiftOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opportunityCode rdf:type rdf:Property ;
    rdfs:label 'Opportunity Code' ;
    rdfs:comment 'Unique business identifier or tracking code for this opportunity, used for external reporting and donor communications.' ;
    rdfs:domain ind:MajorGiftOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Descriptive name or title for this major gift opportunity, typically including donor name and purpose (e.g., \'Smith Foundation - WASH Program Endowment\').' ;
    rdfs:domain ind:MajorGiftOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Probability Percentage' ;
    rdfs:comment 'Estimated likelihood (0-100%) that this opportunity will close successfully, based on donor engagement, capacity, and stage progression.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposalReference rdf:type rdf:Property ;
    rdfs:label 'Proposal Reference' ;
    rdfs:comment 'Reference number or identifier for the formal written proposal or case for support submitted to the donor, if applicable.' ;
    rdfs:domain ind:MajorGiftOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitationStage rdf:type rdf:Property ;
    rdfs:label 'Solicitation Stage' ;
    rdfs:comment 'Current stage in the major gift solicitation pipeline. Tracks progression from initial identification through cultivation, ask, and closure. [ENUM-REF-CANDIDATE: identification|qualification|cultivation|solicitation|negotiation|stewardship|closed_won|closed_lost — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'The channel or method through which this major gift opportunity was originally identified or sourced. [ENUM-REF-CANDIDATE: direct_mail|event|peer_referral|board_introduction|prospect_research|planned_giving|online — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageChangedDate rdf:type rdf:Property ;
    rdfs:label 'Stage Changed Date' ;
    rdfs:comment 'Timestamp when the solicitation_stage was last changed, used to track velocity through the pipeline.' ;
    rdfs:domain ind:MajorGiftOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:weightedValue rdf:type rdf:Property ;
    rdfs:label 'Weighted Value' ;
    rdfs:comment 'Calculated forecast value (expected_gift_amount × probability_percentage) used for revenue forecasting and pipeline analysis.' ;
    rdfs:domain ind:MajorGiftOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGivingId rdf:type rdf:Property ;
    rdfs:label 'Planned Giving Id' ;
    rdfs:comment 'Unique identifier for the planned giving arrangement. Primary key for the planned giving record.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPlannedDonorConstituentId rdf:type rdf:Property ;
    rdfs:label 'Primary Planned Donor Constituent Id' ;
    rdfs:comment 'Reference to the donor who has made the planned giving commitment. Links to the donor master record in Salesforce Nonprofit Cloud or Raisers Edge NXT.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:attorneyContact rdf:type rdf:Property ;
    rdfs:label 'Attorney Contact' ;
    rdfs:comment 'Contact information (email or phone) for the estate planning attorney. Used for verification and coordination purposes.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attorneyFirm rdf:type rdf:Property ;
    rdfs:label 'Attorney Firm' ;
    rdfs:comment 'Law firm or legal practice of the estate planning attorney.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attorneyName rdf:type rdf:Property ;
    rdfs:label 'Attorney Name' ;
    rdfs:comment 'Name of the estate planning attorney or legal advisor who prepared the planned giving documentation.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Date' ;
    rdfs:comment 'Date when the donor formally committed to the planned gift arrangement, typically when legal documentation was executed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidentialityFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Flag' ;
    rdfs:comment 'Indicates whether the donor has requested that the planned gift remain confidential and not be publicly acknowledged or included in donor recognition materials.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'Discount rate applied for present value calculations of future planned gift proceeds. Typically based on IRS Section 7520 rate or organizational cost of capital.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentationReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Documentation Received Date' ;
    rdfs:comment 'Date when the organization received formal legal documentation of the planned gift (e.g., copy of will provision, trust agreement, beneficiary designation form).' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estateReference rdf:type rdf:Property ;
    rdfs:label 'Estate Reference' ;
    rdfs:comment 'Reference to the donor\'s estate plan, will, or trust document that contains the planned gift provision. May include estate case number or trust name.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Value' ;
    rdfs:comment 'Estimated present or future value of the planned gift in the organization\'s functional currency. For bequests, this represents the estimated bequest amount; for trusts and annuities, the expected remainder value.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Estimated Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated value (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAdvisorFirm rdf:type rdf:Property ;
    rdfs:label 'Financial Advisor Firm' ;
    rdfs:comment 'Financial advisory firm or wealth management company of the financial advisor.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAdvisorName rdf:type rdf:Property ;
    rdfs:label 'Financial Advisor Name' ;
    rdfs:comment 'Name of the financial advisor or wealth manager involved in the planned giving arrangement.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftVehicleSubtype rdf:type rdf:Property ;
    rdfs:label 'Gift Vehicle Subtype' ;
    rdfs:comment 'Detailed subtype of the planned gift vehicle, such as CRUT (Charitable Remainder Unitrust), CRAT (Charitable Remainder Annuity Trust), or specific bequest type (residual, specific, contingent).' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legacySocietyMember rdf:type rdf:Property ;
    rdfs:label 'Legacy Society Member' ;
    rdfs:comment 'Indicates whether the donor has been inducted into the organization\'s legacy society or planned giving recognition program as a result of this commitment.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalDocumentationStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Documentation Status' ;
    rdfs:comment 'Status of the legal documentation supporting the planned gift. Tracks progression from verbal intent through executed legal documents to verification and potential revocation.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maturityDate rdf:type rdf:Property ;
    rdfs:label 'Maturity Date' ;
    rdfs:comment 'Expected date when the planned gift will be realized by the organization. For life-contingent gifts, this may be estimated based on actuarial life expectancy; for term trusts, this is the trust termination date.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date when the organization was formally notified of the planned giving intention by the donor, estate attorney, or financial advisor.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedGiftType rdf:type rdf:Property ;
    rdfs:label 'Planned Gift Type' ;
    rdfs:comment 'Classification of the planned giving vehicle. Includes bequest intentions, charitable remainder trusts (CRT), charitable lead trusts (CLT), charitable gift annuities (CGA), life insurance policy assignments, and retained life estate arrangements.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentValue rdf:type rdf:Property ;
    rdfs:label 'Present Value' ;
    rdfs:comment 'Present value of the planned gift calculated by discounting the estimated future value to current dollars using the discount rate and expected maturity date.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:probabilityScore rdf:type rdf:Property ;
    rdfs:label 'Probability Score' ;
    rdfs:comment 'Estimated probability (0-100%) that the planned gift will be realized, based on documentation status, donor age, relationship strength, and other factors. Used for revenue forecasting.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:realizationDate rdf:type rdf:Property ;
    rdfs:label 'Realization Date' ;
    rdfs:comment 'Actual date when the planned gift was received and converted to a realized gift. Populated when the gift transitions from planned to actual.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:realizedValue rdf:type rdf:Property ;
    rdfs:label 'Realized Value' ;
    rdfs:comment 'Actual value received when the planned gift was realized. May differ from estimated value due to market changes, estate settlement, or other factors.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognitionPreference rdf:type rdf:Property ;
    rdfs:label 'Recognition Preference' ;
    rdfs:comment 'Donor\'s preference for recognition of the planned gift. Options include public recognition, anonymous giving, inclusion in legacy society, or no recognition.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Updated By' ;
    rdfs:comment 'User or system identifier of the person or process that last updated this planned giving record.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date when the planned gift was revoked or withdrawn by the donor. Populated if the donor amends their estate plan to remove the organization as beneficiary.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Reason provided for revocation of the planned gift, if known. May include change in financial circumstances, change in philanthropic priorities, or family considerations.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustReference rdf:type rdf:Property ;
    rdfs:label 'Trust Reference' ;
    rdfs:comment 'Reference identifier for the charitable trust (CRT or CLT) if applicable. May include trust name, trust tax ID, or trustee reference number.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'Date when the estimated value was determined or last updated.' ;
    rdfs:domain ind:PlannedGiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'Method used to determine the estimated value of the planned gift. Options include donor self-estimate, professional appraisal, actuarial calculation for annuities, estate planning document reference, or financial statement review.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentSent rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Sent' ;
    rdfs:comment 'Indicates whether a pledge acknowledgment letter or receipt has been sent to the donor.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'The cumulative amount paid to date across all installments. Updated as installment payments are received.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceOutstanding rdf:type rdf:Property ;
    rdfs:label 'Balance Outstanding' ;
    rdfs:comment 'The remaining unpaid balance on the pledge. Calculated as total_pledge_amount minus amount_paid.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date on which the donor or organization cancelled the pledge commitment. Populated only when pledge_status is cancelled.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstInstallmentDate rdf:type rdf:Property ;
    rdfs:label 'First Installment Date' ;
    rdfs:comment 'The scheduled due date for the first installment payment.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Date' ;
    rdfs:comment 'The date on which the pledge was fully paid and marked as fulfilled. Populated only when pledge_status is fulfilled.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Installment Frequency' ;
    rdfs:comment 'The recurring schedule for installment payments. One-time for single-payment pledges; monthly, quarterly, semi-annual, annual for standard recurring schedules; custom for irregular or donor-specified schedules.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installmentsPaid rdf:type rdf:Property ;
    rdfs:label 'Installments Paid' ;
    rdfs:comment 'The count of installments that have been fully paid to date. Updated as installment payments are received.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentsRemaining rdf:type rdf:Property ;
    rdfs:label 'Installments Remaining' ;
    rdfs:comment 'The count of installments that are still unpaid. Calculated as number_of_installments minus installments_paid.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this pledge is a recurring sustainer commitment with ongoing installments beyond the initial schedule.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInstallmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Installment Date' ;
    rdfs:comment 'The scheduled due date for the final installment payment.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'The amount of the most recent installment payment received.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'The date on which the most recent installment payment was received.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextInstallmentAmount rdf:type rdf:Property ;
    rdfs:label 'Next Installment Amount' ;
    rdfs:comment 'The scheduled amount for the next unpaid installment.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInstallmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Installment Due Date' ;
    rdfs:comment 'The due date for the next unpaid installment. Used for reminder generation and overdue tracking.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfInstallments rdf:type rdf:Property ;
    rdfs:label 'Number Of Installments' ;
    rdfs:comment 'The total number of scheduled installment payments for this pledge. For one-time pledges, this is 1.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pledgeDate rdf:type rdf:Property ;
    rdfs:label 'Pledge Date' ;
    rdfs:comment 'The date on which the donor made the pledge commitment. This is the principal business event timestamp for the pledge.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pledgeNumber rdf:type rdf:Property ;
    rdfs:label 'Pledge Number' ;
    rdfs:comment 'Human-readable business identifier for the pledge commitment, often displayed on donor communications and receipts.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pledgeStatus rdf:type rdf:Property ;
    rdfs:label 'Pledge Status' ;
    rdfs:comment 'Current lifecycle status of the pledge commitment. Active indicates ongoing installment schedule; fulfilled indicates all installments paid; lapsed indicates overdue with no recent payment; written-off indicates uncollectible; cancelled indicates donor withdrew commitment; pending indicates awaiting approval or activation.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pledgeType rdf:type rdf:Property ;
    rdfs:label 'Pledge Type' ;
    rdfs:comment 'Classification of the pledge based on its purpose and structure. Standard for general multi-installment pledges; sustainer for recurring monthly giving; major gift for high-value commitments; planned giving for estate or deferred gifts; capital campaign for infrastructure projects; endowment for permanent fund contributions.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderSchedule rdf:type rdf:Property ;
    rdfs:label 'Reminder Schedule' ;
    rdfs:comment 'The timing for automated payment reminders sent to the donor before each installment due date.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPledgeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Pledge Amount' ;
    rdfs:comment 'The total monetary value committed by the donor across all installments. This is the gross pledge amount before any payments.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'The outstanding balance amount that was written off. Populated only when pledge_status is written_off.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The date on which the pledge was written off as uncollectible. Populated only when pledge_status is written_off.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffReason rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason' ;
    rdfs:comment 'Free-text explanation for why the pledge was written off (e.g., donor deceased, donor financial hardship, unable to contact, donor dispute).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Assignment Id' ;
    rdfs:comment 'Primary key for portfolio_assignment' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPortfolioStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Portfolio Staff Member Id' ;
    rdfs:comment 'Reference to the major gift officer or fundraising staff member responsible for cultivating this constituent. Links to the staff/workforce record.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:stewardshipPlanId rdf:type rdf:Property ;
    rdfs:label 'Stewardship Plan Id' ;
    rdfs:comment 'Reference to the customized stewardship plan for this constituent. Links to the detailed stewardship activity schedule and touchpoint requirements.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:affinityFocusArea rdf:type rdf:Property ;
    rdfs:label 'Affinity Focus Area' ;
    rdfs:comment 'The program area, cause, or mission focus that aligns with the constituent\'s philanthropic interests. Used for matching donors with appropriate gift officers and program staff.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Assignment Created By' ;
    rdfs:comment 'Username or identifier of the system user who created this portfolio assignment record. Used for audit trail and accountability.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Created Timestamp' ;
    rdfs:comment 'System timestamp when this portfolio assignment record was first created in the CRM system. Used for data lineage and audit purposes.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'The date when the constituent was assigned to the gift officer\'s portfolio. Marks the start of the cultivation relationship.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'The date when the portfolio assignment was terminated or transferred. Null for active assignments. Used for calculating relationship duration and officer performance metrics.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Assignment Modified By' ;
    rdfs:comment 'Username or identifier of the system user who last modified this portfolio assignment record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Modified Timestamp' ;
    rdfs:comment 'System timestamp when this portfolio assignment record was last updated. Used for tracking data freshness and change history.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text notes documenting the context, history, or special considerations for this portfolio assignment. May include relationship history, donor preferences, or strategic guidance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'The business rationale for assigning this constituent to the gift officer. Provides context for portfolio management decisions and relationship continuity. [ENUM-REF-CANDIDATE: new_prospect|capacity_upgrade|geographic_alignment|relationship_transfer|officer_departure|portfolio_rebalance|strategic_priority|donor_request — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the portfolio assignment became effective. Used for tracking officer workload and relationship tenure.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:capacityCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Capacity Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated capacity amount. Supports multi-currency fundraising operations for international donors.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFrequencyTargetDays rdf:type rdf:Property ;
    rdfs:label 'Contact Frequency Target Days' ;
    rdfs:comment 'The target number of days between meaningful contacts for this portfolio tier. Used to monitor adherence to cultivation standards and identify overdue outreach.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementReadinessIndicator rdf:type rdf:Property ;
    rdfs:label 'Engagement Readiness Indicator' ;
    rdfs:comment 'Assessment of the constituent\'s current receptiveness to cultivation and solicitation activities. Informs timing and approach for next moves.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCapacityAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Capacity Amount' ;
    rdfs:comment 'The prospect research team\'s estimate of the constituent\'s philanthropic capacity. Used for portfolio segmentation and solicitation strategy. Confidential business intelligence.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedAskAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Ask Amount' ;
    rdfs:comment 'The planned solicitation amount for the next major gift request. Based on capacity research, giving history, and strategic priorities. Confidential cultivation planning data.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedAskDate rdf:type rdf:Property ;
    rdfs:label 'Expected Ask Date' ;
    rdfs:comment 'The target date for making the next major gift solicitation. Used for pipeline forecasting and officer activity planning.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicTerritory rdf:type rdf:Property ;
    rdfs:label 'Geographic Territory' ;
    rdfs:comment 'The geographic region or territory this constituent belongs to, used for portfolio segmentation when officers are assigned by geography. May be city, state, region, or country.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastGiftAmount rdf:type rdf:Property ;
    rdfs:label 'Last Gift Amount' ;
    rdfs:comment 'The monetary value of the most recent gift from this constituent. Used for upgrade potential assessment and solicitation sizing.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextContactScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Contact Scheduled Date' ;
    rdfs:comment 'The planned date for the next cultivation contact or stewardship touchpoint. Used for officer task management and ensuring consistent donor engagement.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portfolioLoadWeight rdf:type rdf:Property ;
    rdfs:label 'Portfolio Load Weight' ;
    rdfs:comment 'Weighted value representing the workload contribution of this assignment to the officer\'s total portfolio. Higher-tier prospects carry greater weight. Used for portfolio load balancing.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Portfolio Priority Rank' ;
    rdfs:comment 'Numeric ranking of this constituent within the officer\'s portfolio based on giving capacity, engagement readiness, and strategic importance. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portfolioStatus rdf:type rdf:Property ;
    rdfs:label 'Portfolio Status' ;
    rdfs:comment 'Current state of the portfolio assignment. Active indicates ongoing cultivation; on-hold indicates temporary pause; transferred indicates reassignment to another officer; inactive indicates no current engagement; graduated indicates moved to sustained giving program; declined indicates prospect declined engagement.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioTier rdf:type rdf:Property ;
    rdfs:label 'Portfolio Tier' ;
    rdfs:comment 'Classification of the portfolio segment based on giving capacity and cultivation strategy. Determines the level of personalized engagement and stewardship required.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Proposal Submitted Date' ;
    rdfs:comment 'The date when the most recent gift proposal was submitted to the constituent. Used for tracking proposal aging and follow-up timing.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposalSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Proposal Submitted Flag' ;
    rdfs:comment 'Indicates whether a formal gift proposal has been submitted to this constituent. True if proposal is pending or under consideration; false otherwise.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipStrengthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength Score' ;
    rdfs:comment 'Numeric score (typically 1-10 or 1-100) representing the depth and quality of the relationship between the gift officer and constituent. Used for prioritization and readiness assessment.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLifetimeGivingAmount rdf:type rdf:Property ;
    rdfs:label 'Total Lifetime Giving Amount' ;
    rdfs:comment 'Cumulative total of all gifts from this constituent to the organization across their entire giving history. Used for portfolio segmentation and recognition planning.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Date' ;
    rdfs:comment 'The date when the constituent was transferred from the previous gift officer to the current officer. Null if this is the initial assignment.' ;
    rdfs:domain ind:PortfolioAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prospectId rdf:type rdf:Property ;
    rdfs:label 'Prospect Id' ;
    rdfs:comment 'Unique identifier for the prospect record. Primary key for the prospect entity.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prospect .

ind:prospectAssignedResearcherStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Prospect Assigned Researcher Staff Member Id' ;
    rdfs:comment 'Reference to the prospect research professional assigned to conduct research on this prospect. Links to staff record in HRIS or CRM.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:prospectStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Prospect Staff Member Id' ;
    rdfs:comment 'Reference to the major gift officer or fundraising staff member assigned primary responsibility for cultivating this prospect. Links to staff record in HRIS (Human Resource Information System) or CRM.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:abilityScore rdf:type rdf:Property ;
    rdfs:label 'Ability Score' ;
    rdfs:comment 'Ability score component of the LAI (Linkage-Ability-Interest) assessment. Measures financial capacity to make a significant gift. Typically scored 1-5.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardAffiliation rdf:type rdf:Property ;
    rdfs:label 'Board Affiliation' ;
    rdfs:comment 'Known board memberships or trustee positions held by the prospect at other nonprofit organizations, foundations, or corporate boards. Indicates philanthropic engagement and network connections.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date when the prospect converted to an active donor by making their first gift or grant commitment. Null if not yet converted.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cultivationStrategy rdf:type rdf:Property ;
    rdfs:label 'Cultivation Strategy' ;
    rdfs:comment 'Detailed narrative describing the cultivation strategy, engagement plan, and relationship-building approach for this prospect. Includes key talking points, areas of interest, preferred communication channels, and strategic next steps.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Explanation for why the prospect was disqualified from active cultivation. Null if prospect is not disqualified. Examples: \'Insufficient capacity\', \'No mission alignment\', \'Unresponsive to outreach\', \'Ethical concerns\'.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorRecognitionPreference rdf:type rdf:Property ;
    rdfs:label 'Donor Recognition Preference' ;
    rdfs:comment 'Prospect\'s stated preference for public recognition of their giving. Public (full recognition in donor lists and materials), Anonymous (no public attribution), Limited (recognition in select contexts only), No Preference (not yet specified).' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for prospect communication and correspondence.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCapacity rdf:type rdf:Property ;
    rdfs:label 'Estimated Capacity' ;
    rdfs:comment 'Estimated total giving capacity of the prospect in USD. Based on wealth screening, research, and capacity assessment. For institutional donors, represents estimated annual grant-making budget available for alignment with organizational mission.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedGiftRangeMax rdf:type rdf:Property ;
    rdfs:label 'Estimated Gift Range Max' ;
    rdfs:comment 'Maximum estimated gift amount expected from this prospect in USD. Upper bound of the anticipated solicitation range.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedGiftRangeMin rdf:type rdf:Property ;
    rdfs:label 'Estimated Gift Range Min' ;
    rdfs:comment 'Minimum estimated gift amount expected from this prospect in USD. Lower bound of the anticipated solicitation range.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicInterest rdf:type rdf:Property ;
    rdfs:label 'Geographic Interest' ;
    rdfs:comment 'Geographic regions or countries where the prospect has expressed interest in supporting programs. Comma-separated list of ISO 3166-1 alpha-3 country codes or regional descriptors.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationDate rdf:type rdf:Property ;
    rdfs:label 'Identification Date' ;
    rdfs:comment 'Date when the prospect was first identified and entered into the cultivation pipeline. Marks the beginning of the prospect lifecycle.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestScore rdf:type rdf:Property ;
    rdfs:label 'Interest Score' ;
    rdfs:comment 'Interest score component of the LAI (Linkage-Ability-Interest) assessment. Measures alignment of prospect\'s philanthropic interests with organizational mission and programs. Typically scored 1-5.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastContactType rdf:type rdf:Property ;
    rdfs:label 'Last Contact Type' ;
    rdfs:comment 'Type of the most recent contact or engagement activity with the prospect. [ENUM-REF-CANDIDATE: meeting|phone_call|email|event|site_visit|proposal_submission|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkageScore rdf:type rdf:Property ;
    rdfs:label 'Linkage Score' ;
    rdfs:comment 'Linkage score component of the LAI (Linkage-Ability-Interest) assessment. Measures strength of existing connections to the organization (board members, staff, volunteers, beneficiaries). Typically scored 1-5.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mailingAddress rdf:type rdf:Property ;
    rdfs:label 'Mailing Address' ;
    rdfs:comment 'Full mailing address for prospect correspondence. Includes street address, city, state/province, postal code, and country.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Date' ;
    rdfs:comment 'Scheduled date for the next cultivation activity or touchpoint with this prospect. Used for pipeline management and follow-up tracking.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextActionDescription rdf:type rdf:Property ;
    rdfs:label 'Next Action Description' ;
    rdfs:comment 'Description of the planned next cultivation action or engagement activity (e.g., \'Schedule site visit\', \'Send program impact report\', \'Invite to annual gala\', \'Submit grant proposal\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousGivingHistory rdf:type rdf:Property ;
    rdfs:label 'Previous Giving History' ;
    rdfs:comment 'Summary of the prospect\'s known philanthropic giving history to other organizations or prior gifts to this organization. Includes gift amounts, recipient organizations, and giving patterns.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programInterestArea rdf:type rdf:Property ;
    rdfs:label 'Program Interest Area' ;
    rdfs:comment 'Primary program area or thematic focus that aligns with the prospect\'s philanthropic interests (e.g., \'WASH\', \'Education\', \'Health\', \'Emergency Response\', \'Gender Equality\'). May reference SDG (Sustainable Development Goal) alignment.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectName rdf:type rdf:Property ;
    rdfs:label 'Prospect Name' ;
    rdfs:comment 'Full legal or preferred name of the prospective donor or funder. For institutional donors, this is the organization name.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectStatus rdf:type rdf:Property ;
    rdfs:label 'Prospect Status' ;
    rdfs:comment 'Current operational status of the prospect record. Active (currently being cultivated), Inactive (no current engagement), Disqualified (determined not viable), Converted (became active donor), On Hold (temporarily paused cultivation).' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectType rdf:type rdf:Property ;
    rdfs:label 'Prospect Type' ;
    rdfs:comment 'Classification of the prospect by donor category. Individual (major gift prospects), Foundation (private/family/community foundations), Corporate (corporate sponsors), Institutional (USAID, DFID, DAC members), Government (bilateral government donors), Multilateral (UN agencies, World Bank, regional development banks).' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date when the prospect was qualified as a viable cultivation target after initial research and assessment. Null if not yet qualified.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rating rdf:type rdf:Property ;
    rdfs:label 'Rating' ;
    rdfs:comment 'Qualitative rating assigned by prospect research or major gift officer indicating overall prospect quality and likelihood of conversion. A+ (highest priority, strongest capacity and affinity), D (lowest priority).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchStage rdf:type rdf:Property ;
    rdfs:label 'Research Stage' ;
    rdfs:comment 'Current stage of prospect research activities. Not Started (no research conducted), Preliminary (initial screening and public records review), In Depth (comprehensive research including wealth screening and relationship mapping), Completed (research finalized and briefing prepared), Ongoing Monitoring (periodic updates and news monitoring).' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitationAmount rdf:type rdf:Property ;
    rdfs:label 'Solicitation Amount' ;
    rdfs:comment 'Specific dollar amount being requested or proposed in the current solicitation. Null if not yet at solicitation stage.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solicitationDate rdf:type rdf:Property ;
    rdfs:label 'Solicitation Date' ;
    rdfs:comment 'Date when the formal ask or grant proposal was submitted to the prospect. Null if not yet solicited.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceOfWealth rdf:type rdf:Property ;
    rdfs:label 'Source Of Wealth' ;
    rdfs:comment 'Primary source of the prospect\'s wealth or funding capacity (e.g., \'Technology entrepreneur\', \'Inherited wealth\', \'Real estate\', \'Government appropriation\', \'Endowment income\'). For institutional donors, describes funding source.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage in the donor cultivation pipeline lifecycle. Identification (newly identified prospect), Qualification (research and capacity assessment underway), Cultivation (relationship building and engagement), Solicitation (active proposal or ask), Negotiation (terms and agreement discussion), Stewardship (post-gift relationship management).' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wealthScreeningScore rdf:type rdf:Property ;
    rdfs:label 'Wealth Screening Score' ;
    rdfs:comment 'Quantitative wealth screening score from third-party wealth screening service (e.g., WealthEngine, iWave). Typically scaled 0-100 indicating relative wealth capacity.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:softCreditId rdf:type rdf:Property ;
    rdfs:label 'Soft Credit Id' ;
    rdfs:comment 'Unique identifier for the soft credit record. Primary key.' ;
    rdfs:domain ind:SoftCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditedConstituentId rdf:type rdf:Property ;
    rdfs:label 'Credited Constituent Id' ;
    rdfs:comment 'Reference to the constituent receiving soft credit attribution for this gift. This is the individual or organization being credited for influence or shared recognition, distinct from the primary donor of record.' ;
    rdfs:domain ind:SoftCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:primarySoftUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Soft User Account Id' ;
    rdfs:comment 'Identifier of the user or system process that created the soft credit record. Used for audit trail and accountability tracking.' ;
    rdfs:domain ind:SoftCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:acknowledgmentSentFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Sent Flag' ;
    rdfs:comment 'Indicates whether a soft credit acknowledgment or notification has been sent to the credited constituent. True if acknowledgment sent, False if not sent. Used to track stewardship communication completion.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of the total gift amount allocated to this soft credit. Used when multiple soft credits split attribution for a single gift. Value ranges from 0.00 to 100.00. Sum of all allocation percentages for a gift may equal or exceed 100% depending on organizational attribution policy.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimeValueEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Lifetime Value Eligible Flag' ;
    rdfs:comment 'Indicates whether this soft credit amount should be included in the credited constituent\'s lifetime giving value calculation. True if included in lifetime value, False if excluded. Used to ensure accurate donor lifetime value metrics.' ;
    rdfs:domain ind:SoftCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Recognition Eligible Flag' ;
    rdfs:comment 'Indicates whether this soft credit counts toward donor recognition levels, giving societies, or cumulative giving milestones. True if eligible for recognition programs, False if excluded.' ;
    rdfs:domain ind:SoftCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:softCreditDate rdf:type rdf:Property ;
    rdfs:label 'Soft Credit Date' ;
    rdfs:comment 'Date when the soft credit was recorded or attributed. Typically matches the gift date but may differ if soft credit is applied retroactively or during gift processing workflows.' ;
    rdfs:domain ind:SoftCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:softCreditStatus rdf:type rdf:Property ;
    rdfs:label 'Soft Credit Status' ;
    rdfs:comment 'Current lifecycle status of the soft credit record. Active indicates the credit is valid and counted in reports. Inactive indicates the credit has been deactivated. Reversed indicates the credit was removed due to gift refund or correction. Pending indicates the credit is awaiting approval or verification.' ;
    rdfs:domain ind:SoftCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softCreditType rdf:type rdf:Property ;
    rdfs:label 'Soft Credit Type' ;
    rdfs:comment 'Classification of the soft credit attribution. Defines the relationship or role of the credited constituent to the gift. Common types include household member (spouse/partner sharing credit), solicitor credit (fundraiser who secured the gift), matching gift credit (employer matching program), tribute notification recipient (honoree or memorial notification), gift officer (staff member managing the relationship), and volunteer solicitor (board member or volunteer who influenced the gift).' ;
    rdfs:domain ind:SoftCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitorRelationship rdf:type rdf:Property ;
    rdfs:label 'Solicitor Relationship' ;
    rdfs:comment 'Describes the relationship of the credited constituent to the organization or primary donor. Used to segment soft credit attribution by relationship type for performance analysis and stewardship planning. [ENUM-REF-CANDIDATE: staff|board_member|volunteer|peer|family|advisor|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SoftCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPlanId rdf:type rdf:Property ;
    rdfs:label 'Distribution Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.distribution_plan. Business justification: Donor stewardship includes site visits to distributions, impact reports showing how gifts funded specific distribution plans, and donor recognition at distribution events. Critical for major donor eng' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionPlan .

ind:primaryStewardshipUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Stewardship User Account Id' ;
    rdfs:comment 'Reference to the system user who created this stewardship activity record. Audit trail for data governance.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:relatedProgramInterventionId rdf:type rdf:Property ;
    rdfs:label 'Related Program Intervention Id' ;
    rdfs:comment 'Reference to a specific program or project that was discussed or showcased during the stewardship activity. Nullable if not program-specific.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Intervention .

ind:acknowledgementSentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Sent Date' ;
    rdfs:comment 'The date on which the acknowledgement communication was sent to the donor. Nullable if no acknowledgement was sent.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgementSentFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Sent Flag' ;
    rdfs:comment 'Boolean indicator of whether a formal acknowledgement or thank-you communication was sent following this stewardship activity.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activityDate rdf:type rdf:Property ;
    rdfs:label 'Activity Date' ;
    rdfs:comment 'The date on which the stewardship activity was conducted or scheduled. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activityDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Description' ;
    rdfs:comment 'Detailed narrative description of the stewardship activity, including context, discussion points, and any relevant details captured by the staff member.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityOutcome rdf:type rdf:Property ;
    rdfs:label 'Activity Outcome' ;
    rdfs:comment 'Summary of the outcome or result of the stewardship activity, including donor response, feedback received, and any commitments made.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current lifecycle status of the stewardship activity indicating whether it is planned, completed, cancelled, rescheduled, or pending.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activitySubject rdf:type rdf:Property ;
    rdfs:label 'Activity Subject' ;
    rdfs:comment 'Brief subject line or title summarizing the purpose of the stewardship activity.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Number of individuals who participated in the stewardship activity, including staff and constituents. Applicable for meetings, site visits, and events.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'The medium or channel through which the stewardship activity was conducted (in-person meeting, phone call, email, video conference, postal mail, or event).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'The actual date on which the stewardship activity was marked as completed. Nullable for activities that are planned or cancelled.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorSentiment rdf:type rdf:Property ;
    rdfs:label 'Donor Sentiment' ;
    rdfs:comment 'Qualitative assessment of the donor\'s sentiment or engagement level observed during the stewardship activity, used for relationship health tracking.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactStorySharedFlag rdf:type rdf:Property ;
    rdfs:label 'Impact Story Shared Flag' ;
    rdfs:comment 'Boolean indicator of whether a beneficiary impact story or program outcome was shared with the donor during this activity.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical or virtual location where the stewardship activity took place (office address, donor site, event venue, or virtual meeting platform).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextSteps rdf:type rdf:Property ;
    rdfs:label 'Next Steps' ;
    rdfs:comment 'Documented follow-up actions or next steps identified during or after the stewardship activity to continue donor cultivation.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Solicitation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the solicitation amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitationMadeFlag rdf:type rdf:Property ;
    rdfs:label 'Solicitation Made Flag' ;
    rdfs:comment 'Boolean indicator of whether a funding solicitation or ask was made to the donor during this stewardship activity.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stewardshipPlanStage rdf:type rdf:Property ;
    rdfs:label 'Stewardship Plan Stage' ;
    rdfs:comment 'The stage in the donor cultivation and stewardship lifecycle that this activity supports, aligned with the organization\'s donor relationship management framework.' ;
    rdfs:domain ind:StewardshipActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wealthScreeningId rdf:type rdf:Property ;
    rdfs:label 'Wealth Screening Id' ;
    rdfs:comment 'Unique identifier for the wealth screening record. Primary key for the wealth screening data product.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessAffiliations rdf:type rdf:Property ;
    rdfs:label 'Business Affiliations' ;
    rdfs:comment 'Summary of the constituent\'s current and past business affiliations, including corporate board memberships, executive positions, and professional associations.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessOwnershipValue rdf:type rdf:Property ;
    rdfs:label 'Business Ownership Value' ;
    rdfs:comment 'Estimated value of private business ownership interests held by the constituent, including closely-held corporations, partnerships, and sole proprietorships.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityRatingTier rdf:type rdf:Property ;
    rdfs:label 'Capacity Rating Tier' ;
    rdfs:comment 'Assigned capacity rating tier or gift level classification based on the screening results, used by major gift officers for portfolio segmentation and solicitation strategy.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Consent Flag' ;
    rdfs:comment 'Boolean flag indicating whether the constituent has provided consent for wealth screening and prospect research activities, in compliance with data privacy regulations.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSourcesUsed rdf:type rdf:Property ;
    rdfs:label 'Data Sources Used' ;
    rdfs:comment 'Summary of the data sources and databases consulted by the screening provider, such as public records, SEC filings, property records, and philanthropic databases.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedNetWorth rdf:type rdf:Property ;
    rdfs:label 'Estimated Net Worth' ;
    rdfs:comment 'Estimated total net worth of the constituent in USD, calculated by the screening provider based on real estate holdings, stock portfolios, business ownership, and other wealth indicators.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foundationAffiliations rdf:type rdf:Property ;
    rdfs:label 'Foundation Affiliations' ;
    rdfs:comment 'List of private foundations or donor-advised funds with which the constituent is affiliated as a trustee, officer, or donor, indicating institutional giving capacity.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importBatchReference rdf:type rdf:Property ;
    rdfs:label 'Import Batch Reference' ;
    rdfs:comment 'Identifier for the batch import process that loaded this screening record from the third-party provider into Raisers Edge NXT, used for data lineage and troubleshooting.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWorthRange rdf:type rdf:Property ;
    rdfs:label 'Net Worth Range' ;
    rdfs:comment 'Categorical range classification of the constituent\'s estimated net worth, used for segmentation and prioritization in major gift programs.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonprofitBoardAffiliations rdf:type rdf:Property ;
    rdfs:label 'Nonprofit Board Affiliations' ;
    rdfs:comment 'List or summary of nonprofit organizations where the constituent serves or has served on the board of directors, trustees, or advisory council, indicating philanthropic engagement and sector interests.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:philanthropicCapacityEstimate rdf:type rdf:Property ;
    rdfs:label 'Philanthropic Capacity Estimate' ;
    rdfs:comment 'Estimated annual or lifetime philanthropic giving capacity in USD, calculated by the screening provider based on wealth indicators, income, and giving history patterns.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:politicalGivingTotal rdf:type rdf:Property ;
    rdfs:label 'Political Giving Total' ;
    rdfs:comment 'Total amount of political contributions made by the constituent to candidates, parties, and political action committees (PACs), sourced from Federal Election Commission (FEC) records.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:realEstateValue rdf:type rdf:Property ;
    rdfs:label 'Real Estate Value' ;
    rdfs:comment 'Estimated total value of real estate holdings owned by the constituent, including primary residence, investment properties, and land holdings.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewedByOfficer rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Officer' ;
    rdfs:comment 'Name or identifier of the major gift officer or prospect researcher who reviewed and validated the screening results.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Screening Confidence Score' ;
    rdfs:comment 'Confidence score or quality rating assigned by the screening provider, typically expressed as a percentage (0-100), indicating the reliability and completeness of the wealth data.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:screeningCost rdf:type rdf:Property ;
    rdfs:label 'Screening Cost' ;
    rdfs:comment 'Cost in USD charged by the third-party screening provider for this individual screening or as part of a batch screening contract.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:screeningProvider rdf:type rdf:Property ;
    rdfs:label 'Screening Provider' ;
    rdfs:comment 'Name of the third-party wealth screening and prospect research vendor that performed the screening analysis.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningType rdf:type rdf:Property ;
    rdfs:label 'Screening Type' ;
    rdfs:comment 'Type or category of wealth screening performed, indicating whether it was an individual deep-dive, batch upload, or portfolio-wide refresh.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockHoldingsValue rdf:type rdf:Property ;
    rdfs:label 'Stock Holdings Value' ;
    rdfs:comment 'Estimated total value of publicly traded stock holdings and securities owned by the constituent, derived from SEC filings and public disclosures.' ;
    rdfs:domain ind:WealthScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessConstraintId rdf:type rdf:Property ;
    rdfs:label 'Access Constraint Id' ;
    rdfs:comment 'Unique identifier for the humanitarian access constraint record.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedShipmentId rdf:type rdf:Property ;
    rdfs:label 'Affected Shipment Id' ;
    rdfs:comment 'Foreign key linking to supply.shipment. Business justification: Access constraints (roadblocks, armed conflict, bureaucratic delays) directly impact shipment delivery. Linking access_constraint to affected shipment enables donor reporting on pipeline delays, insur' ;
    rdfs:domain ind:Field ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:countryId rdf:type rdf:Property ;
    rdfs:label 'Country Id' ;
    rdfs:comment 'Foreign key linking to field.country. Business justification: access_constraint has country_code (STRING) but no FK to the country reference table. Access constraints are country-specific operational issues. Adding country_id FK normalizes the country reference ' ;
    rdfs:domain ind:Field ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:securityIncidentId rdf:type rdf:Property ;
    rdfs:label 'Security Incident Id' ;
    rdfs:comment 'Foreign key linking to field.security_incident. Business justification: Access constraints are often caused by security incidents. The access_constraint table has a boolean flag \'security_incident_linked\' indicating when a constraint is related to a security incident. Add' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SecurityIncident .

ind:affectedActivitiesDescription rdf:type rdf:Property ;
    rdfs:label 'Affected Activities Description' ;
    rdfs:comment 'Narrative description of the planned humanitarian activities that were delayed, cancelled, or modified due to the access constraint. May include distribution events, mobile health clinics, WASH interventions, or protection services.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedLocationName rdf:type rdf:Property ;
    rdfs:label 'Affected Location Name' ;
    rdfs:comment 'Name of the geographic location, project site, or supply route affected by the access constraint. May reference a specific village, district, road segment, or border crossing.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedPcode rdf:type rdf:Property ;
    rdfs:label 'Affected Pcode' ;
    rdfs:comment 'OCHA-standard place code (P-Code) identifying the administrative area affected by the constraint. Enables standardized geographic aggregation and mapping across humanitarian datasets.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeRouteAvailable rdf:type rdf:Property ;
    rdfs:label 'Alternative Route Available' ;
    rdfs:comment 'Indicates whether an alternative access route or delivery mechanism is available to reach the affected beneficiaries.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternativeRouteDescription rdf:type rdf:Property ;
    rdfs:label 'Alternative Route Description' ;
    rdfs:comment 'Description of the alternative route, delivery mechanism, or programming modality used to mitigate the access constraint (e.g., river transport, air drop, remote cash transfer, partner-led distribution).' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:armedActorInvolved rdf:type rdf:Property ;
    rdfs:label 'Armed Actor Involved' ;
    rdfs:comment 'Name or identifier of the armed actor (state or non-state) responsible for or associated with the access constraint. Confidential due to security and negotiation sensitivity.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterAffiliation rdf:type rdf:Property ;
    rdfs:label 'Cluster Affiliation' ;
    rdfs:comment 'OCHA cluster or sector most affected by the access constraint (e.g., Health, WASH, Protection, Food Security, Shelter, Education). Supports cluster coordination and sector-specific reporting. [ENUM-REF-CANDIDATE: health|wash|protection|food_security|shelter_nfi|education|nutrition|camp_coordination|early_recovery|logistics|emergency_telecommunications — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintCode rdf:type rdf:Property ;
    rdfs:label 'Constraint Code' ;
    rdfs:comment 'Externally-known unique code for the access constraint, typically formatted as AC-{COUNTRY}-{SEQUENCE} for tracking and reporting purposes.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintEndDate rdf:type rdf:Property ;
    rdfs:label 'Constraint End Date' ;
    rdfs:comment 'Date when the access constraint was resolved or mitigated, allowing resumption of normal operations. Null if constraint remains active.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constraintNotes rdf:type rdf:Property ;
    rdfs:label 'Constraint Notes' ;
    rdfs:comment 'Additional contextual notes, observations, or lessons learned related to the access constraint. May include details on community dynamics, seasonal patterns, or coordination challenges.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintStartDate rdf:type rdf:Property ;
    rdfs:label 'Constraint Start Date' ;
    rdfs:comment 'Date when the access constraint was first identified or reported. Marks the beginning of the impediment to humanitarian operations.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constraintStatus rdf:type rdf:Property ;
    rdfs:label 'Constraint Status' ;
    rdfs:comment 'Current lifecycle status of the access constraint. Active indicates ongoing impediment; monitoring indicates under observation; mitigated indicates workaround implemented; resolved indicates constraint removed; escalated indicates elevated to senior management or OCHA coordination.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintType rdf:type rdf:Property ;
    rdfs:label 'Constraint Type' ;
    rdfs:comment 'Classification of the humanitarian access constraint affecting field operations. Active conflict includes armed hostilities; road blockage includes physical barriers; administrative denial includes government refusals; armed actor checkpoint includes non-state armed group controls; bureaucratic impediment includes visa/permit delays; weather/natural hazard includes floods, landslides, or extreme weather.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationStatus rdf:type rdf:Property ;
    rdfs:label 'Escalation Status' ;
    rdfs:comment 'Indicates whether and to what level the access constraint has been escalated for senior management attention or inter-agency coordination. Used for tracking high-severity incidents requiring strategic intervention.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedBeneficiariesUnreached rdf:type rdf:Property ;
    rdfs:label 'Estimated Beneficiaries Unreached' ;
    rdfs:comment 'Estimated number of beneficiaries (Persons of Concern, PoC) who could not be reached or served due to this access constraint. Used for impact assessment and donor reporting.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactOnProgramTimeline rdf:type rdf:Property ;
    rdfs:label 'Impact On Program Timeline' ;
    rdfs:comment 'Description of how the access constraint affected program implementation timelines, including delays in days/weeks and impact on grant deliverables and reporting milestones.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Mitigation Actions Taken' ;
    rdfs:comment 'Description of actions taken to mitigate or work around the access constraint, such as alternative routes, negotiation with armed actors, remote programming, or partner-led delivery.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationRequired rdf:type rdf:Property ;
    rdfs:label 'Negotiation Required' ;
    rdfs:comment 'Indicates whether humanitarian access negotiation with armed actors, government authorities, or community leaders is required to resolve the constraint.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingSource rdf:type rdf:Property ;
    rdfs:label 'Reporting Source' ;
    rdfs:comment 'Entity or system that reported the access constraint. OCHA (Office for the Coordination of Humanitarian Affairs), UNDSS (UN Department of Safety and Security), INSO (International NGO Safety Organisation), field staff, partner organization, cluster lead, or other source. [ENUM-REF-CANDIDATE: ocha|undss|inso|field_staff|partner_org|cluster_lead|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSourceContact rdf:type rdf:Property ;
    rdfs:label 'Reporting Source Contact' ;
    rdfs:comment 'Name or identifier of the individual or team who reported the constraint. Confidential to protect field staff and sources in sensitive environments.' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityIncidentLinked rdf:type rdf:Property ;
    rdfs:label 'Security Incident Linked' ;
    rdfs:comment 'Indicates whether the access constraint is linked to a specific security incident (e.g., attack on humanitarian workers, kidnapping, armed confrontation).' ;
    rdfs:domain ind:AccessConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sitrepIncluded rdf:type rdf:Property ;
    rdfs:label 'Sitrep Included' ;
    rdfs:comment 'Indicates whether this access constraint was included in an OCHA or organizational Situation Report (SitRep) for external stakeholder communication.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentId rdf:type rdf:Property ;
    rdfs:label 'Assessment Id' ;
    rdfs:comment 'Unique identifier for the field assessment record. Primary key.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assessment .

ind:distributionEventId rdf:type rdf:Property ;
    rdfs:label 'Distribution Event Id' ;
    rdfs:comment 'Reference to the distribution event being monitored. Applicable for Post-Distribution Monitoring (PDM) assessments only.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionEvent .

ind:teamLeadStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Team Lead Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Assessments require designated team lead for operational accountability, coordination, and donor reporting compliance. Essential for tracking who is responsible for assessment quality and findings val' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:adequacyScore rdf:type rdf:Property ;
    rdfs:label 'Adequacy Score' ;
    rdfs:comment 'For PDM assessments: score representing beneficiary assessment of whether the distributed items met their needs in terms of quantity, quality, and timeliness. Typically on a scale of 1-5 or 1-10.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentName rdf:type rdf:Property ;
    rdfs:label 'Assessment Name' ;
    rdfs:comment 'Human-readable name or title of the assessment, describing its purpose and scope.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiarySatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Satisfaction Score' ;
    rdfs:comment 'Overall satisfaction rating provided by beneficiaries regarding the program or distribution. Supports Accountability to Affected Populations (AAP) and CHS compliance.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clusterCoordinationBody rdf:type rdf:Property ;
    rdfs:label 'Cluster Coordination Body' ;
    rdfs:comment 'The OCHA cluster or sector coordination group to which this assessment is reported (e.g., WASH Cluster, Health Cluster, Food Security Cluster).' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintsReceivedCount rdf:type rdf:Property ;
    rdfs:label 'Complaints Received Count' ;
    rdfs:comment 'Number of complaints or grievances raised by beneficiaries during the assessment. Critical for accountability and feedback mechanisms.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:donorVisibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Visibility Flag' ;
    rdfs:comment 'Indicates whether this assessment is designated for inclusion in donor reports and external visibility materials.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Precise date and time when the assessment fieldwork was completed.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:keyFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Findings Summary' ;
    rdfs:comment 'Executive summary of the main findings, insights, and observations from the assessment. Used for SitRep generation and donor reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melIndicatorLinked rdf:type rdf:Property ;
    rdfs:label 'Mel Indicator Linked' ;
    rdfs:comment 'Flag indicating whether this assessment is linked to specific MEL indicators in the logical framework (LogFrame) or results framework.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'The research methodology employed for data collection and analysis.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionConcernsDescription rdf:type rdf:Property ;
    rdfs:label 'Protection Concerns Description' ;
    rdfs:comment 'Detailed description of any protection concerns identified, including nature of risk and affected population. Confidential to ensure beneficiary safety.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionConcernsNoted rdf:type rdf:Property ;
    rdfs:label 'Protection Concerns Noted' ;
    rdfs:comment 'Flag indicating whether any protection concerns (GBV, child protection, safety risks) were identified during the assessment. Triggers referral protocols.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendations rdf:type rdf:Property ;
    rdfs:label 'Recommendations' ;
    rdfs:comment 'Actionable recommendations derived from the assessment findings for program adjustments, response planning, or advocacy.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportUrl rdf:type rdf:Property ;
    rdfs:label 'Report Url' ;
    rdfs:comment 'Link to the full assessment report document stored in the document management system or shared drive.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleMethodology rdf:type rdf:Property ;
    rdfs:label 'Sample Methodology' ;
    rdfs:comment 'The sampling approach used to select assessment participants. Particularly important for PDM assessments to ensure representativeness.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Precise date and time when the assessment fieldwork began.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetPopulation rdf:type rdf:Property ;
    rdfs:label 'Target Population' ;
    rdfs:comment 'Description of the population segment or beneficiary group targeted by this assessment (e.g., IDPs, host community, women-headed households, children under 5).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamSize rdf:type rdf:Property ;
    rdfs:label 'Team Size' ;
    rdfs:comment 'Number of enumerators, facilitators, or team members who participated in conducting the assessment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Percent' ;
    rdfs:comment 'For PDM assessments: percentage of beneficiaries who reported using the distributed items as intended. Key indicator of program effectiveness.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'Name or identifier of the staff member who validated the assessment data and findings.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date when the assessment data was validated and approved by the MEL team or program management.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentResponseId rdf:type rdf:Property ;
    rdfs:label 'Assessment Response Id' ;
    rdfs:comment 'Unique identifier for the assessment response record. Primary key for individual survey or interview responses collected during field assessments.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:respondentAnonymizedRegistrantId rdf:type rdf:Property ;
    rdfs:label 'Respondent Anonymized Registrant Id' ;
    rdfs:comment 'Anonymized identifier for the survey respondent to enable longitudinal tracking while protecting personally identifiable information. Used for follow-up assessments and trend analysis.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registrant .

ind:childrenUnder5Count rdf:type rdf:Property ;
    rdfs:label 'Children Under 5 Count' ;
    rdfs:comment 'Number of children under 5 years of age in the household. Critical for nutrition, health, and protection program targeting.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentDataSharing rdf:type rdf:Property ;
    rdfs:label 'Consent Data Sharing' ;
    rdfs:comment 'Indicator that the respondent has provided informed consent for their data to be shared with partner organizations for service delivery purposes.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentFollowUp rdf:type rdf:Property ;
    rdfs:label 'Consent Follow Up' ;
    rdfs:comment 'Indicator that the respondent has consented to be contacted for follow-up assessments or post-distribution monitoring activities.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:debtBurdenFlag rdf:type rdf:Property ;
    rdfs:label 'Debt Burden Flag' ;
    rdfs:comment 'Indicator that the household is experiencing significant debt burden affecting their ability to meet basic needs. Used for economic vulnerability profiling.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disabilityPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Disability Present Flag' ;
    rdfs:comment 'Indicator that one or more household members have a disability. Used for inclusive programming and accessibility considerations.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displacementDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Displacement Duration Months' ;
    rdfs:comment 'Number of months the household has been displaced from their place of origin. Indicates protractedness of displacement and informs durable solutions programming.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:educationAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Education Access Flag' ;
    rdfs:comment 'Indicator that school-age children in the household have access to education services. Monitors education in emergencies programming effectiveness.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:elderlyOver60Count rdf:type rdf:Property ;
    rdfs:label 'Elderly Over 60 Count' ;
    rdfs:comment 'Number of elderly individuals over 60 years of age in the household. Used for vulnerability assessment and targeted assistance programs.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:foodSecurityScore rdf:type rdf:Property ;
    rdfs:label 'Food Security Score' ;
    rdfs:comment 'Calculated food security index based on household consumption patterns and coping strategies. Higher scores indicate greater food insecurity.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdSize rdf:type rdf:Property ;
    rdfs:label 'Household Size' ;
    rdfs:comment 'Total number of individuals in the respondent household. Key demographic indicator for needs assessment and resource allocation calculations.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Interview Duration Minutes' ;
    rdfs:comment 'Total time in minutes taken to complete the assessment interview. Used for quality control and enumerator performance monitoring.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewLanguage rdf:type rdf:Property ;
    rdfs:label 'Interview Language' ;
    rdfs:comment 'Language in which the assessment interview was conducted. Important for data quality assessment and ensuring linguistic accessibility.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyIncomeUsd rdf:type rdf:Property ;
    rdfs:label 'Monthly Income Usd' ;
    rdfs:comment 'Estimated total monthly household income in United States Dollars. Used for economic vulnerability assessment and cash transfer program targeting.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryNeedCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Need Category' ;
    rdfs:comment 'The most urgent need identified by the respondent household. Used for prioritization and resource allocation in humanitarian response. [ENUM-REF-CANDIDATE: food|water|shelter|health|protection|education|nfi|wash|livelihoods|psychosocial — promote to reference product]' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Referral Required Flag' ;
    rdfs:comment 'Indicator that the assessment identified needs requiring referral to specialized services such as protection, health, or case management.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current lifecycle status of the assessment response indicating data quality validation state and approval workflow position.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryNeedCategory rdf:type rdf:Property ;
    rdfs:label 'Secondary Need Category' ;
    rdfs:comment 'The second most urgent need identified by the respondent household. Provides additional context for multi-sectoral response planning.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelterCondition rdf:type rdf:Property ;
    rdfs:label 'Shelter Condition' ;
    rdfs:comment 'Assessment of the physical condition and habitability of the household shelter. Used for prioritizing shelter repair and upgrade interventions.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionLatitude rdf:type rdf:Property ;
    rdfs:label 'Submission Latitude' ;
    rdfs:comment 'GPS latitude coordinate captured at the time and location of survey submission. Used for spatial analysis and verification of field coverage.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionLongitude rdf:type rdf:Property ;
    rdfs:label 'Submission Longitude' ;
    rdfs:comment 'GPS longitude coordinate captured at the time and location of survey submission. Used for spatial analysis and verification of field coverage.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationNotes rdf:type rdf:Property ;
    rdfs:label 'Validation Notes' ;
    rdfs:comment 'Free-text notes from data validation and quality assurance review. Documents any data quality issues, corrections, or contextual information.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterAccessMinutes rdf:type rdf:Property ;
    rdfs:label 'Water Access Minutes' ;
    rdfs:comment 'Time in minutes required for household members to access safe drinking water. Key WASH (Water Sanitation and Hygiene) indicator for service delivery monitoring.' ;
    rdfs:domain ind:AssessmentResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clusterCoordinationId rdf:type rdf:Property ;
    rdfs:label 'Cluster Coordination Id' ;
    rdfs:comment 'Unique identifier for the cluster coordination record.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClusterCoordination .

ind:clusterStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Cluster Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:primaryClusterStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Cluster Staff Member Id' ;
    rdfs:comment 'Reference to the staff member designated as the NGO focal point for this cluster coordination activity.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:clusterActivationDate rdf:type rdf:Property ;
    rdfs:label 'Cluster Activation Date' ;
    rdfs:comment 'Date when the cluster was officially activated in the country.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clusterActivationStatus rdf:type rdf:Property ;
    rdfs:label 'Cluster Activation Status' ;
    rdfs:comment 'Current activation status of the cluster in the country context. Active indicates the cluster is operational; Inactive or Deactivated indicates the cluster has been stood down.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterCode rdf:type rdf:Property ;
    rdfs:label 'Cluster Code' ;
    rdfs:comment 'Standardized code or abbreviation for the cluster as defined by OCHA or IASC.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterDeactivationDate rdf:type rdf:Property ;
    rdfs:label 'Cluster Deactivation Date' ;
    rdfs:comment 'Date when the cluster was officially deactivated or stood down in the country, if applicable.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clusterName rdf:type rdf:Property ;
    rdfs:label 'Cluster Name' ;
    rdfs:comment 'Name of the OCHA humanitarian cluster in which the NGO participates. CCCM refers to Camp Coordination and Camp Management. [ENUM-REF-CANDIDATE: WASH|Food Security|Health|Nutrition|Shelter|Protection|Education|Logistics|CCCM|Early Recovery|Emergency Telecommunications — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterStrategyAlignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Cluster Strategy Alignment Status' ;
    rdfs:comment 'Degree to which the NGO programs and activities align with the cluster strategic objectives and response plan.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterWorkingGroupMembership rdf:type rdf:Property ;
    rdfs:label 'Cluster Working Group Membership' ;
    rdfs:comment 'Names of any cluster sub-working groups or technical working groups in which the NGO participates (e.g., WASH Technical Working Group, Protection Sub-Cluster).' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coLeadAgencyName rdf:type rdf:Property ;
    rdfs:label 'Co Lead Agency Name' ;
    rdfs:comment 'Name of the co-lead agency or organization sharing cluster leadership responsibilities, if applicable.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinationMeetingDay rdf:type rdf:Property ;
    rdfs:label 'Coordination Meeting Day' ;
    rdfs:comment 'Day of the week or month when cluster coordination meetings are typically held.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinationMeetingFrequency rdf:type rdf:Property ;
    rdfs:label 'Coordination Meeting Frequency' ;
    rdfs:comment 'Scheduled frequency of cluster coordination meetings (e.g., weekly, monthly).' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinationMeetingLocation rdf:type rdf:Property ;
    rdfs:label 'Coordination Meeting Location' ;
    rdfs:comment 'Physical or virtual location where cluster coordination meetings are held (e.g., OCHA office, Zoom link).' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinationMeetingTime rdf:type rdf:Property ;
    rdfs:label 'Coordination Meeting Time' ;
    rdfs:comment 'Time of day when cluster coordination meetings are typically held (e.g., 10:00 AM local time).' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coordinationNotes rdf:type rdf:Property ;
    rdfs:label 'Coordination Notes' ;
    rdfs:comment 'Free-text notes capturing key coordination issues, decisions, action items, or strategic positioning considerations related to this cluster participation.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hpcCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Hpc Commitment Amount' ;
    rdfs:comment 'Financial commitment amount pledged by the NGO within the Humanitarian Programme Cycle for this cluster.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hpcCommitmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Hpc Commitment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the HPC commitment amount.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hpcCommitmentDescription rdf:type rdf:Property ;
    rdfs:label 'Hpc Commitment Description' ;
    rdfs:comment 'Description of the NGO commitments made within the Humanitarian Programme Cycle framework, including planned activities, target beneficiaries, and resource allocations.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informationSharingAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Information Sharing Agreement Date' ;
    rdfs:comment 'Date when the information-sharing agreement was signed.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:informationSharingAgreementSignedFlag rdf:type rdf:Property ;
    rdfs:label 'Information Sharing Agreement Signed Flag' ;
    rdfs:comment 'Indicates whether the NGO has signed an information-sharing agreement with the cluster.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMeetingAttendanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Meeting Attendance Date' ;
    rdfs:comment 'Date of the most recent cluster coordination meeting attended by the NGO focal point.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSitrepContributionDate rdf:type rdf:Property ;
    rdfs:label 'Last Sitrep Contribution Date' ;
    rdfs:comment 'Date of the most recent situation report to which the NGO contributed information.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastThreeWSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Last Three W Submission Date' ;
    rdfs:comment 'Date when the NGO last submitted a 3W report to the cluster.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadAgencyName rdf:type rdf:Property ;
    rdfs:label 'Lead Agency Name' ;
    rdfs:comment 'Name of the UN agency or international organization designated as the cluster lead (e.g., UNICEF for WASH, WFP for Food Security).' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextThreeWSubmissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Three W Submission Due Date' ;
    rdfs:comment 'Date by which the next 3W report is due to the cluster lead.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ngoParticipationEndDate rdf:type rdf:Property ;
    rdfs:label 'Ngo Participation End Date' ;
    rdfs:comment 'Date when the NGO formally ended or withdrew from participation in this cluster coordination activity, if applicable.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ngoParticipationStartDate rdf:type rdf:Property ;
    rdfs:label 'Ngo Participation Start Date' ;
    rdfs:comment 'Date when the NGO formally began participating in this cluster coordination activity.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ngoParticipationStatus rdf:type rdf:Property ;
    rdfs:label 'Ngo Participation Status' ;
    rdfs:comment 'Current status of the NGO participation in the cluster coordination activity.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sitrepContributionFlag rdf:type rdf:Property ;
    rdfs:label 'Sitrep Contribution Flag' ;
    rdfs:comment 'Indicates whether the NGO regularly contributes data or narrative to cluster situation reports.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threeWReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Three W Reporting Frequency' ;
    rdfs:comment 'Frequency at which the NGO is required to submit 3W reports to the cluster.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWReportingObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Three W Reporting Obligation Flag' ;
    rdfs:comment 'Indicates whether the NGO has a formal obligation to submit 3W reports to the cluster. 3W refers to Who does What Where reporting.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threeWSubmissionComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Three W Submission Compliance Status' ;
    rdfs:comment 'Current compliance status of the NGO with 3W reporting obligations.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMeetingsAttendedCount rdf:type rdf:Property ;
    rdfs:label 'Total Meetings Attended Count' ;
    rdfs:comment 'Cumulative count of cluster coordination meetings attended by the NGO since activation.' ;
    rdfs:domain ind:ClusterCoordination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkSiteId rdf:type rdf:Property ;
    rdfs:label 'Network Site Id' ;
    rdfs:comment 'Foreign key linking to technology.network_site. Business justification: Country offices are primary network nodes. This link is essential for IT infrastructure management, disaster recovery planning, connectivity SLA tracking, and bandwidth allocation—critical for operati' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkSite .

ind:parentOfficeCountryOfficeId rdf:type rdf:Property ;
    rdfs:label 'Parent Office Country Office Id' ;
    rdfs:comment 'Reference to the parent country office or regional office to which this office reports, enabling hierarchical office structure.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CountryOffice .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address or building location of the country office.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information such as suite, floor, or building name.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the country office is located.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryDirectorEmail rdf:type rdf:Property ;
    rdfs:label 'Country Director Email' ;
    rdfs:comment 'Email address of the country director for official communications.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryDirectorName rdf:type rdf:Property ;
    rdfs:label 'Country Director Name' ;
    rdfs:comment 'Full name of the senior management official responsible for leading the country office operations.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentDate rdf:type rdf:Property ;
    rdfs:label 'Establishment Date' ;
    rdfs:comment 'Date when the country office was first established and began operations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isEmergencyResponse rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Response' ;
    rdfs:comment 'Indicates whether this office was established specifically for emergency or humanitarian crisis response operations.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Official legal name under which the country office is registered with host government authorities, which may differ from the operational office name.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mouEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Mou Effective Date' ;
    rdfs:comment 'Date when the Memorandum of Understanding (MoU) with the host government became effective.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mouExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Mou Expiry Date' ;
    rdfs:comment 'Date when the current Memorandum of Understanding (MoU) with the host government expires.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mouWithGovernment rdf:type rdf:Property ;
    rdfs:label 'Mou With Government' ;
    rdfs:comment 'Indicates whether a formal Memorandum of Understanding (MoU) is in place with the host government defining the terms of operation.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ochaClusterParticipation rdf:type rdf:Property ;
    rdfs:label 'Ocha Cluster Participation' ;
    rdfs:comment 'List of Office for the Coordination of Humanitarian Affairs (OCHA) humanitarian clusters in which this country office actively participates (e.g., WASH, Health, Protection, Education).' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeCode rdf:type rdf:Property ;
    rdfs:label 'Office Code' ;
    rdfs:comment 'Unique business identifier for the country office following organizational naming convention (e.g., KEN-NAI01 for Nairobi office in Kenya).' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeName rdf:type rdf:Property ;
    rdfs:label 'Office Name' ;
    rdfs:comment 'Official name of the country office or sub-office (e.g., Kenya Country Office, Nairobi Sub-Office).' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeType rdf:type rdf:Property ;
    rdfs:label 'Office Type' ;
    rdfs:comment 'Classification of the office based on its operational mandate and scope within the organizational hierarchy.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalMandate rdf:type rdf:Property ;
    rdfs:label 'Operational Mandate' ;
    rdfs:comment 'Description of the office\'s operational mandate, including sectors of focus (e.g., Water Sanitation and Hygiene (WASH), health, education, protection) and target populations served.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the country office indicating whether it is actively managing field operations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the office location.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Registration Expiry Date' ;
    rdfs:comment 'Date when the current host government registration expires and requires renewal.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Current security risk assessment level for the country office location, informing operational protocols and staff safety measures.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffCount rdf:type rdf:Property ;
    rdfs:label 'Staff Count' ;
    rdfs:comment 'Total number of staff members (national and international) currently assigned to this country office.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region within the host country.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the country office location (e.g., Africa/Nairobi, Asia/Damascus) for scheduling and coordination purposes.' ;
    rdfs:domain ind:CountryOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Field Deployment Id' ;
    rdfs:comment 'Unique identifier for the field deployment record. Primary key.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldDeployment .

ind:deployingCountryOfficeId rdf:type rdf:Property ;
    rdfs:label 'Deploying Country Office Id' ;
    rdfs:comment 'Reference to the country office or organizational unit that is sending the field team or staff member on deployment.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CountryOffice .

ind:fieldTeamId rdf:type rdf:Property ;
    rdfs:label 'Field Team Id' ;
    rdfs:comment 'Foreign key linking to field.team. Business justification: Deployment currently has \'deployed_team_name\' as a STRING attribute, but should FK to the team master record for referential integrity and to enable tracking team deployment history. The \'team_size\' a' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldTeam .

ind:partnershipAgreementId rdf:type rdf:Property ;
    rdfs:label 'Partnership Agreement Id' ;
    rdfs:comment 'Foreign key linking to partnership.partnership_agreement. Business justification: Deployments to partner-managed sites or joint operations are often governed by partnership agreements defining roles, responsibilities, and cost-sharing. Linking enables compliance tracking, cost allo' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnershipAgreement .

ind:primaryFieldDeployedStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Field Deployed Staff Member Id' ;
    rdfs:comment 'Reference to the individual staff member being deployed. Nullable if the deployment is for a team rather than an individual.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:safeguardingTrainingCompletionId rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Training Completion Id' ;
    rdfs:comment 'Foreign key linking to safeguarding.training_completion. Business justification: Deployments to emergency/field contexts require pre-deployment safeguarding training verification. Standard HR practice links deployment clearance to mandatory PSEA training completion records for com' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafeguardingTrainingCompletion .

ind:accommodationType rdf:type rdf:Property ;
    rdfs:label 'Accommodation Type' ;
    rdfs:comment 'Type of accommodation arranged for the deployed personnel during the mission.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'The actual date the deployment concluded, which may differ from the planned end date due to operational needs, early completion, or extension.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'The actual date the deployment commenced, which may differ from the planned start date due to logistical delays, security clearances, or travel disruptions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Estimated total cost of the deployment in the organization\'s functional currency, including travel, accommodation, per diem, and operational expenses.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deploymentCode rdf:type rdf:Property ;
    rdfs:label 'Deployment Code' ;
    rdfs:comment 'Human-readable unique code for the deployment, typically formatted as country-office-prefix followed by sequential number (e.g., SYR-000123).' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Status' ;
    rdfs:comment 'Current lifecycle status of the deployment: planned (approved but not yet started), active (team is currently deployed), completed (deployment finished successfully), cancelled (deployment did not proceed), or suspended (temporarily paused).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentType rdf:type rdf:Property ;
    rdfs:label 'Deployment Type' ;
    rdfs:comment 'Classification of the deployment purpose: emergency response for rapid humanitarian crises, routine program delivery for ongoing operations, assessment mission for needs evaluation, training for capacity building, surge support for temporary reinforcement, or monitoring visit for MEL activities.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'The planned duration of the deployment in calendar days, calculated from start date to end date.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gisTrackEnabled rdf:type rdf:Property ;
    rdfs:label 'Gis Track Enabled' ;
    rdfs:comment 'Indicates whether GPS tracking and GIS data collection are enabled for this deployment to capture movement and location data for security and operational monitoring.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handoverNotes rdf:type rdf:Property ;
    rdfs:label 'Handover Notes' ;
    rdfs:comment 'Free-text notes documenting key information, lessons learned, outstanding issues, and recommendations for follow-up recorded at the conclusion of the deployment.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageType rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Type' ;
    rdfs:comment 'Level of insurance coverage provided for this deployment, reflecting the risk profile of the destination and activities.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Required' ;
    rdfs:comment 'Indicates whether medical clearance or specific vaccinations are required for this deployment due to health risks at the destination.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purposeDescription rdf:type rdf:Property ;
    rdfs:label 'Purpose Description' ;
    rdfs:comment 'Detailed narrative describing the specific objectives, activities, and expected outcomes of this deployment mission.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseType rdf:type rdf:Property ;
    rdfs:label 'Response Type' ;
    rdfs:comment 'Classification of the humanitarian context for this deployment: rapid onset emergency (sudden disaster), protracted crisis (long-term displacement), development program (routine service delivery), or recovery transition (post-crisis stabilization).' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Level' ;
    rdfs:comment 'The minimum security clearance level required for personnel on this deployment, aligned with the destination site security rating and operational risk assessment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sitrepReference rdf:type rdf:Property ;
    rdfs:label 'Sitrep Reference' ;
    rdfs:comment 'Reference to the situation report or operational update that triggered or documented this deployment, enabling traceability to humanitarian response coordination.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportationMode rdf:type rdf:Property ;
    rdfs:label 'Transportation Mode' ;
    rdfs:comment 'Primary mode of transportation used to reach the deployment site.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelAuthorizationReference rdf:type rdf:Property ;
    rdfs:label 'Travel Authorization Reference' ;
    rdfs:comment 'Reference number or code for the official travel authorization document approving this deployment, used for duty-of-care and insurance purposes.' ;
    rdfs:domain ind:FieldDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionVehicleItAssetId rdf:type rdf:Property ;
    rdfs:label 'Distribution Vehicle It Asset Id' ;
    rdfs:comment 'Foreign key linking to technology.it_asset. Business justification: Distribution events use vehicles/equipment for logistics. Tracking asset utilization supports cost allocation, maintenance planning, mileage tracking, and insurance claims—essential for distribution o' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItAsset .

ind:actualBeneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Actual Beneficiary Count' ;
    rdfs:comment 'Actual number of beneficiaries who received assistance in this distribution event, verified through registration or biometric verification.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the distribution event concluded.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualExpenditureAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Expenditure Amount' ;
    rdfs:comment 'Total actual expenditure incurred for this distribution event, including commodity costs, logistics, and operational expenses.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualHouseholdCount rdf:type rdf:Property ;
    rdfs:label 'Actual Household Count' ;
    rdfs:comment 'Actual number of households that received assistance in this distribution event.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when the distribution event commenced on the ground.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adminLevel3 rdf:type rdf:Property ;
    rdfs:label 'Admin Level 3' ;
    rdfs:comment 'Third-level administrative division (e.g., sub-district, municipality) where the distribution event took place.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Category' ;
    rdfs:comment 'Primary category of items distributed in this event. For NFI distributions may include shelter materials, hygiene kits, blankets; for food distributions may include staple foods, fortified foods; for WASH may include water containers, purification tablets. Pipe-enum overflow candidate with 15+ standard categories.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionEventCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Event Code' ;
    rdfs:comment 'Externally-known unique business identifier for the distribution event, typically formatted as country-cluster-sequence (e.g., SYR-WASH-000123).' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionEventName rdf:type rdf:Property ;
    rdfs:label 'Distribution Event Name' ;
    rdfs:comment 'Human-readable name or title of the distribution event for reporting and communication purposes.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Distribution Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the distribution event location, captured via GPS or GIS system.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Distribution Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the distribution event location, captured via GPS or GIS system.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionLocationName rdf:type rdf:Property ;
    rdfs:label 'Distribution Location Name' ;
    rdfs:comment 'Human-readable name of the distribution location (e.g., community center, camp sector, village name).' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionModality rdf:type rdf:Property ;
    rdfs:label 'Distribution Modality' ;
    rdfs:comment 'Method of assistance delivery: in-kind (physical goods), cash (physical currency), voucher (paper/card voucher), mobile money (digital wallet), e-transfer (bank transfer), or hybrid (combination of modalities).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current lifecycle status of the distribution event in the operational workflow. [ENUM-REF-CANDIDATE: planned|approved|in_progress|completed|cancelled|suspended|under_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionType rdf:type rdf:Property ;
    rdfs:label 'Distribution Type' ;
    rdfs:comment 'Classification of the distribution approach: general (universal coverage), targeted (specific beneficiary criteria), blanket (entire population segment), voucher redemption (voucher exchange), emergency response (rapid onset), or seasonal (recurring planned distribution).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Incident Reported Flag' ;
    rdfs:comment 'Indicates whether any security incident, operational disruption, or beneficiary complaint was reported during this distribution event.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pdmCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Pdm Completion Date' ;
    rdfs:comment 'Date when the Post-Distribution Monitoring activity for this distribution event was completed.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pdmScheduledFlag rdf:type rdf:Property ;
    rdfs:label 'Pdm Scheduled Flag' ;
    rdfs:comment 'Indicates whether a Post-Distribution Monitoring activity has been scheduled for this distribution event to assess beneficiary satisfaction and assistance effectiveness.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedBeneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Planned Beneficiary Count' ;
    rdfs:comment 'Target number of beneficiaries planned to receive assistance in this distribution event.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedHouseholdCount rdf:type rdf:Property ;
    rdfs:label 'Planned Household Count' ;
    rdfs:comment 'Target number of households planned to receive assistance in this distribution event.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sitrepIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Sitrep Included Flag' ;
    rdfs:comment 'Indicates whether this distribution event has been included in a Situation Report (SitRep) submitted to OCHA or other coordination bodies.' ;
    rdfs:domain ind:DistributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldDistributionLineId rdf:type rdf:Property ;
    rdfs:label 'Field Distribution Line Id' ;
    rdfs:comment 'Unique identifier for the distribution line item. Primary key.' ;
    rdfs:domain ind:FieldDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Each distribution line item posts to a specific GL account (food commodities, NFI, cash transfers). Required for financial statement preparation, expense classification, and audit trail.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:actualQuantityDistributed rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity Distributed' ;
    rdfs:comment 'The actual quantity of the item that was distributed to beneficiaries. Used for BvA (Budget versus Actual) reconciliation and MEL reporting.' ;
    rdfs:domain ind:FieldDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Count' ;
    rdfs:comment 'Number of individual beneficiaries or households who received this specific item in this distribution line. Supports disaggregated MEL reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clusterSector rdf:type rdf:Property ;
    rdfs:label 'Cluster Sector' ;
    rdfs:comment 'OCHA humanitarian cluster or sector to which this distribution line item is attributed (e.g., Food Security, WASH, Shelter, Health, Protection).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionMethod rdf:type rdf:Property ;
    rdfs:label 'Distribution Method' ;
    rdfs:comment 'The method or modality used to distribute this item (e.g., direct hand distribution, voucher redemption, cash transfer for purchase, mobile distribution unit, fixed distribution site).' ;
    rdfs:domain ind:FieldDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorEarmark rdf:type rdf:Property ;
    rdfs:label 'Donor Earmark' ;
    rdfs:comment 'Identifier or name of the donor whose funds were earmarked for this specific item distribution. Supports restricted fund accounting and donor reporting.' ;
    rdfs:domain ind:FieldDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatiTransactionType rdf:type rdf:Property ;
    rdfs:label 'Iati Transaction Type' ;
    rdfs:comment 'IATI-compliant transaction type code for this distribution line, supporting international aid transparency and reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'High-level category of the distributed item. NFI = Non-Food Item, WASH = Water Sanitation and Hygiene.' ;
    rdfs:domain ind:FieldDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemCode rdf:type rdf:Property ;
    rdfs:label 'Item Code' ;
    rdfs:comment 'Standardized code identifying the specific commodity or NFI item. May align with supply chain master item codes or donor-specific item catalogs.' ;
    rdfs:domain ind:FieldDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Detailed textual description of the distributed item including specifications, brand, quality grade, or other distinguishing characteristics.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the distribution event. Used for ordering and referencing specific items within the distribution.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineSource rdf:type rdf:Property ;
    rdfs:label 'Pipeline Source' ;
    rdfs:comment 'Identifier of the supply pipeline or procurement source from which the item was drawn (e.g., central warehouse, local procurement, in-kind donation, CERF allocation).' ;
    rdfs:domain ind:FieldDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'The quantity of the item that was planned or targeted for distribution in this line item, as per the distribution plan or LogFrame target.' ;
    rdfs:domain ind:FieldDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCheckDate rdf:type rdf:Property ;
    rdfs:label 'Quality Check Date' ;
    rdfs:comment 'Date when the quality inspection was performed on this distribution line item.' ;
    rdfs:domain ind:FieldDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Check Status' ;
    rdfs:comment 'Result of quality inspection performed on this item batch before or during distribution. Ensures compliance with SPHERE and CHS standards.' ;
    rdfs:domain ind:FieldDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'The total monetary value of this distribution line (typically unit_value × actual_quantity_distributed). Supports financial reconciliation and grant expenditure tracking.' ;
    rdfs:domain ind:FieldDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The unit in which the item quantity is measured (e.g., pieces, kilograms, liters, boxes, kits, households).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitValue rdf:type rdf:Property ;
    rdfs:label 'Unit Value' ;
    rdfs:comment 'The monetary value per unit of the distributed item. Used for financial tracking and donor reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Difference between planned_quantity and actual_quantity_distributed. Positive values indicate over-distribution, negative values indicate under-distribution. Used for BvA analysis.' ;
    rdfs:domain ind:FieldDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReason rdf:type rdf:Property ;
    rdfs:label 'Variance Reason' ;
    rdfs:comment 'Explanation for any significant variance between planned and actual quantities. Supports accountability and learning in MEL processes.' ;
    rdfs:domain ind:FieldDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileHealthOutreachId rdf:type rdf:Property ;
    rdfs:label 'Mobile Health Outreach Id' ;
    rdfs:comment 'Unique identifier for the mobile health outreach session record. Primary key.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MobileHealthOutreach .

ind:projectSiteId rdf:type rdf:Property ;
    rdfs:label 'Project Project Site Id' ;
    rdfs:comment 'Reference to the program project under which this mobile health outreach session was conducted.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectSite .

ind:beneficiariesReachedFemale18To59 rdf:type rdf:Property ;
    rdfs:label 'Beneficiaries Reached Female 18 To 59' ;
    rdfs:comment 'Number of female beneficiaries aged 18 to 59 years reached during this mobile health outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiariesReachedFemale5To17 rdf:type rdf:Property ;
    rdfs:label 'Beneficiaries Reached Female 5 To 17' ;
    rdfs:comment 'Number of female beneficiaries aged 5 to 17 years reached during this mobile health outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiariesReachedFemale60Plus rdf:type rdf:Property ;
    rdfs:label 'Beneficiaries Reached Female 60 Plus' ;
    rdfs:comment 'Number of female beneficiaries aged 60 years and above reached during this mobile health outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiariesReachedFemaleUnder5 rdf:type rdf:Property ;
    rdfs:label 'Beneficiaries Reached Female Under 5' ;
    rdfs:comment 'Number of female beneficiaries under 5 years of age reached during this mobile health outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiariesReachedMale18To59 rdf:type rdf:Property ;
    rdfs:label 'Beneficiaries Reached Male 18 To 59' ;
    rdfs:comment 'Number of male beneficiaries aged 18 to 59 years reached during this mobile health outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiariesReachedMale5To17 rdf:type rdf:Property ;
    rdfs:label 'Beneficiaries Reached Male 5 To 17' ;
    rdfs:comment 'Number of male beneficiaries aged 5 to 17 years reached during this mobile health outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiariesReachedMale60Plus rdf:type rdf:Property ;
    rdfs:label 'Beneficiaries Reached Male 60 Plus' ;
    rdfs:comment 'Number of male beneficiaries aged 60 years and above reached during this mobile health outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiariesReachedMaleUnder5 rdf:type rdf:Property ;
    rdfs:label 'Beneficiaries Reached Male Under 5' ;
    rdfs:comment 'Number of male beneficiaries under 5 years of age reached during this mobile health outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chwTeamSize rdf:type rdf:Property ;
    rdfs:label 'Chw Team Size' ;
    rdfs:comment 'Total number of community health workers and support staff who participated in the outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dhis2ReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Dhis2 Reporting Period' ;
    rdfs:comment 'The DHIS2 reporting period to which this mobile health outreach session data is attributed, formatted as YYYY-Q# (quarterly), YYYY-M## (monthly), or YYYY-W## (weekly).' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthClusterReported rdf:type rdf:Property ;
    rdfs:label 'Health Cluster Reported' ;
    rdfs:comment 'Indicates whether this mobile health outreach session data has been reported to the OCHA health cluster coordination mechanism.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name of the community, village, or settlement where the mobile health outreach session was conducted.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralFacilityPrimary rdf:type rdf:Property ;
    rdfs:label 'Referral Facility Primary' ;
    rdfs:comment 'Name of the primary health facility to which beneficiaries were referred during this session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralsMadeCount rdf:type rdf:Property ;
    rdfs:label 'Referrals Made Count' ;
    rdfs:comment 'Total number of referrals made to health facilities or specialized services during this mobile health outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceAncProvided rdf:type rdf:Property ;
    rdfs:label 'Service Anc Provided' ;
    rdfs:comment 'Indicates whether antenatal care services were delivered during this mobile health outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceGbvReferralProvided rdf:type rdf:Property ;
    rdfs:label 'Service Gbv Referral Provided' ;
    rdfs:comment 'Indicates whether GBV referral services were provided during this mobile health outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceImmunizationProvided rdf:type rdf:Property ;
    rdfs:label 'Service Immunization Provided' ;
    rdfs:comment 'Indicates whether immunization services were delivered during this mobile health outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceMuacScreeningProvided rdf:type rdf:Property ;
    rdfs:label 'Service Muac Screening Provided' ;
    rdfs:comment 'Indicates whether MUAC screening for malnutrition was conducted during this mobile health outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:servicePssProvided rdf:type rdf:Property ;
    rdfs:label 'Service Pss Provided' ;
    rdfs:comment 'Indicates whether psychosocial support services were delivered during this mobile health outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceWashHygienePromotionProvided rdf:type rdf:Property ;
    rdfs:label 'Service Wash Hygiene Promotion Provided' ;
    rdfs:comment 'Indicates whether WASH hygiene promotion activities were conducted during this mobile health outreach session.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sessionCode rdf:type rdf:Property ;
    rdfs:label 'Session Code' ;
    rdfs:comment 'Externally-known unique business identifier for the mobile health outreach session, typically formatted as MHO-{country}-{sequence}.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionDate rdf:type rdf:Property ;
    rdfs:label 'Session Date' ;
    rdfs:comment 'The date on which the mobile health outreach session was conducted in the field.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sessionEndTime rdf:type rdf:Property ;
    rdfs:label 'Session End Time' ;
    rdfs:comment 'The timestamp when the mobile health outreach session concluded service delivery.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionNotes rdf:type rdf:Property ;
    rdfs:label 'Session Notes' ;
    rdfs:comment 'Free-text field for additional observations, challenges, or contextual information about the mobile health outreach session.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionStartTime rdf:type rdf:Property ;
    rdfs:label 'Session Start Time' ;
    rdfs:comment 'The timestamp when the mobile health outreach session began service delivery.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current status of the mobile health outreach session in its operational lifecycle.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sphereCompliant rdf:type rdf:Property ;
    rdfs:label 'Sphere Compliant' ;
    rdfs:comment 'Indicates whether this mobile health outreach session met SPHERE humanitarian standards for health service delivery.' ;
    rdfs:domain ind:MobileHealthOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalBeneficiariesReached rdf:type rdf:Property ;
    rdfs:label 'Total Beneficiaries Reached' ;
    rdfs:comment 'Total number of beneficiaries reached across all sex and age groups during this mobile health outreach session.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pdmSurveyId rdf:type rdf:Property ;
    rdfs:label 'Pdm Survey Id' ;
    rdfs:comment 'Unique identifier for the Post-Distribution Monitoring survey record. Primary key.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyorTeamLeadStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Surveyor Team Lead Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Post-distribution monitoring requires designated team lead for accountability and quality control. Essential for CHS compliance, AAP frameworks, and tracking responsibility for beneficiary feedback co' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:aapScore rdf:type rdf:Property ;
    rdfs:label 'Aap Score' ;
    rdfs:comment 'Composite score measuring the organization\'s accountability to affected populations based on PDM findings, including information sharing, participation, feedback mechanisms, and complaint handling effectiveness.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ageDisaggregationAvailable rdf:type rdf:Property ;
    rdfs:label 'Age Disaggregation Available' ;
    rdfs:comment 'Flag indicating whether the PDM survey data includes age-disaggregated responses enabling analysis of differential impacts across age groups.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chsComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Chs Compliance Rating' ;
    rdfs:comment 'Assessment of the distribution event\'s compliance with CHS commitments based on PDM survey findings, particularly Commitment 4 (communities know their rights and entitlements) and Commitment 5 (complaints are welcomed and addressed).' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Flag indicating whether the PDM survey findings necessitate immediate corrective actions or programmatic adjustments to address identified deficiencies or protection concerns.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysPostDistribution rdf:type rdf:Property ;
    rdfs:label 'Days Post Distribution' ;
    rdfs:comment 'Number of days elapsed between the distribution event completion and the PDM survey date. Critical for assessing timeliness of accountability mechanisms per CHS standards.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genderDisaggregationAvailable rdf:type rdf:Property ;
    rdfs:label 'Gender Disaggregation Available' ;
    rdfs:comment 'Flag indicating whether the PDM survey data includes gender-disaggregated responses enabling analysis of differential impacts and experiences by gender.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protectionConcernDescription rdf:type rdf:Property ;
    rdfs:label 'Protection Concern Description' ;
    rdfs:comment 'Detailed narrative description of any protection concerns identified during the PDM survey, including GBV (Gender-Based Violence) risks, safety issues, or other vulnerabilities requiring immediate attention.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Report Approved Date' ;
    rdfs:comment 'Date when the PDM survey report was formally approved by program management or MEL leadership, authorizing dissemination and action on findings.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Report Submitted Date' ;
    rdfs:comment 'Date when the final PDM survey report was submitted to program management, donors, or coordination bodies for review and action.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleSizeActual rdf:type rdf:Property ;
    rdfs:label 'Sample Size Actual' ;
    rdfs:comment 'The actual number of beneficiary households or individuals successfully surveyed during PDM field data collection.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSizePlanned rdf:type rdf:Property ;
    rdfs:label 'Sample Size Planned' ;
    rdfs:comment 'The planned number of beneficiary households or individuals to be surveyed as part of the PDM sample design.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplingMethod rdf:type rdf:Property ;
    rdfs:label 'Sampling Method' ;
    rdfs:comment 'The statistical sampling approach used to select beneficiaries for the PDM survey to ensure representativeness and validity of findings.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Score' ;
    rdfs:comment 'Overall beneficiary satisfaction score (typically 0.00 to 5.00 scale) with the distribution process, item quality, and timeliness. Core accountability metric per CHS Commitment 4.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyCode rdf:type rdf:Property ;
    rdfs:label 'Survey Code' ;
    rdfs:comment 'Externally-known unique business identifier for the PDM survey, typically following organizational naming conventions for tracking and reporting purposes.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyDate rdf:type rdf:Property ;
    rdfs:label 'Survey Date' ;
    rdfs:comment 'The principal date when the PDM survey field data collection was conducted or completed. Represents the business event timestamp for accountability reporting.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyEndDate rdf:type rdf:Property ;
    rdfs:label 'Survey End Date' ;
    rdfs:comment 'Date when the PDM survey field data collection activities were completed.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyMethodology rdf:type rdf:Property ;
    rdfs:label 'Survey Methodology' ;
    rdfs:comment 'The primary data collection methodology employed for this PDM survey, such as household interviews, FGD (Focus Group Discussion), KII (Key Informant Interview), or mobile data collection via KoboToolbox.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyStartDate rdf:type rdf:Property ;
    rdfs:label 'Survey Start Date' ;
    rdfs:comment 'Date when the PDM survey field data collection activities commenced.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyStatus rdf:type rdf:Property ;
    rdfs:label 'Survey Status' ;
    rdfs:comment 'Current lifecycle status of the PDM survey indicating its progress through planning, field data collection, analysis, and approval stages.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorOrganization rdf:type rdf:Property ;
    rdfs:label 'Surveyor Organization' ;
    rdfs:comment 'Name of the organization (implementing partner, third-party evaluator, or internal MEL team) that conducted the PDM survey.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerabilityDisaggregationAvailable rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Disaggregation Available' ;
    rdfs:comment 'Flag indicating whether the PDM survey data includes disaggregation by vulnerability status (e.g., persons with disabilities, elderly, female-headed households) for equity analysis.' ;
    rdfs:domain ind:PdmSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessibilityRating rdf:type rdf:Property ;
    rdfs:label 'Accessibility Rating' ;
    rdfs:comment 'Assessment of physical accessibility to the project site considering road conditions, security, terrain, and seasonal factors.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for official communication with the project site.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary phone number for reaching the project site or site manager.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electricityAvailable rdf:type rdf:Property ;
    rdfs:label 'Electricity Available' ;
    rdfs:comment 'Indicates whether electrical power is available at the project site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityOwnership rdf:type rdf:Property ;
    rdfs:label 'Facility Ownership' ;
    rdfs:comment 'Legal ownership or usage arrangement for the physical facility at the project site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisDataSource rdf:type rdf:Property ;
    rdfs:label 'Gis Data Source' ;
    rdfs:comment 'Source system or method used to capture GIS coordinates for this project site (e.g., GPS device, OpenStreetMap, satellite imagery).' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internetConnectivity rdf:type rdf:Property ;
    rdfs:label 'Internet Connectivity' ;
    rdfs:comment 'Type of internet connectivity available at the project site for data collection and reporting.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:koboCollectionEnabled rdf:type rdf:Property ;
    rdfs:label 'Kobo Collection Enabled' ;
    rdfs:comment 'Indicates whether mobile data collection via KoboToolbox is enabled and operational at this site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pcode rdf:type rdf:Property ;
    rdfs:label 'Pcode' ;
    rdfs:comment 'OCHA-assigned unique place code (P-code) for standardized geographic referencing in humanitarian operations and reporting.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationCatchment rdf:type rdf:Property ;
    rdfs:label 'Population Catchment' ;
    rdfs:comment 'Estimated number of beneficiaries or persons of concern (PoC) within the service catchment area of this project site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteAddress rdf:type rdf:Property ;
    rdfs:label 'Site Address' ;
    rdfs:comment 'Physical street address or location description of the project site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Site Area Sqm' ;
    rdfs:comment 'Total physical area of the project site measured in square meters.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the project site for field operations and reporting. Used in SitReps and OCHA coordination.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteDescription rdf:type rdf:Property ;
    rdfs:label 'Site Description' ;
    rdfs:comment 'Detailed narrative description of the project site including physical characteristics, surrounding environment, and operational context.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteManagerName rdf:type rdf:Property ;
    rdfs:label 'Site Manager Name' ;
    rdfs:comment 'Name of the staff member responsible for managing operations at this project site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Human-readable name of the project site or operational location.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the project site based on its primary function and service delivery model.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterSourceAvailable rdf:type rdf:Property ;
    rdfs:label 'Water Source Available' ;
    rdfs:comment 'Indicates whether a reliable water source is available at or near the project site for WASH operations.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primarySecurityFocalPointStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Security Focal Point Staff Member Id' ;
    rdfs:comment 'Reference to the designated security focal point or security manager responsible for managing the incident response and investigation.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:affectedPersonnelCount rdf:type rdf:Property ;
    rdfs:label 'Affected Personnel Count' ;
    rdfs:comment 'Total number of NGO staff, volunteers, or contractors directly affected by the security incident (injured, detained, threatened, or otherwise impacted).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetDamageDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Damage Description' ;
    rdfs:comment 'Narrative description of damage to organizational assets (vehicles, equipment, facilities, supplies) resulting from the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseClosedDate rdf:type rdf:Property ;
    rdfs:label 'Case Closed Date' ;
    rdfs:comment 'Date when the security incident case was formally closed after investigation and resolution (yyyy-MM-dd format).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Taken' ;
    rdfs:comment 'Description of corrective or preventive actions implemented following the security incident to mitigate future risk (e.g., enhanced security protocols, staff training, route changes).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAssetLossUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Asset Loss Usd' ;
    rdfs:comment 'Estimated monetary value of asset damage or loss in United States Dollars (USD) resulting from the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:immediateResponseActions rdf:type rdf:Property ;
    rdfs:label 'Immediate Response Actions' ;
    rdfs:comment 'Description of immediate actions taken by field staff or security personnel in response to the security incident (e.g., evacuation, medical assistance, notification of authorities, lockdown).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentLocationName rdf:type rdf:Property ;
    rdfs:label 'Incident Location Name' ;
    rdfs:comment 'Descriptive name or address of the specific location where the security incident occurred (e.g., village name, road name, facility name).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentSeverity rdf:type rdf:Property ;
    rdfs:label 'Incident Severity' ;
    rdfs:comment 'Severity classification of the security incident based on impact to personnel, assets, and operations. Critical = life-threatening or major asset loss; Major = serious injury or significant damage; Moderate = minor injury or moderate damage; Minor = no injury, minimal damage.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTime rdf:type rdf:Property ;
    rdfs:label 'Incident Time' ;
    rdfs:comment 'Precise date and time when the security incident occurred, in local time zone (yyyy-MM-ddTHH:mm:ss.SSSXXX format).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:insoReportDate rdf:type rdf:Property ;
    rdfs:label 'Inso Report Date' ;
    rdfs:comment 'Date when the security incident was reported to INSO, if applicable (yyyy-MM-dd format).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationFindings rdf:type rdf:Property ;
    rdfs:label 'Investigation Findings' ;
    rdfs:comment 'Summary of findings from the security incident investigation, including root causes, contributing factors, and lessons learned.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current status of the internal or external investigation into the security incident.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localAuthoritiesReportDate rdf:type rdf:Property ;
    rdfs:label 'Local Authorities Report Date' ;
    rdfs:comment 'Date when the security incident was reported to local authorities, if applicable (yyyy-MM-dd format).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policeCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Police Case Number' ;
    rdfs:comment 'Official case or reference number assigned by local law enforcement authorities for the security incident, if reported.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the security incident was first reported to the organization\'s security management system (yyyy-MM-ddTHH:mm:ss.SSSXXX format).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportedToInso rdf:type rdf:Property ;
    rdfs:label 'Reported To Inso' ;
    rdfs:comment 'Indicates whether the security incident was formally reported to the International NGO Safety Organisation (INSO) for coordination and information sharing among NGOs.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedToLocalAuthorities rdf:type rdf:Property ;
    rdfs:label 'Reported To Local Authorities' ;
    rdfs:comment 'Indicates whether the security incident was reported to local law enforcement or government authorities.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedToUndss rdf:type rdf:Property ;
    rdfs:label 'Reported To Undss' ;
    rdfs:comment 'Indicates whether the security incident was formally reported to the United Nations Department of Safety and Security (UNDSS) for coordination and situational awareness.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:staffFatalityCount rdf:type rdf:Property ;
    rdfs:label 'Staff Fatality Count' ;
    rdfs:comment 'Number of staff members who died as a result of the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:staffInjuredCount rdf:type rdf:Property ;
    rdfs:label 'Staff Injured Count' ;
    rdfs:comment 'Number of staff members who sustained physical injuries as a result of the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:undssReportDate rdf:type rdf:Property ;
    rdfs:label 'Undss Report Date' ;
    rdfs:comment 'Date when the security incident was reported to UNDSS, if applicable (yyyy-MM-dd format).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emergencyId rdf:type rdf:Property ;
    rdfs:label 'Emergency Id' ;
    rdfs:comment 'Reference to the crisis or emergency context this situation report addresses.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Emergency .

ind:sitrepApprovedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Sitrep Approved By Staff Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who approved this situation report for submission or publication.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:sitrepStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Sitrep Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who prepared this situation report.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accessImpedimentsCount rdf:type rdf:Property ;
    rdfs:label 'Access Impediments Count' ;
    rdfs:comment 'Number of access impediments or incidents that restricted humanitarian operations during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adminLevel1Name rdf:type rdf:Property ;
    rdfs:label 'Admin Level 1 Name' ;
    rdfs:comment 'Name of the first-level administrative division (province, state, region) covered by this report.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adminLevel2Name rdf:type rdf:Property ;
    rdfs:label 'Admin Level 2 Name' ;
    rdfs:comment 'Name of the second-level administrative division (district, county) covered by this report.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cerfApplicationStatus rdf:type rdf:Property ;
    rdfs:label 'Cerf Application Status' ;
    rdfs:comment 'Status of any CERF funding application related to operations covered by this report.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterCoordinationUpdates rdf:type rdf:Property ;
    rdfs:label 'Cluster Coordination Updates' ;
    rdfs:comment 'Summary of cluster coordination activities, inter-agency meetings, and coordination outcomes during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterLeadAgency rdf:type rdf:Property ;
    rdfs:label 'Cluster Lead Agency' ;
    rdfs:comment 'Name of the lead agency for the primary cluster or sector covered by this report.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisisContextSummary rdf:type rdf:Property ;
    rdfs:label 'Crisis Context Summary' ;
    rdfs:comment 'Brief narrative summary of the emergency or crisis context, including key developments during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorSubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Donor Submission Required' ;
    rdfs:comment 'Indicates whether this situation report is required to be submitted to donors as part of grant reporting obligations.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:educationBeneficiariesReached rdf:type rdf:Property ;
    rdfs:label 'Education Beneficiaries Reached' ;
    rdfs:comment 'Number of children and youth reached through education programs during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:foodDistributionsCompleted rdf:type rdf:Property ;
    rdfs:label 'Food Distributions Completed' ;
    rdfs:comment 'Number of food distribution events completed during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fundingGapUsd rdf:type rdf:Property ;
    rdfs:label 'Funding Gap Usd' ;
    rdfs:comment 'Estimated funding gap in US dollars for operations covered by this report.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthConsultationsCompleted rdf:type rdf:Property ;
    rdfs:label 'Health Consultations Completed' ;
    rdfs:comment 'Number of health consultations or medical encounters completed during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hrpProgressPercentage rdf:type rdf:Property ;
    rdfs:label 'Hrp Progress Percentage' ;
    rdfs:comment 'Percentage of Humanitarian Response Plan targets achieved as of the end of the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nfiDistributionsCompleted rdf:type rdf:Property ;
    rdfs:label 'Nfi Distributions Completed' ;
    rdfs:comment 'Number of non-food item distribution events completed during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nfiKitsDistributed rdf:type rdf:Property ;
    rdfs:label 'Nfi Kits Distributed' ;
    rdfs:comment 'Total number of NFI kits or packages distributed during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ochaSubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Ocha Submission Required' ;
    rdfs:comment 'Indicates whether this situation report is required to be submitted to OCHA for coordination purposes.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalConstraints rdf:type rdf:Property ;
    rdfs:label 'Operational Constraints' ;
    rdfs:comment 'Narrative description of operational constraints, access issues, security incidents, or logistical challenges encountered during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionCasesRegistered rdf:type rdf:Property ;
    rdfs:label 'Protection Cases Registered' ;
    rdfs:comment 'Number of new protection cases registered during the reporting period, including GBV, child protection, and other protection concerns.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known unique identifier for this situation report, typically following organizational numbering convention.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the situation report (draft, under review, approved, submitted to OCHA/donors, published, archived).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportTitle rdf:type rdf:Property ;
    rdfs:label 'Report Title' ;
    rdfs:comment 'Descriptive title of the situation report, typically including crisis name and reporting period.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceGapsSummary rdf:type rdf:Property ;
    rdfs:label 'Resource Gaps Summary' ;
    rdfs:comment 'Narrative description of critical resource gaps, funding shortfalls, or supply needs identified during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityIncidentsCount rdf:type rdf:Property ;
    rdfs:label 'Security Incidents Count' ;
    rdfs:comment 'Number of security incidents affecting staff, operations, or beneficiaries during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shelterUnitsProvided rdf:type rdf:Property ;
    rdfs:label 'Shelter Units Provided' ;
    rdfs:comment 'Number of shelter units (tents, transitional shelters, housing units) provided during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:washBeneficiariesReached rdf:type rdf:Property ;
    rdfs:label 'Wash Beneficiaries Reached' ;
    rdfs:comment 'Number of beneficiaries reached through WASH interventions during the reporting period.' ;
    rdfs:domain ind:Sitrep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fundingSourceId rdf:type rdf:Property ;
    rdfs:label 'Funding Source Id' ;
    rdfs:comment 'Reference to the grant or funding source that finances this team\'s operations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundingSource .

ind:itAssetId rdf:type rdf:Property ;
    rdfs:label 'It Asset Id' ;
    rdfs:comment 'Reference to the primary vehicle or transport asset assigned to this team for field operations and mobility.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItAsset .

ind:activitiesCompletedCount rdf:type rdf:Property ;
    rdfs:label 'Activities Completed Count' ;
    rdfs:comment 'Total number of field activities, distributions, assessments, or service delivery events completed by this team.' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiariesServedCount rdf:type rdf:Property ;
    rdfs:label 'Beneficiaries Served Count' ;
    rdfs:comment 'Cumulative number of unique beneficiaries or PoC (Persons of Concern) served by this team since deployment start.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationEquipment rdf:type rdf:Property ;
    rdfs:label 'Communication Equipment' ;
    rdfs:comment 'Description of communication equipment assigned to the team (e.g., satellite phones, radios, mobile devices, GPS units) to maintain contact with coordination centers and ensure safety.' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Coverage Area Description' ;
    rdfs:comment 'Textual description of the geographic area or communities covered by this team (e.g., \'Northern District villages\', \'IDP (Internally Displaced Person) camps in Region 3\').' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentEndDate rdf:type rdf:Property ;
    rdfs:label 'Deployment End Date' ;
    rdfs:comment 'Planned or actual date when the team deployment concluded or is scheduled to conclude. Null for ongoing deployments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deploymentStartDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Start Date' ;
    rdfs:comment 'Date when the team was first deployed or became operational.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Name of the primary emergency contact person for this team (typically a field coordinator or security officer).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Phone number of the primary emergency contact for this team, used for urgent communication and security incidents.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled' ;
    rdfs:comment 'Indicates whether GPS tracking is enabled for this team\'s movements and field activities for safety monitoring and activity verification.' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the most recent formal performance review or evaluation conducted for this team.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSitrepDate rdf:type rdf:Property ;
    rdfs:label 'Last Sitrep Date' ;
    rdfs:comment 'Date when the team last submitted a SitRep (Situation Report) to the coordination center or country office.' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobileDataCollectionPlatform rdf:type rdf:Property ;
    rdfs:label 'Mobile Data Collection Platform' ;
    rdfs:comment 'Name of the mobile data collection tool or platform used by this team (e.g., KoboToolbox, CommCare, ODK, DHIS2 mobile).' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyOperationalBudget rdf:type rdf:Property ;
    rdfs:label 'Monthly Operational Budget' ;
    rdfs:comment 'Planned monthly operational budget allocated for this team\'s activities, including salaries, transport, supplies, and per diems.' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Most recent performance assessment rating for the team based on MEL (Monitoring Evaluation and Learning) indicators, service delivery quality, and beneficiary feedback.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyClearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Clearance Level' ;
    rdfs:comment 'Security risk level classification for the team\'s operational area, aligned with UN security phase system. Determines safety protocols and movement restrictions.' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamCode rdf:type rdf:Property ;
    rdfs:label 'Team Code' ;
    rdfs:comment 'Short alphanumeric code used for operational identification and reporting (e.g., \'DT-001\', \'MHU-03\', \'WASH-A\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamName rdf:type rdf:Property ;
    rdfs:label 'Team Name' ;
    rdfs:comment 'Human-readable name or designation of the field team (e.g., \'Delta Distribution Team\', \'Mobile Health Unit 3\', \'WASH Response Team Alpha\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamType rdf:type rdf:Property ;
    rdfs:label 'Team Type' ;
    rdfs:comment 'Classification of the team based on its primary operational function. Distribution teams handle NFI (Non-Food Item) distributions; CHW (Community Health Worker) teams provide mobile health outreach; WASH (Water Sanitation and Hygiene) teams deliver water and sanitation interventions; assessment teams conduct FGD (Focus Group Discussion) and KII (Key Informant Interview); protection teams address GBV (Gender-Based Violence) and child protection; rapid response teams handle emergency deployments; nutrition teams manage SAM (Severe Acute Malnutrition) and GAM (Global Acute Malnutrition) programs; education teams deliver learning programs; shelter teams provide housing assistance; logistics teams manage supply chain and transport. [ENUM-REF-CANDIDATE: distribution|community_health_worker|wash|assessment|protection|rapid_response|nutrition|education|shelter|logistics — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCertifications rdf:type rdf:Property ;
    rdfs:label 'Training Certifications' ;
    rdfs:comment 'Comma-separated list of key training certifications held by team members (e.g., \'SPHERE\', \'CHS\', \'PSS (Psychosocial Support)\', \'GBV Response\', \'First Aid\').' ;
    rdfs:domain ind:FieldTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:washInterventionId rdf:type rdf:Property ;
    rdfs:label 'Wash Intervention Id' ;
    rdfs:comment 'Unique identifier for the WASH intervention activity record.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WashIntervention .

ind:coordinationMeetingId rdf:type rdf:Property ;
    rdfs:label 'Coordination Meeting Id' ;
    rdfs:comment 'Reference to the OCHA WASH cluster coordination meeting where this intervention was discussed, planned, or reported, supporting inter-agency coordination and avoiding duplication.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoordinationMeeting .

ind:primaryWashStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Wash Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who created this WASH intervention record in the system, supporting accountability and data governance.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:actualBeneficiariesReached rdf:type rdf:Property ;
    rdfs:label 'Actual Beneficiaries Reached' ;
    rdfs:comment 'The actual number of beneficiaries who received services or benefits from this WASH intervention, captured through Post-Distribution Monitoring (PDM) or field assessments.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualExpenditureUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Expenditure Usd' ;
    rdfs:comment 'The actual expenditure incurred for this WASH intervention in United States Dollars, captured from financial transactions in the Enterprise Resource Planning (ERP) system for donor reporting and financial stewardship.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'The primary assessment methodology used to evaluate this WASH intervention, including Focus Group Discussion (FGD), Key Informant Interview (KII), household survey, direct observation, or Post-Distribution Monitoring (PDM).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocatedUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Usd' ;
    rdfs:comment 'The total budget allocated for this WASH intervention in United States Dollars, drawn from grant or program funds and tracked for Budget versus Actual (BvA) analysis.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communityContribution rdf:type rdf:Property ;
    rdfs:label 'Community Contribution' ;
    rdfs:comment 'Description of in-kind or cash contributions provided by the community for this WASH intervention, such as labor, local materials, or land access, supporting sustainability and community ownership.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorName rdf:type rdf:Property ;
    rdfs:label 'Contractor Name' ;
    rdfs:comment 'The name of the contractor or construction firm responsible for physical infrastructure work (borehole drilling, latrine construction, water system installation) for this WASH intervention.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disabilityInclusion rdf:type rdf:Property ;
    rdfs:label 'Disability Inclusion' ;
    rdfs:comment 'Description of accessibility features and disability inclusion measures incorporated into this WASH intervention, such as ramps, handrails, or accessible latrine designs for persons with disabilities.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Assessment' ;
    rdfs:comment 'Status of environmental impact assessment for this WASH intervention, particularly relevant for infrastructure projects such as borehole drilling or wastewater management that may affect local ecosystems.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderConsiderations rdf:type rdf:Property ;
    rdfs:label 'Gender Considerations' ;
    rdfs:comment 'Description of gender-sensitive design and implementation considerations for this WASH intervention, such as separate facilities for women and men, menstrual hygiene management provisions, and women\'s participation in decision-making.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hygienePromotionConducted rdf:type rdf:Property ;
    rdfs:label 'Hygiene Promotion Conducted' ;
    rdfs:comment 'Boolean flag indicating whether hygiene promotion activities (behavior change communication, hygiene education sessions, community mobilization) were conducted as part of this WASH intervention.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:infrastructureGpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Gps Latitude' ;
    rdfs:comment 'The GPS latitude coordinate of the WASH infrastructure (borehole, latrine block, water point) installed or rehabilitated, captured via mobile data collection tools such as KoboToolbox or Humanitarian OpenStreetMap.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:infrastructureGpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Gps Longitude' ;
    rdfs:comment 'The GPS longitude coordinate of the WASH infrastructure (borehole, latrine block, water point) installed or rehabilitated, captured via mobile data collection tools such as KoboToolbox or Humanitarian OpenStreetMap.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interventionDescription rdf:type rdf:Property ;
    rdfs:label 'Intervention Description' ;
    rdfs:comment 'Detailed narrative description of the WASH intervention activity, including technical specifications, community engagement approach, and any special considerations or challenges encountered during implementation.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interventionStatus rdf:type rdf:Property ;
    rdfs:label 'Intervention Status' ;
    rdfs:comment 'Current lifecycle status of the WASH intervention activity, tracking progress from planning through completion or closure.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interventionType rdf:type rdf:Property ;
    rdfs:label 'Intervention Type' ;
    rdfs:comment 'Classification of the WASH intervention activity type, aligned with SPHERE standards and OCHA WASH cluster categories. [ENUM-REF-CANDIDATE: borehole_rehabilitation|latrine_construction|hygiene_kit_distribution|water_trucking|chlorination|handwashing_station|septic_tank_installation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nfiDistributedQuantity rdf:type rdf:Property ;
    rdfs:label 'Nfi Distributed Quantity' ;
    rdfs:comment 'The quantity of Non-Food Items (NFI) such as hygiene kits, water containers, or soap distributed as part of this WASH intervention, tracked for supply chain management and Post-Distribution Monitoring (PDM).' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ochaWashClusterCode rdf:type rdf:Property ;
    rdfs:label 'Ocha Wash Cluster Code' ;
    rdfs:comment 'The standardized OCHA WASH cluster reporting code used for inter-agency coordination and Situation Report (SitRep) generation, enabling aggregation across humanitarian actors.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sitrepReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Sitrep Reporting Period' ;
    rdfs:comment 'The reporting period (quarterly or monthly) during which this WASH intervention was included in Situation Reports (SitRep) submitted to OCHA or donors, formatted as YYYY-QX or YYYY-MXX.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sphereLatrineCoverageRatio rdf:type rdf:Property ;
    rdfs:label 'Sphere Latrine Coverage Ratio' ;
    rdfs:comment 'The ratio of latrines to population served, expressed as 1:X (e.g., 1:20), used to assess compliance with SPHERE minimum standard of 1 latrine per 20 people in emergency settings.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sphereWaterQuantityLpd rdf:type rdf:Property ;
    rdfs:label 'Sphere Water Quantity Lpd' ;
    rdfs:comment 'The water quantity indicator measured in liters per person per day, used to assess compliance with SPHERE minimum standard of 15 liters per person per day for survival needs.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityPlan rdf:type rdf:Property ;
    rdfs:label 'Sustainability Plan' ;
    rdfs:comment 'Narrative description of the sustainability plan for this WASH intervention, including community management structures, maintenance arrangements, and capacity building activities to ensure long-term functionality.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPopulationCount rdf:type rdf:Property ;
    rdfs:label 'Target Population Count' ;
    rdfs:comment 'The number of beneficiaries (Persons of Concern (PoC), Internally Displaced Persons (IDP), or community members) this WASH intervention is designed to serve.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waterQualityTestResult rdf:type rdf:Property ;
    rdfs:label 'Water Quality Test Result' ;
    rdfs:comment 'The result of water quality testing conducted on water sources or distribution points associated with this WASH intervention, assessing microbiological and chemical safety per SPHERE standards.' ;
    rdfs:domain ind:WashIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Unique identifier for the bank account record. Primary key for the bank account entity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:createdByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Created By Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Finance tracks which staff member created each bank account record for accountability in bank account setup and treasury management.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:grantAwardId rdf:type rdf:Property ;
    rdfs:label 'Grant Award Id' ;
    rdfs:comment 'Foreign key reference to the specific grant award associated with this bank account, if the account is dedicated to a single grant or project. Supports grant financial management and compliance reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Award .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The official name or title of the bank account as registered with the financial institution. Typically reflects the organization name, office, or fund designation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The full bank account number as issued by the financial institution. May be masked for security purposes in reporting layers. Critical for payment processing, reconciliation, and fund transfers.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumberMasked rdf:type rdf:Property ;
    rdfs:label 'Account Number Masked' ;
    rdfs:comment 'Partially masked version of the bank account number for display in reports and user interfaces (e.g., ****1234). Protects sensitive financial data while allowing account identification.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the bank account. Active accounts are operational for transactions; dormant accounts have no recent activity but remain open; closed accounts are permanently deactivated; frozen accounts are temporarily suspended due to compliance or security issues; pending activation accounts are newly opened but not yet operational.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the bank account based on its operational purpose. Operating accounts support general organizational expenses; restricted accounts hold donor-restricted funds; payroll accounts are dedicated to staff compensation; project accounts are tied to specific grants or programs; donor-specific accounts are ring-fenced per donor requirements. [ENUM-REF-CANDIDATE: operating|restricted|payroll|project|donor_specific|savings|escrow|petty_cash — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBalance rdf:type rdf:Property ;
    rdfs:label 'Available Balance' ;
    rdfs:comment 'The available balance in the bank account, accounting for pending transactions, holds, and minimum balance requirements. Represents the actual funds available for disbursement. Denominated in the account currency.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankBranchCode rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Code' ;
    rdfs:comment 'The unique code assigned to the bank branch by the financial institution or national banking authority. Used for domestic payment routing and reconciliation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchName rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Name' ;
    rdfs:comment 'The name or identifier of the specific bank branch where the account is domiciled. Supports localized banking operations and correspondence.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactEmail rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Email' ;
    rdfs:comment 'The email address of the primary contact person at the financial institution for this bank account. Used for correspondence and issue resolution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactName rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Name' ;
    rdfs:comment 'The name of the primary contact person at the financial institution for this bank account. Supports relationship management and issue resolution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactPhone rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Phone' ;
    rdfs:comment 'The phone number of the primary contact person at the financial institution for this bank account. Used for urgent inquiries and issue resolution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'The legal name of the financial institution where the account is held. Essential for payment routing, reconciliation, and financial reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingDate rdf:type rdf:Property ;
    rdfs:label 'Closing Date' ;
    rdfs:comment 'The date when the bank account was officially closed. Null for active or dormant accounts. Marks the end of the account lifecycle.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'The current balance of the bank account as of the last update or reconciliation. Denominated in the account currency. Used for cash flow monitoring and liquidity management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorName rdf:type rdf:Property ;
    rdfs:label 'Donor Name' ;
    rdfs:comment 'The name of the donor or funding agency whose funds are held in this account, applicable for donor-specific or restricted accounts. Supports donor reporting and fund segregation requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Restriction Flag' ;
    rdfs:comment 'Indicates whether this bank account holds donor-restricted funds that can only be used for specific purposes as stipulated by the donor. True if restricted; false if unrestricted. Critical for FASB ASC 958 compliance and donor stewardship.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'The International Bank Account Number, a standardized international numbering system for bank accounts. Used primarily in Europe and other regions for cross-border payments. Format varies by country but always starts with 2-letter country code followed by 2 check digits.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestBearingFlag rdf:type rdf:Property ;
    rdfs:label 'Interest Bearing Flag' ;
    rdfs:comment 'Indicates whether this bank account earns interest on deposited funds. True if interest-bearing; false otherwise. Relevant for savings accounts and certain restricted fund accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'The annual interest rate applied to this bank account, expressed as a decimal (e.g., 0.0250 for 2.5%). Applicable only for interest-bearing accounts. Used for interest income forecasting and financial planning.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'The date when the bank account was last successfully reconciled against the General Ledger (GL). Used to monitor compliance with reconciliation frequency requirements and identify overdue reconciliations.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'The date of the most recent transaction (deposit, withdrawal, or transfer) on this bank account. Used to identify dormant accounts and monitor account activity.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumBalanceRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Requirement' ;
    rdfs:comment 'The minimum balance that must be maintained in this bank account to avoid fees or penalties, as stipulated by the financial institution. Denominated in the account currency.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'The organizational office or location that owns and manages this bank account (e.g., Headquarters, Kenya Country Office, Syria Regional Office). Supports decentralized financial management and cost center allocation.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'The date when the bank account was officially opened with the financial institution. Marks the start of the account lifecycle.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'The maximum overdraft amount permitted on this bank account, if overdraft protection is enabled. Denominated in the account currency. Null if no overdraft protection exists.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdraftProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Overdraft Protection Flag' ;
    rdfs:comment 'Indicates whether this bank account has overdraft protection enabled. True if overdraft protection is active; false otherwise. Overdraft protection allows transactions to proceed even if the account balance is insufficient, subject to bank terms.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationFrequency rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Frequency' ;
    rdfs:comment 'The required frequency for reconciling this bank account against the General Ledger (GL). High-volume or high-risk accounts may require daily reconciliation; lower-activity accounts may be reconciled monthly or quarterly per internal controls policy.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'The 9-digit routing transit number (RTN) used in the United States for domestic wire transfers, ACH transactions, and check processing. Identifies the financial institution in the US banking system.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Signatory Requirement' ;
    rdfs:comment 'The number and level of authorized signatories required to approve transactions on this bank account. Single signatory allows one authorized person; dual signatory requires two; triple requires three; board approval requires formal board resolution. Supports segregation of duties and fraud prevention.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Signatory Threshold Amount' ;
    rdfs:comment 'The monetary threshold above which elevated signatory requirements apply. For example, transactions below this amount may require single signatory, while transactions above require dual or board approval. Denominated in the account currency.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'The Society for Worldwide Interbank Financial Telecommunication (SWIFT) code, also known as Bank Identifier Code (BIC). An 8 or 11-character code used for international wire transfers and cross-border payments. Format: 4-letter bank code, 2-letter country code, 2-character location code, optional 3-character branch code.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Bank Reconciliation Id' ;
    rdfs:comment 'Unique identifier for the bank reconciliation record. Primary key.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBankUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Bank User Account Id' ;
    rdfs:comment 'System user identifier of the finance staff member who performed the reconciliation. Links to the workforce user registry.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:tertiaryBankApprovedByUserUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Bank Approved By User User Account Id' ;
    rdfs:comment 'System user identifier of the authorized approver. Links to the workforce user registry.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:adjustedBankBalance rdf:type rdf:Property ;
    rdfs:label 'Adjusted Bank Balance' ;
    rdfs:comment 'Bank statement closing balance after adjustments for outstanding deposits, outstanding checks, and other in-transit items.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedGlBalance rdf:type rdf:Property ;
    rdfs:label 'Adjusted Gl Balance' ;
    rdfs:comment 'General ledger book balance after adjustments for unrecorded bank charges, interest, and other reconciling items.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking this bank reconciliation to external audit documentation, supporting schedules, or compliance evidence.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Flag indicating whether this bank reconciliation meets all internal control requirements, OMB Uniform Guidance standards, and donor compliance obligations.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCount rdf:type rdf:Property ;
    rdfs:label 'Exception Count' ;
    rdfs:comment 'Number of exceptions or discrepancies identified during the reconciliation that require follow-up or corrective action.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Fiscal period (month or quarter) within the fiscal year to which this bank reconciliation belongs.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glBookBalance rdf:type rdf:Property ;
    rdfs:label 'Gl Book Balance' ;
    rdfs:comment 'Cash balance recorded in the general ledger for the corresponding GL account at the reconciliation date.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRestrictedFund rdf:type rdf:Property ;
    rdfs:label 'Is Restricted Fund' ;
    rdfs:comment 'Flag indicating whether the bank account holds donor-restricted funds subject to specific use restrictions and compliance requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outstandingChecksAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Checks Amount' ;
    rdfs:comment 'Total amount of checks issued and recorded in the general ledger but not yet cleared by the bank.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingDepositsAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Deposits Amount' ;
    rdfs:comment 'Total amount of deposits recorded in the general ledger but not yet reflected on the bank statement (deposits in transit).' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciledBy rdf:type rdf:Property ;
    rdfs:label 'Reconciled By' ;
    rdfs:comment 'Name or identifier of the finance staff member who performed the bank reconciliation.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date when the bank reconciliation activity was performed and completed by the reconciling officer.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Document Number' ;
    rdfs:comment 'Externally-known business identifier for the bank reconciliation document, used for audit trail and reference purposes.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationNotes rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Notes' ;
    rdfs:comment 'Free-text notes and comments documenting reconciling items, variances, adjustments, and any issues identified during the reconciliation process.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period End Date' ;
    rdfs:comment 'End date of the reconciliation period covered by this bank reconciliation activity.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period Start Date' ;
    rdfs:comment 'Start date of the reconciliation period covered by this bank reconciliation activity.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Current lifecycle status of the bank reconciliation process. Tracks workflow from initiation through approval.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconcilingItemsCount rdf:type rdf:Property ;
    rdfs:label 'Reconciling Items Count' ;
    rdfs:comment 'Total number of reconciling items identified during the bank reconciliation process, including outstanding deposits, outstanding checks, and unrecorded transactions.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or identifier of the supervisor or manager who reviewed the bank reconciliation for accuracy and completeness.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementClosingBalance rdf:type rdf:Property ;
    rdfs:label 'Statement Closing Balance' ;
    rdfs:comment 'Closing balance as reported on the bank statement at the end of the reconciliation period.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementDate rdf:type rdf:Property ;
    rdfs:label 'Statement Date' ;
    rdfs:comment 'Official date of the bank statement being reconciled against the general ledger.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementOpeningBalance rdf:type rdf:Property ;
    rdfs:label 'Statement Opening Balance' ;
    rdfs:comment 'Opening balance as reported on the bank statement at the beginning of the reconciliation period.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrecordedBankChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Unrecorded Bank Charges Amount' ;
    rdfs:comment 'Total amount of bank service charges, fees, and other deductions appearing on the bank statement but not yet recorded in the general ledger.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrecordedBankCreditsAmount rdf:type rdf:Property ;
    rdfs:label 'Unrecorded Bank Credits Amount' ;
    rdfs:comment 'Total amount of bank interest income, wire transfers, or other credits appearing on the bank statement but not yet recorded in the general ledger.' ;
    rdfs:domain ind:BankReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Difference between adjusted GL balance and adjusted bank balance. A zero variance indicates successful reconciliation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Unique identifier for the budget record. Primary key.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:financeNicraRateId rdf:type rdf:Property ;
    rdfs:label 'Finance Nicra Rate Id' ;
    rdfs:comment 'Foreign key linking to finance.nicra_rate. Business justification: Budgets reference NICRA rates for indirect cost budgeting. This FK enables joining to get the approved rate percentage and effective dates.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NicraRate .

ind:approvedModificationsCount rdf:type rdf:Property ;
    rdfs:label 'Approved Modifications Count' ;
    rdfs:comment 'The number of formal modifications or amendments that have been approved for this budget since initial approval. Tracks budget revision history and compliance with donor prior-approval requirements.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardCeilingAmount rdf:type rdf:Property ;
    rdfs:label 'Award Ceiling Amount' ;
    rdfs:comment 'The maximum allowable expenditure under the grant award, including all approved modifications. For grant-type budgets, this represents the donor\'s total funding commitment and cannot be exceeded without prior approval.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying this budget in financial systems and donor reports. Used as the business identifier for budget tracking and reference.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Descriptive name of the budget, typically including program or grant reference for easy identification by finance and program staff.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle state of the budget. Draft indicates initial preparation; submitted means under review; approved indicates formal authorization; revised indicates modifications post-approval; active indicates currently in use; closed indicates budget period ended; cancelled indicates budget was terminated before completion. [ENUM-REF-CANDIDATE: draft|submitted|approved|revised|active|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget by its purpose and funding nature. Operational budgets support ongoing organizational activities; project budgets are tied to specific initiatives; grant budgets are donor-funded and compliance-driven; capital budgets fund long-term assets; restricted budgets have donor-imposed limitations; unrestricted budgets have no donor restrictions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:burnRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Burn Rate Percentage' ;
    rdfs:comment 'The percentage of the total approved budget that has been expended to date. Calculated as (total_actual_expenditure / total_approved_amount) * 100. Used to monitor spending pace and forecast budget depletion.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costShareRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Share Requirement Amount' ;
    rdfs:comment 'The amount of cost-sharing or matching funds required by the donor as a condition of the grant. Represents the organization\'s commitment to contribute resources beyond the donor award.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directCostBudget rdf:type rdf:Property ;
    rdfs:label 'Direct Cost Budget' ;
    rdfs:comment 'The portion of the total budget allocated to direct costs that can be specifically attributed to program activities, such as salaries, supplies, and travel directly supporting the program or grant.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Donor Reporting Frequency' ;
    rdfs:comment 'The frequency at which financial reports must be submitted to the donor for this budget. Drives the cadence of Budget vs. Actual (BvA) reporting and compliance monitoring.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icrRateApplied rdf:type rdf:Property ;
    rdfs:label 'Icr Rate Applied' ;
    rdfs:comment 'The indirect cost rate percentage applied to calculate the indirect cost budget. Expressed as a percentage (e.g., 15.00 for 15%). May be based on NICRA or donor-imposed rate caps.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indirectCostBudget rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Budget' ;
    rdfs:comment 'The portion of the total budget allocated to indirect costs (overhead, facilities, administration) that support the organization but cannot be directly attributed to a single program or grant. Calculated using the Indirect Cost Rate (ICR).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Modification Date' ;
    rdfs:comment 'The date of the most recent approved modification to this budget. Used to track budget revision history and ensure compliance with donor reporting timelines.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'The name or identifier of the individual responsible for managing and monitoring this budget (e.g., Program Manager, Finance Manager). Accountable for budget performance and variance management.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The date when this budget period ends. For grant budgets, this aligns with the award period end date. Used to calculate burn rate and remaining budget availability.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The date when this budget period begins. For grant budgets, this aligns with the award period start date. Critical for Budget vs. Actual (BvA) tracking and compliance reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorApprovalThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Approval Threshold Amount' ;
    rdfs:comment 'The monetary threshold above which budget modifications or reallocations require prior written approval from the donor. Varies by donor and grant terms (e.g., USAID, DFID, UN agencies).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'The program or project code associated with this budget. Links the budget to specific programmatic activities for Monitoring, Evaluation, and Learning (MEL) and Results-Based Management (RBM) reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalActualExpenditure rdf:type rdf:Property ;
    rdfs:label 'Total Actual Expenditure' ;
    rdfs:comment 'The cumulative actual expenditure recorded against this budget to date. Used in Budget vs. Actual (BvA) variance analysis and burn rate calculations.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalApprovedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Approved Amount' ;
    rdfs:comment 'The total approved budget amount for this budget period, including both direct and indirect costs. Represents the authorized spending ceiling.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Total Variance Amount' ;
    rdfs:comment 'The difference between the total approved budget amount and the total actual expenditure. Positive variance indicates under-spending; negative variance indicates over-spending. Key metric for Budget vs. Actual (BvA) reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Unique identifier for the budget line item. Primary key.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetLine .

ind:activityCode rdf:type rdf:Property ;
    rdfs:label 'Activity Code' ;
    rdfs:comment 'Specific program activity or intervention this budget line funds. Supports Logical Framework (LogFrame) and Theory of Change (ToC) budget alignment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate shared or indirect costs to this budget line. Ensures transparent and auditable cost allocation per OMB Uniform Guidance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Line Status' ;
    rdfs:comment 'Current lifecycle status of the budget line. Tracks approval workflow and budget lock-down for financial control.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNarrative rdf:type rdf:Property ;
    rdfs:label 'Budget Narrative' ;
    rdfs:comment 'Detailed justification and description of the budget line item. Explains the purpose, calculation basis, and alignment with program activities. Required for donor budget submissions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPeriodType rdf:type rdf:Property ;
    rdfs:label 'Budget Period Type' ;
    rdfs:comment 'Granularity of the budget period for this line item. Determines reporting frequency and BvA tracking intervals.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costShareSource rdf:type rdf:Property ;
    rdfs:label 'Cost Share Source' ;
    rdfs:comment 'Source of cost-sharing contribution for this budget line. Distinguishes between organizational funds, third-party contributions, in-kind, or cash match.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costType rdf:type rdf:Property ;
    rdfs:label 'Cost Type' ;
    rdfs:comment 'Classification of cost as direct (attributable to a single program), indirect (Facilities and Administration / F&A), or shared (allocated across multiple programs). Critical for NICRA compliance.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorBudgetCategory rdf:type rdf:Property ;
    rdfs:label 'Donor Budget Category' ;
    rdfs:comment 'Donor-specific budget category or line item code as required by the funding source. Maps internal budget structure to donor reporting templates.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseCategory rdf:type rdf:Property ;
    rdfs:label 'Expense Category' ;
    rdfs:comment 'High-level classification of the budget line expenditure type. Aligns with OMB Uniform Guidance cost categories and donor budget templates. [ENUM-REF-CANDIDATE: personnel|travel|equipment|supplies|contractual|other_direct|indirect — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAllowable rdf:type rdf:Property ;
    rdfs:label 'Is Allowable' ;
    rdfs:comment 'Indicates whether this budget line represents an allowable cost under the grant terms and OMB Uniform Guidance. Used for compliance validation.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCostShare rdf:type rdf:Property ;
    rdfs:label 'Is Cost Share' ;
    rdfs:comment 'Indicates whether this budget line represents a cost-sharing or matching contribution required by the donor. Critical for grant compliance tracking.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalAmount rdf:type rdf:Property ;
    rdfs:label 'Original Amount' ;
    rdfs:comment 'Initial planned expenditure or revenue amount for this budget line as approved in the original budget submission. Baseline for tracking budget changes.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Number of units planned for this budget line. Used in conjunction with unit cost to calculate total budget amount.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Amount' ;
    rdfs:comment 'Current approved budget amount after amendments, reallocations, or donor-approved modifications. Used for current-period BvA tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential version number tracking amendments and modifications to this budget line. Enables budget change history and audit compliance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Explanation for the most recent revision to this budget line. Documents the business justification for budget amendments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Cost per unit for this budget line. Multiplied by quantity to derive the total budget amount. Supports transparent budget calculation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitDescription rdf:type rdf:Property ;
    rdfs:label 'Unit Description' ;
    rdfs:comment 'Description of the unit of measure for this budget line (e.g., staff month, trip, item, training session). Provides context for quantity-based budget calculations.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Unique identifier for the cost allocation transaction record. Primary key.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Source Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Cost allocations originate from a source cost center. This FK enables tracking which cost center is the source of allocated costs. Label prefix \'source_\' distinguishes this from target_cost_center_id.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:sourceFinanceFundId rdf:type rdf:Property ;
    rdfs:label 'Source Finance Fund Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_fund. Business justification: Cost allocations originate from a source fund. This FK enables tracking which fund is the source of allocated costs and ensures compliance with donor restrictions. Label prefix \'source_\' distinguishes' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceFund .

ind:targetCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Target Cost Center Id' ;
    rdfs:comment 'FK to finance.cost_center' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:targetFinanceFundId rdf:type rdf:Property ;
    rdfs:label 'Target Finance Fund Id' ;
    rdfs:comment 'FK to finance.finance_fund' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceFund .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The monetary value of the cost being allocated from the source to the target. Represents the actual dollar amount distributed in this allocation transaction.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBasis rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis' ;
    rdfs:comment 'The quantitative basis or driver used to calculate the allocation distribution, such as headcount, square footage, direct costs, full-time equivalents (FTE), revenue, beneficiary count, transaction volume, or time spent. [ENUM-REF-CANDIDATE: headcount|square_footage|direct_costs|fte|revenue|beneficiary_count|transaction_volume|time_spent — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationBasisQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Quantity' ;
    rdfs:comment 'The quantitative measure of the allocation basis used in the calculation (e.g., number of employees, square feet, total direct costs). Used in conjunction with allocation_rate to compute allocated_amount.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBasisUnit rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Unit' ;
    rdfs:comment 'The unit of measure for the allocation basis quantity (e.g., employees, square_feet, USD, FTE, hours).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date on which the cost allocation was executed and recorded in the general ledger.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Document Number' ;
    rdfs:comment 'Externally-known unique document number for this cost allocation transaction, used for audit trail and reference in financial systems.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes or comments providing additional context, justification, or documentation for this cost allocation transaction.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRate rdf:type rdf:Property ;
    rdfs:label 'Allocation Rate' ;
    rdfs:comment 'The rate or percentage applied to the allocation basis to calculate the allocated amount. For NICRA-based allocations, this represents the negotiated indirect cost rate.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle status of the cost allocation transaction: draft (being prepared), pending approval (awaiting review), approved (authorized), posted (recorded in GL), reversed (cancelled), or rejected (not approved).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'Classification of the cost being allocated: direct program costs, indirect costs, facilities and administration (F&A), shared services, or overhead.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPool rdf:type rdf:Property ;
    rdfs:label 'Cost Pool' ;
    rdfs:comment 'The name or identifier of the cost pool from which costs are being allocated. Cost pools aggregate similar indirect costs for distribution.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFaCost rdf:type rdf:Property ;
    rdfs:label 'Is Fa Cost' ;
    rdfs:comment 'Boolean flag indicating whether this allocation represents Facilities and Administration (F&A) costs, also known as indirect costs, that are recoverable under federal grants.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which this cost allocation was posted to the general ledger and became part of the official financial records.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which this cost allocation was reversed or cancelled, if applicable. Null if the allocation has not been reversed.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Explanation for why this cost allocation was reversed or cancelled, if applicable.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Reference to the parent cost center in the organizational hierarchy. Enables roll-up reporting from field offices to regional hubs to headquarters. Nullable for top-level cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:primaryCostUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Cost User Account Id' ;
    rdfs:comment 'Reference to the user who created this cost center record. Used for accountability and audit purposes.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:tertiaryCostApprovedByUserUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Cost Approved By User User Account Id' ;
    rdfs:comment 'Reference to the user who approved this cost center for activation. Typically a finance director, controller, or Chief Financial Officer (CFO). Nullable for cost centers not yet approved.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'The total approved budget amount for this cost center for the current fiscal year. Used in Budget versus Actual (BvA) variance analysis and financial stewardship reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The date and time when this cost center was approved for activation. Used for audit trail and compliance reporting. Nullable for cost centers not yet approved.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'The date and time when this cost center was permanently closed and all balances were transferred or reconciled. Used for grant closeout, project completion, and organizational restructuring. Nullable for active cost centers.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'The SAP S/4HANA or Unit4 ERP company code representing the legal entity to which this cost center belongs. Used for multi-entity consolidation and statutory reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'The SAP S/4HANA controlling area (CO module) to which this cost center is assigned. Controlling areas represent organizational units for internal cost accounting and management reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'The methodology used to allocate shared or indirect costs to this cost center. Direct allocation assigns costs explicitly; proportional uses a percentage driver; headcount allocates by staff count; square footage uses physical space; activity-based costing (ABC) uses cost drivers; not allocated for cost centers that do not receive shared cost allocations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'SAP S/4HANA cost center category classification. Production cost centers deliver direct program services; service cost centers provide internal support; administrative cost centers manage overhead; auxiliary cost centers support shared services; project cost centers are time-bound; temporary cost centers are short-term or pilot initiatives.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The externally-known unique alphanumeric code identifying the cost center in SAP S/4HANA and Unit4 ERP. Used in general ledger posting, budget tracking, and financial reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Detailed narrative description of the cost center\'s purpose, scope, and responsibilities. Includes information on program activities, geographic coverage, donor restrictions, and organizational context.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The full descriptive name of the cost center as it appears in financial reports and organizational charts.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active cost centers accept expense postings; inactive cost centers are temporarily disabled; suspended cost centers are under review; closed cost centers are permanently retired; pending activation cost centers are awaiting approval.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by functional expense category per GAAP for nonprofits. Program cost centers support direct mission delivery; administrative cost centers support organizational management; fundraising cost centers support donor cultivation and gift processing; general and administrative (G&A) support overall operations; mission support provides enabling services; field operations manage country office and site-level activities.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'The functional department or division to which this cost center belongs (e.g., Health Programs, WASH, Education, Finance, Human Resources, Monitoring Evaluation and Learning). Used for cross-cutting organizational reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalExpenseClassification rdf:type rdf:Property ;
    rdfs:label 'Functional Expense Classification' ;
    rdfs:comment 'GAAP functional expense category per FASB ASC 958-720. Program services are mission-delivery activities; management and general (M&G) are administrative overhead; fundraising supports donor cultivation; membership development supports constituent engagement. Required for Form 990 and audited financial statements.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Fund Restriction Type' ;
    rdfs:comment 'Classification of donor-imposed restrictions on funds allocated to this cost center per FASB ASC 958-205. Unrestricted funds have no donor-imposed restrictions; temporarily restricted funds have time or purpose restrictions that will lapse; permanently restricted funds (endowments) must be maintained in perpetuity.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'The depth of this cost center in the organizational hierarchy tree. Level 1 represents headquarters or top-level divisions; higher numbers represent nested field offices, country offices, or project sites.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indirectCostEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Eligible Flag' ;
    rdfs:comment 'Indicates whether expenses posted to this cost center are eligible for indirect cost recovery under the organization\'s Negotiated Indirect Cost Rate Agreement (NICRA). True for direct program cost centers; false for administrative or already-indirect cost centers. Used in Facilities and Administration (F&A) cost allocation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nicraBaseCategory rdf:type rdf:Property ;
    rdfs:label 'Nicra Base Category' ;
    rdfs:comment 'The indirect cost base category used for calculating indirect cost recovery for this cost center per the organization\'s NICRA with the federal government. Modified Total Direct Costs (MTDC) is the most common base; direct salaries and wages is used for some research organizations; total direct costs includes all direct expenses. Not applicable for cost centers that do not participate in indirect cost allocation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'The profit center code for organizations using profit center accounting in SAP S/4HANA. Used for segment reporting and internal performance measurement. Nullable for nonprofits not using profit center structures.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programArea rdf:type rdf:Property ;
    rdfs:label 'Program Area' ;
    rdfs:comment 'The thematic program area or sector this cost center supports (e.g., WASH - Water Sanitation and Hygiene, GBV - Gender-Based Violence, Health, Education, Livelihoods, Emergency Response). Used for Sustainable Development Goal (SDG) alignment and donor reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Geographic region for multi-country or regional cost centers. Used for regional program offices, humanitarian response hubs, and Development Assistance Committee (DAC) reporting. [ENUM-REF-CANDIDATE: africa|asia_pacific|europe|latin_america_caribbean|middle_east|north_america|global — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearToDateActualAmount rdf:type rdf:Property ;
    rdfs:label 'Year To Date Actual Amount' ;
    rdfs:comment 'The cumulative actual expenses posted to this cost center from the start of the fiscal year to the current reporting period. Used in BvA reporting and burn rate analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateId rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Id' ;
    rdfs:comment 'Unique identifier for the exchange rate record. Primary key for the exchange rate reference master.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByRateExchangeRateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Exchange Rate Id' ;
    rdfs:comment 'Reference to the exchange rate record that replaces this rate. Nullable for current active rates. Creates a chain of rate succession for historical tracking and audit purposes.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExchangeRate .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this exchange rate requires formal approval before being activated for use in financial transactions. True indicates approval workflow is required; false indicates rate can be used immediately upon publication.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'Username or identifier of the authorized user who approved this exchange rate for use in financial transactions. Nullable for rates that do not require approval. Supports audit trail and accountability.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorRequiredRateFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Required Rate Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this exchange rate is mandated by a specific donor or grant agreement. True indicates the rate must be used for specific donor reporting; false indicates it is a general organizational rate. Critical for grant compliance.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exchangeRateValue rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Value' ;
    rdfs:comment 'The numeric exchange rate value representing how many units of the target currency equal one unit of the source currency. For example, if USD to EUR rate is 0.85, then 1 USD equals 0.85 EUR. Stored with six decimal places for precision.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fromCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'From Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the source currency in the exchange rate pair (e.g., USD, EUR, GBP). The currency being converted from.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inverseRateValue rdf:type rdf:Property ;
    rdfs:label 'Inverse Rate Value' ;
    rdfs:comment 'The inverse of the exchange rate value, representing how many units of the source currency equal one unit of the target currency. Calculated as 1 divided by exchange_rate_value. Facilitates bidirectional currency conversions.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:midMarketRateFlag rdf:type rdf:Property ;
    rdfs:label 'Mid Market Rate Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this rate represents the mid-market rate (the midpoint between buy and sell rates). True indicates a neutral market rate without spread markup; false indicates a rate that may include transaction costs or spreads.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Rate Calculation Method' ;
    rdfs:comment 'Description of the methodology used to calculate or derive the exchange rate. For average rates, describes the averaging period and calculation approach. For budget rates, describes the forecasting methodology. Ensures transparency in rate determination.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePublicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rate Publication Timestamp' ;
    rdfs:comment 'The exact date and time when the exchange rate was officially published or released by the rate source. Provides precise temporal reference for rate validity and audit purposes.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'The authoritative source or provider of the exchange rate data. Examples include central banks (Federal Reserve, European Central Bank), commercial providers (OANDA, Bloomberg, Reuters), UN Operational Rates of Exchange, or internal treasury systems. Ensures traceability and auditability of rate origins.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSourceReference rdf:type rdf:Property ;
    rdfs:label 'Rate Source Reference' ;
    rdfs:comment 'External reference identifier or URL from the rate source system that can be used to verify or trace back to the original rate publication. Supports audit trail and compliance verification.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the exchange rate record. Active rates are currently in use, inactive rates are no longer valid, superseded rates have been replaced by newer rates, pending rates are awaiting approval, and draft rates are under preparation.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the exchange rate indicating its purpose and calculation method. Spot rates are real-time market rates, average rates are period averages, budget rates are planning rates, closing rates are end-of-period rates, forward rates are future-dated contracts, and historical rates are past reference rates.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revaluationRateFlag rdf:type rdf:Property ;
    rdfs:label 'Revaluation Rate Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this rate is designated for use in general ledger foreign currency revaluation processes. True indicates the rate should be used for balance sheet revaluation; false indicates it is for transactional purposes only.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spreadPercentage rdf:type rdf:Property ;
    rdfs:label 'Spread Percentage' ;
    rdfs:comment 'The percentage spread or markup applied to the base exchange rate to account for transaction costs, bank fees, or foreign exchange margins. Expressed as a decimal (e.g., 0.0150 for 1.5%). Nullable for rates without spreads.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'To Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the target currency in the exchange rate pair (e.g., USD, EUR, GBP). The currency being converted to.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unOperationalRateFlag rdf:type rdf:Property ;
    rdfs:label 'Un Operational Rate Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this rate is sourced from the United Nations Operational Rates of Exchange, commonly used by international NGOs and humanitarian organizations for standardized multi-currency reporting.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageContext rdf:type rdf:Property ;
    rdfs:label 'Usage Context' ;
    rdfs:comment 'Description of the specific business contexts or transaction types for which this exchange rate should be used. Examples include donor reporting, budget planning, accounts payable processing, grant financial statements, or general ledger revaluation. Provides guidance for appropriate rate application.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFromPriorRate rdf:type rdf:Property ;
    rdfs:label 'Variance From Prior Rate' ;
    rdfs:comment 'The absolute difference between this exchange rate value and the immediately preceding rate for the same currency pair and rate type. Facilitates trend analysis and identification of significant rate movements.' ;
    rdfs:domain ind:ExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The percentage change between this exchange rate and the immediately preceding rate for the same currency pair and rate type. Expressed as a decimal (e.g., 0.0250 for 2.5% increase). Supports volatility monitoring and financial risk assessment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentFundFinanceFundId rdf:type rdf:Property ;
    rdfs:label 'Parent Fund Finance Fund Id' ;
    rdfs:comment 'Reference to a parent fund if this fund is a sub-fund or component of a larger fund structure. Enables hierarchical fund accounting and roll-up reporting.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceFund .

ind:allowableCostCategories rdf:type rdf:Property ;
    rdfs:label 'Allowable Cost Categories' ;
    rdfs:comment 'Comma-separated list or description of cost categories that are allowable charges to this fund per donor restrictions or OMB Uniform Guidance. Guides expense posting and audit compliance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Required Flag' ;
    rdfs:comment 'Indicates whether this fund is subject to external audit requirements under OMB Uniform Guidance Single Audit provisions or donor-specific audit clauses.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total budgeted amount allocated to the fund for the current fiscal period. Used as the baseline for Budget versus Actual (BvA) variance analysis.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chartOfAccountsSegment rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Segment' ;
    rdfs:comment 'The fund dimension segment code in the organization\'s Chart of Accounts structure. Used for General Ledger posting and financial reporting in SAP S/4HANA.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Total amount committed through purchase orders, contracts, or other encumbrances but not yet expended. Used for fund availability calculations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expendedAmount rdf:type rdf:Property ;
    rdfs:label 'Expended Amount' ;
    rdfs:comment 'Total amount expended from the fund during the current fiscal period. Tracks actual spending against budget for BvA reporting.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'The date of the most recent external audit that included this fund. Used for audit cycle tracking and compliance monitoring.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReportDate rdf:type rdf:Property ;
    rdfs:label 'Last Report Date' ;
    rdfs:comment 'The date when the most recent financial report was submitted to the donor for this fund. Tracks reporting compliance and timeliness.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchFulfilledAmount rdf:type rdf:Property ;
    rdfs:label 'Match Fulfilled Amount' ;
    rdfs:comment 'The total amount of matching funds or in-kind contributions fulfilled to date. Tracked for grant reporting and compliance verification.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Match Requirement Percentage' ;
    rdfs:comment 'The percentage of matching funds or cost share required by the donor or grant agreement. Critical for tracking cost share commitments and compliance.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'The scheduled date for the next external audit covering this fund. Supports audit planning and documentation preparation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Report Due Date' ;
    rdfs:comment 'The due date for the next scheduled financial report to the donor. Critical for compliance and relationship management.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'The fund balance at the beginning of the current fiscal year or at fund inception. Represents the starting financial position for Budget versus Actual (BvA) tracking.' ;
    rdfs:domain ind:FinanceFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Detailed description of the intended use and purpose of the fund, including any donor-specified restrictions or programmatic objectives.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unallowableCostCategories rdf:type rdf:Property ;
    rdfs:label 'Unallowable Cost Categories' ;
    rdfs:comment 'Comma-separated list or description of cost categories that are explicitly unallowable for this fund. Prevents non-compliant expense posting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountDescription rdf:type rdf:Property ;
    rdfs:label 'Account Description' ;
    rdfs:comment 'Detailed business description of the GL account purpose, usage guidelines, and what types of transactions should be posted to this account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'The account group or category within the Chart of Accounts structure (e.g., \'Current Assets\', \'Fixed Assets\', \'Restricted Contributions\', \'Program Expenses\').' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOwner rdf:type rdf:Property ;
    rdfs:label 'Account Owner' ;
    rdfs:comment 'The name or identifier of the business owner or responsible party for this GL account (e.g., Finance Director, Program Manager, Grant Manager).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetControlFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Control Flag' ;
    rdfs:comment 'Indicates whether this account is subject to budget control and Budget versus Actual (BvA) monitoring. When true, transactions require budget availability checking before posting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coaStructureCode rdf:type rdf:Property ;
    rdfs:label 'Coa Structure Code' ;
    rdfs:comment 'The Chart of Accounts structure identifier or version code. Nonprofits may maintain multiple CoA structures for different legal entities or reporting requirements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account Number' ;
    rdfs:comment 'The GL account number used for consolidated financial reporting across multiple legal entities or country offices. Used when the nonprofit has a multi-entity structure.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationBaseFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Base Flag' ;
    rdfs:comment 'Indicates whether this account serves as an allocation base for distributing indirect costs across programs and grants (e.g., direct salaries, total direct costs).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:donorRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Restricted Flag' ;
    rdfs:comment 'Indicates whether this account tracks donor-restricted funds requiring specific usage compliance and separate reporting per donor agreements and FASB ASC 958.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReportingCode rdf:type rdf:Property ;
    rdfs:label 'External Reporting Code' ;
    rdfs:comment 'The mapping code used for external regulatory reporting (e.g., IRS Form 990 line item, IATI activity code, donor-specific reporting category).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementClassification rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Classification' ;
    rdfs:comment 'The primary financial statement where this account appears: balance sheet (statement of financial position), statement of activities (income statement equivalent for nonprofits), statement of functional expenses, statement of cash flows, or off-balance-sheet.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalExpenseCategory rdf:type rdf:Property ;
    rdfs:label 'Functional Expense Category' ;
    rdfs:comment 'The functional expense classification required by FASB ASC 958 for expense accounts: program services, management and general (administrative), fundraising, or not applicable (for non-expense accounts). Used for Form 990 reporting and functional expense allocation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundRestrictionClass rdf:type rdf:Property ;
    rdfs:label 'Fund Restriction Class' ;
    rdfs:comment 'The net asset restriction classification per FASB ASC 958: unrestricted (no donor restrictions), temporarily restricted (time or purpose restrictions), or permanently restricted (endowment principal). Critical for nonprofit fund accounting and donor compliance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Grant Eligible Flag' ;
    rdfs:comment 'Indicates whether expenses posted to this account are eligible for reimbursement under federal grants per OMB Uniform Guidance 2 CFR 200. Critical for grant financial management and cost allocation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indirectCostPoolFlag rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Pool Flag' ;
    rdfs:comment 'Indicates whether this account is part of the indirect cost pool for Negotiated Indirect Cost Rate Agreement (NICRA) calculations and Facilities and Administration (F&A) cost allocation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPostingDate rdf:type rdf:Property ;
    rdfs:label 'Last Posting Date' ;
    rdfs:comment 'The date of the most recent transaction posted to this GL account. Used for account activity monitoring and dormant account identification.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:naturalExpenseClassification rdf:type rdf:Property ;
    rdfs:label 'Natural Expense Classification' ;
    rdfs:comment 'The natural classification of expense by type (e.g., salaries, benefits, travel, supplies, professional fees, rent, utilities). Used alongside functional classification for comprehensive expense reporting per FASB ASC 958.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalBalanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Normal Balance Indicator' ;
    rdfs:comment 'Indicates whether this account normally carries a debit or credit balance per double-entry accounting principles.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Eligible Flag' ;
    rdfs:comment 'Indicates whether transactions can be directly posted to this account (true for detail accounts) or if it is a summary/roll-up account that only receives aggregated balances (false).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programServiceCode rdf:type rdf:Property ;
    rdfs:label 'Program Service Code' ;
    rdfs:comment 'The program or service line code that this account supports (e.g., WASH, Health, Education, Emergency Response). Used for program-level financial reporting and Monitoring Evaluation and Learning (MEL).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Flag' ;
    rdfs:comment 'Indicates whether this account requires regular reconciliation (e.g., bank accounts, accounts receivable, accounts payable control accounts). Used for internal control and audit compliance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdgAlignmentCode rdf:type rdf:Property ;
    rdfs:label 'Sdg Alignment Code' ;
    rdfs:comment 'The United Nations Sustainable Development Goal(s) that activities posted to this account contribute toward (e.g., SDG 1 - No Poverty, SDG 6 - Clean Water and Sanitation). Used for impact reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRelevanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Tax Relevance Indicator' ;
    rdfs:comment 'Indicates the tax treatment of transactions posted to this account: taxable income, non-taxable, tax-exempt per IRS 501(c)(3) regulations, or not applicable.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unrelatedBusinessIncomeFlag rdf:type rdf:Property ;
    rdfs:label 'Unrelated Business Income Flag' ;
    rdfs:comment 'Indicates whether revenue posted to this account constitutes Unrelated Business Income (UBI) subject to taxation under IRS regulations for tax-exempt organizations.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantBudgetId rdf:type rdf:Property ;
    rdfs:label 'Grant Budget Id' ;
    rdfs:comment 'Unique identifier for the grant budget record. Primary key for the grant budget entity in Unit4 ERP.' ;
    rdfs:domain ind:GrantBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetManagerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Budget Manager Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:GrantBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:approvedModificationCount rdf:type rdf:Property ;
    rdfs:label 'Approved Modification Count' ;
    rdfs:comment 'Number of approved budget modifications or amendments made since the original budget approval. Tracks budget revision history.' ;
    rdfs:domain ind:GrantBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Budget Approval Date' ;
    rdfs:comment 'Date when the grant budget was officially approved by the donor and became effective for expenditure authorization.' ;
    rdfs:domain ind:GrantBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'Classification of the budget by funding purpose and restriction type. Aligns with FASB ASC 958 net asset classification requirements.' ;
    rdfs:domain ind:GrantBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCloseoutDate rdf:type rdf:Property ;
    rdfs:label 'Budget Closeout Date' ;
    rdfs:comment 'Date when the grant budget was officially closed out after all financial reporting and reconciliation requirements were completed.' ;
    rdfs:domain ind:GrantBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetNotes rdf:type rdf:Property ;
    rdfs:label 'Budget Notes' ;
    rdfs:comment 'Additional notes, comments, or special instructions related to budget management, donor restrictions, or compliance requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Budget Period End Date' ;
    rdfs:comment 'End date of the budget period. Expenditures after this date may require prior approval or budget modification.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Budget Period Start Date' ;
    rdfs:comment 'Start date of the budget period during which approved funds may be obligated and expended.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Budget Submission Date' ;
    rdfs:comment 'Date when the grant budget was submitted to the donor for review and approval.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Version Number' ;
    rdfs:comment 'Version number of the budget document. Increments with each approved modification or amendment to maintain audit trail.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costShareAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Share Amount' ;
    rdfs:comment 'Required cost-sharing or matching contribution amount that the organization must provide from non-grant sources to meet donor requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Donor Reference Number' ;
    rdfs:comment 'External reference number or grant agreement number assigned by the donor organization (USAID, DFID, UN agency, private foundation).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icrRate rdf:type rdf:Property ;
    rdfs:label 'Icr Rate' ;
    rdfs:comment 'Percentage rate applied to calculate indirect costs. Expressed as a percentage of the direct cost base (e.g., 15.00 represents 15%).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMultiYear rdf:type rdf:Property ;
    rdfs:label 'Is Multi Year' ;
    rdfs:comment 'Indicates whether this budget spans multiple fiscal years (True) or is contained within a single fiscal year (False).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nicraRate rdf:type rdf:Property ;
    rdfs:label 'Nicra Rate' ;
    rdfs:comment 'Federally negotiated indirect cost rate established through a Negotiated Indirect Cost Rate Agreement (NICRA) with the cognizant federal agency. May differ from the ICR rate applied if donor caps indirect costs.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAwardAmount rdf:type rdf:Property ;
    rdfs:label 'Total Award Amount' ;
    rdfs:comment 'Total approved funding amount for the grant award. Represents the ceiling for all expenditures under this budget.' ;
    rdfs:domain ind:GrantBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique identifier for the journal entry record. Primary key for the journal entry entity.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:primaryJournalUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal User Account Id' ;
    rdfs:comment 'User ID of the person who posted this journal entry to the general ledger. Critical for audit trail, segregation of duties monitoring, and accountability.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:quaternaryJournalModifiedByUserUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Journal Modified By User User Account Id' ;
    rdfs:comment 'User ID of the person who last modified this journal entry. Null if entry has never been modified after creation. Supports change tracking and accountability.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:tertiaryJournalCreatedByUserUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Journal Created By User User Account Id' ;
    rdfs:comment 'User ID of the person who originally created this journal entry document. May differ from posting_user_id if entry creation and posting are performed by different individuals.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Additional free-text notes or comments added for audit trail purposes, explaining unusual circumstances, supporting documentation references, or special handling instructions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date the journal entry document was created or originated, which may differ from the posting date. Used for audit trail and document sequencing.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryDescription rdf:type rdf:Property ;
    rdfs:label 'Entry Description' ;
    rdfs:comment 'Detailed narrative description of the business purpose and nature of this journal entry. Provides context for financial reviewers, auditors, and future reference.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate applied to convert transaction currency amounts to the organization\'s functional currency (typically USD). Null for entries in functional currency. Critical for multi-currency grant financial management.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'Functional area classification (e.g., program services, management and general, fundraising) required for nonprofit functional expense reporting per FASB ASC 958. Supports Form 990 and donor reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 code for the organization\'s functional reporting currency. All journal entries are ultimately reported in this currency for consolidated financial statements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdjustment rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is a manual adjustment or correction entry (as opposed to a system-generated or routine operational entry). True for adjustments; false for standard entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInterCompany rdf:type rdf:Property ;
    rdfs:label 'Is Inter Company' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry represents an inter-company or inter-entity transaction requiring elimination in consolidated financial statements. True for inter-company entries; false otherwise.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'Ledger group or ledger type identifier (e.g., leading ledger, extension ledger, parallel accounting ledger) used in systems supporting multiple parallel accounting views. Supports GAAP and IFRS parallel reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'System-specific posting key code (from SAP or Unit4) that determines the account type (debit/credit) and controls which fields are required during entry. Technical control field for ERP posting logic.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle status of the journal entry in the approval and posting workflow. Tracks progression from draft creation through approval to final posting in the general ledger.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number linking this journal entry to source documents such as invoices, payment vouchers, grant agreements, or other originating transactions. Supports audit trail and source document traceability.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is a reversal of a previously posted entry. True if this entry reverses another entry; false otherwise.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the original journal entry that this entry reverses. Populated only when reversal_indicator is true. Maintains bidirectional audit trail for reversals.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for the journal entry line product.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalLineJournalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Original Line Journal Entry Line Id' ;
    rdfs:comment 'Reference to the original journal entry line ID that this line reverses or corrects. Null if this is not a reversal. Supports audit trail and error correction tracking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntryLine .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Reference to the vendor or supplier associated with this line item for accounts payable transactions. Supports vendor payment tracking and procurement compliance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:allowableCostFlag rdf:type rdf:Property ;
    rdfs:label 'Allowable Cost Flag' ;
    rdfs:comment 'Boolean indicator of whether this cost is allowable under the applicable grant or award terms per OMB Uniform Guidance. Used for grant financial compliance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The credit amount for this journal entry line in the functional currency. Null or zero if this is a debit line. Used for double-entry bookkeeping per GAAP.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'The debit amount for this journal entry line in the functional currency. Null or zero if this is a credit line. Used for double-entry bookkeeping per GAAP.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directCostFlag rdf:type rdf:Property ;
    rdfs:label 'Direct Cost Flag' ;
    rdfs:comment 'Boolean indicator of whether this line item represents a direct cost (true) or an indirect/overhead cost (false). Used for cost allocation and grant compliance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:donorRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Donor Restriction Type' ;
    rdfs:comment 'Classification of donor restrictions on the funds used in this line item per FASB ASC 958: unrestricted, temporarily restricted (time or purpose), or permanently restricted (endowment).' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Boolean indicator of whether this line item represents an intercompany or inter-entity transaction between organizational units or affiliated entities.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The vendor invoice number or internal invoice reference associated with this line item. Used for accounts payable reconciliation and audit trails.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Narrative description of the journal entry line item. Provides context and explanation for the transaction, supporting audit trails and financial transparency.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naturalAccountClassification rdf:type rdf:Property ;
    rdfs:label 'Natural Account Classification' ;
    rdfs:comment 'The natural classification of the expense by type of expenditure (e.g., salaries, benefits, travel, supplies). Complements functional expense reporting per FASB ASC 958. [ENUM-REF-CANDIDATE: salary|benefits|travel|supplies|equipment|occupancy|professional_services — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'The payment reference or check number associated with this line item for accounts payable or accounts receivable transactions. Supports cash reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'The profit center or revenue-generating unit associated with this line item. Used for revenue attribution and financial performance analysis by business unit.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Boolean indicator of whether this line item is a reversal or correction of a previous journal entry line. Used for audit trails and error correction tracking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'Reference to the source document or transaction that generated this journal entry line (e.g., invoice ID, payroll batch ID, grant disbursement ID). Supports audit trails.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax code or VAT code applicable to this line item. Used for tax compliance, reporting, and recovery in jurisdictions where the nonprofit operates.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nicraRateId rdf:type rdf:Property ;
    rdfs:label 'Nicra Rate Id' ;
    rdfs:comment 'Primary key for nicra_rate' ;
    rdfs:domain ind:NicraRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:administrativeRate rdf:type rdf:Property ;
    rdfs:label 'Administrative Rate' ;
    rdfs:comment 'The administrative component of the Facilities and Administration (F&A) rate, if the NICRA separates facilities and administrative costs. This rate covers general administration, departmental administration, and sponsored projects administration.' ;
    rdfs:domain ind:NicraRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'The current lifecycle status of the NICRA agreement. Draft indicates the agreement is being prepared; pending approval means it has been submitted to the cognizant agency; approved means the agency has accepted it; active means it is currently in effect; expired means the effective period has ended; superseded means a newer agreement has replaced it; terminated means it was cancelled before expiration. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|expired|superseded|terminated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carryforwardAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Carryforward Adjustment Amount' ;
    rdfs:comment 'The dollar amount of carryforward adjustment from prior periods that must be applied when using this rate. Carryforward adjustments occur when provisional rates differ from final rates, requiring reconciliation in subsequent periods.' ;
    rdfs:domain ind:NicraRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cognizantAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Cognizant Agency Code' ;
    rdfs:comment 'The code identifying the federal agency responsible for negotiating and approving this indirect cost rate agreement. Common cognizant agencies include USAID, HHS, USDA, and DOD. The cognizant agency is typically the agency providing the most federal funding to the organization.' ;
    rdfs:domain ind:NicraRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cognizantAgencyName rdf:type rdf:Property ;
    rdfs:label 'Cognizant Agency Name' ;
    rdfs:comment 'The full name of the federal agency responsible for negotiating and approving this indirect cost rate agreement (e.g., United States Agency for International Development, Department of Health and Human Services).' ;
    rdfs:domain ind:NicraRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deMinimisRateFlag rdf:type rdf:Property ;
    rdfs:label 'De Minimis Rate Flag' ;
    rdfs:comment 'Indicates whether this record represents the use of the de minimis indirect cost rate. Organizations that have never received a negotiated rate may elect to use a de minimis rate of 10% of Modified Total Direct Costs per OMB Uniform Guidance.' ;
    rdfs:domain ind:NicraRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'Document Reference Url' ;
    rdfs:comment 'URL or file path to the official NICRA agreement document. This provides direct access to the signed agreement for audit and compliance purposes.' ;
    rdfs:domain ind:NicraRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitiesRate rdf:type rdf:Property ;
    rdfs:label 'Facilities Rate' ;
    rdfs:comment 'The facilities component of the Facilities and Administration (F&A) rate, if the NICRA separates facilities and administrative costs. This rate covers depreciation, operations and maintenance, library, and other facility-related costs.' ;
    rdfs:domain ind:NicraRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fringeBenefitRate rdf:type rdf:Property ;
    rdfs:label 'Fringe Benefit Rate' ;
    rdfs:comment 'The negotiated fringe benefit rate expressed as a percentage, if included in the NICRA agreement. Fringe benefits are often negotiated alongside indirect cost rates and applied to salaries and wages to calculate total personnel costs.' ;
    rdfs:domain ind:NicraRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organizationalUnitCode rdf:type rdf:Property ;
    rdfs:label 'Organizational Unit Code' ;
    rdfs:comment 'The code identifying the organizational unit (division, department, or legal entity) to which this NICRA rate applies. Some organizations negotiate separate rates for different divisions or subsidiaries.' ;
    rdfs:domain ind:NicraRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationalUnitName rdf:type rdf:Property ;
    rdfs:label 'Organizational Unit Name' ;
    rdfs:comment 'The name of the organizational unit (division, department, or legal entity) to which this NICRA rate applies.' ;
    rdfs:domain ind:NicraRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCategory rdf:type rdf:Property ;
    rdfs:label 'Rate Category' ;
    rdfs:comment 'The functional category or pool to which this rate applies. Organizations may have multiple rate categories such as headquarters operations, field operations, research, or program-specific pools. This allows for different indirect cost rates for different types of activities.' ;
    rdfs:domain ind:NicraRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePercentage rdf:type rdf:Property ;
    rdfs:label 'Rate Percentage' ;
    rdfs:comment 'The negotiated indirect cost rate expressed as a percentage. This rate is applied to the applicable cost base to calculate allowable indirect cost recovery on federally-funded grants. For example, a rate of 15.50 means 15.50% of the base can be recovered as indirect costs.' ;
    rdfs:domain ind:NicraRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialRemarks rdf:type rdf:Property ;
    rdfs:label 'Special Remarks' ;
    rdfs:comment 'Free-text field capturing any special conditions, limitations, or instructions specified in the NICRA agreement. This may include restrictions on which grants the rate applies to, special calculation methods, or other agency-imposed conditions.' ;
    rdfs:domain ind:NicraRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successorAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Successor Agreement Number' ;
    rdfs:comment 'The agreement number of the subsequent NICRA that supersedes or replaces this agreement. Populated when a new rate is negotiated.' ;
    rdfs:domain ind:NicraRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payableId rdf:type rdf:Property ;
    rdfs:label 'Payable Id' ;
    rdfs:comment 'Primary key for payable' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payable .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Reference to the goods receipt document confirming delivery of goods or services. Used in three-way match process. Null if goods receipt not applicable.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'Identifier for the batch payment run in which this invoice was processed. Used for grouping payments and treasury operations.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Reference to the originating purchase order for three-way match validation (PO, goods receipt, invoice). Null for non-PO invoices.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date the invoice was approved for payment. Used for workflow tracking and compliance reporting. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'SAP clearing document number that closes the open payable item in the general ledger. Links invoice posting to payment posting for account reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Early payment discount or negotiated discount amount applied to the invoice. Reduces the net payable amount. In invoice currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Date the invoice was flagged as disputed. Used for vendor relationship management and dispute resolution tracking. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Payable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Reason code or description if the invoice is disputed (e.g., pricing discrepancy, quantity mismatch, quality issue). Null if not disputed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'Invoice net amount converted to the organization\'s functional currency using the exchange rate. Used for general ledger posting and financial reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Invoice Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the invoice is denominated (e.g., USD, EUR, GBP). Required for multi-currency operations and exchange rate tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date the vendor issued the invoice. Used to calculate payment terms and aging. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description of the goods or services covered by this invoice. Provides business context for the expenditure.' ;
    rdfs:domain ind:Payable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Gross Amount' ;
    rdfs:comment 'Total invoice amount before taxes and adjustments. Base amount for goods or services procured, in invoice currency.' ;
    rdfs:domain ind:Payable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceNetAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Net Amount' ;
    rdfs:comment 'Net payable amount after applying taxes, withholding tax, and discounts. This is the amount to be paid to the vendor. In invoice currency.' ;
    rdfs:domain ind:Payable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Received Date' ;
    rdfs:comment 'Date the invoice was received by the organization. Used for processing time tracking and internal controls. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Payable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isGrantEligible rdf:type rdf:Property ;
    rdfs:label 'Is Grant Eligible' ;
    rdfs:comment 'Flag indicating whether this expenditure is allowable and allocable to the associated grant per OMB Uniform Guidance cost principles. True if eligible, False if not.' ;
    rdfs:domain ind:Payable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Actual date the payment was disbursed to the vendor. Null if payment has not yet been made. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'System-generated payment document number or check number. Links the payable to the actual payment transaction for reconciliation and audit.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the payable invoice in the procure-to-pay process. Tracks progression from invoice receipt through payment disbursement. [ENUM-REF-CANDIDATE: open|scheduled|partially_paid|paid|disputed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Contractual payment terms agreed with the vendor (e.g., Net 30, Net 60, 2/10 Net 30). Determines due date calculation and early payment discount eligibility.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax amount charged on the invoice (VAT, sales tax, GST, etc.). In invoice currency. Used for tax reporting and compliance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way match validation comparing purchase order, goods receipt, and invoice. Matched status is required for automated payment approval per internal controls.' ;
    rdfs:domain ind:Payable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Amount of tax withheld at source per local tax regulations. Reduces the net payment to vendor. In invoice currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payablePaymentId rdf:type rdf:Property ;
    rdfs:label 'Payable Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts payable payment transaction. Primary key for the payable payment record.' ;
    rdfs:domain ind:PayablePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankTransactionId rdf:type rdf:Property ;
    rdfs:label 'Bank Transaction Id' ;
    rdfs:comment 'The unique transaction identifier assigned by the bank for this payment. Used for bank reconciliation and dispute resolution.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankTransaction .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which the payment cleared the bank and the funds were successfully transferred to the vendor. Used for cash reconciliation and liquidity management.' ;
    rdfs:domain ind:PayablePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isGrantFunded rdf:type rdf:Property ;
    rdfs:label 'Is Grant Funded' ;
    rdfs:comment 'Boolean flag indicating whether this payment is funded by a specific grant or donor award. Used for grant expenditure tracking and donor reporting.' ;
    rdfs:domain ind:PayablePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIndirectCost rdf:type rdf:Property ;
    rdfs:label 'Is Indirect Cost' ;
    rdfs:comment 'Boolean flag indicating whether this payment represents an indirect cost (Facilities and Administration) subject to the Negotiated Indirect Cost Rate Agreement (NICRA). Used for federal grant compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'The final net amount disbursed to the vendor after applying discounts, withholding taxes, and other adjustments. This is the actual cash outflow.' ;
    rdfs:domain ind:PayablePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The total gross amount of the payment in the payment currency before any adjustments or deductions. This is the principal monetary value of the disbursement.' ;
    rdfs:domain ind:PayablePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the payment transaction (e.g., USD, EUR, GBP). Supports multi-currency operations in international humanitarian programs.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Description' ;
    rdfs:comment 'A detailed description of the purpose or nature of the payment. Provides context for financial reporting, audit, and grant compliance.' ;
    rdfs:domain ind:PayablePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the payment by its business purpose or recipient category. Distinguishes between vendor payments, partner disbursements, grant advances, staff reimbursements, and other payment types. [ENUM-REF-CANDIDATE: vendor_payment|partner_payment|grant_advance|reimbursement|petty_cash|salary|consultant_fee — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PayablePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivableId rdf:type rdf:Property ;
    rdfs:label 'Receivable Id' ;
    rdfs:comment 'Primary key for receivable' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Receivable .

ind:agingDays rdf:type rdf:Property ;
    rdfs:label 'Aging Days' ;
    rdfs:comment 'Number of days the receivable has been outstanding since the invoice date, used for aging analysis and collection prioritization.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allowanceForDoubtfulAccounts rdf:type rdf:Property ;
    rdfs:label 'Allowance For Doubtful Accounts' ;
    rdfs:comment 'Estimated amount of this receivable that may not be collectible, supporting the contra-asset allowance account per GAAP.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Bank account number into which the payment was deposited, supporting cash reconciliation and treasury management.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'Email address of the billing contact at the payer organization for invoice delivery and payment coordination.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactName rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Name' ;
    rdfs:comment 'Name of the contact person at the payer organization responsible for processing and approving payment of this invoice.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Phone' ;
    rdfs:comment 'Phone number of the billing contact at the payer organization for follow-up on payment status and dispute resolution.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDescription rdf:type rdf:Property ;
    rdfs:label 'Billing Description' ;
    rdfs:comment 'Narrative description of the goods, services, or grant deliverables for which this invoice was issued to the payer.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Reference' ;
    rdfs:comment 'Reference to the clearing document in SAP S/4HANA or Unit4 ERP that applied the payment to this receivable invoice.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current status of the receivable in the collection lifecycle, tracking progress from issuance through final resolution.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Deposit Confirmation Number' ;
    rdfs:comment 'Bank-provided confirmation or transaction number for the deposit, enabling bank reconciliation and audit trail.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicator of whether the payer has disputed this invoice, triggering special handling and resolution processes.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which the invoice dispute was resolved, allowing the receivable to return to normal collection status.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Amount' ;
    rdfs:comment 'Total amount billed on the invoice in the invoice currency, representing the full receivable value at issuance.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'Method by which the invoice was delivered to the payer (e.g., email, postal mail, electronic portal).' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceSentDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Sent Date' ;
    rdfs:comment 'Date on which the invoice was sent or delivered to the payer, establishing the start of the payment terms period.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReminderDate rdf:type rdf:Property ;
    rdfs:label 'Last Reminder Date' ;
    rdfs:comment 'Date on which the most recent payment reminder or collection notice was sent to the payer.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the user who last modified this receivable invoice record, supporting accountability and audit trail.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Current unpaid balance remaining on the invoice after applying all receipts, adjustments, and write-offs.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date on which payment was received from the payer, marking the cash receipt event for this receivable.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Document Number' ;
    rdfs:comment 'Internal document number or reference assigned to the cash receipt transaction in the financial system.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptMethod rdf:type rdf:Property ;
    rdfs:label 'Receipt Method' ;
    rdfs:comment 'Method or instrument by which payment was received from the payer (e.g., wire transfer, check, ACH, online payment).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue associated with this receivable was recognized in the general ledger per FASB ASC 958 revenue recognition principles.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivableReceiptId rdf:type rdf:Property ;
    rdfs:label 'Receivable Receipt Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable cash receipt transaction. Primary key for the receivable receipt record.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'The check number if the receipt method is check. Used for tracking and reconciliation of paper-based payments.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Date' ;
    rdfs:comment 'The date when funds were physically deposited into the bank account. Used for bank reconciliation and cash flow analysis.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorRestrictionPurpose rdf:type rdf:Property ;
    rdfs:label 'Donor Restriction Purpose' ;
    rdfs:comment 'Description of the donor-imposed restriction on the use of funds (e.g., specific program, geographic area, or time period). Critical for restricted fund compliance.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingReference rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Reference' ;
    rdfs:comment 'Reference to the general ledger journal entry or posting document created for this receipt. Links AR receipt to GL for financial statement preparation.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantDrawdownRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Drawdown Request Number' ;
    rdfs:comment 'Reference to the grant drawdown or reimbursement request submitted to the donor or government agency. Links receipt to the originating funding request for compliance tracking.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isInKindConversion rdf:type rdf:Property ;
    rdfs:label 'Is In Kind Conversion' ;
    rdfs:comment 'Indicates whether this cash receipt represents the monetization or conversion of a previously recorded in-kind donation (e.g., sale of donated goods).' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMatchingGift rdf:type rdf:Property ;
    rdfs:label 'Is Matching Gift' ;
    rdfs:comment 'Indicates whether this receipt is a matching gift from a corporate donor or foundation matching an individual donor\'s contribution.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRefund rdf:type rdf:Property ;
    rdfs:label 'Is Refund' ;
    rdfs:comment 'Indicates whether this receipt is a refund or return of funds previously disbursed (e.g., sub-grantee returning unused funds, vendor refund).' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payerReference rdf:type rdf:Property ;
    rdfs:label 'Payer Reference' ;
    rdfs:comment 'External reference or remittance information provided by the payer (donor, government agency, or sub-grantee) to identify the purpose of the payment.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptAmount rdf:type rdf:Property ;
    rdfs:label 'Receipt Amount' ;
    rdfs:comment 'The total amount of cash received in the receipt currency. This is the gross amount before any adjustments or allocations.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptChannel rdf:type rdf:Property ;
    rdfs:label 'Receipt Channel' ;
    rdfs:comment 'The interface or channel through which the payment was received (e.g., bank transfer, mail, online donor portal, mobile app, in-person at field office).' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Receipt Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the payment was received (e.g., USD, EUR, GBP). Critical for multi-currency grant management.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the cash receipt in the accounts receivable workflow. Tracks progression from initial entry through final reconciliation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireTransferReference rdf:type rdf:Property ;
    rdfs:label 'Wire Transfer Reference' ;
    rdfs:comment 'Bank wire transfer reference number or SWIFT message identifier for electronic fund transfers. Used for high-value grant drawdowns and major gifts.' ;
    rdfs:domain ind:ReceivableReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advancePaymentAllowed rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Allowed' ;
    rdfs:comment 'Indicates whether the donor allows advance payments or if reimbursement-only is required.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agreementSignedDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Signed Date' ;
    rdfs:comment 'The date on which the award agreement was signed by both the donor and the NGO.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'The total number of amendments or modifications made to the original award agreement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Audit Threshold Amount' ;
    rdfs:comment 'The expenditure threshold that triggers audit requirements under this award.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedAmount rdf:type rdf:Property ;
    rdfs:label 'Authorized Amount' ;
    rdfs:comment 'The maximum amount authorized for expenditure under this award, which may differ from the obligated amount due to amendments or modifications.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardNumber rdf:type rdf:Property ;
    rdfs:label 'Award Number' ;
    rdfs:comment 'The externally-known unique award number assigned by the donor or funding agency. This is the official reference number used in all donor communications and reporting.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardStatus rdf:type rdf:Property ;
    rdfs:label 'Award Status' ;
    rdfs:comment 'Current lifecycle status of the award: pipeline (anticipated), active (in execution), no-cost extension (extended without additional funds), suspended, or closed.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardType rdf:type rdf:Property ;
    rdfs:label 'Award Type' ;
    rdfs:comment 'The classification of the funding mechanism: cooperative agreement, contract, grant, sub-award, consortium lead, or consortium member.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandingMarkingRequirements rdf:type rdf:Property ;
    rdfs:label 'Branding Marking Requirements' ;
    rdfs:comment 'Donor-specific requirements for branding, marking, and visibility of donor support in program materials and communications.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the award amount is denominated.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateToFunctional rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate To Functional' ;
    rdfs:comment 'The exchange rate used to convert the award currency to the NGO\'s functional currency for accounting purposes.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Functional Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code of the NGO\'s functional currency for financial reporting.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingMechanism rdf:type rdf:Property ;
    rdfs:label 'Funding Mechanism' ;
    rdfs:comment 'The specific funding instrument or mechanism used by the donor (e.g., bilateral grant, multilateral pooled fund, emergency response fund).' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indirectCostCeiling rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Ceiling' ;
    rdfs:comment 'The maximum indirect cost rate allowed by the donor for this award, expressed as a decimal.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'The date of the most recent amendment or modification to the award agreement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nicraIcrRate rdf:type rdf:Property ;
    rdfs:label 'Nicra Icr Rate' ;
    rdfs:comment 'The negotiated indirect cost rate applicable to this award, expressed as a decimal (e.g., 0.1500 for 15%).' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalEndDate rdf:type rdf:Property ;
    rdfs:label 'Original End Date' ;
    rdfs:comment 'The original end date specified in the initial award agreement, before any no-cost extensions or amendments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodOfPerformanceMonths rdf:type rdf:Property ;
    rdfs:label 'Period Of Performance Months' ;
    rdfs:comment 'The total duration of the award period of performance expressed in months.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Primary Country Code' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country code for the primary country of implementation.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Any special conditions, restrictions, or requirements imposed by the donor on this award.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thematicSector rdf:type rdf:Property ;
    rdfs:label 'Thematic Sector' ;
    rdfs:comment 'The primary thematic sector or focus area of the award (e.g., WASH, health, education, protection, food security).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalObligatedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Obligated Amount' ;
    rdfs:comment 'The total amount of funds obligated by the donor under this award in the award currency.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalObligatedAmountFunctional rdf:type rdf:Property ;
    rdfs:label 'Total Obligated Amount Functional' ;
    rdfs:comment 'The total obligated amount converted to the NGO\'s functional currency using the exchange rate.' ;
    rdfs:domain ind:Award ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardBudgetId rdf:type rdf:Property ;
    rdfs:label 'Award Budget Id' ;
    rdfs:comment 'Unique identifier for the award budget record. Primary key.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AwardBudget .

ind:grantAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Grant Amendment Id' ;
    rdfs:comment 'Foreign key linking to grant.grant_amendment. Business justification: Budget revisions are often triggered by grant amendments. award_budget has is_amendment flag, amendment_date, and amendment_reason, but no FK to the actual amendment record. Adding amendment_id links ' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GrantAmendment .

ind:awardCurrency rdf:type rdf:Property ;
    rdfs:label 'Award Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the budget is denominated (e.g., USD, EUR, GBP). This is the donor-facing currency.' ;
    rdfs:domain ind:AwardBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNarrativeReference rdf:type rdf:Property ;
    rdfs:label 'Budget Narrative Reference' ;
    rdfs:comment 'Reference identifier or document location for the detailed budget narrative that explains and justifies each budget line item. Typically a document management system reference.' ;
    rdfs:domain ind:AwardBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPeriod rdf:type rdf:Property ;
    rdfs:label 'Budget Period' ;
    rdfs:comment 'The budget period this budget covers, typically expressed as Year 1, Year 2, etc., or Period 1, Period 2, etc., or Full Award Period for multi-year consolidated budgets.' ;
    rdfs:domain ind:AwardBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractualCosts rdf:type rdf:Property ;
    rdfs:label 'Contractual Costs' ;
    rdfs:comment 'Approved budget for sub-awards to implementing partners and consultant fees.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Donor Approval Date' ;
    rdfs:comment 'The date the donor officially approved this budget version.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Donor Approval Reference' ;
    rdfs:comment 'Reference number or document identifier for the donors formal approval of this budget (e.g., award letter number, amendment approval letter).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCosts rdf:type rdf:Property ;
    rdfs:label 'Equipment Costs' ;
    rdfs:comment 'Approved budget for equipment purchases (typically items with acquisition cost of $5,000 or more and useful life of more than one year, per donor definition).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fringeBenefitsCosts rdf:type rdf:Property ;
    rdfs:label 'Fringe Benefits Costs' ;
    rdfs:comment 'Approved budget for fringe benefits associated with personnel costs (health insurance, retirement, payroll taxes, etc.).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indirectCostBase rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Base' ;
    rdfs:comment 'The cost base to which the NICRA rate is applied. Common bases include Modified Total Direct Costs (MTDC), Total Direct Costs, or Salaries and Wages.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAmendment rdf:type rdf:Property ;
    rdfs:label 'Is Amendment' ;
    rdfs:comment 'Flag indicating whether this budget version is an amendment to a previously approved budget (True) or the original budget (False).' ;
    rdfs:domain ind:AwardBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nicraRateApplied rdf:type rdf:Property ;
    rdfs:label 'Nicra Rate Applied' ;
    rdfs:comment 'The indirect cost rate (expressed as a percentage) applied to calculate F&A costs. This is the rate from the organizations NICRA with the cognizant federal agency.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDirectCosts rdf:type rdf:Property ;
    rdfs:label 'Other Direct Costs' ;
    rdfs:comment 'Approved budget for other direct costs not classified in standard categories (e.g., communications, rent, utilities, participant support costs).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:personnelCosts rdf:type rdf:Property ;
    rdfs:label 'Personnel Costs' ;
    rdfs:comment 'Approved budget for salaries and wages of staff directly working on the grant.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preparedBy rdf:type rdf:Property ;
    rdfs:label 'Prepared By' ;
    rdfs:comment 'Name or identifier of the staff member who prepared this budget version.' ;
    rdfs:domain ind:AwardBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppliesCosts rdf:type rdf:Property ;
    rdfs:label 'Supplies Costs' ;
    rdfs:comment 'Approved budget for supplies and consumables used in grant activities (items below equipment threshold).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalApprovedBudget rdf:type rdf:Property ;
    rdfs:label 'Total Approved Budget' ;
    rdfs:comment 'The total approved budget amount for this budget period in the award currency. Sum of all direct and indirect costs.' ;
    rdfs:domain ind:AwardBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDirectCosts rdf:type rdf:Property ;
    rdfs:label 'Total Direct Costs' ;
    rdfs:comment 'Sum of all direct cost categories (personnel, fringe, travel, equipment, supplies, contractual, other direct costs) approved for this budget period.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalIndirectCosts rdf:type rdf:Property ;
    rdfs:label 'Total Indirect Costs' ;
    rdfs:comment 'Total indirect costs (Facilities and Administration / F&A) approved for this budget period. Calculated by applying the NICRA rate to the approved direct cost base.' ;
    rdfs:domain ind:AwardBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelCosts rdf:type rdf:Property ;
    rdfs:label 'Travel Costs' ;
    rdfs:comment 'Approved budget for domestic and international travel expenses directly related to grant activities.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardBudgetLineId rdf:type rdf:Property ;
    rdfs:label 'Award Budget Line Id' ;
    rdfs:comment 'Unique identifier for the award budget line item. Primary key for this entity.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financeBudgetLineId rdf:type rdf:Property ;
    rdfs:label 'Finance Budget Line Id' ;
    rdfs:comment 'Foreign key linking to finance.budget_line. Business justification: Award budget line items must link to finance budget lines for detailed expenditure tracking, budget-to-actual variance reporting, and grant financial statement preparation. Nonprofits track grant budg' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetLine .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: NGOs allocate grant budget lines to specific authorized positions for personnel cost tracking, effort certification, and donor reporting on staffing costs. Essential for grant budget execution and com' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:allocabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Allocability Flag' ;
    rdfs:comment 'Indicates whether costs charged to this budget line are allocable to the grant award in accordance with relative benefits received, per OMB Uniform Guidance 2 CFR 200.405.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Allowability Flag' ;
    rdfs:comment 'Indicates whether this budget line item is allowable under applicable donor regulations (OMB Uniform Guidance 2 CFR 200 Subpart E, USAID ADS). True if allowable; False if unallowable or requires special approval.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Original approved budget amount for this line item as authorized in the initial grant award agreement.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Approved Amount Usd' ;
    rdfs:comment 'Approved budget amount converted to United States Dollars for standardized reporting and analysis.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costShareRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Share Required Flag' ;
    rdfs:comment 'Indicates whether this budget line requires cost sharing or matching funds from the organization or other non-federal sources, per donor agreement terms.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costSubcategory rdf:type rdf:Property ;
    rdfs:label 'Cost Subcategory' ;
    rdfs:comment 'Secondary classification providing granular detail within the cost category (e.g., international travel, local travel, office supplies, medical supplies).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeExpenditure rdf:type rdf:Property ;
    rdfs:label 'Cumulative Expenditure' ;
    rdfs:comment 'Total actual expenditure incurred against this budget line from award inception through the current reporting period.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeExpenditureUsd rdf:type rdf:Property ;
    rdfs:label 'Cumulative Expenditure Usd' ;
    rdfs:comment 'Cumulative expenditure converted to United States Dollars for standardized variance analysis and donor reporting.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Donor Reporting Category' ;
    rdfs:comment 'Donor-specific classification or reporting code required for financial reports submitted to the funding agency (e.g., BHA, USAID, DFID, CERF).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indirectCostAmount rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Amount' ;
    rdfs:comment 'Calculated indirect cost (facilities and administration) amount allocated to this budget line based on the applied NICRA rate.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineItemCode rdf:type rdf:Property ;
    rdfs:label 'Line Item Code' ;
    rdfs:comment 'Unique alphanumeric code identifying this budget line within the award budget structure, often aligned with donor or organizational chart of accounts.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonablenessFlag rdf:type rdf:Property ;
    rdfs:label 'Reasonableness Flag' ;
    rdfs:comment 'Indicates whether the budgeted amount is reasonable and does not exceed what a prudent person would incur under similar circumstances, per OMB Uniform Guidance 2 CFR 200.404.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisedAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Revised Amount Usd' ;
    rdfs:comment 'Revised budget amount converted to United States Dollars. Null if no revisions have occurred.' ;
    rdfs:domain ind:AwardBudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Date of the most recent budget revision or amendment affecting this line item. Null if no revisions have occurred.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier or file path to supporting documentation for this budget line (e.g., quotes, justifications, donor correspondence).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costShareCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Cost Share Commitment Id' ;
    rdfs:comment 'Unique identifier for the cost-share commitment record. Primary key.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inkindDonationId rdf:type rdf:Property ;
    rdfs:label 'Inkind Donation Id' ;
    rdfs:comment 'Foreign key linking to supply.inkind_donation. Business justification: Cost share commitments are frequently satisfied through in-kind donations. NGOs must track which specific donations fulfill which cost share obligations for donor compliance reporting, audit verificat' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InkindDonation .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the individual who approved the cost-share commitment or verification.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByTitle rdf:type rdf:Property ;
    rdfs:label 'Approved By Title' ;
    rdfs:comment 'Job title or role of the individual who approved the cost-share commitment or verification.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingReference rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Reference' ;
    rdfs:comment 'Reference to any audit findings or observations related to this cost-share commitment, if applicable.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentNotes rdf:type rdf:Property ;
    rdfs:label 'Commitment Notes' ;
    rdfs:comment 'Additional notes, comments, or context regarding this cost-share commitment, including any special conditions or donor instructions.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Reference Number' ;
    rdfs:comment 'External reference number or code assigned to this cost-share commitment for tracking and reporting purposes.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the cost-share commitment: planned (identified but not yet committed), committed (formally committed), verified (documentation complete and approved), partially_verified (some verification complete), non_compliant (commitment not met), or waived (donor waived requirement).' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costShareSourceDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Share Source Description' ;
    rdfs:comment 'Detailed description of the source of the cost-share contribution, including the contributing organization, department, or funding stream.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costShareType rdf:type rdf:Property ;
    rdfs:label 'Cost Share Type' ;
    rdfs:comment 'Type of cost-share contribution: cash (direct monetary contribution), in-kind (goods or services), third-party (contributions from external partners), or volunteer (volunteer time and services).' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inKindValuationMethod rdf:type rdf:Property ;
    rdfs:label 'In Kind Valuation Method' ;
    rdfs:comment 'Method used to value in-kind contributions (e.g., fair market value, independent appraisal, standard volunteer rate, depreciated asset value). Applicable only when cost_share_type is in-kind.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this cost-share commitment is mandatory per the grant agreement (true) or voluntary (false).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredCostShareAmount rdf:type rdf:Property ;
    rdfs:label 'Required Cost Share Amount' ;
    rdfs:comment 'Total cost-share amount required by the donor as a condition of the grant award, expressed in the grant currency.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredCostSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Required Cost Share Percentage' ;
    rdfs:comment 'Required cost-share expressed as a percentage of total project costs (e.g., 25.00 for 25% match requirement).' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Source Organization Name' ;
    rdfs:comment 'Name of the organization providing the cost-share contribution (may be the NGO itself, a partner, or a third-party donor).' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedAmount rdf:type rdf:Property ;
    rdfs:label 'Verified Amount' ;
    rdfs:comment 'Amount of cost-share that has been verified through documentation and approved by the donor or auditor, expressed in the grant currency.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volunteerHourlyRate rdf:type rdf:Property ;
    rdfs:label 'Volunteer Hourly Rate' ;
    rdfs:comment 'Standard hourly rate used to value volunteer time for cost-share purposes. Applicable only when cost_share_type is volunteer.' ;
    rdfs:domain ind:CostShareCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volunteerHours rdf:type rdf:Property ;
    rdfs:label 'Volunteer Hours' ;
    rdfs:comment 'Total number of volunteer hours contributed as part of this cost-share commitment. Applicable only when cost_share_type is volunteer.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorConditionId rdf:type rdf:Property ;
    rdfs:label 'Donor Condition Id' ;
    rdfs:comment 'Unique identifier for the donor condition record. Primary key for the donor_condition data product.' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'The entity or role that has the authority to approve or waive this condition (e.g., \'Donor Grants Officer\', \'Chief Financial Officer\', \'USAID Agreement Officer\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Reference Number' ;
    rdfs:comment 'Reference number or identifier for the formal approval document or communication (e.g., approval letter number, email reference).' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionCategory rdf:type rdf:Property ;
    rdfs:label 'Condition Category' ;
    rdfs:comment 'Broader categorization of the condition by functional area. Values: financial (budget, cost, financial reporting), programmatic (deliverables, milestones, beneficiary targets), administrative (staffing, procurement, subcontracting), compliance (regulatory, legal, policy adherence), safeguarding (protection, GBV prevention, child safeguarding), environmental (environmental impact, WASH standards).' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Condition Reference Number' ;
    rdfs:comment 'Externally-known unique identifier or code assigned to this donor condition by the donor or grant management system (e.g., SAC-2024-001, COND-BHA-45).' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionTitle rdf:type rdf:Property ;
    rdfs:label 'Condition Title' ;
    rdfs:comment 'Short, human-readable title or summary of the donor condition (e.g., \'Quarterly Financial Report Submission\', \'Prior Approval for Subawards Over $100K\').' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'Classification of the donor condition indicating the nature of the compliance obligation. Values: prior_approval_requirement (donor must approve before action), restricted_cost (specific cost category restrictions), reporting_obligation (scheduled or ad-hoc reporting requirement), key_personnel_approval (approval required for key staff changes), branding_marking_requirement (logo, attribution, visibility requirements), audit_requirement (financial or programmatic audit mandate).' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverable Description' ;
    rdfs:comment 'Detailed description of the specific deliverable, report, approval, or action required to satisfy this condition.' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Threshold Amount' ;
    rdfs:comment 'Monetary threshold associated with this condition (e.g., prior approval required for subawards exceeding $100,000). Null if the condition does not have a financial threshold.' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialThresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Threshold Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial threshold amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSpecialAwardCondition rdf:type rdf:Property ;
    rdfs:label 'Is Special Award Condition' ;
    rdfs:comment 'Boolean flag indicating whether this condition is a Special Award Condition (SAC) imposed by the donor due to identified risks or past performance issues. True if this is a SAC, False otherwise.' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'How frequently the organization monitors progress toward meeting this condition. Values: daily, weekly, monthly, quarterly, as_needed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRecurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Next Recurrence Date' ;
    rdfs:comment 'For recurring conditions, the date of the next scheduled occurrence or deadline. Null for one-time conditions.' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recurrenceFrequency rdf:type rdf:Property ;
    rdfs:label 'Recurrence Frequency' ;
    rdfs:comment 'Indicates whether this condition is a one-time requirement or recurs on a regular schedule. Values: one_time (single occurrence), monthly, quarterly, semi_annually, annually, as_needed (triggered by specific events).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'Reference to the specific regulatory or policy section that mandates or governs this condition (e.g., \'2 CFR 200.308\', \'USAID ADS 303.3.10\', \'DFID Smart Rule 4.2.3\').' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sacJustification rdf:type rdf:Property ;
    rdfs:label 'Sac Justification' ;
    rdfs:comment 'Narrative explanation provided by the donor for why this Special Award Condition was imposed, including any identified risks or deficiencies.' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Date' ;
    rdfs:comment 'The date on which the donor formally waived this condition. Null if the condition was not waived.' ;
    rdfs:domain ind:DonorCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorReportId rdf:type rdf:Property ;
    rdfs:label 'Donor Report Id' ;
    rdfs:comment 'Unique identifier for the donor report submission record. Primary key.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DonorReport .

ind:auditFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Audit Findings Count' ;
    rdfs:comment 'Number of audit findings or compliance issues identified by internal or external auditors related to this reporting period, if applicable.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiariesReached rdf:type rdf:Property ;
    rdfs:label 'Beneficiaries Reached' ;
    rdfs:comment 'Total number of unique beneficiaries or persons of concern (PoC) reached or served during the reporting period, as reported to the donor.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Amount' ;
    rdfs:comment 'The difference between the budgeted amount and the actual expenditure for the reporting period, calculated as actual minus budget (positive indicates overspend, negative indicates underspend).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Percentage' ;
    rdfs:comment 'The budget variance expressed as a percentage of the budgeted amount, calculated as (actual - budget) / budget * 100.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Flag' ;
    rdfs:comment 'Boolean flag indicating whether the responsible staff member has certified that this report complies with all donor requirements, grant terms, and applicable regulations (True = certified, False = not certified).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulativeExpenditureToDate rdf:type rdf:Property ;
    rdfs:label 'Cumulative Expenditure To Date' ;
    rdfs:comment 'Total cumulative expenditure reported to the donor from the grant start date through the end of this reporting period.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of calendar days by which the report submission was late, calculated as submission date minus due date. Null or zero if submitted on time.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:donorAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Donor Acceptance Date' ;
    rdfs:comment 'The date on which the donor formally accepted or approved this report submission, marking it as satisfactory and compliant.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorFeedbackSummary rdf:type rdf:Property ;
    rdfs:label 'Donor Feedback Summary' ;
    rdfs:comment 'Summary of feedback, comments, or recommendations provided by the donor in response to this report submission.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateUsed rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Used' ;
    rdfs:comment 'The foreign exchange rate applied to convert the reported financial amount from the grant currency to USD, if applicable.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialAmountReported rdf:type rdf:Property ;
    rdfs:label 'Financial Amount Reported' ;
    rdfs:comment 'Total financial expenditure or disbursement amount reported to the donor for the reporting period, in the grant currency.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialAmountReportedUsd rdf:type rdf:Property ;
    rdfs:label 'Financial Amount Reported Usd' ;
    rdfs:comment 'Total financial expenditure or disbursement amount reported to the donor, converted to United States Dollars (USD) for standardized reporting and analysis.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial amounts reported in this donor report (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFinalVersion rdf:type rdf:Property ;
    rdfs:label 'Is Final Version' ;
    rdfs:comment 'Boolean flag indicating whether this version of the donor report is the final, accepted version (True) or an interim/draft version (False).' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverdue rdf:type rdf:Property ;
    rdfs:label 'Is Overdue' ;
    rdfs:comment 'Boolean flag indicating whether this donor report was submitted after its due date (True = overdue, False = submitted on time or not yet due).' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyPerformanceIndicatorsMet rdf:type rdf:Property ;
    rdfs:label 'Key Performance Indicators Met' ;
    rdfs:comment 'Number of Key Performance Indicators (KPIs) or LogFrame indicators that met or exceeded their targets during the reporting period.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:keyPerformanceIndicatorsTotal rdf:type rdf:Property ;
    rdfs:label 'Key Performance Indicators Total' ;
    rdfs:comment 'Total number of Key Performance Indicators (KPIs) or LogFrame indicators being tracked and reported for this grant during the reporting period.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:narrativeSummary rdf:type rdf:Property ;
    rdfs:label 'Narrative Summary' ;
    rdfs:comment 'Textual summary of programmatic activities, achievements, challenges, and lessons learned during the reporting period, as required by the donor.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNotes rdf:type rdf:Property ;
    rdfs:label 'Report Notes' ;
    rdfs:comment 'Free-text field for internal notes, special circumstances, or additional context related to this donor report submission.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Report Reference Number' ;
    rdfs:comment 'Externally-known unique identifier or tracking number for this donor report submission, often assigned by the donor or grant management system.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the donor report by its purpose and format, such as SF-425 Federal Financial Report, quarterly programmatic report, annual narrative, situation report (SitRep), final closeout report, or IATI transparency disclosure.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionRequestedDate rdf:type rdf:Property ;
    rdfs:label 'Revision Requested Date' ;
    rdfs:comment 'The date on which the donor requested revisions or additional information for this report, if applicable.' ;
    rdfs:domain ind:DonorReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version number of this donor report submission, incremented each time a revised version is submitted (e.g., 1 for initial submission, 2 for first revision).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRequirement rdf:type rdf:Property ;
    rdfs:label 'Audit Requirement' ;
    rdfs:comment 'The type of audit required by the donor for grants funded by this source. Single audit refers to OMB Uniform Guidance 2 CFR 200 Subpart F audits; program-specific audit refers to audits of individual programs; financial audit refers to organization-wide financial statement audits; no audit required indicates the donor does not mandate an audit.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetFlexibility rdf:type rdf:Property ;
    rdfs:label 'Budget Flexibility' ;
    rdfs:comment 'Classification of the degree of budget flexibility allowed by the donor for grants funded by this source. Fixed budgets require donor approval for any changes; flexible within categories allows reallocation within cost categories; flexible with approval allows reallocation with prior donor consent; fully flexible allows unrestricted reallocation.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetRevisionThreshold rdf:type rdf:Property ;
    rdfs:label 'Budget Revision Threshold' ;
    rdfs:comment 'The percentage threshold (expressed as a decimal, e.g., 0.1000 for 10%) above which budget revisions or reallocations require prior donor approval. Null if no threshold applies.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closeoutPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Closeout Period Days' ;
    rdfs:comment 'The number of calendar days after the grant end date within which all closeout activities (final reports, financial reconciliation, asset disposition) must be completed for grants funded by this source.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactPersonName rdf:type rdf:Property ;
    rdfs:label 'Contact Person Name' ;
    rdfs:comment 'The name of the primary contact person at the donor organization responsible for this funding source. Used for relationship management and grant administration inquiries.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingEndDate rdf:type rdf:Property ;
    rdfs:label 'Funding End Date' ;
    rdfs:comment 'The date on which this funding source expires or is no longer available for new grant awards. Represents the end of the funding period. Nullable for open-ended funding sources.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundingMechanismType rdf:type rdf:Property ;
    rdfs:label 'Funding Mechanism Type' ;
    rdfs:comment 'Classification of the funding mechanism through which resources are provided. Distinguishes between Official Development Assistance (ODA) bilateral and multilateral channels, foundation grants, corporate philanthropy, Central Emergency Response Fund (CERF) pooled funds, government contracts, private donations, and endowment income. [ENUM-REF-CANDIDATE: oda_bilateral|oda_multilateral|foundation_grant|corporate_philanthropy|cerf_pooled_fund|government_contract|private_donation|endowment_income — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSourceCode rdf:type rdf:Property ;
    rdfs:label 'Funding Source Code' ;
    rdfs:comment 'The unique alphanumeric code or identifier assigned to this funding source by the donor organization or internal grant management system for tracking and reporting purposes.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSourceDescription rdf:type rdf:Property ;
    rdfs:label 'Funding Source Description' ;
    rdfs:comment 'Detailed narrative description of the funding source, including its purpose, strategic priorities, target beneficiary populations, and any special conditions or donor intent. Used for internal reference and proposal development.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSourceName rdf:type rdf:Property ;
    rdfs:label 'Funding Source Name' ;
    rdfs:comment 'The official name of the funding source or funding mechanism as recognized by the donor organization and used in grant agreements.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSourceStatus rdf:type rdf:Property ;
    rdfs:label 'Funding Source Status' ;
    rdfs:comment 'Current lifecycle status of the funding source indicating whether it is actively available for grant awards, temporarily suspended, permanently closed, pending activation, or under review.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingStartDate rdf:type rdf:Property ;
    rdfs:label 'Funding Start Date' ;
    rdfs:comment 'The date from which this funding source becomes available for grant awards and disbursements. Represents the beginning of the funding period.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes or regional designations indicating geographic areas where this funding source may be used. Empty if no geographic restrictions apply.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indirectCostRateType rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Rate Type' ;
    rdfs:comment 'The type of indirect cost rate mechanism applicable to this funding source. NICRA refers to a formally negotiated rate; de minimis refers to the 10% rate allowed under 2 CFR 200.414(f); cost reimbursement, fixed rate, and negotiated rate represent other donor-specific mechanisms.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odaDacClassification rdf:type rdf:Property ;
    rdfs:label 'Oda Dac Classification' ;
    rdfs:comment 'The OECD Development Assistance Committee classification code for this funding source if it qualifies as Official Development Assistance. Used for international aid transparency and reporting to DAC member countries.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementStandards rdf:type rdf:Property ;
    rdfs:label 'Procurement Standards' ;
    rdfs:comment 'Description of the procurement and contracting standards that must be followed when using this funding source (e.g., OMB Uniform Guidance 2 CFR 200.318-200.326, USAID Mandatory Standard Provisions, DFID Procurement Guidelines). Ensures compliance with donor procurement rules.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programIncomeTreatment rdf:type rdf:Property ;
    rdfs:label 'Program Income Treatment' ;
    rdfs:comment 'The method by which program income earned under grants funded by this source must be treated per OMB Uniform Guidance 2 CFR 200.307. Addition means income is added to the grant; deduction means income reduces the donor share; cost-sharing means income is used to meet cost-share requirements; no program income indicates the funding source does not generate program income.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Record Retention Years' ;
    rdfs:comment 'The number of years that financial and programmatic records for grants funded by this source must be retained after grant closeout, as required by the donor or applicable regulations (e.g., OMB Uniform Guidance requires 3 years).' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sdgAlignmentCodes rdf:type rdf:Property ;
    rdfs:label 'Sdg Alignment Codes' ;
    rdfs:comment 'Comma-separated list of United Nations Sustainable Development Goal codes (e.g., SDG 1, SDG 3, SDG 5) that this funding source is aligned with or restricted to support. Enables portfolio analysis by SDG impact area.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subawardAllowed rdf:type rdf:Property ;
    rdfs:label 'Subaward Allowed' ;
    rdfs:comment 'Boolean flag indicating whether this funding source permits the organization to issue subawards or subgrants to implementing partners and community-based organizations.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subawardApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Subaward Approval Required' ;
    rdfs:comment 'Boolean flag indicating whether the donor organization must provide prior written approval before the organization can issue subawards using this funding source.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thematicRestriction rdf:type rdf:Property ;
    rdfs:label 'Thematic Restriction' ;
    rdfs:comment 'Description of thematic or sectoral restrictions on the use of this funding source (e.g., WASH programs only, education initiatives, health services, emergency response). Empty if no thematic restrictions apply.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFundingAvailable rdf:type rdf:Property ;
    rdfs:label 'Total Funding Available' ;
    rdfs:comment 'The total amount of funding available from this source across all grant awards, expressed in the funding source currency. May represent a ceiling or allocation limit.' ;
    rdfs:domain ind:FundingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indicatorTargetId rdf:type rdf:Property ;
    rdfs:label 'Indicator Target Id' ;
    rdfs:comment 'Foreign key linking to mel.indicator_target. Business justification: Amendments adjust indicator targets when period of performance, budget, or scope changes. Target revisions require donor prior approval, and amendment documents must specify which indicator targets ar' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndicatorTarget .

ind:melLogframeId rdf:type rdf:Property ;
    rdfs:label 'Mel Logframe Id' ;
    rdfs:comment 'Foreign key linking to mel.mel_logframe. Business justification: Amendments revise logframes when scope, geography, or results chain changes. Formal amendments update intervention logic, assumptions, and indicator hierarchies in donor-approved logframe, requiring v' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MelLogframe .

ind:supersedesAmendmentGrantAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Amendment Grant Amendment Id' ;
    rdfs:comment 'Reference to a previous amendment that this amendment supersedes or replaces. Used to track amendment version history.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GrantAmendment .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Detailed narrative description of the changes introduced by this amendment. Explains the rationale, scope, and impact of the modification.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential or hierarchical identifier for this amendment within the grant lifecycle (e.g., Amendment 001, A-1, Mod 3). Serves as the business identifier for the amendment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle status of the amendment. Tracks the amendment from initial drafting through donor approval and execution. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|executed|rejected|withdrawn|superseded — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the amendment based on the nature of the modification. Indicates whether the amendment extends the period, modifies the budget, changes scope, updates key personnel, expands geographic coverage, or adjusts other terms. [ENUM-REF-CANDIDATE: no_cost_extension|budget_modification|scope_change|key_personnel_change|geographic_expansion|period_of_performance_change|funding_increase|funding_decrease|administrative_correction|terms_and_conditions_change — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetModificationSummary rdf:type rdf:Property ;
    rdfs:label 'Budget Modification Summary' ;
    rdfs:comment 'Summary of budget line item changes resulting from this amendment. Describes reallocations, increases, or decreases across cost categories.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorPriorApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Donor Prior Approval Required' ;
    rdfs:comment 'Indicates whether this amendment required formal prior approval from the donor agency before implementation, as mandated by OMB Uniform Guidance 2 CFR 200.308.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date when the amendment was fully executed and became legally binding. This is the principal business event timestamp for the amendment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundingChange rdf:type rdf:Property ;
    rdfs:label 'Funding Change' ;
    rdfs:comment 'Net change in funding resulting from this amendment. Positive values indicate funding increases, negative values indicate decreases. Zero for non-financial amendments.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Geographic Change Description' ;
    rdfs:comment 'Description of any changes to the geographic coverage or implementation locations resulting from this amendment (e.g., expansion to new regions, closure of field sites).' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Internal Approval Date' ;
    rdfs:comment 'Date when the amendment request was approved internally by the nonprofit organization before submission to the donor.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalApproverName rdf:type rdf:Property ;
    rdfs:label 'Internal Approver Name' ;
    rdfs:comment 'Name of the internal organizational authority who approved the amendment request (e.g., Executive Director, Chief Grants Officer).' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isNoCostExtension rdf:type rdf:Property ;
    rdfs:label 'Is No Cost Extension' ;
    rdfs:comment 'Indicates whether this amendment is a no-cost extension, extending the period of performance without additional funding.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Business and programmatic justification for requesting the amendment. Explains why the modification is necessary and how it aligns with program objectives.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyPersonnelChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Key Personnel Change Description' ;
    rdfs:comment 'Description of any changes to key personnel roles, including additions, removals, or role modifications. Key personnel typically include Principal Investigator, Project Director, and other critical leadership positions.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalStartDate rdf:type rdf:Property ;
    rdfs:label 'Original Start Date' ;
    rdfs:comment 'Original start date of the grant period of performance before this amendment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalTotalObligation rdf:type rdf:Property ;
    rdfs:label 'Original Total Obligation' ;
    rdfs:comment 'Total obligated funding amount before this amendment. Provides baseline for calculating the impact of funding changes.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodExtensionDays rdf:type rdf:Property ;
    rdfs:label 'Period Extension Days' ;
    rdfs:comment 'Number of calendar days by which the period of performance is extended by this amendment. Calculated as the difference between revised and original end dates.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date when the amendment request was formally submitted to the donor or funding agency for review and approval.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisedEndDate rdf:type rdf:Property ;
    rdfs:label 'Revised End Date' ;
    rdfs:comment 'Revised end date of the grant period of performance after this amendment. Commonly modified in no-cost extension amendments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisedStartDate rdf:type rdf:Property ;
    rdfs:label 'Revised Start Date' ;
    rdfs:comment 'Revised start date of the grant period of performance after this amendment. Typically unchanged unless the amendment is retroactive.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisedTotalObligation rdf:type rdf:Property ;
    rdfs:label 'Revised Total Obligation' ;
    rdfs:comment 'Total obligated funding amount after applying this amendment. Equals original total obligation plus amendment funding change.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scopeChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Change Description' ;
    rdfs:comment 'Detailed description of any changes to the programmatic scope, objectives, deliverables, or activities resulting from this amendment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAndConditionsChange rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Change' ;
    rdfs:comment 'Description of any modifications to the legal terms, conditions, reporting requirements, or compliance obligations under the grant agreement.' ;
    rdfs:domain ind:GrantAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantCloseoutId rdf:type rdf:Property ;
    rdfs:label 'Grant Closeout Id' ;
    rdfs:comment 'Unique identifier for the grant closeout record. Primary key. Each award has exactly one closeout record created when the period of performance ends or early termination is initiated.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalEvaluationId rdf:type rdf:Property ;
    rdfs:label 'Final Evaluation Id' ;
    rdfs:comment 'Foreign key linking to mel.evaluation. Business justification: Grant closeout packages reference final/endline evaluations as required deliverables. Closeout cannot be completed until final evaluation is submitted, accepted by donor, and findings are incorporated' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Evaluation .

ind:closeoutStatus rdf:type rdf:Property ;
    rdfs:label 'Closeout Status' ;
    rdfs:comment 'Current lifecycle state of the closeout process. Tracks progression from initiation through donor acceptance and final closure. [ENUM-REF-CANDIDATE: initiated|in_progress|final_reports_submitted|donor_review|donor_accepted|closed|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeoutType rdf:type rdf:Property ;
    rdfs:label 'Closeout Type' ;
    rdfs:comment 'Classification of the closeout trigger. Distinguishes between normal period of performance expiration, early termination scenarios, and mutual agreement closures.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Date' ;
    rdfs:comment 'Date when internal compliance certification was completed confirming all closeout requirements met. Internal control checkpoint before donor submission.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceCertifiedBy rdf:type rdf:Property ;
    rdfs:label 'Compliance Certified By' ;
    rdfs:comment 'Name and title of the authorized official who certified compliance with all closeout requirements. Provides accountability for certification.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorCloseoutContactEmail rdf:type rdf:Property ;
    rdfs:label 'Donor Closeout Contact Email' ;
    rdfs:comment 'Email address of the donor closeout contact. Used for submission of final reports and closeout correspondence.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorCloseoutContactName rdf:type rdf:Property ;
    rdfs:label 'Donor Closeout Contact Name' ;
    rdfs:comment 'Name of the donor representative responsible for reviewing and accepting the closeout. Primary point of contact for closeout correspondence.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentDispositionDate rdf:type rdf:Property ;
    rdfs:label 'Equipment Disposition Date' ;
    rdfs:comment 'Date when equipment disposition was completed and documented. Required for federal grant closeout per 2 CFR 200.313.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentDispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Disposition Status' ;
    rdfs:comment 'Disposition method for equipment purchased with grant funds. Documents compliance with 2 CFR 200.313 equipment disposition requirements.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalAuditCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Final Audit Completion Date' ;
    rdfs:comment 'Date when final audit was completed and report issued. Required for grants subject to single audit per 2 CFR 200.501.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalAuditReference rdf:type rdf:Property ;
    rdfs:label 'Final Audit Reference' ;
    rdfs:comment 'Reference number or document identifier for the final audit report. Links to audit findings and resolution documentation.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Final Audit Status' ;
    rdfs:comment 'Status of final audit or single audit requirement for the grant. Tracks compliance with 2 CFR 200 Subpart F audit requirements.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalFinancialReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Final Financial Report Due Date' ;
    rdfs:comment 'Deadline for submission of final financial report (SF-425 or equivalent). Typically 90-120 days after period of performance end per 2 CFR 200.344.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalFinancialReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Final Financial Report Submission Date' ;
    rdfs:comment 'Actual date when the final financial report (SF-425 or donor-specific form) was submitted to the donor. Must be within 120 days of period end per 2 CFR 200.344.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalInventoryReference rdf:type rdf:Property ;
    rdfs:label 'Final Inventory Reference' ;
    rdfs:comment 'Document reference for the final property and equipment inventory report. Tracks disposition of federally-owned assets.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalInventorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Final Inventory Submission Date' ;
    rdfs:comment 'Date when final inventory of federally-owned property and equipment was submitted. Required for federal grants per 2 CFR 200.313 and 200.344.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalProgrammaticReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Final Programmatic Report Due Date' ;
    rdfs:comment 'Deadline for submission of final programmatic or technical report. Typically aligned with financial report deadline per donor requirements.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalProgrammaticReportReference rdf:type rdf:Property ;
    rdfs:label 'Final Programmatic Report Reference' ;
    rdfs:comment 'Document reference or tracking number for the submitted final programmatic report. Links to document management system or grant management system record.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalProgrammaticReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Final Programmatic Report Submission Date' ;
    rdfs:comment 'Actual date when the final programmatic or technical report was submitted to the donor. Documents achievement of grant objectives and deliverables.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiationDate rdf:type rdf:Property ;
    rdfs:label 'Initiation Date' ;
    rdfs:comment 'Date when the formal closeout process was initiated. Typically triggered by period of performance end date or termination notice.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intellectualPropertyDisposition rdf:type rdf:Property ;
    rdfs:label 'Intellectual Property Disposition' ;
    rdfs:comment 'Disposition of intellectual property rights developed under the grant. Documents ownership and usage rights per grant agreement terms.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingIssuesDescription rdf:type rdf:Property ;
    rdfs:label 'Outstanding Issues Description' ;
    rdfs:comment 'Detailed description of any outstanding issues preventing closeout completion. Documents barriers and resolution plans.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingIssuesFlag rdf:type rdf:Property ;
    rdfs:label 'Outstanding Issues Flag' ;
    rdfs:comment 'Indicates whether any unresolved issues exist that may delay closeout completion. True if issues exist, false if all requirements met.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodOfPerformanceEndDate rdf:type rdf:Property ;
    rdfs:label 'Period Of Performance End Date' ;
    rdfs:comment 'Final date of the grant award period of performance. Closeout activities must commence after this date per 2 CFR 200.344.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordsDestructionDate rdf:type rdf:Property ;
    rdfs:label 'Records Destruction Date' ;
    rdfs:comment 'Actual date when grant records were destroyed after retention period expired. Documents compliance with records retention policy.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordsRetentionEndDate rdf:type rdf:Property ;
    rdfs:label 'Records Retention End Date' ;
    rdfs:comment 'Date when grant records may be destroyed. Typically 3 years from final financial report submission per 2 CFR 200.334, or longer if audit findings exist.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Business identifier for the closeout process. Externally-known reference number used in donor correspondence and audit trails.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unliquidatedObligationsAmount rdf:type rdf:Property ;
    rdfs:label 'Unliquidated Obligations Amount' ;
    rdfs:comment 'Total amount of obligations incurred but not yet paid at closeout. Must be reported on final SF-425 and disposition determined with donor.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unliquidatedObligationsDisposition rdf:type rdf:Property ;
    rdfs:label 'Unliquidated Obligations Disposition' ;
    rdfs:comment 'Disposition method for any remaining unliquidated obligations at closeout. Documents how outstanding commitments will be resolved.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unobligatedBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Unobligated Balance Amount' ;
    rdfs:comment 'Total amount of grant funds that remain unobligated at closeout. Must be returned to donor or deobligated per 2 CFR 200.344.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unobligatedBalanceReturnDate rdf:type rdf:Property ;
    rdfs:label 'Unobligated Balance Return Date' ;
    rdfs:comment 'Date when unobligated balance was returned to the donor. Required within closeout period per donor terms.' ;
    rdfs:domain ind:GrantCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorApprovalId rdf:type rdf:Property ;
    rdfs:label 'Prior Approval Id' ;
    rdfs:comment 'Unique identifier for the prior approval request record. Primary key for the prior approval entity.' ;
    rdfs:domain ind:PriorApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPriorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Prior Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who prepared and submitted the prior approval request. Links to the staff or workforce entity.' ;
    rdfs:domain ind:PriorApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:approvalConditions rdf:type rdf:Property ;
    rdfs:label 'Approval Conditions' ;
    rdfs:comment 'Specific conditions, restrictions, or requirements imposed by the donor as part of a conditional approval. Must be satisfied before the approved action can be implemented.' ;
    rdfs:domain ind:PriorApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDecision rdf:type rdf:Property ;
    rdfs:label 'Approval Decision' ;
    rdfs:comment 'Final decision rendered by the donor on the prior approval request. Approved indicates full approval, conditionally approved requires additional actions, denied rejects the request, not required indicates prior approval was not needed, and pending indicates decision is still outstanding.' ;
    rdfs:domain ind:PriorApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalSubtype rdf:type rdf:Property ;
    rdfs:label 'Approval Subtype' ;
    rdfs:comment 'More granular classification within the approval type, such as specific budget line item category or personnel role affected. Provides additional context for the request.' ;
    rdfs:domain ind:PriorApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalType rdf:type rdf:Property ;
    rdfs:label 'Approval Type' ;
    rdfs:comment 'Category of prior approval being requested. Common types include budget reallocation exceeding 10%, equipment purchase, foreign travel, key personnel change, no-cost extension request, change of scope, subaward modification, or indirect cost rate change. [ENUM-REF-CANDIDATE: budget_reallocation|equipment_purchase|foreign_travel|key_personnel_change|no_cost_extension|scope_change|subaward_modification|indirect_cost_rate_change|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PriorApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedAmountCurrency rdf:type rdf:Property ;
    rdfs:label 'Approved Amount Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the approved amount. Ensures accurate financial tracking across multi-currency grants.' ;
    rdfs:domain ind:PriorApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Explanation provided by the donor for denying the prior approval request. Includes rationale, policy basis, or alternative recommendations.' ;
    rdfs:domain ind:PriorApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorResponseDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Donor Response Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the formal donor response letter or decision document. Provides audit trail for compliance verification.' ;
    rdfs:domain ind:PriorApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergency rdf:type rdf:Property ;
    rdfs:label 'Is Emergency' ;
    rdfs:comment 'Indicates whether this prior approval request is being submitted under emergency or urgent circumstances requiring expedited donor review.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRetroactive rdf:type rdf:Property ;
    rdfs:label 'Is Retroactive' ;
    rdfs:comment 'Indicates whether this prior approval request is being submitted retroactively after the action has already been taken. Retroactive requests carry higher compliance risk.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'Citation of the specific regulatory or contractual provision that requires prior approval for this action. Examples include 2 CFR 200.407, USAID ADS 303, or specific grant award terms.' ;
    rdfs:domain ind:PriorApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Request Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this prior approval request for tracking and correspondence with the donor.' ;
    rdfs:domain ind:PriorApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the prior approval request. Tracks progression from draft through submission, review, and final decision by the donor. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|conditionally_approved|denied|withdrawn|not_required — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedAmount rdf:type rdf:Property ;
    rdfs:label 'Requested Amount' ;
    rdfs:comment 'Monetary value requested in the prior approval submission for budget-related requests. Provides baseline for comparison with approved amount.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedAmountCurrency rdf:type rdf:Property ;
    rdfs:label 'Requested Amount Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the requested amount. Ensures accurate financial tracking across multi-currency grants.' ;
    rdfs:domain ind:PriorApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalId rdf:type rdf:Property ;
    rdfs:label 'Proposal Id' ;
    rdfs:comment 'Unique identifier for the grant proposal or concept note submission. Primary key for the proposal data product.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:solicitationId rdf:type rdf:Property ;
    rdfs:label 'Solicitation Id' ;
    rdfs:comment 'Reference to the donor solicitation or funding opportunity this proposal responds to. Links to the solicitation entity for RFA, RFP, NOFO tracking. Null for unsolicited proposals.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Solicitation .

ind:awardNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Award Notification Date' ;
    rdfs:comment 'Date the organization was officially notified of the award decision by the donor. Null if proposal was not awarded or decision is still pending.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessDevelopmentOwner rdf:type rdf:Property ;
    rdfs:label 'Business Development Owner' ;
    rdfs:comment 'Name or identifier of the business development staff member responsible for managing this proposal opportunity and donor relationship.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Completed' ;
    rdfs:comment 'Boolean flag indicating whether compliance and risk review was completed before submission. Ensures adherence to donor regulations and organizational policies.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consortiumLeadOrganization rdf:type rdf:Property ;
    rdfs:label 'Consortium Lead Organization' ;
    rdfs:comment 'Name of the lead organization if this proposal is part of a consortium or joint application. Null if organization is the prime or applying solo.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costProposalSummary rdf:type rdf:Property ;
    rdfs:label 'Cost Proposal Summary' ;
    rdfs:comment 'Summary of the cost proposal structure, including major budget categories, cost-sharing arrangements, and indirect cost rate applied. Provides financial overview without detailed line items.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'File path, document management system reference, or URL to the submitted proposal document package. Enables retrieval of the full proposal for audit and reference.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goNoGoDecision rdf:type rdf:Property ;
    rdfs:label 'Go No Go Decision' ;
    rdfs:comment 'Internal decision on whether to pursue this funding opportunity. Tracks strategic alignment, capacity assessment, and risk evaluation outcomes.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goNoGoDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Go No Go Decision Date' ;
    rdfs:comment 'Date the internal go/no-go decision was made regarding pursuit of this funding opportunity.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indirectCostRateProposed rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Rate Proposed' ;
    rdfs:comment 'Indirect cost rate (ICR) or facilities and administration (F&A) rate proposed in the budget, expressed as a percentage. May reference the organization\'s NICRA (Negotiated Indirect Cost Rate Agreement).' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Internal Review Date' ;
    rdfs:comment 'Date the proposal completed internal review and was approved for submission by organizational leadership or review committee.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadProposalWriter rdf:type rdf:Property ;
    rdfs:label 'Lead Proposal Writer' ;
    rdfs:comment 'Name or identifier of the staff member who served as the lead technical writer for this proposal. Used for workload tracking and expertise mapping.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTechnicalSector rdf:type rdf:Property ;
    rdfs:label 'Lead Technical Sector' ;
    rdfs:comment 'Primary technical sector or thematic area for the proposed intervention (e.g., WASH, Health, Education, Protection, Livelihoods, GBV, Nutrition). Aligns with DAC sector codes and organizational program taxonomy.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipModel rdf:type rdf:Property ;
    rdfs:label 'Partnership Model' ;
    rdfs:comment 'Organizational role and partnership structure for this proposal. Indicates whether the organization is applying as prime recipient, sub-awardee, consortium member, joint venture partner, or solo applicant.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalStatus rdf:type rdf:Property ;
    rdfs:label 'Proposal Status' ;
    rdfs:comment 'Current lifecycle status of the proposal. Tracks progression from draft through internal review, submission, donor review, shortlisting, and final outcome (awarded, rejected, or withdrawn). [ENUM-REF-CANDIDATE: draft|internal_review|submitted|under_review|shortlisted|awarded|rejected|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalType rdf:type rdf:Property ;
    rdfs:label 'Proposal Type' ;
    rdfs:comment 'Classification of the proposal submission format and stage. Indicates whether this is a full application, concept note, expression of interest, unsolicited submission, pre-proposal, or letter of inquiry.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Proposed Duration Months' ;
    rdfs:comment 'Total duration of the proposed project period of performance expressed in months. Calculated from proposed start and end dates.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedEndDate rdf:type rdf:Property ;
    rdfs:label 'Proposed End Date' ;
    rdfs:comment 'Proposed end date for the period of performance if the grant is awarded. Marks the conclusion of the planned implementation timeline.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedStartDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Start Date' ;
    rdfs:comment 'Proposed start date for the period of performance if the grant is awarded. Marks the beginning of the planned implementation timeline.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Primary reason provided by the donor for proposal rejection, or internal assessment of why the proposal was not successful. Used for lessons learned and win-rate improvement analysis.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Requested Amount Usd' ;
    rdfs:comment 'Total funding amount requested converted to USD using the exchange rate at submission date. Enables cross-proposal comparison and pipeline analysis in a common currency.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedCurrency rdf:type rdf:Property ;
    rdfs:label 'Requested Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the requested funding amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBeneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Target Beneficiary Count' ;
    rdfs:comment 'Estimated number of direct beneficiaries the proposed project aims to reach. Used for cost-per-beneficiary analysis and impact projections.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalApproachSummary rdf:type rdf:Property ;
    rdfs:label 'Technical Approach Summary' ;
    rdfs:comment 'High-level summary of the proposed technical approach, methodology, and intervention strategy. Captures key elements of the Theory of Change (ToC) and implementation plan.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winLossOutcome rdf:type rdf:Property ;
    rdfs:label 'Win Loss Outcome' ;
    rdfs:comment 'Final outcome of the proposal submission. Indicates whether the proposal was won (awarded), lost (rejected), is still pending donor decision, or was withdrawn by the organization.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingConstituentId rdf:type rdf:Property ;
    rdfs:label 'Issuing Constituent Id' ;
    rdfs:comment 'Foreign key linking to donor.constituent. Business justification: Solicitations (RFPs, funding opportunities) issued by specific donor organizations. Links to constituent for tracking issuing donor, managing donor relationships, and analyzing funding opportunity sou' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:anticipatedAwardDate rdf:type rdf:Property ;
    rdfs:label 'Anticipated Award Date' ;
    rdfs:comment 'Expected date on which the donor will announce award decisions, as stated in the solicitation or estimated by the organization.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:anticipatedStartDate rdf:type rdf:Property ;
    rdfs:label 'Anticipated Start Date' ;
    rdfs:comment 'Expected start date for program implementation if the grant is awarded, as specified in the solicitation.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationDeadline rdf:type rdf:Property ;
    rdfs:label 'Application Deadline' ;
    rdfs:comment 'Date and time by which proposals or applications must be submitted. Critical for proposal pipeline planning and resource allocation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveIntelligenceNotes rdf:type rdf:Property ;
    rdfs:label 'Competitive Intelligence Notes' ;
    rdfs:comment 'Internal notes on competitive landscape, known competitors, incumbent organizations, partnership opportunities, and strategic considerations for this solicitation. Business-confidential information.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consortiumAllowed rdf:type rdf:Property ;
    rdfs:label 'Consortium Allowed' ;
    rdfs:comment 'Indicates whether the solicitation permits or encourages consortium or partnership applications.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Summary of organizational eligibility requirements (e.g., 501(c)(3) status, registration in specific countries, minimum years of operational experience, financial capacity thresholds, consortium requirements).' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Funding Amount' ;
    rdfs:comment 'Total estimated funding available under this solicitation, expressed in the donor\'s currency. May represent a range or ceiling amount.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedNumberOfAwards rdf:type rdf:Property ;
    rdfs:label 'Estimated Number Of Awards' ;
    rdfs:comment 'Expected number of grants or contracts the donor intends to award under this solicitation. Null if not specified.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fundingCurrency rdf:type rdf:Property ;
    rdfs:label 'Funding Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated funding amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicEligibility rdf:type rdf:Property ;
    rdfs:label 'Geographic Eligibility' ;
    rdfs:comment 'Countries, regions, or geographic areas eligible for funding under this solicitation. Uses ISO 3166-1 alpha-3 country codes where applicable (e.g., SYR, YEM, ETH, Global, Sub-Saharan Africa).' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goNoGoRationale rdf:type rdf:Property ;
    rdfs:label 'Go No Go Rationale' ;
    rdfs:comment 'Summary of the strategic rationale for the go or no-go decision, including alignment with organizational mission, capacity, competitive positioning, and resource availability.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedBy rdf:type rdf:Property ;
    rdfs:label 'Identified By' ;
    rdfs:comment 'Name or identifier of the staff member or business development team member who identified this solicitation opportunity.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date on which this solicitation was first identified and entered into the organization\'s opportunity tracking system.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indirectCostRateAllowed rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Rate Allowed' ;
    rdfs:comment 'Indicates whether the donor allows recovery of indirect costs (NICRA/ICR/F&A) in the budget.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indirectCostRateCap rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Rate Cap' ;
    rdfs:comment 'Maximum allowable indirect cost rate as a percentage, if the donor imposes a cap (e.g., 10% de minimis rate under 2 CFR 200.414).' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalPriorityScore rdf:type rdf:Property ;
    rdfs:label 'Internal Priority Score' ;
    rdfs:comment 'Internal scoring or ranking assigned to this solicitation based on strategic fit, likelihood of success, and resource availability. Scale and methodology defined by organizational business development process.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localPartnerRequirement rdf:type rdf:Property ;
    rdfs:label 'Local Partner Requirement' ;
    rdfs:comment 'Description of any requirements for local or national NGO partnership, localization commitments, or sub-award percentages to local organizations.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Program Duration Months' ;
    rdfs:comment 'Expected duration of the funded program in months, as specified in the solicitation.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:questionsDeadline rdf:type rdf:Property ;
    rdfs:label 'Questions Deadline' ;
    rdfs:comment 'Deadline by which applicants must submit questions to the donor regarding the solicitation.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:solicitationNumber rdf:type rdf:Property ;
    rdfs:label 'Solicitation Number' ;
    rdfs:comment 'External reference number assigned by the donor or issuing agency (e.g., RFA-2024-001, NOFO-BHA-2024-12, RFP-DFID-2024-WASH). This is the official identifier used in all donor communications and proposal submissions.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitationStatus rdf:type rdf:Property ;
    rdfs:label 'Solicitation Status' ;
    rdfs:comment 'Current status of the solicitation in the organization\'s business development pipeline: Identified (opportunity discovered), Evaluating (under internal review), Go (decision to pursue), No-Go (decision not to pursue), Submitted (proposal submitted), Closed (deadline passed), Awarded (grant awarded to any organization), Cancelled (donor cancelled solicitation). [ENUM-REF-CANDIDATE: Identified|Evaluating|Go|No-Go|Submitted|Closed|Awarded|Cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitationType rdf:type rdf:Property ;
    rdfs:label 'Solicitation Type' ;
    rdfs:comment 'Classification of the funding opportunity mechanism: Request for Applications (RFA), Request for Proposals (RFP), Notice of Funding Opportunity (NOFO), Invitation to Tender (ITT), Expression of Interest (EOI), Concept Note solicitation, Direct Award notification, or Unsolicited opportunity. [ENUM-REF-CANDIDATE: RFA|RFP|NOFO|ITT|EOI|Concept Note|Direct Award|Unsolicited — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionRequirements rdf:type rdf:Property ;
    rdfs:label 'Submission Requirements' ;
    rdfs:comment 'Summary of required documents and formats for proposal submission (e.g., technical proposal, budget narrative, organizational capacity statement, past performance references, certifications, page limits).' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thematicFocusArea rdf:type rdf:Property ;
    rdfs:label 'Thematic Focus Area' ;
    rdfs:comment 'Primary programmatic theme or sector focus of the solicitation (e.g., WASH, Health, Education, Food Security, Protection, GBV Prevention, Livelihoods, Emergency Response). May include multiple themes separated by semicolons.' ;
    rdfs:domain ind:Solicitation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subAwardDisbursementId rdf:type rdf:Property ;
    rdfs:label 'Sub Award Disbursement Id' ;
    rdfs:comment 'Unique system-generated identifier for each sub-award disbursement transaction record in the grant management system.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subawardId rdf:type rdf:Property ;
    rdfs:label 'Subaward Id' ;
    rdfs:comment 'Reference to the parent sub-award agreement under which this disbursement is made. Links the disbursement to the specific sub-award instrument and implementing partner.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subaward .

ind:advanceBalanceOutstanding rdf:type rdf:Property ;
    rdfs:label 'Advance Balance Outstanding' ;
    rdfs:comment 'Remaining unliquidated advance balance owed by the implementing partner at the time of this disbursement record. Calculated as cumulative advances disbursed minus cumulative liquidations submitted. Supports 2 CFR 200.305 advance payment monitoring and cash management.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankTransferReference rdf:type rdf:Property ;
    rdfs:label 'Bank Transfer Reference' ;
    rdfs:comment 'Bank-issued or payment-system-issued reference number for the wire transfer, EFT, or mobile money transaction. Used for bank reconciliation, audit trail, and confirmation of funds receipt by the implementing partner.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursement Amount' ;
    rdfs:comment 'Gross amount disbursed to the implementing partner in the transaction currency. Used as the primary monetary value for Budget vs. Actual (BvA) tracking at the sub-award level.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Disbursement Amount Usd' ;
    rdfs:comment 'Disbursement amount converted to US Dollars (USD) using the applied exchange rate. Used for consolidated Budget vs. Actual (BvA) reporting, donor financial reports, and NICRA/Indirect Cost Rate (ICR) calculations across multi-currency sub-awards.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementCurrency rdf:type rdf:Property ;
    rdfs:label 'Disbursement Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the currency in which the disbursement was made to the implementing partner (e.g., USD, EUR, KES, NGN). Supports multi-currency operations in international humanitarian programs.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementDate rdf:type rdf:Property ;
    rdfs:label 'Disbursement Date' ;
    rdfs:comment 'Actual date on which funds were transferred to the implementing partner\'s bank account or mobile money wallet. This is the principal business event date for Budget vs. Actual (BvA) reporting and cash flow tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disbursementMethod rdf:type rdf:Property ;
    rdfs:label 'Disbursement Method' ;
    rdfs:comment 'Mechanism by which funds are transferred to the implementing partner. Includes wire transfer for international bank transfers, mobile money for field-based digital payments (e.g., M-Pesa), check, cash for remote/emergency contexts, and electronic funds transfer (EFT) for domestic payments.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementNotes rdf:type rdf:Property ;
    rdfs:label 'Disbursement Notes' ;
    rdfs:comment 'Free-text field for grants staff to record contextual notes, special conditions, or explanations related to this disbursement, such as reasons for partial payment, exchange rate justification, or emergency authorization rationale.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Disbursement Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference number assigned to this disbursement transaction, used in bank transfer instructions, financial records, and audit trails. Corresponds to the payment reference in SAP S/4HANA Accounts Payable.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Disbursement Status' ;
    rdfs:comment 'Current lifecycle state of the disbursement transaction. Tracks progression from draft request through approval, actual disbursement, and final liquidation or cancellation. Drives workflow routing in the Grant Management System (GMS).' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementType rdf:type rdf:Property ;
    rdfs:label 'Disbursement Type' ;
    rdfs:comment 'Classification of the disbursement as an advance payment to the sub-recipient prior to expenditure, a reimbursement for costs already incurred, a direct payment to a third-party vendor on behalf of the sub-recipient, or a letter-of-credit drawdown. Governs compliance with 2 CFR 200.305 advance payment requirements.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergencyDisbursement rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Disbursement' ;
    rdfs:comment 'Indicates whether this disbursement was processed as an emergency or expedited payment outside the standard approval workflow, such as for rapid-onset disaster response under CERF or BHA emergency funding mechanisms.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liquidatedAmount rdf:type rdf:Property ;
    rdfs:label 'Liquidated Amount' ;
    rdfs:comment 'Amount of the advance disbursement that has been accounted for through submission of eligible expenditure documentation by the implementing partner. The difference between disbursement_amount and liquidated_amount represents the outstanding advance balance.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidationDate rdf:type rdf:Property ;
    rdfs:label 'Liquidation Date' ;
    rdfs:comment 'Actual date on which the implementing partner submitted the expenditure documentation or financial report fully accounting for the advance disbursement. Null if liquidation is pending or not yet completed.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liquidationDeadline rdf:type rdf:Property ;
    rdfs:label 'Liquidation Deadline' ;
    rdfs:comment 'Contractual deadline by which the implementing partner must submit expenditure documentation (financial report or liquidation report) to account for advance funds disbursed. Compliance with this date is required under 2 CFR 200.305.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liquidationStatus rdf:type rdf:Property ;
    rdfs:label 'Liquidation Status' ;
    rdfs:comment 'Current status of the liquidation (financial accountability reporting) for this advance disbursement. Tracks whether the implementing partner has submitted expenditure documentation to account for advanced funds per 2 CFR 200.305 requirements.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netDisbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Disbursement Amount' ;
    rdfs:comment 'Actual net amount transferred to the implementing partner after deducting any withholding amounts from the gross disbursement amount. This is the amount reflected in the bank transfer instruction.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postDistributionMonitoringRef rdf:type rdf:Property ;
    rdfs:label 'Post Distribution Monitoring Ref' ;
    rdfs:comment 'Reference identifier linking this disbursement to a Post-Distribution Monitoring (PDM) exercise conducted to verify that funds reached intended beneficiaries and were used for approved purposes. Supports accountability and learning under the Core Humanitarian Standard (CHS).' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trancheNumber rdf:type rdf:Property ;
    rdfs:label 'Tranche Number' ;
    rdfs:comment 'Sequential tranche number identifying this disbursement within the overall sub-award payment schedule. Enables tracking of phased funding releases against milestone-based or time-based disbursement plans.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:withholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Amount' ;
    rdfs:comment 'Amount withheld from the gross disbursement (e.g., performance-based retention, tax withholding, or compliance hold) before net transfer to the implementing partner. Null or zero if no withholding applies.' ;
    rdfs:domain ind:SubAwardDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursedAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursed Amount' ;
    rdfs:comment 'The cumulative amount disbursed to the implementing partner to date. Tracks actual cash transferred against the obligated amount.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'The nine-digit DUNS number of the implementing partner organization. Required for FFATA reporting and federal subawards.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffataReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ffata Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this subaward is subject to FFATA reporting requirements (typically subawards of $30,000 or more from federal sources).' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flowDownRequirements rdf:type rdf:Property ;
    rdfs:label 'Flow Down Requirements' ;
    rdfs:comment 'Narrative description of the prime award terms and conditions that must be flowed down to the subrecipient, including compliance obligations, reporting requirements, and audit provisions.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsrsReportDate rdf:type rdf:Property ;
    rdfs:label 'Fsrs Report Date' ;
    rdfs:comment 'The date when the subaward was reported to the FFATA Subaward Reporting System (FSRS), if applicable.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligatedAmount rdf:type rdf:Property ;
    rdfs:label 'Obligated Amount' ;
    rdfs:comment 'The current total obligated amount under the subaward, including any amendments. May differ from the original total subaward amount due to modifications.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentSchedule rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule' ;
    rdfs:comment 'The schedule or basis on which payments are made to the implementing partner (e.g., advance, reimbursement, milestone-based).' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodOfPerformanceStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Of Performance Start Date' ;
    rdfs:comment 'The date when the subaward period of performance begins. Defines the start of the implementing partners authorized work period.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance' ;
    rdfs:comment 'The remaining unspent balance of the subaward. Calculated as obligated amount minus disbursed amount.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:singleAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Single Audit Required Flag' ;
    rdfs:comment 'Indicates whether the implementing partner is required to undergo a Single Audit per 2 CFR 200 Subpart F based on federal expenditure thresholds.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subawardDescription rdf:type rdf:Property ;
    rdfs:label 'Subaward Description' ;
    rdfs:comment 'Detailed narrative description of the subaward scope, objectives, deliverables, and expected outcomes.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subawardNumber rdf:type rdf:Property ;
    rdfs:label 'Subaward Number' ;
    rdfs:comment 'The externally-known unique business identifier for this subaward. Used in all legal documents, reporting, and correspondence.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subawardStatus rdf:type rdf:Property ;
    rdfs:label 'Subaward Status' ;
    rdfs:comment 'Current lifecycle status of the subaward. Tracks the subaward from initial draft through active performance to closeout.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subawardType rdf:type rdf:Property ;
    rdfs:label 'Subaward Type' ;
    rdfs:comment 'Classification of the subaward instrument type. Determines the legal and compliance framework applicable to the subaward.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'The date when the subaward was terminated, if applicable. Used when the subaward is ended prior to the planned end date.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Narrative explanation of the reason for subaward termination, if applicable. Documents the circumstances and justification for early termination.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSubawardAmount rdf:type rdf:Property ;
    rdfs:label 'Total Subaward Amount' ;
    rdfs:comment 'The total obligated amount of the subaward in the subaward currency. Represents the maximum financial obligation to the implementing partner.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSubawardAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Total Subaward Amount Usd' ;
    rdfs:comment 'The total subaward amount converted to USD for consolidated reporting and analysis. Conversion uses the exchange rate at the time of subaward execution.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ueiNumber rdf:type rdf:Property ;
    rdfs:label 'Uei Number' ;
    rdfs:comment 'The twelve-character alphanumeric Unique Entity Identifier assigned to the implementing partner by SAM.gov. Replaces DUNS for federal reporting.' ;
    rdfs:domain ind:Subaward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedVolunteerRoleId rdf:type rdf:Property ;
    rdfs:label 'Authorized Volunteer Role Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer_role. Business justification: Data collection tools specify which volunteer roles are authorized to administer them (e.g., community health workers for health surveys, enumerators for household surveys). Required for training plan' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Role .

ind:capacityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Capacity Assessment Id' ;
    rdfs:comment 'Foreign key linking to partnership.capacity_assessment. Business justification: Capacity assessment tools are a type of data collection tool. Business need: assessment standardization, tool version control, methodology documentation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityAssessment .

ind:mealPlanId rdf:type rdf:Property ;
    rdfs:label 'Meal Plan Id' ;
    rdfs:comment 'Foreign key linking to mel.meal_plan. Business justification: Data collection tools (KoboToolbox forms, CommCare modules) are designed and deployed as part of MEAL plans. This FK links the tool to the MEAL plan it serves, enabling tracking of MEAL plan data coll' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MealPlan .

ind:primaryDataStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Data Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who approved the data collection tool.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:programLogframeId rdf:type rdf:Property ;
    rdfs:label 'Program Logframe Id' ;
    rdfs:comment 'Identifier of the LogFrame (Logical Framework) to which this tool is aligned.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramLogframe .

ind:safeguardingRiskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to safeguarding.risk_assessment. Business justification: Data collection tools (surveys, FGDs, KIIs) involving beneficiaries require safeguarding risk assessments to identify risks (power dynamics, retraumatization, child safeguarding) and embed mitigation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:additionalLanguages rdf:type rdf:Property ;
    rdfs:label 'Additional Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639 language codes for additional languages supported by the tool.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMechanism rdf:type rdf:Property ;
    rdfs:label 'Consent Mechanism' ;
    rdfs:comment 'Method by which informed consent is obtained from respondents using this tool.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProtectionCompliance rdf:type rdf:Property ;
    rdfs:label 'Data Protection Compliance' ;
    rdfs:comment 'Data protection and privacy framework to which this tool adheres. GDPR (General Data Protection Regulation), DPA (Data Protection Act), CHS (Core Humanitarian Standard).' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityValidationRules rdf:type rdf:Property ;
    rdfs:label 'Data Quality Validation Rules' ;
    rdfs:comment 'Description or reference to validation rules embedded in the tool to ensure data quality at point of collection.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCompletionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Time Minutes' ;
    rdfs:comment 'Expected time in minutes required to complete the data collection tool.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ethicalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Ethical Review Status' ;
    rdfs:comment 'Status of ethical review or institutional review board (IRB) approval for the data collection tool.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalToolUrl rdf:type rdf:Property ;
    rdfs:label 'External Tool Url' ;
    rdfs:comment 'URL or hyperlink to the external platform where the tool is hosted or accessed.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedIndicatorIds rdf:type rdf:Property ;
    rdfs:label 'Linked Indicator Ids' ;
    rdfs:comment 'Comma-separated list of indicator IDs that this tool is designed to measure or collect data for.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:questionCount rdf:type rdf:Property ;
    rdfs:label 'Question Count' ;
    rdfs:comment 'Total number of questions or data fields in the collection tool.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:respondentType rdf:type rdf:Property ;
    rdfs:label 'Respondent Type' ;
    rdfs:comment 'Classification of the target respondent or data subject for this collection tool. [ENUM-REF-CANDIDATE: beneficiary|household|community_leader|key_informant|staff|partner|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolCode rdf:type rdf:Property ;
    rdfs:label 'Tool Code' ;
    rdfs:comment 'Unique business identifier code for the data collection tool, used for external reference and integration.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Tool Documentation Url' ;
    rdfs:comment 'URL or reference to documentation, user guides, or training materials for the data collection tool.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolName rdf:type rdf:Property ;
    rdfs:label 'Tool Name' ;
    rdfs:comment 'Human-readable name of the data collection tool or instrument.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolStatus rdf:type rdf:Property ;
    rdfs:label 'Tool Status' ;
    rdfs:comment 'Current lifecycle status of the data collection tool.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolType rdf:type rdf:Property ;
    rdfs:label 'Tool Type' ;
    rdfs:comment 'Classification of the data collection tool by format and platform.' ;
    rdfs:domain ind:DataCollectionTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Data Quality Assessment Id' ;
    rdfs:comment 'Unique identifier for the data quality assessment record. Primary key for the data quality assessment entity.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataCollectorVolunteerId rdf:type rdf:Property ;
    rdfs:label 'Data Collector Volunteer Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer. Business justification: DQA audits data collected by volunteers, must track collector identity for accountability, corrective action targeting, and retraining decisions. Essential for volunteer data quality management and do' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:fieldMonitoringVisitId rdf:type rdf:Property ;
    rdfs:label 'Field Monitoring Visit Id' ;
    rdfs:comment 'Foreign key linking to partnership.field_monitoring_visit. Business justification: DQAs conducted during field monitoring visits. Business need: on-site data verification, partner oversight, spot-check DQA execution.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldMonitoringVisit .

ind:partnerPerformanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Partner Performance Review Id' ;
    rdfs:comment 'Foreign key linking to partnership.partner_performance_review. Business justification: DQA results feed into partner performance ratings. Business need: performance review evidence base, reporting compliance scoring, data quality rating component.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerPerformanceReview .

ind:partnerReportSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Partner Report Submission Id' ;
    rdfs:comment 'Foreign key linking to partnership.partner_report_submission. Business justification: DQAs validate data in partner reports. Business need: report acceptance decision, data quality scoring, verification evidence for donor reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerReportSubmission .

ind:reviewerStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Staff Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who reviewed or approved the data quality assessment findings.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accuracyScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Accuracy Score Percentage' ;
    rdfs:comment 'The percentage score representing the accuracy of the data assessed, calculated as the proportion of verified records that matched source documentation.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assessment End Date' ;
    rdfs:comment 'The date when the data quality assessment activities concluded.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Start Date' ;
    rdfs:comment 'The date when the data quality assessment activities began.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'The full name of the staff member or consultant who conducted the data quality assessment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorOrganization rdf:type rdf:Property ;
    rdfs:label 'Assessor Organization' ;
    rdfs:comment 'The name of the organization or unit to which the assessor belongs (e.g., internal MEL team, external auditor, donor verification team).' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completenessScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Completeness Score Percentage' ;
    rdfs:comment 'The percentage score representing the completeness of the data assessed, calculated as the proportion of required fields that were populated.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consistencyScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Consistency Score Percentage' ;
    rdfs:comment 'The percentage score representing the consistency of the data assessed, calculated as the proportion of records that were internally consistent and aligned across systems.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'The actual date when corrective actions were completed.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'The target date by which corrective actions should be completed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current status of the implementation of corrective actions (e.g., not started, in progress, completed, verified, overdue).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActions rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions' ;
    rdfs:comment 'Detailed description of the corrective actions recommended or taken to address the data quality issues identified during the assessment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dacCriteriaAssessed rdf:type rdf:Property ;
    rdfs:label 'Dac Criteria Assessed' ;
    rdfs:comment 'The DAC evaluation criteria that were assessed during the data quality review (e.g., relevance, effectiveness, efficiency, impact, sustainability, coherence).' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceType rdf:type rdf:Property ;
    rdfs:label 'Data Source Type' ;
    rdfs:comment 'The type or category of the data source audited (e.g., DHIS2, KoboToolbox, CommCare, field register, paper form, Excel, ERP, CRM). [ENUM-REF-CANDIDATE: dhis2|kobo|commcare|field_register|paper_form|excel|erp|crm|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyCount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Count' ;
    rdfs:comment 'The total number of discrepancies or errors identified during the data quality assessment.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discrepancyFindings rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Findings' ;
    rdfs:comment 'Detailed narrative description of the discrepancies, errors, or data quality issues identified during the assessment.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorReportingRequirement rdf:type rdf:Property ;
    rdfs:label 'Donor Reporting Requirement' ;
    rdfs:comment 'Indicates whether this data quality assessment was conducted to meet a specific donor reporting or verification requirement (e.g., USAID DQA, Global Fund LFA, DFID verification, BHA audit).' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallDqaScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Overall Dqa Score Percentage' ;
    rdfs:comment 'The overall composite data quality score, typically calculated as a weighted average of accuracy, completeness, timeliness, and consistency scores.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordsVerified rdf:type rdf:Property ;
    rdfs:label 'Records Verified' ;
    rdfs:comment 'The total number of records that were successfully verified during the assessment.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timelinessScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Timeliness Score Percentage' ;
    rdfs:comment 'The percentage score representing the timeliness of the data assessed, calculated as the proportion of records submitted or updated within required timeframes.' ;
    rdfs:domain ind:DataQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dhis2AggregateReportId rdf:type rdf:Property ;
    rdfs:label 'Dhis2 Aggregate Report Id' ;
    rdfs:comment 'Unique identifier for the DHIS2 aggregate report record. Primary key for this entity.' ;
    rdfs:domain ind:Dhis2AggregateReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingPeriodId rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Id' ;
    rdfs:comment 'The DHIS2 period identifier representing the time dimension for this report (e.g., \'202401\' for January 2024, \'2024Q1\' for Q1 2024).' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingPeriod .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text comments or notes provided by the reporting user regarding this aggregate report, including explanations for anomalies or data quality issues.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSetName rdf:type rdf:Property ;
    rdfs:label 'Data Set Name' ;
    rdfs:comment 'Human-readable name of the DHIS2 data set (e.g., \'Monthly Health Facility Report\', \'WASH Quarterly Indicators\').' ;
    rdfs:domain ind:Dhis2AggregateReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dhis2DataSetCode rdf:type rdf:Property ;
    rdfs:label 'Dhis2 Data Set Code' ;
    rdfs:comment 'The DHIS2 data set identifier that defines the collection of indicators and data elements included in this report.' ;
    rdfs:domain ind:Dhis2AggregateReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorCount rdf:type rdf:Property ;
    rdfs:label 'Indicator Count' ;
    rdfs:comment 'Total number of indicators or data elements included in this aggregate report.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:integrationStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Status' ;
    rdfs:comment 'Status of the integration of this report from the field DHIS2 instance into the enterprise data lakehouse.' ;
    rdfs:domain ind:Dhis2AggregateReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Integration Timestamp' ;
    rdfs:comment 'The timestamp when this aggregate report was successfully integrated into the enterprise lakehouse.' ;
    rdfs:domain ind:Dhis2AggregateReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportIdentifier rdf:type rdf:Property ;
    rdfs:label 'Report Identifier' ;
    rdfs:comment 'The externally-known unique identifier or reference number for this aggregate report as assigned by DHIS2 or the reporting system.' ;
    rdfs:domain ind:Dhis2AggregateReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Type' ;
    rdfs:comment 'The frequency or granularity of the reporting period (daily, weekly, monthly, quarterly, annual).' ;
    rdfs:domain ind:Dhis2AggregateReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingUserName rdf:type rdf:Property ;
    rdfs:label 'Reporting User Name' ;
    rdfs:comment 'The name of the user who submitted this aggregate report.' ;
    rdfs:domain ind:Dhis2AggregateReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRuleViolations rdf:type rdf:Property ;
    rdfs:label 'Validation Rule Violations' ;
    rdfs:comment 'Count of DHIS2 validation rule violations detected in this aggregate report.' ;
    rdfs:domain ind:Dhis2AggregateReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionedByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Commissioned By Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Evaluation management requires tracking internal staff who commissioned and oversee evaluations (distinct from external lead_evaluator_name). Essential for budget accountability, management response t' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:beneficiarySampleSize rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Sample Size' ;
    rdfs:comment 'Number of beneficiaries or respondents included in the evaluation sample for primary data collection.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coherenceRating rdf:type rdf:Property ;
    rdfs:label 'Coherence Rating' ;
    rdfs:comment 'Rating of the program\'s coherence (compatibility with other interventions, internal consistency) per DAC criteria (2019 revision).' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMethods rdf:type rdf:Property ;
    rdfs:label 'Data Collection Methods' ;
    rdfs:comment 'Comma-separated list of data collection methods used: household surveys, FGD (Focus Group Discussion), KII (Key Informant Interview), PDM (Post-Distribution Monitoring), direct observation, secondary data review, etc.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disseminationDate rdf:type rdf:Property ;
    rdfs:label 'Dissemination Date' ;
    rdfs:comment 'Date when the evaluation findings were formally disseminated to stakeholders, donors, and internal teams.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Rating' ;
    rdfs:comment 'Rating of the program\'s effectiveness (extent to which objectives were achieved) per DAC criteria.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficiencyRating rdf:type rdf:Property ;
    rdfs:label 'Efficiency Rating' ;
    rdfs:comment 'Rating of the program\'s efficiency (value for money, resource utilization) per DAC criteria.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsApprovalObtained rdf:type rdf:Property ;
    rdfs:label 'Ethics Approval Obtained' ;
    rdfs:comment 'Indicates whether ethics approval or institutional review board clearance was obtained for the evaluation, particularly for studies involving vulnerable populations (true/false).' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evaluationCode rdf:type rdf:Property ;
    rdfs:label 'Evaluation Code' ;
    rdfs:comment 'Externally-known unique code or reference number for the evaluation, used in donor reports and internal tracking.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationScope rdf:type rdf:Property ;
    rdfs:label 'Evaluation Scope' ;
    rdfs:comment 'Detailed description of the evaluation scope, including geographic coverage, beneficiary segments, program components, and time period covered.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current lifecycle status of the evaluation: planned (scheduled but not started), inception (terms of reference development), fieldwork (data collection in progress), analysis (data analysis phase), draft_report (draft under review), final_report (completed), disseminated (findings shared with stakeholders), or cancelled. [ENUM-REF-CANDIDATE: planned|inception|fieldwork|analysis|draft_report|final_report|disseminated|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Type' ;
    rdfs:comment 'Type of evaluation conducted: baseline (pre-intervention), midterm (mid-cycle), endline (post-intervention), impact (long-term outcomes), formative (process improvement), summative (final judgment), or real-time (during crisis). [ENUM-REF-CANDIDATE: baseline|midterm|endline|impact|formative|summative|real-time — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorType rdf:type rdf:Property ;
    rdfs:label 'Evaluator Type' ;
    rdfs:comment 'Type of evaluator conducting the assessment: internal (staff-led), external (independent consultant or firm), joint (internal and external collaboration), or participatory (beneficiary-led).' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'Executive summary of key evaluation findings, including strengths, weaknesses, and evidence against DAC criteria.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactRating rdf:type rdf:Property ;
    rdfs:label 'Impact Rating' ;
    rdfs:comment 'Rating of the program\'s impact (long-term changes and contribution to higher-level goals) per DAC criteria.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadEvaluatorName rdf:type rdf:Property ;
    rdfs:label 'Lead Evaluator Name' ;
    rdfs:comment 'Name of the lead evaluator or evaluation firm responsible for conducting the evaluation.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementResponseDate rdf:type rdf:Property ;
    rdfs:label 'Management Response Date' ;
    rdfs:comment 'Date when the management response to evaluation recommendations was formally completed and approved.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementResponseStatus rdf:type rdf:Property ;
    rdfs:label 'Management Response Status' ;
    rdfs:comment 'Status of the management response to evaluation recommendations: pending (not yet started), in_progress (being drafted), completed (response finalized and action plan developed), or not_required.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Overall performance rating assigned by the evaluation, typically on a six-point scale aligned with donor standards (e.g., USAID, DFID).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Planned date when the evaluation is scheduled to be completed and final report delivered.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Planned date when the evaluation fieldwork or data collection is scheduled to begin.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityAssuranceConducted rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Conducted' ;
    rdfs:comment 'Indicates whether independent quality assurance review of the evaluation was conducted (true/false).' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendationsSummary rdf:type rdf:Property ;
    rdfs:label 'Recommendations Summary' ;
    rdfs:comment 'Summary of actionable recommendations arising from the evaluation, including strategic, operational, and programmatic improvements.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relevanceRating rdf:type rdf:Property ;
    rdfs:label 'Relevance Rating' ;
    rdfs:comment 'Rating of the program\'s relevance (alignment with beneficiary needs, country priorities, and organizational strategy) per DAC criteria.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityRating rdf:type rdf:Property ;
    rdfs:label 'Sustainability Rating' ;
    rdfs:comment 'Rating of the program\'s sustainability (likelihood that benefits will continue after program closure) per DAC criteria.' ;
    rdfs:domain ind:Evaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationFindingId rdf:type rdf:Property ;
    rdfs:label 'Evaluation Finding Id' ;
    rdfs:comment 'Unique identifier for the evaluation finding record. Primary key.' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionOwnerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Action Owner Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Management response tracking and corrective action monitoring require linking findings to accountable staff member. Currently text field responsible_person_name; FK enables performance tracking, workl' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:capacityBuildingPlanId rdf:type rdf:Property ;
    rdfs:label 'Capacity Building Plan Id' ;
    rdfs:comment 'Foreign key linking to partnership.capacity_building_plan. Business justification: Evaluation findings trigger capacity building activities. Business need: corrective action planning, capacity gap closure, finding remediation tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityBuildingPlan .

ind:actionPlan rdf:type rdf:Property ;
    rdfs:label 'Action Plan' ;
    rdfs:comment 'Detailed plan outlining the steps, resources, and timeline for implementing the recommendation.' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryCategory rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Category' ;
    rdfs:comment 'Category or segment of beneficiaries affected by or relevant to this finding (e.g., IDP, refugee, host community, women, children).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Final notes or comments documenting the closure or resolution of this finding or recommendation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossCuttingTheme rdf:type rdf:Property ;
    rdfs:label 'Cross Cutting Theme' ;
    rdfs:comment 'Cross-cutting themes addressed by this finding (e.g., gender equality, disability inclusion, environmental sustainability, accountability).' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dacCriterion rdf:type rdf:Property ;
    rdfs:label 'Dac Criterion' ;
    rdfs:comment 'The DAC evaluation criterion this finding relates to: relevance, coherence, effectiveness, efficiency, impact, or sustainability.' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorName rdf:type rdf:Property ;
    rdfs:label 'Evaluator Name' ;
    rdfs:comment 'Name of the lead evaluator or evaluation team member who documented this finding.' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceBase rdf:type rdf:Property ;
    rdfs:label 'Evidence Base' ;
    rdfs:comment 'Summary of the data sources and evidence that support this finding (e.g., FGD results, KII transcripts, PDM data, program records).' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDate rdf:type rdf:Property ;
    rdfs:label 'Finding Date' ;
    rdfs:comment 'Date when the finding was formally documented or recorded in the evaluation report.' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Sequential or hierarchical identifier for the finding within the evaluation report (e.g., F1, F2.1, Finding-03).' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatement rdf:type rdf:Property ;
    rdfs:label 'Finding Statement' ;
    rdfs:comment 'The full text of the finding, conclusion, or recommendation as documented in the evaluation report.' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationProgressPercentage rdf:type rdf:Property ;
    rdfs:label 'Implementation Progress Percentage' ;
    rdfs:comment 'Percentage completion of the recommendation implementation (0.00 to 100.00).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current status of the recommendation or corrective action: not started, in progress, partially implemented, fully implemented, closed, or rejected.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskImplication rdf:type rdf:Property ;
    rdfs:label 'Risk Implication' ;
    rdfs:comment 'Description of risks or potential negative consequences if the finding or recommendation is not addressed.' ;
    rdfs:domain ind:EvaluationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sector rdf:type rdf:Property ;
    rdfs:label 'Sector' ;
    rdfs:comment 'Humanitarian or development sector this finding relates to (e.g., WASH, health, education, protection, food security).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorSafeguardingRequirementId rdf:type rdf:Property ;
    rdfs:label 'Donor Safeguarding Requirement Id' ;
    rdfs:comment 'Foreign key linking to safeguarding.donor_safeguarding_requirement. Business justification: Donors mandate specific safeguarding indicators (% staff trained, incident response time, beneficiary awareness metrics). MEL indicators must track compliance with donor safeguarding requirements for ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DonorSafeguardingRequirement .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'The date when the baseline value was measured or established.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'The initial measured value of the indicator at the start of the program or project, used as the reference point for measuring change and progress.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Formula or methodology used to calculate the indicator value. For ratio indicators, includes numerator and denominator definitions. For count indicators, specifies aggregation rules.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dacCriteriaAlignment rdf:type rdf:Property ;
    rdfs:label 'Dac Criteria Alignment' ;
    rdfs:comment 'The OECD DAC (Development Assistance Committee) evaluation criteria that this indicator addresses: relevance, coherence, effectiveness, efficiency, impact, or sustainability. Multiple criteria may be comma-separated.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Data Collection Frequency' ;
    rdfs:comment 'How often data for this indicator is collected and reported (e.g., monthly, quarterly, annually, one-time baseline/endline). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi-annually|annually|one-time|event-based — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definition rdf:type rdf:Property ;
    rdfs:label 'Definition' ;
    rdfs:comment 'Detailed technical definition of what the indicator measures, including scope, boundaries, and any specific criteria or conditions that must be met.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denominatorDescription rdf:type rdf:Property ;
    rdfs:label 'Denominator Description' ;
    rdfs:comment 'Definition of the denominator for percentage or ratio indicators. Describes the total population or base being measured. Null for count-based indicators.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dhis2IndicatorCode rdf:type rdf:Property ;
    rdfs:label 'Dhis2 Indicator Code' ;
    rdfs:comment 'The unique identifier for this indicator in the DHIS2 (District Health Information System 2) platform, used for integration and data synchronization.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directionOfChange rdf:type rdf:Property ;
    rdfs:label 'Direction Of Change' ;
    rdfs:comment 'The desired direction of change for this indicator to represent positive program impact (increase for positive indicators like vaccination coverage, decrease for negative indicators like malnutrition rates).' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disaggregationDimensions rdf:type rdf:Property ;
    rdfs:label 'Disaggregation Dimensions' ;
    rdfs:comment 'Comma-separated list of dimensions by which this indicator should be disaggregated for analysis (e.g., age, gender, location, disability status, IDP/refugee status). Critical for equity and inclusion analysis.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorCategory rdf:type rdf:Property ;
    rdfs:label 'Indicator Category' ;
    rdfs:comment 'Measurement category of the indicator: quantitative (numeric), qualitative (descriptive), or composite (combination of multiple measures).' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorCode rdf:type rdf:Property ;
    rdfs:label 'Indicator Code' ;
    rdfs:comment 'Unique business identifier code for the indicator used across programs and grants. Often follows organizational or donor-specific coding conventions.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorName rdf:type rdf:Property ;
    rdfs:label 'Indicator Name' ;
    rdfs:comment 'Full descriptive name of the indicator as it appears in LogFrames (Logical Frameworks), donor reports, and MEL (Monitoring Evaluation and Learning) dashboards.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorStatus rdf:type rdf:Property ;
    rdfs:label 'Indicator Status' ;
    rdfs:comment 'Current lifecycle status of the indicator in the MEL (Monitoring Evaluation and Learning) system.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorType rdf:type rdf:Property ;
    rdfs:label 'Indicator Type' ;
    rdfs:comment 'Classification of the indicator within the Results-Based Management (RBM) results chain: input (resources), process (activities), output (deliverables), outcome (short-term change), or impact (long-term change).' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustom rdf:type rdf:Property ;
    rdfs:label 'Is Custom' ;
    rdfs:comment 'Flag indicating whether this is a custom indicator developed specifically for this organization or program (true) or a standard indicator from an external framework (false).' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logframeLevel rdf:type rdf:Property ;
    rdfs:label 'Logframe Level' ;
    rdfs:comment 'The level in the LogFrame (Logical Framework) hierarchy where this indicator is positioned: goal (impact), purpose (outcome), output (deliverable), or activity (process).' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numeratorDescription rdf:type rdf:Property ;
    rdfs:label 'Numerator Description' ;
    rdfs:comment 'Definition of the numerator for percentage or ratio indicators. Describes what is being counted in the top of the fraction. Null for count-based indicators.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Role' ;
    rdfs:comment 'The organizational role or position responsible for collecting, validating, and reporting data for this indicator (e.g., MEL Officer, Program Manager, Field Coordinator).' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDate rdf:type rdf:Property ;
    rdfs:label 'Target Date' ;
    rdfs:comment 'The date by which the target value is expected to be achieved.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The planned or target value that the program aims to achieve for this indicator by the end of the reporting period or project lifecycle.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectedByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Collected By Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Data quality assessments and MEAL audits require traceability to the staff member who collected indicator data. Currently tracked as collection_team text; FK enables accountability audits and capacity' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'Date when the indicator data was physically collected in the field or extracted from source systems. Distinct from reporting period dates.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributingFactors rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors' ;
    rdfs:comment 'Description of key factors that contributed to achievement or non-achievement of the indicator target. Supports learning and adaptive management.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeResult rdf:type rdf:Property ;
    rdfs:label 'Cumulative Result' ;
    rdfs:comment 'Cumulative total of indicator results from program start through current reporting period. Used for life-of-project performance tracking.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityNotes rdf:type rdf:Property ;
    rdfs:label 'Data Quality Notes' ;
    rdfs:comment 'Free-text notes documenting data quality issues, limitations, or contextual factors affecting the reliability of this indicator result.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disaggregationAgeGroup rdf:type rdf:Property ;
    rdfs:label 'Disaggregation Age Group' ;
    rdfs:comment 'Age group disaggregation of the indicator result. Enables age-sensitive analysis and compliance with Sustainable Development Goal (SDG) reporting.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disaggregationDisability rdf:type rdf:Property ;
    rdfs:label 'Disaggregation Disability' ;
    rdfs:comment 'Disability status disaggregation per Washington Group Short Set. Required for inclusive programming and disability-focused donor reporting.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disaggregationDisplacementStatus rdf:type rdf:Property ;
    rdfs:label 'Disaggregation Displacement Status' ;
    rdfs:comment 'Displacement status disaggregation. Distinguishes Internally Displaced Persons (IDP), refugees, returnees, and host community members per UNHCR standards.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disaggregationSex rdf:type rdf:Property ;
    rdfs:label 'Disaggregation Sex' ;
    rdfs:comment 'Sex disaggregation of the indicator result. Required by most donors for gender-sensitive programming and reporting.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceFilePath rdf:type rdf:Property ;
    rdfs:label 'Evidence File Path' ;
    rdfs:comment 'File path or document reference to supporting evidence for this indicator result. Includes photos, survey data files, or verification reports.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicLevel rdf:type rdf:Property ;
    rdfs:label 'Geographic Level' ;
    rdfs:comment 'Administrative level at which this indicator result was measured. Enables hierarchical geographic aggregation and sub-national analysis.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorLevel rdf:type rdf:Property ;
    rdfs:label 'Indicator Level' ;
    rdfs:comment 'Level of the indicator in the results chain per Theory of Change (ToC). Distinguishes between immediate outputs, medium-term outcomes, and long-term impact.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMilestone rdf:type rdf:Property ;
    rdfs:label 'Is Milestone' ;
    rdfs:comment 'Indicates whether this indicator result represents a contractual milestone or critical deliverable per grant agreement terms.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:narrativeDescription rdf:type rdf:Property ;
    rdfs:label 'Narrative Description' ;
    rdfs:comment 'Qualitative narrative describing the context, achievements, challenges, and lessons learned related to this indicator result. Used in donor reports.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedToDonor rdf:type rdf:Property ;
    rdfs:label 'Reported To Donor' ;
    rdfs:comment 'Indicates whether this indicator result has been included in formal donor reporting. Tracks reporting compliance and audit trail.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Current workflow status of the indicator result record. Tracks approval and review lifecycle.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValue rdf:type rdf:Property ;
    rdfs:label 'Result Value' ;
    rdfs:comment 'Actual achieved value recorded for the indicator during the reporting period. The primary quantitative outcome measurement.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceFromTarget rdf:type rdf:Property ;
    rdfs:label 'Variance From Target' ;
    rdfs:comment 'Calculated difference between actual result and target value. Positive values indicate over-achievement, negative values indicate under-achievement.' ;
    rdfs:domain ind:IndicatorResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the MEL officer or evaluator who verified this indicator result. Supports accountability and quality assurance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScopeId rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope Id' ;
    rdfs:comment 'Reference to the geographic area (country, region, district, community) where this target applies.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicScope .

ind:primaryIndicatorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Indicator Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or MEL officer accountable for tracking and reporting on this target.' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:assumptions rdf:type rdf:Property ;
    rdfs:label 'Assumptions' ;
    rdfs:comment 'Key assumptions underlying the achievement of this target, including external factors and preconditions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disaggregationDisabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Disaggregation Disability Status' ;
    rdfs:comment 'Disability status disaggregation for this target, supporting inclusive programming and Washington Group standards.' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'How often this indicator target is measured and reported (daily, weekly, monthly, quarterly, semi-annually, annually, one-time, continuous). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi_annually|annually|one_time|continuous — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Mitigation Strategy' ;
    rdfs:comment 'Planned strategies or actions to mitigate identified risks and ensure target achievement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:risks rdf:type rdf:Property ;
    rdfs:label 'Risks' ;
    rdfs:comment 'Identified risks that may prevent the achievement of this target, including contextual, operational, and external risks.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Business identifier or code for this indicator target, often used in donor reports and LogFrame documentation.' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDescription rdf:type rdf:Property ;
    rdfs:label 'Target Description' ;
    rdfs:comment 'Detailed narrative description of what this target represents, including context and rationale.' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetName rdf:type rdf:Property ;
    rdfs:label 'Target Name' ;
    rdfs:comment 'Human-readable name or label for this indicator target.' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStatus rdf:type rdf:Property ;
    rdfs:label 'Target Status' ;
    rdfs:comment 'Current lifecycle status of the indicator target: draft (being defined), approved (validated by stakeholders), active (currently being tracked), on_track (progressing as planned), at_risk (may not be achieved), off_track (unlikely to be achieved), achieved (target met), not_achieved (target not met), revised (target has been modified), cancelled (target no longer applicable). [ENUM-REF-CANDIDATE: draft|approved|active|on_track|at_risk|off_track|achieved|not_achieved|revised|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetType rdf:type rdf:Property ;
    rdfs:label 'Target Type' ;
    rdfs:comment 'Classification of the target based on the results chain level: output (direct deliverables), outcome (intermediate results), impact (long-term change), process (operational efficiency), or input (resources).' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationSource rdf:type rdf:Property ;
    rdfs:label 'Verification Source' ;
    rdfs:comment 'The source or means of verification for this target (e.g., program records, beneficiary surveys, third-party evaluation, DHIS2 reports).' ;
    rdfs:domain ind:IndicatorTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningAgendaId rdf:type rdf:Property ;
    rdfs:label 'Learning Agenda Id' ;
    rdfs:comment 'Unique identifier for the learning agenda record. Primary key for the learning agenda entity.' ;
    rdfs:domain ind:LearningAgenda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkedEvaluationId rdf:type rdf:Property ;
    rdfs:label 'Linked Evaluation Id' ;
    rdfs:comment 'Reference to a formal evaluation, impact assessment, or research study that will address this learning question. Links to evaluation master data.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Evaluation .

ind:linkedIndicatorId rdf:type rdf:Property ;
    rdfs:label 'Linked Indicator Id' ;
    rdfs:comment 'Reference to the Key Performance Indicator (KPI) or Logical Framework (LogFrame) indicator that this learning question is designed to inform or validate. Links to indicator library.' ;
    rdfs:domain ind:Mel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Indicator .

ind:budgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated' ;
    rdfs:comment 'Financial resources allocated to evidence generation activities for this learning question. Expressed in the organizations base currency. Supports Budget versus Actual (BvA) tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetSpent rdf:type rdf:Property ;
    rdfs:label 'Budget Spent' ;
    rdfs:comment 'Actual financial expenditure incurred for evidence generation activities related to this learning question. Used for Budget versus Actual (BvA) analysis and financial stewardship.' ;
    rdfs:domain ind:LearningAgenda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collaborationPartners rdf:type rdf:Property ;
    rdfs:label 'Collaboration Partners' ;
    rdfs:comment 'Names or identifiers of external partners, Civil Society Organizations (CSO), Community-Based Organizations (CBO), or research institutions collaborating on evidence generation for this learning question.' ;
    rdfs:domain ind:LearningAgenda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityAssurancePlan rdf:type rdf:Property ;
    rdfs:label 'Data Quality Assurance Plan' ;
    rdfs:comment 'Description of quality assurance measures, validation protocols, and data quality checks planned for evidence generation. Ensures reliability and credibility of findings.' ;
    rdfs:domain ind:LearningAgenda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disseminationPlan rdf:type rdf:Property ;
    rdfs:label 'Dissemination Plan' ;
    rdfs:comment 'Description of how findings and lessons learned will be shared with stakeholders, including donors, partners, and internal teams. Supports knowledge management and organizational learning.' ;
    rdfs:domain ind:LearningAgenda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Ethics Approval Date' ;
    rdfs:comment 'Date when ethics approval or institutional review board clearance was granted for evidence generation activities. Null if not required or not yet obtained.' ;
    rdfs:domain ind:LearningAgenda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ethicsApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Ethics Approval Required' ;
    rdfs:comment 'Indicates whether formal ethics review or institutional review board approval is required for the evidence generation activities associated with this learning question. True if ethics approval needed, false otherwise.' ;
    rdfs:domain ind:LearningAgenda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceGenerationMethod rdf:type rdf:Property ;
    rdfs:label 'Evidence Generation Method' ;
    rdfs:comment 'Primary methodology or data collection approach planned to answer this learning question. Includes Focus Group Discussion (FGD), Key Informant Interview (KII), Post-Distribution Monitoring (PDM), and other Monitoring Evaluation and Learning (MEL) methods. [ENUM-REF-CANDIDATE: quantitative_survey|qualitative_interview|focus_group_discussion|key_informant_interview|post_distribution_monitoring|case_study|mixed_methods|secondary_data_analysis|participatory_assessment — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LearningAgenda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningAgendaStatus rdf:type rdf:Property ;
    rdfs:label 'Learning Agenda Status' ;
    rdfs:comment 'Current lifecycle status of this learning agenda item. Tracks progression from planning through evidence generation to completion. Supports Monitoring Evaluation Accountability and Learning (MEAL) accountability. [ENUM-REF-CANDIDATE: draft|approved|in_progress|data_collection|analysis|completed|on_hold|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LearningAgenda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningQuestionIdentifier rdf:type rdf:Property ;
    rdfs:label 'Learning Question Identifier' ;
    rdfs:comment 'Externally-known unique code or number assigned to this learning question for tracking and reporting purposes. Format: LQ- followed by alphanumeric code.' ;
    rdfs:domain ind:LearningAgenda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningQuestionText rdf:type rdf:Property ;
    rdfs:label 'Learning Question Text' ;
    rdfs:comment 'The full text of the priority learning question or knowledge gap that this agenda item seeks to address. Defines the core inquiry driving evidence generation.' ;
    rdfs:domain ind:LearningAgenda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningQuestionType rdf:type rdf:Property ;
    rdfs:label 'Learning Question Type' ;
    rdfs:comment 'Classification of the learning question based on the Development Assistance Committee (DAC) evaluation criteria or Results-Based Management (RBM) framework. Indicates the dimension of program performance being examined.' ;
    rdfs:domain ind:LearningAgenda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Target date by which evidence generation and analysis for this learning question should be completed. Critical for adaptive management and donor reporting cycles.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rationale rdf:type rdf:Property ;
    rdfs:label 'Rationale' ;
    rdfs:comment 'Detailed explanation of why this learning question is a priority, including the evidence gap, strategic importance, and expected contribution to adaptive management or organizational learning.' ;
    rdfs:domain ind:LearningAgenda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPlanId rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Id' ;
    rdfs:comment 'Foreign key linking to program.budget_plan. Business justification: MEL budget reconciliation requires linking meal_plan.budget_allocated to source program.budget_plan for variance analysis, donor reporting, and financial compliance. Real business process: quarterly M' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetPlan .

ind:primaryMealStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Meal Staff Member Id' ;
    rdfs:comment 'Reference to the MEL staff member who is the lead or primary responsible party for implementing this MEAL plan.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accountabilityMechanisms rdf:type rdf:Property ;
    rdfs:label 'Accountability Mechanisms' ;
    rdfs:comment 'Description of accountability mechanisms embedded in the MEAL plan, including beneficiary feedback channels, complaint response mechanisms, and Core Humanitarian Standard (CHS) commitments.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Completion Date' ;
    rdfs:comment 'Date when the baseline assessment was completed. Baseline data provides the starting point for measuring program outcomes and impact.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiaryFeedbackChannels rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Feedback Channels' ;
    rdfs:comment 'Description of channels through which beneficiaries can provide feedback, complaints, and suggestions, including hotlines, suggestion boxes, community meetings, and digital platforms.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chsCommitmentAlignment rdf:type rdf:Property ;
    rdfs:label 'Chs Commitment Alignment' ;
    rdfs:comment 'Description of how this MEAL plan aligns with and monitors the nine Core Humanitarian Standard commitments to communities and people affected by crisis.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dacCriteriaCoverage rdf:type rdf:Property ;
    rdfs:label 'Dac Criteria Coverage' ;
    rdfs:comment 'Description of which DAC evaluation criteria (relevance, coherence, effectiveness, efficiency, impact, sustainability) are addressed in this MEAL plan and how they will be assessed.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionTools rdf:type rdf:Property ;
    rdfs:label 'Data Collection Tools' ;
    rdfs:comment 'List of digital and paper-based tools and platforms to be used for data collection, such as KoboToolbox, CommCare, ODK, DHIS2, mobile data collection apps, and paper forms.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataDisaggregationPlan rdf:type rdf:Property ;
    rdfs:label 'Data Disaggregation Plan' ;
    rdfs:comment 'Description of how data will be disaggregated for analysis, including by age, gender, disability status, geographic location, and other relevant demographic and vulnerability factors.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataManagementProtocols rdf:type rdf:Property ;
    rdfs:label 'Data Management Protocols' ;
    rdfs:comment 'Description of data management protocols, including data storage, security, privacy, access controls, backup procedures, and compliance with data protection regulations.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityProtocols rdf:type rdf:Property ;
    rdfs:label 'Data Quality Protocols' ;
    rdfs:comment 'Description of data quality assurance and quality control protocols, including validation rules, data cleaning procedures, inter-rater reliability checks, and data verification processes.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorReportingRequirements rdf:type rdf:Property ;
    rdfs:label 'Donor Reporting Requirements' ;
    rdfs:comment 'Description of specific donor reporting requirements that this MEAL plan must satisfy, including report formats, indicators, frequency, and submission deadlines.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endlinePlannedDate rdf:type rdf:Property ;
    rdfs:label 'Endline Planned Date' ;
    rdfs:comment 'Planned date for the endline evaluation. Endline evaluations measure final outcomes and impact at the conclusion of the program cycle.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ethicalConsiderations rdf:type rdf:Property ;
    rdfs:label 'Ethical Considerations' ;
    rdfs:comment 'Description of ethical considerations and safeguards in data collection and evaluation, including informed consent procedures, do-no-harm principles, and protection of vulnerable populations.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationStrategy rdf:type rdf:Property ;
    rdfs:label 'Evaluation Strategy' ;
    rdfs:comment 'Description of the evaluation strategy, including planned evaluations (baseline, midline, endline), evaluation questions, methodologies, and timing aligned with DAC criteria.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningAgenda rdf:type rdf:Property ;
    rdfs:label 'Learning Agenda' ;
    rdfs:comment 'Description of the learning agenda, including key learning questions, knowledge management activities, and how learning will be captured and disseminated to inform adaptive management.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Mel Team Members' ;
    rdfs:comment 'Comma-separated list or description of MEL team members and their roles in implementing the MEAL plan, including data collectors, analysts, and coordinators.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:midlinePlannedDate rdf:type rdf:Property ;
    rdfs:label 'Midline Planned Date' ;
    rdfs:comment 'Planned date for the midline evaluation. Midline evaluations assess progress toward outcomes at the midpoint of the program cycle.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringStrategy rdf:type rdf:Property ;
    rdfs:label 'Monitoring Strategy' ;
    rdfs:comment 'Comprehensive description of the monitoring strategy, including frequency, methods, data sources, and responsible parties for ongoing program monitoring.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planTitle rdf:type rdf:Property ;
    rdfs:label 'Plan Title' ;
    rdfs:comment 'The official title or name of the MEAL plan document. Used for identification and reference in donor reports and internal documentation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version number or identifier for this iteration of the MEAL plan. Tracks revisions and updates to the plan over the program lifecycle.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rbmFrameworkAlignment rdf:type rdf:Property ;
    rdfs:label 'Rbm Framework Alignment' ;
    rdfs:comment 'Description of how this MEAL plan aligns with the organization\'s Results-Based Management framework and donor RBM requirements.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCalendar rdf:type rdf:Property ;
    rdfs:label 'Reporting Calendar' ;
    rdfs:comment 'Description of the reporting calendar, including frequency and timing of internal reports, donor reports, Situation Reports (SitRep), and other MEL deliverables.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionHistory rdf:type rdf:Property ;
    rdfs:label 'Revision History' ;
    rdfs:comment 'Summary of major revisions and amendments to the MEAL plan over its lifecycle, including dates and reasons for changes.' ;
    rdfs:domain ind:MealPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Plan' ;
    rdfs:comment 'Description of risks to MEL implementation (e.g., access constraints, security incidents, data quality issues) and mitigation strategies.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tocNarrative rdf:type rdf:Property ;
    rdfs:label 'Toc Narrative' ;
    rdfs:comment 'Narrative description of the Theory of Change that underpins this MEAL plan. Explains the causal pathway from inputs to impact and the assumptions being tested.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentLogframeMelLogframeId rdf:type rdf:Property ;
    rdfs:label 'Parent Logframe Mel Logframe Id' ;
    rdfs:comment 'Self-referencing foreign key to the parent LogFrame entry in the hierarchy. Enables nested results chains where outputs roll up to outcomes, outcomes to goals.' ;
    rdfs:domain ind:MelLogframe ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MelLogframe .

ind:responsibleStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Responsible Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Logframes track responsible_party as text but MEL accountability frameworks and donor reporting (USAID, FCDO) require linking to actual staff member for performance management and results framework ow' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'Date of the most recent actual measurement. Used to track reporting currency and identify data staleness.' ;
    rdfs:domain ind:MelLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'Most recent measured or reported value for the indicator. Updated through Monitoring Evaluation and Learning (MEL) data collection activities such as Post-Distribution Monitoring (PDM), Focus Group Discussions (FGD), or District Health Information System 2 (DHIS2) reporting.' ;
    rdfs:domain ind:MelLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dacEvaluationCriterion rdf:type rdf:Property ;
    rdfs:label 'Dac Evaluation Criterion' ;
    rdfs:comment 'Development Assistance Committee (DAC) evaluation criterion that this LogFrame element addresses. Used to align program design with international evaluation standards.' ;
    rdfs:domain ind:MelLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorTemplateType rdf:type rdf:Property ;
    rdfs:label 'Donor Template Type' ;
    rdfs:comment 'Identifies the donor-specific logical framework template or format used. Different donors require different LogFrame structures and terminology. [ENUM-REF-CANDIDATE: DFID|FCDO|USAID|EU|ECHO|UN|World Bank|Generic|Other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MelLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchySequence rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Sequence' ;
    rdfs:comment 'Numeric ordering within the results chain hierarchy. Used to maintain the logical sequence of goals, outcomes, outputs, and activities.' ;
    rdfs:domain ind:MelLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interventionStatement rdf:type rdf:Property ;
    rdfs:label 'Intervention Statement' ;
    rdfs:comment 'Narrative description of the intervention logic at this level of the results chain. Describes what the program intends to achieve or deliver.' ;
    rdfs:domain ind:MelLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomIndicator rdf:type rdf:Property ;
    rdfs:label 'Is Custom Indicator' ;
    rdfs:comment 'Flag indicating whether this is a custom indicator defined by the implementing organization rather than a standard donor or sector indicator.' ;
    rdfs:domain ind:MelLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatoryDonorIndicator rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory Donor Indicator' ;
    rdfs:comment 'Flag indicating whether this indicator is a mandatory reporting requirement from the donor. Mandatory indicators cannot be modified without prior approval.' ;
    rdfs:domain ind:MelLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logframeCode rdf:type rdf:Property ;
    rdfs:label 'Logframe Code' ;
    rdfs:comment 'Business identifier or reference code for the logical framework, often aligned with donor proposal numbering or internal program codes.' ;
    rdfs:domain ind:MelLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logframeName rdf:type rdf:Property ;
    rdfs:label 'Logframe Name' ;
    rdfs:comment 'Descriptive name or title of the logical framework, typically reflecting the program or intervention name.' ;
    rdfs:domain ind:MelLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meansOfVerification rdf:type rdf:Property ;
    rdfs:label 'Means Of Verification' ;
    rdfs:comment 'Data source or method by which the indicator will be measured and verified. Examples include surveys, administrative records, Post-Distribution Monitoring (PDM), or District Health Information System 2 (DHIS2) reports.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melLogframeStatus rdf:type rdf:Property ;
    rdfs:label 'Mel Logframe Status' ;
    rdfs:comment 'Current status of this LogFrame element in its lifecycle. Tracks whether targets are being met and whether the intervention logic remains valid. [ENUM-REF-CANDIDATE: Draft|Active|On Track|At Risk|Behind Schedule|Achieved|Closed|Cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MelLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectivelyVerifiableIndicator rdf:type rdf:Property ;
    rdfs:label 'Objectively Verifiable Indicator' ;
    rdfs:comment 'The measurable indicator that will be used to verify achievement of this results chain level. Links to the indicator library for tracking.' ;
    rdfs:domain ind:MelLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Organization or team responsible for delivering this results chain element. May be the International Non-Governmental Organization (INGO), a Community-Based Organization (CBO), or a consortium partner.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultsChainLevel rdf:type rdf:Property ;
    rdfs:label 'Results Chain Level' ;
    rdfs:comment 'Hierarchical level within the results chain that this LogFrame row represents. Defines whether this is a goal, outcome, output, or activity level entry. [ENUM-REF-CANDIDATE: Goal|Impact|Purpose|Outcome|Output|Activity|Input — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MelLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoryOfChangeComponent rdf:type rdf:Property ;
    rdfs:label 'Theory Of Change Component' ;
    rdfs:comment 'Identifies which component of the Theory of Change (ToC) this LogFrame row represents. Links the LogFrame to the broader causal pathway and intervention logic.' ;
    rdfs:domain ind:MelLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melNeedsAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Mel Needs Assessment Id' ;
    rdfs:comment 'Unique identifier for the needs assessment record. Primary key.' ;
    rdfs:domain ind:MelNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMelStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Mel Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who led the needs assessment field team and is responsible for data quality.' ;
    rdfs:domain ind:MelNeedsAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:educationNeedsPriority rdf:type rdf:Property ;
    rdfs:label 'Education Needs Priority' ;
    rdfs:comment 'Priority ranking of education and learning needs identified in the assessment.' ;
    rdfs:domain ind:MelNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReportUrl rdf:type rdf:Property ;
    rdfs:label 'External Report Url' ;
    rdfs:comment 'URL link to the published needs assessment report or dataset on external platforms (e.g., Humanitarian Data Exchange, ReliefWeb, organizational website).' ;
    rdfs:domain ind:MelNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gamRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Gam Rate Percentage' ;
    rdfs:comment 'Percentage of children under 5 years with Global Acute Malnutrition (weight-for-height Z-score < -2 or Mid-Upper Arm Circumference (MUAC) < 125mm or bilateral pitting edema) identified in the assessment. GAM rates above 15% indicate a critical nutrition emergency.' ;
    rdfs:domain ind:MelNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthNeedsPriority rdf:type rdf:Property ;
    rdfs:label 'Health Needs Priority' ;
    rdfs:comment 'Priority ranking of health service and medical needs identified in the assessment.' ;
    rdfs:domain ind:MelNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdsAssessed rdf:type rdf:Property ;
    rdfs:label 'Households Assessed' ;
    rdfs:comment 'Total number of households surveyed or included in the needs assessment sample.' ;
    rdfs:domain ind:MelNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:muacScreeningCount rdf:type rdf:Property ;
    rdfs:label 'Muac Screening Count' ;
    rdfs:comment 'Number of children screened using Mid-Upper Arm Circumference (MUAC) measurement during the needs assessment.' ;
    rdfs:domain ind:MelNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nutritionNeedsPriority rdf:type rdf:Property ;
    rdfs:label 'Nutrition Needs Priority' ;
    rdfs:comment 'Priority ranking of nutrition and food security needs identified in the assessment.' ;
    rdfs:domain ind:MelNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationAssessed rdf:type rdf:Property ;
    rdfs:label 'Population Assessed' ;
    rdfs:comment 'Total number of individuals in the target population covered by the needs assessment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protectionNeedsPriority rdf:type rdf:Property ;
    rdfs:label 'Protection Needs Priority' ;
    rdfs:comment 'Priority ranking of protection needs including Gender-Based Violence (GBV), child protection, and psychosocial support identified in the assessment.' ;
    rdfs:domain ind:MelNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Sam Rate Percentage' ;
    rdfs:comment 'Percentage of children under 5 years with Severe Acute Malnutrition (weight-for-height Z-score < -3 or MUAC < 115mm or bilateral pitting edema) identified in the assessment. SAM rates above 2% indicate a critical nutrition emergency.' ;
    rdfs:domain ind:MelNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelterNeedsPriority rdf:type rdf:Property ;
    rdfs:label 'Shelter Needs Priority' ;
    rdfs:comment 'Priority ranking of shelter and housing needs identified in the assessment.' ;
    rdfs:domain ind:MelNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Status of the needs assessment data validation and quality assurance review process.' ;
    rdfs:domain ind:MelNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:washNeedsPriority rdf:type rdf:Property ;
    rdfs:label 'Wash Needs Priority' ;
    rdfs:comment 'Priority ranking of Water, Sanitation, and Hygiene needs identified in the assessment. Critical indicates immediate life-threatening gaps; high indicates urgent but not immediately life-threatening; medium and low indicate longer-term development needs.' ;
    rdfs:domain ind:MelNeedsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualitativeRecordId rdf:type rdf:Property ;
    rdfs:label 'Qualitative Record Id' ;
    rdfs:comment 'Primary key for qualitative_record' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryQualitativeStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Qualitative Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who facilitated the FGD or conducted the KII.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:quaternaryQualitativeReviewedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Qualitative Reviewed By Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the MEL staff member who reviewed and validated the qualitative data collection record.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:tertiaryQualitativeTranslatorStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Qualitative Translator Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member or volunteer who provided translation services during the session.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:collectionEndTime rdf:type rdf:Property ;
    rdfs:label 'Collection End Time' ;
    rdfs:comment 'Timestamp when the qualitative data collection session ended.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:collectionMethodType rdf:type rdf:Property ;
    rdfs:label 'Collection Method Type' ;
    rdfs:comment 'Type of qualitative data collection method used. FGD = Focus Group Discussion, KII = Key Informant Interview, MSC = Most Significant Change.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStartTime rdf:type rdf:Property ;
    rdfs:label 'Collection Start Time' ;
    rdfs:comment 'Timestamp when the qualitative data collection session began.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataQualityRating rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rating' ;
    rdfs:comment 'Assessment of the quality of the qualitative data collected, based on completeness, clarity, and reliability.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informantOrganization rdf:type rdf:Property ;
    rdfs:label 'Informant Organization' ;
    rdfs:comment 'Organization or institution the key informant represents (for KIIs), e.g., Ministry of Health, local CBO, partner NGO.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informantRole rdf:type rdf:Property ;
    rdfs:label 'Informant Role' ;
    rdfs:comment 'Role or position of the key informant (for KIIs), e.g., community leader, health worker, teacher, local government official.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informedConsentObtained rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Obtained' ;
    rdfs:comment 'Indicates whether informed consent was obtained from all participants prior to the qualitative data collection.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyThemesEmerging rdf:type rdf:Property ;
    rdfs:label 'Key Themes Emerging' ;
    rdfs:comment 'Summary of key themes, patterns, or insights that emerged from the qualitative data collection session.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageUsed rdf:type rdf:Property ;
    rdfs:label 'Language Used' ;
    rdfs:comment 'Primary language used during the qualitative data collection session.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantAgeGroupDistribution rdf:type rdf:Property ;
    rdfs:label 'Participant Age Group Distribution' ;
    rdfs:comment 'Distribution of participants by age group (e.g., 0-5: 2, 6-17: 5, 18-59: 8, 60+: 3). Free-text summary of age disaggregation.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantCount rdf:type rdf:Property ;
    rdfs:label 'Participant Count' ;
    rdfs:comment 'Total number of participants in the qualitative data collection event (for FGDs) or 1 for KIIs.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantFemaleCount rdf:type rdf:Property ;
    rdfs:label 'Participant Female Count' ;
    rdfs:comment 'Number of female participants in the qualitative data collection event.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantMaleCount rdf:type rdf:Property ;
    rdfs:label 'Participant Male Count' ;
    rdfs:comment 'Number of male participants in the qualitative data collection event.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantOtherGenderCount rdf:type rdf:Property ;
    rdfs:label 'Participant Other Gender Count' ;
    rdfs:comment 'Number of participants identifying as other gender in the qualitative data collection event.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTheme rdf:type rdf:Property ;
    rdfs:label 'Primary Theme' ;
    rdfs:comment 'Primary theme or topic area explored in the qualitative data collection (e.g., access to services, community perceptions, program satisfaction).' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualitativeRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Qualitative Record Status' ;
    rdfs:comment 'Current lifecycle status of the qualitative data collection record.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingConsentObtained rdf:type rdf:Property ;
    rdfs:label 'Recording Consent Obtained' ;
    rdfs:comment 'Indicates whether explicit consent was obtained from participants to record the session (audio or video).' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordingMethod rdf:type rdf:Property ;
    rdfs:label 'Recording Method' ;
    rdfs:comment 'Method used to record the qualitative data collection session (e.g., audio recording, written notes, digital form).' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topicGuideUsed rdf:type rdf:Property ;
    rdfs:label 'Topic Guide Used' ;
    rdfs:comment 'Name or identifier of the topic guide, interview protocol, or discussion guide used for the qualitative data collection.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationRequired rdf:type rdf:Property ;
    rdfs:label 'Translation Required' ;
    rdfs:comment 'Indicates whether translation or interpretation services were required during the qualitative data collection.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verbatimQuotes rdf:type rdf:Property ;
    rdfs:label 'Verbatim Quotes' ;
    rdfs:comment 'Selected verbatim quotes from participants or key informants that illustrate key findings or themes. Confidential to protect participant identity.' ;
    rdfs:domain ind:QualitativeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Agreement Amendment Id' ;
    rdfs:comment 'Unique system-generated identifier for each formal modification record to a partnership agreement. Serves as the primary key for the agreement_amendment entity.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAgreementStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Agreement Staff Member Id' ;
    rdfs:comment 'Reference to the staff member record of the individual who formally approved this amendment. Links to the workforce domain for accountability and audit trail purposes.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:amendmentTitle rdf:type rdf:Property ;
    rdfs:label 'Amendment Title' ;
    rdfs:comment 'Short descriptive title summarizing the purpose of the amendment (e.g., \'No-Cost Extension to December 2025\', \'Budget Realignment Q3 2024\'). Used in correspondence, dashboards, and partner communications.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryTargetChange rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Target Change' ;
    rdfs:comment 'Indicates whether this amendment modifies the target beneficiary numbers, population groups, or vulnerability criteria for the program. True = beneficiary targets modified; False = no change. Relevant for MEL/MEAL reporting and SDG indicator tracking.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Change Amount' ;
    rdfs:comment 'The net monetary change to the agreement budget introduced by this amendment (revised_budget_amount minus original_budget_amount). Positive values indicate budget increases; negative values indicate reductions. Null for non-financial amendments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clausesModified rdf:type rdf:Property ;
    rdfs:label 'Clauses Modified' ;
    rdfs:comment 'Enumeration or description of the specific agreement clauses, articles, or sections that are modified by this amendment (e.g., \'Article 3 — Scope of Work, Article 7 — Budget\'). Supports legal review and compliance tracking.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionDurationDays rdf:type rdf:Property ;
    rdfs:label 'Extension Duration Days' ;
    rdfs:comment 'Number of calendar days by which the period of performance is extended by this amendment. Null for non-extension amendments. Used for program planning, resource allocation, and donor reporting on timeline changes.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicScopeChange rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope Change' ;
    rdfs:comment 'Indicates whether this amendment modifies the geographic coverage or operational areas of the agreement (e.g., adding or removing districts, countries, or OCHA cluster areas). True = geographic scope modified; False = no geographic change.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmsReference rdf:type rdf:Property ;
    rdfs:label 'Gms Reference' ;
    rdfs:comment 'External reference identifier for this amendment as recorded in the Grant Management System (GMS) or donor\'s award management platform (e.g., USAID ASIST, DFID ARIES). Enables cross-system reconciliation and donor audit support.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatiActivityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Iati Activity Identifier' ;
    rdfs:comment 'IATI-standard activity identifier associated with the parent agreement, used to publish amendment data to the IATI Registry for transparency and open data compliance. Format follows IATI hierarchical identifier standard.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ngoSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Ngo Signatory Name' ;
    rdfs:comment 'Full name of the authorized representative of Ngo who signs this amendment on behalf of the organization. Required for legal enforceability and signatory change tracking.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Original Budget Amount' ;
    rdfs:comment 'The total authorized budget of the agreement prior to this amendment, expressed in the agreement currency. Retained for Budget versus Actual (BvA) analysis and audit trail of financial modifications.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Partner Signatory Name' ;
    rdfs:comment 'Full name of the authorized representative of the partner organization who signs this amendment on behalf of the CSO, CBO, INGO, government body, or UN agency. Required for signatory change amendments and legal enforceability.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedBeneficiaryTarget rdf:type rdf:Property ;
    rdfs:label 'Revised Beneficiary Target' ;
    rdfs:comment 'Updated total number of direct beneficiaries targeted under the agreement following this amendment. Null if beneficiary_target_change is False. Used for MEL/MEAL indicator tracking and donor results reporting.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Budget Amount' ;
    rdfs:comment 'The total authorized budget of the agreement as updated by this amendment. Null if this amendment does not modify the budget. Used for BvA reporting and donor financial compliance.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'The date on which the amendment request was formally submitted to the approval authority or donor/prime for review. Used to track processing timelines and compliance with advance notification requirements under 2 CFR 200.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryCapacityStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Capacity Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or consultant who led the capacity assessment process. Used for accountability, quality assurance, and audit trail purposes.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:priorAssessmentCapacityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Prior Assessment Capacity Assessment Id' ;
    rdfs:comment 'Reference to the immediately preceding capacity assessment record for the same partner, enabling longitudinal tracking of capacity development progress over time.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityAssessment .

ind:assessmentLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Assessment Location Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the country where the capacity assessment was physically conducted. Relevant for field-based assessments of local partners.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReportUrl rdf:type rdf:Property ;
    rdfs:label 'Assessment Report Url' ;
    rdfs:comment 'URL or document management system path to the full capacity assessment report. Classified as confidential due to sensitive organizational information about the partner.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScope rdf:type rdf:Property ;
    rdfs:label 'Assessment Scope' ;
    rdfs:comment 'Indicates the depth and modality of the assessment: FULL (comprehensive on-site assessment covering all functional areas), ABBREVIATED (targeted review of selected areas), DESK_REVIEW (document-based review without site visit), FIELD_VISIT (on-site verification component).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityBuildingPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Capacity Building Plan Required' ;
    rdfs:comment 'Indicates whether the assessment results mandate the development of a formal capacity-building plan (True) or whether the partner\'s capacity is sufficient without a structured intervention plan (False).' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enhancedMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Enhanced Monitoring Required' ;
    rdfs:comment 'Indicates whether the assessment outcome requires enhanced programmatic or financial monitoring of the partner (True), such as more frequent reporting, additional site visits, or pre-approval of expenditures, as mandated by donor regulations.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialMgmtScore rdf:type rdf:Property ;
    rdfs:label 'Financial Mgmt Score' ;
    rdfs:comment 'Numeric score assigned to the partner\'s financial management functional area, covering accounting systems, internal controls, audit compliance, and fund stewardship. Typically scored on a 0–100 or 1–5 scale per the assessment methodology.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialRiskRating rdf:type rdf:Property ;
    rdfs:label 'Financial Risk Rating' ;
    rdfs:comment 'Specific risk rating for the partner\'s financial management functional area, used to determine sub-award monitoring intensity, payment modality, and required financial controls.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceScore rdf:type rdf:Property ;
    rdfs:label 'Governance Score' ;
    rdfs:comment 'Numeric score for the partner\'s organizational governance functional area, including board oversight, legal registration, organizational policies, and leadership accountability.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hrMgmtScore rdf:type rdf:Property ;
    rdfs:label 'Hr Mgmt Score' ;
    rdfs:comment 'Numeric score for the partner\'s human resources management functional area, including HR policies, recruitment practices, staff development, and safeguarding compliance.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itSystemsScore rdf:type rdf:Property ;
    rdfs:label 'It Systems Score' ;
    rdfs:comment 'Numeric score for the partner\'s ICT4D and information systems functional area, covering data management infrastructure, cybersecurity practices, and digital reporting capabilities.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadAssessorOrganization rdf:type rdf:Property ;
    rdfs:label 'Lead Assessor Organization' ;
    rdfs:comment 'Name of the organization to which the lead assessor belongs (e.g., the NGO\'s headquarters, an independent consulting firm, or a donor agency). Relevant when external assessors are engaged.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melScore rdf:type rdf:Property ;
    rdfs:label 'Mel Score' ;
    rdfs:comment 'Numeric score for the partner\'s Monitoring, Evaluation, and Learning (MEL) functional area, covering data collection systems, indicator tracking, reporting quality, and learning practices.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRiskRating rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Rating' ;
    rdfs:comment 'Categorical risk classification assigned to the partner based on the capacity assessment results: LOW (strong capacity, minimal oversight needed), MEDIUM (adequate capacity with some gaps), HIGH (significant capacity gaps requiring intensive support), CRITICAL (fundamental weaknesses posing fiduciary or programmatic risk).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Composite numeric score representing the partner\'s overall organizational capacity across all assessed functional areas. Calculated per the assessment methodology\'s weighting scheme and recorded as the official assessment result.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerSelfAssessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Partner Self Assessment Completed' ;
    rdfs:comment 'Indicates whether the partner organization completed a self-assessment component prior to or alongside the external assessment (True). Many OCA methodologies include a parallel self-assessment to identify perception gaps.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerSelfAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Partner Self Assessment Score' ;
    rdfs:comment 'Overall score submitted by the partner organization in their self-assessment component. Compared against the external assessor\'s score to identify perception gaps and inform capacity-building dialogue.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentModalityRecommendation rdf:type rdf:Property ;
    rdfs:label 'Payment Modality Recommendation' ;
    rdfs:comment 'Payment modality recommended for sub-award disbursements based on the partner\'s financial risk rating: ADVANCE (funds transferred before expenditure), REIMBURSEMENT (funds transferred after expenditure documentation), DIRECT_PAYMENT (NGO pays vendors directly on partner\'s behalf), MIXED (combination of modalities).' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementScore rdf:type rdf:Property ;
    rdfs:label 'Procurement Score' ;
    rdfs:comment 'Numeric score for the partner\'s procurement and supply chain management functional area, covering procurement policies, competitive bidding, vendor management, and asset control.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programMgmtScore rdf:type rdf:Property ;
    rdfs:label 'Program Mgmt Score' ;
    rdfs:comment 'Numeric score for the partner\'s program design and management functional area, including project planning, implementation capacity, beneficiary targeting, and service delivery quality.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedInterventions rdf:type rdf:Property ;
    rdfs:label 'Recommended Interventions' ;
    rdfs:comment 'Narrative description of the specific capacity-building interventions recommended based on assessment findings, such as financial management training, procurement system upgrades, MEL system strengthening, or governance policy development.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreScaleMax rdf:type rdf:Property ;
    rdfs:label 'Score Scale Max' ;
    rdfs:comment 'The maximum possible score on the scoring scale used by the assessment methodology (e.g., 100 for percentage-based scales, 5 for Likert-based scales). Required to normalize scores across different methodologies for comparative analytics.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityBuildingActivityId rdf:type rdf:Property ;
    rdfs:label 'Capacity Building Activity Id' ;
    rdfs:comment 'Unique system-generated identifier for each capacity-building activity record delivered to a partner organization. Serves as the primary key for this entity. Entity role: TRANSACTION_HEADER — a discrete, trackable business event with its own lifecycle.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityCostUsd rdf:type rdf:Property ;
    rdfs:label 'Activity Cost Usd' ;
    rdfs:comment 'Total direct cost incurred to deliver this capacity-building activity, expressed in US Dollars. Includes facilitator fees, venue, materials, and travel. Used for Budget versus Actual (BvA) tracking and cost-effectiveness analysis under OMB Uniform Guidance 2 CFR 200.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activityReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Activity Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this capacity-building activity, used in partner communications, donor reports, and IATI disclosures. Format: CBA-{COUNTRY}-{YEAR}-{SEQUENCE}. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityTitle rdf:type rdf:Property ;
    rdfs:label 'Activity Title' ;
    rdfs:comment 'Descriptive title of the capacity-building activity (e.g., \'Financial Management Training for Partner Finance Officers\', \'MEAL System Technical Assistance Visit\'). Used in reports and partner communications.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The real-world date on which the capacity-building activity was delivered or commenced. The principal business event date for this transaction. Satisfies TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityDomain rdf:type rdf:Property ;
    rdfs:label 'Capacity Domain' ;
    rdfs:comment 'High-level domain of organizational capacity being strengthened through this activity, aligned with standard capacity assessment frameworks. Used for portfolio-level gap analysis and Theory of Change (ToC) alignment.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the accrediting or certifying body that issued the certificate for this activity (e.g., \'CHS Alliance\', \'SPHERE Association\', \'USAID\', \'Internal\'). Populated only when is_certified is True.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionRatePct rdf:type rdf:Property ;
    rdfs:label 'Completion Rate Pct' ;
    rdfs:comment 'Percentage of registered participants who completed the full capacity-building activity (attended all sessions or met minimum attendance threshold). Key MEL indicator for activity quality and partner engagement.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryMode rdf:type rdf:Property ;
    rdfs:label 'Delivery Mode' ;
    rdfs:comment 'Mode through which the capacity-building activity was delivered to participants. Distinguishes face-to-face field visits from remote or blended approaches, relevant for cost analysis and ICT4D reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total number of contact hours delivered during this capacity-building activity. Used for MEL indicator reporting (e.g., total training hours delivered to partners) and cost-per-hour analysis.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilitatorType rdf:type rdf:Property ;
    rdfs:label 'Facilitator Type' ;
    rdfs:comment 'Classification of the entity or individual who facilitated the capacity-building activity. Distinguishes internal staff-led sessions from externally contracted consultants or peer-learning facilitated by other NGOs or UN agencies.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackCollected rdf:type rdf:Property ;
    rdfs:label 'Feedback Collected' ;
    rdfs:comment 'Indicates whether participant feedback or a post-distribution monitoring (PDM) equivalent survey was collected for this capacity-building activity. Supports accountability and learning (MEAL) requirements.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:femaleParticipants rdf:type rdf:Property ;
    rdfs:label 'Female Participants' ;
    rdfs:comment 'Number of female participants in this capacity-building activity. Required for gender disaggregation reporting per USAID Gender Equality Policy, DFID guidelines, and SDG 5 indicators.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCertified rdf:type rdf:Property ;
    rdfs:label 'Is Certified' ;
    rdfs:comment 'Indicates whether a certificate of completion or competency was issued to participants upon successful completion of this capacity-building activity. Relevant for accredited training programs and professional development tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedCapacityGap rdf:type rdf:Property ;
    rdfs:label 'Linked Capacity Gap' ;
    rdfs:comment 'Description or reference code of the specific capacity gap identified in the partner\'s capacity assessment that this activity is designed to address. Enables traceability from gap identification to intervention delivery.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maleParticipants rdf:type rdf:Property ;
    rdfs:label 'Male Participants' ;
    rdfs:comment 'Number of male participants in this capacity-building activity. Required for gender disaggregation reporting per USAID Gender Equality Policy and SDG 5 indicators.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialsProvided rdf:type rdf:Property ;
    rdfs:label 'Materials Provided' ;
    rdfs:comment 'Indicates whether training materials, toolkits, manuals, or job aids were distributed to participants as part of this capacity-building activity. Relevant for resource tracking and follow-up support planning.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:participantSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Participant Satisfaction Score' ;
    rdfs:comment 'Average satisfaction rating provided by participants in post-activity feedback forms, typically on a scale of 1–5 or 1–10. Used for activity quality improvement and facilitator performance assessment.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Post Assessment Score' ;
    rdfs:comment 'Average knowledge or competency assessment score recorded for participants after the capacity-building activity concluded. Compared against pre-assessment score to measure learning gain and activity effectiveness.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Pre Assessment Score' ;
    rdfs:comment 'Average knowledge or competency assessment score recorded for participants before the capacity-building activity commenced. Used to establish a baseline for measuring learning gain. Expressed as a percentage (0–100). Satisfies TRANSACTION_HEADER QUANTITATIVE_RESULT category (non-monetary).' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned date on which the capacity-building activity was originally scheduled to conclude. Used for duration planning and workplan management.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date on which the capacity-building activity was originally scheduled to begin. Used for planning, calendar management, and variance analysis against actual delivery.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:topicsCovered rdf:type rdf:Property ;
    rdfs:label 'Topics Covered' ;
    rdfs:comment 'Free-text or structured description of the specific topics, modules, or competencies addressed during the activity (e.g., \'Budget vs Actual reporting, SAP navigation, donor compliance rules\'). Supports curriculum documentation and knowledge management.' ;
    rdfs:domain ind:CapacityBuildingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProgramId rdf:type rdf:Property ;
    rdfs:label 'Training Program Id' ;
    rdfs:comment 'Foreign key linking to safeguarding.training_program. Business justification: Capacity building plans specify safeguarding training programs to address partner capacity gaps identified in assessments. Links planned interventions to standardized training curriculum for implement' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingProgram .

ind:baselineCapacityScore rdf:type rdf:Property ;
    rdfs:label 'Baseline Capacity Score' ;
    rdfs:comment 'Numeric score representing the partner organization\'s overall organizational capacity at the time of the baseline assessment, prior to plan implementation. Typically scored on a standardized scale (e.g., 1–5 or 0–100) per the assessment tool used.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityScoreScale rdf:type rdf:Property ;
    rdfs:label 'Capacity Score Scale' ;
    rdfs:comment 'The scoring scale used for baseline, target, and current capacity scores in this plan (e.g., \'1_to_5\', \'0_to_100\'). Ensures consistent interpretation of scores across different assessment tools and reporting periods.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chsStandardAligned rdf:type rdf:Property ;
    rdfs:label 'Chs Standard Aligned' ;
    rdfs:comment 'Indicates whether this capacity building plan is designed in alignment with the Core Humanitarian Standard (CHS) on Quality and Accountability, ensuring the partner is supported to meet CHS commitments.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentCapacityScore rdf:type rdf:Property ;
    rdfs:label 'Current Capacity Score' ;
    rdfs:comment 'Most recently recorded organizational capacity score for the partner, updated following periodic reassessments or milestone reviews during plan implementation. Enables tracking of progress toward the target capacity score.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Donor Reporting Required' ;
    rdfs:comment 'Indicates whether progress on this capacity building plan must be reported to the donor as part of grant compliance obligations. True = donor reporting required; False = internal plan only.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expenditureToDateUsd rdf:type rdf:Property ;
    rdfs:label 'Expenditure To Date Usd' ;
    rdfs:comment 'Cumulative actual expenditure incurred against this capacity building plan to date, expressed in US Dollars (USD). Used for Budget versus Actual (BvA) tracking and financial stewardship reporting.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:genderMainstreamingIncluded rdf:type rdf:Property ;
    rdfs:label 'Gender Mainstreaming Included' ;
    rdfs:comment 'Indicates whether gender mainstreaming and Gender-Based Violence (GBV) prevention components are explicitly included in this capacity building plan, in line with donor gender policies and SDG (Sustainable Development Goal) 5 commitments.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grandBargainCommitmentRef rdf:type rdf:Property ;
    rdfs:label 'Grand Bargain Commitment Ref' ;
    rdfs:comment 'Reference code or description of the specific Grand Bargain commitment (e.g., Workstream 2 — Localization) that this capacity building plan contributes to. Supports donor accountability and IATI transparency reporting.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationRegion rdf:type rdf:Property ;
    rdfs:label 'Implementation Region' ;
    rdfs:comment 'Sub-national region, state, or province where the partner organization and this capacity building plan are primarily based. Supports geographic disaggregation in MEL dashboards and GIS (Geographic Information System) reporting.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationStrategyAligned rdf:type rdf:Property ;
    rdfs:label 'Localization Strategy Aligned' ;
    rdfs:comment 'Indicates whether this capacity building plan is formally aligned with Ngo\'s localization strategy and Grand Bargain commitments to strengthen local and national actors. True = aligned and documented; False = not formally aligned.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallObjective rdf:type rdf:Property ;
    rdfs:label 'Overall Objective' ;
    rdfs:comment 'High-level statement of the primary objective of this capacity building plan, describing the intended organizational capability improvement to be achieved by the plan\'s end date.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallProgressStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Progress Status' ;
    rdfs:comment 'Qualitative assessment of the overall implementation progress of the capacity building plan relative to the planned timeline and milestones. Distinct from plan_status (lifecycle state); this reflects delivery performance.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerFocalPointName rdf:type rdf:Property ;
    rdfs:label 'Partner Focal Point Name' ;
    rdfs:comment 'Full name of the designated focal point or primary contact person at the partner organization who is responsible for coordinating and participating in capacity building activities under this plan.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerFocalPointTitle rdf:type rdf:Property ;
    rdfs:label 'Partner Focal Point Title' ;
    rdfs:comment 'Job title or role of the partner organization\'s designated focal point for this capacity building plan (e.g., \'Executive Director\', \'Finance Manager\', \'MEL Officer\').' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Plan Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this capacity building plan, used in donor reports, partner correspondence, and IATI disclosures. Format: CBP-[PartnerCode]-[Year]-[Sequence].' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeguardingComponentIncluded rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Component Included' ;
    rdfs:comment 'Indicates whether this capacity building plan includes a dedicated safeguarding (Protection from Sexual Exploitation and Abuse — PSEA) component. Required for compliance with donor safeguarding policies and CHS commitments.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCapacityScore rdf:type rdf:Property ;
    rdfs:label 'Target Capacity Score' ;
    rdfs:comment 'Numeric score representing the desired organizational capacity level to be achieved by the partner organization upon successful completion of this plan. Used to measure progress and plan effectiveness.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetedFunctionalAreas rdf:type rdf:Property ;
    rdfs:label 'Targeted Functional Areas' ;
    rdfs:comment 'Comma-separated list of organizational functional areas targeted by this plan for strengthening, as identified in the capacity assessment. Common values include: financial management, human resources, procurement, governance, MEL (Monitoring Evaluation and Learning), safeguarding, communications, ICT4D (Information and Communication Technology for Development).' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoryOfChangeSummary rdf:type rdf:Property ;
    rdfs:label 'Theory Of Change Summary' ;
    rdfs:comment 'Narrative summary of the Theory of Change (ToC) underpinning this capacity building plan, describing the causal pathway from planned interventions to expected organizational capability improvements and ultimate program outcomes.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalActivitiesCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Activities Completed' ;
    rdfs:comment 'Count of capacity building activity line-items that have been fully delivered and marked as completed under this plan. Used to calculate overall plan completion rate for MEL dashboards and donor reporting.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalActivitiesPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Activities Planned' ;
    rdfs:comment 'Total number of capacity building activity line-items (trainings, mentoring sessions, technical assistance visits, peer learning events) planned under this plan. Used for progress tracking and workload planning.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Total Budget Usd' ;
    rdfs:comment 'Total approved budget allocated for the implementation of this capacity building plan, expressed in US Dollars (USD). Covers all activity costs including training, technical assistance, materials, and facilitator fees.' ;
    rdfs:domain ind:CapacityBuildingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consortiumId rdf:type rdf:Property ;
    rdfs:label 'Consortium Id' ;
    rdfs:comment 'Unique system-generated identifier for the consortium record. Primary key for the consortium master data product within the partnership domain.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consortium .

ind:leadPartnerOrgId rdf:type rdf:Property ;
    rdfs:label 'Lead Partner Org Id' ;
    rdfs:comment 'FK to partnership.partner_org' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerOrg .

ind:ngoFocalPointStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Ngo Focal Point Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Consortium management requires designated NGO staff focal point for coordination, steering committee participation, and member communication. Standard practice in multi-agency humanitarian response co' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:chsComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Chs Compliance Status' ;
    rdfs:comment 'Status of the consortium\'s adherence to the Core Humanitarian Standard (CHS) on Quality and Accountability, assessed through partner due diligence and capacity assessments.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consortiumName rdf:type rdf:Property ;
    rdfs:label 'Consortium Name' ;
    rdfs:comment 'Official full name of the multi-partner consortium or joint programming arrangement as registered with the lead donor or coordinating body (e.g., OCHA cluster).' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consortiumType rdf:type rdf:Property ;
    rdfs:label 'Consortium Type' ;
    rdfs:comment 'Classification of the consortium arrangement indicating Ngo\'s role and the structural form. Lead_agency means Ngo is the prime recipient; member means Ngo is a sub-partner; pooled_fund indicates a CERF or similar mechanism. [ENUM-REF-CANDIDATE: lead_agency|member|co_implementer|pooled_fund|consortium_of_consortia — promote to reference product]' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionMakingProtocol rdf:type rdf:Property ;
    rdfs:label 'Decision Making Protocol' ;
    rdfs:comment 'Formal protocol governing how decisions are made within the consortium. Consensus requires unanimous agreement; majority_vote uses simple majority; lead_agency_authority delegates decisions to the prime recipient; weighted_vote allocates votes by funding share.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDiligenceDate rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Date' ;
    rdfs:comment 'Date on which the most recent due diligence assessment for the consortium was completed. Used to track expiry and schedule renewal per donor compliance requirements.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDiligenceStatus rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Status' ;
    rdfs:comment 'Current status of the due diligence process for the consortium arrangement, covering financial management capacity, safeguarding policies, and anti-terrorism compliance checks.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceStructure rdf:type rdf:Property ;
    rdfs:label 'Governance Structure' ;
    rdfs:comment 'Narrative description of the consortium\'s governance model including steering committee composition, decision-making protocols, voting rights, and escalation procedures as defined in the consortium agreement.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grandBargainLocalization rdf:type rdf:Property ;
    rdfs:label 'Grand Bargain Localization' ;
    rdfs:comment 'Indicates whether this consortium is formally counted toward Ngo\'s Grand Bargain localization commitments, specifically the 25% funding to local and national actors target.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iascWorkingGroup rdf:type rdf:Property ;
    rdfs:label 'Iasc Working Group' ;
    rdfs:comment 'Name of the IASC working group or task force with which this consortium coordinates, relevant for inter-agency humanitarian response planning and joint needs assessments.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Localization Percentage' ;
    rdfs:comment 'Percentage of the total consortium funding envelope directed to local and national CSOs or CBOs as sub-partners, tracked against Grand Bargain 25% localization commitment.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:logframeRef rdf:type rdf:Property ;
    rdfs:label 'Logframe Ref' ;
    rdfs:comment 'Reference identifier or document title of the consortium\'s Logical Framework (LogFrame) used for results-based management (RBM), KPI tracking, and donor reporting.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melFrameworkRef rdf:type rdf:Property ;
    rdfs:label 'Mel Framework Ref' ;
    rdfs:comment 'Reference identifier or document title of the consortium\'s joint MEL (Monitoring Evaluation and Learning) or MEAL (Monitoring Evaluation Accountability and Learning) framework used for collective results measurement.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ngoFundingShare rdf:type rdf:Property ;
    rdfs:label 'Ngo Funding Share' ;
    rdfs:comment 'Portion of the total consortium funding envelope allocated to Ngo, whether as lead agency managing sub-awards or as a sub-partner receiving a sub-grant. Used for BvA (Budget versus Actual) reporting and ICR/NICRA calculations.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ngoRole rdf:type rdf:Property ;
    rdfs:label 'Ngo Role' ;
    rdfs:comment 'Specific role that Ngo plays within this consortium arrangement. Lead_agency means Ngo holds the prime award and manages sub-awards; co_lead means shared leadership; sub_partner means Ngo receives a sub-award from the lead.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ochaClusterAlignment rdf:type rdf:Property ;
    rdfs:label 'Ocha Cluster Alignment' ;
    rdfs:comment 'Name of the OCHA humanitarian cluster(s) or sector working group(s) to which this consortium is formally aligned or co-leads (e.g., WASH Cluster, Food Security Cluster, Health Cluster, Protection Cluster).' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pooledFundMechanism rdf:type rdf:Property ;
    rdfs:label 'Pooled Fund Mechanism' ;
    rdfs:comment 'Name of the pooled funding mechanism associated with the consortium if applicable (e.g., CERF, Country-Based Pooled Fund (CBPF), ECHO, BHA). Supports ODA tracking and joint donor reporting.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceCode rdf:type rdf:Property ;
    rdfs:label 'Reference Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the consortium by the lead donor, OCHA, or internal grant management system (GMS) for cross-system identification and reporting.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or commonly used name or acronym for the consortium used in SitReps, donor reports, and inter-agency communications.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:steeringCommitteeComposition rdf:type rdf:Property ;
    rdfs:label 'Steering Committee Composition' ;
    rdfs:comment 'Description of the steering committee membership including designated representatives from each partner organization, their roles (chair, co-chair, member), and meeting frequency.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thematicFocus rdf:type rdf:Property ;
    rdfs:label 'Thematic Focus' ;
    rdfs:comment 'Primary humanitarian or development sector(s) addressed by the consortium (e.g., WASH, GBV, food security, health, education, PSS). Aligns with OCHA cluster system and IASC sector classifications.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoryOfChangeRef rdf:type rdf:Property ;
    rdfs:label 'Theory Of Change Ref' ;
    rdfs:comment 'Reference identifier or document title of the consortium\'s Theory of Change (ToC) that articulates the causal pathway from inputs and activities to intended outcomes and impact. Used in MEL and MEAL frameworks.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Total Funding Amount' ;
    rdfs:comment 'Total funding envelope committed to the consortium across all member organizations and donor sources, expressed in the reporting currency. Used for Grand Bargain localization tracking and joint donor reporting.' ;
    rdfs:domain ind:Consortium ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consortiumMemberId rdf:type rdf:Property ;
    rdfs:label 'Consortium Member Id' ;
    rdfs:comment 'Unique identifier for the consortium member association record.' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Capacity Assessment Date' ;
    rdfs:comment 'The date when the most recent capacity assessment was conducted for this member organization.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Capacity Assessment Score' ;
    rdfs:comment 'Overall capacity assessment score for this member organization at the time of consortium formation, typically on a scale of 0-100.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionType rdf:type rdf:Property ;
    rdfs:label 'Contribution Type' ;
    rdfs:comment 'The primary type of contribution this member provides to the consortium (financial resources, in-kind goods/services, technical assistance, capacity building, advocacy, coordination).' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDiligenceCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Completion Date' ;
    rdfs:comment 'The date when the due diligence review for this member organization was completed.' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundingAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Funding Allocation Amount' ;
    rdfs:comment 'The absolute monetary amount allocated to this member organization from the consortium budget.' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Funding Allocation Percentage' ;
    rdfs:comment 'The percentage of total consortium funding allocated to this member organization for their scope of work.' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Funding Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the funding allocation amount.' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicResponsibility rdf:type rdf:Property ;
    rdfs:label 'Geographic Responsibility' ;
    rdfs:comment 'The geographic area, region, or administrative unit where this member has primary implementation responsibility within the consortium arrangement.' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Performance Review Date' ;
    rdfs:comment 'The date when the most recent performance review was conducted for this member organization.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingTemplateReference rdf:type rdf:Property ;
    rdfs:label 'Reporting Template Reference' ;
    rdfs:comment 'Reference identifier or name of the standardized reporting template that this member must use for consortium reporting.' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Signing Authority Name' ;
    rdfs:comment 'Full name of the authorized representative from the member organization who signed the consortium agreement or MoU.' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingAuthorityTitle rdf:type rdf:Property ;
    rdfs:label 'Signing Authority Title' ;
    rdfs:comment 'Official title or position of the signing authority within the member organization (e.g., Executive Director, Country Director, Chief Executive Officer).' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingDate rdf:type rdf:Property ;
    rdfs:label 'Signing Date' ;
    rdfs:comment 'The date when the member organization\'s authorized representative signed the consortium agreement or MoU.' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:steeringCommitteeRepresentative rdf:type rdf:Property ;
    rdfs:label 'Steering Committee Representative' ;
    rdfs:comment 'Name of the individual representing this member organization on the consortium steering committee or governance body.' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subAwardAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Sub Award Agreement Number' ;
    rdfs:comment 'Unique identifier or reference number of the sub-award agreement or sub-grant issued to this member organization.' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subAwardType rdf:type rdf:Property ;
    rdfs:label 'Sub Award Type' ;
    rdfs:comment 'The type of legal instrument governing this member\'s participation (sub-grant, sub-contract, MoU - Memorandum of Understanding, LoA - Letter of Agreement, SoW - Scope of Work).' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalWorkingGroupParticipation rdf:type rdf:Property ;
    rdfs:label 'Technical Working Group Participation' ;
    rdfs:comment 'List or description of technical working groups, IASC clusters, or OCHA coordination mechanisms in which this member actively participates on behalf of the consortium.' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thematicResponsibility rdf:type rdf:Property ;
    rdfs:label 'Thematic Responsibility' ;
    rdfs:comment 'The thematic area, sector, or technical domain where this member has primary responsibility (e.g., WASH, health, protection, education, nutrition).' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votingRights rdf:type rdf:Property ;
    rdfs:label 'Voting Rights' ;
    rdfs:comment 'Indicates whether this member organization has voting rights in consortium governance decisions and steering committee meetings.' ;
    rdfs:domain ind:ConsortiumMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ngoLeadRepresentativeStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Ngo Lead Representative Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Coordination meetings require tracking which NGO staff member represented the organization at inter-agency/cluster coordination forums. Essential for accountability, follow-up action assignment, and h' ;
    rdfs:domain ind:CoordinationMeeting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:actionItemsSummary rdf:type rdf:Property ;
    rdfs:label 'Action Items Summary' ;
    rdfs:comment 'Summary of agreed action items arising from the meeting, including responsible parties and target completion dates where recorded. Supports follow-up tracking and accountability.' ;
    rdfs:domain ind:CoordinationMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agendaDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Agenda Document Url' ;
    rdfs:comment 'URL or file path reference to the pre-circulated meeting agenda document. Supports pre-meeting preparation and post-meeting institutional memory.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agendaSummary rdf:type rdf:Property ;
    rdfs:label 'Agenda Summary' ;
    rdfs:comment 'Structured summary of the meeting agenda items as circulated prior to or during the meeting. Captures the key topics discussed for institutional memory and follow-up tracking.' ;
    rdfs:domain ind:CoordinationMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedResponsePlan rdf:type rdf:Property ;
    rdfs:label 'Associated Response Plan' ;
    rdfs:comment 'Name or code of the Humanitarian Response Plan (HRP), Flash Appeal, or other inter-agency response framework that this meeting is associated with. Contextualizes the meeting within the broader humanitarian response architecture.' ;
    rdfs:domain ind:CoordinationMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Precise timestamp marking the scheduled or actual end of the coordination meeting. Used to calculate meeting duration and assess time investment in coordination activities.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:followUpStatus rdf:type rdf:Property ;
    rdfs:label 'Follow Up Status' ;
    rdfs:comment 'Current status of post-meeting follow-up actions. Tracks whether action items from the meeting have been addressed, are in progress, or are overdue.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostingOrganization rdf:type rdf:Property ;
    rdfs:label 'Hosting Organization' ;
    rdfs:comment 'Name of the organization that hosted or convened the coordination meeting. May be Ngo itself, a UN agency, government body, or another INGO acting as cluster lead.' ;
    rdfs:domain ind:CoordinationMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humanitarianContext rdf:type rdf:Property ;
    rdfs:label 'Humanitarian Context' ;
    rdfs:comment 'Operational context in which the coordination meeting takes place. Distinguishes acute emergency response from protracted crisis, recovery, development, or preparedness phases.' ;
    rdfs:domain ind:CoordinationMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyDecisions rdf:type rdf:Property ;
    rdfs:label 'Key Decisions' ;
    rdfs:comment 'Narrative record of the principal decisions made during the coordination meeting. Essential for institutional memory, accountability, and follow-up action tracking per CHS and HAP standards.' ;
    rdfs:domain ind:CoordinationMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Indicates whether the meeting was conducted in-person, virtually (e.g., via video conferencing), or in a hybrid format combining both modalities.' ;
    rdfs:domain ind:CoordinationMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Meeting Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to the meeting for cross-system tracking and institutional memory. Used in SitReps, donor reports, and OCHA coordination logs.' ;
    rdfs:domain ind:CoordinationMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingStatus rdf:type rdf:Property ;
    rdfs:label 'Meeting Status' ;
    rdfs:comment 'Current lifecycle state of the coordination meeting record. Tracks whether the meeting is planned, has occurred, was cancelled, or is in draft preparation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingTitle rdf:type rdf:Property ;
    rdfs:label 'Meeting Title' ;
    rdfs:comment 'Official title or name of the coordination meeting as recorded in the meeting notice or invitation. Provides human-readable identification for institutional memory and reporting.' ;
    rdfs:domain ind:CoordinationMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minutesDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Minutes Document Url' ;
    rdfs:comment 'URL or file path reference to the official meeting minutes document stored in the document management system. Enables direct access to the full minutes for institutional memory.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minutesRecorded rdf:type rdf:Property ;
    rdfs:label 'Minutes Recorded' ;
    rdfs:comment 'Indicates whether formal meeting minutes were recorded and are available for this coordination meeting. Supports institutional memory and accountability requirements.' ;
    rdfs:domain ind:CoordinationMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Next Meeting Date' ;
    rdfs:comment 'Scheduled date of the next meeting in the series or the follow-up meeting agreed upon at this meeting. Supports coordination planning and scheduling.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ngoAttendeesCount rdf:type rdf:Property ;
    rdfs:label 'Ngo Attendees Count' ;
    rdfs:comment 'Number of Ngo staff members who attended the coordination meeting. Supports workforce engagement analysis and coordination effort reporting.' ;
    rdfs:domain ind:CoordinationMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organizationsRepresented rdf:type rdf:Property ;
    rdfs:label 'Organizations Represented' ;
    rdfs:comment 'Number of distinct organizations represented at the coordination meeting. Indicates breadth of inter-agency engagement and cluster participation.' ;
    rdfs:domain ind:CoordinationMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relatedSitrepReference rdf:type rdf:Property ;
    rdfs:label 'Related Sitrep Reference' ;
    rdfs:comment 'Reference code or identifier of the OCHA Situation Report (SitRep) that this meeting contributed to or is referenced in. Links coordination activity to humanitarian situation reporting.' ;
    rdfs:domain ind:CoordinationMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Series Reference Code' ;
    rdfs:comment 'Reference code linking this meeting instance to its parent recurring series. Enables series-level aggregation and trend analysis across multiple meeting instances.' ;
    rdfs:domain ind:CoordinationMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Precise timestamp marking the scheduled or actual start of the coordination meeting, including timezone offset. Used for scheduling, conflict detection, and attendance tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalAttendees rdf:type rdf:Property ;
    rdfs:label 'Total Attendees' ;
    rdfs:comment 'Total number of individuals who attended the coordination meeting. Used for participation analytics, cluster engagement metrics, and donor reporting on coordination activities.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dueDiligenceRecordId rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Record Id' ;
    rdfs:comment 'Unique system-generated identifier for the due diligence and partner verification record. Primary key for this entity. Entity role: MASTER_AGREEMENT — this record represents a formal compliance verification container with its own lifecycle, effective dates, and binding outcome.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DueDiligenceRecord .

ind:amlCftCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Cft Check Status' ;
    rdfs:comment 'Result of Anti-Money Laundering (AML) and Counter-Financing of Terrorism (CFT) due diligence checks conducted on the partner organization and its key principals, per FATF Recommendations and donor requirements.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:antiTerrorismCertDate rdf:type rdf:Property ;
    rdfs:label 'Anti Terrorism Cert Date' ;
    rdfs:comment 'Date on which the partner\'s anti-terrorism certification was signed and received. Required for USAID and BHA-funded sub-awards.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:antiTerrorismCertification rdf:type rdf:Property ;
    rdfs:label 'Anti Terrorism Certification' ;
    rdfs:comment 'Indicates whether the partner has signed and submitted a valid anti-terrorism certification (e.g., USAID Standard Provision — Certification Regarding Terrorist Financing) as required for US Government-funded awards.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chsCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Chs Cert Expiry Date' ;
    rdfs:comment 'Date on which the partner\'s CHS certification expires. Triggers renewal alerts and may affect partner eligibility for humanitarian sub-awards.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chsCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Chs Certificate Number' ;
    rdfs:comment 'Official certificate number issued by the CHS Alliance upon successful third-party verification of the partner\'s compliance with the Core Humanitarian Standard.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chsCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Chs Certification Status' ;
    rdfs:comment 'Accreditation status of the partner against the Core Humanitarian Standard on Quality and Accountability (CHS). Certified status requires third-party verification by the CHS Alliance.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsOfApproval rdf:type rdf:Property ;
    rdfs:label 'Conditions Of Approval' ;
    rdfs:comment 'Free-text description of any conditions, restrictions, or corrective actions attached to an approved-with-conditions outcome. Documents required remediation steps and timelines before full approval is granted.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debarmentCheckDate rdf:type rdf:Property ;
    rdfs:label 'Debarment Check Date' ;
    rdfs:comment 'Date on which the most recent debarment and suspension check was performed against SAM.gov and equivalent exclusion registries.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:debarmentCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Debarment Check Status' ;
    rdfs:comment 'Result of verification against the US System for Award Management (SAM.gov) exclusions list and equivalent debarment/suspension registries to confirm the partner is not excluded from receiving federal awards.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diligenceStatus rdf:type rdf:Property ;
    rdfs:label 'Diligence Status' ;
    rdfs:comment 'Current lifecycle state of the due diligence record, tracking progress from initiation through completion or failure. Drives workflow routing and compliance dashboards.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diligenceType rdf:type rdf:Property ;
    rdfs:label 'Diligence Type' ;
    rdfs:comment 'Classification of the due diligence exercise by its trigger and scope. Pre-award is conducted before sub-award execution; periodic review is scheduled; triggered review is initiated by a risk event; close-out is conducted at agreement end; enhanced due diligence applies to high-risk partners.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAuditOpinion rdf:type rdf:Property ;
    rdfs:label 'Financial Audit Opinion' ;
    rdfs:comment 'Type of auditor\'s opinion issued in the partner\'s most recent external financial audit. An unqualified (clean) opinion is required for most donor sub-award eligibility. Adverse or disclaimer opinions trigger enhanced due diligence.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAuditReviewed rdf:type rdf:Property ;
    rdfs:label 'Financial Audit Reviewed' ;
    rdfs:comment 'Indicates whether the partner\'s most recent external financial audit report has been reviewed and assessed as part of this due diligence exercise.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialAuditYear rdf:type rdf:Property ;
    rdfs:label 'Financial Audit Year' ;
    rdfs:comment 'Fiscal year covered by the most recent external financial audit report reviewed during due diligence. Used to assess currency of financial information.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:governanceVerified rdf:type rdf:Property ;
    rdfs:label 'Governance Verified' ;
    rdfs:comment 'Indicates whether the partner\'s governance structure (board composition, conflict of interest policies, organizational chart, and decision-making authority) has been reviewed and verified.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hapMembershipStatus rdf:type rdf:Property ;
    rdfs:label 'Hap Membership Status' ;
    rdfs:comment 'Indicates the partner\'s membership status with the Humanitarian Accountability Partnership (HAP), a predecessor accountability framework now integrated into the CHS Alliance.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso Cert Expiry Date' ;
    rdfs:comment 'Date on which the partner\'s ISO certification expires. Null if no ISO certification is held or if certification is not time-limited.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isoCertificationType rdf:type rdf:Property ;
    rdfs:label 'Iso Certification Type' ;
    rdfs:comment 'Type of ISO certification held by the partner organization (e.g., ISO 9001 Quality Management, ISO 27001 Information Security). Null if no ISO certification is held. [ENUM-REF-CANDIDATE: ISO_9001|ISO_27001|ISO_14001|ISO_45001|ISO_31000|none — promote to reference product]' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalRegistrationVerified rdf:type rdf:Property ;
    rdfs:label 'Legal Registration Verified' ;
    rdfs:comment 'Indicates whether the partner\'s legal registration and incorporation status in its country of operation has been verified against official national NGO registration records or company registry.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ngoRegistrationCountry rdf:type rdf:Property ;
    rdfs:label 'Ngo Registration Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction in which the partner is legally registered as an NGO or nonprofit entity.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ngoRegistrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Ngo Registration Expiry Date' ;
    rdfs:comment 'Date on which the partner\'s national NGO registration expires and must be renewed. Null if registration is perpetual. Triggers compliance alerts when approaching expiry.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ngoRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Ngo Registration Number' ;
    rdfs:comment 'Official registration number issued by the national NGO regulatory authority or charity commission in the partner\'s country of primary operation. Key identifier for legal compliance verification.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallOutcome rdf:type rdf:Property ;
    rdfs:label 'Overall Outcome' ;
    rdfs:comment 'Final determination of the due diligence exercise indicating whether the partner is cleared for sub-award or partnership engagement. Approved with conditions requires a documented corrective action plan.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Record Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference code assigned to this due diligence record, used in correspondence, audit trails, and donor reporting. Format: DDR-YYYY-NNNNNN.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Composite risk rating assigned to the partner following due diligence, reflecting financial, governance, compliance, and operational risk factors. Determines monitoring intensity and sub-award conditions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeguardingPolicyVerified rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Policy Verified' ;
    rdfs:comment 'Indicates whether the partner has a documented and operational safeguarding policy covering protection from sexual exploitation, abuse, and harassment (PSEAH), child protection, and GBV prevention, as required by IASC and donor standards.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sphereComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Sphere Compliance Status' ;
    rdfs:comment 'Assessment of the partner\'s operational compliance with the Sphere Humanitarian Charter and Minimum Standards in Humanitarian Response, covering WASH, food security, shelter, and health sectors.' ;
    rdfs:domain ind:DueDiligenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Ref' ;
    rdfs:comment 'Reference identifier or URL pointing to the document management system location where supporting due diligence evidence (audit reports, registration certificates, signed certifications) is stored.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorVisitFieldMonitoringVisitId rdf:type rdf:Property ;
    rdfs:label 'Prior Visit Field Monitoring Visit Id' ;
    rdfs:comment 'Reference to the previous field monitoring visit record for the same partner and site, enabling longitudinal tracking of compliance trends and verification of prior corrective actions.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldMonitoringVisit .

ind:assetsVerified rdf:type rdf:Property ;
    rdfs:label 'Assets Verified' ;
    rdfs:comment 'Indicates whether donor-funded assets (equipment, vehicles, NFI stocks, infrastructure) were physically verified against the partner\'s asset register during this monitoring visit.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficiariesInterviewedCount rdf:type rdf:Property ;
    rdfs:label 'Beneficiaries Interviewed Count' ;
    rdfs:comment 'Number of program beneficiaries or Persons of Concern (PoC) directly interviewed or consulted during the monitoring visit as part of accountability and feedback mechanisms.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveActionPlanDeadline rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Deadline' ;
    rdfs:comment 'Date by which the partner is required to submit or fully implement the Corrective Action Plan (CAP) addressing findings from this monitoring visit.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Required' ;
    rdfs:comment 'Indicates whether the monitoring visit findings require the partner to develop and submit a formal Corrective Action Plan (CAP) to address identified non-compliance issues.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Status' ;
    rdfs:comment 'Current status of the Corrective Action Plan (CAP) associated with this monitoring visit, tracking partner response from submission through acceptance.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Financial Findings Summary' ;
    rdfs:comment 'Narrative description of financial management findings from the spot-check component of the visit, including observations on expenditure documentation, procurement compliance, BvA accuracy, and fund accounting practices.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpVisitDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Visit Due Date' ;
    rdfs:comment 'Target date by which the follow-up verification visit must be completed to confirm corrective action implementation and close outstanding findings.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpVisitRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Visit Required' ;
    rdfs:comment 'Indicates whether a subsequent field monitoring visit is required to verify implementation of corrective actions or to conduct additional oversight based on findings from this visit.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of findings classified as major severity (significant non-compliance requiring corrective action within a defined timeframe) identified during the visit.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of findings classified as minor severity (observations or recommendations for improvement that do not constitute material non-compliance) identified during the visit.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringChecklistVersion rdf:type rdf:Property ;
    rdfs:label 'Monitoring Checklist Version' ;
    rdfs:comment 'Version identifier of the standardized monitoring checklist or tool used during the visit (e.g., KoboToolbox form version, internal checklist version number), ensuring reproducibility and comparability across visits.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Partner Acknowledgement Date' ;
    rdfs:comment 'Date on which the partner organization formally acknowledged receipt of the monitoring visit report and findings, initiating the corrective action response timeline.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerRepName rdf:type rdf:Property ;
    rdfs:label 'Partner Rep Name' ;
    rdfs:comment 'Full name of the senior partner organization representative who received the monitoring team and participated in the opening and closing meetings during the visit.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programSector rdf:type rdf:Property ;
    rdfs:label 'Program Sector' ;
    rdfs:comment 'Humanitarian or development sector of the program being monitored (e.g., WASH, GBV, Nutrition, Education, Shelter, Health, Livelihoods, PSS). Aligns with OCHA cluster system and IATI sector codes. [ENUM-REF-CANDIDATE: wash|gbv|nutrition|education|shelter|health|livelihoods|pss|food_security|protection — promote to reference product]' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeguardingFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Findings Summary' ;
    rdfs:comment 'Narrative description of safeguarding and protection findings from the visit, including observations on GBV prevention measures, child protection protocols, complaint and feedback mechanisms, and CHS compliance.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAdmin1Name rdf:type rdf:Property ;
    rdfs:label 'Site Admin1 Name' ;
    rdfs:comment 'First-level administrative division (state, province, region, governorate) where the monitored project site is located, aligned with OCHA Common Operational Datasets (COD) administrative boundaries.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAdmin2Name rdf:type rdf:Property ;
    rdfs:label 'Site Admin2 Name' ;
    rdfs:comment 'Second-level administrative division (district, county, department, woreda) where the monitored project site is located, supporting geographic disaggregation in SitRep and donor reporting.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCountryCode rdf:type rdf:Property ;
    rdfs:label 'Site Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the country where the monitored project site is located.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteLatitude rdf:type rdf:Property ;
    rdfs:label 'Site Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the monitored project site in decimal degrees (WGS84), enabling GIS mapping and spatial analysis of monitoring coverage.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteLongitude rdf:type rdf:Property ;
    rdfs:label 'Site Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the monitored project site in decimal degrees (WGS84), enabling GIS mapping and spatial analysis of monitoring coverage.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:staffInterviewedCount rdf:type rdf:Property ;
    rdfs:label 'Staff Interviewed Count' ;
    rdfs:comment 'Number of partner organization staff members interviewed or consulted during the monitoring visit, supporting assessment of organizational capacity and program implementation quality.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitDate rdf:type rdf:Property ;
    rdfs:label 'Visit Date' ;
    rdfs:comment 'The actual calendar date on which the field monitoring visit was conducted at the partner project site. Principal real-world event date for this transaction.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitEndTime rdf:type rdf:Property ;
    rdfs:label 'Visit End Time' ;
    rdfs:comment 'Precise date and time when the field monitoring visit concluded at the partner site, enabling duration tracking and staff time reporting.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:visitPurpose rdf:type rdf:Property ;
    rdfs:label 'Visit Purpose' ;
    rdfs:comment 'Primary objective classification of the field monitoring visit. Determines the scope of review activities, checklists applied, and reporting obligations. [ENUM-REF-CANDIDATE: programmatic_monitoring|financial_spot_check|safeguarding_audit|asset_verification|capacity_building|closeout_review — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Visit Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to the visit for tracking in grant management systems, donor reports, and partner correspondence. Format: FMV-YYYY-NNNNNN.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitReportSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Visit Report Submitted Date' ;
    rdfs:comment 'Date on which the completed field monitoring visit report was formally submitted to the partnership management team and/or uploaded to the grant management system.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitReportUrl rdf:type rdf:Property ;
    rdfs:label 'Visit Report Url' ;
    rdfs:comment 'URL or document management system path to the full field monitoring visit report, including all findings, recommendations, and supporting evidence uploaded to the GMS or document repository.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitStartTime rdf:type rdf:Property ;
    rdfs:label 'Visit Start Time' ;
    rdfs:comment 'Precise date and time when the field monitoring visit commenced at the partner site, used for scheduling, duration calculation, and audit trail purposes.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:visitStatus rdf:type rdf:Property ;
    rdfs:label 'Visit Status' ;
    rdfs:comment 'Current lifecycle state of the field monitoring visit record, tracking progression from planning through completion and any required follow-up actions.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitType rdf:type rdf:Property ;
    rdfs:label 'Visit Type' ;
    rdfs:comment 'Modality of the monitoring visit indicating whether the partner was notified in advance (announced), visited without prior notice (unannounced), conducted remotely, or performed as a desk review of submitted documentation.' ;
    rdfs:domain ind:FieldMonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mouObligationId rdf:type rdf:Property ;
    rdfs:label 'Mou Obligation Id' ;
    rdfs:comment 'Unique system-generated identifier for each obligation, deliverable, or commitment record defined within an MoU or partnership agreement. Primary key for this entity.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:achievedValue rdf:type rdf:Property ;
    rdfs:label 'Achieved Value' ;
    rdfs:comment 'Actual quantitative result achieved against the target value at the time of completion or latest reporting. Enables performance tracking and BvA (Budget versus Actual) style analysis for non-financial obligations.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentReference rdf:type rdf:Property ;
    rdfs:label 'Amendment Reference' ;
    rdfs:comment 'Reference number or description of the partnership agreement amendment that introduced or modified this obligation. Null for obligations defined in the original agreement. Supports change management and audit trail.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityBuildingComponent rdf:type rdf:Property ;
    rdfs:label 'Capacity Building Component' ;
    rdfs:comment 'Boolean flag indicating whether this obligation includes a capacity building or institutional strengthening component for the partner organization (e.g., training, mentoring, systems development). Supports partner capacity assessment tracking.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationNotes rdf:type rdf:Property ;
    rdfs:label 'Escalation Notes' ;
    rdfs:comment 'Free-text narrative documenting the reason for escalation, actions taken, and resolution steps. Captures the escalation history for audit and learning purposes.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceDescription rdf:type rdf:Property ;
    rdfs:label 'Evidence Description' ;
    rdfs:comment 'Narrative description of the evidence submitted to demonstrate fulfillment of this obligation (e.g., \'Quarterly narrative report submitted via email on 2024-03-31\', \'Training attendance register and photos uploaded to SharePoint\'). Supports audit and compliance review.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Reference' ;
    rdfs:comment 'File path, document management system reference, URL, or unique document identifier pointing to the supporting evidence artifact (report, photo, attendance list, financial statement) that demonstrates fulfillment of this obligation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialValueAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Value Amount' ;
    rdfs:comment 'Monetary value associated with this obligation where it involves a financial commitment (e.g., sub-grant tranche disbursement, in-kind contribution valuation, or cost-sharing commitment). Null for non-financial obligations.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indicatorReference rdf:type rdf:Property ;
    rdfs:label 'Indicator Reference' ;
    rdfs:comment 'Reference to the specific KPI or MEL indicator that this obligation contributes to, as defined in the partnership\'s MEAL framework or donor reporting requirements. Supports DHIS2 indicator tracking and MEL dashboard reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalObligation rdf:type rdf:Property ;
    rdfs:label 'Is Critical Obligation' ;
    rdfs:comment 'Boolean flag indicating whether this obligation is classified as critical to the partnership\'s core deliverables or donor compliance requirements. Critical obligations trigger priority escalation workflows and are highlighted in SitRep and donor reporting.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDonorReportable rdf:type rdf:Property ;
    rdfs:label 'Is Donor Reportable' ;
    rdfs:comment 'Boolean flag indicating whether fulfillment of this obligation must be reported to the donor (e.g., USAID BHA, DFID, CERF). Drives inclusion in donor compliance reports and IATI activity updates.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logframeOutputReference rdf:type rdf:Property ;
    rdfs:label 'Logframe Output Reference' ;
    rdfs:comment 'Reference code or label linking this obligation to a specific output, outcome, or activity in the partnership\'s Logical Framework (LogFrame) or Theory of Change (ToC). Enables Results-Based Management (RBM) tracking and MEL alignment.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed narrative description of the obligation, deliverable, or commitment as defined in the partnership instrument. Captures the full scope, quality standards, and acceptance criteria agreed upon by both parties.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric code or clause reference identifying this obligation within the partnership instrument (e.g., \'MOU-2024-001-OBL-03\', or clause reference \'Section 4.2.1\'). Used in partner communications and compliance reporting.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationTitle rdf:type rdf:Property ;
    rdfs:label 'Obligation Title' ;
    rdfs:comment 'Short, human-readable title summarizing the obligation or deliverable (e.g., \'Quarterly Program Progress Report\', \'WASH Training for 50 Community Health Workers\'). Used in dashboards and partner communications.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalCountryCode rdf:type rdf:Property ;
    rdfs:label 'Operational Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code identifying the country where this obligation is to be fulfilled. Enables geographic filtering and country-level compliance reporting.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderDaysBeforeDue rdf:type rdf:Property ;
    rdfs:label 'Reminder Days Before Due' ;
    rdfs:comment 'Number of calendar days before the due_date that an automated reminder notification should be triggered to the responsible focal point and partnership manager. Configurable per obligation based on complexity and risk.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleFocalPointName rdf:type rdf:Property ;
    rdfs:label 'Responsible Focal Point Name' ;
    rdfs:comment 'Full name of the individual designated as the primary focal point accountable for fulfilling this obligation on behalf of the responsible party. Used for escalation and follow-up communications.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Target Unit Of Measure' ;
    rdfs:comment 'Unit of measurement for the target value (e.g., \'beneficiaries\', \'households\', \'training sessions\', \'metric tons\', \'reports\'). Required when target_value is populated to give the quantity business meaning.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedByName rdf:type rdf:Property ;
    rdfs:label 'Verified By Name' ;
    rdfs:comment 'Full name of the staff member or authorized representative who verified and accepted the fulfillment evidence for this obligation on behalf of the receiving party.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedDate rdf:type rdf:Property ;
    rdfs:label 'Verified Date' ;
    rdfs:comment 'Date on which the receiving party formally verified and accepted the evidence of fulfillment for this obligation. Distinct from completion_date, which is when the responsible party submitted the deliverable.' ;
    rdfs:domain ind:MouObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerAccreditationId rdf:type rdf:Property ;
    rdfs:label 'Partner Accreditation Id' ;
    rdfs:comment 'Unique system-generated identifier for each partner accreditation record. Primary key for the partner_accreditation data product.' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accreditationCode rdf:type rdf:Property ;
    rdfs:label 'Accreditation Code' ;
    rdfs:comment 'Standardized short code or identifier for the accreditation scheme (e.g., \'CHS\', \'SPHERE\', \'HAP\', \'ISO9001\', \'ISO27001\', \'NGO-REG\'). Used for filtering, reporting, and cross-partner comparisons in MEL dashboards.' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationName rdf:type rdf:Property ;
    rdfs:label 'Accreditation Name' ;
    rdfs:comment 'Full descriptive name of the accreditation, certification, or standard (e.g., \'Core Humanitarian Standard Certification\', \'ISO 9001:2015 Quality Management\', \'Sphere Humanitarian Standards Compliance\', \'HAP Membership\', \'National NGO Registration – Kenya\'). Human-readable label used in due diligence reports and partner dashboards.' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationScore rdf:type rdf:Property ;
    rdfs:label 'Accreditation Score' ;
    rdfs:comment 'Numeric score or rating assigned by the accrediting body upon assessment, where applicable (e.g., CHS self-assessment score out of 100, ISO audit score). Null if the accreditation is pass/fail with no numeric score. Used in partner capacity assessment scoring and due diligence risk rating calculations.' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Current lifecycle status of the accreditation record. \'active\' indicates the accreditation is valid and in force; \'expired\' indicates the validity period has lapsed; \'suspended\' indicates temporary withdrawal by the accrediting body; \'pending_renewal\' indicates renewal application submitted; \'withdrawn\' indicates permanent revocation; \'under_review\' indicates the accrediting body is conducting a review.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationType rdf:type rdf:Property ;
    rdfs:label 'Accreditation Type' ;
    rdfs:comment 'Broad category of the accreditation record. Distinguishes between formal certifications (e.g., CHS, ISO), membership bodies (e.g., HAP), national NGO registrations, compliance standards (e.g., Sphere), licenses, and awards. [ENUM-REF-CANDIDATE: certification|membership|registration|compliance_standard|license|award — promote to reference product if additional values emerge]' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditingBodyCountryCode rdf:type rdf:Property ;
    rdfs:label 'Accrediting Body Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the accrediting body is domiciled or where the registration is issued (e.g., \'CHE\' for Switzerland-based CHS Alliance, \'GBR\' for UK Charity Commission). Supports geographic compliance analysis.' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditingBodyName rdf:type rdf:Property ;
    rdfs:label 'Accrediting Body Name' ;
    rdfs:comment 'Full name of the organization or authority that issued the accreditation or certification (e.g., \'CHS Alliance\', \'Sphere Association\', \'Bureau Veritas\', \'Kenya NGO Coordination Board\', \'ISO Certification Body\'). Critical for verification and audit trail purposes.' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableStandardVersion rdf:type rdf:Property ;
    rdfs:label 'Applicable Standard Version' ;
    rdfs:comment 'Version or edition of the standard or framework against which the accreditation was assessed (e.g., \'CHS 2018\', \'Sphere 2018\', \'ISO 9001:2015\'). Important for tracking compliance against evolving standards and identifying partners certified to outdated versions.' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Official certificate or registration number issued by the accrediting body. Serves as the externally-known unique identifier for the accreditation document. Used for verification with the issuing body and referenced in due diligence reports and donor compliance submissions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chsCommitmentLevel rdf:type rdf:Property ;
    rdfs:label 'Chs Commitment Level' ;
    rdfs:comment 'For CHS-specific accreditations, records the highest CHS commitment level achieved by the partner organization (Commitments 1–9 per the CHS framework). Null for non-CHS accreditations. Supports CHS-aligned partner quality benchmarking. [ENUM-REF-CANDIDATE: commitment_1|commitment_2|commitment_3|commitment_4|commitment_5|commitment_6|commitment_7|commitment_8|commitment_9 — promote to reference product]' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUploadDate rdf:type rdf:Property ;
    rdfs:label 'Document Upload Date' ;
    rdfs:comment 'The date on which the accreditation certificate document was uploaded to Ngo\'s document management system. Used to assess document currency and flag records where the uploaded document may be outdated relative to the most recent renewal. Stored in yyyy-MM-dd format.' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorReference rdf:type rdf:Property ;
    rdfs:label 'Donor Reference' ;
    rdfs:comment 'Name or identifier of the donor that mandates this accreditation as a grant or sub-award condition (e.g., \'USAID/BHA\', \'FCDO\', \'CERF\'). Populated only when donor_required is True. Supports grant compliance reporting and sub-award management.' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorRequired rdf:type rdf:Property ;
    rdfs:label 'Donor Required' ;
    rdfs:comment 'Indicates whether this specific accreditation is required by a donor as a condition of a grant or sub-award agreement. True if mandated by a donor (e.g., USAID, DFID/FCDO, CERF); False otherwise. Supports grant compliance tracking and sub-award due diligence.' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dueDiligenceWeight rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Weight' ;
    rdfs:comment 'Numeric weight assigned to this accreditation in Ngo\'s partner due diligence scoring model (e.g., 0.25 for 25% weight). Reflects the relative importance of this accreditation type in the overall partner risk rating calculation. Configured by the Partnership team in alignment with donor requirements.' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicApplicability rdf:type rdf:Property ;
    rdfs:label 'Geographic Applicability' ;
    rdfs:comment 'Country or region where this accreditation is valid and recognized. May be a specific ISO 3166-1 alpha-3 country code (e.g., \'KEN\', \'ETH\'), a regional designation, or \'GLOBAL\' for internationally recognized accreditations. Supports geographic due diligence and partner deployment decisions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatoryForPartnership rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory For Partnership' ;
    rdfs:comment 'Indicates whether this accreditation is a mandatory prerequisite for Ngo to enter into or maintain a partnership agreement with this organization. True if required by Ngo\'s partnership policy, donor conditions, or regulatory requirements; False if optional or informational. Drives partnership eligibility checks.' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxPossibleScore rdf:type rdf:Property ;
    rdfs:label 'Max Possible Score' ;
    rdfs:comment 'The maximum score achievable under the accreditation assessment framework, used to contextualize the accreditation_score (e.g., 100 for a percentage-based CHS assessment). Null if the accreditation is pass/fail. Enables normalized cross-partner comparisons.' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalAlertDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Alert Days' ;
    rdfs:comment 'Number of days before the accreditation expiry_date at which an automated renewal alert should be triggered for the partnership management team. Configurable per accreditation type (e.g., 90 days for CHS certification, 30 days for national NGO registration). Supports proactive compliance management.' ;
    rdfs:domain ind:PartnerAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date on which the partner organization submitted or is scheduled to submit a renewal application for this accreditation. Distinct from expiry_date (when it lapses) and issue_date (when originally granted). Supports proactive renewal tracking and partner capacity management workflows.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Narrative description of the scope, coverage, or applicability of the accreditation. Specifies which programs, sectors, geographic areas, or operational activities the accreditation covers (e.g., \'WASH and shelter programs in East Africa\', \'Financial management systems only\'). Supports targeted due diligence assessments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerContactId rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Id' ;
    rdfs:comment 'Unique system-generated identifier for the partner contact record. Primary key for the partner_contact data product within the partnership domain.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clusterMembership rdf:type rdf:Property ;
    rdfs:label 'Cluster Membership' ;
    rdfs:comment 'Name of the OCHA humanitarian cluster(s) or IASC working group(s) in which this contact participates as a representative or lead (e.g., WASH Cluster, Health Cluster, Protection Cluster, Food Security Cluster). Supports inter-agency coordination tracking.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the partner contact record. Indicates whether the contact is actively engaged in partnership coordination, temporarily unavailable, or no longer with the organization.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates that the partner contact has requested to not be contacted, or has been flagged by the organization as ineligible for outreach. Overrides all communication workflows and must be respected in all outreach campaigns.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dutyStation rdf:type rdf:Property ;
    rdfs:label 'Duty Station' ;
    rdfs:comment 'Specific city, town, or field location where the partner contact is stationed. Used in humanitarian operations to identify field presence, coordinate cluster meetings, and assign contacts to geographic response zones.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Self-identified gender of the partner contact. Used for gender disaggregation in partnership reporting, Sustainable Development Goal (SDG) 5 compliance tracking, and gender-balanced stakeholder engagement analysis.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAuthorizedSignatory rdf:type rdf:Property ;
    rdfs:label 'Is Authorized Signatory' ;
    rdfs:comment 'Indicates whether the partner contact is an authorized legal signatory for agreements such as Memoranda of Understanding (MoU), Letters of Agreement (LoA), sub-award agreements, and Scope of Work (SoW) documents. Critical for compliance with OMB Uniform Guidance 2 CFR 200 and donor requirements.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFinancialAuthorized rdf:type rdf:Property ;
    rdfs:label 'Is Financial Authorized' ;
    rdfs:comment 'Indicates whether the partner contact holds financial authorization authority, such as approving sub-grant disbursements, signing financial reports, or authorizing Budget versus Actual (BvA) submissions. Supports financial stewardship and fund accounting controls.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this individual is the designated primary focal point for the partner organization. Only one contact per organization should be flagged as primary. Drives automated routing of official communications and partnership notifications.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'Date of the most recent recorded interaction or communication with the partner contact. Used to identify dormant relationships, prioritize re-engagement, and support relationship management workflows in the Constituent Relationship Management (CRM) system.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedinProfile rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile' ;
    rdfs:comment 'LinkedIn professional profile URL for the partner contact. Used for prospect research, due diligence verification, and professional background validation during partner capacity assessments.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or second given name of the partner contact, used in formal legal correspondence and official documentation such as Memoranda of Understanding (MoU) and Letters of Agreement (LoA).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile or cellular phone number for the partner contact in E.164 international format. Critical for field operations communication, WhatsApp coordination, and emergency contact in humanitarian contexts.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the nationality of the partner contact. Used for visa and travel coordination, national staff vs. international staff classification, and compliance with local labor regulations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeAddress rdf:type rdf:Property ;
    rdfs:label 'Office Address' ;
    rdfs:comment 'Physical office address of the partner contact\'s workplace. Used for formal correspondence, field visit coordination, and partner mapping in Geographic Information System (GIS) tools.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officePhone rdf:type rdf:Property ;
    rdfs:label 'Office Phone' ;
    rdfs:comment 'Direct office or landline telephone number for the partner contact, including extension where applicable. Used for formal business communications and official coordination calls.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 or ISO 639-3 language code representing the partner contact\'s preferred language for communications and documentation (e.g., \'en\' for English, \'fr\' for French, \'ar\' for Arabic, \'es\' for Spanish). Supports multilingual coordination in international humanitarian operations.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Functional role classification of the contact within the partnership relationship. Determines the contact\'s authority and responsibilities in coordination workflows. [ENUM-REF-CANDIDATE: focal_point|authorized_representative|technical_lead|financial_officer|program_manager|legal_signatory|cluster_coordinator|field_officer — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Secondary Language' ;
    rdfs:comment 'ISO 639-1 or ISO 639-3 language code for the partner contact\'s secondary working language. Supports assignment of contacts to multilingual coordination meetings, cluster working groups, and OCHA-led inter-agency processes.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skypeHandle rdf:type rdf:Property ;
    rdfs:label 'Skype Handle' ;
    rdfs:comment 'Skype username or identifier for the partner contact. Used for virtual coordination meetings, remote field communications, and inter-agency conference calls in areas with limited connectivity.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemContactReference rdf:type rdf:Property ;
    rdfs:label 'Source System Contact Reference' ;
    rdfs:comment 'The unique identifier assigned to this contact record in the originating operational system of record (e.g., Salesforce Contact ID, Dynamics 365 Contact GUID). Enables cross-system reconciliation and data lineage tracing in the lakehouse Silver layer.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipManagerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Partnership management best practice assigns NGO staff as relationship owner for each partner organization. Critical for due diligence oversight, capacity assessment coordination, performance monitori' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:annualBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Usd' ;
    rdfs:comment 'Most recently reported annual organizational budget of the partner in US Dollars. Used for financial capacity assessment, sub-award sizing decisions, and due diligence under OMB Uniform Guidance. Sourced from partner financial disclosures or audited accounts.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedRepName rdf:type rdf:Property ;
    rdfs:label 'Authorized Rep Name' ;
    rdfs:comment 'Full name of the individual legally authorized to sign agreements (MoUs, LoAs, SoWs, sub-award agreements) on behalf of the partner organization. Required for agreement execution and legal compliance.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedRepTitle rdf:type rdf:Property ;
    rdfs:label 'Authorized Rep Title' ;
    rdfs:comment 'Official title of the authorized signatory at the partner organization (e.g., Executive Director, CEO, Country Representative). Validates signing authority for sub-award and partnership agreements.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCountry rdf:type rdf:Property ;
    rdfs:label 'Bank Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the partner organization\'s primary bank account is held. Used for international wire transfer compliance and OFAC/sanctions screening.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chsCertified rdf:type rdf:Property ;
    rdfs:label 'Chs Certified' ;
    rdfs:comment 'Indicates whether the partner organization holds a valid Core Humanitarian Standard (CHS) certification. CHS certification demonstrates commitment to accountability, quality, and improvement in humanitarian response.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clusterMemberships rdf:type rdf:Property ;
    rdfs:label 'Cluster Memberships' ;
    rdfs:comment 'Comma-separated list of OCHA humanitarian cluster(s) in which the partner organization holds active membership or co-lead roles (e.g., WASH, Health, Shelter, Food Security, Protection). Used for coordination mapping and IASC working group engagement tracking.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countriesOfOperation rdf:type rdf:Property ;
    rdfs:label 'Countries Of Operation' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where the partner organization has active field operations. Distinct from country of registration. Used for geographic coverage analysis and OCHA 3W (Who does What Where) reporting.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDiligenceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Expiry Date' ;
    rdfs:comment 'Date on which the current due diligence clearance expires and a new assessment must be completed before the partner can enter into new sub-award or partnership agreements.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financeContactEmail rdf:type rdf:Property ;
    rdfs:label 'Finance Contact Email' ;
    rdfs:comment 'Email address of the partner organization\'s designated financial officer or finance focal point. Used for Budget versus Actual (BvA) reporting, financial documentation requests, and sub-grant financial management communications.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foundingYear rdf:type rdf:Property ;
    rdfs:label 'Founding Year' ;
    rdfs:comment 'Calendar year in which the partner organization was founded or established. Used to assess organizational maturity, track record, and eligibility for capacity-strengthening programs.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hqAddress rdf:type rdf:Property ;
    rdfs:label 'Hq Address' ;
    rdfs:comment 'Full mailing address of the partner organization\'s global headquarters including street, city, postal code, and country. Used for official correspondence, legal notices, and sub-award agreement documentation.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqCity rdf:type rdf:Property ;
    rdfs:label 'Hq City' ;
    rdfs:comment 'City where the partner organization\'s global headquarters is located. Used for correspondence, coordination meetings, and geographic reporting.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqCountry rdf:type rdf:Property ;
    rdfs:label 'Hq Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the partner organization\'s global headquarters is located. Used for geographic analysis, donor reporting, and OCHA cluster coordination mapping.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatiOrgIdentifier rdf:type rdf:Property ;
    rdfs:label 'Iati Org Identifier' ;
    rdfs:comment 'Globally unique organization identifier assigned under the International Aid Transparency Initiative (IATI) standard (e.g., GB-CHC-1234567). Enables cross-organization data linkage and transparency reporting to IATI registry. Required for DFID and many EU donor compliance reports.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missionStatement rdf:type rdf:Property ;
    rdfs:label 'Mission Statement' ;
    rdfs:comment 'Official mission statement of the partner organization describing its core purpose and mandate. Used for alignment assessment with Ngo\'s Theory of Change (ToC) and program design.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgAcronym rdf:type rdf:Property ;
    rdfs:label 'Org Acronym' ;
    rdfs:comment 'Commonly used acronym or short name for the partner organization (e.g., CARE, IRC, MSF). Widely used in SitReps, cluster coordination, and OCHA reporting to identify partners concisely.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgName rdf:type rdf:Property ;
    rdfs:label 'Org Name' ;
    rdfs:comment 'Full legal registered name of the partner organization as it appears on official registration documents. Used as the primary human-readable identity label for the partner across all systems including Microsoft Dynamics 365 and Salesforce Nonprofit Cloud.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgType rdf:type rdf:Property ;
    rdfs:label 'Org Type' ;
    rdfs:comment 'Categorical classification of the partner organization type. Distinguishes between International Non-Governmental Organizations (INGOs), Civil Society Organizations (CSOs), Community-Based Organizations (CBOs), UN agencies, government bodies, consortia, private sector entities, and academic institutions. Drives eligibility rules for sub-award agreements and due diligence requirements. [ENUM-REF-CANDIDATE: INGO|NGO|CSO|CBO|UN_AGENCY|GOVERNMENT|CONSORTIUM|PRIVATE_SECTOR|ACADEMIC — promote to reference product]' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgWebsite rdf:type rdf:Property ;
    rdfs:label 'Org Website' ;
    rdfs:comment 'Official public website URL of the partner organization. Used for due diligence verification, public profile validation, and IATI transparency reporting.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipStatus rdf:type rdf:Property ;
    rdfs:label 'Partnership Status' ;
    rdfs:comment 'Current lifecycle status of the partner organization relationship. Controls whether the partner is eligible for new agreements, sub-awards, or field collaboration. \'pending_vetting\' indicates due diligence is in progress; \'blacklisted\' indicates the partner is barred from engagement per donor or regulatory requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Official email address of the primary focal point at the partner organization. Used for formal communications, agreement notifications, and reporting requests.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary focal point or authorized representative at the partner organization. This is the principal contact for partnership coordination, agreement negotiations, and official communications.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Direct phone number (including country code) for the primary focal point at the partner organization. Used for urgent field coordination and emergency communications.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Job title or designation of the primary focal point at the partner organization (e.g., Country Director, Partnership Manager, Executive Director). Used to assess seniority and authority level for agreement signing.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedAt rdf:type rdf:Property ;
    rdfs:label 'Record Created At' ;
    rdfs:comment 'Timestamp indicating when the partner organization record was first created in the system. Serves as the audit trail creation marker and supports data lineage tracking in the Databricks Silver Layer.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedAt rdf:type rdf:Property ;
    rdfs:label 'Record Updated At' ;
    rdfs:comment 'Timestamp indicating when the partner organization record was most recently modified. Used for change tracking, data freshness monitoring, and incremental load processing in the Databricks Lakehouse Silver Layer.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sanctionsScreenDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screen Date' ;
    rdfs:comment 'Date on which the most recent sanctions screening was completed for the partner organization. Used to determine whether re-screening is required before new agreements or disbursements.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsScreened rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screened' ;
    rdfs:comment 'Indicates whether the partner organization has been screened against applicable sanctions lists (e.g., OFAC SDN List, UN Consolidated Sanctions List, EU Sanctions List) as part of the due diligence process. Required for USAID and US Government-funded programs.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Government-issued tax identification number (e.g., EIN in the US, VAT number in the EU) for the partner organization. Required for financial transactions, sub-award agreements, and compliance with NICRA (Negotiated Indirect Cost Rate Agreement) reporting.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thematicFocusAreas rdf:type rdf:Property ;
    rdfs:label 'Thematic Focus Areas' ;
    rdfs:comment 'Comma-separated list of primary thematic areas in which the partner organization operates (e.g., WASH, GBV, PSS, Health, Education, Livelihoods, NFI Distribution). Used for partner matching in program design and cluster coordination with OCHA.' ;
    rdfs:domain ind:PartnerOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volunteerCount rdf:type rdf:Property ;
    rdfs:label 'Volunteer Count' ;
    rdfs:comment 'Total number of active volunteers engaged by the partner organization. Reflects community mobilization capacity and is used in operational capacity assessments for field program delivery.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:implementationPlanId rdf:type rdf:Property ;
    rdfs:label 'Implementation Plan Id' ;
    rdfs:comment 'Reference to the program or project that the implementing partner is delivering under review.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ImplementationPlan .

ind:primaryPartnerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Partner Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or team lead who conducted and is accountable for this performance review.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:areasForImprovement rdf:type rdf:Property ;
    rdfs:label 'Areas For Improvement' ;
    rdfs:comment 'Narrative description of performance gaps, weaknesses, or risks identified during the review that require corrective action or capacity strengthening.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryFeedbackIncorporated rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Feedback Incorporated' ;
    rdfs:comment 'Indicates whether beneficiary feedback (e.g., from Post-Distribution Monitoring (PDM), Focus Group Discussions (FGD), or KoboToolbox surveys) was incorporated into the review findings.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetUtilisationRate rdf:type rdf:Property ;
    rdfs:label 'Budget Utilisation Rate' ;
    rdfs:comment 'Percentage of the sub-award budget expended by the partner during the review period (0.00–100.00). Key Budget versus Actual (BvA) indicator for financial stewardship assessment.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityBuildingAreas rdf:type rdf:Property ;
    rdfs:label 'Capacity Building Areas' ;
    rdfs:comment 'Narrative description of specific capacity building areas recommended for the partner (e.g., financial management, MEL systems, safeguarding, ICT4D). Populated when capacity_building_recommended is True.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityBuildingRecommended rdf:type rdf:Property ;
    rdfs:label 'Capacity Building Recommended' ;
    rdfs:comment 'Indicates whether the reviewer recommends a formal capacity building or organisational development intervention for the partner based on identified gaps.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether a formal Corrective Action Plan (CAP) is required as an outcome of this review. True triggers a CAP workflow in the partnership management system.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldVisitConducted rdf:type rdf:Property ;
    rdfs:label 'Field Visit Conducted' ;
    rdfs:comment 'Indicates whether a physical field visit to the partner\'s implementation site was conducted as part of this review. Required for high-risk partners per OMB Uniform Guidance subrecipient monitoring standards.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialAccountabilityRating rdf:type rdf:Property ;
    rdfs:label 'Financial Accountability Rating' ;
    rdfs:comment 'Rating of the partner\'s financial management practices including Budget versus Actual (BvA) variance, expenditure documentation, and compliance with Indirect Cost Rate (ICR) / NICRA requirements.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneAchievementRate rdf:type rdf:Property ;
    rdfs:label 'Milestone Achievement Rate' ;
    rdfs:comment 'Percentage of agreed SoW milestones achieved within the review period (0.00–100.00). Key Results-Based Management (RBM) indicator for partner performance tracking.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestonesAchievedCount rdf:type rdf:Property ;
    rdfs:label 'Milestones Achieved Count' ;
    rdfs:comment 'Number of SoW milestones fully achieved within the review period. Numerator for milestone achievement rate calculation.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestonesPlannedCount rdf:type rdf:Property ;
    rdfs:label 'Milestones Planned Count' ;
    rdfs:comment 'Total number of SoW milestones scheduled for delivery within the review period. Denominator for milestone achievement rate calculation.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Scheduled date for the next performance review of this partner under the current agreement. Determined by risk level and agreement terms.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Overall Performance Rating' ;
    rdfs:comment 'Composite performance rating assigned to the partner for the review period. Drives partnership renewal, risk classification, and sub-award decisions. Aligned with DAC evaluation criteria.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Overall Performance Score' ;
    rdfs:comment 'Numeric composite score (e.g., 0.00–100.00) aggregating all scored dimensions of the review. Enables quantitative ranking and trend analysis across partners.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerAcknowledgementReceived rdf:type rdf:Property ;
    rdfs:label 'Partner Acknowledgement Received' ;
    rdfs:comment 'Indicates whether the implementing partner has formally acknowledged receipt of the review findings and agreed corrective actions. Required for CHS accountability compliance.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnershipRenewalRecommendation rdf:type rdf:Property ;
    rdfs:label 'Partnership Renewal Recommendation' ;
    rdfs:comment 'Reviewer\'s recommendation on whether to renew, conditionally renew, or terminate the partnership agreement based on this review\'s findings. Feeds into partnership pipeline decisions.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticQualityRating rdf:type rdf:Property ;
    rdfs:label 'Programmatic Quality Rating' ;
    rdfs:comment 'Rating of the partner\'s delivery quality against agreed SoW milestones, Theory of Change (ToC) outputs, and LogFrame indicators. Distinct from financial accountability.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Reporting Compliance Rating' ;
    rdfs:comment 'Rating of the partner\'s adherence to agreed reporting schedules, SitRep submissions, and donor reporting requirements including IATI data publication obligations.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportsDueCount rdf:type rdf:Property ;
    rdfs:label 'Reports Due Count' ;
    rdfs:comment 'Total number of reports required from the partner during the review period per the agreement schedule.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportsSubmittedCount rdf:type rdf:Property ;
    rdfs:label 'Reports Submitted Count' ;
    rdfs:comment 'Number of required narrative and financial reports submitted by the partner during the review period.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewMethod rdf:type rdf:Property ;
    rdfs:label 'Review Method' ;
    rdfs:comment 'Methodology used to conduct the performance review. Field visits provide direct observation; desk reviews rely on submitted documentation; joint reviews involve donor or cluster lead participation.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Review Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this review for tracking in correspondence, donor reports, and audit trails. Format: PPR-YYYY-NNNNNN.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeguardingComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Compliance Rating' ;
    rdfs:comment 'Rating of the partner\'s compliance with safeguarding policies including GBV prevention, child protection, and HAP/CHS accountability commitments.' ;
    rdfs:domain ind:PartnerPerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthsNoted rdf:type rdf:Property ;
    rdfs:label 'Strengths Noted' ;
    rdfs:comment 'Narrative description of the partner\'s notable strengths and positive performance areas identified during the review. Used for learning and best-practice documentation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'The approved sub-award budget amount for the reporting period against which the partner\'s reported expenditure is compared in Budget versus Actual (BvA) analysis.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysLate rdf:type rdf:Property ;
    rdfs:label 'Days Late' ;
    rdfs:comment 'Number of calendar days by which the submission exceeded the due date. Zero or negative values indicate on-time or early submission. Used for partner performance scoring and compliance reporting.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:donorReportReference rdf:type rdf:Property ;
    rdfs:label 'Donor Report Reference' ;
    rdfs:comment 'The reference number or identifier of the upstream donor report into which this partner submission\'s data has been incorporated, enabling traceability from sub-award reporting to prime award donor reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorReportingObligation rdf:type rdf:Property ;
    rdfs:label 'Donor Reporting Obligation' ;
    rdfs:comment 'Indicates whether this partner report submission is required to satisfy a specific donor reporting obligation (e.g., USAID BHA, DFID, CERF), meaning the data must be incorporated into the prime recipient\'s donor report.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feedbackProvided rdf:type rdf:Property ;
    rdfs:label 'Feedback Provided' ;
    rdfs:comment 'Detailed written feedback, comments, or queries provided by the reviewer to the implementing partner following the review of the submitted report. Captures specific issues, clarifications required, or commendations.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialDocumentationAttached rdf:type rdf:Property ;
    rdfs:label 'Financial Documentation Attached' ;
    rdfs:comment 'Indicates whether the partner attached supporting financial documentation (receipts, invoices, bank statements) to this report submission as required under 2 CFR 200 and the sub-award agreement.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLateSubmission rdf:type rdf:Property ;
    rdfs:label 'Is Late Submission' ;
    rdfs:comment 'Indicates whether the report was submitted after the contractually obligated due date. True if submission_date is after due_date. Used for partner performance monitoring and compliance tracking.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:melIndicatorsReported rdf:type rdf:Property ;
    rdfs:label 'Mel Indicators Reported' ;
    rdfs:comment 'Indicates whether the partner included MEL (Monitoring Evaluation and Learning) indicator data and results in this report submission, as required by the sub-award agreement.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Additional notes, contextual observations, or internal comments recorded by the grants management team regarding this report submission, such as exceptional circumstances, force majeure events, or escalation notes.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportPeriodFrequency rdf:type rdf:Property ;
    rdfs:label 'Report Period Frequency' ;
    rdfs:comment 'The scheduled reporting cadence for this submission as defined in the sub-award agreement, indicating whether the report covers a monthly, quarterly, semi-annual, annual, or ad hoc period.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportVersion rdf:type rdf:Property ;
    rdfs:label 'Report Version' ;
    rdfs:comment 'Sequential version number of the report submission, incremented each time the partner resubmits a revised version following feedback or a revision request. Version 1 is the initial submission.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'The date on which the review of the partner report was completed and a decision (accepted, feedback issued, or rejected) was communicated to the partner.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionDeadline rdf:type rdf:Property ;
    rdfs:label 'Revision Deadline' ;
    rdfs:comment 'The deadline by which the implementing partner must resubmit a revised report following a revision request or feedback issuance. Null if no revision has been requested.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetBeneficiaries rdf:type rdf:Property ;
    rdfs:label 'Target Beneficiaries' ;
    rdfs:comment 'The planned number of beneficiaries the partner was expected to reach during the reporting period as defined in the sub-award agreement or LogFrame targets.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalExpenditureReported rdf:type rdf:Property ;
    rdfs:label 'Total Expenditure Reported' ;
    rdfs:comment 'The total financial expenditure reported by the implementing partner for the reporting period, as stated in the financial report. Used for Budget versus Actual (BvA) analysis and donor financial reporting.' ;
    rdfs:domain ind:PartnerReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerRiskRegisterId rdf:type rdf:Property ;
    rdfs:label 'Partner Risk Register Id' ;
    rdfs:comment 'Unique surrogate identifier for each risk entry in the partner risk register. Primary key for this data product.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compositeRiskScore rdf:type rdf:Property ;
    rdfs:label 'Composite Risk Score' ;
    rdfs:comment 'Calculated product of likelihood_rating multiplied by impact_rating (range 1–25), yielding the overall risk severity score used to prioritise mitigation actions and sub-award oversight decisions. Stored as a business-recorded value from the risk assessment process, not a real-time derived metric.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:donorNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Donor Notified Date' ;
    rdfs:comment 'Date on which the donor was formally notified of this risk or incident. Null if notification has not yet occurred or is not required. Used for compliance tracking against donor agreement notification timelines.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDiligenceLevel rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Level' ;
    rdfs:comment 'Level of due diligence applied to this partner in relation to this risk: standard (routine checks), enhanced (additional scrutiny for high-risk partners), simplified (low-risk, minimal checks). Aligns with donor-mandated partner vetting requirements.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedTo rdf:type rdf:Property ;
    rdfs:label 'Escalated To' ;
    rdfs:comment 'Name or role of the individual, committee, or external body to whom this risk was escalated (e.g., \'Country Director\', \'Board Risk Committee\', \'USAID Agreement Officer\'). Supports accountability and audit trail requirements.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiduciaryRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Fiduciary Risk Flag' ;
    rdfs:comment 'Indicates whether this risk entry has been classified as a fiduciary risk (True) involving financial management, fund accountability, or procurement integrity concerns. Triggers enhanced financial monitoring protocols.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialExposureUsd rdf:type rdf:Property ;
    rdfs:label 'Financial Exposure Usd' ;
    rdfs:comment 'Estimated maximum financial exposure in US Dollars associated with this risk, representing the value of funds at risk if the risk materialises (e.g., sub-award value at risk of misappropriation). Used in fiduciary risk prioritisation and BvA oversight.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inherentImpactRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Impact Rating' ;
    rdfs:comment 'Impact rating (1–5) assessed BEFORE any mitigation controls are applied. Together with inherent_likelihood_rating, establishes the gross risk score prior to control application.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Likelihood Rating' ;
    rdfs:comment 'Likelihood rating (1–5) assessed BEFORE any mitigation controls are applied. Captures the gross/inherent risk level to benchmark the effectiveness of mitigation measures.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:likelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Likelihood Rating' ;
    rdfs:comment 'Numeric score (1–5) representing the probability that the risk will materialise: 1=Rare, 2=Unlikely, 3=Possible, 4=Likely, 5=Almost Certain. Used in composite risk scoring per standard NGO risk matrices.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationMeasures rdf:type rdf:Property ;
    rdfs:label 'Mitigation Measures' ;
    rdfs:comment 'Narrative description of the specific controls, actions, and safeguards implemented or planned to reduce the likelihood or impact of the risk. May include capacity-building, enhanced financial monitoring, spot-checks, or escalation protocols.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStatus rdf:type rdf:Property ;
    rdfs:label 'Mitigation Status' ;
    rdfs:comment 'Current implementation status of the mitigation measures: planned (not yet started), in_progress (underway), completed (fully implemented), overdue (past target date without completion).' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oversightMechanism rdf:type rdf:Property ;
    rdfs:label 'Oversight Mechanism' ;
    rdfs:comment 'Description of the specific oversight mechanism applied to manage this risk (e.g., \'Monthly financial spot-checks\', \'Quarterly field monitoring visits\', \'Third-party audit\', \'PDM surveys\'). Documents the control environment for donor compliance.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAppetiteAlignment rdf:type rdf:Property ;
    rdfs:label 'Risk Appetite Alignment' ;
    rdfs:comment 'Assessment of whether this risk falls within the organisation\'s defined risk appetite: within_appetite (acceptable), at_tolerance (borderline, requires monitoring), exceeds_appetite (unacceptable, requires immediate action or sub-award suspension).' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClosureDate rdf:type rdf:Property ;
    rdfs:label 'Risk Closure Date' ;
    rdfs:comment 'The date on which this risk was formally closed, either because it was fully mitigated, the sub-award ended, or the risk was deemed no longer applicable. Null if the risk remains open.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskIdentificationDate rdf:type rdf:Property ;
    rdfs:label 'Risk Identification Date' ;
    rdfs:comment 'The date on which this risk was first formally identified and entered into the risk register. Marks the start of the risk lifecycle and is used for ageing analysis.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskMaterialisationDate rdf:type rdf:Property ;
    rdfs:label 'Risk Materialisation Date' ;
    rdfs:comment 'Date on which the risk was confirmed to have materialised into an actual incident or adverse event. Null if the risk has not materialised. Used for incident timeline analysis and donor reporting.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskMaterialised rdf:type rdf:Property ;
    rdfs:label 'Risk Materialised' ;
    rdfs:comment 'Indicates whether the identified risk has actually materialised into an incident or adverse event (True). When True, triggers incident management workflows and may require sub-award suspension or termination review.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskOwner rdf:type rdf:Property ;
    rdfs:label 'Risk Owner' ;
    rdfs:comment 'Name or role title of the individual within the NGO responsible for monitoring and managing this risk entry. Typically a Program Manager, Grants Manager, or Country Director.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRegisterCode rdf:type rdf:Property ;
    rdfs:label 'Risk Register Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to this risk entry for cross-system reference and reporting (e.g., RR-FISC-2024-0012). Used in donor reports, audit trails, and compliance filings.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle state of the risk entry: open (identified, not yet addressed), under_review (being assessed), mitigated (controls applied), escalated (elevated to senior management or donor), closed (resolved or no longer applicable).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Risk Subcategory' ;
    rdfs:comment 'Granular classification within the risk category (e.g., \'Procurement Fraud\' under fiduciary, \'GBV Incident\' under safeguarding, \'FCPA Violation\' under compliance). [ENUM-REF-CANDIDATE: procurement_fraud|financial_misreporting|conflict_of_interest|gbv_incident|child_protection|data_breach|political_interference|media_exposure|delivery_failure|quality_failure|regulatory_breach|donor_condition_breach — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTitle rdf:type rdf:Property ;
    rdfs:label 'Risk Title' ;
    rdfs:comment 'Short, human-readable title summarising the risk (e.g., \'Inadequate financial controls at field office level\'). Used as the primary label in risk dashboards and SitRep summaries.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeguardingRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Risk Flag' ;
    rdfs:comment 'Indicates whether this risk entry involves safeguarding concerns (True), including GBV, child protection, or protection of beneficiaries and staff from exploitation and abuse. Triggers mandatory escalation per CHS safeguarding protocols.' ;
    rdfs:domain ind:PartnerRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programManagerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Program Manager Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Partnership agreements require designated NGO program manager for oversight, amendment approvals, performance review sign-off, and donor reporting accountability. Distinct from partner_org relationshi' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to safeguarding.risk_assessment. Business justification: Partnership agreements require safeguarding risk assessments before execution per donor compliance standards (CHS, Grand Bargain). Risk assessment informs partnership approval decisions and monitoring' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the formal inter-organizational legal instrument. MoU = Memorandum of Understanding; LoA = Letter of Agreement; SoW = Scope of Work; sub_award = sub-grant or sub-award agreement; consortium = multi-party consortium agreement; other = any other instrument type. [ENUM-REF-CANDIDATE: MoU|LoA|SoW|sub_award|consortium|framework|other — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date on which the most recent amendment to the agreement was executed. Null for original agreements with no amendments.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Capacity Assessment Status' ;
    rdfs:comment 'Status of the partner due diligence and capacity assessment conducted prior to or during the agreement. not_required = exempt; pending = assessment initiated but not complete; completed = assessment passed; failed = partner did not meet threshold; waived = formally waived by authorized approver.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Agreed mechanism for resolving disputes arising under the agreement. Captured from the legal instrument\'s dispute resolution clause.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDiligenceRiskRating rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Risk Rating' ;
    rdfs:comment 'Risk rating assigned to the partner following due diligence review. Informs monitoring intensity, financial controls, and reporting requirements under the agreement.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingCeilingAmount rdf:type rdf:Property ;
    rdfs:label 'Funding Ceiling Amount' ;
    rdfs:comment 'Maximum total financial value authorized under the agreement in the agreement\'s stated currency. For sub-awards, this is the maximum sub-grant amount. Null for non-financial MoUs.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingLawCountryCode rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern the interpretation and enforcement of the agreement (e.g., GBR, USA, CHE).' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConsortiumAgreement rdf:type rdf:Property ;
    rdfs:label 'Is Consortium Agreement' ;
    rdfs:comment 'Indicates whether this agreement governs a multi-party consortium arrangement (True) rather than a bilateral agreement (False). Consortium agreements may have additional members tracked separately.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubAward rdf:type rdf:Property ;
    rdfs:label 'Is Sub Award' ;
    rdfs:comment 'Indicates whether this agreement is a sub-award (True) or a prime/direct agreement (False). Drives compliance requirements under OMB Uniform Guidance 2 CFR 200 for pass-through entities.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Lead Organization Name' ;
    rdfs:comment 'Legal name of the primary organization (typically the prime recipient or lead INGO) that is the principal party initiating or managing the agreement. Serves as the PARTY_REFERENCE anchor for the agreement.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Parent Agreement Reference' ;
    rdfs:comment 'Agreement reference number of the parent or prime agreement under which this sub-award or amendment was issued. Enables hierarchical agreement traceability. Null for top-level agreements.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Indicates whether the agreement contains a renewal or extension option clause (True) that allows the parties to extend the agreement beyond the effective end date without a full renegotiation.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatoryNameLead rdf:type rdf:Property ;
    rdfs:label 'Signatory Name Lead' ;
    rdfs:comment 'Full name of the authorized signatory representing the lead organization on the agreement. Captured for legal validity and audit purposes.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryNamePartner rdf:type rdf:Property ;
    rdfs:label 'Signatory Name Partner' ;
    rdfs:comment 'Full name of the authorized signatory representing the partner organization on the agreement. Captured for legal validity and audit purposes.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of calendar days\' written notice required by either party to terminate the agreement without cause, as specified in the termination clause.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:theoryOfChangeReference rdf:type rdf:Property ;
    rdfs:label 'Theory Of Change Reference' ;
    rdfs:comment 'Reference identifier or title of the Theory of Change (ToC) or LogFrame (Logical Framework) document that underpins the program activities governed by this agreement. Links the agreement to the MEL framework.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Approved By Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Budget approval authority must be traceable to specific staff for financial controls, donor compliance, audit trails, and delegation of authority documentation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:itProjectId rdf:type rdf:Property ;
    rdfs:label 'It Project Id' ;
    rdfs:comment 'Foreign key linking to technology.it_project. Business justification: IT projects often have dedicated budget plans within program budgets (technology procurement, system implementation costs). Required for financial tracking of technology investments and cost allocatio' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItProject .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Explanation of why this budget plan was amended or revised, if applicable.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAssumptions rdf:type rdf:Property ;
    rdfs:label 'Budget Assumptions' ;
    rdfs:comment 'Key assumptions underlying the budget plan, such as exchange rates, inflation rates, beneficiary numbers, or activity volumes.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetOwner rdf:type rdf:Property ;
    rdfs:label 'Budget Owner' ;
    rdfs:comment 'Name or identifier of the program manager or budget holder responsible for this budget plan.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPlanName rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Name' ;
    rdfs:comment 'Descriptive name or title of the budget plan, typically aligned with program or grant phase.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Number' ;
    rdfs:comment 'Externally-known unique identifier or code for this budget plan, used in donor reporting and financial communications.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorBudgetCode rdf:type rdf:Property ;
    rdfs:label 'Donor Budget Code' ;
    rdfs:comment 'Donor-specific budget classification code or identifier required for reporting and compliance.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financeContact rdf:type rdf:Property ;
    rdfs:label 'Finance Contact' ;
    rdfs:comment 'Name or identifier of the finance team member responsible for financial oversight of this budget plan.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indirectCosts rdf:type rdf:Property ;
    rdfs:label 'Indirect Costs' ;
    rdfs:comment 'Total budgeted amount for indirect costs (Facilities and Administration), calculated by applying the indirect cost rate to the direct cost base.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sectorClassification rdf:type rdf:Property ;
    rdfs:label 'Sector Classification' ;
    rdfs:comment 'Humanitarian or development sector classification for this budget plan. [ENUM-REF-CANDIDATE: wash|health|nutrition|education|protection|livelihoods|shelter|food_security|emergency_response|capacity_building — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalApprovedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Approved Budget Amount' ;
    rdfs:comment 'Total approved budget amount for this plan, representing the sum of all cost categories.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetPlanLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Line Id' ;
    rdfs:comment 'Unique identifier for the budget plan line item. Primary key for this entity.' ;
    rdfs:domain ind:BudgetPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetPlanLineStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Line Status' ;
    rdfs:comment 'Current lifecycle status of the budget line item. Tracks approval workflow and execution state. [ENUM-REF-CANDIDATE: draft|submitted|approved|active|revised|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BudgetPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'General Ledger account code from the organization\'s Chart of Accounts. Links budget planning to financial accounting and enables BvA tracking.' ;
    rdfs:domain ind:BudgetPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSharingAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Sharing Amount' ;
    rdfs:comment 'The portion of the total planned amount that represents cost sharing or matching contribution. Used for grant compliance reporting.' ;
    rdfs:domain ind:BudgetPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costSharingFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Sharing Flag' ;
    rdfs:comment 'Indicates whether this budget line includes cost sharing or matching funds from the organization or other sources. Critical for grant compliance.' ;
    rdfs:domain ind:BudgetPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costSharingSource rdf:type rdf:Property ;
    rdfs:label 'Cost Sharing Source' ;
    rdfs:comment 'The source of cost sharing funds (e.g., organizational reserves, other grants, in-kind contributions, partner contributions).' ;
    rdfs:domain ind:BudgetPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPlannedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Planned Amount' ;
    rdfs:comment 'The total budgeted amount for this line item, typically calculated as quantity multiplied by unit cost. Primary financial value for budget versus actual (BvA) tracking.' ;
    rdfs:domain ind:BudgetPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_finding. Business justification: Audit findings are often specific to program components (questioned costs by component, compliance deficiencies in specific activities). Essential for tracking corrective actions at component level.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:parentComponentId rdf:type rdf:Property ;
    rdfs:label 'Parent Component Id' ;
    rdfs:comment 'Reference to the parent component if this is a sub-component or workstream. Null for top-level components. Supports hierarchical program navigation.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Component .

ind:budgetEnvelopeAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Envelope Amount' ;
    rdfs:comment 'Total allocated budget for this component in the program\'s base currency. Represents the financial ceiling for component activities and procurement.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentCode rdf:type rdf:Property ;
    rdfs:label 'Component Code' ;
    rdfs:comment 'Externally-known unique business identifier for the component, used in donor reporting, grant management systems, and field operations documentation.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Detailed narrative describing the component\'s objectives, scope, target beneficiaries, and expected outcomes. Supports Theory of Change (ToC) articulation.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentName rdf:type rdf:Property ;
    rdfs:label 'Component Name' ;
    rdfs:comment 'Human-readable name of the program component (e.g., \'Water Supply Infrastructure\', \'Hygiene Promotion\', \'Community Health Worker Training\').' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentStatus rdf:type rdf:Property ;
    rdfs:label 'Component Status' ;
    rdfs:comment 'Current lifecycle status of the component (planned, active, on hold, completed, closed, cancelled). Tracks component progression through implementation phases.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Classification of the component within the program structure (component, sub-component, workstream, activity cluster, pilot, scale-up).' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossCuttingThemes rdf:type rdf:Property ;
    rdfs:label 'Cross Cutting Themes' ;
    rdfs:comment 'Cross-cutting priorities integrated into this component (e.g., gender equality, disability inclusion, environmental sustainability, conflict sensitivity, accountability to affected populations).' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Primary donor, grant, or funding mechanism supporting this component (e.g., USAID BHA, CERF, DFID, private foundation). Enables fund accounting and donor visibility.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Grant Requirement Flag' ;
    rdfs:comment 'Indicates whether this component is mandated by a specific grant agreement or donor requirement (True) or is discretionary within the program design (False).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementationModality rdf:type rdf:Property ;
    rdfs:label 'Implementation Modality' ;
    rdfs:comment 'Delivery approach for this component (direct implementation by NGO staff, partner-led, consortium, sub-award, community-based organization). Affects partnership and compliance requirements.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationFlag rdf:type rdf:Property ;
    rdfs:label 'Integration Flag' ;
    rdfs:comment 'Indicates whether this component is part of an integrated multi-sector program (True) or a standalone single-sector intervention (False). Supports integrated programming analysis.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleManager rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager' ;
    rdfs:comment 'Name of the program manager or component lead accountable for delivery, monitoring, and reporting of this component.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subSector rdf:type rdf:Property ;
    rdfs:label 'Sub Sector' ;
    rdfs:comment 'Detailed sub-sector classification within the primary sector (e.g., for WASH: water supply, sanitation, hygiene promotion; for Health: primary care, maternal health, immunization).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Design Assessment Id' ;
    rdfs:comment 'Unique identifier for the program design assessment record.' ;
    rdfs:domain ind:DesignAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentTeamLead rdf:type rdf:Property ;
    rdfs:label 'Assessment Team Lead' ;
    rdfs:comment 'Name or identifier of the individual or organization leading the assessment team.' ;
    rdfs:domain ind:DesignAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTeamSize rdf:type rdf:Property ;
    rdfs:label 'Assessment Team Size' ;
    rdfs:comment 'Number of enumerators, surveyors, or field staff involved in conducting the assessment.' ;
    rdfs:domain ind:DesignAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentTitle rdf:type rdf:Property ;
    rdfs:label 'Assessment Title' ;
    rdfs:comment 'Descriptive title of the design assessment (e.g., \'Rapid Nutrition Assessment - Northern Province\').' ;
    rdfs:domain ind:DesignAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionEndDate rdf:type rdf:Property ;
    rdfs:label 'Data Collection End Date' ;
    rdfs:comment 'Date when field data collection for this assessment was completed.' ;
    rdfs:domain ind:DesignAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataCollectionStartDate rdf:type rdf:Property ;
    rdfs:label 'Data Collection Start Date' ;
    rdfs:comment 'Date when field data collection for this assessment began.' ;
    rdfs:domain ind:DesignAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSharingRestrictions rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Restrictions' ;
    rdfs:comment 'Description of any restrictions on sharing or publishing the assessment data, due to sensitivity, partner agreements, or ethical considerations.' ;
    rdfs:domain ind:DesignAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicalApprovalObtained rdf:type rdf:Property ;
    rdfs:label 'Ethical Approval Obtained' ;
    rdfs:comment 'Indicates whether formal ethical approval or informed consent protocols were obtained prior to conducting the assessment (True/False).' ;
    rdfs:domain ind:DesignAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gamPrevalencePercent rdf:type rdf:Property ;
    rdfs:label 'Gam Prevalence Percent' ;
    rdfs:comment 'Percentage of the assessed population exhibiting Global Acute Malnutrition, a key nutrition indicator for program design.' ;
    rdfs:domain ind:DesignAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:humanitarianPrinciplesCompliance rdf:type rdf:Property ;
    rdfs:label 'Humanitarian Principles Compliance' ;
    rdfs:comment 'Indicates whether the assessment was conducted in compliance with core humanitarian principles (humanity, neutrality, impartiality, independence): full compliance, partial compliance, or not applicable.' ;
    rdfs:domain ind:DesignAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityNeedsRanking rdf:type rdf:Property ;
    rdfs:label 'Priority Needs Ranking' ;
    rdfs:comment 'Ordered list or narrative of the top priority needs identified by the assessed population, used to inform program design and resource allocation.' ;
    rdfs:domain ind:DesignAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionRisksIdentified rdf:type rdf:Property ;
    rdfs:label 'Protection Risks Identified' ;
    rdfs:comment 'Narrative description of protection risks identified during the assessment, such as GBV (Gender-Based Violence), child protection concerns, or safety threats.' ;
    rdfs:domain ind:DesignAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samPrevalencePercent rdf:type rdf:Property ;
    rdfs:label 'Sam Prevalence Percent' ;
    rdfs:comment 'Percentage of the assessed population exhibiting Severe Acute Malnutrition, indicating urgent intervention needs.' ;
    rdfs:domain ind:DesignAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sectorFocus rdf:type rdf:Property ;
    rdfs:label 'Sector Focus' ;
    rdfs:comment 'Primary humanitarian or development sector this assessment focuses on: WASH (Water Sanitation and Hygiene), health, nutrition, education, protection, livelihoods, shelter, food security, or multi-sector. [ENUM-REF-CANDIDATE: wash|health|nutrition|education|protection|livelihoods|shelter|food_security|multi_sector — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPopulationDescription rdf:type rdf:Property ;
    rdfs:label 'Target Population Description' ;
    rdfs:comment 'Narrative description of the population segment assessed (e.g., \'IDPs in camp settings\', \'rural women of reproductive age\', \'school-age children\').' ;
    rdfs:domain ind:DesignAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:washCoverageGapPercent rdf:type rdf:Property ;
    rdfs:label 'Wash Coverage Gap Percent' ;
    rdfs:comment 'Percentage of the assessed population lacking access to adequate WASH services, indicating program need.' ;
    rdfs:domain ind:DesignAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coordinationMechanism rdf:type rdf:Property ;
    rdfs:label 'Coordination Mechanism' ;
    rdfs:comment 'Description of coordination mechanisms with partners, clusters, local authorities, and other stakeholders for implementation plan execution.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disaggregationApproach rdf:type rdf:Property ;
    rdfs:label 'Disaggregation Approach' ;
    rdfs:comment 'Description of how beneficiary data will be disaggregated (by gender, age, disability, displacement status, etc.) for equity and accountability.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Last Revision Date' ;
    rdfs:comment 'Date of the most recent revision or amendment to this implementation plan.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringApproach rdf:type rdf:Property ;
    rdfs:label 'Monitoring Approach' ;
    rdfs:comment 'Description of the monitoring and evaluation approach for tracking implementation plan progress, including data collection methods and frequency.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planManagerName rdf:type rdf:Property ;
    rdfs:label 'Plan Manager Name' ;
    rdfs:comment 'Full name of the staff member serving as the implementation plan manager or work plan coordinator.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the planning period covered by this implementation plan, marking the scheduled completion of all activities.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the planning period covered by this implementation plan, marking the beginning of scheduled activities.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resourceRequirementsSummary rdf:type rdf:Property ;
    rdfs:label 'Resource Requirements Summary' ;
    rdfs:comment 'Summary of human resources, equipment, supplies, and other resources required to execute this implementation plan.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMitigationSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Summary' ;
    rdfs:comment 'Summary of key risks identified and mitigation strategies planned to ensure implementation plan success.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBeneficiaryType rdf:type rdf:Property ;
    rdfs:label 'Target Beneficiary Type' ;
    rdfs:comment 'Unit of measurement for target beneficiaries (individuals, households, communities, or institutions).' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tocReference rdf:type rdf:Property ;
    rdfs:label 'Toc Reference' ;
    rdfs:comment 'Reference identifier linking this implementation plan to the program Theory of Change pathway and assumptions.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPlannedActivities rdf:type rdf:Property ;
    rdfs:label 'Total Planned Activities' ;
    rdfs:comment 'Total number of discrete activities scheduled in this implementation plan.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPlannedMilestones rdf:type rdf:Property ;
    rdfs:label 'Total Planned Milestones' ;
    rdfs:comment 'Total number of key milestones defined in this implementation plan for progress tracking and donor reporting.' ;
    rdfs:domain ind:ImplementationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:governingPseaPolicyId rdf:type rdf:Property ;
    rdfs:label 'Governing Psea Policy Id' ;
    rdfs:comment 'Foreign key linking to safeguarding.psea_policy. Business justification: Regulatory compliance requirement: interventions must document which PSEA policy version governs their safeguarding obligations. Intervention.safeguarding_policy_applied flag indicates compliance but ' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PseaPolicy .

ind:implementingOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Implementing Org Unit Id' ;
    rdfs:comment 'Identifier of the organizational unit (country office, regional office, or headquarters division) responsible for implementing this intervention.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primarySystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Primary System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Programs track primary digital platforms supporting implementation (KoboToolbox for surveys, CommCare for case management, DHIS2 for health data). Essential for M&E operations, data quality audits, an' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:chsCompliant rdf:type rdf:Property ;
    rdfs:label 'Chs Compliant' ;
    rdfs:comment 'Indicates whether the intervention design and implementation plan adhere to the Core Humanitarian Standard on Quality and Accountability, covering nine commitments from needs assessment through accountability to affected populations.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disabilityInclusionMarkerScore rdf:type rdf:Property ;
    rdfs:label 'Disability Inclusion Marker Score' ;
    rdfs:comment 'Score indicating the level of disability inclusion in the intervention design and implementation. 0: not disability inclusive; 1: disability visible; 2: disability integrated; 3: disability targeted; 4: disability transformative.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNoHarmAssessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Do No Harm Assessment Completed' ;
    rdfs:comment 'Indicates whether a Do No Harm analysis was conducted to identify and mitigate potential negative impacts of the intervention on conflict dynamics, social cohesion, or vulnerable groups.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalImpactAssessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Assessment Completed' ;
    rdfs:comment 'Indicates whether an environmental impact assessment was conducted to evaluate and mitigate potential environmental harm from intervention activities (e.g., water extraction, waste disposal, construction).' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderMarkerScore rdf:type rdf:Property ;
    rdfs:label 'Gender Marker Score' ;
    rdfs:comment 'IASC Gender Marker score indicating the extent to which the intervention integrates gender equality. 0: no gender integration; 1: contributes to gender equality; 2a: has gender equality as a significant objective; 2b: has gender equality as the principal objective.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interventionCode rdf:type rdf:Property ;
    rdfs:label 'Intervention Code' ;
    rdfs:comment 'Externally-known unique business identifier for the intervention, used in donor reporting, grant proposals, and field operations. Often follows organizational or donor-specific coding conventions.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interventionName rdf:type rdf:Property ;
    rdfs:label 'Intervention Name' ;
    rdfs:comment 'Full descriptive name of the intervention as it appears in grant proposals, donor reports, and public communications.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logframeDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Logframe Document Url' ;
    rdfs:comment 'URL or file path to the intervention\'s Logical Framework Matrix document, which details the intervention logic, indicators, means of verification, and assumptions.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logic rdf:type rdf:Property ;
    rdfs:label 'Logic' ;
    rdfs:comment 'Structured description of the intervention\'s logical framework (LogFrame): how activities will produce outputs, how outputs will lead to outcomes, and how outcomes will contribute to impact. Includes key assumptions and risks at each level.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melPlanDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Mel Plan Document Url' ;
    rdfs:comment 'URL or file path to the intervention\'s MEL plan, which outlines the monitoring framework, evaluation schedule, data collection methods, and learning agenda.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Current operational phase within the intervention lifecycle. Design: developing ToC, LogFrame, and proposal; Startup: mobilizing resources, recruiting staff, establishing field presence; Implementation: delivering activities and services; Closeout: finalizing activities, conducting evaluations, submitting final reports.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rbmFrameworkApplied rdf:type rdf:Property ;
    rdfs:label 'Rbm Framework Applied' ;
    rdfs:comment 'Indicates whether the intervention applies a formal Results-Based Management framework with defined inputs, activities, outputs, outcomes, and impact, along with indicators and targets at each level.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safeguardingPolicyApplied rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Policy Applied' ;
    rdfs:comment 'Indicates whether the intervention implements organizational safeguarding policies to prevent sexual exploitation, abuse, and harassment (SEAH) and protect vulnerable populations, particularly children and women.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdgAlignmentType rdf:type rdf:Property ;
    rdfs:label 'Sdg Alignment Type' ;
    rdfs:comment 'Nature of the intervention\'s contribution to the SDG. Direct: intervention activities directly advance the SDG indicator; Indirect: intervention creates conditions that support SDG progress; Enabling: intervention builds capacity or systems that enable others to advance the SDG.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgContributionNarrative rdf:type rdf:Property ;
    rdfs:label 'Sdg Contribution Narrative' ;
    rdfs:comment 'Qualitative description of how the intervention contributes to the identified SDG goal, target, and indicator. Articulates the causal pathway and expected magnitude of contribution.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgGoalPrimary rdf:type rdf:Property ;
    rdfs:label 'Sdg Goal Primary' ;
    rdfs:comment 'Primary UN Sustainable Development Goal that this intervention contributes to, expressed as SDG number (e.g., SDG1 for No Poverty, SDG3 for Good Health and Well-being, SDG6 for Clean Water and Sanitation).' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgIndicatorPrimary rdf:type rdf:Property ;
    rdfs:label 'Sdg Indicator Primary' ;
    rdfs:comment 'Specific SDG indicator used to measure the intervention\'s contribution to the primary target (e.g., 6.1.1 for proportion of population using safely managed drinking water services).' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgTargetPrimary rdf:type rdf:Property ;
    rdfs:label 'Sdg Target Primary' ;
    rdfs:comment 'Specific SDG target within the primary goal that this intervention addresses (e.g., 6.1 for universal access to safe drinking water, 3.8 for universal health coverage).' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:situationAnalysis rdf:type rdf:Property ;
    rdfs:label 'Situation Analysis' ;
    rdfs:comment 'Detailed analysis of the humanitarian or development context that justifies the intervention. Includes needs assessment findings, vulnerability analysis, root causes of the problem, and gaps in existing services or coverage.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sphereStandardsApplied rdf:type rdf:Property ;
    rdfs:label 'Sphere Standards Applied' ;
    rdfs:comment 'Indicates whether the intervention applies Sphere Humanitarian Charter and Minimum Standards in Humanitarian Response, including protection principles and technical standards for WASH, food security, shelter, and health.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetBeneficiaryUnit rdf:type rdf:Property ;
    rdfs:label 'Target Beneficiary Unit' ;
    rdfs:comment 'Unit of measurement for target beneficiaries. Individuals: unique persons; Households: family units; Communities: villages or settlements; Institutions: schools, health facilities, or organizations.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingStrategy rdf:type rdf:Property ;
    rdfs:label 'Targeting Strategy' ;
    rdfs:comment 'Methodology and criteria for identifying and selecting beneficiaries. Describes vulnerability criteria, geographic targeting, inclusion/exclusion criteria, and mechanisms to ensure equitable access and prevent exclusion errors.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoryOfChangeNarrative rdf:type rdf:Property ;
    rdfs:label 'Theory Of Change Narrative' ;
    rdfs:comment 'Comprehensive narrative describing the intervention\'s Theory of Change: the causal pathway from inputs and activities through outputs, outcomes, and impact. Articulates assumptions, preconditions, and the logic connecting intervention activities to intended long-term change.' ;
    rdfs:domain ind:Intervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'Total approved budget for the intervention across all funding sources, expressed in the organization\'s reporting currency. Includes direct program costs, indirect costs, and any cost-sharing or in-kind contributions.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:logframeRowId rdf:type rdf:Property ;
    rdfs:label 'Logframe Row Id' ;
    rdfs:comment 'Unique identifier for the LogFrame row entry. Primary key for the logframe_row product.' ;
    rdfs:domain ind:LogframeRow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentResultLogframeRowId rdf:type rdf:Property ;
    rdfs:label 'Parent Result Logframe Row Id' ;
    rdfs:comment 'Reference to the parent result row in the LogFrame hierarchy. Enables navigation of the results chain (e.g., linking an output to its parent outcome).' ;
    rdfs:domain ind:LogframeRow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LogframeRow .

ind:beneficiaryTargetCount rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Target Count' ;
    rdfs:comment 'The number of beneficiaries or persons of concern (PoC) targeted to benefit from this result. Critical for reach and coverage reporting.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dacCode rdf:type rdf:Property ;
    rdfs:label 'Dac Code' ;
    rdfs:comment 'The OECD DAC sector or purpose code assigned to this result. Enables standardized international development reporting.' ;
    rdfs:domain ind:LogframeRow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationEndDate rdf:type rdf:Property ;
    rdfs:label 'Implementation End Date' ;
    rdfs:comment 'The date when implementation activities for this result are scheduled to be completed.' ;
    rdfs:domain ind:LogframeRow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStartDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Start Date' ;
    rdfs:comment 'The date when implementation activities for this result are scheduled to begin.' ;
    rdfs:domain ind:LogframeRow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:logframeRowStatus rdf:type rdf:Property ;
    rdfs:label 'Logframe Row Status' ;
    rdfs:comment 'Current status of this result in the program lifecycle. Tracks whether the result is on track, at risk, achieved, or cancelled. [ENUM-REF-CANDIDATE: draft|active|on-track|at-risk|delayed|achieved|not-achieved|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LogframeRow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultCode rdf:type rdf:Property ;
    rdfs:label 'Result Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to this result for tracking and reporting purposes. Often follows a hierarchical numbering scheme (e.g., 1.1.1, 1.1.2).' ;
    rdfs:domain ind:LogframeRow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultLevel rdf:type rdf:Property ;
    rdfs:label 'Result Level' ;
    rdfs:comment 'The hierarchical level of this result within the LogFrame structure. Defines whether this row represents a goal, outcome, output, activity, or input in the results chain.' ;
    rdfs:domain ind:LogframeRow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultStatement rdf:type rdf:Property ;
    rdfs:label 'Result Statement' ;
    rdfs:comment 'The narrative description of the intended result at this level. Articulates what change or achievement is expected (e.g., \'Improved access to clean water for 10,000 households\').' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordinal position of this row within the LogFrame document. Determines the display order and hierarchical structure of results.' ;
    rdfs:domain ind:LogframeRow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerLinkageId rdf:type rdf:Property ;
    rdfs:label 'Partner Linkage Id' ;
    rdfs:comment 'Unique identifier for the program-partner linkage record. Primary key.' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerConstituentId rdf:type rdf:Property ;
    rdfs:label 'Partner Constituent Id' ;
    rdfs:comment 'Foreign key linking to donor.constituent. Business justification: Partner organizations may also be donors/funders. Tracks dual-role relationships where implementing partners are also funding partners. Essential for relationship management, conflict-of-interest trac' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:partnerPseaAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Partner Psea Assessment Id' ;
    rdfs:comment 'Foreign key linking to safeguarding.partner_psea_assessment. Business justification: Partnership approval and risk management decisions require direct reference to partner PSEA assessment results. Partner_linkage tracks operational partnership execution (budget, performance, monitorin' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerPseaAssessment .

ind:partnershipSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Partnership System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Partner relationships managed in CRM or partnership management platforms (Salesforce, custom partner portals). Tracks capacity assessments, performance data, and compliance documentation. Essential fo' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:beneficiaryReachedCount rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Reached Count' ;
    rdfs:comment 'Actual number of beneficiaries reached by this partner to date within this program.' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityBuildingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capacity Building Required Flag' ;
    rdfs:comment 'Indicates whether capacity building or technical assistance is required for this partner to successfully implement the program (True/False).' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communityBasedOrganizationFlag rdf:type rdf:Property ;
    rdfs:label 'Community Based Organization Flag' ;
    rdfs:comment 'Indicates whether this partner is a community-based organization (CBO) operating at grassroots level (True/False).' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMonitoringVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Monitoring Visit Date' ;
    rdfs:comment 'Date of the most recent field monitoring visit to the partners implementation sites for this program.' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Last Report Submission Date' ;
    rdfs:comment 'Date when the partner last submitted a progress or financial report for this program.' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localPartnerFlag rdf:type rdf:Property ;
    rdfs:label 'Local Partner Flag' ;
    rdfs:comment 'Indicates whether this partner is a local or national organization (as opposed to an international organization) (True/False).' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monitoringVisitCount rdf:type rdf:Property ;
    rdfs:label 'Monitoring Visit Count' ;
    rdfs:comment 'Total number of field monitoring visits conducted to this partners implementation sites for this program.' ;
    rdfs:domain ind:PartnerLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnershipRole rdf:type rdf:Property ;
    rdfs:label 'Partnership Role' ;
    rdfs:comment 'The functional role the partner organization plays in this program intervention (e.g., lead implementer, sub-grantee, technical partner, government counterpart, consortium member, capacity building partner).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipType rdf:type rdf:Property ;
    rdfs:label 'Partnership Type' ;
    rdfs:comment 'Classification of the partnership arrangement (e.g., direct implementation, sub-award, technical assistance, coordination, joint implementation, government collaboration).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subAwardReference rdf:type rdf:Property ;
    rdfs:label 'Sub Award Reference' ;
    rdfs:comment 'Reference number or identifier of the sub-award agreement if this partnership involves a financial sub-grant. Links to the legal agreement in the partnership domain.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Program Amendment Id' ;
    rdfs:comment 'Unique identifier for the program amendment record. Primary key.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetChangeCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Change Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget change amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Compliance Impact Assessment' ;
    rdfs:comment 'Assessment of how this amendment affects compliance with donor requirements, regulatory obligations, and organizational policies.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorApprovingAuthority rdf:type rdf:Property ;
    rdfs:label 'Donor Approving Authority' ;
    rdfs:comment 'Name or title of the donor representative or agency (e.g., USAID Agreement Officer, DFID Programme Manager) who approved the amendment on behalf of the funding organization.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageChange rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Change' ;
    rdfs:comment 'Description of changes to geographic scope, including new districts, provinces, or countries added or removed from program coverage.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalApprovingAuthority rdf:type rdf:Property ;
    rdfs:label 'Internal Approving Authority' ;
    rdfs:comment 'Name or title of the internal organizational authority (e.g., Program Director, Country Director, Chief Executive Officer) who approved the amendment.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:justificationNarrative rdf:type rdf:Property ;
    rdfs:label 'Justification Narrative' ;
    rdfs:comment 'Detailed business rationale and context explaining why the amendment is necessary, including operational, programmatic, or external factors driving the change.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logframeRevisionFlag rdf:type rdf:Property ;
    rdfs:label 'Logframe Revision Flag' ;
    rdfs:comment 'Indicates whether this amendment includes changes to the program LogFrame (results framework, indicators, targets, or assumptions). True if LogFrame is revised, False otherwise.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logframeRevisionSummary rdf:type rdf:Property ;
    rdfs:label 'Logframe Revision Summary' ;
    rdfs:comment 'Summary of changes made to the LogFrame, including modified indicators, revised targets, new outputs, or updated assumptions.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTargetBeneficiaries rdf:type rdf:Property ;
    rdfs:label 'Original Target Beneficiaries' ;
    rdfs:comment 'The planned number of direct beneficiaries before this amendment, captured for before/after comparison.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedTargetBeneficiaries rdf:type rdf:Property ;
    rdfs:label 'Revised Target Beneficiaries' ;
    rdfs:comment 'The new planned number of direct beneficiaries after this amendment is applied, null if the amendment does not affect beneficiary targets.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Assessment of risks introduced or mitigated by this amendment, including operational, financial, reputational, or compliance risks.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgAlignmentChange rdf:type rdf:Property ;
    rdfs:label 'Sdg Alignment Change' ;
    rdfs:comment 'Description of changes to SDG alignment resulting from this amendment, including new SDG targets added or removed.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorClassificationChange rdf:type rdf:Property ;
    rdfs:label 'Sector Classification Change' ;
    rdfs:comment 'Description of changes to sector classifications (e.g., WASH, Health, Nutrition, Education, Protection) resulting from scope modifications.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderConsultationSummary rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Consultation Summary' ;
    rdfs:comment 'Summary of consultations conducted with beneficiaries, partners, local authorities, and other stakeholders regarding the proposed amendment.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPopulationChange rdf:type rdf:Property ;
    rdfs:label 'Target Population Change' ;
    rdfs:comment 'Description of changes to target beneficiary population, including adjustments to demographic criteria, vulnerability profiles, or total beneficiary numbers.' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timelineExtensionDays rdf:type rdf:Property ;
    rdfs:label 'Timeline Extension Days' ;
    rdfs:comment 'Number of calendar days by which the program implementation period is extended (positive for extensions, negative for reductions, zero if no timeline change).' ;
    rdfs:domain ind:ProgramAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programCloseoutId rdf:type rdf:Property ;
    rdfs:label 'Program Closeout Id' ;
    rdfs:comment 'Unique identifier for the program closeout record.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certifiedByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Certified By Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Program closeout certification must link to authorizing staff for donor final reporting, compliance certification, and organizational accountability in grant closure.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:archivingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Archiving Completion Date' ;
    rdfs:comment 'Date when all program documentation was archived and the archiving process was completed.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:archivingReference rdf:type rdf:Property ;
    rdfs:label 'Archiving Reference' ;
    rdfs:comment 'Reference identifier for the archived program documentation, including location and retention schedule in compliance with record retention requirements.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDispositionPlan rdf:type rdf:Property ;
    rdfs:label 'Asset Disposition Plan' ;
    rdfs:comment 'Detailed plan for disposition of program assets including equipment, inventory, and property, specifying transfer, sale, or disposal methods in compliance with donor requirements.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Disposition Status' ;
    rdfs:comment 'Current status of asset disposition activities: pending, in progress, completed, donor approval required, or approved.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Completion Status' ;
    rdfs:comment 'Status of any required closeout audit: not required, pending, in progress, completed, findings issued, or resolved.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Audit Findings Summary' ;
    rdfs:comment 'Summary of any audit findings, observations, or recommendations issued during the closeout audit process.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Budget Utilization Percentage' ;
    rdfs:comment 'Percentage of approved budget that was actually expended, calculated as (final expenditure / final budget) * 100.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closeoutNumber rdf:type rdf:Property ;
    rdfs:label 'Closeout Number' ;
    rdfs:comment 'Externally-known unique identifier for this closeout process, used in donor communications and compliance reporting.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorSignoffConditions rdf:type rdf:Property ;
    rdfs:label 'Donor Signoff Conditions' ;
    rdfs:comment 'Any conditions or requirements specified by the donor for final closeout approval, including corrective actions or additional documentation needed.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorSignoffDate rdf:type rdf:Property ;
    rdfs:label 'Donor Signoff Date' ;
    rdfs:comment 'Date when the donor provided formal sign-off and approval for program closeout.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorSignoffStatus rdf:type rdf:Property ;
    rdfs:label 'Donor Signoff Status' ;
    rdfs:comment 'Status of donor formal sign-off on the program closeout: pending, submitted, under review, approved, conditional approval, or rejected.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalBeneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Final Beneficiary Count' ;
    rdfs:comment 'Total number of unique beneficiaries served over the entire program lifecycle, as reported in the final program report.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalBeneficiaryCountFemale rdf:type rdf:Property ;
    rdfs:label 'Final Beneficiary Count Female' ;
    rdfs:comment 'Total number of female beneficiaries served, supporting gender-disaggregated reporting requirements.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalBeneficiaryCountMale rdf:type rdf:Property ;
    rdfs:label 'Final Beneficiary Count Male' ;
    rdfs:comment 'Total number of male beneficiaries served, supporting gender-disaggregated reporting requirements.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalBeneficiaryCountOther rdf:type rdf:Property ;
    rdfs:label 'Final Beneficiary Count Other' ;
    rdfs:comment 'Total number of beneficiaries with non-binary or other gender identities served.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Final Budget Amount' ;
    rdfs:comment 'Final approved budget amount including all amendments and no-cost extensions, in the program\'s functional currency.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalExpenditureAmount rdf:type rdf:Property ;
    rdfs:label 'Final Expenditure Amount' ;
    rdfs:comment 'Total actual expenditure amount for the program at closeout, in the program\'s functional currency.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalFinancialReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Final Financial Reconciliation Status' ;
    rdfs:comment 'Status of the final financial reconciliation process: pending, in progress, reconciled, discrepancies identified, resolved, or audited.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalReportApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Final Report Approval Date' ;
    rdfs:comment 'Date when the final program report was approved by the donor or governing body.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Final Report Submission Date' ;
    rdfs:comment 'Date when the final program report was submitted to the donor or governing body.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:knowledgeManagementOutputs rdf:type rdf:Property ;
    rdfs:label 'Knowledge Management Outputs' ;
    rdfs:comment 'List and description of knowledge management outputs produced during closeout, including case studies, best practice documents, training materials, and research publications.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonsLearnedSummary rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned Summary' ;
    rdfs:comment 'Comprehensive summary of key lessons learned during program implementation, including successes, challenges, and recommendations for future programs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingObligationsDescription rdf:type rdf:Property ;
    rdfs:label 'Outstanding Obligations Description' ;
    rdfs:comment 'Detailed description of any outstanding financial or contractual obligations that remain at closeout, including amounts and expected resolution dates.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingObligationsFlag rdf:type rdf:Property ;
    rdfs:label 'Outstanding Obligations Flag' ;
    rdfs:comment 'Indicates whether there are any outstanding financial or contractual obligations at closeout (True = outstanding obligations exist, False = all obligations settled).' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programEndDate rdf:type rdf:Property ;
    rdfs:label 'Program End Date' ;
    rdfs:comment 'Actual end date of program operations, which may differ from the original planned end date.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordRetentionEndDate rdf:type rdf:Property ;
    rdfs:label 'Record Retention End Date' ;
    rdfs:comment 'Date when the record retention period expires and program documentation may be disposed of, typically 3-7 years after closeout per donor and regulatory requirements.' ;
    rdfs:domain ind:ProgramCloseout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indicatorReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Indicator Reference Code' ;
    rdfs:comment 'Code or identifier linking this LogFrame row to the corresponding indicator in the Monitoring Evaluation and Learning (MEL) indicator library.' ;
    rdfs:domain ind:ProgramLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programLogframeStatus rdf:type rdf:Property ;
    rdfs:label 'Program Logframe Status' ;
    rdfs:comment 'Current lifecycle status of this LogFrame row indicating progress and health (draft during proposal, active during implementation, achieved/not_achieved at closeout). [ENUM-REF-CANDIDATE: draft|active|on_track|at_risk|delayed|achieved|not_achieved|archived — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProgramLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rowSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Row Sequence Number' ;
    rdfs:comment 'Ordinal position of this row within the LogFrame matrix for display and reporting purposes.' ;
    rdfs:domain ind:ProgramLogframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewEventId rdf:type rdf:Property ;
    rdfs:label 'Review Event Id' ;
    rdfs:comment 'Unique identifier for the program review, reporting, or learning event. Primary key.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Reporting System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Program reviews submitted through specific donor portals or M&E platforms (e.g., IATI Registry, donor-specific reporting systems). Critical for compliance, submission tracking, and access management. ' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:beneficiaryReachChildren rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Reach Children' ;
    rdfs:comment 'Number of children (under 18) reached during the reporting period.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiaryReachFemale rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Reach Female' ;
    rdfs:comment 'Number of female beneficiaries reached during the reporting period.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiaryReachMale rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Reach Male' ;
    rdfs:comment 'Number of male beneficiaries reached during the reporting period.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiaryReachTotal rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Reach Total' ;
    rdfs:comment 'Total number of beneficiaries reached during the reporting period, as reported in this review event.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:challengesNarrative rdf:type rdf:Property ;
    rdfs:label 'Challenges Narrative' ;
    rdfs:comment 'Narrative description of challenges, constraints, and obstacles encountered during the reporting period.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterSubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Cluster Submission Flag' ;
    rdfs:comment 'Indicates whether this report was submitted to a humanitarian cluster coordination mechanism (e.g., WASH cluster, Health cluster).' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executiveSummary rdf:type rdf:Property ;
    rdfs:label 'Executive Summary' ;
    rdfs:comment 'High-level summary of the review event or report, capturing key messages for senior management and donors.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialSummaryBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Summary Budget Amount' ;
    rdfs:comment 'Total budget allocated for the program or grant during the reporting period.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialSummaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Financial Summary Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the financial figures reported in this review event.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialSummaryExpenditureAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Summary Expenditure Amount' ;
    rdfs:comment 'Total expenditure incurred during the reporting period, as reported in this review event.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpActions rdf:type rdf:Property ;
    rdfs:label 'Follow Up Actions' ;
    rdfs:comment 'List or narrative of follow-up actions agreed upon in response to the review findings and recommendations.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyFindings rdf:type rdf:Property ;
    rdfs:label 'Key Findings' ;
    rdfs:comment 'Summary of the key findings from the review, assessment, or reporting period. Captures evidence-based observations.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuthorName rdf:type rdf:Property ;
    rdfs:label 'Lead Author Name' ;
    rdfs:comment 'Name of the primary author or team lead responsible for preparing the review or report.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:progressNarrative rdf:type rdf:Property ;
    rdfs:label 'Progress Narrative' ;
    rdfs:comment 'Detailed narrative describing progress against planned outputs, outcomes, and activities during the reporting period.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sphereStandardsAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Sphere Standards Applied Flag' ;
    rdfs:comment 'Indicates whether Sphere Humanitarian Charter and Minimum Standards were applied or assessed in this review event.' ;
    rdfs:domain ind:ReviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskRegisterId rdf:type rdf:Property ;
    rdfs:label 'Risk Register Id' ;
    rdfs:comment 'Unique identifier for the risk register entry. Primary key for the risk register product.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedSdg rdf:type rdf:Property ;
    rdfs:label 'Affected Sdg' ;
    rdfs:comment 'Reference to the Sustainable Development Goal(s) that may be impacted if this risk materializes. Supports alignment with global development frameworks and donor reporting.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSector rdf:type rdf:Property ;
    rdfs:label 'Affected Sector' ;
    rdfs:comment 'Program sector(s) that would be impacted by the risk (e.g., WASH, Health, Nutrition, Education, Protection, Livelihoods). Supports sector-specific risk analysis and reporting.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyPlan rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan' ;
    rdfs:comment 'Detailed response plan to be activated if the risk materializes. Includes trigger points, escalation procedures, alternative delivery mechanisms, and resource reallocation strategies.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicates whether the risk requires escalation to senior management or board level due to its severity or potential organizational impact. True if escalation is required; false otherwise.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactScore rdf:type rdf:Property ;
    rdfs:label 'Impact Score' ;
    rdfs:comment 'Numeric score representing the severity of impact if the risk occurs, typically on a scale of 1-5 where 1 is very low and 5 is very high. Used for quantitative risk prioritization.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentRiskScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Score' ;
    rdfs:comment 'Calculated risk score before mitigation measures are applied, typically the product of likelihood_score and impact_score. Represents the raw exposure level.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:likelihoodScore rdf:type rdf:Property ;
    rdfs:label 'Likelihood Score' ;
    rdfs:comment 'Numeric score representing the likelihood of risk occurrence, typically on a scale of 1-5 where 1 is very low and 5 is very high. Used for quantitative risk prioritization.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Calculated risk score after mitigation measures are applied. Represents the remaining exposure after controls are in place. Used to assess whether risk is within acceptable tolerance.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskCode rdf:type rdf:Property ;
    rdfs:label 'Risk Code' ;
    rdfs:comment 'Unique business identifier for the risk entry, typically following organizational risk coding standards (e.g., OPR-001, CTX-045). Used for cross-referencing in donor reports and internal risk management systems.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Risk Owner Email' ;
    rdfs:comment 'Email address of the risk owner for communication and escalation purposes.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPopulationId rdf:type rdf:Property ;
    rdfs:label 'Target Population Id' ;
    rdfs:comment 'Unique identifier for the target population definition. Primary key for this entity.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeMax rdf:type rdf:Property ;
    rdfs:label 'Age Range Max' ;
    rdfs:comment 'Maximum age in years for individuals in the target population. Null if no maximum age restriction applies.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeMin rdf:type rdf:Property ;
    rdfs:label 'Age Range Min' ;
    rdfs:comment 'Minimum age in years for individuals in the target population. Null if no minimum age restriction applies.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doNoHarmConsiderations rdf:type rdf:Property ;
    rdfs:label 'Do No Harm Considerations' ;
    rdfs:comment 'Documentation of potential risks and mitigation strategies to ensure the targeting approach does not inadvertently cause harm, stigma, or conflict within communities.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedPopulationSize rdf:type rdf:Property ;
    rdfs:label 'Estimated Population Size' ;
    rdfs:comment 'Estimated total number of individuals in the target population based on needs assessment, census data, or other planning sources.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Criteria that explicitly exclude individuals or households from the target population, ensuring appropriate targeting and avoiding duplication with other programs.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderIntegrationApproach rdf:type rdf:Property ;
    rdfs:label 'Gender Integration Approach' ;
    rdfs:comment 'Description of how gender considerations and gender-based vulnerabilities are integrated into the targeting and selection of this population.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostCommunityPopulationCount rdf:type rdf:Property ;
    rdfs:label 'Host Community Population Count' ;
    rdfs:comment 'Estimated number of host community members (non-displaced local population) within the target population. Null if not applicable.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:idpPopulationCount rdf:type rdf:Property ;
    rdfs:label 'Idp Population Count' ;
    rdfs:comment 'Estimated number of Internally Displaced Persons (IDPs) within the target population. Null if not applicable.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Inclusion Criteria' ;
    rdfs:comment 'Detailed criteria that define who is eligible to be included in the target population (e.g., \'Children aged 6-59 months with MUAC < 12.5 cm\', \'Households with female head and 3+ dependents\').' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedReach rdf:type rdf:Property ;
    rdfs:label 'Planned Reach' ;
    rdfs:comment 'Number of individuals the program plans to reach or serve from this target population, considering resource constraints and program scope.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:populationCode rdf:type rdf:Property ;
    rdfs:label 'Population Code' ;
    rdfs:comment 'Short alphanumeric code or identifier used in reporting and documentation to reference this target population (e.g., \'TP-001\', \'WASH-IDPs-2024\').' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationDescription rdf:type rdf:Property ;
    rdfs:label 'Population Description' ;
    rdfs:comment 'Detailed narrative description of the target population, including demographic characteristics, vulnerability profile, and rationale for targeting.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationName rdf:type rdf:Property ;
    rdfs:label 'Population Name' ;
    rdfs:comment 'Human-readable name or label for this target population segment (e.g., \'Malnourished Children Under 5 in Borno State\', \'IDP Women Heads of Household\').' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionMainstreamingFlag rdf:type rdf:Property ;
    rdfs:label 'Protection Mainstreaming Flag' ;
    rdfs:comment 'Indicates whether protection principles and safeguarding measures are integrated into the targeting and service delivery for this population.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refugeePopulationCount rdf:type rdf:Property ;
    rdfs:label 'Refugee Population Count' ;
    rdfs:comment 'Estimated number of refugees within the target population. Null if not applicable.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sexDisaggregation rdf:type rdf:Property ;
    rdfs:label 'Sex Disaggregation' ;
    rdfs:comment 'Sex or gender composition of the target population (e.g., \'female\' for women-only programs, \'all\' for mixed populations).' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPopulationStatus rdf:type rdf:Property ;
    rdfs:label 'Target Population Status' ;
    rdfs:comment 'Current lifecycle status of the target population definition within the program planning and execution workflow.' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingMethodology rdf:type rdf:Property ;
    rdfs:label 'Targeting Methodology' ;
    rdfs:comment 'Primary approach or method used to identify and select beneficiaries from the target population (e.g., MUAC screening for malnutrition, vulnerability scoring, community-based targeting). [ENUM-REF-CANDIDATE: community_based|vulnerability_scoring|muac_screening|household_economy_approach|geographic|categorical|self_targeting|mixed_methods — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TargetPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoryOfChangeId rdf:type rdf:Property ;
    rdfs:label 'Theory Of Change Id' ;
    rdfs:comment 'Unique identifier for the Theory of Change record. Primary key.' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityStatement rdf:type rdf:Property ;
    rdfs:label 'Activity Statement' ;
    rdfs:comment 'Summary of the key actions and interventions the program will undertake to produce outputs. Describes what the program does.' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorRequirements rdf:type rdf:Property ;
    rdfs:label 'Donor Requirements' ;
    rdfs:comment 'Specific donor-mandated requirements or frameworks that this Theory of Change must satisfy. May include reporting formats, result frameworks, or compliance standards.' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enablingConditions rdf:type rdf:Property ;
    rdfs:label 'Enabling Conditions' ;
    rdfs:comment 'External factors and preconditions necessary for the Theory of Change to succeed. Contextual elements that facilitate or hinder the intervention logic.' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humanitarianPrinciplesAlignment rdf:type rdf:Property ;
    rdfs:label 'Humanitarian Principles Alignment' ;
    rdfs:comment 'Description of how the Theory of Change adheres to core humanitarian principles: humanity, neutrality, impartiality, and independence.' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactStatement rdf:type rdf:Property ;
    rdfs:label 'Impact Statement' ;
    rdfs:comment 'High-level statement of the ultimate long-term change the program aims to achieve. Represents the apex of the results chain in the Theory of Change.' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputStatement rdf:type rdf:Property ;
    rdfs:label 'Input Statement' ;
    rdfs:comment 'Description of the resources (financial, human, material) required to implement activities. Foundation of the results chain.' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melFrameworkReference rdf:type rdf:Property ;
    rdfs:label 'Mel Framework Reference' ;
    rdfs:comment 'Reference to the MEL or MEAL framework that defines how the Theory of Change will be monitored, evaluated, and adapted based on learning.' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeStatement rdf:type rdf:Property ;
    rdfs:label 'Outcome Statement' ;
    rdfs:comment 'Description of the medium-term changes in behavior, relationships, actions, or conditions that the program seeks to influence. Intermediate results leading to impact.' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputStatement rdf:type rdf:Property ;
    rdfs:label 'Output Statement' ;
    rdfs:comment 'Description of the direct products, goods, and services delivered by program activities. Tangible deliverables under program control.' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderEngagementApproach rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Engagement Approach' ;
    rdfs:comment 'Description of how stakeholders (beneficiaries, partners, communities, government) were engaged in developing and validating the Theory of Change. Reflects participatory design principles.' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeframeEndDate rdf:type rdf:Property ;
    rdfs:label 'Timeframe End Date' ;
    rdfs:comment 'Planned end date for the intervention period covered by this Theory of Change. Marks the target completion of the results chain.' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeframeStartDate rdf:type rdf:Property ;
    rdfs:label 'Timeframe Start Date' ;
    rdfs:comment 'Planned start date for the intervention period covered by this Theory of Change. Marks the beginning of the results chain timeline.' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tocStatus rdf:type rdf:Property ;
    rdfs:label 'Toc Status' ;
    rdfs:comment 'Current lifecycle status of the Theory of Change document. Tracks progression from draft through approval to active use and eventual archival.' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tocTitle rdf:type rdf:Property ;
    rdfs:label 'Toc Title' ;
    rdfs:comment 'Descriptive title of the Theory of Change, summarizing the intervention logic and intended impact pathway.' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tocVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Toc Version Number' ;
    rdfs:comment 'Version identifier for this Theory of Change iteration. Supports tracking revisions across program cycles (e.g., 1.0, 1.1, 2.0).' ;
    rdfs:domain ind:TheoryOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allegedPerpetratorId rdf:type rdf:Property ;
    rdfs:label 'Alleged Perpetrator Id' ;
    rdfs:comment 'Unique identifier for the alleged perpetrator record. Primary key for the alleged perpetrator entity.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllegedPerpetrator .

ind:investigationId rdf:type rdf:Property ;
    rdfs:label 'Investigation Id' ;
    rdfs:comment 'Foreign key linking to safeguarding.investigation. Business justification: Alleged perpetrators must be linked to the formal investigation(s) conducted about them. Currently alleged_perpetrator has investigation_status, investigation_start_date, investigation_completion_date' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigation .

ind:primaryAllegedStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Alleged Staff Member Id' ;
    rdfs:comment 'Employee or volunteer identifier if the alleged perpetrator is or was a member of the workforce. Nullable for external perpetrators. Maintained separately from workforce records to enforce investigation integrity.' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accessRestrictionLevel rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Level' ;
    rdfs:comment 'Data classification level controlling who can access this alleged perpetrator record. Strictly access-controlled to enforce investigation integrity and protect due process.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allegationDate rdf:type rdf:Property ;
    rdfs:label 'Allegation Date' ;
    rdfs:comment 'Date when the allegation against this individual was formally recorded in the safeguarding system.' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allegationSeverity rdf:type rdf:Property ;
    rdfs:label 'Allegation Severity' ;
    rdfs:comment 'Severity classification of the allegation based on organizational risk assessment framework.' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allegationType rdf:type rdf:Property ;
    rdfs:label 'Allegation Type' ;
    rdfs:comment 'Primary category of the allegation against this individual. Aligns with organizational safeguarding policy categories. [ENUM-REF-CANDIDATE: sexual_exploitation|sexual_abuse|child_abuse|harassment|bullying|fraud|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNotes rdf:type rdf:Property ;
    rdfs:label 'Case Notes' ;
    rdfs:comment 'Confidential notes documenting key investigation milestones, decisions, and rationale. Strictly controlled access.' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseOutcome rdf:type rdf:Property ;
    rdfs:label 'Case Outcome' ;
    rdfs:comment 'Final organizational action taken against the alleged perpetrator following investigation conclusion. Cleared indicates no wrongdoing found. [ENUM-REF-CANDIDATE: dismissed|written_warning|final_warning|termination|criminal_referral|cleared|pending — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfficeAtIncident rdf:type rdf:Property ;
    rdfs:label 'Country Office At Incident' ;
    rdfs:comment 'Three-letter ISO country code of the country office where the alleged perpetrator was based at the time of the incident.' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criminalReferralAuthority rdf:type rdf:Property ;
    rdfs:label 'Criminal Referral Authority' ;
    rdfs:comment 'Name of the law enforcement agency or criminal justice authority to which the case was referred, if applicable.' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criminalReferralDate rdf:type rdf:Property ;
    rdfs:label 'Criminal Referral Date' ;
    rdfs:comment 'Date when the case was referred to law enforcement, if applicable. Nullable if no referral made.' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criminalReferralMade rdf:type rdf:Property ;
    rdfs:label 'Criminal Referral Made' ;
    rdfs:comment 'Indicates whether the case was referred to law enforcement or criminal justice authorities.' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disciplinaryActionDate rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Date' ;
    rdfs:comment 'Date when disciplinary action was formally applied, if applicable. Nullable if no action taken or case pending.' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employmentStatusAtIncident rdf:type rdf:Property ;
    rdfs:label 'Employment Status At Incident' ;
    rdfs:comment 'Employment or engagement status of the alleged perpetrator at the time the incident occurred. Critical for determining organizational liability and jurisdiction.' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimMeasuresApplied rdf:type rdf:Property ;
    rdfs:label 'Interim Measures Applied' ;
    rdfs:comment 'Administrative measures applied to the alleged perpetrator pending investigation outcome. Multiple measures may be concatenated.' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationOutcome rdf:type rdf:Property ;
    rdfs:label 'Investigation Outcome' ;
    rdfs:comment 'Final determination of the investigation. Substantiated means evidence supports the allegation; unsubstantiated means insufficient evidence; inconclusive means investigation could not reach a determination.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:misconductDatabaseReportDate rdf:type rdf:Property ;
    rdfs:label 'Misconduct Database Report Date' ;
    rdfs:comment 'Date when the case was reported to inter-agency misconduct databases, if applicable.' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:misconductDatabaseReported rdf:type rdf:Property ;
    rdfs:label 'Misconduct Database Reported' ;
    rdfs:comment 'Indicates whether the case was reported to inter-agency misconduct disclosure schemes or databases (e.g., UN ClearCheck, Misconduct Disclosure Scheme).' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perpetratorCode rdf:type rdf:Property ;
    rdfs:label 'Perpetrator Code' ;
    rdfs:comment 'Anonymized unique code assigned to the alleged perpetrator to protect identity during investigation. Format: AP-NNNNNN.' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehireEligibility rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligibility' ;
    rdfs:comment 'Determination of whether the individual is eligible for future employment or engagement with the organization or its partners.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipToOrganization rdf:type rdf:Property ;
    rdfs:label 'Relationship To Organization' ;
    rdfs:comment 'The alleged perpetrator\'s relationship to the organization at the time of the incident. Determines investigation jurisdiction and accountability mechanisms.' ;
    rdfs:domain ind:AllegedPerpetrator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'Date when suspension or administrative leave ended, if applicable. Nullable if suspension is ongoing or not applied.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'Date when suspension or administrative leave commenced, if applicable. Nullable if no suspension applied.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditLastModifiedByUserUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Audit Last Modified By User User Account Id' ;
    rdfs:comment 'Identifier of the system user who most recently modified this safeguarding audit record. Supports accountability and audit trail requirements.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:auditUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Audit User Account Id' ;
    rdfs:comment 'Identifier of the system user who created this safeguarding audit record. Supports accountability and audit trail requirements.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:auditedSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Audited System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Safeguarding audits frequently assess technology systems that handle sensitive data (case management platforms, incident reporting tools, survivor databases). Auditors need to link audit scope to spec' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:auditCategory rdf:type rdf:Property ;
    rdfs:label 'Audit Category' ;
    rdfs:comment 'Thematic focus area of the safeguarding audit. Indicates whether the audit covers Protection from Sexual Exploitation and Abuse (PSEA), child safeguarding, staff conduct, organizational policy compliance, incident management processes, survivor support mechanisms, or a comprehensive review across all safeguarding domains. [ENUM-REF-CANDIDATE: psea|child_safeguarding|staff_conduct|organizational_policy|incident_management|survivor_support|comprehensive — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the boundaries, focus areas, organizational units, programs, and geographic locations covered by this safeguarding audit. Defines what is included and excluded from the audit review.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the safeguarding audit by its commissioning authority and purpose. Distinguishes between internal self-assessments, donor-commissioned reviews, inter-agency peer reviews, CHS safeguarding commitment audits, external independent audits, and regulatory compliance audits.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningOrganization rdf:type rdf:Property ;
    rdfs:label 'Commissioning Organization' ;
    rdfs:comment 'Name of the organization or entity that commissioned or requested this safeguarding audit. May be internal (e.g., Board of Directors, Executive Leadership) or external (e.g., donor agency, regulatory body, inter-agency network).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Quantitative compliance score or percentage representing the organization\'s adherence to safeguarding standards and requirements assessed in this audit. Scale and methodology defined by the audit framework.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Required Flag' ;
    rdfs:comment 'Indicates whether a formal corrective action plan is required in response to this safeguarding audit findings. True if management must develop and implement a structured action plan.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentsReviewedCount rdf:type rdf:Property ;
    rdfs:label 'Documents Reviewed Count' ;
    rdfs:comment 'Total number of policies, procedures, incident reports, training records, and other documents reviewed during this safeguarding audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalReportingDate rdf:type rdf:Property ;
    rdfs:label 'External Reporting Date' ;
    rdfs:comment 'Date when the safeguarding audit results were reported to external stakeholders such as donors, regulatory authorities, or inter-agency coordination bodies.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'External Reporting Required Flag' ;
    rdfs:comment 'Indicates whether the results of this safeguarding audit must be reported to external stakeholders such as donors, regulatory bodies, or inter-agency networks. True if external reporting is mandatory.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required Flag' ;
    rdfs:comment 'Indicates whether a follow-up audit is required to verify implementation of corrective actions and recommendations from this safeguarding audit. True if follow-up review is mandated.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpAuditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Scheduled Date' ;
    rdfs:comment 'Planned date for the follow-up audit to verify implementation of corrective actions and recommendations from this safeguarding audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodPracticesIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Good Practices Identified Count' ;
    rdfs:comment 'Number of good practices, strengths, or exemplary safeguarding approaches identified during this audit that can be shared and replicated across the organization.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewsConductedCount rdf:type rdf:Property ;
    rdfs:label 'Interviews Conducted Count' ;
    rdfs:comment 'Total number of interviews conducted with staff, beneficiaries, partners, and other stakeholders as part of this safeguarding audit fieldwork.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor responsible for this safeguarding audit. Captured for reporting and accountability purposes.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementResponseReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Management Response Received Flag' ;
    rdfs:comment 'Indicates whether management has provided a formal response to the audit findings and recommendations. True if management response has been received and documented.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallSafeguardingMaturityRating rdf:type rdf:Property ;
    rdfs:label 'Overall Safeguarding Maturity Rating' ;
    rdfs:comment 'Overall assessment of the organization\'s safeguarding maturity level based on this audit. Uses a capability maturity model scale from initial (Level 1) to optimized (Level 5), reflecting the sophistication and effectiveness of safeguarding systems, policies, and culture.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationsCount rdf:type rdf:Property ;
    rdfs:label 'Recommendations Count' ;
    rdfs:comment 'Total number of recommendations for improvement issued as part of this safeguarding audit. Includes all severity levels and action items proposed to strengthen safeguarding systems.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteVisitsConductedCount rdf:type rdf:Property ;
    rdfs:label 'Site Visits Conducted Count' ;
    rdfs:comment 'Total number of field offices, program sites, or operational locations physically visited by the audit team during this safeguarding audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list or narrative description of all team members, consultants, and subject matter experts who participated in conducting this safeguarding audit.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRecommendationId rdf:type rdf:Property ;
    rdfs:label 'Audit Recommendation Id' ;
    rdfs:comment 'Unique identifier for the audit recommendation record. Primary key for the audit recommendation entity.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAuditStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Audit Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who is accountable for implementing this recommendation and ensuring completion by the target date.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:quaternaryAuditLastModifiedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Audit Last Modified By Staff Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who last updated this recommendation record.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:quinaryAuditResponsibleOwnerStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Quinary Audit Responsible Owner Staff Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:relatedPolicyPseaPolicyId rdf:type rdf:Property ;
    rdfs:label 'Related Policy Psea Policy Id' ;
    rdfs:comment 'Reference to the Protection from Sexual Exploitation and Abuse (PSEA) policy or safeguarding policy that this recommendation relates to or requires updating.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PseaPolicy .

ind:tertiaryAuditCreatedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Audit Created By Staff Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who created this recommendation record, typically the lead auditor or investigator.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:budgetAllocatedFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Flag' ;
    rdfs:comment 'Indicates whether budget has been allocated to implement this recommendation. Critical for tracking resource constraints that may delay implementation.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deferralReason rdf:type rdf:Property ;
    rdfs:label 'Deferral Reason' ;
    rdfs:comment 'Justification provided when a recommendation is deferred, including resource constraints, competing priorities, or external dependencies that prevent immediate implementation.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredUntilDate rdf:type rdf:Property ;
    rdfs:label 'Deferred Until Date' ;
    rdfs:comment 'New target date when a deferred recommendation is expected to be addressed.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorReportedDate rdf:type rdf:Property ;
    rdfs:label 'Donor Reported Date' ;
    rdfs:comment 'Date when the recommendation and its status were reported to donors or oversight bodies.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this recommendation and its implementation status must be reported to donors or oversight bodies as part of safeguarding accountability requirements.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Url' ;
    rdfs:comment 'Link to the document management system location where supporting evidence of recommendation completion is stored.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceOfCompletion rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Completion' ;
    rdfs:comment 'Description of the evidence provided to verify that the recommendation has been fully implemented (e.g., updated policy document, training records, system screenshots, process documentation).' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Required Flag' ;
    rdfs:comment 'Indicates whether additional follow-up actions or monitoring are required after initial implementation to ensure sustained compliance.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementationCostUsd rdf:type rdf:Property ;
    rdfs:label 'Implementation Cost Usd' ;
    rdfs:comment 'Estimated or actual cost in United States Dollars to implement the recommendation, including staff time, training, system changes, or policy development costs.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managementAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Management Acceptance Status' ;
    rdfs:comment 'Indicates whether management has accepted the recommendation. Accepted indicates full agreement and commitment to implement; partially accepted indicates agreement with modifications; not accepted indicates disagreement with recommendation; under review indicates management is still evaluating.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationCategory rdf:type rdf:Property ;
    rdfs:label 'Recommendation Category' ;
    rdfs:comment 'Safeguarding domain category that this recommendation addresses: Protection from Sexual Exploitation and Abuse (PSEA), child safeguarding, staff conduct, survivor support, reporting mechanism, or investigation process.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationNumber rdf:type rdf:Property ;
    rdfs:label 'Recommendation Number' ;
    rdfs:comment 'Business identifier for the recommendation, typically formatted as audit number plus sequential recommendation number (e.g., AUD-2024-001-R01).' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationText rdf:type rdf:Property ;
    rdfs:label 'Recommendation Text' ;
    rdfs:comment 'Full detailed text of the recommendation describing the required action, improvement, or corrective measure to address the identified safeguarding gap or risk.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationTitle rdf:type rdf:Property ;
    rdfs:label 'Recommendation Title' ;
    rdfs:comment 'Short descriptive title summarizing the recommendation action or improvement area.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationType rdf:type rdf:Property ;
    rdfs:label 'Recommendation Type' ;
    rdfs:comment 'Classification of the recommendation by the nature of the improvement required: policy change, process enhancement, training requirement, system upgrade, structural change, behavioral change, or compliance action. [ENUM-REF-CANDIDATE: policy|process|training|system|structural|behavioral|compliance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Verification Outcome' ;
    rdfs:comment 'Result of the independent verification process. Verified indicates full implementation confirmed; partially verified indicates incomplete implementation; not verified indicates implementation not confirmed; pending verification indicates verification scheduled but not yet completed.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Verification Required Flag' ;
    rdfs:comment 'Indicates whether independent verification or audit follow-up is required to confirm recommendation implementation. True for critical and high priority recommendations.' ;
    rdfs:domain ind:AuditRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryCommunityStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Community Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who facilitated or led the community awareness session.' ;
    rdfs:domain ind:CommunityAwarenessSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:quaternaryCommunityLastModifiedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Community Last Modified By Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who last updated or modified this community awareness session record.' ;
    rdfs:domain ind:CommunityAwarenessSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:tertiaryCommunityCreatedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Community Created By Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who created this community awareness session record in the system.' ;
    rdfs:domain ind:CommunityAwarenessSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:attendanceSheetDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Attendance Sheet Document Url' ;
    rdfs:comment 'URL or file path to the attendance sheet or participant registration document for audit and verification purposes.' ;
    rdfs:domain ind:CommunityAwarenessSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Actions Required' ;
    rdfs:comment 'Description of any follow-up actions, additional sessions, or support activities identified as necessary based on session outcomes and participant feedback.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyMessagesDelivered rdf:type rdf:Property ;
    rdfs:label 'Key Messages Delivered' ;
    rdfs:comment 'Summary of the key safeguarding messages, topics, and information delivered during the community awareness session.' ;
    rdfs:domain ind:CommunityAwarenessSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Location Country Code' ;
    rdfs:comment 'Three-letter ISO country code indicating the country where the community awareness session was conducted.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationDistrict rdf:type rdf:Property ;
    rdfs:label 'Location District' ;
    rdfs:comment 'District or sub-regional administrative area where the session was conducted.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationRegion rdf:type rdf:Property ;
    rdfs:label 'Location Region' ;
    rdfs:comment 'Administrative region or province where the community awareness session took place.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationSiteName rdf:type rdf:Property ;
    rdfs:label 'Location Site Name' ;
    rdfs:comment 'Name of the specific site, community center, camp, or settlement where the awareness session was held.' ;
    rdfs:domain ind:CommunityAwarenessSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsDistributed rdf:type rdf:Property ;
    rdfs:label 'Materials Distributed' ;
    rdfs:comment 'Description of information, education, and communication (IEC) materials distributed to participants during the session, such as brochures, posters, or handouts.' ;
    rdfs:domain ind:CommunityAwarenessSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Participant Satisfaction Rating' ;
    rdfs:comment 'Overall satisfaction rating provided by participants regarding the quality and relevance of the awareness session.' ;
    rdfs:domain ind:CommunityAwarenessSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantsAdults18To59 rdf:type rdf:Property ;
    rdfs:label 'Participants Adults 18 To 59' ;
    rdfs:comment 'Number of adult participants aged 18 to 59 years who attended the session.' ;
    rdfs:domain ind:CommunityAwarenessSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantsChildrenUnder18 rdf:type rdf:Property ;
    rdfs:label 'Participants Children Under 18' ;
    rdfs:comment 'Number of child participants under 18 years of age who attended the session, supporting age-disaggregated reporting.' ;
    rdfs:domain ind:CommunityAwarenessSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantsElderly60Plus rdf:type rdf:Property ;
    rdfs:label 'Participants Elderly 60 Plus' ;
    rdfs:comment 'Number of elderly participants aged 60 years and above who attended the session.' ;
    rdfs:domain ind:CommunityAwarenessSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantsWithDisabilities rdf:type rdf:Property ;
    rdfs:label 'Participants With Disabilities' ;
    rdfs:comment 'Number of participants with disabilities who attended the session, supporting inclusion monitoring.' ;
    rdfs:domain ind:CommunityAwarenessSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referralMadeFlag rdf:type rdf:Property ;
    rdfs:label 'Referral Made Flag' ;
    rdfs:comment 'Indicates whether any participant was referred to support services, case management, or other assistance as a result of the session.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sessionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Session Reference Number' ;
    rdfs:comment 'Externally-known unique reference number or code assigned to this community awareness session for tracking and reporting purposes.' ;
    rdfs:domain ind:CommunityAwarenessSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionReportDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Session Report Document Url' ;
    rdfs:comment 'URL or file path to the detailed session report documenting activities, outcomes, and participant engagement.' ;
    rdfs:domain ind:CommunityAwarenessSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionType rdf:type rdf:Property ;
    rdfs:label 'Session Type' ;
    rdfs:comment 'Type or category of safeguarding awareness session conducted with the community. Indicates the primary focus area of the sensitization activity.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Translation Provided Flag' ;
    rdfs:comment 'Indicates whether translation or interpretation services were provided during the session to accommodate multilingual participants.' ;
    rdfs:domain ind:CommunityAwarenessSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disciplinaryOutcomeId rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Outcome Id' ;
    rdfs:comment 'Unique identifier for the disciplinary outcome record. Primary key for this entity.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDisciplinaryUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Disciplinary User Account Id' ;
    rdfs:comment 'Identifier of the system user who created this disciplinary outcome record.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:separationEventId rdf:type rdf:Property ;
    rdfs:label 'Separation Event Id' ;
    rdfs:comment 'Foreign key linking to workforce.separation_event. Business justification: Disciplinary terminations must link to separation_event for final settlement calculation, rehire eligibility enforcement, reference check flagging, and mandatory donor/regulatory reporting (IRS Form 9' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeparationEvent .

ind:aggravatingFactors rdf:type rdf:Property ;
    rdfs:label 'Aggravating Factors' ;
    rdfs:comment 'Description of any aggravating circumstances or factors that influenced the disciplinary outcome decision toward greater severity.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Decision Date' ;
    rdfs:comment 'The date on which the appeal decision was finalized and communicated, if applicable.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFiledDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Date' ;
    rdfs:comment 'The date on which the appeal was formally filed by the subject employee, if applicable.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether the subject employee filed a formal appeal against this disciplinary outcome.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'The result of the appeal process, if an appeal was filed. Includes upheld, denied, partially upheld, withdrawn, pending, or not applicable.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criminalChargesFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Criminal Charges Filed Flag' ;
    rdfs:comment 'Indicates whether criminal charges were filed against the subject as a result of this case.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionAuthority rdf:type rdf:Property ;
    rdfs:label 'Decision Authority' ;
    rdfs:comment 'The role or title of the individual or committee who authorized and issued this disciplinary outcome (e.g., Country Director, HR Director, Disciplinary Panel).' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementAgency rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Agency' ;
    rdfs:comment 'The name of the law enforcement or criminal justice agency to which the case was referred, if applicable.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementReferralDate rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Referral Date' ;
    rdfs:comment 'The date on which the case was formally referred to law enforcement authorities, if applicable.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lawEnforcementReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Referral Flag' ;
    rdfs:comment 'Indicates whether the case was referred to law enforcement or criminal justice authorities.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mdsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Mds Reference Number' ;
    rdfs:comment 'The unique reference number assigned by the Inter-Agency Misconduct Disclosure Scheme (MDS) for this reported case.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdsReportDate rdf:type rdf:Property ;
    rdfs:label 'Mds Report Date' ;
    rdfs:comment 'The date on which the case was reported to the Inter-Agency Misconduct Disclosure Scheme (MDS), if applicable.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mdsReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Mds Reported Flag' ;
    rdfs:comment 'Indicates whether this case was reported to the Inter-Agency Misconduct Disclosure Scheme (MDS) or equivalent external reporting mechanism.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mitigatingFactors rdf:type rdf:Property ;
    rdfs:label 'Mitigating Factors' ;
    rdfs:comment 'Description of any mitigating circumstances or factors that influenced the disciplinary outcome decision in favor of leniency.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeDate rdf:type rdf:Property ;
    rdfs:label 'Outcome Date' ;
    rdfs:comment 'The date on which the disciplinary outcome decision was formally issued and communicated to the subject.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcomeDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Outcome Document Url' ;
    rdfs:comment 'Secure URL or file path to the formal disciplinary outcome decision document.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeRationale rdf:type rdf:Property ;
    rdfs:label 'Outcome Rationale' ;
    rdfs:comment 'Detailed explanation of the reasoning and justification for the disciplinary outcome decision, including mitigating and aggravating factors considered.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Outcome Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for this disciplinary outcome, used for tracking and reporting purposes.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeStatus rdf:type rdf:Property ;
    rdfs:label 'Outcome Status' ;
    rdfs:comment 'Current status of the disciplinary outcome in its lifecycle, including pending, finalized, under appeal, appeal upheld, appeal denied, or overturned.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeType rdf:type rdf:Property ;
    rdfs:label 'Outcome Type' ;
    rdfs:comment 'The type of disciplinary or administrative action applied following the substantiated investigation. Includes written warning, final warning, demotion, suspension, termination, criminal referral, or no action. [ENUM-REF-CANDIDATE: written_warning|final_warning|demotion|suspension|termination|criminal_referral|no_action — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyViolations rdf:type rdf:Property ;
    rdfs:label 'Policy Violations' ;
    rdfs:comment 'Comma-separated list or description of the specific organizational policies that were violated, leading to this disciplinary outcome.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceCheckFlag rdf:type rdf:Property ;
    rdfs:label 'Reference Check Flag' ;
    rdfs:comment 'Indicates whether this outcome will be disclosed in future employment reference checks for the subject.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rehabilitationPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Plan Required Flag' ;
    rdfs:comment 'Indicates whether a formal rehabilitation or performance improvement plan is required as part of the disciplinary outcome.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restitutionAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Restitution Amount Usd' ;
    rdfs:comment 'The monetary amount of restitution required from the subject, expressed in United States Dollars (USD).' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restitutionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Restitution Required Flag' ;
    rdfs:comment 'Indicates whether the subject is required to provide financial or other restitution as part of the disciplinary outcome.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCompletionDeadline rdf:type rdf:Property ;
    rdfs:label 'Training Completion Deadline' ;
    rdfs:comment 'The deadline by which required training must be completed, if applicable.' ;
    rdfs:domain ind:DisciplinaryOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether mandatory training (e.g., safeguarding, code of conduct, ethics) is required as part of the disciplinary outcome.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedPolicyPseaPolicyId rdf:type rdf:Property ;
    rdfs:label 'Linked Policy Psea Policy Id' ;
    rdfs:comment 'Identifier of the internal safeguarding policy that addresses or fulfills this donor requirement. Links to the PSEA policy or other safeguarding policy master.' ;
    rdfs:domain ind:DonorSafeguardingRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PseaPolicy .

ind:tertiaryDonorLastModifiedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Donor Last Modified By Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who last modified this donor safeguarding requirement record.' ;
    rdfs:domain ind:DonorSafeguardingRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:applicableCountryCodes rdf:type rdf:Property ;
    rdfs:label 'Applicable Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this safeguarding requirement applies. May be null if requirement applies globally across all operations.' ;
    rdfs:domain ind:DonorSafeguardingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProgramIds rdf:type rdf:Property ;
    rdfs:label 'Applicable Program Ids' ;
    rdfs:comment 'Comma-separated list of program identifiers to which this safeguarding requirement applies. May be null if requirement applies organization-wide.' ;
    rdfs:domain ind:DonorSafeguardingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReportingTimeframeHours rdf:type rdf:Property ;
    rdfs:label 'Incident Reporting Timeframe Hours' ;
    rdfs:comment 'For incident reporting requirements, the maximum number of hours within which safeguarding incidents must be reported to the donor. Common values include 24, 48, or 72 hours.' ;
    rdfs:domain ind:DonorSafeguardingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether this safeguarding requirement is mandatory for grant award or continuation. True if non-compliance would result in grant suspension or termination.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requirementStatus rdf:type rdf:Property ;
    rdfs:label 'Requirement Status' ;
    rdfs:comment 'Current compliance status of the safeguarding requirement. Tracks progression from pending through submission to approval or identifies overdue or waived requirements. [ENUM-REF-CANDIDATE: pending|in_progress|submitted|approved|rejected|overdue|waived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementType rdf:type rdf:Property ;
    rdfs:label 'Requirement Type' ;
    rdfs:comment 'Category of safeguarding compliance requirement imposed by the donor. Examples include PSEA policy submission, training completion evidence, incident reporting within specified timeframe, annual safeguarding report, background check verification, or safeguarding audit.' ;
    rdfs:domain ind:DonorSafeguardingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionFormat rdf:type rdf:Property ;
    rdfs:label 'Submission Format' ;
    rdfs:comment 'Required format or method for submitting the safeguarding requirement evidence to the donor. [ENUM-REF-CANDIDATE: pdf_document|online_portal|email|certified_letter|audit_report|training_certificate|policy_document — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DonorSafeguardingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiry Date' ;
    rdfs:comment 'Date when the granted waiver expires and the safeguarding requirement becomes mandatory again.' ;
    rdfs:domain ind:DonorSafeguardingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:focalPointId rdf:type rdf:Property ;
    rdfs:label 'Focal Point Id' ;
    rdfs:comment 'Unique identifier for the safeguarding focal point assignment record.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldOfficeId rdf:type rdf:Property ;
    rdfs:label 'Field Office Id' ;
    rdfs:comment 'Reference to the field office for field-level focal points.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CountryOffice .

ind:primaryBackupFocalPointStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Backup Focal Point Staff Staff Member Id' ;
    rdfs:comment 'Reference to the staff member designated as backup or alternate focal point for continuity of safeguarding coverage.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:quaternaryFocalCreatedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Focal Created By Staff Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who created this focal point assignment record.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:quinaryFocalLastModifiedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Quinary Focal Last Modified By Staff Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who last modified this focal point assignment record.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:successorFocalPointId rdf:type rdf:Property ;
    rdfs:label 'Successor Focal Point Id' ;
    rdfs:comment 'Reference to the focal point record that succeeded this assignment.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FocalPoint .

ind:tertiaryFocalReportingLineStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Focal Reporting Line Staff Staff Member Id' ;
    rdfs:comment 'Reference to the staff member to whom the focal point reports for safeguarding matters.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:appointmentDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Date' ;
    rdfs:comment 'Date when the staff member was officially appointed to the focal point role.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availabilityHours rdf:type rdf:Property ;
    rdfs:label 'Availability Hours' ;
    rdfs:comment 'Description of the focal point\'s availability hours for safeguarding support (e.g., 24/7, business hours, on-call).' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the focal point\'s safeguarding training certification expires and renewal is required.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidentialHotline rdf:type rdf:Property ;
    rdfs:label 'Confidential Hotline' ;
    rdfs:comment 'Dedicated confidential hotline number for reporting safeguarding incidents to the focal point.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationType rdf:type rdf:Property ;
    rdfs:label 'Designation Type' ;
    rdfs:comment 'Type of safeguarding focal point designation. PSEA = Protection from Sexual Exploitation and Abuse, GBV = Gender-Based Violence.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReportingAuthority rdf:type rdf:Property ;
    rdfs:label 'External Reporting Authority' ;
    rdfs:comment 'Flag indicating whether the focal point has authority to report incidents to external authorities or donors.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:focalPointCode rdf:type rdf:Property ;
    rdfs:label 'Focal Point Code' ;
    rdfs:comment 'Business identifier for the focal point assignment, typically formatted as FP-[COUNTRY]-[NUMBER].' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:focalPointStatus rdf:type rdf:Property ;
    rdfs:label 'Focal Point Status' ;
    rdfs:comment 'Current status of the focal point assignment in its lifecycle.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Handover Completed Flag' ;
    rdfs:comment 'Flag indicating whether a formal handover to a successor focal point has been completed.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handoverDate rdf:type rdf:Property ;
    rdfs:label 'Handover Date' ;
    rdfs:comment 'Date when the formal handover to a successor focal point was completed.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentResponseAuthority rdf:type rdf:Property ;
    rdfs:label 'Incident Response Authority' ;
    rdfs:comment 'Flag indicating whether the focal point has authority to initiate incident response actions without escalation.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentsHandledCount rdf:type rdf:Property ;
    rdfs:label 'Incidents Handled Count' ;
    rdfs:comment 'Total number of safeguarding incidents handled by this focal point during their term.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigationAuthority rdf:type rdf:Property ;
    rdfs:label 'Investigation Authority' ;
    rdfs:comment 'Flag indicating whether the focal point has authority to lead or participate in safeguarding investigations.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageProficiency rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency' ;
    rdfs:comment 'Languages in which the focal point can provide safeguarding support, comma-separated.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastIncidentDate rdf:type rdf:Property ;
    rdfs:label 'Last Incident Date' ;
    rdfs:comment 'Date of the most recent safeguarding incident handled by this focal point.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryResponsibilityDescription rdf:type rdf:Property ;
    rdfs:label 'Primary Responsibility Description' ;
    rdfs:comment 'Detailed description of the focal point\'s primary safeguarding responsibilities and accountabilities.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Code identifying the geographic region of responsibility for regional focal points.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeType rdf:type rdf:Property ;
    rdfs:label 'Scope Type' ;
    rdfs:comment 'Type of organizational or geographic scope for which the focal point has responsibility.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termEndDate rdf:type rdf:Property ;
    rdfs:label 'Term End Date' ;
    rdfs:comment 'Date when the focal point term of service ends. Nullable for open-ended assignments.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termStartDate rdf:type rdf:Property ;
    rdfs:label 'Term Start Date' ;
    rdfs:comment 'Date when the focal point term of service begins.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Training Certification Status' ;
    rdfs:comment 'Current status of required safeguarding training certification for the focal point.' ;
    rdfs:domain ind:FocalPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'Name of the organization or institution that provided the safeguarding training certification.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationLastModifiedByUserUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Investigation Last Modified By User User Account Id' ;
    rdfs:comment 'Reference to the user who last modified the investigation record.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:investigationUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Investigation User Account Id' ;
    rdfs:comment 'Reference to the user who created the investigation record in the system.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:costUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Usd' ;
    rdfs:comment 'Total cost of conducting the investigation in USD, including investigator fees, travel, translation, legal counsel, and administrative expenses. Confidential business information.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disciplinaryActionTaken rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Taken' ;
    rdfs:comment 'Description of disciplinary actions taken against subjects of the investigation, including warnings, suspension, termination, or referral to law enforcement. Confidential business information.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceItemsCollectedCount rdf:type rdf:Property ;
    rdfs:label 'Evidence Items Collected Count' ;
    rdfs:comment 'Total number of evidence items collected and catalogued during the investigation, including documents, photographs, recordings, and physical evidence.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalDetermination rdf:type rdf:Property ;
    rdfs:label 'Final Determination' ;
    rdfs:comment 'Final determination of the investigation: substantiated (allegations proven), unsubstantiated (allegations not proven), inconclusive (insufficient evidence), or partially substantiated (some allegations proven).' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCategory rdf:type rdf:Property ;
    rdfs:label 'Investigation Category' ;
    rdfs:comment 'Primary safeguarding category under investigation: Protection from Sexual Exploitation and Abuse (PSEA), child safeguarding, staff misconduct, Gender-Based Violence (GBV), fraud, or harassment.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationScope rdf:type rdf:Property ;
    rdfs:label 'Investigation Scope' ;
    rdfs:comment 'Detailed description of the boundaries and focus areas of the investigation, including specific allegations, time periods, locations, and individuals involved.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationType rdf:type rdf:Property ;
    rdfs:label 'Investigation Type' ;
    rdfs:comment 'Classification of the investigation approach: internal (conducted by organizational staff), external (third-party investigator), joint with UN/OCHA, joint with partner organization, or independent external review.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyViolationsIdentified rdf:type rdf:Property ;
    rdfs:label 'Policy Violations Identified' ;
    rdfs:comment 'Comma-separated list of specific organizational policies, codes of conduct, or standards that were found to have been violated during the investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedActions rdf:type rdf:Property ;
    rdfs:label 'Recommended Actions' ;
    rdfs:comment 'Detailed recommendations for corrective actions, disciplinary measures, policy changes, or systemic improvements based on investigation findings. Confidential business information.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:survivorSupportProvided rdf:type rdf:Property ;
    rdfs:label 'Survivor Support Provided' ;
    rdfs:comment 'Description of support services provided to survivors or complainants, including Psychosocial Support (PSS), medical care, legal assistance, and safe accommodation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsOfReference rdf:type rdf:Property ;
    rdfs:label 'Terms Of Reference' ;
    rdfs:comment 'Formal Terms of Reference (ToR) document outlining the investigation mandate, objectives, methodology, timeline, reporting requirements, and confidentiality protocols.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationActionId rdf:type rdf:Property ;
    rdfs:label 'Investigation Action Id' ;
    rdfs:comment 'Unique identifier for each investigation action record. Primary key for the investigation action entity.' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryInvestigationStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Investigation Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or investigator responsible for executing this investigation action. Links to workforce or investigator master data.' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:primaryInvestigationUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Investigation User Account Id' ;
    rdfs:comment 'Identifier of the system user who created this investigation action record. Supports accountability and audit trail.' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:survivorRecordId rdf:type rdf:Property ;
    rdfs:label 'Survivor Record Id' ;
    rdfs:comment 'Foreign key linking to safeguarding.survivor_record. Business justification: Investigation actions frequently involve survivors (witness interviews, support coordination, consent collection). Currently investigation_action has witness_statement_flag and survivor_support_provid' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurvivorRecord .

ind:actionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Action Cost Amount' ;
    rdfs:comment 'Direct cost incurred for this investigation action (e.g., travel expenses, expert consultation fees, translation services). Supports budget tracking and financial accountability.' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actionCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Action Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the action cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed narrative description of the investigation action taken. Captures the specifics of what was done, who was involved, and any relevant context.' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action End Timestamp' ;
    rdfs:comment 'Precise date and time when the investigation action was completed. Used for duration calculation and workflow tracking.' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actionLocation rdf:type rdf:Property ;
    rdfs:label 'Action Location' ;
    rdfs:comment 'Physical or virtual location where the investigation action took place (e.g., field office, remote interview, headquarters, community site).' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Human-readable business identifier for the investigation action, typically formatted as a sequential or hierarchical code within the investigation (e.g., INV-2024-001-A01).' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Start Timestamp' ;
    rdfs:comment 'Precise date and time when the investigation action commenced. Used for detailed audit trail and duration tracking.' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:evidenceCollectedFlag rdf:type rdf:Property ;
    rdfs:label 'Evidence Collected Flag' ;
    rdfs:comment 'Indicates whether physical or documentary evidence was collected during this investigation action. True if evidence was gathered, false otherwise.' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference Number' ;
    rdfs:comment 'Reference identifier for evidence collected during this action. Links to evidence management system or document repository.' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuthorityNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'External Authority Notified Flag' ;
    rdfs:comment 'Indicates whether external authorities (e.g., law enforcement, regulatory bodies, United Nations Office for the Coordination of Humanitarian Affairs (OCHA)) were notified as part of this action.' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interimMeasureApplied rdf:type rdf:Property ;
    rdfs:label 'Interim Measure Applied' ;
    rdfs:comment 'Description of any interim protective or administrative measures applied during this action (e.g., suspension, reassignment, access restriction, no-contact order).' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Name of the individual or team responsible for the investigation action. Provides human-readable identification of the action owner.' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:survivorSupportProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Survivor Support Provided Flag' ;
    rdfs:comment 'Indicates whether survivor-centered support services were provided during or as a result of this investigation action (e.g., Psychosocial Support (PSS), medical care, legal assistance).' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:witnessStatementFlag rdf:type rdf:Property ;
    rdfs:label 'Witness Statement Flag' ;
    rdfs:comment 'Indicates whether a formal witness statement was taken during this investigation action. True if statement was recorded, false otherwise.' ;
    rdfs:domain ind:InvestigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:misconductDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Misconduct Disclosure Id' ;
    rdfs:comment 'Unique identifier for the misconduct disclosure record. Primary key for the misconduct disclosure entity.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMisconductUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Misconduct User Account Id' ;
    rdfs:comment 'Foreign key reference to the user who created this disclosure record. Used for accountability and audit trail.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:recruitmentRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Recruitment Requisition Id' ;
    rdfs:comment 'Foreign key reference to the recruitment or vetting process that triggered this misconduct disclosure request. Links disclosure to the hiring or partner vetting workflow.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecruitmentRequisition .

ind:subjectPositionId rdf:type rdf:Property ;
    rdfs:label 'Subject Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Misconduct disclosure requests must identify position held by subject for role-specific risk assessment (child contact roles, beneficiary-facing positions, supervisory authority). Required for inter-a' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:actionTakenByRequestingOrg rdf:type rdf:Property ;
    rdfs:label 'Action Taken By Requesting Org' ;
    rdfs:comment 'Action taken by the requesting organization based on the disclosure response: candidate rejected (not hired/engaged), candidate accepted with conditions (hired with additional safeguarding measures), additional vetting required, no action (disclosure did not impact decision), or pending review.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryFacingRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Facing Role Flag' ;
    rdfs:comment 'Boolean indicator of whether the position involves direct contact with beneficiaries, particularly vulnerable populations. True if beneficiary-facing, False if back-office or non-beneficiary-facing role. Critical for safeguarding risk assessment.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:childContactRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Child Contact Role Flag' ;
    rdfs:comment 'Boolean indicator of whether the position involves direct contact with children (individuals under 18 years of age). True if child-contact role, False otherwise. Triggers enhanced child safeguarding vetting requirements.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataRetentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Expiry Date' ;
    rdfs:comment 'Date when this disclosure record is scheduled for archival or deletion per organizational data retention policies and legal requirements. Ensures compliance with data protection regulations.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disclosureChannel rdf:type rdf:Property ;
    rdfs:label 'Disclosure Channel' ;
    rdfs:comment 'Communication channel through which the disclosure request or response was transmitted: Misconduct Disclosure Scheme (MDS) platform, email, secure portal, phone, in-person, or other.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureDirection rdf:type rdf:Property ;
    rdfs:label 'Disclosure Direction' ;
    rdfs:comment 'Direction of the disclosure transaction: outbound request (organization requesting information about a candidate), inbound response (organization providing information in response to another organization\'s request), or bilateral exchange (mutual information sharing).' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureNotes rdf:type rdf:Property ;
    rdfs:label 'Disclosure Notes' ;
    rdfs:comment 'Free-text field for additional context, observations, or follow-up actions related to the disclosure. May include details about the disclosure process, communication with the responding organization, or internal decision-making rationale.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Disclosure Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this disclosure transaction within the Inter-Agency Misconduct Disclosure Scheme or equivalent reference check mechanism. Format: MDS-{ORG}-{SEQUENCE}.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureRequestDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Request Date' ;
    rdfs:comment 'Date when the misconduct disclosure request was initiated or received. Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disclosureResponseDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Response Date' ;
    rdfs:comment 'Date when the disclosure response was provided or received. Null if no response has been received or provided yet.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Disclosure Status' ;
    rdfs:comment 'Current lifecycle status of the disclosure transaction: pending (request initiated but not yet processed), in progress (under review), completed (response received or provided), no response (request timed out), declined (organization declined to provide information).' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureType rdf:type rdf:Property ;
    rdfs:label 'Disclosure Type' ;
    rdfs:comment 'Category of misconduct being disclosed: prior misconduct (general misconduct history), Sexual Exploitation and Abuse (SEA) finding, disciplinary termination, safeguarding concern, Protection from Sexual Exploitation and Abuse (PSEA) violation, or child safeguarding breach.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Employment Period End Date' ;
    rdfs:comment 'End date of the subject\'s employment or engagement with the responding organization. Null if currently employed or engagement is ongoing.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employmentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Employment Period Start Date' ;
    rdfs:comment 'Start date of the subject\'s employment or engagement with the responding organization. Used to establish timeline context for misconduct incidents.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:misconductCategory rdf:type rdf:Property ;
    rdfs:label 'Misconduct Category' ;
    rdfs:comment 'Primary category of confirmed misconduct disclosed: sexual exploitation, sexual abuse, child abuse, harassment, fraud, theft, violence, or other. Populated only if misconduct was confirmed. [ENUM-REF-CANDIDATE: sexual_exploitation|sexual_abuse|child_abuse|harassment|fraud|theft|violence|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:misconductConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Misconduct Confirmed Flag' ;
    rdfs:comment 'Boolean indicator of whether prior misconduct was confirmed in the disclosure response. True if misconduct confirmed, False if no misconduct found or not applicable.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:misconductIncidentDate rdf:type rdf:Property ;
    rdfs:label 'Misconduct Incident Date' ;
    rdfs:comment 'Date when the disclosed misconduct incident occurred. May be approximate if exact date is unknown. Populated only if misconduct was confirmed.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:misconductSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Misconduct Severity Level' ;
    rdfs:comment 'Severity classification of the confirmed misconduct: critical (immediate threat to beneficiaries or staff), high (serious policy violation), medium (moderate violation), low (minor infraction).' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingOrganizationCountry rdf:type rdf:Property ;
    rdfs:label 'Requesting Organization Country' ;
    rdfs:comment 'Country where the requesting or responding organization is headquartered or registered, represented as a 3-letter ISO country code.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Requesting Organization Name' ;
    rdfs:comment 'Name of the organization requesting misconduct disclosure information (for outbound requests) or the organization from which information is being requested (for inbound responses).' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingOrganizationType rdf:type rdf:Property ;
    rdfs:label 'Requesting Organization Type' ;
    rdfs:comment 'Type of organization requesting or providing disclosure information: International Non-Governmental Organization (INGO), Civil Society Organization (CSO), Community-Based Organization (CBO), United Nations (UN) agency, government, donor, or private sector. [ENUM-REF-CANDIDATE: ingo|cso|cbo|un_agency|government|donor|private_sector — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Response Received Flag' ;
    rdfs:comment 'Boolean indicator of whether a response has been received for an outbound disclosure request. True if response received, False if pending or no response.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseTurnaroundDays rdf:type rdf:Property ;
    rdfs:label 'Response Turnaround Days' ;
    rdfs:comment 'Number of calendar days between the disclosure request date and the response date. Used to track compliance with Inter-Agency Misconduct Disclosure Scheme (MDS) response time standards.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectReferenceType rdf:type rdf:Property ;
    rdfs:label 'Subject Reference Type' ;
    rdfs:comment 'Type of individual or entity that is the subject of the misconduct disclosure: staff candidate (prospective employee), volunteer candidate, consultant, partner organization, or vendor.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationForCauseFlag rdf:type rdf:Property ;
    rdfs:label 'Termination For Cause Flag' ;
    rdfs:comment 'Boolean indicator of whether the subject\'s employment was terminated for cause related to the disclosed misconduct. True if terminated for cause, False otherwise.' ;
    rdfs:domain ind:MisconductDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quaternaryPartnerLastModifiedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Partner Last Modified By Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who last modified this PSEA assessment record.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:tertiaryPartnerCreatedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Partner Created By Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who created this PSEA assessment record.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:assessmentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Completion Date' ;
    rdfs:comment 'Date when the PSEA assessment was finalized and results documented.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Expiry Date' ;
    rdfs:comment 'Date when this PSEA assessment expires and a new assessment must be conducted.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentMethodologyDescription rdf:type rdf:Property ;
    rdfs:label 'Assessment Methodology Description' ;
    rdfs:comment 'Description of the specific methodology, tools, and approach used to conduct the PSEA assessment.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this PSEA assessment for tracking and reporting purposes.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReportDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Assessment Report Document Url' ;
    rdfs:comment 'URL or file path to the detailed PSEA assessment report document.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentValidityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Assessment Validity Period Months' ;
    rdfs:comment 'Number of months for which this PSEA assessment remains valid before a new assessment is required.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityBuildingPlanTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Capacity Building Plan Triggered Flag' ;
    rdfs:comment 'Indicates whether the assessment findings triggered the requirement for a formal capacity-building plan to address identified gaps.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityScore rdf:type rdf:Property ;
    rdfs:label 'Capacity Score' ;
    rdfs:comment 'Numerical score representing the partner\'s PSEA capacity, calculated using the assessment tool\'s scoring methodology.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionalApprovalRequirements rdf:type rdf:Property ;
    rdfs:label 'Conditional Approval Requirements' ;
    rdfs:comment 'Specific conditions and milestones that must be met if the partnership was conditionally approved pending PSEA capacity improvements.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalGapFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Gap Flag' ;
    rdfs:comment 'Indicates whether critical safeguarding gaps were identified that pose immediate risk and require urgent remediation before partnership can proceed.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationCapacityRating rdf:type rdf:Property ;
    rdfs:label 'Investigation Capacity Rating' ;
    rdfs:comment 'Rating of the partner\'s capacity to conduct fair, timely, and survivor-centered investigations of safeguarding incidents.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyGapsIdentified rdf:type rdf:Property ;
    rdfs:label 'Key Gaps Identified' ;
    rdfs:comment 'Summary of the main safeguarding and PSEA capacity gaps identified during the assessment that require remediation.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPossibleScore rdf:type rdf:Property ;
    rdfs:label 'Maximum Possible Score' ;
    rdfs:comment 'Maximum score achievable in the PSEA assessment tool used, providing context for the capacity score.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallCapacityRating rdf:type rdf:Property ;
    rdfs:label 'Overall Capacity Rating' ;
    rdfs:comment 'Overall rating of the partner\'s safeguarding and PSEA capacity based on the assessment findings.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Partnership Approval Status' ;
    rdfs:comment 'Decision on whether the partner is approved for partnership engagement based on PSEA assessment results.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyExistenceRating rdf:type rdf:Property ;
    rdfs:label 'Policy Existence Rating' ;
    rdfs:comment 'Rating of whether the partner has adequate PSEA and safeguarding policies in place.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reassessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Reassessment Due Date' ;
    rdfs:comment 'Date by which the partner must undergo a follow-up PSEA assessment to verify capacity improvements.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reassessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reassessment Required Flag' ;
    rdfs:comment 'Indicates whether a follow-up reassessment is required to verify implementation of capacity-building actions.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingMechanismRating rdf:type rdf:Property ;
    rdfs:label 'Reporting Mechanism Rating' ;
    rdfs:comment 'Rating of the adequacy and accessibility of the partner\'s safeguarding incident reporting mechanisms.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffTrainingRating rdf:type rdf:Property ;
    rdfs:label 'Staff Training Rating' ;
    rdfs:comment 'Rating of the partner\'s PSEA and safeguarding training programs for staff and volunteers.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:survivorSupportRating rdf:type rdf:Property ;
    rdfs:label 'Survivor Support Rating' ;
    rdfs:comment 'Rating of the partner\'s capacity to provide survivor-centered support and referral services.' ;
    rdfs:domain ind:PartnerPseaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeguardingPolicyAcknowledgmentId rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Policy Acknowledgment Id' ;
    rdfs:comment 'Unique identifier for the policy acknowledgment record. Primary key.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafeguardingPolicyAcknowledgment .

ind:acknowledgerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Acknowledger Staff Member Id' ;
    rdfs:comment 'Identifier of the individual who acknowledged the policy. References staff, volunteer, partner staff, or contractor depending on acknowledger type.' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:learningCourseId rdf:type rdf:Property ;
    rdfs:label 'Learning Course Id' ;
    rdfs:comment 'Identifier of the safeguarding training course completed by the acknowledger, if applicable.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LearningCourse .

ind:primarySafeguardingUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Safeguarding User Account Id' ;
    rdfs:comment 'Identifier of the system user or administrator who created this acknowledgment record.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:supersededAcknowledgmentSafeguardingPolicyAcknowledgmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded Acknowledgment Safeguarding Policy Acknowledgment Id' ;
    rdfs:comment 'Identifier of the previous acknowledgment record that this acknowledgment supersedes, if applicable (e.g., when a new policy version is acknowledged).' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafeguardingPolicyAcknowledgment .

ind:acknowledgerEmail rdf:type rdf:Property ;
    rdfs:label 'Acknowledger Email' ;
    rdfs:comment 'Email address of the individual acknowledging the policy, used for notification and audit trail.' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgerName rdf:type rdf:Property ;
    rdfs:label 'Acknowledger Name' ;
    rdfs:comment 'Full legal name of the individual acknowledging the policy.' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgerType rdf:type rdf:Property ;
    rdfs:label 'Acknowledger Type' ;
    rdfs:comment 'Category of individual acknowledging the policy: staff, volunteer, partner staff, contractor, consultant, or board member.' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentLanguage rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Language' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language in which the policy was acknowledged.' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentLocation rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Location' ;
    rdfs:comment 'Physical or organizational location where the acknowledgment was completed (e.g., headquarters, field office, training venue).' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentMethod rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Method' ;
    rdfs:comment 'Method by which the acknowledgment was captured: digital signature, wet signature (physical), Learning Management System (LMS) confirmation, email confirmation, verbal recorded, or paper form.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Reference Number' ;
    rdfs:comment 'Externally-visible unique reference number for this acknowledgment record, used for audit trail and compliance reporting.' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Status' ;
    rdfs:comment 'Current lifecycle status of the acknowledgment: current (valid), expired (past validity period), superseded (new version acknowledged), revoked (acknowledgment withdrawn), or pending (awaiting confirmation).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Timestamp' ;
    rdfs:comment 'Precise timestamp when the acknowledgment was recorded in the system, including time zone.' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:acknowledgmentValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Valid From Date' ;
    rdfs:comment 'Date from which this acknowledgment becomes effective and valid.' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentValidUntilDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Valid Until Date' ;
    rdfs:comment 'Date until which this acknowledgment remains valid; after this date, re-acknowledgment may be required.' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentToProcessDataFlag rdf:type rdf:Property ;
    rdfs:label 'Consent To Process Data Flag' ;
    rdfs:comment 'Indicates whether the acknowledger provided consent for their acknowledgment data to be processed and stored (True/False).' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:digitalSignature rdf:type rdf:Property ;
    rdfs:label 'Digital Signature' ;
    rdfs:comment 'Encrypted digital signature or hash captured during electronic acknowledgment, if applicable.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lmsConfirmationCode rdf:type rdf:Property ;
    rdfs:label 'Lms Confirmation Code' ;
    rdfs:comment 'Unique confirmation identifier from the Learning Management System (LMS) if acknowledgment was captured via LMS.' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'Date by which the next renewal acknowledgment is due.' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyTitle rdf:type rdf:Property ;
    rdfs:label 'Policy Title' ;
    rdfs:comment 'Title of the safeguarding policy or code of conduct acknowledged.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Version Number' ;
    rdfs:comment 'Version number of the policy document acknowledged (e.g., 1.0, 2.1, 3.0.1).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderSentDate rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Date' ;
    rdfs:comment 'Date on which the most recent renewal reminder was sent to the acknowledger.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reminderSentFlag rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Flag' ;
    rdfs:comment 'Indicates whether a renewal reminder has been sent to the acknowledger (True/False).' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'Number of months between required renewals of acknowledgment, if renewal is required.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date on which the acknowledger completed the required safeguarding training, if applicable.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingCompletionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Completion Required Flag' ;
    rdfs:comment 'Indicates whether completion of safeguarding training was required before acknowledgment (True/False).' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:witnessRole rdf:type rdf:Property ;
    rdfs:label 'Witness Role' ;
    rdfs:comment 'Organizational role or title of the witness (e.g., HR Manager, Supervisor, Compliance Officer).' ;
    rdfs:domain ind:SafeguardingPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pseaNetworkMembershipId rdf:type rdf:Property ;
    rdfs:label 'Psea Network Membership Id' ;
    rdfs:comment 'Unique identifier for the PSEA network membership record. Primary key for this entity.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkId rdf:type rdf:Property ;
    rdfs:label 'Network Id' ;
    rdfs:comment 'Reference to the inter-agency PSEA network or safeguarding coordination body that the organization is a member of.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PseaNetwork .

ind:primaryPseaStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Psea Staff Member Id' ;
    rdfs:comment 'Reference to the staff member designated as the organization\'s focal point or representative to the network.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:primaryPseaUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Psea User Account Id' ;
    rdfs:comment 'Reference to the user who created this membership record.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:pseaStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Psea Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:tertiaryPseaFocalPointStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Psea Focal Point Staff Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:incidentReportingProtocolAdoptedFlag rdf:type rdf:Property ;
    rdfs:label 'Incident Reporting Protocol Adopted Flag' ;
    rdfs:comment 'Indicates whether the organization has adopted the network\'s standardized incident reporting protocol.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:informationSharingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Information Sharing Consent Flag' ;
    rdfs:comment 'Indicates whether the organization has consented to share safeguarding incident information with network members in accordance with confidentiality protocols.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jointTrainingParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Joint Training Participation Flag' ;
    rdfs:comment 'Indicates whether the organization participates in joint PSEA and safeguarding training activities organized by the network.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyCommitments rdf:type rdf:Property ;
    rdfs:label 'Key Commitments' ;
    rdfs:comment 'Description of the key commitments and obligations the organization has made under the network\'s terms of reference, such as information sharing, joint training, incident reporting protocols, and survivor support coordination.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFeePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Fee Payment Date' ;
    rdfs:comment 'Date when the organization last paid the membership fee.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingAttendanceFrequency rdf:type rdf:Property ;
    rdfs:label 'Meeting Attendance Frequency' ;
    rdfs:comment 'Expected frequency of the organization\'s attendance at network coordination meetings.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Membership Approval Date' ;
    rdfs:comment 'Date when the organization\'s membership application was formally approved by the network.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Membership Approved By' ;
    rdfs:comment 'Name or title of the network authority or committee that approved the membership.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Membership Fee Amount' ;
    rdfs:comment 'Annual or periodic membership fee amount required by the network, if applicable.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:membershipFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Membership Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the membership fee.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipFeeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Membership Fee Required Flag' ;
    rdfs:comment 'Indicates whether the network requires a membership fee or financial contribution from member organizations.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:membershipReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Membership Reference Number' ;
    rdfs:comment 'External reference number or code assigned by the network to identify this organization\'s membership.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCoordinatorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Network Coordinator Contact Email' ;
    rdfs:comment 'Email address of the network coordinator for administrative and coordination purposes.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCoordinatorOrganization rdf:type rdf:Property ;
    rdfs:label 'Network Coordinator Organization' ;
    rdfs:comment 'Name of the lead organization or agency coordinating the network.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:survivorReferralPathwayAdoptedFlag rdf:type rdf:Property ;
    rdfs:label 'Survivor Referral Pathway Adopted Flag' ;
    rdfs:comment 'Indicates whether the organization has adopted the network\'s survivor-centered referral pathway for support services.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Reason for suspension of the organization\'s membership, if applicable (e.g., non-compliance with network standards, failure to meet commitments).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsOfReferenceAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Terms Of Reference Acceptance Date' ;
    rdfs:comment 'Date when the organization formally accepted the network\'s terms of reference.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termsOfReferenceAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Terms Of Reference Accepted Flag' ;
    rdfs:comment 'Indicates whether the organization has formally accepted the network\'s terms of reference and membership obligations.' ;
    rdfs:domain ind:PseaNetworkMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededPolicyPseaPolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded Policy Psea Policy Id' ;
    rdfs:comment 'Reference to the previous policy version that this policy replaces. Null if this is the first version.' ;
    rdfs:domain ind:PseaPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PseaPolicy .

ind:acknowledgmentAudience rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Audience' ;
    rdfs:comment 'Target audience required to acknowledge the policy (e.g., All Staff, Field Staff, Volunteers, Partners, Board Members).' ;
    rdfs:domain ind:PseaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Deadline Days' ;
    rdfs:comment 'Number of days from policy effective date or staff onboarding within which acknowledgment must be completed.' ;
    rdfs:domain ind:PseaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceStandard rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard' ;
    rdfs:comment 'Industry or humanitarian standards the policy aligns with (e.g., CHS, Sphere, HAP, Keeping Children Safe).' ;
    rdfs:domain ind:PseaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClause rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause' ;
    rdfs:comment 'Summary of confidentiality and data protection provisions within the policy.' ;
    rdfs:domain ind:PseaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLanguage rdf:type rdf:Property ;
    rdfs:label 'Document Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code of the policy document (e.g., en, fr, es, ar).' ;
    rdfs:domain ind:PseaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalFrameworkReference rdf:type rdf:Property ;
    rdfs:label 'Legal Framework Reference' ;
    rdfs:comment 'Citation of relevant legal or regulatory frameworks that inform the policy (e.g., UN Convention on the Rights of the Child, local child protection laws).' ;
    rdfs:domain ind:PseaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether staff, volunteers, or partners are required to formally acknowledge and sign this policy.' ;
    rdfs:domain ind:PseaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyCategory rdf:type rdf:Property ;
    rdfs:label 'Policy Category' ;
    rdfs:comment 'Functional category of the policy within the safeguarding framework.' ;
    rdfs:domain ind:PseaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed summary of the policy purpose, scope, and key provisions.' ;
    rdfs:domain ind:PseaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyOwner rdf:type rdf:Property ;
    rdfs:label 'Policy Owner' ;
    rdfs:comment 'Department or role responsible for maintaining and updating the policy (e.g., Safeguarding Team, Human Resources, Compliance).' ;
    rdfs:domain ind:PseaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the safeguarding policy document type. [ENUM-REF-CANDIDATE: PSEA|Child Safeguarding|Code of Conduct|Whistleblower|Survivor Support|Beneficiary Protection|Staff Conduct — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PseaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pseaPolicyStatus rdf:type rdf:Property ;
    rdfs:label 'Psea Policy Status' ;
    rdfs:comment 'Current lifecycle status of the policy document.' ;
    rdfs:domain ind:PseaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingMechanismDescription rdf:type rdf:Property ;
    rdfs:label 'Reporting Mechanism Description' ;
    rdfs:comment 'Description of the reporting channels and procedures outlined in the policy for safeguarding concerns or violations.' ;
    rdfs:domain ind:PseaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsDescription rdf:type rdf:Property ;
    rdfs:label 'Sanctions Description' ;
    rdfs:comment 'Description of disciplinary actions or sanctions for policy violations.' ;
    rdfs:domain ind:PseaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Translation Available Flag' ;
    rdfs:comment 'Indicates whether translations of the policy are available in other languages.' ;
    rdfs:domain ind:Safeguarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingChannelId rdf:type rdf:Property ;
    rdfs:label 'Reporting Channel Id' ;
    rdfs:comment 'Unique identifier for the safeguarding reporting channel. Primary key.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReportingStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Reporting Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member designated as the primary focal point responsible for monitoring, maintaining, and responding to reports received through this channel.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:primaryReportingUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Reporting User Account Id' ;
    rdfs:comment 'Identifier of the system user who created this reporting channel record. Supports accountability and audit requirements.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:accessMethodDescription rdf:type rdf:Property ;
    rdfs:label 'Access Method Description' ;
    rdfs:comment 'Detailed instructions on how to access and use the reporting channel, including phone numbers, URLs, physical locations, or contact procedures.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessibilityAccommodations rdf:type rdf:Property ;
    rdfs:label 'Accessibility Accommodations' ;
    rdfs:comment 'Description of accommodations provided to ensure the channel is accessible to persons with disabilities, including visual, hearing, mobility, or cognitive impairments.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:additionalLanguagesSupported rdf:type rdf:Property ;
    rdfs:label 'Additional Languages Supported' ;
    rdfs:comment 'Comma-separated list of ISO 639-3 language codes for additional languages supported by the channel, enabling multilingual access for diverse affected populations.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anonymitySupportedFlag rdf:type rdf:Property ;
    rdfs:label 'Anonymity Supported Flag' ;
    rdfs:comment 'Indicates whether the channel allows anonymous reporting without requiring reporter identification. Critical for Protection from Sexual Exploitation and Abuse (PSEA) compliance.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Average Response Time Hours' ;
    rdfs:comment 'Mean time in hours from report receipt to initial acknowledgment or response through this channel. Key performance indicator for channel responsiveness.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Unique business identifier code for the reporting channel, used for external reference and reporting to Protection from Sexual Exploitation and Abuse (PSEA) networks.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCostAnnualUsd rdf:type rdf:Property ;
    rdfs:label 'Channel Cost Annual Usd' ;
    rdfs:comment 'Estimated annual operating cost of maintaining this reporting channel in United States Dollars, including technology, staffing, and third-party service fees.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Descriptive name of the reporting channel as communicated to affected populations and staff.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational status of the reporting channel. Active channels are available for receiving complaints and reports.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Classification of the reporting mechanism type. Determines the mode of access and operational requirements for the channel.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Contact Email Address' ;
    rdfs:comment 'Dedicated email address for receiving safeguarding reports and complaints through this channel.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Contact Phone Number' ;
    rdfs:comment 'Primary phone number for hotline-based reporting channels, including country code and extension if applicable.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCodesServed rdf:type rdf:Property ;
    rdfs:label 'Country Codes Served' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this channel is operational and accessible to affected populations and staff.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPolicy rdf:type rdf:Property ;
    rdfs:label 'Data Retention Policy' ;
    rdfs:comment 'Description of how long reports received through this channel are retained, including archival and destruction procedures in compliance with data protection regulations.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReportingIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'External Reporting Integration Flag' ;
    rdfs:comment 'Indicates whether this channel is integrated with external reporting systems such as United Nations Office for the Coordination of Humanitarian Affairs (OCHA) or donor-mandated platforms.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlineFormUrl rdf:type rdf:Property ;
    rdfs:label 'Online Form Url' ;
    rdfs:comment 'Web address of the online reporting form for digital submission channels. Must be secure (HTTPS) to protect reporter confidentiality.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursDescription rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Description' ;
    rdfs:comment 'Textual description of when the channel is available for receiving reports, including days of week, time ranges, and timezone information.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalLocationAddress rdf:type rdf:Property ;
    rdfs:label 'Physical Location Address' ;
    rdfs:comment 'Physical address where suggestion boxes or in-person reporting facilities are located, including building name, street, and office number.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionMaterialsAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Materials Available Flag' ;
    rdfs:comment 'Indicates whether information, education, and communication materials about this channel are available and distributed to target audiences.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pseaNetworkRegisteredFlag rdf:type rdf:Property ;
    rdfs:label 'Psea Network Registered Flag' ;
    rdfs:comment 'Indicates whether this channel is registered with the inter-agency Protection from Sexual Exploitation and Abuse (PSEA) network for coordinated reporting and referral.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportsReceivedCount rdf:type rdf:Property ;
    rdfs:label 'Reports Received Count' ;
    rdfs:comment 'Cumulative number of safeguarding reports and complaints received through this channel since activation. Used for channel effectiveness analysis.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Number of months between scheduled reviews of the reporting channel. Typical values are 6 or 12 months depending on organizational policy and channel risk profile.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thirdPartyProviderName rdf:type rdf:Property ;
    rdfs:label 'Third Party Provider Name' ;
    rdfs:comment 'Name of the external organization or service provider operating the reporting channel on behalf of the organization, if applicable.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationServiceAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Translation Service Available Flag' ;
    rdfs:comment 'Indicates whether real-time or on-demand translation services are available through this channel to support reporters who speak languages not directly supported.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:twentyFourSevenAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Twenty Four Seven Availability Flag' ;
    rdfs:comment 'Indicates whether the channel operates continuously without time restrictions. True for always-available channels such as online forms or third-party platforms.' ;
    rdfs:domain ind:ReportingChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountabilityMechanismRiskRating rdf:type rdf:Property ;
    rdfs:label 'Accountability Mechanism Risk Rating' ;
    rdfs:comment 'Risk rating for the adequacy and accessibility of accountability mechanisms, feedback channels, and complaint response systems for safeguarding concerns.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Assessment Scope Description' ;
    rdfs:comment 'Detailed description of the scope, boundaries, and focus areas covered by this safeguarding risk assessment, including specific programs, locations, or activities evaluated.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryConsultationConducted rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Consultation Conducted' ;
    rdfs:comment 'Flag indicating whether beneficiaries and affected populations were directly consulted as part of the risk assessment process.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communityTrustRiskRating rdf:type rdf:Property ;
    rdfs:label 'Community Trust Risk Rating' ;
    rdfs:comment 'Risk rating for community trust and perception of the organization, which impacts willingness to report safeguarding concerns.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlGapsIdentified rdf:type rdf:Property ;
    rdfs:label 'Control Gaps Identified' ;
    rdfs:comment 'Specific gaps, weaknesses, or deficiencies identified in existing safeguarding controls and risk mitigation measures.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedMitigationCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Mitigation Cost Usd' ;
    rdfs:comment 'Estimated cost in United States Dollars (USD) to implement all recommended safeguarding risk mitigation measures.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:existingControlsAssessment rdf:type rdf:Property ;
    rdfs:label 'Existing Controls Assessment' ;
    rdfs:comment 'Evaluation of existing safeguarding controls, policies, procedures, and mechanisms currently in place and their effectiveness.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyRisksIdentified rdf:type rdf:Property ;
    rdfs:label 'Key Risks Identified' ;
    rdfs:comment 'Summary of the most significant safeguarding risks identified during the assessment, including specific vulnerabilities and threat scenarios.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Mitigation Plan Status' ;
    rdfs:comment 'Current implementation status of the safeguarding risk mitigation plan developed from this assessment.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalEnvironmentRiskRating rdf:type rdf:Property ;
    rdfs:label 'Operational Environment Risk Rating' ;
    rdfs:comment 'Risk rating for the operational environment including conflict, displacement, humanitarian crisis conditions that may elevate safeguarding risks.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallSafeguardingRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Overall Safeguarding Risk Level' ;
    rdfs:comment 'Composite overall safeguarding risk level determined by aggregating individual risk category ratings and applying organizational risk assessment methodology.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerDueDiligenceRiskRating rdf:type rdf:Property ;
    rdfs:label 'Partner Due Diligence Risk Rating' ;
    rdfs:comment 'Risk rating for partner organization safeguarding capacity, policies, and due diligence processes.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerImbalanceRiskRating rdf:type rdf:Property ;
    rdfs:label 'Power Imbalance Risk Rating' ;
    rdfs:comment 'Risk rating for power imbalance between staff/volunteers and beneficiaries, a key safeguarding risk category under Protection from Sexual Exploitation and Abuse (PSEA) frameworks.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityActions rdf:type rdf:Property ;
    rdfs:label 'Priority Actions' ;
    rdfs:comment 'High-priority immediate actions required to address critical safeguarding risks identified in the assessment.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reassessmentFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Reassessment Frequency Months' ;
    rdfs:comment 'Recommended frequency in months for conducting reassessments, typically based on the overall risk level (e.g., critical risks require more frequent reassessment).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recommendedMitigations rdf:type rdf:Property ;
    rdfs:label 'Recommended Mitigations' ;
    rdfs:comment 'Detailed recommendations for mitigating identified safeguarding risks, including policy enhancements, training, process improvements, and resource allocation.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceRequirements rdf:type rdf:Property ;
    rdfs:label 'Resource Requirements' ;
    rdfs:comment 'Description of resources (financial, human, technical) required to implement recommended safeguarding risk mitigation measures.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffConductRiskRating rdf:type rdf:Property ;
    rdfs:label 'Staff Conduct Risk Rating' ;
    rdfs:comment 'Risk rating for staff and volunteer conduct, including adherence to code of conduct, safeguarding policies, and ethical standards.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholdersConsulted rdf:type rdf:Property ;
    rdfs:label 'Stakeholders Consulted' ;
    rdfs:comment 'List of stakeholder groups consulted during the assessment including staff, beneficiaries, community leaders, partners, and local authorities.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerablePopulationAccessRiskRating rdf:type rdf:Property ;
    rdfs:label 'Vulnerable Population Access Risk Rating' ;
    rdfs:comment 'Risk rating for staff and volunteer access to vulnerable populations including children, women, Internally Displaced Persons (IDP), and Persons of Concern (PoC).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedFocalPointId rdf:type rdf:Property ;
    rdfs:label 'Assigned Focal Point Id' ;
    rdfs:comment 'Foreign key linking to safeguarding.focal_point. Business justification: Safeguarding incidents must be assigned to designated safeguarding focal points for case management and response coordination. Currently safeguarding_incident has investigator_name as STRING but no FK' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FocalPoint .

ind:distributionOrderId rdf:type rdf:Property ;
    rdfs:label 'Distribution Order Id' ;
    rdfs:comment 'Foreign key linking to supply.distribution_order. Business justification: Distribution operations involve direct beneficiary contact and are high-risk safeguarding contexts. Required for incident investigation, distribution safety protocols, and beneficiary protection durin' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionOrder .

ind:survivorRegistrantId rdf:type rdf:Property ;
    rdfs:label 'Survivor Registrant Id' ;
    rdfs:comment 'Foreign key linking to beneficiary.registrant. Business justification: Safeguarding incidents often involve beneficiaries as survivors/witnesses. Linking incident to registrant enables integrated protection case management, coordinates with protection_flag tracking, ensu' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registrant .

ind:allegedPerpetratorName rdf:type rdf:Property ;
    rdfs:label 'Alleged Perpetrator Name' ;
    rdfs:comment 'The name of the alleged perpetrator, if known. Highly sensitive and access-restricted during investigation.' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allegedPerpetratorType rdf:type rdf:Property ;
    rdfs:label 'Alleged Perpetrator Type' ;
    rdfs:comment 'The category of the alleged perpetrator: staff member, volunteer, partner organization personnel, contractor, beneficiary, external party, or unknown. [ENUM-REF-CANDIDATE: staff|volunteer|partner|contractor|beneficiary|external|unknown — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anonymizationFlag rdf:type rdf:Property ;
    rdfs:label 'Anonymization Flag' ;
    rdfs:comment 'Indicates whether the incident report has been anonymized to protect the identity of the reporter or survivor. True if anonymized, False if identifiable information is retained.' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Description of organizational corrective actions, policy changes, or systemic improvements implemented in response to this incident to prevent recurrence.' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Investigation Required Flag' ;
    rdfs:comment 'Indicates whether a formal investigation is required for this incident. True if investigation needed, False if incident can be resolved through other means.' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigatorName rdf:type rdf:Property ;
    rdfs:label 'Investigator Name' ;
    rdfs:comment 'The name of the lead investigator assigned to this safeguarding incident case.' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notified Flag' ;
    rdfs:comment 'Indicates whether local law enforcement or legal authorities were notified of this incident. True if notified, False otherwise.' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationCountry rdf:type rdf:Property ;
    rdfs:label 'Location Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the safeguarding incident occurred.' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationSite rdf:type rdf:Property ;
    rdfs:label 'Location Site' ;
    rdfs:comment 'The specific site, facility, or field location where the incident occurred (e.g., distribution center, health clinic, office, camp).' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterContact rdf:type rdf:Property ;
    rdfs:label 'Reporter Contact' ;
    rdfs:comment 'Contact information (phone or email) for the reporter, if provided and consent given for follow-up communication.' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterName rdf:type rdf:Property ;
    rdfs:label 'Reporter Name' ;
    rdfs:comment 'The full name of the person who reported the safeguarding incident, if known and consent provided. May be null for anonymous reports.' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterType rdf:type rdf:Property ;
    rdfs:label 'Reporter Type' ;
    rdfs:comment 'The category of person who reported the incident: beneficiary, staff member, volunteer, partner organization staff, community member, or anonymous reporter.' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Detailed sub-classification of the incident type providing additional specificity (e.g., sexual harassment, physical abuse, financial fraud, conflict of interest).' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:survivorAgeGroup rdf:type rdf:Property ;
    rdfs:label 'Survivor Age Group' ;
    rdfs:comment 'Age group classification of the survivor to support child safeguarding analysis without revealing precise age. Used for statistical reporting and risk assessment.' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:survivorGender rdf:type rdf:Property ;
    rdfs:label 'Survivor Gender' ;
    rdfs:comment 'Gender of the survivor, used for Gender-Based Violence (GBV) analysis and safeguarding pattern identification.' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:survivorInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Survivor Involved Flag' ;
    rdfs:comment 'Indicates whether there is an identified survivor or victim involved in this safeguarding incident. True if survivor identified, False if no survivor or incident does not involve a victim.' ;
    rdfs:domain ind:SafeguardingIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportServiceReferralId rdf:type rdf:Property ;
    rdfs:label 'Support Service Referral Id' ;
    rdfs:comment 'Unique identifier for the support service referral record. Primary key for this entity.' ;
    rdfs:domain ind:SupportServiceReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualServiceStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Service Start Date' ;
    rdfs:comment 'Actual date when the survivor began receiving the referred service. Null if service has not yet started.' ;
    rdfs:domain ind:SupportServiceReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedServiceStartDate rdf:type rdf:Property ;
    rdfs:label 'Expected Service Start Date' ;
    rdfs:comment 'Anticipated date when the survivor will begin receiving the referred service. Used for planning and follow-up.' ;
    rdfs:domain ind:SupportServiceReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpOutcome rdf:type rdf:Property ;
    rdfs:label 'Follow Up Outcome' ;
    rdfs:comment 'Summary of the follow-up findings, including survivor feedback and service delivery status. Confidential survivor information.' ;
    rdfs:domain ind:SupportServiceReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informationSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Information Sharing Consent' ;
    rdfs:comment 'Level of consent provided by the survivor for sharing their information with the service provider. Governs what details can be disclosed.' ;
    rdfs:domain ind:SupportServiceReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interagencyReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Interagency Referral Flag' ;
    rdfs:comment 'Indicates whether this referral is part of an interagency coordination mechanism or referral pathway. Used for humanitarian coordination reporting.' ;
    rdfs:domain ind:SupportServiceReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingOrganizationType rdf:type rdf:Property ;
    rdfs:label 'Receiving Organization Type' ;
    rdfs:comment 'Classification of the service provider organization. Distinguishes between internal departments, partner organizations, government services, and other provider types.' ;
    rdfs:domain ind:SupportServiceReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralChannel rdf:type rdf:Property ;
    rdfs:label 'Referral Channel' ;
    rdfs:comment 'Communication channel or mechanism used to transmit the referral to the service provider.' ;
    rdfs:domain ind:SupportServiceReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralPathwayName rdf:type rdf:Property ;
    rdfs:label 'Referral Pathway Name' ;
    rdfs:comment 'Name of the formal referral pathway or protocol being followed. Common in coordinated humanitarian response contexts.' ;
    rdfs:domain ind:SupportServiceReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralUrgency rdf:type rdf:Property ;
    rdfs:label 'Referral Urgency' ;
    rdfs:comment 'Priority level of the referral indicating how quickly the survivor needs to access the service. Guides provider response time.' ;
    rdfs:domain ind:SupportServiceReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referringDepartment rdf:type rdf:Property ;
    rdfs:label 'Referring Department' ;
    rdfs:comment 'Department or program unit within the organization that initiated the referral. Used for internal coordination and reporting.' ;
    rdfs:domain ind:SupportServiceReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Service Completion Date' ;
    rdfs:comment 'Date when the referred service was completed or concluded. Null if service is ongoing or not yet started.' ;
    rdfs:domain ind:SupportServiceReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Detailed description of the specific support service or intervention being referred. Provides context for the receiving provider.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceProviderContactName rdf:type rdf:Property ;
    rdfs:label 'Service Provider Contact Name' ;
    rdfs:comment 'Name of the specific individual or focal point at the receiving organization responsible for this referral.' ;
    rdfs:domain ind:SupportServiceReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceProviderEmail rdf:type rdf:Property ;
    rdfs:label 'Service Provider Email' ;
    rdfs:comment 'Email address for the service provider or focal point. Used for formal referral documentation and communication.' ;
    rdfs:domain ind:SupportServiceReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceProviderPhone rdf:type rdf:Property ;
    rdfs:label 'Service Provider Phone' ;
    rdfs:comment 'Contact phone number for the service provider or focal point. Used for coordination and follow-up.' ;
    rdfs:domain ind:SupportServiceReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Category of support service being referred. Classifies the nature of assistance the survivor requires.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryRegistrantId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Registrant Id' ;
    rdfs:comment 'Foreign key linking to beneficiary.registrant. Business justification: When consent and confidentiality protocols permit, linking survivor_record to registrant enables integrated case management across safeguarding and program systems, coordinates protection flags, ensur' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registrant .

ind:primarySurvivorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Survivor Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member assigned as the primary support focal point for this survivor. Responsible for coordinating survivor-centered support services and case management.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:survivorCreatedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Survivor Created By Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who created this survivor record. Supports accountability and audit trail for sensitive data handling.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:survivorLastModifiedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Survivor Last Modified By Staff Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who last modified this survivor record. Supports accountability and audit trail for sensitive data handling.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:ageGroup rdf:type rdf:Property ;
    rdfs:label 'Age Group' ;
    rdfs:comment 'Age bracket of the survivor at the time of incident reporting. Stored as range rather than exact age to reduce re-identification risk while enabling age-appropriate support planning.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseClosureNotes rdf:type rdf:Property ;
    rdfs:label 'Case Closure Notes' ;
    rdfs:comment 'Confidential notes documenting the circumstances and outcomes at case closure. Supports case management quality assurance and learning.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseClosureReason rdf:type rdf:Property ;
    rdfs:label 'Case Closure Reason' ;
    rdfs:comment 'Reason for closing the survivor support case. Provides accountability and learning for case management quality.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Breach Flag' ;
    rdfs:comment 'Indicates whether a confidentiality breach has been identified in the handling of this survivor\'s case. Triggers corrective action and accountability measures.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:economicSupportProvided rdf:type rdf:Property ;
    rdfs:label 'Economic Support Provided' ;
    rdfs:comment 'Indicates whether economic assistance (cash, livelihood support, etc.) has been provided to the survivor. Supports survivor resilience and recovery.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferralMade rdf:type rdf:Property ;
    rdfs:label 'External Referral Made' ;
    rdfs:comment 'Indicates whether the survivor has been referred to external service providers (health, legal, psychosocial, etc.). Tracks multi-agency coordination.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalSupportProvided rdf:type rdf:Property ;
    rdfs:label 'Legal Support Provided' ;
    rdfs:comment 'Indicates whether legal assistance or referral to legal services has been provided to the survivor. Tracks access to justice pathways.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalSupportProvided rdf:type rdf:Property ;
    rdfs:label 'Medical Support Provided' ;
    rdfs:comment 'Indicates whether medical or health services have been provided or facilitated for the survivor. Essential for comprehensive survivor care tracking.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Survivor\'s preferred method for follow-up communication. Respects survivor autonomy and safety considerations in contact planning.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psychosocialSupportProvided rdf:type rdf:Property ;
    rdfs:label 'Psychosocial Support Provided' ;
    rdfs:comment 'Indicates whether Psychosocial Support (PSS) services have been provided to the survivor as part of the response. Critical for tracking holistic survivor care.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordLastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Last Modified Timestamp' ;
    rdfs:comment 'Timestamp when this survivor record was last updated. Critical for audit trail and ensuring data currency in active cases.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:safeContactEmail rdf:type rdf:Property ;
    rdfs:label 'Safe Contact Email' ;
    rdfs:comment 'Email address designated by survivor as safe for contact. Used only with explicit consent and when email is the preferred contact method.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeContactPhone rdf:type rdf:Property ;
    rdfs:label 'Safe Contact Phone' ;
    rdfs:comment 'Phone number designated by survivor as safe for contact. May differ from primary phone to protect confidentiality and safety.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportEndDate rdf:type rdf:Property ;
    rdfs:label 'Support End Date' ;
    rdfs:comment 'Date when survivor support services were concluded or case was closed. Nullable for ongoing support cases.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportStartDate rdf:type rdf:Property ;
    rdfs:label 'Support Start Date' ;
    rdfs:comment 'Date when formal survivor support services were initiated. Marks the beginning of the organization\'s survivor-centered response.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportStatus rdf:type rdf:Property ;
    rdfs:label 'Support Status' ;
    rdfs:comment 'Current stage of survivor support services. Tracks progression through the survivor-centered response pathway from initial contact through case closure.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:survivorCode rdf:type rdf:Property ;
    rdfs:label 'Survivor Code' ;
    rdfs:comment 'Pseudonymized or anonymized identifier assigned to protect survivor identity while enabling case tracking across systems. Used in place of real name to maintain confidentiality per PSEA protocols.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:survivorType rdf:type rdf:Property ;
    rdfs:label 'Survivor Type' ;
    rdfs:comment 'Classification of the survivor\'s relationship to the organization at the time of the incident. Determines applicable safeguarding protocols and support pathways.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerabilityNotes rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Notes' ;
    rdfs:comment 'Confidential notes documenting specific vulnerabilities, risks, or special considerations for this survivor. Used to inform tailored support planning and risk mitigation.' ;
    rdfs:domain ind:SurvivorRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:survivorSupportPlanId rdf:type rdf:Property ;
    rdfs:label 'Survivor Support Plan Id' ;
    rdfs:comment 'Unique identifier for the survivor support plan record. Primary key.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySurvivorUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Survivor User Account Id' ;
    rdfs:comment 'Reference to the staff user who initially created this survivor support plan record.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:educationServiceDescription rdf:type rdf:Property ;
    rdfs:label 'Education Service Description' ;
    rdfs:comment 'Detailed description of education support services to be provided, including school enrollment assistance, tutoring, vocational training, and educational materials.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationSupportRequired rdf:type rdf:Property ;
    rdfs:label 'Education Support Required' ;
    rdfs:comment 'Indicates whether educational services and support are included in the survivor support plan.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:housingServiceDescription rdf:type rdf:Property ;
    rdfs:label 'Housing Service Description' ;
    rdfs:comment 'Detailed description of safe housing services to be provided, including temporary shelter, relocation assistance, or long-term housing support.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalServiceDescription rdf:type rdf:Property ;
    rdfs:label 'Legal Service Description' ;
    rdfs:comment 'Detailed description of legal aid services to be provided, including legal representation, rights information, and justice system navigation support.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:livelihoodServiceDescription rdf:type rdf:Property ;
    rdfs:label 'Livelihood Service Description' ;
    rdfs:comment 'Detailed description of livelihood support services to be provided, including skills training, cash assistance, income generation activities, and employment support.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:livelihoodSupportRequired rdf:type rdf:Property ;
    rdfs:label 'Livelihood Support Required' ;
    rdfs:comment 'Indicates whether economic empowerment and livelihood assistance services are included in the survivor support plan.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalReferralRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Referral Required' ;
    rdfs:comment 'Indicates whether medical care or health services referral is included in the survivor support plan.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalServiceDescription rdf:type rdf:Property ;
    rdfs:label 'Medical Service Description' ;
    rdfs:comment 'Detailed description of medical services to be provided or referred, including clinical care, reproductive health services, and ongoing treatment needs.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:needsAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Needs Assessment Date' ;
    rdfs:comment 'Date when the comprehensive needs assessment was conducted with the survivor to identify required support services.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Planned or actual date when the survivor support plan is scheduled to conclude or was completed.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planGoals rdf:type rdf:Property ;
    rdfs:label 'Plan Goals' ;
    rdfs:comment 'Documented goals and objectives of the survivor support plan as agreed with the survivor, outlining desired outcomes and recovery milestones.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Reference Number' ;
    rdfs:comment 'Human-readable unique reference number for the survivor support plan, formatted as SSP-YYYY-NNNNNN.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'Date when the survivor support plan becomes active and service delivery begins.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:progressNotes rdf:type rdf:Property ;
    rdfs:label 'Progress Notes' ;
    rdfs:comment 'Ongoing narrative documentation of progress toward plan goals, service delivery updates, and any adjustments made to the support plan.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pssServiceDescription rdf:type rdf:Property ;
    rdfs:label 'Pss Service Description' ;
    rdfs:comment 'Detailed description of psychosocial support services to be provided, including counseling, peer support groups, and mental health interventions.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psychosocialSupportRequired rdf:type rdf:Property ;
    rdfs:label 'Psychosocial Support Required' ;
    rdfs:comment 'Indicates whether psychosocial support services are included in the survivor support plan.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralPathwayUsed rdf:type rdf:Property ;
    rdfs:label 'Referral Pathway Used' ;
    rdfs:comment 'Name or identifier of the inter-agency referral pathway or service directory used to connect the survivor with appropriate service providers.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Scheduled frequency for reviewing and updating the survivor support plan to ensure services remain appropriate and effective.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeHousingRequired rdf:type rdf:Property ;
    rdfs:label 'Safe Housing Required' ;
    rdfs:comment 'Indicates whether safe shelter or housing assistance is included in the survivor support plan.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyPlanIncluded rdf:type rdf:Property ;
    rdfs:label 'Safety Plan Included' ;
    rdfs:comment 'Indicates whether a personalized safety plan has been developed and included as part of the survivor support plan.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:survivorCenteredApproach rdf:type rdf:Property ;
    rdfs:label 'Survivor Centered Approach' ;
    rdfs:comment 'Indicates whether the support plan was developed using survivor-centered principles, prioritizing the survivors autonomy, safety, and expressed needs.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:survivorConsentObtained rdf:type rdf:Property ;
    rdfs:label 'Survivor Consent Obtained' ;
    rdfs:comment 'Indicates whether informed consent was obtained from the survivor for the support plan and associated service delivery.' ;
    rdfs:domain ind:SurvivorSupportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numeric score achieved by the participant on the training assessment or quiz. Expressed as a percentage (0.00 to 100.00) to measure comprehension of safeguarding principles.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attemptsCount rdf:type rdf:Property ;
    rdfs:label 'Attempts Count' ;
    rdfs:comment 'Number of attempts the participant made to pass the training assessment. Used to identify individuals requiring additional support or remedial training.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'Date when the training certificate expires and the participant must complete refresher training. Critical for tracking mandatory recertification obligations under PSEA and safeguarding policies.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'Date when the completion certificate was officially issued to the participant. May differ from completion date due to administrative processing time.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Flag' ;
    rdfs:comment 'Indicates whether a completion certificate was issued to the participant. True when certificate has been generated and delivered; false otherwise.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionChannel rdf:type rdf:Property ;
    rdfs:label 'Completion Channel' ;
    rdfs:comment 'Delivery method or platform through which the training was completed. Distinguishes between Learning Management System (LMS) online courses, in-person classroom sessions, and other modalities.' ;
    rdfs:domain ind:SafeguardingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Completion Reference Number' ;
    rdfs:comment 'Business identifier for this training completion record. Used for audit trails, certificate references, and external reporting to donors or regulators.' ;
    rdfs:domain ind:SafeguardingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline Date' ;
    rdfs:comment 'Date by which the participant was required to complete the training to meet organizational or donor compliance obligations. Used to identify overdue training and non-compliance risk.' ;
    rdfs:domain ind:SafeguardingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalProviderName rdf:type rdf:Property ;
    rdfs:label 'External Provider Name' ;
    rdfs:comment 'Name of the external training provider or consultancy that delivered the course, if not conducted in-house. Null for internally-delivered training.' ;
    rdfs:domain ind:SafeguardingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackComments rdf:type rdf:Property ;
    rdfs:label 'Feedback Comments' ;
    rdfs:comment 'Free-text comments provided by the participant about the training experience. Captures suggestions for improvement, content gaps, or delivery issues.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackRating rdf:type rdf:Property ;
    rdfs:label 'Feedback Rating' ;
    rdfs:comment 'Participant satisfaction rating for the training course, typically on a scale of 1 to 5. Used for continuous improvement of safeguarding training quality.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'Name of the facilitator or instructor who delivered the training for in-person or virtual instructor-led sessions. Null for self-paced online courses.' ;
    rdfs:domain ind:SafeguardingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lmsCourseCode rdf:type rdf:Property ;
    rdfs:label 'Lms Course Code' ;
    rdfs:comment 'External identifier from the Learning Management System where the training was delivered. Used for integration and reconciliation with LMS platforms such as Workday Learning.' ;
    rdfs:domain ind:SafeguardingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryTrainingFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Training Flag' ;
    rdfs:comment 'Indicates whether this training was mandatory for the participant based on their role, location, or organizational policy. True for required safeguarding training; false for optional professional development.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextRefresherDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Refresher Due Date' ;
    rdfs:comment 'Date when the participant must complete refresher training to maintain current certification. Calculated based on certificate expiry date and organizational recertification policies.' ;
    rdfs:domain ind:SafeguardingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdueFlag rdf:type rdf:Property ;
    rdfs:label 'Overdue Flag' ;
    rdfs:comment 'Indicates whether the training completion occurred after the compliance deadline. True when completed late or still incomplete past deadline; false when completed on time.' ;
    rdfs:domain ind:SafeguardingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:participantType rdf:type rdf:Property ;
    rdfs:label 'Participant Type' ;
    rdfs:comment 'Classification of the individual completing the training. Determines compliance obligations and reporting requirements under organizational safeguarding policies.' ;
    rdfs:domain ind:SafeguardingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Binary outcome of the training assessment. Determines whether the participant met the minimum competency requirements for safeguarding knowledge.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score required to pass the training assessment at the time of completion. Captured to support historical audit when passing thresholds change over time.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refresherRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Refresher Required Flag' ;
    rdfs:comment 'Indicates whether this completion record requires a future refresher training. True for certifications with expiry dates; false for one-time orientation training.' ;
    rdfs:domain ind:SafeguardingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'Total number of hours the participant spent completing the training. Used for professional development tracking and compliance with donor-mandated training hour requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'Physical location or virtual platform where the training was conducted. Examples include country office name, city, or virtual meeting platform (Zoom, Teams).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Date' ;
    rdfs:comment 'Date when the training waiver was officially approved. Used for audit trail and compliance documentation.' ;
    rdfs:domain ind:SafeguardingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the authorized individual who approved the training waiver. Typically a safeguarding focal point, HR director, or country director.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPlatformSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Delivery Platform System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Safeguarding training programs (PSEA, code of conduct, child protection) are delivered through LMS platforms. Organizations need this link for user provisioning, completion tracking integration, certi' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:primaryTrainingUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Training User Account Id' ;
    rdfs:comment 'Identifier of the user who created this training program record.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:requiredForJobProfileId rdf:type rdf:Property ;
    rdfs:label 'Required For Job Profile Id' ;
    rdfs:comment 'Foreign key linking to workforce.job_profile. Business justification: Training programs are mapped to job profiles to define mandatory safeguarding training by role type (all staff, managers, beneficiary-facing, designated roles). Enables systematic compliance tracking,' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:supersededProgramTrainingProgramId rdf:type rdf:Property ;
    rdfs:label 'Superseded Program Training Program Id' ;
    rdfs:comment 'Identifier of the previous version of this training program that this version replaces. Null if this is the first version.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingProgram .

ind:accreditingBody rdf:type rdf:Property ;
    rdfs:label 'Accrediting Body' ;
    rdfs:comment 'Name of the external organization or internal department that accredits or certifies this training program.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assessment Required Flag' ;
    rdfs:comment 'Indicates whether participants must complete an assessment to receive certification. True if assessment required, False otherwise.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availableLanguages rdf:type rdf:Property ;
    rdfs:label 'Available Languages' ;
    rdfs:comment 'Comma-separated list of two-letter ISO 639-1 language codes for all languages in which this training is available.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Issued Flag' ;
    rdfs:comment 'Indicates whether a formal certificate is issued upon successful completion. True if certificate issued, False otherwise.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentUrl rdf:type rdf:Property ;
    rdfs:label 'Content Url' ;
    rdfs:comment 'Web address or file path where the training content, materials, or Learning Management System (LMS) course can be accessed.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerParticipantUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Participant Usd' ;
    rdfs:comment 'Cost in United States Dollars to deliver the training program per participant, including materials, instructor fees, and platform costs.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryModality rdf:type rdf:Property ;
    rdfs:label 'Delivery Modality' ;
    rdfs:comment 'Method by which the training is delivered to participants.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentCapacity rdf:type rdf:Property ;
    rdfs:label 'Enrollment Capacity' ;
    rdfs:comment 'Maximum number of participants that can be enrolled in a single session or cohort of this training program. Null indicates unlimited capacity.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilitatorQualifications rdf:type rdf:Property ;
    rdfs:label 'Facilitator Qualifications' ;
    rdfs:comment 'Required qualifications, certifications, or experience for individuals authorized to facilitate this training program.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitatorRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Facilitator Required Flag' ;
    rdfs:comment 'Indicates whether a trained facilitator or instructor is required to deliver this training. True if facilitator required, False for self-paced programs.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:learningObjectives rdf:type rdf:Property ;
    rdfs:label 'Learning Objectives' ;
    rdfs:comment 'Specific, measurable learning objectives that participants will achieve upon completion of the training.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsDescription rdf:type rdf:Property ;
    rdfs:label 'Materials Description' ;
    rdfs:comment 'Description of the training materials provided to participants, including format (digital, printed) and content overview.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Materials Provided Flag' ;
    rdfs:comment 'Indicates whether training materials (handouts, guides, reference documents) are provided to participants. True if materials provided, False otherwise.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passingScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Passing Score Percentage' ;
    rdfs:comment 'Minimum percentage score required to pass the assessment and receive certification. Null if no assessment required.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisites rdf:type rdf:Property ;
    rdfs:label 'Prerequisites' ;
    rdfs:comment 'Any prerequisite training programs, certifications, or experience required before enrolling in this program.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Detailed description of the training program content, objectives, and expected learning outcomes.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the training program. Determines availability for enrollment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programTitle rdf:type rdf:Property ;
    rdfs:label 'Program Title' ;
    rdfs:comment 'Full title of the safeguarding training program as displayed to learners and in catalogs.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Category of safeguarding training. Defines the primary focus area of the program.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Validity Period Months' ;
    rdfs:comment 'Number of months the training certification remains valid before renewal or refresher training is required. Null indicates no expiration.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coldChainRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required Flag' ;
    rdfs:comment 'Indicates whether the commodity requires continuous temperature-controlled storage and transport (cold chain) from procurement through distribution, typical for vaccines and certain medical supplies.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the commodity item across procurement, warehousing, and distribution systems. Often aligned with UNSPSC or internal cataloging standards.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityDescription rdf:type rdf:Property ;
    rdfs:label 'Commodity Description' ;
    rdfs:comment 'Detailed textual description of the commodity including specifications, intended use, and any special characteristics relevant to field operations and beneficiary distribution.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityName rdf:type rdf:Property ;
    rdfs:label 'Commodity Name' ;
    rdfs:comment 'Full descriptive name of the humanitarian commodity or relief item as it appears in procurement documents and distribution manifests.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityStatus rdf:type rdf:Property ;
    rdfs:label 'Commodity Status' ;
    rdfs:comment 'Current lifecycle status of the commodity in the master catalog (e.g., active for procurement and distribution, inactive, discontinued, pending approval, restricted use).' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorRestrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Donor Restriction Notes' ;
    rdfs:comment 'Free-text description of specific donor restrictions or conditions attached to the commodity, including geographic limitations, beneficiary eligibility criteria, or usage constraints.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harmonizedTariffCode rdf:type rdf:Property ;
    rdfs:label 'Harmonized Tariff Code' ;
    rdfs:comment 'International Harmonized System (HS) tariff classification code for the commodity, used for customs clearance, import/export documentation, and duty calculation.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'Specific hazard classification code or category (e.g., flammable, corrosive, toxic, biohazard) if the commodity is flagged as hazardous material, following UN or GHS standards.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether the commodity is classified as hazardous material requiring special handling, storage, and transport procedures per international safety standards.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inKindDonationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'In Kind Donation Eligible Flag' ;
    rdfs:comment 'Indicates whether the commodity is eligible to be received as an in-kind donation from corporate or individual donors, subject to organizational acceptance policies and quality standards.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kitAssemblyFlag rdf:type rdf:Property ;
    rdfs:label 'Kit Assembly Flag' ;
    rdfs:comment 'Indicates whether the commodity is a pre-assembled kit or bundle composed of multiple component items (e.g., hygiene kit, shelter kit, medical kit) rather than a single item.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kitComponentCount rdf:type rdf:Property ;
    rdfs:label 'Kit Component Count' ;
    rdfs:comment 'Number of distinct component items included in the kit or assembly if the commodity is flagged as a kit, used for bill of materials tracking and inventory management.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the manufacturer or producer of the commodity, important for quality assurance, traceability, and compliance with donor or regulatory requirements.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Manufacturer-assigned part number or model identifier for the commodity, used for precise specification matching and procurement accuracy.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum quantity that must be ordered from suppliers per procurement transaction, driven by vendor requirements or economic order quantity considerations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Procurement Lead Time Days' ;
    rdfs:comment 'Average number of days required from purchase order issuance to commodity receipt at warehouse, used for supply chain planning and emergency response preparedness.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityCertification rdf:type rdf:Property ;
    rdfs:label 'Quality Certification' ;
    rdfs:comment 'Quality certifications or standards compliance held by the commodity (e.g., ISO, WHO prequalification, FDA approval, CE marking), ensuring safety and efficacy for humanitarian use.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'Inventory level threshold that triggers automatic reorder or procurement action to maintain adequate stock for field operations and emergency response.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Number of days the commodity remains usable and safe from the date of manufacture or receipt, critical for inventory rotation and distribution planning.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text instructions for special handling, storage, or transport requirements not captured in structured fields, including fragility, orientation, stacking limits, or security considerations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sphereCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sphere Compliant Flag' ;
    rdfs:comment 'Indicates whether the commodity meets Sphere Humanitarian Charter and Minimum Standards for quality, safety, and appropriateness in humanitarian response.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardUnitCost rdf:type rdf:Property ;
    rdfs:label 'Standard Unit Cost' ;
    rdfs:comment 'Standard or average cost per unit of measure for the commodity, used for budgeting, procurement planning, and financial reporting. Currency is organizational default unless otherwise specified.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageHumidityMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Max Percent' ;
    rdfs:comment 'Maximum relative humidity percentage allowed in storage environment to prevent commodity degradation, mold, or spoilage.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max Celsius' ;
    rdfs:comment 'Maximum storage temperature in degrees Celsius required to maintain commodity integrity and safety, particularly critical for medical supplies and cold-chain items.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min Celsius' ;
    rdfs:comment 'Minimum storage temperature in degrees Celsius required to maintain commodity integrity and safety, particularly critical for medical supplies and cold-chain items.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Secondary classification providing finer granularity within the primary commodity category (e.g., within WASH: hygiene kits, water purification tablets, sanitation supplies).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumePerUnitCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Per Unit Cubic Meters' ;
    rdfs:comment 'Volume in cubic meters occupied by a single unit of the commodity, used for warehouse space planning, transport capacity optimization, and last-mile logistics.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightPerUnitKg rdf:type rdf:Property ;
    rdfs:label 'Weight Per Unit Kg' ;
    rdfs:comment 'Weight in kilograms of a single unit of the commodity, used for logistics planning, freight cost calculation, and warehouse capacity management.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuingWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Issuing Warehouse Id' ;
    rdfs:comment 'Reference to the warehouse from which commodities will be released and dispatched. Source location for stock movement.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:primaryDistributionStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Staff Member Id' ;
    rdfs:comment 'Reference to the staff member responsible for overseeing the loading and dispatch of commodities from the warehouse. Accountability for stock release.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the transport carrier or logistics provider responsible for delivering the commodities. May be internal fleet or third-party contractor.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Required Flag' ;
    rdfs:comment 'Indicates whether this distribution order requires customs clearance for cross-border shipment. Triggers customs documentation and compliance processes.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsReference rdf:type rdf:Property ;
    rdfs:label 'Customs Reference' ;
    rdfs:comment 'Reference number for customs clearance documentation if cross-border shipment is required. Used for tracking and compliance verification.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Special instructions or notes for the delivery of commodities to the destination distribution point. May include access constraints, security protocols, or handling requirements.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchDate rdf:type rdf:Property ;
    rdfs:label 'Dispatch Date' ;
    rdfs:comment 'Date when commodities were physically dispatched from the issuing warehouse. Marks the start of last-mile logistics execution.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:driverContact rdf:type rdf:Property ;
    rdfs:label 'Driver Contact' ;
    rdfs:comment 'Contact phone number for the driver during transit. Enables real-time communication for tracking and issue resolution during delivery.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'Name of the driver responsible for transporting the commodities. Used for accountability and security purposes in field operations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Flag' ;
    rdfs:comment 'Indicates whether this distribution order is part of an emergency response operation. True for rapid-onset disaster or crisis response orders.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedValueUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Value Usd' ;
    rdfs:comment 'Estimated total monetary value of all commodities in this distribution order, expressed in US dollars. Used for financial tracking and donor reporting.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inKindDonationFlag rdf:type rdf:Property ;
    rdfs:label 'In Kind Donation Flag' ;
    rdfs:comment 'Indicates whether commodities in this order were received as in-kind donations rather than purchased. Affects valuation and donor acknowledgment processes.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalSuppliesFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Supplies Flag' ;
    rdfs:comment 'Indicates whether this distribution order contains medical supplies or pharmaceuticals. Triggers special handling and regulatory compliance requirements.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nfiFlag rdf:type rdf:Property ;
    rdfs:label 'Nfi Flag' ;
    rdfs:comment 'Indicates whether this distribution order contains Non-Food Items such as shelter materials, hygiene kits, or household supplies. Used for commodity classification.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Date when the distribution order was created and entered into the system. Business event timestamp for order initiation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Human-readable unique order number assigned to this distribution order for tracking and reference purposes. Format: DO-YYYYMMDD-sequence.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the distribution order. Tracks progression from draft through approval, dispatch, transit, delivery, and closure. [ENUM-REF-CANDIDATE: draft|approved|dispatched|in_transit|delivered|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Planned date for delivery of commodities to the destination distribution point. Used for logistics planning and beneficiary communication.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialHandlingRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Handling Requirements' ;
    rdfs:comment 'Specific handling requirements for commodities in this order, such as fragile items, hazardous materials, or temperature-sensitive goods. Ensures proper care during transport.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCommodityLines rdf:type rdf:Property ;
    rdfs:label 'Total Commodity Lines' ;
    rdfs:comment 'Total number of distinct commodity line items included in this distribution order. Summary count for order complexity assessment.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'Aggregate quantity of all commodities in this distribution order, expressed in standard units. Summary measure for order volume.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'Total volume of all commodities in this distribution order, measured in cubic meters. Used for warehouse space and transport capacity planning.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total weight of all commodities in this distribution order, measured in kilograms. Used for transport planning and capacity management.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportCostUsd rdf:type rdf:Property ;
    rdfs:label 'Transport Cost Usd' ;
    rdfs:comment 'Actual or estimated cost of transporting commodities from warehouse to distribution point, expressed in US dollars. Used for budget tracking and cost analysis.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Primary mode of transportation used for dispatching commodities from warehouse to distribution point. Critical for logistics planning and cost allocation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleRegistration rdf:type rdf:Property ;
    rdfs:label 'Vehicle Registration' ;
    rdfs:comment 'Registration number or identifier of the vehicle used for transporting commodities. Used for fleet management and security tracking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waybillReference rdf:type rdf:Property ;
    rdfs:label 'Waybill Reference' ;
    rdfs:comment 'Reference number of the transport waybill or shipping document accompanying the commodity shipment. Used for tracking and proof of dispatch.' ;
    rdfs:domain ind:DistributionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Planning System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Distribution plans are created in logistics/program management platforms. System tracking supports data lineage for donor reporting, integration monitoring between supply and program systems, and plat' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:coordinationCluster rdf:type rdf:Property ;
    rdfs:label 'Coordination Cluster' ;
    rdfs:comment 'Humanitarian cluster or sector coordinating this distribution (e.g., Food Security, WASH, Shelter, Health, Protection).' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionDurationDays rdf:type rdf:Property ;
    rdfs:label 'Distribution Duration Days' ;
    rdfs:comment 'Planned duration in days for the distribution activities to be completed.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Distribution Frequency' ;
    rdfs:comment 'Planned frequency of distribution events under this plan (one-time, recurring weekly, monthly, etc.).' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Budget Amount' ;
    rdfs:comment 'Estimated total budget allocated for this distribution plan including commodity costs, logistics, and operational expenses.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTotalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Volume M3' ;
    rdfs:comment 'Estimated total volume in cubic meters of all commodities to be distributed under this plan.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTotalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Weight Kg' ;
    rdfs:comment 'Estimated total weight in kilograms of all commodities to be distributed under this plan.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicCoverageAdmin1 rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Admin1' ;
    rdfs:comment 'First-level administrative division (province, state, region) where distribution will occur.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageAdmin2 rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Admin2' ;
    rdfs:comment 'Second-level administrative division (district, county) where distribution will occur.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageAdmin3 rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Admin3' ;
    rdfs:comment 'Third-level administrative division (sub-district, municipality) where distribution will occur.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageCountry rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Country' ;
    rdfs:comment 'Three-letter ISO country code where the distribution will take place.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melIndicatorAlignment rdf:type rdf:Property ;
    rdfs:label 'Mel Indicator Alignment' ;
    rdfs:comment 'Key MEL indicators or KPIs (Key Performance Indicators) that this distribution plan contributes to achieving.' ;
    rdfs:domain ind:DistributionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Required' ;
    rdfs:comment 'Indicates whether security clearance or authorization is required before distribution can proceed in the target area.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetHouseholdCount rdf:type rdf:Property ;
    rdfs:label 'Target Household Count' ;
    rdfs:comment 'Planned number of households to receive assistance under this distribution plan.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frameworkAgreementId rdf:type rdf:Property ;
    rdfs:label 'Framework Agreement Id' ;
    rdfs:comment 'Unique identifier for the framework agreement record. Primary key.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FrameworkAgreement .

ind:contractSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Contract System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Framework agreements are managed in contract management systems. System tracking supports compliance audits, contract lifecycle visibility, and integration with procurement platforms for call-off orde' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:primaryFrameworkStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Framework Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or procurement officer responsible for managing this framework agreement and approving call-off orders.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:primaryFrameworkUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Framework User Account Id' ;
    rdfs:comment 'Reference to the user who created this framework agreement record in the system. Audit trail field.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:agreementTitle rdf:type rdf:Property ;
    rdfs:label 'Agreement Title' ;
    rdfs:comment 'Descriptive title or name of the framework agreement, typically indicating the commodity categories or services covered.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callOffMechanism rdf:type rdf:Property ;
    rdfs:label 'Call Off Mechanism' ;
    rdfs:comment 'Agreed method or process for placing call-off orders against this framework agreement (e.g., formal purchase order, email request, vendor portal).' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCategories rdf:type rdf:Property ;
    rdfs:label 'Commodity Categories' ;
    rdfs:comment 'Comma-separated list of commodity categories or Non-Food Item (NFI) types covered under this framework agreement (e.g., Shelter Materials, WASH Supplies, Medical Supplies, Emergency Relief Commodities).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'Standard delivery lead time in days from call-off order placement to delivery at destination, as agreed in the framework contract. Critical for emergency response planning.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Pre-negotiated discount percentage off vendor catalog prices, if applicable. Null if pricing structure is not discount-based.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyDeliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Emergency Delivery Lead Time Days' ;
    rdfs:comment 'Expedited delivery lead time in days for emergency call-off orders, typically 24-72 hours for humanitarian rapid-response procurement.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'Standard Incoterm defining the division of costs and risks between vendor and buyer for delivery under this framework agreement. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum quantity per single call-off order as stipulated in the framework agreement. Null if no maximum applies.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Value' ;
    rdfs:comment 'Maximum cumulative monetary value of all call-off orders that can be placed against this framework agreement over its validity period. Null if no ceiling applies.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingStructure rdf:type rdf:Property ;
    rdfs:label 'Pricing Structure' ;
    rdfs:comment 'Agreed pricing or discount structure mechanism for commodities under this framework agreement. Determines how unit costs are calculated for call-off orders.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStandards rdf:type rdf:Property ;
    rdfs:label 'Quality Standards' ;
    rdfs:comment 'Quality certification or compliance standards required for commodities supplied under this framework agreement (e.g., ISO 9001, GMP, Sphere-compliant, WHO Prequalification).' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOptionCount rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Count' ;
    rdfs:comment 'Number of renewal periods available under the framework agreement terms. Null if no renewal options exist.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Conditions and process for renewing or extending the framework agreement beyond the initial validity period. May include automatic renewal clauses or renegotiation requirements.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soleSourceJustification rdf:type rdf:Property ;
    rdfs:label 'Sole Source Justification' ;
    rdfs:comment 'Documentation and rationale for sole-source or limited-competition procurement if this framework agreement was not established through full competitive bidding. Required for 2 CFR 200 compliance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Conditions under which either party may terminate the framework agreement prior to the effective end date (e.g., for cause, for convenience, notice period requirements).' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrdersPlaced rdf:type rdf:Property ;
    rdfs:label 'Total Orders Placed' ;
    rdfs:comment 'Cumulative count of call-off purchase orders placed against this framework agreement since effective start date. Used for utilization tracking.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalValueUtilized rdf:type rdf:Property ;
    rdfs:label 'Total Value Utilized' ;
    rdfs:comment 'Cumulative monetary value of all call-off orders placed against this framework agreement. Tracked against maximum order value ceiling.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Reference to the inbound shipment or logistics movement that delivered these goods.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:waybillId rdf:type rdf:Property ;
    rdfs:label 'Waybill Id' ;
    rdfs:comment 'Foreign key linking to supply.waybill. Business justification: Goods receipts are recorded when commodities arrive at a warehouse. The waybill is the shipping document that accompanies the delivery. The goods_receipt table has delivery_note_number (STRING) which ' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Waybill .

ind:conditionOnArrival rdf:type rdf:Property ;
    rdfs:label 'Condition On Arrival' ;
    rdfs:comment 'Assessment of the physical condition of the goods upon receipt. Good indicates acceptable condition, damaged indicates physical damage, expired indicates past expiry date, partial_damage indicates some units damaged, quality_issue indicates substandard quality.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Date' ;
    rdfs:comment 'Date on which the goods cleared customs and were released for delivery to the warehouse or field location.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsCleared rdf:type rdf:Property ;
    rdfs:label 'Customs Cleared' ;
    rdfs:comment 'Indicates whether the goods have cleared customs and import formalities. True if cleared, False if pending customs clearance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicates whether there was a discrepancy between ordered and received quantities or condition. True if discrepancy exists, False if receipt matches order exactly.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Detailed notes explaining any discrepancies in quantity, quality, or condition between what was ordered and what was received. Includes reasons for rejection or partial acceptance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCharges rdf:type rdf:Property ;
    rdfs:label 'Freight Charges' ;
    rdfs:comment 'Transportation and freight costs associated with this goods receipt, if separately tracked.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Indicates whether the received goods require formal quality inspection before being released to inventory. True for medical supplies, food items, and high-value commodities.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Status of the quality inspection process. Pending indicates inspection not yet completed, passed indicates goods approved for use, failed indicates goods rejected, waived indicates inspection was not required.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Supplier or donor lot number for the received commodity, used for tracking and quality control purposes.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'Date on which the commodity was manufactured, used to calculate shelf life and ensure quality standards.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'The quantity of the commodity that was originally ordered on the purchase order or expected from the donation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'The actual quantity of the commodity physically received and accepted at the warehouse or field location.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRejected rdf:type rdf:Property ;
    rdfs:label 'Quantity Rejected' ;
    rdfs:comment 'The quantity of the commodity that was rejected upon receipt due to damage, expiry, or quality issues.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Precise date and time when the goods receipt was recorded in the system, including time zone information.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Unique serial number for individually tracked items such as medical equipment, vehicles, or high-value assets.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Specific storage location or bin within the warehouse where the received goods were placed. Used for precise inventory tracking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Total cost of the goods received, calculated as quantity received multiplied by unit cost. Used for accounts payable and budget tracking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Receiving Warehouse Id' ;
    rdfs:comment 'Reference to the warehouse or storage facility where the in-kind donation was received and is currently stored.' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:batchLotNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Lot Number' ;
    rdfs:comment 'Manufacturer batch or lot number for the donated commodity, used for quality control, recall management, and traceability.' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Status' ;
    rdfs:comment 'Physical condition of the donated commodity at receipt: new, good, fair, damaged, or expired. Critical for distribution planning and beneficiary safety.' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Status' ;
    rdfs:comment 'Status of customs clearance for the in-kind donation: pending, cleared, held for inspection, released, or exempted from duties.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Donation Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this in-kind donation for tracking and acknowledgment purposes.' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorRestrictions rdf:type rdf:Property ;
    rdfs:label 'Donor Restrictions' ;
    rdfs:comment 'Any restrictions or conditions imposed by the donor on the use, distribution, or geographic allocation of the in-kind donation. Critical for compliance with donor intent.' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorType rdf:type rdf:Property ;
    rdfs:label 'Donor Type' ;
    rdfs:comment 'Classification of the donor providing the in-kind donation: individual, corporate partner, government agency, foundation, multilateral organization, bilateral agency, or Civil Society Organization (CSO). [ENUM-REF-CANDIDATE: individual|corporate|government|foundation|multilateral|bilateral|cso — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFairMarketValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Fair Market Value' ;
    rdfs:comment 'Estimated fair market value of the in-kind donation in the reporting currency, used for non-cash contribution accounting per FASB ASC 958 and donor stewardship reporting.' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iatiReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Iati Reporting Flag' ;
    rdfs:comment 'Boolean indicator whether this in-kind donation must be reported to the International Aid Transparency Initiative (IATI) for transparency and accountability (True = reportable, False = not reportable).' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Date' ;
    rdfs:comment 'Date the quality inspection was performed on the in-kind donation to verify condition and compliance with standards.' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Flag' ;
    rdfs:comment 'Boolean indicator whether the in-kind donation underwent quality inspection upon receipt (True = inspected, False = not inspected).' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Result' ;
    rdfs:comment 'Result of the quality inspection: passed (acceptable for distribution), failed (rejected), conditional (usable with restrictions), or not inspected.' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the in-kind donation was received.' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingLocationName rdf:type rdf:Property ;
    rdfs:label 'Receiving Location Name' ;
    rdfs:comment 'Name of the warehouse, field office, or storage location where the in-kind donation was received.' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedUseFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Use Flag' ;
    rdfs:comment 'Boolean indicator whether the in-kind donation has donor-imposed restrictions on its use or distribution (True = restricted, False = unrestricted).' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentOriginCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipment Origin Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code from which the in-kind donation was shipped.' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDeductibleFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Deductible Flag' ;
    rdfs:comment 'Boolean indicator whether this in-kind donation qualifies for tax deduction by the donor under applicable tax regulations (True = deductible, False = not deductible).' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated fair market value (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:InkindDonation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryBalanceId rdf:type rdf:Property ;
    rdfs:label 'Inventory Balance Id' ;
    rdfs:comment 'Unique identifier for the inventory balance record. Primary key for this entity.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'Date of the most recent inventory transaction (receipt, issue, transfer, or adjustment) for this balance record. Used for aging analysis and pipeline monitoring.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or cycle count for this commodity at this warehouse. Used for inventory accuracy tracking and audit compliance.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'Maximum stock capacity or target level for this commodity at this warehouse. Used for inventory optimization and storage planning.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipelineStatus rdf:type rdf:Property ;
    rdfs:label 'Pipeline Status' ;
    rdfs:comment 'Current status of the inventory balance in the commodity pipeline. Used for OCHA cluster reporting and pipeline gap analysis.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Net quantity available for new distribution allocations. Calculated as quantity_on_hand minus quantity_reserved minus quantity_quarantined.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityInTransit rdf:type rdf:Property ;
    rdfs:label 'Quantity In Transit' ;
    rdfs:comment 'Quantity currently in transit to this warehouse from suppliers or other warehouses. Not yet available for distribution.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current physical stock quantity available in the warehouse. Represents the total inventory balance at the snapshot date.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityQuarantined rdf:type rdf:Property ;
    rdfs:label 'Quantity Quarantined' ;
    rdfs:comment 'Quantity held in quarantine due to quality issues, expiration concerns, or pending inspection. Not available for distribution.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Quantity allocated or reserved for planned distribution events but not yet dispatched. Reduces available stock for new allocations.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderLevel rdf:type rdf:Property ;
    rdfs:label 'Reorder Level' ;
    rdfs:comment 'Minimum stock level threshold that triggers a replenishment order. Used for pipeline management and pre-positioning decisions.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'Date for which this inventory balance snapshot is recorded. Supports historical trend analysis and time-series reporting.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Required storage condition for the commodity. Used for warehouse capacity planning and quality assurance.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValuation rdf:type rdf:Property ;
    rdfs:label 'Total Valuation' ;
    rdfs:comment 'Total monetary value of the inventory balance. Calculated as quantity_on_hand multiplied by unit_cost. Used for financial statements and donor reporting.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseLocation rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location' ;
    rdfs:comment 'Geographic location of the warehouse including city, region, or country. Used for logistics planning and SitRep reporting.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementRequestId rdf:type rdf:Property ;
    rdfs:label 'Procurement Request Id' ;
    rdfs:comment 'Unique identifier for the procurement request. Primary key for this entity.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementRequest .

ind:preferredVendorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Id' ;
    rdfs:comment 'Identifier of a preferred or pre-qualified vendor for this procurement, if applicable. May be based on prior performance, framework agreements, or emergency response partnerships.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:primaryProcurementUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Procurement User Account Id' ;
    rdfs:comment 'Identifier of the user (staff member) who provided final approval for this procurement request. Links to workforce or user management system.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:requestingOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Requesting Org Unit Id' ;
    rdfs:comment 'Identifier of the organizational unit (country office, program unit, or field team) that raised this procurement request.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:requestingProjectSiteId rdf:type rdf:Property ;
    rdfs:label 'Requesting Project Site Id' ;
    rdfs:comment 'Identifier of the specific field project site or location where the procured items or services will be delivered or utilized.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectSite .

ind:tertiaryProcurementLastModifiedByUserUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Procurement Last Modified By User User Account Id' ;
    rdfs:comment 'Identifier of the user who last modified this procurement request record. Used for audit trail and accountability.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:approvalLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Level Required' ;
    rdfs:comment 'Highest approval authority level required for this procurement request based on value thresholds and organizational delegation of authority: team lead, program manager, country director, regional director, headquarters procurement, Chief Financial Officer (CFO), or Chief Executive Officer (CEO). [ENUM-REF-CANDIDATE: team_lead|program_manager|country_director|regional_director|hq_procurement|cfo|ceo — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Required' ;
    rdfs:comment 'Boolean flag indicating whether this procurement requires additional compliance checks such as sanctions screening, export control review, or anti-terrorism financing verification. True if compliance check is required, false otherwise.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryAddress rdf:type rdf:Property ;
    rdfs:label 'Delivery Address' ;
    rdfs:comment 'Full text address for delivery if the delivery location is not a standard warehouse or registered site. Includes street, city, region, and country details.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Cost' ;
    rdfs:comment 'Total estimated cost for the entire procurement request, calculated as quantity requested multiplied by estimated unit cost. May include additional costs such as shipping or taxes.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Cost' ;
    rdfs:comment 'Estimated cost per unit of the requested item or service. Used for budget planning and approval thresholds.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localProcurementPreference rdf:type rdf:Property ;
    rdfs:label 'Local Procurement Preference' ;
    rdfs:comment 'Boolean flag indicating whether this procurement should prioritize local or in-country vendors to support local economies and reduce lead times. True if local preference applies, false otherwise.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Numeric quantity of the item or service being requested. May represent units, volume, weight, or service hours depending on the request type.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the procurement request by the nature of what is being requested: goods, services, works, consultancy, Non-Food Items (NFI), medical supplies, equipment, vehicle, or construction. [ENUM-REF-CANDIDATE: goods|services|works|consultancy|nfi|medical_supplies|equipment|vehicle|construction — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the requested items or services must be delivered to the requesting location. Critical for supply chain planning and program delivery timelines.' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Externally visible unique requisition number assigned to this procurement request. Used for tracking and reference across systems and communications.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Classification of the urgency of this procurement request: routine (standard lead time), urgent (expedited processing), emergency (immediate need), or life-saving (critical humanitarian response).' ;
    rdfs:domain ind:ProcurementRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPurchaseUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase User Account Id' ;
    rdfs:comment 'Reference to the staff member who provided final approval for this purchase order. Used for audit trail and accountability per RACI (Responsible Accountable Consulted Informed) framework.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'Foreign key linking to supply.rfq. Business justification: Purchase orders are issued after RFQ evaluation and vendor award. This FK links the PO to the competitive bidding process that preceded it. Standard procurement workflow: procurement_request → rfq → p' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfq .

ind:tertiaryPurchaseModifiedByUserUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Purchase Modified By User User Account Id' ;
    rdfs:comment 'Reference to the staff member who last modified this purchase order record. Used for accountability and audit trail.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:approvalWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Status' ;
    rdfs:comment 'Current status of the purchase order in the multi-level approval workflow. Tracks progression through procurement authority levels per delegation of authority matrix.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Flag' ;
    rdfs:comment 'Indicates whether this purchase order was issued under emergency procurement procedures due to humanitarian crisis or disaster response. Allows expedited approval and relaxed competitive bidding requirements per CERF (Central Emergency Response Fund) guidelines.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erpDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Erp Document Reference' ;
    rdfs:comment 'Reference number or document ID from the source ERP system (SAP S/4HANA, Unit4, etc.). Used for system integration, reconciliation, and audit trail back to operational system of record.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Vendor-committed delivery date as agreed in the purchase order. Used for goods receipt scheduling and vendor performance measurement.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Total freight, shipping, and logistics charges for delivery of commodities. Critical for last-mile logistics cost tracking.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Status' ;
    rdfs:comment 'Aggregate status of goods receipt across all purchase order line items. Used for three-way matching (PO-GRN-Invoice) and inventory management.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceMatchingStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Matching Status' ;
    rdfs:comment 'Status of three-way matching between purchase order, goods receipt note, and vendor invoice. Critical for accounts payable processing and financial control per 2 CFR 200.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'Date when the purchase order was officially issued to the vendor. Principal business event timestamp for procurement tracking and lead time calculation.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known unique purchase order document number issued to vendor. Business identifier used in procurement communications and three-way matching (PO-GRN-Invoice).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order in the procurement workflow. Tracks progression from draft through approval, issuance, goods receipt, and closure. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|issued|partially_received|fully_received|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order type: standard (one-time procurement), blanket (recurring deliveries), contract (long-term agreement), emergency (urgent humanitarian response), framework (pre-negotiated terms).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementMethod rdf:type rdf:Property ;
    rdfs:label 'Procurement Method' ;
    rdfs:comment 'Method used to select the vendor: competitive bidding, request for quotation (RFQ), sole source justification, framework agreement, or emergency procurement waiver. Required for donor compliance and audit trail per 2 CFR 200.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Date by which the requesting program needs the commodities delivered. Used for procurement lead time planning and emergency response timeline tracking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Sum of all line item amounts before taxes, duties, and freight charges. Base procurement value for budget tracking.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Grand total value of the purchase order including subtotal, taxes, freight, and all other charges. Used for budget commitment and three-way matching.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfqApprovalAuthorityStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Rfq Approval Authority Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or committee with authority to approve the award decision, based on procurement threshold policies.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:rfqStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Rfq Staff Member Id' ;
    rdfs:comment 'Reference to the staff member responsible for managing this RFQ process.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date when the contract or purchase order was officially awarded to the winning vendor.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardedAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Amount' ;
    rdfs:comment 'Total contract value awarded to the winning vendor, in the currency specified by currency_code.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidOpeningDate rdf:type rdf:Property ;
    rdfs:label 'Bid Opening Date' ;
    rdfs:comment 'Scheduled date and time when submitted bids will be opened, typically in the presence of authorized personnel or bidders.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clarificationDeadline rdf:type rdf:Property ;
    rdfs:label 'Clarification Deadline' ;
    rdfs:comment 'Date and time by which vendors may submit questions or requests for clarification regarding the RFQ specifications.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryDeadline rdf:type rdf:Property ;
    rdfs:label 'Delivery Deadline' ;
    rdfs:comment 'Required date by which goods must be delivered or services completed. Critical for emergency response and program timelines.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Destination address or site where goods must be delivered or services performed (warehouse, project site, country office).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyProcurement rdf:type rdf:Property ;
    rdfs:label 'Emergency Procurement' ;
    rdfs:comment 'Indicates whether this RFQ was issued under emergency procurement procedures, allowing expedited timelines and simplified processes.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evaluationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Completion Date' ;
    rdfs:comment 'Date when the bid evaluation process was completed and final scoring/ranking was determined.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'Documented criteria and weighting used to evaluate and score vendor bids (e.g., price 40%, technical quality 30%, delivery time 20%, past performance 10%).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invitedVendorCount rdf:type rdf:Property ;
    rdfs:label 'Invited Vendor Count' ;
    rdfs:comment 'Number of vendors invited to submit quotations for this RFQ. Relevant for restricted tenders and competitive bidding documentation.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumQualificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Minimum Qualification Requirements' ;
    rdfs:comment 'Mandatory qualifications vendors must meet to be eligible (e.g., certifications, licenses, financial capacity, prior experience, quality standards compliance).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Category of procurement: goods (commodities, equipment), services (professional services), works (construction), consultancy, NFI (Non-Food Items), or medical supplies.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedUrl rdf:type rdf:Property ;
    rdfs:label 'Published Url' ;
    rdfs:comment 'Web address where the RFQ documentation is publicly posted, supporting transparency and open competitive bidding.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedBidCount rdf:type rdf:Property ;
    rdfs:label 'Received Bid Count' ;
    rdfs:comment 'Number of valid bids or quotations received by the submission deadline.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsiveBidCount rdf:type rdf:Property ;
    rdfs:label 'Responsive Bid Count' ;
    rdfs:comment 'Number of bids that met all mandatory requirements and were deemed responsive for evaluation.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Externally-known unique business identifier for the RFQ, typically following organizational numbering convention (e.g., RFQ-USA-2024-00123).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle status of the RFQ: draft (being prepared), open (accepting bids), closed (submission deadline passed), under evaluation (bids being reviewed), awarded (vendor selected), or cancelled.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'Date and time by which vendor quotations or bids must be submitted. No late submissions accepted after this timestamp.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trackingSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Tracking System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Shipments are tracked in TMS/logistics platforms. System reference enables integration health monitoring, data quality assessments, and troubleshooting shipment visibility issues critical for emergenc' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Actual date when the shipment arrived at the destination port or warehouse, as confirmed by receiving personnel.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Date' ;
    rdfs:comment 'Actual date when the shipment departed from the origin port or warehouse, as confirmed by the carrier or freight forwarder.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Bill of Lading number for sea freight or Airway Bill number for air freight, serving as the legal document of title and receipt for the cargo.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Reference Number' ;
    rdfs:comment 'Carrier-assigned tracking number or booking reference for the shipment.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'ISO container number for sea freight (e.g., ABCD1234567) or vehicle registration/truck number for road transport.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Type of container or vehicle used: 20ft or 40ft standard containers, 40ft high cube for volume cargo, refrigerated for cold chain medical supplies, open top or flat rack for oversized items, truck for road transport, or aircraft for air freight. [ENUM-REF-CANDIDATE: 20ft_standard|40ft_standard|40ft_high_cube|refrigerated|open_top|flat_rack|truck|aircraft — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerName rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Name' ;
    rdfs:comment 'Name of the licensed customs broker or clearing agent engaged to facilitate customs clearance and import documentation in the destination country.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the shipment destination country (e.g., SYR, YEM, SDN for field operations).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationName rdf:type rdf:Property ;
    rdfs:label 'Destination Location Name' ;
    rdfs:comment 'Human-readable name of the final destination warehouse, project site, or distribution point for the shipment.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPortCode rdf:type rdf:Property ;
    rdfs:label 'Destination Port Code' ;
    rdfs:comment 'UN/LOCODE or IATA code for the arrival port (sea) or airport (air) where the shipment enters the destination country.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyExemptionReference rdf:type rdf:Property ;
    rdfs:label 'Duty Exemption Reference' ;
    rdfs:comment 'Reference number or letter from host government granting duty and tax exemption for humanitarian relief goods under bilateral agreements or United Nations privileges.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'Planned or estimated date when the shipment is expected to arrive at the destination port or warehouse.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Departure Date' ;
    rdfs:comment 'Planned or estimated date when the shipment is scheduled to depart from the origin port or warehouse.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCostUsd rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Usd' ;
    rdfs:comment 'Total freight transportation cost in United States Dollars, including carrier charges, fuel surcharges, and handling fees.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'UN hazardous materials classification code (e.g., UN1170 for ethanol, UN3373 for biological substances) if the shipment contains dangerous goods requiring special handling and documentation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Import Permit Number' ;
    rdfs:comment 'Government-issued import permit or license number required for controlled goods such as medical supplies, pharmaceuticals, or telecommunications equipment.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Insurance policy number covering the shipment cargo against loss, damage, or theft during transit.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuredValueUsd rdf:type rdf:Property ;
    rdfs:label 'Insured Value Usd' ;
    rdfs:comment 'Declared value of the shipment cargo in United States Dollars for insurance purposes, representing the replacement cost of the goods.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfCartons rdf:type rdf:Property ;
    rdfs:label 'Number Of Cartons' ;
    rdfs:comment 'Total count of individual cartons, boxes, or packages in the shipment, used for inventory reconciliation and distribution planning.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfPallets rdf:type rdf:Property ;
    rdfs:label 'Number Of Pallets' ;
    rdfs:comment 'Total count of pallets or skids in the shipment, used for warehouse handling and loading dock planning.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originLocationName rdf:type rdf:Property ;
    rdfs:label 'Origin Location Name' ;
    rdfs:comment 'Human-readable name of the origin location, warehouse, or facility from which the shipment departs.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPortCode rdf:type rdf:Property ;
    rdfs:label 'Origin Port Code' ;
    rdfs:comment 'UN/LOCODE or IATA code for the departure port (sea) or airport (air) from which the shipment originates.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phytosanitaryCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Phytosanitary Certificate Number' ;
    rdfs:comment 'Certificate number issued by the origin country plant protection authority for shipments containing agricultural products, seeds, or wooden packaging materials, certifying compliance with international phytosanitary standards.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment: planned for pipeline forecasting, booked with carrier, in transit en route, customs clearance awaiting documentation, cleared and released, delivered to final destination, or cancelled. [ENUM-REF-CANDIDATE: planned|booked|in_transit|customs_clearance|cleared|delivered|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classification of the shipment purpose: emergency relief for rapid response, pre-positioned stock for contingency warehouses, program supply for ongoing operations, in-kind donation from corporate or government donors, medical supply for health programs, or Non-Food Item (NFI) consignment for shelter and household goods.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Indicates whether the shipment requires temperature-controlled transport (cold chain) for medical supplies, vaccines, or perishable goods.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureRangeMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max C' ;
    rdfs:comment 'Maximum allowed temperature in Celsius for temperature-controlled shipments, ensuring cold chain integrity for vaccines and medical supplies.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min C' ;
    rdfs:comment 'Minimum required temperature in Celsius for temperature-controlled shipments, ensuring cold chain integrity for vaccines and medical supplies.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCargoVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Cargo Volume M3' ;
    rdfs:comment 'Total volume of the shipment cargo in cubic meters, used for warehouse space planning and freight costing for volumetric shipments.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCargoWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Cargo Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment cargo in kilograms, including packaging and pallets, used for freight costing and capacity planning.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Unique identifier for the stock movement transaction record. Primary key for the stock movement log.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryStockUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock User Account Id' ;
    rdfs:comment 'Identifier of the system user who created this stock movement record. Part of audit trail for accountability and compliance.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:sourceWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Source Warehouse Id' ;
    rdfs:comment 'Foreign key linking to supply.warehouse. Business justification: Stock movements track inventory transfers between warehouses or within a warehouse. The source_location_id (BIGINT) currently holds the origin warehouse reference. Renaming to source_warehouse_id and ' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:authorizingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Authorizing Officer Name' ;
    rdfs:comment 'Full name of the staff member who authorized this stock movement. Denormalized for reporting and audit trail readability.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countTeamReference rdf:type rdf:Property ;
    rdfs:label 'Count Team Reference' ;
    rdfs:comment 'Reference identifier for the physical inventory count team or cycle that generated this movement record (applicable only for movement_type = physical_count). Links to physical inventory count documentation.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Donor Restriction Code' ;
    rdfs:comment 'Classification of donor-imposed restrictions on the use of this commodity. Unrestricted = no limitations; Geographic_restricted = specific country/region only; Program_restricted = specific program use only; Beneficiary_restricted = specific beneficiary population only; Time_restricted = must be distributed within donor-specified timeframe. Critical for compliance with donor agreements.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Date on which quality inspection was performed on the commodity. Null if inspection was not required or waived.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Name of the staff member or third-party inspector who performed the quality inspection. Null if inspection was not required or waived.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementDate rdf:type rdf:Property ;
    rdfs:label 'Movement Date' ;
    rdfs:comment 'Business date on which the stock movement occurred or is scheduled to occur. This is the operational event date, distinct from system audit timestamps.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:movementNumber rdf:type rdf:Property ;
    rdfs:label 'Movement Number' ;
    rdfs:comment 'Externally-known unique reference number for this stock movement transaction, used for audit trail and cross-system reconciliation. Format typically includes movement type prefix and sequential number.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of the stock movement transaction. Tracks workflow state from initiation through completion or cancellation. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|in_transit|completed|cancelled|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Timestamp' ;
    rdfs:comment 'Precise date and time when the physical stock movement was executed or recorded. Used for detailed audit trail and sequence reconstruction.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'Classification of the stock movement transaction. Receipt = goods received into warehouse; Issue = goods distributed/issued out; Transfer = movement between warehouses; Adjustment = correction entry; Physical_count = reconciliation from physical inventory count; Loss = documented loss/damage; Write_off = removal from inventory due to expiry/obsolescence. [ENUM-REF-CANDIDATE: receipt|issue|transfer|adjustment|physical_count|loss|write_off — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Purchase order number associated with this receipt transaction. Links stock movement to procurement documentation for donor reporting and financial reconciliation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Result of quality inspection performed on the commodity at the time of receipt or movement. Pending = inspection not yet completed; Passed = meets quality standards; Failed = rejected; Waived = inspection requirement waived for emergency; Not_required = commodity type does not require inspection.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code explaining the business reason for the stock movement. Critical for loss analysis, donor reporting, and pipeline management. Normal_receipt = routine procurement; Emergency_receipt = rapid response; Beneficiary_distribution = direct aid delivery; Program_issue = program consumption; Inter_warehouse_transfer = logistics optimization; Count_adjustment = inventory reconciliation; Expiry/Damage/Theft/Loss_in_transit/Obsolescence = loss categories. [ENUM-REF-CANDIDATE: normal_receipt|emergency_receipt|beneficiary_distribution|program_issue|inter_warehouse_transfer|count_adjustment|expiry|damage|theft|loss_in_transit|obsolescence — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text detailed explanation of the reason for the stock movement, especially for adjustments, losses, and write-offs. Provides context beyond the standardized reason code.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of source document that authorizes or records this stock movement. GRN = Goods Received Note; Waybill = transport document; Distribution_order = beneficiary distribution plan; Count_sheet = physical inventory count; Adjustment_memo = correction authorization; Loss_report = documented loss/damage; Write_off_authorization = disposal approval. [ENUM-REF-CANDIDATE: GRN|waybill|distribution_order|count_sheet|adjustment_memo|loss_report|write_off_authorization — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking number for the shipment associated with this stock movement. Enables real-time visibility of in-transit commodities.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierPortalSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Supplier Portal System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Vendors access e-procurement portals for RFQ responses, bid submissions, and PO acknowledgments. Tracking the platform enables audit trails for vendor interactions, access provisioning, and compliance' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:bankSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Bank Swift Code' ;
    rdfs:comment 'SWIFT/BIC code of the vendor\'s bank, used for international wire transfers and cross-border payments.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blacklistEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Blacklist Effective Date' ;
    rdfs:comment 'The date when the vendor blacklist or debarment status became effective.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blacklistExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Blacklist Expiry Date' ;
    rdfs:comment 'The date when the vendor blacklist or debarment status expires, after which the vendor may be eligible for reinstatement (nullable for permanent debarments).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blacklistFlag rdf:type rdf:Property ;
    rdfs:label 'Blacklist Flag' ;
    rdfs:comment 'Boolean indicator (True/False) showing whether the vendor is currently blacklisted or debarred from humanitarian procurement due to fraud, corruption, poor performance, or ethical violations.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfOperation rdf:type rdf:Property ;
    rdfs:label 'Country Of Operation' ;
    rdfs:comment 'Primary country where the vendor operates or is registered, using ISO 3166-1 alpha-3 country code (e.g., USA, GBR, KEN).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetSize rdf:type rdf:Property ;
    rdfs:label 'Fleet Size' ;
    rdfs:comment 'Number of vehicles or transport units in the vendor\'s fleet (applicable for transport and logistics providers). Indicates capacity for humanitarian logistics operations.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Flag' ;
    rdfs:comment 'Boolean indicator (True/False) showing whether the vendor holds Good Manufacturing Practice (GMP) certification, required for pharmaceutical and medical supply vendors.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:humanitarianNetworkMembership rdf:type rdf:Property ;
    rdfs:label 'Humanitarian Network Membership' ;
    rdfs:comment 'Comma-separated list of humanitarian logistics networks or consortia the vendor is a member of, such as WFP Logistics Hub Framework (LHF), UNHRD (UN Humanitarian Response Depot), or Logistics Cluster.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoCertification rdf:type rdf:Property ;
    rdfs:label 'Iso Certification' ;
    rdfs:comment 'Comma-separated list of ISO certifications held by the vendor, such as ISO 9001 (Quality Management), ISO 14001 (Environmental Management), or ISO 45001 (Occupational Health and Safety).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Last Performance Score' ;
    rdfs:comment 'The most recent performance score assigned to the vendor during the last performance review, typically on a scale of 0-100 or 0-5, measuring quality, delivery, compliance, and responsiveness.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Standard payment terms offered by the vendor, expressed as the number of days from invoice date to payment due date (e.g., 30, 60, 90 days).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Classification tier based on the vendor\'s historical performance, quality, delivery reliability, and compliance with humanitarian standards. Tier 1 represents preferred vendors with excellent track records.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prequalificationDate rdf:type rdf:Property ;
    rdfs:label 'Prequalification Date' ;
    rdfs:comment 'The date when the vendor successfully completed the prequalification process and was approved for humanitarian procurement.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prequalificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Prequalification Expiry Date' ;
    rdfs:comment 'The date when the vendor\'s prequalification status expires and requires renewal or reassessment.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prequalificationStatus rdf:type rdf:Property ;
    rdfs:label 'Prequalification Status' ;
    rdfs:comment 'Indicates whether the vendor has completed and passed the organization\'s prequalification process for humanitarian procurement, ensuring compliance with quality, ethical, and operational standards.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'The vendor\'s tax identification number (TIN), VAT number, or equivalent tax registration identifier issued by the country of operation.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportModesOffered rdf:type rdf:Property ;
    rdfs:label 'Transport Modes Offered' ;
    rdfs:comment 'Comma-separated list of transportation modes offered by the vendor (applicable for logistics and transport providers), such as air freight, sea freight, road transport, rail transport, or last-mile delivery.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unVendorNumber rdf:type rdf:Property ;
    rdfs:label 'Un Vendor Number' ;
    rdfs:comment 'The unique vendor registration number assigned by the United Nations Global Marketplace (UNGM) for vendors participating in UN procurement.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Internal unique alphanumeric code assigned to the vendor for procurement and supply chain operations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'The full legal name of the vendor, supplier, or service provider as registered with governing authorities.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current lifecycle status of the vendor in the procurement system, indicating whether the vendor is eligible for new contracts and purchase orders.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Classification of the vendor based on the primary service or product category they provide in the humanitarian supply chain. [ENUM-REF-CANDIDATE: commodity_supplier|manufacturer|freight_forwarder|clearing_agent|trucking_company|air_cargo_operator|last_mile_delivery_partner|warehouse_operator|service_provider|customs_broker|cold_chain_provider — promote to reference product]' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseCapacitySqm rdf:type rdf:Property ;
    rdfs:label 'Warehouse Capacity Sqm' ;
    rdfs:comment 'Total warehouse storage capacity in square meters available from the vendor (applicable for warehouse operators and logistics providers).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Manager Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Warehouses require designated managers for accountability, security clearance, inventory oversight, and operational decision-making. Nonprofit supply chain audits and donor compliance reports require ' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accessRestrictions rdf:type rdf:Property ;
    rdfs:label 'Access Restrictions' ;
    rdfs:comment 'Description of any access restrictions or special requirements for entering the warehouse facility.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line of the warehouse facility.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for additional location details such as building or unit number.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date when the warehouse facility was officially commissioned and became operational.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsBonded rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded' ;
    rdfs:comment 'Indicates whether the warehouse operates as a customs bonded facility allowing duty-free storage of international goods.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the warehouse facility was decommissioned and ceased operations, if applicable.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emergencyAccess247 rdf:type rdf:Property ;
    rdfs:label 'Emergency Access 24 7' ;
    rdfs:comment 'Indicates whether the warehouse can be accessed 24 hours a day, 7 days a week for emergency response operations.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the warehouse based on its role in the humanitarian supply network.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forkliftCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Forklift Capacity Kg' ;
    rdfs:comment 'Maximum lifting capacity of forklifts available at the warehouse, measured in kilograms.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gisAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Gis Accuracy Meters' ;
    rdfs:comment 'Accuracy of the GIS coordinates measured in meters, indicating the precision of the location data.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Indicates whether the warehouse is certified to store hazardous materials according to international standards.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent safety, security, or compliance inspection of the warehouse facility.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loadingDocksCount rdf:type rdf:Property ;
    rdfs:label 'Loading Docks Count' ;
    rdfs:comment 'Number of loading docks available at the warehouse for receiving and dispatching cargo.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managingEntity rdf:type rdf:Property ;
    rdfs:label 'Managing Entity' ;
    rdfs:comment 'Type of entity responsible for the day-to-day management and operation of the warehouse facility.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalHours rdf:type rdf:Property ;
    rdfs:label 'Operational Hours' ;
    rdfs:comment 'Standard operating hours of the warehouse facility including days and times of operation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership or usage arrangement for the warehouse facility.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity M3' ;
    rdfs:comment 'Total storage capacity of the warehouse measured in cubic meters (m³).' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCapacityPallets rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Pallets' ;
    rdfs:comment 'Total storage capacity of the warehouse measured in standard pallet positions.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warehouseCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code for the warehouse facility used in logistics documentation and tracking systems.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseName rdf:type rdf:Property ;
    rdfs:label 'Warehouse Name' ;
    rdfs:comment 'Official name of the warehouse facility as recognized by the organization and partners.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsSystemName rdf:type rdf:Property ;
    rdfs:label 'Wms System Name' ;
    rdfs:comment 'Name of the warehouse management system software used to track inventory and operations at this facility.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Origin Warehouse Id' ;
    rdfs:comment 'Reference to the warehouse from which the commodities were dispatched. Links to warehouse master data.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:arrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Arrival Timestamp' ;
    rdfs:comment 'Precise date and time when the vehicle arrived at the destination location. Used to calculate actual transit time and delivery performance.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Official customs declaration or clearance document number for cross-border shipments. Required for international humanitarian aid movements.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Departure Timestamp' ;
    rdfs:comment 'Precise date and time when the vehicle departed from the origin warehouse. Used for transit time analysis and security tracking.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discrepancyQuantity rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Quantity' ;
    rdfs:comment 'Difference between total dispatched and total received quantities. Positive values indicate shortages, negative values indicate overages.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Total distance in kilometers between origin and destination. Used for cost calculation and transit time estimation.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverContactNumber rdf:type rdf:Property ;
    rdfs:label 'Driver Contact Number' ;
    rdfs:comment 'Mobile phone number of the driver for real-time communication during transit. Essential for emergency contact and route coordination.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Driver License Number' ;
    rdfs:comment 'Official driver license number for verification and compliance purposes. Required for audit trails and security checks.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Planned or expected date of arrival at destination. Used for distribution planning and beneficiary communication.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Indicates whether cargo insurance is required for this shipment. True for high-value or high-risk shipments.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Receipt Signature Captured Flag' ;
    rdfs:comment 'Indicates whether a physical or digital signature was captured upon receipt. True if signature obtained, False otherwise.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedByName rdf:type rdf:Property ;
    rdfs:label 'Received By Name' ;
    rdfs:comment 'Full name of the person who received and signed for the shipment at destination. Critical for accountability and audit trail.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedByTitle rdf:type rdf:Property ;
    rdfs:label 'Received By Title' ;
    rdfs:comment 'Job title or role of the person who received the shipment. Provides context for authorization level and responsibility.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeDescription rdf:type rdf:Property ;
    rdfs:label 'Route Description' ;
    rdfs:comment 'Description of the planned transport route including major waypoints, checkpoints, or transit hubs. Important for security planning in conflict zones.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicates whether the security seal was intact upon arrival at destination. True if intact, False if broken or tampered.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Unique security seal number applied to the shipment container or vehicle to prevent tampering. Critical for loss prevention and donor audit compliance.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this shipment requires temperature-controlled transport (cold chain). True for medical supplies, vaccines, or perishable items.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum acceptable temperature in Celsius for temperature-controlled shipments. Exceedance may compromise commodity efficacy.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum acceptable temperature in Celsius for temperature-controlled shipments. Critical for cold chain compliance and commodity quality.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDispatchedQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Dispatched Quantity' ;
    rdfs:comment 'Aggregate quantity of all commodity items dispatched on this waybill. Sum of all line-item dispatched quantities.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReceivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Received Quantity' ;
    rdfs:comment 'Aggregate quantity of all commodity items received at destination. Used to calculate overall shipment discrepancy.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportCostAmount rdf:type rdf:Property ;
    rdfs:label 'Transport Cost Amount' ;
    rdfs:comment 'Total cost incurred for transporting this shipment. Includes carrier fees, fuel surcharges, and handling charges.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Transport Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the transport cost amount. Essential for multi-currency operations and financial reporting.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waybillNumber rdf:type rdf:Property ;
    rdfs:label 'Waybill Number' ;
    rdfs:comment 'Externally-known unique waybill document number used for tracking and reference by transporters, warehouses, and auditors. Typically follows organizational numbering convention.' ;
    rdfs:domain ind:Waybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessProvisioningId rdf:type rdf:Property ;
    rdfs:label 'Access Provisioning Id' ;
    rdfs:comment 'Unique identifier for the access provisioning transaction record.' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessRoleId rdf:type rdf:Property ;
    rdfs:label 'Access Role Id' ;
    rdfs:comment 'Foreign key linking to technology.access_role. Business justification: Access provisioning assigns specific RBAC roles to users. The access_role_assigned STRING field should be normalized to FK. N:1 relationship - many provisioning events assign one role. Core RBAC relat' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessRole .

ind:approverStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Approver Staff Member Id' ;
    rdfs:comment 'Identifier of the IT security officer, system owner, or authorized approver who reviewed and approved or rejected the access request.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:primaryAccessStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Access Staff Member Id' ;
    rdfs:comment 'Human Resources Information System (HRIS) employee or volunteer identifier for the target user, formatted as EMP-XXXXXX (employee), VOL-XXXXXX (volunteer), or CON-XXXXXX (consultant).' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:primaryAccessUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Access User Account Id' ;
    rdfs:comment 'Identifier of the staff member or system user who initiated the access provisioning request.' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:quaternaryAccessProvisionedByAdminStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Access Provisioned By Admin Staff Member Id' ;
    rdfs:comment 'Identifier of the IT system administrator or service desk technician who executed the access provisioning in the target system.' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:targetUserUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Target User User Account Id' ;
    rdfs:comment 'Identifier of the staff member or volunteer for whom access is being provisioned, modified, or revoked.' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:tertiaryAccessComplianceSignoffByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Access Compliance Signoff By Staff Member Id' ;
    rdfs:comment 'Identifier of the compliance officer or data protection officer who provided formal sign-off for this access provisioning.' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accessDurationDays rdf:type rdf:Property ;
    rdfs:label 'Access Duration Days' ;
    rdfs:comment 'Number of days the access is valid, calculated from effective start date to effective end date. Null for indefinite access.' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessLevel rdf:type rdf:Property ;
    rdfs:label 'Access Level' ;
    rdfs:comment 'Privilege level granted: read_only (view only), read_write (view and edit), admin (full module administration), super_admin (system-wide administration), or restricted (limited scope access).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Access Review Due Date' ;
    rdfs:comment 'Date when this access provisioning is scheduled for periodic review to validate continued business need and compliance with least privilege principle.' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiaryDataAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Data Access Flag' ;
    rdfs:comment 'Indicates whether this access provisioning grants permission to view or edit beneficiary personally identifiable information (PII) and program participation records (True/False).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Detailed explanation of the business need and rationale for the access provisioning request, including job role requirements, project assignment, or operational necessity.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceSignoffRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Signoff Required Flag' ;
    rdfs:comment 'Indicates whether this access provisioning requires formal compliance officer or data protection officer sign-off before activation (True/False).' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Signoff Timestamp' ;
    rdfs:comment 'Date and time when the compliance officer provided formal sign-off approval for this access provisioning.' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataClassificationAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Data Classification Access Level' ;
    rdfs:comment 'Highest data classification level the user is authorized to access through this provisioning: public (unrestricted), internal (staff only), confidential (business sensitive), or restricted (PII/PHI/donor data).' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprovisioningReason rdf:type rdf:Property ;
    rdfs:label 'Deprovisioning Reason' ;
    rdfs:comment 'Explanation for access revocation or suspension, including termination, role change, security incident, policy violation, or contract end. Populated only for revoke or suspend request types.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorAuditRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Audit Requirement Flag' ;
    rdfs:comment 'Indicates whether this access provisioning is subject to donor audit requirements and must maintain enhanced documentation for compliance reporting (True/False).' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialDataAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Data Access Flag' ;
    rdfs:comment 'Indicates whether this access provisioning grants permission to view or edit financial transactions, donor contributions, or grant accounting data (True/False).' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jmlLifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Jml Lifecycle Stage' ;
    rdfs:comment 'Stage in the employee lifecycle that triggered this access provisioning: joiner (new hire), mover (role change/transfer), leaver (termination/resignation), contractor_onboard (external consultant start), or contractor_offboard (external consultant end).' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Access Review Date' ;
    rdfs:comment 'Date when this access provisioning was last reviewed and validated by the system owner or security officer.' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:multiFactorAuthenticationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Factor Authentication Required Flag' ;
    rdfs:comment 'Indicates whether the provisioned access requires multi-factor authentication for login and session management (True/False).' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:provisioningCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Provisioning Completed Timestamp' ;
    rdfs:comment 'Date and time when the IT administrator or automated provisioning system completed the access setup in the target system.' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:remoteAccessPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Access Permitted Flag' ;
    rdfs:comment 'Indicates whether the user is authorized to access the system remotely from outside the organizational network (True/False).' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Externally-known unique identifier for the access provisioning request, formatted as APR-YYYYMMDD-XXXXXX.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Submitted Timestamp' ;
    rdfs:comment 'Date and time when the access provisioning request was formally submitted for approval.' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:securityIncidentReference rdf:type rdf:Property ;
    rdfs:label 'Security Incident Reference' ;
    rdfs:comment 'Reference number of the security incident that triggered emergency access revocation or suspension, formatted as INC-XXXXXXXX. Populated only when access change is incident-driven.' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSystemEnvironment rdf:type rdf:Property ;
    rdfs:label 'Target System Environment' ;
    rdfs:comment 'Environment tier of the target system where access is being provisioned: production (live operational), staging (pre-production testing), development (build environment), training (user education), or sandbox (isolated testing).' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetUserEmail rdf:type rdf:Property ;
    rdfs:label 'Target User Email' ;
    rdfs:comment 'Email address of the target user receiving the access provisioning action, used for notification and audit trail.' ;
    rdfs:domain ind:AccessProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessScope rdf:type rdf:Property ;
    rdfs:label 'Access Scope' ;
    rdfs:comment 'Geographic or organizational scope of data access granted by this role (global, regional, country-level, program-specific, project-specific, department-specific).' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeUserCount rdf:type rdf:Property ;
    rdfs:label 'Active User Count' ;
    rdfs:comment 'Current number of active users assigned to this role. Used for access governance reporting and license management.' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Name' ;
    rdfs:comment 'Name of the individual or committee authorized to approve assignment of this role to users (e.g., Chief Information Officer, Executive Director, Security Committee).' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthorityTitle rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Title' ;
    rdfs:comment 'Job title or position of the approval authority (e.g., Chief Information Officer, Director of Information Security, Head of Human Resources).' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLoggingRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Logging Required' ;
    rdfs:comment 'Indicates whether all actions performed by users with this role must be logged for audit and compliance purposes (True) or standard logging applies (False).' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataClassificationLevel rdf:type rdf:Property ;
    rdfs:label 'Data Classification Level' ;
    rdfs:comment 'The highest data classification level this role is authorized to access (public, internal, confidential, restricted) per organizational data governance policy.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataDomainAccess rdf:type rdf:Property ;
    rdfs:label 'Data Domain Access' ;
    rdfs:comment 'Comma-separated list of data domains this role can access (e.g., Beneficiary, Donor, Finance, Program, Grant, Volunteer, Supply Chain, MEL).' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRecertificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Recertification Date' ;
    rdfs:comment 'Date when this role definition was last reviewed and recertified by the role owner or approval authority.' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leastPrivilegeFlag rdf:type rdf:Property ;
    rdfs:label 'Least Privilege Flag' ;
    rdfs:comment 'Indicates whether this role adheres to the principle of least privilege (True) or grants elevated/broad access (False).' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moduleAccess rdf:type rdf:Property ;
    rdfs:label 'Module Access' ;
    rdfs:comment 'Comma-separated list of system modules or functional areas this role can access (e.g., Donor Management, Grant Accounting, Case Management, Field Data Collection).' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiFactorAuthenticationRequired rdf:type rdf:Property ;
    rdfs:label 'Multi Factor Authentication Required' ;
    rdfs:comment 'Indicates whether users assigned this role must use multi-factor authentication (MFA) for access (True) or single-factor is permitted (False).' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextRecertificationDate rdf:type rdf:Property ;
    rdfs:label 'Next Recertification Date' ;
    rdfs:comment 'Scheduled date for the next access recertification review of this role definition.' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permissionScope rdf:type rdf:Property ;
    rdfs:label 'Permission Scope' ;
    rdfs:comment 'The level of access permission granted by this role (read-only, write, admin, execute, delete, full control).' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privilegedAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Privileged Access Flag' ;
    rdfs:comment 'Indicates whether this role grants privileged or administrative access requiring enhanced monitoring and audit (True) or standard user access (False).' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recertificationFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Recertification Frequency Days' ;
    rdfs:comment 'Number of days between required access recertification reviews for users assigned this role (e.g., 90, 180, 365). Null if recertification is not required.' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roleCode rdf:type rdf:Property ;
    rdfs:label 'Role Code' ;
    rdfs:comment 'Unique business identifier or short code for the role (e.g., PROG_MGR, FIN_OFF, FLD_COORD) used across systems.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleDescription rdf:type rdf:Property ;
    rdfs:label 'Role Description' ;
    rdfs:comment 'Detailed description of the role\'s purpose, responsibilities, and typical use cases within the organization.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleName rdf:type rdf:Property ;
    rdfs:label 'Role Name' ;
    rdfs:comment 'Human-readable name of the role-based access control (RBAC) role (e.g., Program Manager, Finance Officer, Field Coordinator, Donor Relations Specialist).' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Role Owner Email' ;
    rdfs:comment 'Email address of the role owner for contact and accountability purposes.' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleOwnerName rdf:type rdf:Property ;
    rdfs:label 'Role Owner Name' ;
    rdfs:comment 'Name of the individual or department responsible for defining and maintaining this role (e.g., IT Director, HRIS Manager, Security Officer).' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleStatus rdf:type rdf:Property ;
    rdfs:label 'Role Status' ;
    rdfs:comment 'Current lifecycle status of the access role (active, inactive, suspended, deprecated, pending approval).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationOfDutiesFlag rdf:type rdf:Property ;
    rdfs:label 'Segregation Of Duties Flag' ;
    rdfs:comment 'Indicates whether this role is subject to segregation of duties controls (True) to prevent conflicts of interest or fraud risk (False if not applicable).' ;
    rdfs:domain ind:AccessRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backupScheduleId rdf:type rdf:Property ;
    rdfs:label 'Backup Schedule Id' ;
    rdfs:comment 'Unique identifier for the backup schedule record. Primary key.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertOnFailure rdf:type rdf:Property ;
    rdfs:label 'Alert On Failure' ;
    rdfs:comment 'Indicates whether automated alerts are sent when a backup fails or encounters errors.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertRecipients rdf:type rdf:Property ;
    rdfs:label 'Alert Recipients' ;
    rdfs:comment 'Comma-separated list of email addresses or distribution lists that receive backup failure alerts.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupFrequency rdf:type rdf:Property ;
    rdfs:label 'Backup Frequency' ;
    rdfs:comment 'Frequency at which backups are executed for this schedule.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupType rdf:type rdf:Property ;
    rdfs:label 'Backup Type' ;
    rdfs:comment 'Type of backup performed: full (complete copy), incremental (changes since last backup), differential (changes since last full), snapshot (point-in-time), or continuous (real-time replication).' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupVerificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Backup Verification Enabled' ;
    rdfs:comment 'Indicates whether automated verification and integrity checks are performed on backup files after completion.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backupWindowEndTime rdf:type rdf:Property ;
    rdfs:label 'Backup Window End Time' ;
    rdfs:comment 'Time of day when the backup window ends, in HH:MM format (24-hour).' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:backupWindowStartTime rdf:type rdf:Property ;
    rdfs:label 'Backup Window Start Time' ;
    rdfs:comment 'Time of day when the backup window begins, in HH:MM format (24-hour).' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceFrameworks rdf:type rdf:Property ;
    rdfs:label 'Compliance Frameworks' ;
    rdfs:comment 'Comma-separated list of compliance frameworks or regulations applicable to this backup schedule (e.g., GDPR, HIPAA, SOC2, ISO27001).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionEnabled rdf:type rdf:Property ;
    rdfs:label 'Compression Enabled' ;
    rdfs:comment 'Indicates whether backup data is compressed to reduce storage space and transfer time.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compressionRatio rdf:type rdf:Property ;
    rdfs:label 'Compression Ratio' ;
    rdfs:comment 'Average compression ratio achieved for backups (e.g., 2.5 means data is compressed to 40% of original size).' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataAssetName rdf:type rdf:Property ;
    rdfs:label 'Data Asset Name' ;
    rdfs:comment 'Name of the specific data asset, database, or repository covered by this backup schedule.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disasterRecoveryTier rdf:type rdf:Property ;
    rdfs:label 'Disaster Recovery Tier' ;
    rdfs:comment 'Disaster recovery tier classification indicating the criticality and priority of this backup schedule for business continuity planning.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled' ;
    rdfs:comment 'Indicates whether backup data is encrypted at rest and in transit.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastBackupDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Last Backup Duration Minutes' ;
    rdfs:comment 'Duration in minutes of the most recent backup execution.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastBackupSizeGb rdf:type rdf:Property ;
    rdfs:label 'Last Backup Size Gb' ;
    rdfs:comment 'Size of the most recent backup in gigabytes.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastBackupStatus rdf:type rdf:Property ;
    rdfs:label 'Last Backup Status' ;
    rdfs:comment 'Outcome status of the most recent backup execution attempt.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastBackupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Backup Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful backup execution for this schedule.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Last Verification Status' ;
    rdfs:comment 'Outcome of the most recent backup verification or integrity check.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verification Timestamp' ;
    rdfs:comment 'Timestamp of the most recent backup verification or integrity check.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nextScheduledBackupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Backup Timestamp' ;
    rdfs:comment 'Timestamp when the next backup is scheduled to execute.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rpoMinutes rdf:type rdf:Property ;
    rdfs:label 'Rpo Minutes' ;
    rdfs:comment 'Recovery Point Objective in minutes: the maximum acceptable amount of data loss measured in time. Defines how much data the organization can afford to lose.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rtoMinutes rdf:type rdf:Property ;
    rdfs:label 'Rto Minutes' ;
    rdfs:comment 'Recovery Time Objective in minutes: the maximum acceptable time to restore the system or data after a disruption. Defines how quickly the organization must recover.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Business identifier code for the backup schedule, used for external reference and reporting.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCronExpression rdf:type rdf:Property ;
    rdfs:label 'Schedule Cron Expression' ;
    rdfs:comment 'Cron expression defining the precise timing and recurrence pattern for automated backup execution.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable name of the backup schedule describing the system or data asset covered.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current operational status of the backup schedule.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationType rdf:type rdf:Property ;
    rdfs:label 'Storage Location Type' ;
    rdfs:comment 'Primary storage location type for backup data: on-site (local datacenter), cloud (cloud provider), offsite (third-party facility), or hybrid (multiple locations).' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storagePath rdf:type rdf:Property ;
    rdfs:label 'Storage Path' ;
    rdfs:comment 'File system path, bucket name, or URI where backup files are stored.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageProvider rdf:type rdf:Property ;
    rdfs:label 'Storage Provider' ;
    rdfs:comment 'Name of the storage provider or vendor hosting the backup data (e.g., AWS S3, Azure Blob, local NAS).' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Technical Owner Email' ;
    rdfs:comment 'Email address of the technical owner for notifications and escalations.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalOwnerName rdf:type rdf:Property ;
    rdfs:label 'Technical Owner Name' ;
    rdfs:comment 'Name of the technical owner or system administrator responsible for this backup schedule.' ;
    rdfs:domain ind:BackupSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRequestId rdf:type rdf:Property ;
    rdfs:label 'Change Request Id' ;
    rdfs:comment 'Unique identifier for the IT change request record. Primary key.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cabMeetingId rdf:type rdf:Property ;
    rdfs:label 'Cab Meeting Id' ;
    rdfs:comment 'Identifier of the CAB meeting session where this change request was reviewed. Links to meeting records for audit trail and decision context.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CabMeeting .

ind:primaryChangeStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Change Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member or system user who submitted the change request. Links to workforce or user management system.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:affectedServices rdf:type rdf:Property ;
    rdfs:label 'Affected Services' ;
    rdfs:comment 'Business services and operational capabilities that may experience disruption or modification during change implementation. Used for stakeholder notification and service continuity planning.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSystems rdf:type rdf:Property ;
    rdfs:label 'Affected Systems' ;
    rdfs:comment 'Comma-separated list or description of IT systems, platforms, and applications that will be modified or impacted by the change. Examples include Salesforce, SAP, DHIS2, KoboToolbox, CommCare.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Comments, conditions, or recommendations provided by approvers during the review process. Captures decision rationale and any special instructions.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedToName rdf:type rdf:Property ;
    rdfs:label 'Assigned To Name' ;
    rdfs:comment 'Full name of the individual or team assigned to execute the change implementation. Provides accountability and contact information.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Cab Approval Date' ;
    rdfs:comment 'Date when the Change Advisory Board formally approved or rejected the change request. Null if CAB review is not required or not yet completed.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cabApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Cab Approval Required' ;
    rdfs:comment 'Indicates whether the change requires formal review and approval by the Change Advisory Board. True for normal and emergency changes; false for standard pre-approved changes.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cabApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Cab Approval Status' ;
    rdfs:comment 'Current approval decision status from the Change Advisory Board. Conditional approval indicates approval with specific requirements or constraints.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'Functional area or domain affected by the change request. Used for routing to appropriate technical teams and impact analysis.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'Externally-visible unique change request number following organizational numbering convention (e.g., CHG0001234). Used for tracking and communication across IT teams and stakeholders.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRequestDescription rdf:type rdf:Property ;
    rdfs:label 'Change Request Description' ;
    rdfs:comment 'Detailed narrative describing the change to be implemented, including technical specifications, configuration modifications, and scope of work. Provides comprehensive context for reviewers and implementers.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRequestStatus rdf:type rdf:Property ;
    rdfs:label 'Change Request Status' ;
    rdfs:comment 'Current lifecycle state of the change request in the approval and implementation workflow. Tracks progression from initial submission through completion or cancellation. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|scheduled|in_progress|implemented|closed|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the change request based on risk, urgency, and approval requirements. Standard changes are pre-approved low-risk changes; normal changes require CAB review; emergency changes address critical incidents; expedited changes are fast-tracked normal changes.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeRequired rdf:type rdf:Property ;
    rdfs:label 'Downtime Required' ;
    rdfs:comment 'Indicates whether the change implementation requires system or service downtime. True if downtime is necessary; false if change can be implemented without service interruption.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDowntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Downtime Minutes' ;
    rdfs:comment 'Anticipated duration of system or service unavailability during change implementation, measured in minutes. Used for scheduling and stakeholder communication.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Detailed analysis of potential effects on systems, services, users, and business operations. Identifies affected components, dependencies, and downstream consequences.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationOutcome rdf:type rdf:Property ;
    rdfs:label 'Implementation Outcome' ;
    rdfs:comment 'Final result of the change implementation. Successful indicates change achieved objectives; failed indicates implementation did not complete; partially successful indicates some objectives met; rolled back indicates change was reverted.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationPlan rdf:type rdf:Property ;
    rdfs:label 'Implementation Plan' ;
    rdfs:comment 'Step-by-step technical procedure for executing the change, including pre-implementation tasks, execution steps, validation checkpoints, and post-implementation activities.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postImplementationNotes rdf:type rdf:Property ;
    rdfs:label 'Post Implementation Notes' ;
    rdfs:comment 'Summary of post-implementation review findings, including actual vs. expected outcomes, issues encountered, lessons learned, and recommendations for future changes.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postImplementationReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Post Implementation Review Completed' ;
    rdfs:comment 'Indicates whether a formal post-implementation review has been conducted to assess change success, lessons learned, and process improvements. Required for normal and emergency changes.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postImplementationReviewDate rdf:type rdf:Property ;
    rdfs:label 'Post Implementation Review Date' ;
    rdfs:comment 'Date when the post-implementation review was completed. Used for tracking compliance with change management process requirements.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requesterEmail rdf:type rdf:Property ;
    rdfs:label 'Requester Email' ;
    rdfs:comment 'Email address of the change requester for status updates and communication throughout the change lifecycle.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterName rdf:type rdf:Property ;
    rdfs:label 'Requester Name' ;
    rdfs:comment 'Full name of the individual who initiated the change request. Provides human-readable identification for reporting and communication.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackPlan rdf:type rdf:Property ;
    rdfs:label 'Rollback Plan' ;
    rdfs:comment 'Documented procedure for reverting the change and restoring systems to their previous state if implementation fails or causes unacceptable issues. Critical for risk mitigation.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Planned date and time when change implementation should be completed. Defines the end of the approved implementation window.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time when change implementation will begin. Defines the start of the implementation window approved by Change Advisory Board (CAB).' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Date and time when the change request was formally submitted for review. Marks the beginning of the change request lifecycle and approval workflow.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testPlan rdf:type rdf:Property ;
    rdfs:label 'Test Plan' ;
    rdfs:comment 'Testing strategy and validation procedures to verify successful implementation and confirm that the change achieves intended outcomes without introducing defects.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectivityLogId rdf:type rdf:Property ;
    rdfs:label 'Connectivity Log Id' ;
    rdfs:comment 'Unique identifier for the connectivity log record.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedUsersCount rdf:type rdf:Property ;
    rdfs:label 'Affected Users Count' ;
    rdfs:comment 'Estimated number of users or staff affected by connectivity issues at this site.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bandwidthUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Utilization Percent' ;
    rdfs:comment 'Percentage of available bandwidth currently in use at the time of measurement.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Business Impact Description' ;
    rdfs:comment 'Description of the operational or programmatic impact caused by connectivity issues.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causeClassification rdf:type rdf:Property ;
    rdfs:label 'Cause Classification' ;
    rdfs:comment 'Root cause category for connectivity issues or outages. [ENUM-REF-CANDIDATE: isp_fault|power_outage|equipment_failure|weather|configuration_error|capacity_exceeded|security_incident|maintenance|natural_disaster|vandalism|unknown — promote to reference product]' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionStatus rdf:type rdf:Property ;
    rdfs:label 'Connection Status' ;
    rdfs:comment 'Current operational status of the network connection at the time of measurement.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionType rdf:type rdf:Property ;
    rdfs:label 'Connection Type' ;
    rdfs:comment 'Type of network connection technology used at this site.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceIpAddress rdf:type rdf:Property ;
    rdfs:label 'Device Ip Address' ;
    rdfs:comment 'IP address of the network device or router at the measurement site.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceMacAddress rdf:type rdf:Property ;
    rdfs:label 'Device Mac Address' ;
    rdfs:comment 'MAC address of the network device or router at the measurement site.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Download Speed Mbps' ;
    rdfs:comment 'Measured download speed in megabits per second.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ispProviderName rdf:type rdf:Property ;
    rdfs:label 'Isp Provider Name' ;
    rdfs:comment 'Name of the Internet Service Provider delivering connectivity to this site.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jitterMs rdf:type rdf:Property ;
    rdfs:label 'Jitter Ms' ;
    rdfs:comment 'Variation in latency measured in milliseconds, indicating network stability.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:latencyMs rdf:type rdf:Property ;
    rdfs:label 'Latency Ms' ;
    rdfs:comment 'Network latency measured in milliseconds, representing the round-trip time for data packets.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Method by which the connectivity measurement was performed.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The exact date and time when the connectivity measurement was captured.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:monitoringTool rdf:type rdf:Property ;
    rdfs:label 'Monitoring Tool' ;
    rdfs:comment 'Name of the network monitoring tool or system that captured this measurement.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Outage Duration Minutes' ;
    rdfs:comment 'Total duration of connectivity outage in minutes, if applicable to this measurement.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outageEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Outage End Timestamp' ;
    rdfs:comment 'The date and time when the connectivity outage was resolved.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outageStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Outage Start Timestamp' ;
    rdfs:comment 'The date and time when the connectivity outage began.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packetLossPercent rdf:type rdf:Property ;
    rdfs:label 'Packet Loss Percent' ;
    rdfs:comment 'Percentage of data packets lost during transmission, indicating network quality.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'The date and time when the connectivity issue was fully resolved.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signalStrengthDbm rdf:type rdf:Property ;
    rdfs:label 'Signal Strength Dbm' ;
    rdfs:comment 'Signal strength measured in dBm for wireless connections.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliant Flag' ;
    rdfs:comment 'Indicates whether this connectivity measurement meets the SLA requirements.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetUptimePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Uptime Percent' ;
    rdfs:comment 'The contractual uptime percentage target defined in the SLA with the ISP.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uploadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Upload Speed Mbps' ;
    rdfs:comment 'Measured upload speed in megabits per second.' ;
    rdfs:domain ind:ConnectivityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryItStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary It Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member or employee to whom the asset is currently assigned for use.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'Detailed categorization of the asset within its type, specifying the specific kind of hardware or software. [ENUM-REF-CANDIDATE: laptop|desktop|server|tablet|smartphone|router|switch|firewall|printer|scanner|application_software|operating_system|database|middleware — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCondition rdf:type rdf:Property ;
    rdfs:label 'Asset Condition' ;
    rdfs:comment 'Assessment of the physical or functional condition of the asset, used for maintenance planning and disposal decisions. [ENUM-REF-CANDIDATE: new|excellent|good|fair|poor|damaged|obsolete — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTag rdf:type rdf:Property ;
    rdfs:label 'Asset Tag' ;
    rdfs:comment 'Externally visible unique identifier affixed to the physical asset for inventory tracking and auditing purposes.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'High-level classification of the IT asset distinguishing between hardware, software, network equipment, mobile devices, peripherals, and licenses.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedCountryCode rdf:type rdf:Property ;
    rdfs:label 'Assigned Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the country where the asset is deployed.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedLocationName rdf:type rdf:Property ;
    rdfs:label 'Assigned Location Name' ;
    rdfs:comment 'Name or identifier of the specific office, field location, or facility where the asset is assigned.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedLocationType rdf:type rdf:Property ;
    rdfs:label 'Assigned Location Type' ;
    rdfs:comment 'Type of organizational location where the asset is currently deployed or stored.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method used to depreciate the asset value over its useful life.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date on which the asset was disposed of, sold, donated, or decommissioned.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Method by which the asset was disposed of at end of life, important for environmental and data security compliance.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostname rdf:type rdf:Property ;
    rdfs:label 'Hostname' ;
    rdfs:comment 'Network hostname or computer name assigned to the asset for identification on the organization\'s network.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Date on which the software license expires and requires renewal to maintain compliance.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the asset in its operational lifecycle, indicating whether it is actively in use, stored, under repair, or decommissioned.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macAddress rdf:type rdf:Property ;
    rdfs:label 'Mac Address' ;
    rdfs:comment 'Hardware MAC address uniquely identifying the network interface of the asset.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the company that manufactured or developed the IT asset.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Manufacturer model number or name identifying the specific product variant.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'Name and version of the operating system installed on the asset, critical for software compatibility and security patching.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementCost rdf:type rdf:Property ;
    rdfs:label 'Procurement Cost' ;
    rdfs:comment 'Original purchase price or acquisition cost of the asset in the organization\'s base currency.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementDate rdf:type rdf:Property ;
    rdfs:label 'Procurement Date' ;
    rdfs:comment 'Date on which the asset was purchased or acquired by the organization.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Commercial or marketing name of the IT asset product.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'Estimated residual value of the asset at the end of its useful life.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Version number of the primary software or firmware installed on the asset.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportContractNumber rdf:type rdf:Property ;
    rdfs:label 'Support Contract Number' ;
    rdfs:comment 'Reference number for any active maintenance or support contract associated with the asset.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Support Expiry Date' ;
    rdfs:comment 'Date on which the support or maintenance contract expires.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful life of the asset in years, used for depreciation and replacement planning.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date on which the manufacturer or vendor warranty coverage ends, after which maintenance costs may increase.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'Date on which the manufacturer or vendor warranty coverage begins.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyType rdf:type rdf:Property ;
    rdfs:label 'Warranty Type' ;
    rdfs:comment 'Type of warranty coverage applicable to the asset, distinguishing between manufacturer, extended, or third-party warranties.' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itServiceId rdf:type rdf:Property ;
    rdfs:label 'It Service Id' ;
    rdfs:comment 'Foreign key linking to technology.it_service. Business justification: IT incidents disrupt specific IT services. The affected_service STRING field should be normalized to FK. N:1 relationship - many incidents affect one service. Core ITSM relationship for service availa' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItService .

ind:relatedChangeChangeRequestId rdf:type rdf:Property ;
    rdfs:label 'Related Change Change Request Id' ;
    rdfs:comment 'Identifier of the related change request if this incident was caused by or resolved through a change to IT infrastructure or configuration.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeRequest .

ind:relatedProblemId rdf:type rdf:Property ;
    rdfs:label 'Related Problem Id' ;
    rdfs:comment 'Identifier of the related problem record if this incident is linked to a known underlying problem requiring root cause analysis and permanent fix.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItProblem .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when the assigned team acknowledged receipt and began investigation.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affectedCountryOffice rdf:type rdf:Property ;
    rdfs:label 'Affected Country Office' ;
    rdfs:comment 'Three-letter ISO country code of the country office or field location experiencing the incident (e.g., KEN for Kenya, SYR for Syria, USA for headquarters). Null if incident is global.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProgram rdf:type rdf:Property ;
    rdfs:label 'Affected Program' ;
    rdfs:comment 'Name or code of the humanitarian program or project impacted by the incident (e.g., WASH Emergency Response, Health Services Delivery, Education Access Program).' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Date and time when the incident was assigned to a support team or individual.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'Name or identifier of the IT support team member or group currently responsible for resolving the incident.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Required' ;
    rdfs:comment 'Indicates whether regulatory breach notification is required under GDPR, CCPA, or other data protection laws.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessImpact rdf:type rdf:Property ;
    rdfs:label 'Business Impact' ;
    rdfs:comment 'Assessment of the business impact of the incident: critical (mission-critical operations halted), high (major program disruption), medium (moderate inconvenience), low (minimal impact).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationSent rdf:type rdf:Property ;
    rdfs:label 'Communication Sent' ;
    rdfs:comment 'Indicates whether a communication or notification was sent to affected users or stakeholders about the incident.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataBreach rdf:type rdf:Property ;
    rdfs:label 'Data Breach' ;
    rdfs:comment 'Indicates whether the incident resulted in unauthorized access to or disclosure of sensitive data (beneficiary PII, donor information, financial records).' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'Date and time when the incident was first detected or when the service disruption began (may precede reported_timestamp if detected by monitoring tools).' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Minutes' ;
    rdfs:comment 'Total duration in minutes that the affected system or service was unavailable.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalated rdf:type rdf:Property ;
    rdfs:label 'Escalated' ;
    rdfs:comment 'Indicates whether the incident was escalated to higher-level support or management due to severity or complexity.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Level to which the incident was escalated: L1 (first-line support), L2 (specialist support), L3 (engineering), management (executive attention), vendor (third-party escalation).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the incident was escalated.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:financialImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Usd' ;
    rdfs:comment 'Estimated financial cost of the incident in USD, including lost productivity, recovery costs, and potential donor impact.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactedUserCount rdf:type rdf:Property ;
    rdfs:label 'Impacted User Count' ;
    rdfs:comment 'Estimated number of staff, volunteers, or beneficiaries affected by the incident.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentCategory rdf:type rdf:Property ;
    rdfs:label 'Incident Category' ;
    rdfs:comment 'High-level classification of the incident type: hardware failure, software defect, network outage, security breach, data loss, or platform unavailability.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentSubcategory rdf:type rdf:Property ;
    rdfs:label 'Incident Subcategory' ;
    rdfs:comment 'Detailed classification within the incident category (e.g., ransomware, server crash, database corruption, API timeout, VPN failure).' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeToResolutionMinutes rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Resolution Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from incident detection to resolution. Key performance indicator for IT service quality.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'Name or identifier of the person who first reported the incident (staff member, volunteer, or system monitor).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed narrative of the actions taken to resolve the incident and restore service.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'Date and time when the incident was resolved and service was restored.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified underlying cause of the incident after investigation (e.g., hardware failure, software bug, configuration error, cyberattack, human error, third-party service outage).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level classification of the root cause for trend analysis: infrastructure failure, application defect, configuration error, security breach, human error, or third-party dependency.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityIncident rdf:type rdf:Property ;
    rdfs:label 'Security Incident' ;
    rdfs:comment 'Indicates whether the incident is classified as a security incident (data breach, ransomware, unauthorized access, phishing attack).' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:userSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'User Satisfaction Rating' ;
    rdfs:comment 'Post-resolution satisfaction rating provided by the user (typically 1-5 scale, where 5 is highly satisfied).' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Ticket Number' ;
    rdfs:comment 'External ticket or case number assigned by a third-party vendor or service provider if the incident was escalated externally.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workaroundApplied rdf:type rdf:Property ;
    rdfs:label 'Workaround Applied' ;
    rdfs:comment 'Indicates whether a temporary workaround was applied to restore service before a permanent fix was implemented.' ;
    rdfs:domain ind:ItIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workaroundDescription rdf:type rdf:Property ;
    rdfs:label 'Workaround Description' ;
    rdfs:comment 'Description of the temporary workaround applied, if any.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itProcurementId rdf:type rdf:Property ;
    rdfs:label 'It Procurement Id' ;
    rdfs:comment 'Unique identifier for the IT procurement request or purchase order record.' ;
    rdfs:domain ind:ItProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Approver Staff Staff Member Id' ;
    rdfs:comment 'Unique identifier of the staff member who approved the IT procurement request, typically a budget holder or IT manager.' ;
    rdfs:domain ind:ItProcurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:resultingItAssetId rdf:type rdf:Property ;
    rdfs:label 'Resulting It Asset Id' ;
    rdfs:comment 'Foreign key linking to technology.it_asset. Business justification: IT procurement of hardware results in IT asset records. Tracks procurement-to-asset lifecycle. N:1 relationship (procurement creates asset). Temporal note: FK populated AFTER delivery and asset regist' ;
    rdfs:domain ind:ItProcurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItAsset .

ind:resultingSoftwareLicenseId rdf:type rdf:Property ;
    rdfs:label 'Resulting Software License Id' ;
    rdfs:comment 'Foreign key linking to technology.software_license. Business justification: IT procurement of software/SaaS results in software license records. Tracks procurement-to-license lifecycle. N:1 relationship (procurement creates license). Temporal note: FK populated after license ' ;
    rdfs:domain ind:ItProcurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoftwareLicense .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference number or identifier of the master contract or framework agreement under which this IT procurement is made, if applicable.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Country Office Code' ;
    rdfs:comment 'Three-letter ISO country code identifying the country office or field location requesting the IT procurement.' ;
    rdfs:domain ind:ItProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryConfirmedBy rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmed By' ;
    rdfs:comment 'Name of the staff member who confirmed receipt and acceptance of the IT goods or services.' ;
    rdfs:domain ind:ItProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementStatus rdf:type rdf:Property ;
    rdfs:label 'Procurement Status' ;
    rdfs:comment 'Current lifecycle status of the IT procurement request: draft (being prepared), submitted (awaiting review), pending_approval (in approval workflow), approved (authorized for purchase), rejected (denied), ordered (purchase order issued to vendor), received (goods/services delivered), cancelled (request withdrawn). [ENUM-REF-CANDIDATE: draft|submitted|pending_approval|approved|rejected|ordered|received|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itManagerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'It Manager Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:ItProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:itStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'It Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:ItProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:tertiaryItBusinessSponsorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary It Business Sponsor Staff Member Id' ;
    rdfs:comment 'Identifier of the senior business stakeholder (typically a director or VP) who sponsors and champions the project.' ;
    rdfs:domain ind:ItProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:deliveryMethodology rdf:type rdf:Property ;
    rdfs:label 'Delivery Methodology' ;
    rdfs:comment 'Project management methodology used for delivery: agile (sprint-based, iterative), waterfall (sequential phases), hybrid (combination of agile and waterfall), or iterative (phased releases).' ;
    rdfs:domain ind:ItProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastEndDate rdf:type rdf:Property ;
    rdfs:label 'Forecast End Date' ;
    rdfs:comment 'Current forecast or revised completion date based on actual progress and known risks, updated regularly during project execution.' ;
    rdfs:domain ind:ItProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goLiveDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Date' ;
    rdfs:comment 'Date when the system, platform, or solution delivered by the project was deployed to production and made available to end users.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:healthStatus rdf:type rdf:Property ;
    rdfs:label 'Health Status' ;
    rdfs:comment 'RAG (Red-Amber-Green) health indicator for the project: green (on track, no issues), yellow (at risk, requires attention), red (critical issues, intervention needed). Assessed based on schedule, budget, scope, and quality metrics.' ;
    rdfs:domain ind:ItProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationCount rdf:type rdf:Property ;
    rdfs:label 'Integration Count' ;
    rdfs:comment 'Number of system integrations (APIs, ETL pipelines, data feeds) developed or modified as part of this project.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itProjectDescription rdf:type rdf:Property ;
    rdfs:label 'It Project Description' ;
    rdfs:comment 'Detailed narrative description of the project objectives, scope, deliverables, and expected business outcomes.' ;
    rdfs:domain ind:ItProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Summary of key milestone completion status, typically a brief text indicating which major milestones have been achieved (e.g., \'Requirements Complete, Design 80%, Build 40%\').' ;
    rdfs:domain ind:ItProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentComplete rdf:type rdf:Property ;
    rdfs:label 'Percent Complete' ;
    rdfs:comment 'Overall project completion percentage (0.00 to 100.00), calculated based on earned value, milestone completion, or weighted task progress.' ;
    rdfs:domain ind:ItProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectCategory rdf:type rdf:Property ;
    rdfs:label 'Project Category' ;
    rdfs:comment 'Strategic classification of the project: strategic (aligned with multi-year digital transformation roadmap), operational (business-as-usual system maintenance or enhancement), compliance (regulatory or donor-mandated requirement), or innovation (pilot, proof-of-concept, emerging technology exploration).' ;
    rdfs:domain ind:ItProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Business-assigned unique code for the IT project, typically following organizational naming conventions (e.g., DHIS-2024-001, SAP-MIG-2023).' ;
    rdfs:domain ind:ItProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Full descriptive name of the IT project (e.g., \'Salesforce Nonprofit Cloud Implementation\', \'DHIS2 Upgrade to Version 2.39\', \'Data Governance Framework Rollout\').' ;
    rdfs:domain ind:ItProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the IT project: planning (requirements gathering, design), active (in execution), on_hold (temporarily paused), completed (delivered but not yet closed), cancelled (terminated before completion), or closed (formally closed with lessons learned documented).' ;
    rdfs:domain ind:ItProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the IT project by its primary objective: system implementation (new platform deployment), platform migration (moving from one system to another), infrastructure upgrade (hardware/network improvements), data governance (policies, standards, MDM), security enhancement (cybersecurity, compliance), or integration development (API, ETL, data pipelines).' ;
    rdfs:domain ind:ItProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsoringDomain rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Domain' ;
    rdfs:comment 'The primary business domain or functional area that sponsors and benefits from this IT project (e.g., \'Program\', \'Finance\', \'Monitoring and Evaluation\', \'Donor Relations\'). Maps to the organization\'s data domain taxonomy.' ;
    rdfs:domain ind:ItProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successCriteria rdf:type rdf:Property ;
    rdfs:label 'Success Criteria' ;
    rdfs:comment 'Measurable criteria that define project success, including Key Performance Indicators (KPIs), acceptance criteria, and business outcome targets.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userCount rdf:type rdf:Property ;
    rdfs:label 'User Count' ;
    rdfs:comment 'Estimated or actual number of end users who will be impacted by or will use the solution delivered by this project.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessRequestProcess rdf:type rdf:Property ;
    rdfs:label 'Access Request Process' ;
    rdfs:comment 'Process required for users to request access to this service: self_service (automatic provisioning), manager_approval (requires line manager approval), it_approval (requires IT team approval), or security_clearance (requires security review).' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'Primary authentication mechanism for accessing the service: single_sign_on (SSO via organizational identity provider), username_password (basic credentials), multi_factor (MFA required), or certificate_based (digital certificates).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Availability Target Percent' ;
    rdfs:comment 'Target uptime percentage for the service as defined in the SLA (e.g., 99.9% for critical services, 95% for standard services). Measured over a calendar month.' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference number of the contract or agreement governing the service provision, if applicable. Used for vendor management and compliance tracking.' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disasterRecoveryRpoHours rdf:type rdf:Property ;
    rdfs:label 'Disaster Recovery Rpo Hours' ;
    rdfs:comment 'Recovery Point Objective (RPO) in hours: maximum acceptable age of data that may be lost in a disaster. Defines backup frequency requirements.' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disasterRecoveryRtoHours rdf:type rdf:Property ;
    rdfs:label 'Disaster Recovery Rto Hours' ;
    rdfs:comment 'Recovery Time Objective (RTO) in hours: maximum acceptable time to restore the service after a disaster or major outage. Critical for business continuity planning.' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:knowledgeBaseUrl rdf:type rdf:Property ;
    rdfs:label 'Knowledge Base Url' ;
    rdfs:comment 'URL link to the knowledge base, user guide, or documentation portal for this service. Enables self-service support and user training.' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyCostUsd rdf:type rdf:Property ;
    rdfs:label 'Monthly Cost Usd' ;
    rdfs:comment 'Average monthly cost in USD to deliver this service, including licensing, infrastructure, support, and vendor fees. Used for IT budget planning and cost allocation.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionTimeTargetHours rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Target Hours' ;
    rdfs:comment 'Maximum time in hours to resolve an incident or fulfill a service request for this service, as defined in the SLA.' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseTimeTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Response Time Target Minutes' ;
    rdfs:comment 'Maximum time in minutes for the IT team to acknowledge and begin working on an incident or service request for this service, as defined in the SLA.' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Planned or actual date when the service will be or was decommissioned and removed from the service catalog. Null for active services.' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'High-level classification of the IT service type: connectivity (internet, VPN), infrastructure (servers, storage), application (Salesforce, SAP, DHIS2), support (helpdesk, training), security (firewall, antivirus), or data_management (backup, archiving).' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the service for internal reference and system integration (e.g., EMAIL-001, VPN-002, STORAGE-003).' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDeliveryModel rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Model' ;
    rdfs:comment 'How the service is delivered: in_house (managed by internal IT team), outsourced (managed by external vendor), hybrid (combination of internal and external), or cloud_saas (Software as a Service from cloud provider).' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceHours rdf:type rdf:Property ;
    rdfs:label 'Service Hours' ;
    rdfs:comment 'Hours during which the service is available and supported: 24x7 (24 hours, 7 days a week), business_hours (Monday-Friday, 9am-5pm local time), extended_hours (weekdays plus evenings/weekends), or on_demand (available upon request).' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Service Launch Date' ;
    rdfs:comment 'Date when the service was first made available to users in production. Used for service lifecycle tracking and anniversary reporting.' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceManagerName rdf:type rdf:Property ;
    rdfs:label 'Service Manager Name' ;
    rdfs:comment 'Name of the individual responsible for day-to-day operational management of the service, including incident response and user support.' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceName rdf:type rdf:Property ;
    rdfs:label 'Service Name' ;
    rdfs:comment 'The official name of the IT service as presented to users (e.g., Email Service, VPN Access, Cloud Storage, Helpdesk Support).' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Service Owner Email' ;
    rdfs:comment 'Primary email contact for the service owner for escalations and service-related inquiries.' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceOwnerName rdf:type rdf:Property ;
    rdfs:label 'Service Owner Name' ;
    rdfs:comment 'Name of the individual accountable for the service delivery, performance, and continuous improvement. Typically a senior IT manager or director.' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current lifecycle status of the IT service: active (available for use), inactive (temporarily unavailable), retired (decommissioned), under_development (being built), pilot (limited rollout), or maintenance (scheduled downtime).' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'Service level tier defining response and resolution commitments: platinum (mission-critical, 24/7 support), gold (high priority, business hours), silver (standard support), bronze (basic support), or best_effort (no guaranteed SLA).' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportContactEmail rdf:type rdf:Property ;
    rdfs:label 'Support Contact Email' ;
    rdfs:comment 'Primary email address for users to request support or report issues with this service (e.g., helpdesk@ngo.org, itsupport@ngo.org).' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Support Phone Number' ;
    rdfs:comment 'Primary phone number for users to contact IT support for this service. May include international dialing codes for global services.' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedUserPopulation rdf:type rdf:Property ;
    rdfs:label 'Supported User Population' ;
    rdfs:comment 'Primary user group or population that this service is designed to support: all_staff, field_operations (humanitarian workers in the field), headquarters (HQ staff), program_staff, finance_staff, senior_management, or external_partners (donors, implementing partners). [ENUM-REF-CANDIDATE: all_staff|field_operations|headquarters|program_staff|finance_staff|senior_management|external_partners — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:address rdf:type rdf:Property ;
    rdfs:label 'Address' ;
    rdfs:comment 'Full physical address of the network site location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Backup Bandwidth Mbps' ;
    rdfs:comment 'Bandwidth capacity in megabits per second (Mbps) available on the backup connectivity link.' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backupConnectivityType rdf:type rdf:Property ;
    rdfs:label 'Backup Connectivity Type' ;
    rdfs:comment 'Secondary or backup connectivity technology available for failover in case primary connection fails (e.g., 4G LTE backup for fiber).' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bandwidthCapacityMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Capacity Mbps' ;
    rdfs:comment 'Maximum bandwidth capacity in megabits per second (Mbps) available at this network site.' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCertifications rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications' ;
    rdfs:comment 'List of compliance certifications or standards this network site adheres to (e.g., ISO 27001, SOC 2, CHS).' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectivityType rdf:type rdf:Property ;
    rdfs:label 'Connectivity Type' ;
    rdfs:comment 'Primary connectivity technology used at this network site for internet and WAN access. [ENUM-REF-CANDIDATE: fiber|vsat|4g_lte|5g|microwave|satellite|dsl|cable|vpn — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date when the network site was or will be decommissioned and taken out of service.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentInventory rdf:type rdf:Property ;
    rdfs:label 'Equipment Inventory' ;
    rdfs:comment 'Summary list of key network equipment deployed at this site (routers, switches, access points, modems).' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firewallEnabled rdf:type rdf:Property ;
    rdfs:label 'Firewall Enabled' ;
    rdfs:comment 'Indicates whether a firewall is deployed and active at this network site for security protection.' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the network site was initially installed and commissioned for operational use.' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ipAddressRange rdf:type rdf:Property ;
    rdfs:label 'Ip Address Range' ;
    rdfs:comment 'IP address range or subnet allocated to this network site (e.g., CIDR notation 10.20.30.0/24).' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispContractNumber rdf:type rdf:Property ;
    rdfs:label 'Isp Contract Number' ;
    rdfs:comment 'Contract or account number with the ISP provider for billing and service management.' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispProvider rdf:type rdf:Property ;
    rdfs:label 'Isp Provider' ;
    rdfs:comment 'Name of the Internet Service Provider or telecommunications carrier providing connectivity to this site.' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent scheduled maintenance or inspection performed on this network site.' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:networkAdministratorEmail rdf:type rdf:Property ;
    rdfs:label 'Network Administrator Email' ;
    rdfs:comment 'Email address of the network administrator responsible for this site. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAdministratorName rdf:type rdf:Property ;
    rdfs:label 'Network Administrator Name' ;
    rdfs:comment 'Name of the staff member or team responsible for managing and maintaining this network site.' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAdministratorPhone rdf:type rdf:Property ;
    rdfs:label 'Network Administrator Phone' ;
    rdfs:comment 'Phone number of the network administrator for emergency contact and support escalation. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Scheduled date for the next planned maintenance or inspection of this network site.' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:securityClassification rdf:type rdf:Property ;
    rdfs:label 'Security Classification' ;
    rdfs:comment 'Data security classification level assigned to this network site based on the sensitivity of data and systems it hosts.' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uptimeSlaPercentage rdf:type rdf:Property ;
    rdfs:label 'Uptime Sla Percentage' ;
    rdfs:comment 'Contractual uptime Service Level Agreement percentage guaranteed by the ISP (e.g., 99.9%).' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vlanNumber rdf:type rdf:Property ;
    rdfs:label 'Vlan Number' ;
    rdfs:comment 'Virtual LAN identifier(s) configured at this network site for network segmentation and security.' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vpnEnabled rdf:type rdf:Property ;
    rdfs:label 'Vpn Enabled' ;
    rdfs:comment 'Indicates whether VPN connectivity is configured and available at this network site for secure remote access.' ;
    rdfs:domain ind:NetworkSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformIntegrationId rdf:type rdf:Property ;
    rdfs:label 'Platform Integration Id' ;
    rdfs:comment 'Unique identifier for the platform integration record. Primary key.' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Owner Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:platformStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Platform Staff Member Id' ;
    rdfs:comment 'FK to workforce.staff_member' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:primaryPlatformStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Platform Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who is the business owner responsible for this integration.' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:targetSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Target System Platform Id' ;
    rdfs:comment 'Reference to the target system platform to which data is loaded in this integration.' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:dataDomain rdf:type rdf:Property ;
    rdfs:label 'Data Domain' ;
    rdfs:comment 'Business data domain that this integration serves (e.g., \'Beneficiary\', \'Donor\', \'Program\', \'Finance\', \'Monitoring and Evaluation\').' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataEntity rdf:type rdf:Property ;
    rdfs:label 'Data Entity' ;
    rdfs:comment 'Primary data entity or object being exchanged (e.g., \'Beneficiary Registration\', \'Donor Gift\', \'Program Indicator\', \'Financial Transaction\').' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataTransformationRequired rdf:type rdf:Property ;
    rdfs:label 'Data Transformation Required' ;
    rdfs:comment 'Indicates whether data transformation or mapping is required between source and target schemas (true) or not (false).' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationUrl rdf:type rdf:Property ;
    rdfs:label 'Documentation Url' ;
    rdfs:comment 'URL or file path to the technical documentation, integration specification, or runbook for this integration.' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionProtocol rdf:type rdf:Property ;
    rdfs:label 'Encryption Protocol' ;
    rdfs:comment 'Encryption protocol used for data in transit (e.g., \'TLS 1.3\', \'AES-256\').' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorHandlingStrategy rdf:type rdf:Property ;
    rdfs:label 'Error Handling Strategy' ;
    rdfs:comment 'Strategy for handling errors during integration execution (retry, skip, halt, log and continue).' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationCode rdf:type rdf:Property ;
    rdfs:label 'Integration Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the integration for technical reference and logging.' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationName rdf:type rdf:Property ;
    rdfs:label 'Integration Name' ;
    rdfs:comment 'Human-readable name of the integration (e.g., \'KoboToolbox to DHIS2 Beneficiary Sync\', \'Salesforce to SAP Donor Gift Feed\').' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationPattern rdf:type rdf:Property ;
    rdfs:label 'Integration Pattern' ;
    rdfs:comment 'Technical integration pattern employed (API, ETL, webhook, file transfer, message queue, database replication).' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationType rdf:type rdf:Property ;
    rdfs:label 'Integration Type' ;
    rdfs:comment 'Classification of the integration pattern used (data sync, event stream, batch transfer, API integration, file exchange, webhook).' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFailedRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Failed Run Timestamp' ;
    rdfs:comment 'Timestamp of the most recent failed execution of this integration.' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSuccessfulRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Successful Run Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful execution of this integration.' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:monitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Monitoring Enabled' ;
    rdfs:comment 'Indicates whether automated monitoring and alerting is enabled for this integration (true) or not (false).' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of retry attempts configured for failed integration runs.' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percentage' ;
    rdfs:comment 'Target uptime percentage defined in the service level agreement for this integration (e.g., 99.50 for 99.5%).' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceEndpoint rdf:type rdf:Property ;
    rdfs:label 'Source Endpoint' ;
    rdfs:comment 'Technical endpoint, API URL, or file path from which data is extracted in the source system.' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncFrequency rdf:type rdf:Property ;
    rdfs:label 'Sync Frequency' ;
    rdfs:comment 'Frequency at which data is synchronized between source and target systems (real-time, hourly, daily, weekly, monthly, on-demand).' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncSchedule rdf:type rdf:Property ;
    rdfs:label 'Sync Schedule' ;
    rdfs:comment 'Detailed schedule specification (e.g., cron expression, time of day) for batch integrations.' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEndpoint rdf:type rdf:Property ;
    rdfs:label 'Target Endpoint' ;
    rdfs:comment 'Technical endpoint, API URL, or file path to which data is loaded in the target system.' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeoutSeconds rdf:type rdf:Property ;
    rdfs:label 'Timeout Seconds' ;
    rdfs:comment 'Maximum time in seconds allowed for a single integration execution before timeout.' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRecordsTransferred rdf:type rdf:Property ;
    rdfs:label 'Total Records Transferred' ;
    rdfs:comment 'Cumulative count of records successfully transferred through this integration since go-live.' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transformationLogic rdf:type rdf:Property ;
    rdfs:label 'Transformation Logic' ;
    rdfs:comment 'Description or reference to the transformation logic, mapping rules, or ETL script applied during data exchange.' ;
    rdfs:domain ind:PlatformIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentCost rdf:type rdf:Property ;
    rdfs:label 'Assessment Cost' ;
    rdfs:comment 'Total cost incurred for conducting the security assessment, including consultant fees, tool licenses, and internal resource costs.' ;
    rdfs:domain ind:SecurityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Assessment Frequency' ;
    rdfs:comment 'Planned frequency for conducting security assessments on this system (annual, semi-annual, quarterly, ad-hoc, or continuous monitoring).' ;
    rdfs:domain ind:SecurityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business identifier or reference number for the security assessment, used for tracking and reporting purposes.' ;
    rdfs:domain ind:SecurityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorCertification rdf:type rdf:Property ;
    rdfs:label 'Assessor Certification' ;
    rdfs:comment 'Professional certifications held by the assessor (e.g., CISSP, CEH, CISA, OSCP), demonstrating competence and credibility.' ;
    rdfs:domain ind:SecurityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryDataAtRisk rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Data At Risk' ;
    rdfs:comment 'Flag indicating whether the assessed system processes or stores beneficiary personally identifiable information (PII) or sensitive program data, requiring heightened protection per humanitarian standards.' ;
    rdfs:domain ind:SecurityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conductingEntityName rdf:type rdf:Property ;
    rdfs:label 'Conducting Entity Name' ;
    rdfs:comment 'Name of the organization, department, or individual who conducted the security assessment (e.g., internal IT Security team, external firm name).' ;
    rdfs:domain ind:SecurityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conductingEntityType rdf:type rdf:Property ;
    rdfs:label 'Conducting Entity Type' ;
    rdfs:comment 'Indicates whether the assessment was conducted by internal IT/security staff, external consultants/auditors, or a joint team.' ;
    rdfs:domain ind:SecurityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataClassificationAssessed rdf:type rdf:Property ;
    rdfs:label 'Data Classification Assessed' ;
    rdfs:comment 'Highest data classification level of information processed or stored on the assessed system, determining assessment rigor requirements.' ;
    rdfs:domain ind:SecurityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyRecommendations rdf:type rdf:Property ;
    rdfs:label 'Key Recommendations' ;
    rdfs:comment 'Primary recommendations for improving security posture based on assessment findings.' ;
    rdfs:domain ind:SecurityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodologyUsed rdf:type rdf:Property ;
    rdfs:label 'Methodology Used' ;
    rdfs:comment 'Security assessment methodology or framework used (e.g., OWASP Testing Guide, NIST SP 800-115, PTES, OSSTMM).' ;
    rdfs:domain ind:SecurityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDeadline rdf:type rdf:Property ;
    rdfs:label 'Remediation Deadline' ;
    rdfs:comment 'Target date by which identified vulnerabilities and findings must be remediated or mitigated.' ;
    rdfs:domain ind:SecurityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of remediation efforts for findings identified in this assessment.' ;
    rdfs:domain ind:SecurityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Report Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the detailed assessment report document stored in the document management system.' ;
    rdfs:domain ind:SecurityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolsUsed rdf:type rdf:Property ;
    rdfs:label 'Tools Used' ;
    rdfs:comment 'List of security tools and software used during the assessment (e.g., Nessus, Burp Suite, Metasploit, Qualys).' ;
    rdfs:domain ind:SecurityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityControlId rdf:type rdf:Property ;
    rdfs:label 'Security Control Id' ;
    rdfs:comment 'Unique identifier for the security control record. Primary key.' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcedPseaPolicyId rdf:type rdf:Property ;
    rdfs:label 'Enforced Psea Policy Id' ;
    rdfs:comment 'Foreign key linking to safeguarding.psea_policy. Business justification: Security controls (encryption, access restrictions, audit logging, data retention) implement specific safeguarding policy requirements. Compliance teams need to map which technical controls enforce wh' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PseaPolicy .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this security control record is currently active and in use (True) or has been archived or decommissioned (False).' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualMaintenanceCost rdf:type rdf:Property ;
    rdfs:label 'Annual Maintenance Cost' ;
    rdfs:comment 'Estimated annual cost to maintain, operate, and support this security control, including subscription fees, support contracts, and staff time.' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableDataClassification rdf:type rdf:Property ;
    rdfs:label 'Applicable Data Classification' ;
    rdfs:comment 'Comma-separated list of data classification levels protected by this control (e.g., restricted, confidential, internal, public). Indicates which data sensitivity tiers require this control.' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableSystems rdf:type rdf:Property ;
    rdfs:label 'Applicable Systems' ;
    rdfs:comment 'Comma-separated list of IT systems, platforms, or applications to which this security control applies (e.g., Salesforce, SAP, DHIS2, KoboToolbox, CommCare, network infrastructure).' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required Flag' ;
    rdfs:comment 'Indicates whether this control requires detailed audit logging and trail retention for compliance or forensic purposes (True/False).' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree to which the security control is automated: manual (human-executed), semi-automated (human-initiated with automated execution), or fully automated (no human intervention required).' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensatingControlFlag rdf:type rdf:Property ;
    rdfs:label 'Compensating Control Flag' ;
    rdfs:comment 'Indicates whether this control serves as a compensating control for another control that cannot be fully implemented (True/False).' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceMandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Mandatory Flag' ;
    rdfs:comment 'Indicates whether this control is mandatory for regulatory or donor compliance requirements (True) or is a best-practice recommendation (False).' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlDescription rdf:type rdf:Property ;
    rdfs:label 'Control Description' ;
    rdfs:comment 'Detailed description of the security control objective, scope, and implementation approach.' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDomain rdf:type rdf:Property ;
    rdfs:label 'Control Domain' ;
    rdfs:comment 'Primary security domain or category to which this control belongs (e.g., access management, encryption, vulnerability management, incident response). [ENUM-REF-CANDIDATE: access_management|asset_management|cryptography|physical_security|operations_security|communications_security|system_acquisition|supplier_relationships|incident_management|business_continuity|compliance|vulnerability_management|identity_management|network_security|endpoint_security|data_protection — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlIdentifier rdf:type rdf:Property ;
    rdfs:label 'Control Identifier' ;
    rdfs:comment 'External business identifier for the security control, typically following framework naming conventions (e.g., ISO-27001-A.9.1.1, NIST-CSF-PR.AC-1, CIS-5.1).' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlName rdf:type rdf:Property ;
    rdfs:label 'Control Name' ;
    rdfs:comment 'Human-readable name of the security control (e.g., Access Control Policy, Multi-Factor Authentication, Encryption at Rest).' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlObjective rdf:type rdf:Property ;
    rdfs:label 'Control Objective' ;
    rdfs:comment 'Specific security objective or goal that this control is designed to achieve (e.g., prevent unauthorized access, detect malware, ensure data integrity).' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlOwner rdf:type rdf:Property ;
    rdfs:label 'Control Owner' ;
    rdfs:comment 'Name or identifier of the individual or role responsible for the ongoing management and effectiveness of this security control.' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Control Owner Department' ;
    rdfs:comment 'Organizational department or unit to which the control owner belongs (e.g., IT Security, Infrastructure, Compliance).' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Classification of the control by its function: preventive (stops incidents), detective (identifies incidents), corrective (remediates incidents), deterrent (discourages threats), compensating (alternative control), or directive (policy-based).' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceLocation rdf:type rdf:Property ;
    rdfs:label 'Evidence Location' ;
    rdfs:comment 'File path, URL, or document reference where evidence of control implementation and effectiveness is stored for audit purposes.' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Exception Expiry Date' ;
    rdfs:comment 'Date when the granted exception expires and the control must be re-evaluated or implemented.' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Granted Flag' ;
    rdfs:comment 'Indicates whether a formal exception or waiver has been granted for non-implementation or partial implementation of this control (True/False).' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionJustification rdf:type rdf:Property ;
    rdfs:label 'Exception Justification' ;
    rdfs:comment 'Business or technical justification for granting an exception to this security control requirement.' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkMapping rdf:type rdf:Property ;
    rdfs:label 'Framework Mapping' ;
    rdfs:comment 'Comma-separated list of security frameworks and specific control identifiers to which this control maps (e.g., ISO-27001:A.9.1.1, NIST-CSF:PR.AC-1, CIS-Controls:5.1). Supports multi-framework compliance mapping.' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationCost rdf:type rdf:Property ;
    rdfs:label 'Implementation Cost' ;
    rdfs:comment 'Total cost incurred to implement this security control, including software licenses, hardware, consulting, and labor.' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'Date when the security control was fully implemented and became operational.' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationGuidance rdf:type rdf:Property ;
    rdfs:label 'Implementation Guidance' ;
    rdfs:comment 'Detailed guidance, procedures, or references for implementing and maintaining this security control.' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maturityLevel rdf:type rdf:Property ;
    rdfs:label 'Maturity Level' ;
    rdfs:comment 'Maturity assessment of the control implementation based on capability maturity model: initial (ad-hoc), developing (repeatable), defined (documented process), managed (measured and controlled), optimizing (continuous improvement).' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Date' ;
    rdfs:comment 'Planned date for the next scheduled assessment or audit of this security control.' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relatedPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Related Policy Reference' ;
    rdfs:comment 'Reference to the organizational policy, standard, or procedure document that governs this security control.' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which remediation actions must be completed to bring the control to effective status.' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Description of the action plan to address control deficiencies, gaps, or ineffectiveness identified during assessments.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingFrequency rdf:type rdf:Property ;
    rdfs:label 'Testing Frequency' ;
    rdfs:comment 'Scheduled frequency at which the security control effectiveness is tested or validated. [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|semi_annually|annually|ad_hoc — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSolution rdf:type rdf:Property ;
    rdfs:label 'Vendor Solution' ;
    rdfs:comment 'Name of the third-party vendor or technology solution used to implement this control (e.g., CrowdStrike, Qualys, Okta, Splunk).' ;
    rdfs:domain ind:SecurityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRequestId rdf:type rdf:Property ;
    rdfs:label 'Service Request Id' ;
    rdfs:comment 'Unique identifier for the IT service request ticket. Primary key.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:knowledgeArticleId rdf:type rdf:Property ;
    rdfs:label 'Knowledge Article Id' ;
    rdfs:comment 'Identifier of the knowledge base article used or created as a result of resolving this service request. Null if no article linked.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeArticle .

ind:primaryServiceStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who submitted the service request.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:relatedIncidentItIncidentId rdf:type rdf:Property ;
    rdfs:label 'Related Incident It Incident Id' ;
    rdfs:comment 'Identifier of a related major incident or problem ticket if this service request is linked to a broader system issue. Null if standalone.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItIncident .

ind:resultingChangeRequestId rdf:type rdf:Property ;
    rdfs:label 'Resulting Change Request Id' ;
    rdfs:comment 'Foreign key linking to technology.change_request. Business justification: Service requests can escalate to formal change requests when they require CAB approval or significant system modifications. N:1 relationship (service request escalates to change). Temporal note: FK po' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeRequest .

ind:assignmentGroup rdf:type rdf:Property ;
    rdfs:label 'Assignment Group' ;
    rdfs:comment 'Name of the IT support team or functional group responsible for handling the request (e.g., Desktop Support, Network Operations, Application Support, Field IT, Security Operations).' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactMethod rdf:type rdf:Property ;
    rdfs:label 'Contact Method' ;
    rdfs:comment 'Channel through which the service request was submitted: web portal (self-service), email, phone call, live chat, walk-in (in-person), or mobile app.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the service request was escalated to higher-level support or management (True = escalated, False = not escalated).' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'Date and time when the assigned technician first acknowledged or responded to the service request. Null if no response yet.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reopenedCount rdf:type rdf:Property ;
    rdfs:label 'Reopened Count' ;
    rdfs:comment 'Number of times the service request was reopened after initial resolution due to recurring issues or incomplete resolution.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requesterFeedback rdf:type rdf:Property ;
    rdfs:label 'Requester Feedback' ;
    rdfs:comment 'Free-text feedback or comments provided by the requester about the service experience. Null if no feedback provided.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Requester Satisfaction Rating' ;
    rdfs:comment 'Satisfaction score provided by the requester after resolution, typically on a scale of 1 to 5 (1 = very dissatisfied, 5 = very satisfied). Null if feedback not provided.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionCategory rdf:type rdf:Property ;
    rdfs:label 'Resolution Category' ;
    rdfs:comment 'Classification of how the request was resolved (e.g., hardware replacement, software configuration, password reset, user training, escalation to vendor, workaround provided). Null if not yet resolved.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRequestDescription rdf:type rdf:Property ;
    rdfs:label 'Service Request Description' ;
    rdfs:comment 'Detailed description of the issue or service need provided by the requester, including symptoms, error messages, and context.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRequestStatus rdf:type rdf:Property ;
    rdfs:label 'Service Request Status' ;
    rdfs:comment 'Current lifecycle status of the service request: open (newly submitted), assigned (allocated to technician), in_progress (actively being worked), pending_user (awaiting requester input), resolved (solution provided), closed (confirmed complete), or cancelled (withdrawn). [ENUM-REF-CANDIDATE: open|assigned|in_progress|pending_user|resolved|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the service request resolution exceeded the SLA target time (True = breached, False = within SLA).' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Target resolution time in hours as defined by the IT service level agreement for this request type and priority combination.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ticketNumber rdf:type rdf:Property ;
    rdfs:label 'Ticket Number' ;
    rdfs:comment 'Human-readable external ticket number assigned by the IT helpdesk system (e.g., INC-000012345, SR-20230415-001).' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeSpentHours rdf:type rdf:Property ;
    rdfs:label 'Time Spent Hours' ;
    rdfs:comment 'Total technician effort hours logged against this service request for resolution activities. Null if not yet tracked or resolved.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:softwareLicenseId rdf:type rdf:Property ;
    rdfs:label 'Software License Id' ;
    rdfs:comment 'Unique identifier for the software license record. Primary key.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualCost rdf:type rdf:Property ;
    rdfs:label 'Annual Cost' ;
    rdfs:comment 'The total annual cost of the license or subscription in the specified currency. For multi-year agreements, this represents the annualized cost. Used for budget tracking and cost allocation.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether the license or subscription is configured for automatic renewal. True if auto-renewal is active, false if manual renewal is required.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costPerSeat rdf:type rdf:Property ;
    rdfs:label 'Cost Per Seat' ;
    rdfs:comment 'The cost per individual license seat or user, calculated as annual cost divided by total seats purchased. Used for cost optimization and per-user budget allocation.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMissionCritical rdf:type rdf:Property ;
    rdfs:label 'Is Mission Critical' ;
    rdfs:comment 'Indicates whether this software is mission-critical to humanitarian operations or core business functions. True if downtime would severely impact program delivery or beneficiary services.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'The externally-known license key, agreement reference, or subscription identifier provided by the vendor (e.g., Microsoft 365 tenant ID, Salesforce org ID, SAP license key).' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'License Owner Email' ;
    rdfs:comment 'The email address of the license owner for renewal notifications and vendor communications.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseOwnerName rdf:type rdf:Property ;
    rdfs:label 'License Owner Name' ;
    rdfs:comment 'The name of the staff member or role responsible for managing this license, including renewals, compliance, and vendor relationship management.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current lifecycle state of the license: active (in use and compliant), expired (past renewal date), suspended (temporarily disabled), pending renewal (approaching expiration), cancelled (terminated), or trial (evaluation period).' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'The licensing model governing usage rights: perpetual (one-time purchase, indefinite use), subscription (recurring payment, time-bound), concurrent (shared pool of active sessions), named user (assigned to specific individuals), device (tied to hardware), site (location-based), enterprise (organization-wide), or open source (freely licensed). [ENUM-REF-CANDIDATE: perpetual|subscription|concurrent|named_user|device|site|enterprise|open_source — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'The billing cycle or payment schedule for the license: monthly, quarterly, annually, one-time (perpetual), or multi-year (prepaid multi-year subscription).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBusinessDomain rdf:type rdf:Property ;
    rdfs:label 'Primary Business Domain' ;
    rdfs:comment 'The primary business function or domain supported by this software (e.g., Donor Management, Program Management, Financial Management, Field Data Collection, Monitoring Evaluation and Learning).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productVersion rdf:type rdf:Property ;
    rdfs:label 'Product Version' ;
    rdfs:comment 'The version or release number of the licensed software product (e.g., SAP S/4HANA 2021, Salesforce Spring \'23, DHIS2 2.38).' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'The date the license was originally purchased or the subscription was first activated.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seatsAvailable rdf:type rdf:Property ;
    rdfs:label 'Seats Available' ;
    rdfs:comment 'The number of unused licenses available for assignment (calculated as total_seats_purchased minus seats_consumed).' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsConsumed rdf:type rdf:Property ;
    rdfs:label 'Seats Consumed' ;
    rdfs:comment 'The number of licenses currently assigned or actively in use by staff, volunteers, or partners. Used to track utilization and identify over-provisioning or under-provisioning.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportTier rdf:type rdf:Property ;
    rdfs:label 'Support Tier' ;
    rdfs:comment 'The level of vendor support included with the license: basic (email support), standard (business hours support), premium (24/7 support with SLA), enterprise (dedicated account manager), or community (open-source community support).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactEmail rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Email' ;
    rdfs:comment 'The email address of the technical contact for vendor support escalations and technical communications.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactName rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Name' ;
    rdfs:comment 'The name of the technical staff member responsible for software implementation, configuration, and technical support.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSeatsPurchased rdf:type rdf:Property ;
    rdfs:label 'Total Seats Purchased' ;
    rdfs:comment 'The total number of user licenses, seats, or entitlements purchased under this license agreement. For concurrent licenses, this represents the maximum simultaneous users allowed.' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Account Number' ;
    rdfs:comment 'The organization\'s customer account number or tenant identifier with the vendor (e.g., Salesforce Org ID, Microsoft tenant ID, SAP customer number).' ;
    rdfs:domain ind:SoftwareLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiEndpoint rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint' ;
    rdfs:comment 'Base URL or endpoint for the platforms application programming interface (API) if available.' ;
    rdfs:domain ind:SystemPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'End date or expiration date of the current contract or subscription agreement. Null for perpetual licenses or open-ended agreements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Start date of the current contract or subscription agreement for the platform.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hostingEnvironment rdf:type rdf:Property ;
    rdfs:label 'Hosting Environment' ;
    rdfs:comment 'Specific hosting environment or infrastructure provider (e.g., AWS, Azure, Google Cloud, On-Premise Data Center, Vendor-Hosted).' ;
    rdfs:domain ind:SystemPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMobileEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Mobile Enabled' ;
    rdfs:comment 'Indicates whether the platform has mobile application support or mobile-responsive interface (True/False).' ;
    rdfs:domain ind:SystemPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOfflineCapable rdf:type rdf:Property ;
    rdfs:label 'Is Offline Capable' ;
    rdfs:comment 'Indicates whether the platform supports offline data collection or operation with later synchronization (True/False). Critical for field operations in low-connectivity humanitarian contexts.' ;
    rdfs:domain ind:SystemPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformCode rdf:type rdf:Property ;
    rdfs:label 'Platform Code' ;
    rdfs:comment 'Short alphanumeric code or abbreviation used internally to reference the platform (e.g., KOBO, DHIS2, SFDC, SAP, WD).' ;
    rdfs:domain ind:SystemPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Official name of the digital platform or enterprise information system (e.g., KoboToolbox, CommCare, DHIS2, Salesforce Nonprofit Cloud, SAP S/4HANA for Nonprofits, Workday HCM, Raisers Edge NXT, Unit4 ERP, Power BI, Tableau).' ;
    rdfs:domain ind:SystemPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformStatus rdf:type rdf:Property ;
    rdfs:label 'Platform Status' ;
    rdfs:comment 'Current lifecycle status of the platform (Active, Inactive, Pilot, Sunset, Decommissioned, Under Implementation, Maintenance). [ENUM-REF-CANDIDATE: Active|Inactive|Pilot|Sunset|Decommissioned|Under Implementation|Maintenance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SystemPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'Categorical classification of the platform by its primary business function (e.g., ERP, CRM, HRIS, GIS, Data Collection, Business Intelligence, Grant Management, Donor Management, Case Management, Health Information System, Financial Management, Custom Application, Collaboration Platform, Other). [ENUM-REF-CANDIDATE: ERP|CRM|HRIS|GIS|Data Collection|Business Intelligence|Grant Management|Donor Management|Case Management|Health Information System|Financial Management|Custom Application|Collaboration Platform|Other — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SystemPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemOwner rdf:type rdf:Property ;
    rdfs:label 'System Owner' ;
    rdfs:comment 'Name or identifier of the individual or role responsible for the business ownership and governance of this platform.' ;
    rdfs:domain ind:SystemPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemPlatformDescription rdf:type rdf:Property ;
    rdfs:label 'System Platform Description' ;
    rdfs:comment 'Detailed description of the platforms purpose, capabilities, and business functions it supports.' ;
    rdfs:domain ind:SystemPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalOwner rdf:type rdf:Property ;
    rdfs:label 'Technical Owner' ;
    rdfs:comment 'Name or identifier of the individual or role responsible for the technical administration and support of this platform.' ;
    rdfs:domain ind:SystemPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLockedFlag rdf:type rdf:Property ;
    rdfs:label 'Account Locked Flag' ;
    rdfs:comment 'Indicates whether the account is locked due to excessive failed login attempts or security policy violation. True if locked; requires administrator intervention to unlock.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountLockedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Account Locked Timestamp' ;
    rdfs:comment 'Timestamp when the account was locked. Null if account has never been locked.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activeDirectoryGuid rdf:type rdf:Property ;
    rdfs:label 'Active Directory Guid' ;
    rdfs:comment 'Globally unique identifier assigned by Active Directory. Used for cross-system identity federation and single sign-on (SSO).' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commcareUsername rdf:type rdf:Property ;
    rdfs:label 'Commcare Username' ;
    rdfs:comment 'Username for CommCare mobile case management platform. Used for community health worker tracking and beneficiary follow-up.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProtectionAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Protection Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the user has acknowledged and accepted organizational data protection policies including GDPR, beneficiary data handling, and confidentiality requirements.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deprovisioningDate rdf:type rdf:Property ;
    rdfs:label 'Deprovisioning Date' ;
    rdfs:comment 'Date when the account was permanently deprovisioned and access was revoked across all systems. Typically occurs upon staff departure or contract end.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dhis2Username rdf:type rdf:Property ;
    rdfs:label 'Dhis2 Username' ;
    rdfs:comment 'Username for DHIS2 health program monitoring platform. Used for indicator tracking, aggregate reporting, and Monitoring Evaluation and Learning (MEL) activities.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorDataAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Data Access Flag' ;
    rdfs:comment 'Indicates whether the user has access to donor management and constituent relationship management (CRM) systems. True for fundraising and development staff.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failedLoginAttempts rdf:type rdf:Property ;
    rdfs:label 'Failed Login Attempts' ;
    rdfs:comment 'Count of consecutive failed login attempts since last successful authentication. Used for account lockout policies and security monitoring.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Field Access Flag' ;
    rdfs:comment 'Indicates whether the user has access to field operations systems and mobile data collection platforms. True for field staff and community health workers.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialSystemAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Financial System Access Flag' ;
    rdfs:comment 'Indicates whether the user has access to financial systems including General Ledger (GL), Accounts Payable (AP), Accounts Receivable (AR), and grant financial management. True for finance staff.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kobotoolboxUsername rdf:type rdf:Property ;
    rdfs:label 'Kobotoolbox Username' ;
    rdfs:comment 'Username for KoboToolbox field data collection platform. Used for beneficiary surveys, needs assessments, and humanitarian data collection.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Login Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful authentication to any organizational system. Used for dormant account detection and security monitoring.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastPasswordChangeDate rdf:type rdf:Property ;
    rdfs:label 'Last Password Change Date' ;
    rdfs:comment 'Date when the user last changed their password. Used to enforce password rotation policies and detect stale credentials.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mfaEnrolledFlag rdf:type rdf:Property ;
    rdfs:label 'Mfa Enrolled Flag' ;
    rdfs:comment 'Indicates whether the user has enrolled in multi-factor authentication. True if MFA is configured; false if only password authentication is enabled.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mfaMethod rdf:type rdf:Property ;
    rdfs:label 'Mfa Method' ;
    rdfs:comment 'The primary multi-factor authentication method configured for this account. None indicates MFA is not enabled.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileDeviceRegisteredFlag rdf:type rdf:Property ;
    rdfs:label 'Mobile Device Registered Flag' ;
    rdfs:comment 'Indicates whether the user has registered a mobile device for organizational access. True for users accessing CommCare, KoboToolbox, or other mobile platforms.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passwordExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Password Expiry Date' ;
    rdfs:comment 'Date when the current password expires and must be changed. Enforces organizational password rotation policy.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:privilegedAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Privileged Account Flag' ;
    rdfs:comment 'Indicates whether this is a privileged account with elevated permissions (administrator, super admin, system service). True for accounts requiring enhanced security monitoring.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:provisioningDate rdf:type rdf:Property ;
    rdfs:label 'Provisioning Date' ;
    rdfs:comment 'Date when the user account was initially created and provisioned across organizational systems.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remoteAccessEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Access Enabled Flag' ;
    rdfs:comment 'Indicates whether the user is authorized for remote access via VPN or external networks. True for users working from field locations or home offices.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceUserCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce User Code' ;
    rdfs:comment 'Unique user identifier in Salesforce Nonprofit Cloud. Links digital identity to donor management, constituent tracking, and campaign management activities.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapUserCode rdf:type rdf:Property ;
    rdfs:label 'Sap User Code' ;
    rdfs:comment 'User identifier in SAP S/4HANA for Nonprofits. Provides access to General Ledger (GL), Accounts Payable (AP), Accounts Receivable (AR), fund accounting, and procurement modules.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityTrainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Security Training Completion Date' ;
    rdfs:comment 'Date when the user completed mandatory information security and data protection training. Required for compliance with organizational security policies.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date when the account was suspended. Null if account has never been suspended.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:username rdf:type rdf:Property ;
    rdfs:label 'Username' ;
    rdfs:comment 'Unique username for system authentication. Primary login identifier across Active Directory, Salesforce, SAP, KoboToolbox, CommCare, DHIS2, and email systems.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayUserCode rdf:type rdf:Property ;
    rdfs:label 'Workday User Code' ;
    rdfs:comment 'User identifier in Workday Human Capital Management (HCM) system. Provides access to human resources, payroll, talent management, and learning modules.' ;
    rdfs:domain ind:UserAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualRemediationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Remediation Date' ;
    rdfs:comment 'Actual date when the vulnerability was successfully remediated or closed, after verification of fix effectiveness.' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedComponent rdf:type rdf:Property ;
    rdfs:label 'Affected Component' ;
    rdfs:comment 'Specific component, module, library, or service within the system that contains the vulnerability (e.g., Apache Struts, OpenSSL, Windows RDP).' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedDataClassification rdf:type rdf:Property ;
    rdfs:label 'Affected Data Classification' ;
    rdfs:comment 'Highest data classification level of information that could be exposed or compromised if this vulnerability is exploited.' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedVersion rdf:type rdf:Property ;
    rdfs:label 'Affected Version' ;
    rdfs:comment 'Version number or range of the affected software, application, or component that contains the vulnerability.' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceImpact rdf:type rdf:Property ;
    rdfs:label 'Compliance Impact' ;
    rdfs:comment 'Description of regulatory or compliance implications if the vulnerability is not remediated, including potential violations of donor requirements, GDPR, PCI-DSS, or other frameworks.' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cveIdentifier rdf:type rdf:Property ;
    rdfs:label 'Cve Identifier' ;
    rdfs:comment 'Standardized CVE identifier assigned by MITRE for publicly disclosed cybersecurity vulnerabilities. Format: CVE-YYYY-NNNNN.' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvssScore rdf:type rdf:Property ;
    rdfs:label 'Cvss Score' ;
    rdfs:comment 'Numerical severity score of the vulnerability based on CVSS framework, ranging from 0.0 (informational) to 10.0 (critical).' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cvssVector rdf:type rdf:Property ;
    rdfs:label 'Cvss Vector' ;
    rdfs:comment 'CVSS vector string representing the detailed scoring metrics (Attack Vector, Attack Complexity, Privileges Required, User Interaction, Scope, Confidentiality, Integrity, Availability).' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'Date when the vulnerability was first discovered or identified within the organization\'s environment.' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Discovery Method' ;
    rdfs:comment 'Method or source through which the vulnerability was identified (e.g., vulnerability scan, penetration test, vendor security advisory, internal audit).' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exploitabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Exploitability Status' ;
    rdfs:comment 'Current state of exploit availability and active exploitation: whether exploit code exists, is publicly available, or is being actively used in attacks.' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patchAvailable rdf:type rdf:Property ;
    rdfs:label 'Patch Available' ;
    rdfs:comment 'Indicates whether a vendor-provided patch or security update is available to remediate the vulnerability.' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patchIdentifier rdf:type rdf:Property ;
    rdfs:label 'Patch Identifier' ;
    rdfs:comment 'Vendor-assigned identifier or reference number for the security patch or update that addresses the vulnerability (e.g., MS21-001, KB4012598).' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceUrls rdf:type rdf:Property ;
    rdfs:label 'Reference Urls' ;
    rdfs:comment 'Additional reference links to external resources, security bulletins, or technical documentation related to the vulnerability (comma-separated list).' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationOwner rdf:type rdf:Property ;
    rdfs:label 'Remediation Owner' ;
    rdfs:comment 'Name of the individual or team responsible for remediating the vulnerability (e.g., IT Security Team, System Administrator, Application Owner).' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityRating rdf:type rdf:Property ;
    rdfs:label 'Severity Rating' ;
    rdfs:comment 'Qualitative severity classification of the vulnerability based on CVSS score ranges: Critical (9.0-10.0), High (7.0-8.9), Medium (4.0-6.9), Low (0.1-3.9), Informational (0.0).' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRemediationDate rdf:type rdf:Property ;
    rdfs:label 'Target Remediation Date' ;
    rdfs:comment 'Planned or target date by which the vulnerability should be remediated, based on severity and organizational risk tolerance.' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorAdvisoryUrl rdf:type rdf:Property ;
    rdfs:label 'Vendor Advisory Url' ;
    rdfs:comment 'Web link to the vendor\'s official security advisory or bulletin providing details about the vulnerability and remediation guidance.' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerabilityDescription rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Description' ;
    rdfs:comment 'Detailed technical description of the vulnerability, including the nature of the weakness, potential exploit vectors, and affected components.' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Status' ;
    rdfs:comment 'Current lifecycle status of the vulnerability: Open (newly identified), In Progress (remediation underway), Remediated (fix applied), Accepted (risk accepted), Mitigated (compensating controls applied), Closed (verified resolved).' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerabilityType rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Type' ;
    rdfs:comment 'Classification of the vulnerability by attack type or weakness category (e.g., SQL Injection, XSS, Buffer Overflow, Authentication Bypass). [ENUM-REF-CANDIDATE: SQL Injection|Cross-Site Scripting (XSS)|Buffer Overflow|Authentication Bypass|Privilege Escalation|Remote Code Execution|Denial of Service|Information Disclosure|Insecure Deserialization|Security Misconfiguration — promote to reference product]' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workaroundAvailable rdf:type rdf:Property ;
    rdfs:label 'Workaround Available' ;
    rdfs:comment 'Indicates whether a temporary workaround or compensating control is available to mitigate the vulnerability until a permanent fix is applied.' ;
    rdfs:domain ind:Vulnerability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Unique identifier for the certification record. Primary key for the certification entity.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verifiedByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Verified By Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Tracks which staff member verified volunteer certification authenticity. Critical for audit trail, compliance with safeguarding requirements, and accountability in volunteer credentialing process. No ' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'Name of the accreditation or regulatory body that oversees the issuing organization (e.g., national medical board, international humanitarian standards body). Used for credential validation.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentPassingScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Passing Score' ;
    rdfs:comment 'Minimum score required to pass the certification assessment. Used to determine whether the volunteer met competency standards.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Full name of the certification, credential, or training program (e.g., Certified Emergency Medical Technician, SPHERE Practitioner Certificate, PSEA Compliance Training, Community Health Worker Level 2).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Type of certification record: professional license (e.g., nursing, medical), certificate (e.g., first aid, SPHERE practitioner), training completion, self-assessed proficiency, verified competency, or compliance certificate (e.g., Protection from Sexual Exploitation and Abuse (PSEA), safeguarding).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'Regulatory or organizational compliance category this certification satisfies: Protection from Sexual Exploitation and Abuse (PSEA), safeguarding, data protection, security clearance, health and safety, ethics, or none for non-compliance certifications. [ENUM-REF-CANDIDATE: psea|safeguarding|data_protection|security|health_safety|ethics|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationHours rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours' ;
    rdfs:comment 'Number of continuing education or professional development hours required for renewal. Null if not applicable.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the certification cost amount.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfIssue rdf:type rdf:Property ;
    rdfs:label 'Country Of Issue' ;
    rdfs:comment 'Three-letter ISO country code of the country where the certification was issued. Relevant for professional licenses and country-specific credentials.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentEligible rdf:type rdf:Property ;
    rdfs:label 'Deployment Eligible' ;
    rdfs:comment 'Indicates whether this certification qualifies the volunteer for field deployment. True for certifications that meet deployment readiness criteria (verified, current, and role-appropriate).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'Name of the organization, institution, or authority that issued the certification (e.g., Red Cross, Sphere Association, Ministry of Health, professional licensing board, internal training department).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageOfCertification rdf:type rdf:Property ;
    rdfs:label 'Language Of Certification' ;
    rdfs:comment 'Primary language in which the certification training and assessment were conducted. Important for language-specific skill matching and deployment planning.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when the certification was most recently verified by the organization through documentation review or third-party confirmation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandatoryForRole rdf:type rdf:Property ;
    rdfs:label 'Mandatory For Role' ;
    rdfs:comment 'Indicates whether this certification is mandatory (required) for the volunteer\'s assigned role versus preferred (nice-to-have). Used for deployment readiness assessment and compliance tracking.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level' ;
    rdfs:comment 'Level of proficiency or competency in the skill: beginner (basic awareness), intermediate (can perform with supervision), advanced (can perform independently), expert (can train others), master (recognized authority).' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedByOrganization rdf:type rdf:Property ;
    rdfs:label 'Recognized By Organization' ;
    rdfs:comment 'Indicates whether this certification is formally recognized and accepted by the organization for volunteer deployment and role assignment. False for certifications that are recorded but not organizationally endorsed.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reimbursedByOrganization rdf:type rdf:Property ;
    rdfs:label 'Reimbursed By Organization' ;
    rdfs:comment 'Indicates whether the organization reimbursed the volunteer for the cost of obtaining this certification. Used for financial tracking and volunteer benefit reporting.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Indicates whether this certification requires periodic renewal to remain valid. True for time-limited certifications (e.g., first aid, PSEA training), false for permanent credentials.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skillCategory rdf:type rdf:Property ;
    rdfs:label 'Skill Category' ;
    rdfs:comment 'Primary category of the skill or competency. Aligns with organizational skill taxonomy including medical, logistics, language, psychosocial support (PSS), Water Sanitation and Hygiene (WASH), Information and Communication Technology for Development (ICT4D), community mobilization, protection, nutrition, and education. [ENUM-REF-CANDIDATE: medical|logistics|language|psychosocial|wash|ict4d|community_mobilization|protection|nutrition|education — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillName rdf:type rdf:Property ;
    rdfs:label 'Skill Name' ;
    rdfs:comment 'Specific name of the skill or competency (e.g., First Aid, Community Health Worker Training, SPHERE Standards, Gender-Based Violence (GBV) Response, Mid-Upper Arm Circumference (MUAC) Screening, Psychosocial Support (PSS) Facilitation).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingHours rdf:type rdf:Property ;
    rdfs:label 'Training Hours' ;
    rdfs:comment 'Total number of training or instruction hours completed to earn this certification. Used for volunteer contribution tracking and competency assessment.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedbackId rdf:type rdf:Property ;
    rdfs:label 'Feedback Id' ;
    rdfs:comment 'Unique identifier for the volunteer feedback record. Primary key.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpAssignedToStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Follow Up Assigned To Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Links volunteer feedback requiring follow-up to responsible staff member. Essential for volunteer satisfaction management, issue resolution tracking, and staff accountability. Existing follow_up_assig' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:trainingEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Training Enrollment Id' ;
    rdfs:comment 'Foreign key linking to volunteer.training_enrollment. Business justification: Feedback can be about training experiences in addition to deployment experiences. The feedback table has training_quality_rating and feedback_type fields suggesting feedback can be training-related. T' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingEnrollment .

ind:communicationRating rdf:type rdf:Property ;
    rdfs:label 'Communication Rating' ;
    rdfs:comment 'Numeric rating of the effectiveness and clarity of communication between the organization and the volunteer.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentToFollowUp rdf:type rdf:Property ;
    rdfs:label 'Consent To Follow Up' ;
    rdfs:comment 'Boolean flag indicating whether the volunteer has consented to be contacted for follow-up discussion or clarification regarding their feedback.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feedbackType rdf:type rdf:Property ;
    rdfs:label 'Feedback Type' ;
    rdfs:comment 'Categorization of the feedback subject area: deployment experience, training quality, organizational support, general satisfaction, or incident-related feedback.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAssignedTo rdf:type rdf:Property ;
    rdfs:label 'Follow Up Assigned To' ;
    rdfs:comment 'Name or identifier of the staff member or team responsible for reviewing and acting on this feedback.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed Date' ;
    rdfs:comment 'The date on which follow-up actions related to this feedback were completed and the case was closed.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactPerceptionRating rdf:type rdf:Property ;
    rdfs:label 'Impact Perception Rating' ;
    rdfs:comment 'Numeric rating reflecting the volunteer\'s perception of the impact and meaningfulness of their contribution to the program or mission.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netPromoterScore rdf:type rdf:Property ;
    rdfs:label 'Net Promoter Score' ;
    rdfs:comment 'Net Promoter Score (NPS) rating provided by the volunteer, indicating likelihood to recommend the volunteer opportunity to others. Typically on a 0-10 scale.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Overall Satisfaction Rating' ;
    rdfs:comment 'Numeric rating of the volunteer\'s overall satisfaction with their experience. Typically on a scale of 1-5 or 1-10 depending on organizational standard.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualitativeComments rdf:type rdf:Property ;
    rdfs:label 'Qualitative Comments' ;
    rdfs:comment 'Free-text qualitative feedback and comments provided by the volunteer about their experience, suggestions for improvement, or specific observations.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingScaleMax rdf:type rdf:Property ;
    rdfs:label 'Rating Scale Max' ;
    rdfs:comment 'The maximum value of the rating scale used for this feedback submission (e.g., 5 for 1-5 scale, 10 for 1-10 scale). Enables normalization across different survey instruments.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyRating rdf:type rdf:Property ;
    rdfs:label 'Safety Rating' ;
    rdfs:comment 'Numeric rating of the volunteer\'s perception of safety and security during their deployment or engagement.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suggestions rdf:type rdf:Property ;
    rdfs:label 'Suggestions' ;
    rdfs:comment 'Specific suggestions or recommendations provided by the volunteer for improving volunteer experience, program delivery, or organizational processes.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisionRating rdf:type rdf:Property ;
    rdfs:label 'Supervision Rating' ;
    rdfs:comment 'Numeric rating of the quality of supervision and guidance provided to the volunteer during their engagement.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportQualityRating rdf:type rdf:Property ;
    rdfs:label 'Support Quality Rating' ;
    rdfs:comment 'Numeric rating of the quality of organizational support provided to the volunteer during their deployment or engagement.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyVersion rdf:type rdf:Property ;
    rdfs:label 'Survey Version' ;
    rdfs:comment 'Version number or identifier of the survey instrument used, enabling longitudinal analysis and accounting for changes in feedback collection methodology over time.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingQualityRating rdf:type rdf:Property ;
    rdfs:label 'Training Quality Rating' ;
    rdfs:comment 'Numeric rating of the quality and adequacy of training provided to the volunteer prior to or during their deployment.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wouldVolunteerAgain rdf:type rdf:Property ;
    rdfs:label 'Would Volunteer Again' ;
    rdfs:comment 'Boolean flag indicating whether the volunteer expressed willingness to volunteer with the organization again in the future. Key retention indicator.' ;
    rdfs:domain ind:Feedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hourLogId rdf:type rdf:Property ;
    rdfs:label 'Hour Log Id' ;
    rdfs:comment 'Unique identifier for the volunteer hour log entry. Primary key for the hour log record.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roleId rdf:type rdf:Property ;
    rdfs:label 'Role Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer_role. Business justification: Hour logs record time worked in the context of performing a specific volunteer role. The hour_log table has skill_utilized (STRING) which is a denormalized representation of the role/skill context. No' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Role .

ind:scheduleId rdf:type rdf:Property ;
    rdfs:label 'Schedule Id' ;
    rdfs:comment 'Foreign key linking to volunteer.schedule. Business justification: Hour logs often record time worked against scheduled shifts. While volunteers can log hours for ad-hoc activities not tied to a schedule, many hour logs are for scheduled activities. This FK (nullable' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Schedule .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center or organizational unit to which the volunteer hours are attributed. Supports internal cost allocation and reporting.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceCode rdf:type rdf:Property ;
    rdfs:label 'Device Code' ;
    rdfs:comment 'Identifier of the device used to submit or verify the volunteer hours. Supports digital check-in and GPS verification methods.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorReportEligible rdf:type rdf:Property ;
    rdfs:label 'Donor Report Eligible' ;
    rdfs:comment 'Flag indicating whether the volunteer hours are eligible for inclusion in donor reports and institutional compliance reporting.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fairMarketValueRate rdf:type rdf:Property ;
    rdfs:label 'Fair Market Value Rate' ;
    rdfs:comment 'Fair market value rate per hour used to calculate the in-kind contribution value of volunteer hours. Based on IRS guidelines or local equivalents.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grantAllocationCode rdf:type rdf:Property ;
    rdfs:label 'Grant Allocation Code' ;
    rdfs:comment 'Grant or fund code to which the volunteer hours are allocated. Enables budget versus actual (BvA) reporting on volunteer effort.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursClaimed rdf:type rdf:Property ;
    rdfs:label 'Hours Claimed' ;
    rdfs:comment 'Number of volunteer hours claimed or self-reported by the volunteer for the activity. Initial submission value before verification.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursVerified rdf:type rdf:Property ;
    rdfs:label 'Hours Verified' ;
    rdfs:comment 'Number of volunteer hours verified and approved by a supervisor or through automated validation. Final accepted value for reporting.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inKindValue rdf:type rdf:Property ;
    rdfs:label 'In Kind Value' ;
    rdfs:comment 'Calculated in-kind contribution value of the volunteer hours (hours_verified × fair_market_value_rate). Used for donor reporting and financial statements.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGroupActivity rdf:type rdf:Property ;
    rdfs:label 'Is Group Activity' ;
    rdfs:comment 'Flag indicating whether the volunteer activity was performed as part of a group or team (true) versus individually (false).' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOvertime rdf:type rdf:Property ;
    rdfs:label 'Is Overtime' ;
    rdfs:comment 'Flag indicating whether the volunteer hours exceed the standard expected commitment for the period. Used for volunteer engagement monitoring.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVirtual rdf:type rdf:Property ;
    rdfs:label 'Is Virtual' ;
    rdfs:comment 'Flag indicating whether the volunteer activity was performed virtually or remotely (true) versus on-site (false).' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logDate rdf:type rdf:Property ;
    rdfs:label 'Log Date' ;
    rdfs:comment 'The calendar date on which the volunteer hours were contributed. Primary business event date for timesheet reporting.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionMilestoneTriggered rdf:type rdf:Property ;
    rdfs:label 'Recognition Milestone Triggered' ;
    rdfs:comment 'Flag indicating whether this hour log entry triggered a volunteer recognition milestone (e.g., 100 hours, 500 hours). Used to automate recognition workflows.' ;
    rdfs:domain ind:HourLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentReportId rdf:type rdf:Property ;
    rdfs:label 'Incident Report Id' ;
    rdfs:comment 'Unique identifier for the volunteer incident report record. Primary key.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedRegistrantId rdf:type rdf:Property ;
    rdfs:label 'Affected Registrant Id' ;
    rdfs:comment 'Foreign key linking to beneficiary.registrant. Business justification: Incidents involving beneficiaries during volunteer service delivery must be tracked for safeguarding, protection incident reporting, and duty of care. Links incidents to affected beneficiaries for cas' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registrant .

ind:primaryIncidentStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Incident Staff Member Id' ;
    rdfs:comment 'Identifier of the staff member who reported or documented the incident. Links to workforce/staff master data.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:primaryIncidentVolunteerId rdf:type rdf:Property ;
    rdfs:label 'Primary Incident Volunteer Id' ;
    rdfs:comment 'Identifier of the primary volunteer involved in the incident. Links to the volunteer master record.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:volunteerTeamId rdf:type rdf:Property ;
    rdfs:label 'Volunteer Team Id' ;
    rdfs:comment 'Foreign key linking to volunteer.volunteer_team. Business justification: Incidents can occur during team-based activities and may involve or affect an entire volunteer team. While many incidents are individual-level, team-based incidents (e.g., security incident affecting ' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VolunteerTeam .

ind:incidentLocation rdf:type rdf:Property ;
    rdfs:label 'Incident Location' ;
    rdfs:comment 'Textual description of where the incident occurred, including facility name, address, field site, or geographic area. Supports situational awareness and risk mapping.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReportStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Report Status' ;
    rdfs:comment 'Current lifecycle status of the incident report: open (newly reported, awaiting review), under_review (being assessed or investigated), resolved (actions completed, awaiting closure), closed (case finalized).' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryType rdf:type rdf:Property ;
    rdfs:label 'Injury Type' ;
    rdfs:comment 'Classification of the physical or psychological injury sustained: physical_injury, psychological_trauma, illness, no_injury. Used for health and safety trend analysis.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClaimFiled rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Filed' ;
    rdfs:comment 'Indicates whether an insurance claim was filed related to this incident for medical expenses, liability, or other covered losses. True if filed, False otherwise.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Number' ;
    rdfs:comment 'Reference number assigned by the insurance provider for the claim related to this incident. Supports financial tracking and claim resolution.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationRequired rdf:type rdf:Property ;
    rdfs:label 'Investigation Required' ;
    rdfs:comment 'Indicates whether a formal investigation is required for this incident based on severity, type, or organizational policy. True if investigation needed, False otherwise.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalAttentionRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Attention Required' ;
    rdfs:comment 'Indicates whether the incident required medical attention or treatment for the volunteer. True if medical care was needed, False otherwise.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalFacilityName rdf:type rdf:Property ;
    rdfs:label 'Medical Facility Name' ;
    rdfs:comment 'Name of the medical facility, clinic, or hospital where the volunteer received treatment, if applicable. Supports insurance claims and follow-up care coordination.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policeReportFiled rdf:type rdf:Property ;
    rdfs:label 'Police Report Filed' ;
    rdfs:comment 'Indicates whether a police report or formal law enforcement notification was filed for this incident. True if filed, False otherwise. Required for certain incident types and insurance claims.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policeReportNumber rdf:type rdf:Property ;
    rdfs:label 'Police Report Number' ;
    rdfs:comment 'Official reference number or case number assigned by law enforcement authorities if a police report was filed. Supports legal follow-up and insurance claims.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralToSupportServices rdf:type rdf:Property ;
    rdfs:label 'Referral To Support Services' ;
    rdfs:comment 'Description of any referrals made to support services such as Psychosocial Support (PSS), counseling, legal aid, or victim assistance programs. Documents duty-of-care follow-up.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDate rdf:type rdf:Property ;
    rdfs:label 'Report Date' ;
    rdfs:comment 'The date when the incident was formally reported to the organization. Used to measure reporting timeliness and response lag.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Timestamp' ;
    rdfs:comment 'The precise date and time when the incident report was submitted into the system. Supports audit trail and response time analysis.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome or resolution of the incident case, including any disciplinary actions, compensation provided, or systemic improvements made. Documents accountability and closure.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessCount rdf:type rdf:Property ;
    rdfs:label 'Witness Count' ;
    rdfs:comment 'Number of witnesses to the incident who provided statements or corroborating information. Supports investigation credibility and evidence gathering.' ;
    rdfs:domain ind:IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recognitionId rdf:type rdf:Property ;
    rdfs:label 'Recognition Id' ;
    rdfs:comment 'Unique identifier for the volunteer recognition record. Primary key.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nominatorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Nominator Staff Member Id' ;
    rdfs:comment 'Identifier of the person (staff member, volunteer, or partner) who nominated this volunteer for recognition. Links to the workforce or volunteer master record. Nullable for system-generated recognitions based on automated milestones.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:awardDescription rdf:type rdf:Property ;
    rdfs:label 'Award Description' ;
    rdfs:comment 'Detailed narrative describing the reason for the recognition, the volunteer\'s contributions, and the impact achieved. Used in certificates, announcements, and donor reports.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardTitle rdf:type rdf:Property ;
    rdfs:label 'Award Title' ;
    rdfs:comment 'Formal name or title of the recognition award. Examples: \'Volunteer of the Year\', \'500 Hours Service Award\', \'Outstanding Community Health Worker\', \'Emergency Response Excellence Award\'.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursMilestoneThreshold rdf:type rdf:Property ;
    rdfs:label 'Hours Milestone Threshold' ;
    rdfs:comment 'Cumulative volunteer hours threshold that triggered this recognition, if applicable. For example, 100 hours, 500 hours, 1000 hours milestones. Nullable for recognitions not based on hours served.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monetaryValue rdf:type rdf:Property ;
    rdfs:label 'Monetary Value' ;
    rdfs:comment 'Monetary value of any tangible award or gift accompanying the recognition, in the organization\'s functional currency. Used for budget tracking and tax reporting. Nullable for non-monetary recognitions.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominationDate rdf:type rdf:Property ;
    rdfs:label 'Nomination Date' ;
    rdfs:comment 'Date on which the volunteer was nominated for this recognition. Precedes approval and award dates in the recognition lifecycle.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nominatorType rdf:type rdf:Property ;
    rdfs:label 'Nominator Type' ;
    rdfs:comment 'Category of the nominator. Staff indicates organizational employee, volunteer indicates peer volunteer, partner indicates external partner organization representative, beneficiary indicates program participant, system indicates automated milestone-based nomination.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Public Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the volunteer consented to public acknowledgment of this recognition in external communications, social media, or donor reports. True if public acknowledgment is permitted, false if volunteer requested privacy.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionNumber rdf:type rdf:Property ;
    rdfs:label 'Recognition Number' ;
    rdfs:comment 'Human-readable business identifier for the recognition event, formatted as REC- followed by 8 digits. Used for tracking and reference in volunteer engagement reports.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current lifecycle state of the recognition. Nominated indicates initial submission, approved indicates management approval, awarded indicates formal presentation completed, declined indicates volunteer opted out, revoked indicates withdrawn due to policy violation.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionType rdf:type rdf:Property ;
    rdfs:label 'Recognition Type' ;
    rdfs:comment 'Category of recognition awarded to the volunteer. Includes length-of-service award (milestone anniversaries), outstanding contribution (exceptional impact), skills milestone (competency achievement), program completion certificate (training or project completion), public acknowledgment (featured in communications), and peer nomination (colleague-nominated honors).' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillsCategory rdf:type rdf:Property ;
    rdfs:label 'Skills Category' ;
    rdfs:comment 'Specific skill area or competency domain for which the volunteer is being recognized, if applicable. Examples: \'Community Health\', \'Data Collection\', \'Logistics\', \'Psychosocial Support (PSS)\', \'Water Sanitation and Hygiene (WASH)\'. Nullable for non-skills-based recognitions. [ENUM-REF-CANDIDATE: community_health|data_collection|logistics|pss|wash|nutrition|education|protection|emergency_response — promote to reference product]' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualHours rdf:type rdf:Property ;
    rdfs:label 'Actual Hours' ;
    rdfs:comment 'Actual number of volunteer hours served, recorded after shift completion. May differ from planned hours due to early/late arrival or departure.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedVolunteerCount rdf:type rdf:Property ;
    rdfs:label 'Assigned Volunteer Count' ;
    rdfs:comment 'Number of volunteers currently assigned to this schedule. Used to track fulfillment against required count.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendanceStatus rdf:type rdf:Property ;
    rdfs:label 'Attendance Status' ;
    rdfs:comment 'Status of volunteer attendance for this schedule: scheduled (not yet started), checked_in (volunteer arrived), checked_out (volunteer departed), no_show (did not attend), excused_absence (absence approved), late (arrived after start time), early_departure (left before end time). [ENUM-REF-CANDIDATE: scheduled|checked_in|checked_out|no_show|excused_absence|late|early_departure — promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Date and time when the schedule was cancelled. Null if schedule was not cancelled.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Timestamp' ;
    rdfs:comment 'Date and time when the volunteer checked in or arrived for the shift. Used for attendance tracking and actual hours calculation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check Out Timestamp' ;
    rdfs:comment 'Date and time when the volunteer checked out or departed from the shift. Used for attendance tracking and actual hours calculation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the volunteer confirmed their acceptance of this schedule assignment. Represents a key lifecycle event.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conflictFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Flag' ;
    rdfs:comment 'Boolean indicator of whether this schedule conflicts with the volunteer\'s availability or other assignments. True if conflict detected, False otherwise.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictReason rdf:type rdf:Property ;
    rdfs:label 'Conflict Reason' ;
    rdfs:comment 'Description of the scheduling conflict if conflict_flag is true (e.g., \'Overlaps with another assignment\', \'Outside volunteer availability window\').' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationAddress rdf:type rdf:Property ;
    rdfs:label 'Location Address' ;
    rdfs:comment 'Full street address of the volunteer assignment location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCity rdf:type rdf:Property ;
    rdfs:label 'Location City' ;
    rdfs:comment 'City or municipality where the volunteer assignment takes place.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationLatitude rdf:type rdf:Property ;
    rdfs:label 'Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the volunteer assignment location. Used for mapping and Geographic Information System (GIS) integration.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationLongitude rdf:type rdf:Property ;
    rdfs:label 'Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the volunteer assignment location. Used for mapping and Geographic Information System (GIS) integration.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideApproved rdf:type rdf:Property ;
    rdfs:label 'Override Approved' ;
    rdfs:comment 'Boolean indicator of whether a scheduling conflict or policy exception has been approved by a coordinator. True if override approved, False otherwise.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Business justification for approving a scheduling override or exception (e.g., \'Emergency response requires additional coverage\', \'Volunteer requested exception\').' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedHours rdf:type rdf:Property ;
    rdfs:label 'Planned Hours' ;
    rdfs:comment 'Expected number of volunteer hours for this schedule, calculated from shift start and end times or manually entered for ongoing assignments.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Date and time when the schedule was published and communicated to volunteers. Represents a key lifecycle event.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recurrenceEndDate rdf:type rdf:Property ;
    rdfs:label 'Recurrence End Date' ;
    rdfs:comment 'Date when the recurring schedule pattern ends. Null for one-time schedules or open-ended recurring schedules.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredVolunteerCount rdf:type rdf:Property ;
    rdfs:label 'Required Volunteer Count' ;
    rdfs:comment 'Number of volunteers needed for this schedule or shift. Used for capacity planning and coverage management.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Human-readable business identifier for the schedule, used for communication and coordination purposes (e.g., SCH-2024-001).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the schedule by its nature: shift (regular time-bound shift), event (one-time event), field_assignment (field deployment), ongoing (continuous assignment), ad_hoc (unplanned), emergency_response (disaster/crisis response).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift End Timestamp' ;
    rdfs:comment 'Date and time when the volunteer shift or assignment ends. Used to calculate shift duration and volunteer hours.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift Start Timestamp' ;
    rdfs:comment 'Date and time when the volunteer shift or assignment begins. Represents the principal business event time for this schedule.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stipendId rdf:type rdf:Property ;
    rdfs:label 'Stipend Id' ;
    rdfs:comment 'Unique identifier for the stipend record. Primary key.' ;
    rdfs:domain ind:Stipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disbursementReference rdf:type rdf:Property ;
    rdfs:label 'Disbursement Reference' ;
    rdfs:comment 'External reference number from the payment system or bank transaction. Used for reconciliation and audit.' ;
    rdfs:domain ind:Stipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Reportable Flag' ;
    rdfs:comment 'Indicates whether this stipend must be reported to the donor as part of grant reporting requirements. True if reportable, False otherwise.' ;
    rdfs:domain ind:Stipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inKindDescription rdf:type rdf:Property ;
    rdfs:label 'In Kind Description' ;
    rdfs:comment 'Detailed description of in-kind support provided when stipend_type is in_kind_support. Includes Non-Food Items (NFI), protective equipment, or other goods.' ;
    rdfs:domain ind:Stipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileMoneyNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Money Number' ;
    rdfs:comment 'Mobile money account number or phone number used for mobile money transfer when payment_method is mobile_money.' ;
    rdfs:domain ind:Stipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period End Date' ;
    rdfs:comment 'End date of the period for which this stipend is provided. Used for per diem and periodic allowances.' ;
    rdfs:domain ind:Stipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period Start Date' ;
    rdfs:comment 'Start date of the period for which this stipend is provided. Used for per diem and periodic allowances.' ;
    rdfs:domain ind:Stipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Amount' ;
    rdfs:comment 'Stipend amount converted to the organization\'s reporting currency using the exchange_rate. Used for consolidated financial reporting.' ;
    rdfs:domain ind:Stipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stipendNumber rdf:type rdf:Property ;
    rdfs:label 'Stipend Number' ;
    rdfs:comment 'Human-readable unique identifier or reference number for this stipend transaction, used for tracking and reconciliation.' ;
    rdfs:domain ind:Stipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stipendType rdf:type rdf:Property ;
    rdfs:label 'Stipend Type' ;
    rdfs:comment 'Category of stipend provided to the volunteer. Distinguishes between cash allowances and in-kind support.' ;
    rdfs:domain ind:Stipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxFormType rdf:type rdf:Property ;
    rdfs:label 'Tax Form Type' ;
    rdfs:comment 'Type of tax form required for reporting this stipend (e.g., 1099-MISC, W-2, local tax form). Applicable when tax_reportable_flag is True.' ;
    rdfs:domain ind:Stipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reportable Flag' ;
    rdfs:comment 'Indicates whether this stipend is reportable for tax purposes in the applicable jurisdiction. True if reportable, False otherwise.' ;
    rdfs:domain ind:Stipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingId rdf:type rdf:Property ;
    rdfs:label 'Training Id' ;
    rdfs:comment 'Unique identifier for the training program. Primary key.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Training .

ind:certificationAwarded rdf:type rdf:Property ;
    rdfs:label 'Certification Awarded' ;
    rdfs:comment 'Name of the certificate or credential awarded to volunteers upon successful completion of the training program.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationValidityMonths rdf:type rdf:Property ;
    rdfs:label 'Certification Validity Months' ;
    rdfs:comment 'Number of months the certification remains valid before renewal or recertification is required. Null if certification does not expire.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chsStandardAlignment rdf:type rdf:Property ;
    rdfs:label 'Chs Standard Alignment' ;
    rdfs:comment 'Specific Core Humanitarian Standard (CHS) commitments that this training addresses, ensuring accountability and quality in humanitarian response.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerParticipant rdf:type rdf:Property ;
    rdfs:label 'Cost Per Participant' ;
    rdfs:comment 'Average cost incurred by the organization per volunteer participant for delivering this training, including materials, facilitator fees, and venue costs. Used for budget planning and grant reporting.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date when this training program is scheduled to be retired or replaced. Null if no end date is planned.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandatoryForRoles rdf:type rdf:Property ;
    rdfs:label 'Mandatory For Roles' ;
    rdfs:comment 'Comma-separated list of volunteer role codes or titles for which this training is mandatory before deployment or assignment.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsUrl rdf:type rdf:Property ;
    rdfs:label 'Materials Url' ;
    rdfs:comment 'Web URL where training materials, resources, and documentation can be accessed by volunteers and facilitators.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxParticipants rdf:type rdf:Property ;
    rdfs:label 'Max Participants' ;
    rdfs:comment 'Maximum number of volunteers that can enroll in a single session or cohort of this training program. Null if no limit.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sphereStandardAlignment rdf:type rdf:Property ;
    rdfs:label 'Sphere Standard Alignment' ;
    rdfs:comment 'Specific SPHERE Humanitarian Charter and Minimum Standards chapters or technical standards that this training covers (e.g., WASH, Shelter, Health).' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCategory rdf:type rdf:Property ;
    rdfs:label 'Training Category' ;
    rdfs:comment 'Classification of the training program. Categories include safety and security, technical skills, Core Humanitarian Standard (CHS) orientation, SPHERE standards, Gender-Based Violence (GBV) awareness, Protection from Sexual Exploitation and Abuse (PSEA), first aid, and other capacity-building areas.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCode rdf:type rdf:Property ;
    rdfs:label 'Training Code' ;
    rdfs:comment 'Externally-known unique code for the training program used in volunteer systems and communications.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDescription rdf:type rdf:Property ;
    rdfs:label 'Training Description' ;
    rdfs:comment 'Detailed description of the training program content, learning objectives, and expected outcomes for volunteers.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingStatus rdf:type rdf:Property ;
    rdfs:label 'Training Status' ;
    rdfs:comment 'Current lifecycle status of the training program: draft (under development), active (available for enrollment), suspended (temporarily unavailable), retired (no longer offered), or under review (being updated).' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Instructor Staff Member Id' ;
    rdfs:comment 'Foreign key linking to workforce.staff_member. Business justification: Links volunteer training enrollment to staff member who delivered the training. Essential for instructor workload management, training quality assessment, and compliance with training delivery standar' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:assessmentAttempts rdf:type rdf:Property ;
    rdfs:label 'Assessment Attempts' ;
    rdfs:comment 'Number of times the volunteer attempted the training course assessment.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceTrainingCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Training Category' ;
    rdfs:comment 'Category of compliance or regulatory training that this enrollment represents, such as Protection from Sexual Exploitation and Abuse (PSEA), Core Humanitarian Standard (CHS), safeguarding, data protection, health and safety, or financial integrity. [ENUM-REF-CANDIDATE: psea|chs|safeguarding|data_protection|health_safety|financial_integrity|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationCredits rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Credits' ;
    rdfs:comment 'Number of continuing education or professional development credits earned by the volunteer upon successful completion of the training course.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentCost rdf:type rdf:Property ;
    rdfs:label 'Enrollment Cost' ;
    rdfs:comment 'Cost incurred by the organization for enrolling the volunteer in the training course, including tuition, materials, and administrative fees.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Enrollment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the enrollment cost.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSource rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source' ;
    rdfs:comment 'Source or channel through which the volunteer was enrolled in the training course.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the training enrollment indicating the volunteers progress through the course.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Recertification Due Date' ;
    rdfs:comment 'Date by which the volunteer must complete recertification or refresher training to maintain their certification status.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recertification Required Flag' ;
    rdfs:comment 'Indicates whether the volunteer is required to undergo recertification or refresher training after the certificate expiry date.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingDeliveryMode rdf:type rdf:Property ;
    rdfs:label 'Training Delivery Mode' ;
    rdfs:comment 'Mode or format in which the training course was delivered to the volunteer.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingLanguage rdf:type rdf:Property ;
    rdfs:label 'Training Language' ;
    rdfs:comment 'Primary language in which the training course content was delivered to the volunteer.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingStartDate rdf:type rdf:Property ;
    rdfs:label 'Training Start Date' ;
    rdfs:comment 'Date on which the volunteer began the training course.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingWithdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Training Withdrawal Date' ;
    rdfs:comment 'Date on which the volunteer withdrew from the training course before completion.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availabilityHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Availability Hours Per Week' ;
    rdfs:comment 'Number of hours per week the volunteer is available to contribute, used for scheduling and capacity planning.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current availability status of the volunteer for new assignments. Available indicates ready for deployment, unavailable indicates temporarily not available, on assignment indicates currently deployed, on leave indicates scheduled absence, and inactive indicates not currently volunteering.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'Date when the most recent background check was completed for the volunteer.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Status of the volunteers background check or vetting process. Not required indicates no check needed for this role, pending indicates check requested, in progress indicates check underway, cleared indicates check passed, flagged indicates issues identified, and expired indicates check needs renewal.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifications rdf:type rdf:Property ;
    rdfs:label 'Certifications' ;
    rdfs:comment 'Comma-separated list of professional certifications, licenses, and credentials held by the volunteer, such as first aid, WASH (Water Sanitation and Hygiene) training, PSS (Psychosocial Support) certification, or medical licenses.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactRelationship rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Relationship' ;
    rdfs:comment 'Relationship of the emergency contact to the volunteer, such as spouse, parent, sibling, or friend.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalVolunteerCode rdf:type rdf:Property ;
    rdfs:label 'External Volunteer Code' ;
    rdfs:comment 'Business identifier for the volunteer as known in Microsoft Dynamics 365 for Nonprofits or other external systems. Used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstVolunteerDate rdf:type rdf:Property ;
    rdfs:label 'First Volunteer Date' ;
    rdfs:comment 'Date of the volunteers first volunteer activity or assignment with the organization.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicBase rdf:type rdf:Property ;
    rdfs:label 'Geographic Base' ;
    rdfs:comment 'Primary geographic location or region where the volunteer is based and prefers to serve, used for matching volunteers to local programs and field operations.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVolunteerDate rdf:type rdf:Property ;
    rdfs:label 'Last Volunteer Date' ;
    rdfs:comment 'Date of the volunteers most recent volunteer activity or assignment with the organization.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completion Date' ;
    rdfs:comment 'Date when the volunteer completed all onboarding requirements and became eligible for deployment.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Current status of the volunteers onboarding process. Pending indicates application received, in progress indicates onboarding steps underway, completed indicates fully onboarded and ready for deployment, expired indicates onboarding credentials need renewal, and inactive indicates volunteer is not currently active.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionLevel rdf:type rdf:Property ;
    rdfs:label 'Recognition Level' ;
    rdfs:comment 'Recognition tier or award level assigned to the volunteer based on their contribution hours, impact, and tenure. Used for volunteer appreciation programs and engagement tracking.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skills rdf:type rdf:Property ;
    rdfs:label 'Skills' ;
    rdfs:comment 'Comma-separated list of skills, competencies, and professional qualifications the volunteer possesses, used for matching volunteers to program needs and deployment opportunities.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalVolunteerHours rdf:type rdf:Property ;
    rdfs:label 'Total Volunteer Hours' ;
    rdfs:comment 'Cumulative total number of hours the volunteer has contributed across all assignments and programs since registration.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volunteerType rdf:type rdf:Property ;
    rdfs:label 'Volunteer Type' ;
    rdfs:comment 'Classification of the volunteer based on their role and engagement model. Community health workers provide ongoing health services, field volunteers support program delivery, event-based supporters assist with specific events, skilled professionals offer specialized expertise, youth volunteers are under 25, and corporate volunteers come through employer partnerships.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:willingToTravel rdf:type rdf:Property ;
    rdfs:label 'Willing To Travel' ;
    rdfs:comment 'Indicates whether the volunteer is willing to travel outside their geographic base for assignments, deployments, or emergency response.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicationId rdf:type rdf:Property ;
    rdfs:label 'Application Id' ;
    rdfs:comment 'Unique identifier for the volunteer application record. Primary key.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'The date on which the volunteer application was submitted by the applicant.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Externally visible unique application reference number assigned to this volunteer application for tracking and communication purposes.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the volunteer application in the recruitment and onboarding workflow. [ENUM-REF-CANDIDATE: submitted|under_review|screening|interview_scheduled|accepted|rejected|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Completed Date' ;
    rdfs:comment 'The date on which the background check was completed.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckOutcome rdf:type rdf:Property ;
    rdfs:label 'Background Check Outcome' ;
    rdfs:comment 'The final outcome or result of the background check process.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Background Check Required' ;
    rdfs:comment 'Indicates whether a background check is required for this volunteer application based on role sensitivity and organizational policy.' ;
    rdfs:domain ind:Volunteer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codeOfConductSigned rdf:type rdf:Property ;
    rdfs:label 'Code Of Conduct Signed' ;
    rdfs:comment 'Indicates whether the volunteer has signed the organization\'s code of conduct and ethical standards agreement.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Commitment Duration Months' ;
    rdfs:comment 'The number of months the applicant is willing to commit to the volunteer role.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'The date on which the final decision on the volunteer application was made.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionMadeBy rdf:type rdf:Property ;
    rdfs:label 'Decision Made By' ;
    rdfs:comment 'Name or identifier of the staff member or committee who made the final decision on the application.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionStatus rdf:type rdf:Property ;
    rdfs:label 'Decision Status' ;
    rdfs:comment 'The final decision status on the volunteer application: whether the applicant has been accepted, rejected, or placed on a waitlist.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactProvided rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Provided' ;
    rdfs:comment 'Indicates whether the volunteer has provided emergency contact information as part of the onboarding process.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Hours Per Week' ;
    rdfs:comment 'The number of hours per week the applicant is available to volunteer.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Interview Completed Date' ;
    rdfs:comment 'The date on which the interview was conducted.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interviewNotes rdf:type rdf:Property ;
    rdfs:label 'Interview Notes' ;
    rdfs:comment 'Internal notes and observations recorded by the interviewer during or after the volunteer interview.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Interview Outcome' ;
    rdfs:comment 'The outcome or recommendation resulting from the volunteer interview.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewRequired rdf:type rdf:Property ;
    rdfs:label 'Interview Required' ;
    rdfs:comment 'Indicates whether an interview is required as part of the volunteer application process for this role.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interviewScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Interview Scheduled Date' ;
    rdfs:comment 'The date and time when the interview with the applicant is scheduled.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagesSpoken rdf:type rdf:Property ;
    rdfs:label 'Languages Spoken' ;
    rdfs:comment 'Comma-separated list of languages the applicant speaks, relevant for field operations and beneficiary communication.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:motivationStatement rdf:type rdf:Property ;
    rdfs:label 'Motivation Statement' ;
    rdfs:comment 'Applicant\'s written statement explaining their motivation for volunteering and alignment with the organization\'s mission.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completed Date' ;
    rdfs:comment 'The date on which the volunteer successfully completed all onboarding requirements and is ready for deployment.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingStartDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Start Date' ;
    rdfs:comment 'The date on which the volunteer onboarding process began.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orientationCompleted rdf:type rdf:Property ;
    rdfs:label 'Orientation Completed' ;
    rdfs:comment 'Indicates whether the volunteer has completed the required orientation session introducing them to the organization\'s mission, values, and policies.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredStartDate rdf:type rdf:Property ;
    rdfs:label 'Preferred Start Date' ;
    rdfs:comment 'The date on which the applicant indicates they are available to begin volunteering.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousVolunteerExperience rdf:type rdf:Property ;
    rdfs:label 'Previous Volunteer Experience' ;
    rdfs:comment 'Narrative description of the applicant\'s prior volunteer experience with this organization or other NGOs, CSOs, or INGOs.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruitmentChannel rdf:type rdf:Property ;
    rdfs:label 'Recruitment Channel' ;
    rdfs:comment 'The channel or source through which the applicant learned about the volunteer opportunity and submitted their application.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceCheckCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Reference Check Completed Date' ;
    rdfs:comment 'The date on which reference checks were completed.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referenceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Reference Check Status' ;
    rdfs:comment 'Status of the reference check process, including verification of applicant\'s professional or personal references.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeguardingPolicyAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Policy Acknowledged' ;
    rdfs:comment 'Indicates whether the volunteer has acknowledged and agreed to the organization\'s safeguarding and protection policies.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screeningCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Screening Completed Date' ;
    rdfs:comment 'The date on which the initial screening process was completed.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:skillsOffered rdf:type rdf:Property ;
    rdfs:label 'Skills Offered' ;
    rdfs:comment 'Comma-separated list or narrative description of the skills, competencies, and expertise the applicant brings to the volunteer role.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Training Completed' ;
    rdfs:comment 'Indicates whether the volunteer has completed all required role-specific training modules.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentId rdf:type rdf:Property ;
    rdfs:label 'Consent Id' ;
    rdfs:comment 'Unique identifier for the volunteer consent record. Primary key.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confirmationSent rdf:type rdf:Property ;
    rdfs:label 'Confirmation Sent' ;
    rdfs:comment 'Indicates whether a confirmation notification was sent to the volunteer acknowledging receipt of their consent.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationSentDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Sent Date' ;
    rdfs:comment 'Date on which the consent confirmation notification was sent to the volunteer.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentNumber rdf:type rdf:Property ;
    rdfs:label 'Consent Number' ;
    rdfs:comment 'Human-readable unique reference number for this consent record, used for tracking and audit purposes.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Detailed description of what the consent covers, including specific data categories, processing activities, or use cases authorized by the volunteer.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Precise timestamp when the consent was granted, including time zone information. Used for audit trail and legal compliance.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:donorDueDiligenceFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Due Diligence Flag' ;
    rdfs:comment 'Indicates whether this consent record is required for donor due diligence or compliance reporting purposes.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantingMethod rdf:type rdf:Property ;
    rdfs:label 'Granting Method' ;
    rdfs:comment 'Method by which the volunteer provided consent. Indicates the channel and format used to capture the consent.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianName rdf:type rdf:Property ;
    rdfs:label 'Guardian Name' ;
    rdfs:comment 'Name of the parent or legal guardian who provided consent on behalf of a minor volunteer.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianRelationship rdf:type rdf:Property ;
    rdfs:label 'Guardian Relationship' ;
    rdfs:comment 'Relationship of the guardian to the minor volunteer. Defines the legal authority to provide consent.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Minor Consent Flag' ;
    rdfs:comment 'Indicates whether this consent was obtained for a volunteer who is a minor, requiring parental or guardian consent.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Retention Period Months' ;
    rdfs:comment 'Number of months for which this consent record must be retained after withdrawal or expiry, as required by data protection regulations and organizational policy.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safeguardingCategory rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Category' ;
    rdfs:comment 'Category of safeguarding policy or protection measure that this consent relates to. Used for safeguarding compliance tracking.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalMethod rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Method' ;
    rdfs:comment 'Channel through which the volunteer communicated their withdrawal of consent.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentNumber rdf:type rdf:Property ;
    rdfs:label 'Deployment Number' ;
    rdfs:comment 'Human-readable unique business identifier for the deployment assignment, used for tracking and reporting.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteEquivalent rdf:type rdf:Property ;
    rdfs:label 'Fte Equivalent' ;
    rdfs:comment 'The full-time equivalent contribution of the volunteer during this deployment, expressed as a decimal (e.g., 0.5000 for half-time, 1.0000 for full-time).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursContributed rdf:type rdf:Property ;
    rdfs:label 'Hours Contributed' ;
    rdfs:comment 'Total number of hours the volunteer has contributed during this specific deployment to this partner organization. Used for tracking volunteer engagement and reporting.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orientationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Orientation Completed Date' ;
    rdfs:comment 'The date when the volunteer completed the deployment-specific orientation or onboarding.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orientationCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Orientation Completed Flag' ;
    rdfs:comment 'Indicates whether the volunteer has completed the required orientation or onboarding for this specific deployment.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionAwardedFlag rdf:type rdf:Property ;
    rdfs:label 'Recognition Awarded Flag' ;
    rdfs:comment 'Indicates whether the volunteer received formal recognition or an award for their contribution during this deployment.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteDeploymentFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Deployment Flag' ;
    rdfs:comment 'Indicates whether this is a remote or virtual deployment where the volunteer contributes remotely rather than being physically present at the project site.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:role rdf:type rdf:Property ;
    rdfs:label 'Role' ;
    rdfs:comment 'Specific role or function the volunteer performs during this deployment (e.g., Community Health Worker, Field Coordinator, Training Facilitator). The same volunteer may have different roles at different partner organizations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volunteerDeploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Volunteer Deployment Status' ;
    rdfs:comment 'Current lifecycle status of the deployment. Active indicates ongoing assignment, Completed indicates successfully finished deployment, Suspended indicates temporarily paused, Cancelled indicates terminated before completion.' ;
    rdfs:domain ind:VolunteerDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSafeguardingTrainingProgramId rdf:type rdf:Property ;
    rdfs:label 'Required Safeguarding Training Program Id' ;
    rdfs:comment 'Foreign key linking to safeguarding.training_program. Business justification: Volunteer roles define required safeguarding training programs based on beneficiary contact level and risk. Role definitions specify which safeguarding training_program must be completed before deploy' ;
    rdfs:domain ind:Role ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingProgram .

ind:deploymentContext rdf:type rdf:Property ;
    rdfs:label 'Deployment Context' ;
    rdfs:comment 'The operational context in which this volunteer role is typically deployed, aligned with program phases and humanitarian response cycles. [ENUM-REF-CANDIDATE: Emergency Response|Development Program|Advocacy Campaign|Community Outreach|Capacity Building|Disaster Relief|Long-Term Recovery — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTimeCommitmentHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Time Commitment Hours' ;
    rdfs:comment 'Expected number of volunteer hours per week or per assignment period for this role, used for scheduling and capacity planning.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCoverageRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Required' ;
    rdfs:comment 'Indicates whether the organization must provide or verify insurance coverage (medical, liability, travel) for volunteers in this role.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageRequirements rdf:type rdf:Property ;
    rdfs:label 'Language Requirements' ;
    rdfs:comment 'Languages required or preferred for this volunteer role, including proficiency levels, to ensure effective communication with beneficiaries and team members.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumConcurrentAssignments rdf:type rdf:Property ;
    rdfs:label 'Maximum Concurrent Assignments' ;
    rdfs:comment 'Maximum number of volunteers that can be simultaneously assigned to this role, used for capacity planning and deployment management.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumAgeRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Requirement' ;
    rdfs:comment 'Minimum age in years that a volunteer must be to be eligible for this role, based on legal, safety, and program requirements.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumCertificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Minimum Certification Requirements' ;
    rdfs:comment 'Mandatory certifications, licenses, or formal qualifications required before a volunteer can be assigned to this role (e.g., First Aid, SPHERE certification, safeguarding training, driver\'s license).' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalDemands rdf:type rdf:Property ;
    rdfs:label 'Physical Demands' ;
    rdfs:comment 'Level of physical exertion and mobility required for this volunteer role, ranging from sedentary office work to strenuous field activities.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSkills rdf:type rdf:Property ;
    rdfs:label 'Preferred Skills' ;
    rdfs:comment 'Comma-separated list of desirable but not mandatory skills that would enhance volunteer effectiveness in this role.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionProgramEligible rdf:type rdf:Property ;
    rdfs:label 'Recognition Program Eligible' ;
    rdfs:comment 'Indicates whether volunteers in this role are eligible for formal recognition programs, awards, or certificates upon completion.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteWorkEligible rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligible' ;
    rdfs:comment 'Indicates whether this volunteer role can be performed remotely or requires physical presence at a specific location.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingRequirements rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirements' ;
    rdfs:comment 'Description of reporting obligations for volunteers in this role, including frequency, format, and content of activity reports or timesheets.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSkills rdf:type rdf:Property ;
    rdfs:label 'Required Skills' ;
    rdfs:comment 'Comma-separated list of essential skills, competencies, and technical abilities required to perform this volunteer role effectively.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeguardingTrainingRequired rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Training Required' ;
    rdfs:comment 'Indicates whether completion of organizational safeguarding and protection training is mandatory before deployment in this role.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stipendAmount rdf:type rdf:Property ;
    rdfs:label 'Stipend Amount' ;
    rdfs:comment 'Standard stipend or per diem amount provided to volunteers in this role, if applicable. Null if no stipend is provided.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stipendCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Stipend Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the stipend amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stipendEligible rdf:type rdf:Property ;
    rdfs:label 'Stipend Eligible' ;
    rdfs:comment 'Indicates whether volunteers in this role are eligible to receive a stipend, per diem, or other financial support to cover expenses.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisionLevel rdf:type rdf:Property ;
    rdfs:label 'Supervision Level' ;
    rdfs:comment 'Level of supervision and oversight required for volunteers in this role, ranging from independent work to intensive direct supervision.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeCommitmentUnit rdf:type rdf:Property ;
    rdfs:label 'Time Commitment Unit' ;
    rdfs:comment 'Unit of measure for the estimated time commitment (e.g., hours per week, total hours for event-based roles).' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequired rdf:type rdf:Property ;
    rdfs:label 'Travel Required' ;
    rdfs:comment 'Indicates whether this volunteer role requires travel to field sites, beneficiary locations, or other operational areas.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typicalAssignmentDurationDays rdf:type rdf:Property ;
    rdfs:label 'Typical Assignment Duration Days' ;
    rdfs:comment 'Standard length of a volunteer assignment in this role measured in days, used for planning and volunteer expectation setting.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadVolunteerId rdf:type rdf:Property ;
    rdfs:label 'Lead Volunteer Id' ;
    rdfs:comment 'Identifier of the volunteer who serves as the team lead or coordinator. May be null if led by staff.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Volunteer .

ind:budgetAllocation rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation' ;
    rdfs:comment 'The financial budget allocated to support this volunteer team\'s operations, including training, supplies, and recognition activities. Stored in the organization\'s base currency.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentMemberCount rdf:type rdf:Property ;
    rdfs:label 'Current Member Count' ;
    rdfs:comment 'The current number of active volunteers who are members of this team.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'The date on which the volunteer team was officially dissolved or deactivated. Null if the team is still active.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentAssigned rdf:type rdf:Property ;
    rdfs:label 'Equipment Assigned' ;
    rdfs:comment 'Description or list of equipment, supplies, or Non-Food Items (NFI) assigned to the team for operational use (e.g., \'Mobile tablets, first aid kits, distribution tents, hygiene kits\').' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'The date on which the volunteer team was officially formed and became operational.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicArea rdf:type rdf:Property ;
    rdfs:label 'Geographic Area' ;
    rdfs:comment 'Textual description of the geographic area, district, camp, or community where the team is deployed (e.g., \'District 5, Northern Province\', \'Refugee Camp B, Sector 3\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingFrequency rdf:type rdf:Property ;
    rdfs:label 'Meeting Frequency' ;
    rdfs:comment 'The regular frequency at which the team holds coordination or planning meetings.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionAwardsCount rdf:type rdf:Property ;
    rdfs:label 'Recognition Awards Count' ;
    rdfs:comment 'Total number of recognition awards, certificates, or commendations received by the team for outstanding service.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Comma-separated list of certifications or training modules required for team membership (e.g., \'First Aid, SPHERE Standards, Protection Principles, PSS Basics\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentsCount rdf:type rdf:Property ;
    rdfs:label 'Safety Incidents Count' ;
    rdfs:comment 'Total number of safety or security incidents involving team members during operations.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletionRequired rdf:type rdf:Property ;
    rdfs:label 'Training Completion Required' ;
    rdfs:comment 'Indicates whether all team members are required to complete specific training or certification before joining the team.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volunteerTeamStatus rdf:type rdf:Property ;
    rdfs:label 'Volunteer Team Status' ;
    rdfs:comment 'Current operational status of the volunteer team in its lifecycle.' ;
    rdfs:domain ind:VolunteerTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Id' ;
    rdfs:comment 'Unique surrogate identifier for each benefit enrollment record in the Workday HCM Benefits module. Serves as the primary key for this Silver Layer data product.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitPlanId rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Id' ;
    rdfs:comment 'Reference to the benefit plan catalog entry that the staff member is enrolled in. Links to the benefit plan master record defining plan name, provider, type, and eligibility rules.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPlan .

ind:beneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Name' ;
    rdfs:comment 'Full name of the designated beneficiary for life insurance or pension death benefit plans. Populated for life insurance and pension plan types. Sensitive PII requiring restricted access.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryRelationship rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Relationship' ;
    rdfs:comment 'Relationship of the designated beneficiary to the enrolled staff member for life insurance or pension death benefit purposes (e.g., spouse, child, parent).' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraEligible rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible' ;
    rdfs:comment 'Indicates whether the staff member is eligible for continuation of health coverage under COBRA (Consolidated Omnibus Budget Reconciliation Act) or equivalent continuation provisions upon termination of employment. Applicable primarily for US-based staff.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributionCurrency rdf:type rdf:Property ;
    rdfs:label 'Contribution Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which employee and employer contributions are denominated (e.g., USD, GBP, EUR). Critical for multi-currency NGO operations across field offices.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Contribution Frequency' ;
    rdfs:comment 'The pay period frequency at which employee and employer contributions are deducted and remitted. Aligns with the payroll cycle configured in Workday HCM.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'The coverage level selected by the staff member, indicating whether the plan covers the employee alone or extends to dependents. Drives cost-sharing calculations and dependent eligibility.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependentCount rdf:type rdf:Property ;
    rdfs:label 'Dependent Count' ;
    rdfs:comment 'Number of dependents (spouse, children, or other eligible family members) covered under this enrollment. Drives coverage tier classification and premium calculation.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dutyStationCountry rdf:type rdf:Property ;
    rdfs:label 'Duty Station Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the staff member\'s duty station at time of enrollment. Determines eligibility for international vs. national staff benefit plans and medical evacuation entitlements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyStationHardshipLevel rdf:type rdf:Property ;
    rdfs:label 'Duty Station Hardship Level' ;
    rdfs:comment 'UN/OCHA hardship classification of the duty station (H=Headquarters, A through E indicating increasing hardship). Determines eligibility for R&R (Rest and Recuperation) entitlements and hazard pay benefit components.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityRuleCode rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule Code' ;
    rdfs:comment 'Code referencing the eligibility rule set in Workday HCM that governs which staff categories qualify for this plan (e.g., \'INTL-STAFF-ONLY\', \'NAT-STAFF-PENSION\', \'ALL-STAFF-HEALTH\'). Supports automated eligibility validation.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'The monetary amount contributed by the staff member per pay period toward the benefit plan premium or pension. Used in payroll deduction processing and Budget versus Actual (BvA) reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'The monetary amount contributed by the organization per pay period toward the benefit plan premium or pension on behalf of the staff member. Included in Facilities and Administration (F&A) cost calculations and grant budget reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentEventType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Event Type' ;
    rdfs:comment 'The qualifying business event that triggered this enrollment record in Workday HCM. Determines eligibility windows and audit trail for compliance. Life events include marriage, birth, adoption, and loss of other coverage.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantCode rdf:type rdf:Property ;
    rdfs:label 'Grant Code' ;
    rdfs:comment 'Grant or award identifier to which the employer benefit contribution is allocated, supporting donor-restricted fund accounting and indirect cost rate (ICR/NICRA) compliance reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDependentCoverage rdf:type rdf:Property ;
    rdfs:label 'Is Dependent Coverage' ;
    rdfs:comment 'Indicates whether this enrollment includes coverage for one or more dependents beyond the enrolled staff member. True when coverage_tier extends beyond employee-only.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifeInsuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Life Insurance Coverage Amount' ;
    rdfs:comment 'The face value or sum assured of the life insurance benefit plan in the contribution currency. Populated only for life insurance plan type enrollments. Used for beneficiary payout calculations.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medevacCoverageZone rdf:type rdf:Property ;
    rdfs:label 'Medevac Coverage Zone' ;
    rdfs:comment 'Geographic zone or region to which the staff member is entitled to be medically evacuated under the medical evacuation benefit plan (e.g., \'Regional Hub\', \'Home Country\', \'Nearest Adequate Facility\'). Applicable for international and field staff.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openEnrollmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment Period' ;
    rdfs:comment 'Identifier or label for the open enrollment window during which this enrollment was submitted (e.g., \'OE-2024-Q4\'). Supports audit and reconciliation of annual benefit elections.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pensionContributionRatePct rdf:type rdf:Property ;
    rdfs:label 'Pension Contribution Rate Pct' ;
    rdfs:comment 'The percentage of the staff member\'s gross salary contributed to the pension plan per pay period (combined employee and employer rate). Applicable for pension plan type enrollments. Used in NICRA indirect cost rate calculations.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planProvider rdf:type rdf:Property ;
    rdfs:label 'Plan Provider' ;
    rdfs:comment 'Name of the external insurance carrier, pension fund administrator, or service provider delivering the benefit plan (e.g., \'Cigna Global\', \'AXA International\', \'CIGNA Expatriate Benefits\').' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planProviderPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Provider Policy Number' ;
    rdfs:comment 'The policy or contract number issued by the benefit plan provider to the organization. Used for claims processing and provider reconciliation.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'The four-digit calendar or fiscal year of the benefit plan cycle to which this enrollment belongs (e.g., \'2024\'). Used for annual open enrollment reconciliation and FASB ASC 958 period reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rrCycleDays rdf:type rdf:Property ;
    rdfs:label 'Rr Cycle Days' ;
    rdfs:comment 'Number of days in the Rest and Recuperation (R&R) entitlement cycle for this enrollment, applicable to field staff in hardship locations. Determined by duty station hardship level per OCHA/organizational policy.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:staffCategory rdf:type rdf:Property ;
    rdfs:label 'Staff Category' ;
    rdfs:comment 'Classification of the staff member at time of enrollment, determining eligibility for specific benefit plans. National staff, international staff, and expatriates typically have distinct benefit entitlements in NGO/INGO operations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Waiting Period Days' ;
    rdfs:comment 'Number of calendar days between the enrollment date and the effective start date during which the staff member is not yet eligible to claim benefits. Defined by the plan\'s eligibility rules.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adminSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Admin System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Links benefit plans to their administration platform (Workday, SAP, local HRIS). Required for enrollment processing, vendor integration management, data migration planning, and system-specific configu' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:annualCoverageLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Coverage Limit Usd' ;
    rdfs:comment 'Maximum total benefit payout or coverage amount per enrolled staff member per plan year, expressed in US Dollars. Used for financial liability estimation and BvA (Budget versus Actual) reporting in Unit4 ERP.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageDescription rdf:type rdf:Property ;
    rdfs:label 'Coverage Description' ;
    rdfs:comment 'Narrative description of the benefits and services covered under this plan, including key inclusions and exclusions (e.g., inpatient/outpatient care, emergency evacuation, dental, maternity, pre-existing conditions). Sourced from the provider\'s Summary of Benefits document.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount Usd' ;
    rdfs:comment 'The amount an enrolled staff member must pay out-of-pocket before the benefit plan begins covering costs, expressed in US Dollars. Relevant for health insurance and medical evacuation plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dependentCoverageAllowed rdf:type rdf:Property ;
    rdfs:label 'Dependent Coverage Allowed' ;
    rdfs:comment 'Indicates whether enrolled staff members may extend coverage under this plan to eligible dependents (spouse, children). Drives dependent enrollment workflows in Workday HCM.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeContributionAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount Usd' ;
    rdfs:comment 'Fixed monetary amount deducted from the enrolled staff member\'s salary per contribution period, expressed in USD. Used when the employee contribution is a flat amount rather than a percentage.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeContributionPct rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Pct' ;
    rdfs:comment 'Percentage of the total benefit plan premium or contribution deducted from the enrolled staff member\'s salary. Complements employer_contribution_pct to total 100% of the plan cost.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount Usd' ;
    rdfs:comment 'Fixed monetary amount contributed by Ngo per enrolled staff member per contribution period, expressed in USD. Used when the employer contribution is a flat amount rather than a percentage. Feeds into payroll and grant F&A (Facilities and Administration) cost calculations.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionPct rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Pct' ;
    rdfs:comment 'Percentage of the total benefit plan premium or contribution that Ngo (the employer) pays on behalf of the enrolled staff member. Used for payroll cost allocation and grant budget charging in SAP S/4HANA and Unit4 ERP.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employmentTypeEligibility rdf:type rdf:Property ;
    rdfs:label 'Employment Type Eligibility' ;
    rdfs:comment 'Specifies which employment contract types are eligible for this benefit plan (e.g., full_time permanent, part_time, fixed_term contract, or all). Drives automated eligibility checks during onboarding in Workday HCM.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Type' ;
    rdfs:comment 'Indicates whether enrollment in this plan is automatic (all eligible staff are enrolled by default), voluntary (staff opt in), or mandatory (required by law or policy). Drives Workday HCM enrollment workflow logic.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardshipLocationApplicable rdf:type rdf:Property ;
    rdfs:label 'Hardship Location Applicable' ;
    rdfs:comment 'Indicates whether this benefit plan is specifically designed for or applicable to staff deployed in hardship or non-family duty stations (e.g., conflict zones, remote field locations). Relevant for MedEvac, R&R, and hazard pay benefit plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGrantChargeable rdf:type rdf:Property ;
    rdfs:label 'Is Grant Chargeable' ;
    rdfs:comment 'Indicates whether the employer\'s contribution to this benefit plan can be directly charged to donor grants as an allowable cost under OMB Uniform Guidance 2 CFR 200. Affects grant budget preparation and financial reporting to donors such as USAID and BHA.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMedevacIncluded rdf:type rdf:Property ;
    rdfs:label 'Is Medevac Included' ;
    rdfs:comment 'Indicates whether medical evacuation (MedEvac) coverage is included within this benefit plan. Critical for field personnel and expatriate staff operating in high-risk humanitarian contexts. Aligns with Sphere and CHS duty-of-care standards.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRnrIncluded rdf:type rdf:Property ;
    rdfs:label 'Is Rnr Included' ;
    rdfs:comment 'Indicates whether Rest and Recuperation (R&R) entitlements are included in this benefit plan. R&R is a mandatory staff welfare provision for personnel deployed in hardship or non-family duty stations per INGO HR policy.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which the benefit plan was last formally reviewed by HR leadership or the benefits committee for adequacy, cost, and compliance. Supports governance and audit trail requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxDependentsCovered rdf:type rdf:Property ;
    rdfs:label 'Max Dependents Covered' ;
    rdfs:comment 'Maximum number of dependents that can be enrolled under a single staff member\'s benefit plan coverage. Null or zero indicates no dependent coverage or unlimited dependents per plan rules.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumServiceMonths rdf:type rdf:Property ;
    rdfs:label 'Minimum Service Months' ;
    rdfs:comment 'Minimum number of months of continuous service an employee must complete before becoming eligible to enroll in this benefit plan. A value of 0 indicates immediate eligibility upon hire.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openEnrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment End Date' ;
    rdfs:comment 'The date on which the annual open enrollment window closes. Staff who do not act before this date are subject to default enrollment rules or waiver of coverage for the plan year.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openEnrollmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment Start Date' ;
    rdfs:comment 'The date on which the annual open enrollment window opens, allowing eligible staff to enroll in, modify, or waive coverage for the upcoming plan year. Managed in Workday HCM Benefits enrollment events.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Plan Document Url' ;
    rdfs:comment 'URL or document management system path to the official plan document, Summary of Benefits, or provider contract. Enables HR staff and auditors to access the authoritative plan terms for compliance verification.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYearStartMonth rdf:type rdf:Property ;
    rdfs:label 'Plan Year Start Month' ;
    rdfs:comment 'The calendar month (1–12) in which the benefit plan year begins. Determines open enrollment windows, annual coverage resets, and financial year-end accruals in SAP S/4HANA and Unit4 ERP.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Name of the external insurance company, pension fund administrator, or benefit service provider underwriting or administering this plan (e.g., \'Cigna Global Health\', \'AXA Assistance\', \'Allianz Care\').' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Provider Policy Number' ;
    rdfs:comment 'The policy or contract reference number issued by the benefit provider to Ngo. Used for claims processing, renewals, and regulatory filings. Classified as confidential due to contractual sensitivity.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Reference' ;
    rdfs:comment 'Reference to the specific regulatory framework, local labor law, or donor compliance requirement that mandates or governs this benefit plan (e.g., \'Kenya Employment Act 2007\', \'IRS 501(c)(3)\', \'OMB 2 CFR 200\', \'DFID Supplier Standards\'). Supports compliance reporting and audit readiness.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rnrFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Rnr Frequency Days' ;
    rdfs:comment 'Number of days between each R&R entitlement cycle for staff covered under this plan (e.g., every 60 days for hardship locations). Applicable only when is_rnr_included is True.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:staffCategoryEligibility rdf:type rdf:Property ;
    rdfs:label 'Staff Category Eligibility' ;
    rdfs:comment 'Defines which staff category is eligible to enroll in this benefit plan. Distinguishes between national staff (locally hired), international staff (expatriates/INGOs), or both. Critical for INGO compliance and equitable HR policy under CHS.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryCaseId rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Case Id' ;
    rdfs:comment 'Unique system-generated identifier for the disciplinary, grievance, or safeguarding investigation case record in the Workday HCM and case management system.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDisciplinaryStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Disciplinary Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who is the subject of the disciplinary or safeguarding case. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:tertiaryDisciplinaryInvestigatorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Disciplinary Investigator Staff Member Id' ;
    rdfs:comment 'Reference to the staff member or external investigator assigned as the lead investigator for the case. May be an internal HR/legal officer or an externally contracted investigator for PSEA/SEA cases.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:appealDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Date' ;
    rdfs:comment 'The date on which the subject employee formally lodged an appeal against the investigation outcome or sanction. Null if no appeal was filed.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Resolution Date' ;
    rdfs:comment 'The date on which the appeal was formally resolved and a final determination was communicated to the subject employee. Null if no appeal was filed or appeal is still pending.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorityReferralDate rdf:type rdf:Property ;
    rdfs:label 'Authority Referral Date' ;
    rdfs:comment 'The date on which the case was formally referred to external law enforcement or regulatory authorities. Null if no referral was made.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiaryInvolved rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Involved' ;
    rdfs:comment 'Flag indicating whether the alleged incident involved a program beneficiary, Person of Concern (PoC), or Internally Displaced Person (IDP) as a victim or witness. Cases involving beneficiaries trigger heightened safeguarding protocols and mandatory PSEA reporting.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Case Opened Date' ;
    rdfs:comment 'The date on which the formal disciplinary or safeguarding case was officially opened and registered in the case management system. This is the principal business event date for the case lifecycle.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:casePriority rdf:type rdf:Property ;
    rdfs:label 'Case Priority' ;
    rdfs:comment 'The priority level assigned to the case at intake, reflecting urgency of investigation based on severity of allegation, vulnerability of parties involved, and operational risk. Critical priority cases (e.g., PSEA involving beneficiaries) require immediate escalation.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Case Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference code assigned to the disciplinary case at initiation, used in all correspondence, donor incident reports, and regulatory filings. Format: [ORG_CODE]-DISC-[YEAR]-[SEQUENCE].' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charityCommissionReported rdf:type rdf:Property ;
    rdfs:label 'Charity Commission Reported' ;
    rdfs:comment 'Flag indicating whether this case was reported to the Charity Commission (UK) as a Serious Incident, as required for registered UK charities when incidents involve significant harm, financial loss, or reputational risk.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complainantType rdf:type rdf:Property ;
    rdfs:label 'Complainant Type' ;
    rdfs:comment 'Classification of how the complaint or allegation was submitted, indicating whether the complainant is anonymous, named, self-referred, a third party, or referred by management. Informs confidentiality protocols and investigation approach.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'The type of employment contract held by the subject employee at the time of the case. Determines applicable disciplinary procedures, notice periods, and legal obligations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorReportSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Donor Report Submitted Date' ;
    rdfs:comment 'The date on which the mandatory donor incident report was submitted to the relevant funding body. Null if no donor report is required or has not yet been submitted. Used to track compliance with donor reporting deadlines.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationEndDate rdf:type rdf:Property ;
    rdfs:label 'Investigation End Date' ;
    rdfs:comment 'The date on which the formal investigation was concluded and findings were documented. Used to calculate investigation duration and compliance with timeliness standards.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Investigation Findings Summary' ;
    rdfs:comment 'A concise narrative summary of the key findings from the investigation, documenting evidence reviewed, witness accounts, and the basis for the investigation outcome determination.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irsForm990Reportable rdf:type rdf:Property ;
    rdfs:label 'Irs Form 990 Reportable' ;
    rdfs:comment 'Flag indicating whether this disciplinary case involves a matter that must be disclosed on IRS Form 990 (e.g., diversion of assets, fraud, or governance failures) for US-registered 501(c)(3) organizations.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExternalInvestigator rdf:type rdf:Property ;
    rdfs:label 'Is External Investigator' ;
    rdfs:comment 'Flag indicating whether the investigation was conducted by an external independent investigator rather than internal HR or legal staff. External investigators are typically required for PSEA/SEA cases or senior staff misconduct.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatoryDonorReportRequired rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory Donor Report Required' ;
    rdfs:comment 'Flag indicating whether this case triggers a mandatory donor incident reporting obligation to a funding body such as USAID (BHA), DFID, CERF, or other institutional donors per grant agreement terms.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPseaCase rdf:type rdf:Property ;
    rdfs:label 'Is Psea Case' ;
    rdfs:comment 'Flag indicating whether this case involves a Prevention of Sexual Exploitation and Abuse (PSEA) or Sexual Exploitation and Abuse (SEA) allegation, triggering mandatory donor incident reporting obligations under USAID, DFID, and OCHA protocols.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referredToAuthorities rdf:type rdf:Property ;
    rdfs:label 'Referred To Authorities' ;
    rdfs:comment 'Flag indicating whether the case was referred to external law enforcement, national authorities, or regulatory bodies (e.g., Charity Commission UK, IRS, local police) as part of the disciplinary outcome.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sanctionApplied rdf:type rdf:Property ;
    rdfs:label 'Sanction Applied' ;
    rdfs:comment 'The disciplinary sanction or corrective action applied to the subject employee following a substantiated investigation outcome. Null if outcome is unsubstantiated or inconclusive. [ENUM-REF-CANDIDATE: verbal_warning|written_warning|final_written_warning|suspension|termination|referral_to_authorities|demotion|mandatory_training|no_sanction — promote to reference product]' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayCaseReference rdf:type rdf:Property ;
    rdfs:label 'Workday Case Reference' ;
    rdfs:comment 'The source system identifier for this disciplinary case record in Workday HCM, used for data lineage, reconciliation, and integration with the HRIS system of record.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentContractId rdf:type rdf:Property ;
    rdfs:label 'Employment Contract Id' ;
    rdfs:comment 'Unique system-generated identifier for each employment contract record in Workday HCM. Serves as the primary key for the employment_contract data product in the workforce domain.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmploymentContract .

ind:jobProfileId rdf:type rdf:Property ;
    rdfs:label 'Job Profile Id' ;
    rdfs:comment 'Foreign key linking to workforce.job_profile. Business justification: Employment contracts should reference the standardized job profile catalog to ensure consistency in role definitions, competency requirements, and pay grade alignment. The job_family, job_function, an' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:amendmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Effective Date' ;
    rdfs:comment 'The date from which the most recent contract amendment takes effect. Null for original contracts with no amendments. Used in conjunction with amendment_number to track the timeline of contract changes.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baseSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Base Salary Amount' ;
    rdfs:comment 'The gross base salary payable to the staff member per the contract terms, expressed in the contract currency. Excludes allowances, benefits, and other compensation components. Used in payroll processing, BvA (Budget versus Actual) reporting, and grant cost allocation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference number assigned to the employment contract, used in HR correspondence, legal documentation, and audit trails. Typically formatted as ORG-YEAR-SEQUENCE (e.g., NGO-2024-EMP0042).' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the employment contract. Draft indicates pending approval; active indicates a currently binding agreement; on_hold covers suspension; terminated covers early cessation; expired covers contracts that reached their end date without renewal; amended covers contracts under revision.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyStationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Duty Station Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country of the duty station (e.g., ETH for Ethiopia, SSD for South Sudan, COD for Democratic Republic of Congo). Used for geographic reporting, compliance, and multi-country workforce analytics.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Education Allowance Amount' ;
    rdfs:comment 'The annual monetary amount of education allowance provided for dependent children of expatriate staff members. Covers school fees and related educational expenses at the duty station or in the home country. Expressed in the contract currency. Null for non-expatriate staff or staff without eligible dependents.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardshipAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Hardship Allowance Amount' ;
    rdfs:comment 'The monthly monetary amount of hardship allowance payable to the expatriate staff member based on their hardship tier and salary grade. Expressed in the contract currency. Null for non-expatriate staff or H-classified duty stations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardshipTier rdf:type rdf:Property ;
    rdfs:label 'Hardship Tier' ;
    rdfs:comment 'The UN/ICSC hardship classification tier assigned to the duty station, determining the hardship allowance percentage applicable to the staff member\'s salary. H = headquarters (no hardship); A through E represent increasing levels of hardship, with E being the most difficult duty stations (e.g., active conflict zones). Null for non-expatriate staff.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeLeaveFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Home Leave Frequency Months' ;
    rdfs:comment 'The number of months between home leave entitlements for expatriate staff, defining how frequently the staff member is entitled to travel to their home country at organizational expense. Typically 12 or 24 months depending on duty station hardship classification. Null for non-expatriate staff.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:housingAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Housing Allowance Amount' ;
    rdfs:comment 'The monthly monetary amount of housing allowance provided to the expatriate staff member at the duty station. Reflects local rental market rates and organizational housing policy. Expressed in the contract currency. Null for non-expatriate staff or staff in NGO-provided accommodation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingoSalaryScale rdf:type rdf:Property ;
    rdfs:label 'Ingo Salary Scale' ;
    rdfs:comment 'The salary scale framework applied to this contract, particularly relevant for internationally-recruited staff. UN common system applies UN salary tables; organizational_scale uses the NGO\'s internal scale; national_scale applies host-country national staff scales. Determines applicable grade tables and allowance structures.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExpatriate rdf:type rdf:Property ;
    rdfs:label 'Is Expatriate' ;
    rdfs:comment 'Indicates whether the staff member under this contract is classified as an expatriate (internationally-recruited staff deployed outside their home country). Triggers eligibility for expatriate compensation package components including hardship allowance, housing allowance, education allowance, home leave, and R&R.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Labor Law Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction whose labor laws and employment regulations govern this contract (e.g., \'Kenya\', \'Ethiopia\', \'United Kingdom\', \'United States\'). Determines statutory entitlements, termination procedures, and compliance obligations. Critical for multi-country NGO operations.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medevacCoverageLevel rdf:type rdf:Property ;
    rdfs:label 'Medevac Coverage Level' ;
    rdfs:comment 'The tier of medical evacuation coverage provided under this contract, determining the scope of emergency medical transport and treatment entitlements. Full coverage includes international evacuation to a tertiary care facility; basic covers regional evacuation only. Critical for field staff safety and duty of care compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'The number of calendar days of advance notice required by either party to terminate the employment contract. Varies by contract type, seniority, and applicable labor law jurisdiction. Used in workforce planning and HR compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:probationEndDate rdf:type rdf:Property ;
    rdfs:label 'Probation End Date' ;
    rdfs:comment 'The date on which the staff member\'s probationary period concludes. During probation, different notice periods and performance review requirements typically apply. Null if no probation period is applicable (e.g., for short-term consultancies).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relocationAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Relocation Allowance Amount' ;
    rdfs:comment 'The one-time monetary amount provided to cover relocation costs when the staff member moves to the duty station at the start of the contract. Expressed in the contract currency. Null for locally-recruited national staff or contract renewals without relocation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rnrCycleWeeks rdf:type rdf:Property ;
    rdfs:label 'Rnr Cycle Weeks' ;
    rdfs:comment 'The number of weeks between Rest and Recuperation (R&R) breaks for staff deployed to high-hardship or non-family duty stations. R&R is a mandatory welfare entitlement for staff in difficult operating environments (e.g., every 6, 8, or 12 weeks). Null for staff at H or A hardship-classified duty stations.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salaryCurrency rdf:type rdf:Property ;
    rdfs:label 'Salary Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the base salary and allowances are denominated (e.g., USD, EUR, GBP, KES, ETB). Supports multi-currency compensation management across 50+ country operations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryFrequency rdf:type rdf:Property ;
    rdfs:label 'Salary Frequency' ;
    rdfs:comment 'The frequency at which the base salary is paid to the staff member. Determines payroll cycle alignment and annualization calculations for budget planning and grant reporting.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryGrade rdf:type rdf:Property ;
    rdfs:label 'Salary Grade' ;
    rdfs:comment 'The compensation band or grade level assigned to the position under this contract, as defined in the NGO\'s salary scale (e.g., UN common system grade G5, P3, or organizational scale Band C). Determines the salary range and step progression applicable to the staff member.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryStep rdf:type rdf:Property ;
    rdfs:label 'Salary Step' ;
    rdfs:comment 'The incremental step within the salary grade assigned to the staff member, reflecting years of experience or merit progression within the grade band (e.g., Step 1, Step 2, Step III). Used in conjunction with salary_grade to determine exact base pay.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayContractReference rdf:type rdf:Property ;
    rdfs:label 'Workday Contract Reference' ;
    rdfs:comment 'The native contract or worker agreement identifier from Workday HCM, the system of record for this data product. Used for data lineage, source system reconciliation, and integration with Workday payroll and benefits modules.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expatPackageId rdf:type rdf:Property ;
    rdfs:label 'Expat Package Id' ;
    rdfs:comment 'Unique system-generated identifier for the expatriate compensation and benefits package record. Primary key for this entity.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryExpatStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Expat Staff Member Id' ;
    rdfs:comment 'Reference to the internationally-recruited staff member to whom this expatriate package applies. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'Date on which the expatriate\'s international assignment and this compensation package become effective. Marks the beginning of entitlement to expatriate benefits.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dependentsCovered rdf:type rdf:Property ;
    rdfs:label 'Dependents Covered' ;
    rdfs:comment 'Indicates whether the health insurance and applicable benefits under this package extend to the expatriate\'s eligible dependents (spouse/partner and children) accompanying them to the duty station.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dutyStationName rdf:type rdf:Property ;
    rdfs:label 'Duty Station Name' ;
    rdfs:comment 'Name of the specific duty station or field office location where the expatriate is posted (e.g., Nairobi, Juba, Kabul). Used for operational reporting and SitRep (Situation Report) alignment.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date on which this specific version of the expatriate package ceases to be in effect. Nullable for the current active version. Supports bi-temporal tracking of package changes.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employerPensionContributionPct rdf:type rdf:Property ;
    rdfs:label 'Employer Pension Contribution Pct' ;
    rdfs:comment 'Percentage of base salary contributed by the organization to the expatriate\'s pension or retirement savings scheme. Used for total compensation costing and grant budget allocation.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardshipAllowanceTier rdf:type rdf:Property ;
    rdfs:label 'Hardship Allowance Tier' ;
    rdfs:comment 'UN/ICSC-aligned hardship classification tier for the duty station, ranging from H (headquarters/no hardship) through A–E (increasing hardship levels). Determines the hardship allowance percentage applied to base salary.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthInsurancePlan rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Plan' ;
    rdfs:comment 'Name or code of the international health insurance plan covering the expatriate and eligible dependents, typically provided through a group scheme (e.g., Cigna Global, Aetna International, BUPA International).' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeCountry rdf:type rdf:Property ;
    rdfs:label 'Home Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the expatriate\'s home country, used for home leave travel entitlement, tax equalization, and repatriation planning.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeLeaveCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Home Leave Cycle Months' ;
    rdfs:comment 'Duration in months of the home leave cycle, i.e., how frequently the expatriate is entitled to take home leave (e.g., every 12 or 24 months). Determines the frequency of home leave travel entitlement.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homeLeaveEntitlementDays rdf:type rdf:Property ;
    rdfs:label 'Home Leave Entitlement Days' ;
    rdfs:comment 'Number of paid home leave days the expatriate is entitled to per leave cycle, allowing return to their home country for rest and family contact. Distinct from annual leave and R&R (Rest and Recuperation) leave.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:housingProvisionType rdf:type rdf:Property ;
    rdfs:label 'Housing Provision Type' ;
    rdfs:comment 'Method by which housing is provided to the expatriate: \'cash_allowance\' means a monetary payment; \'org_provided\' means the organization arranges and pays for accommodation directly; \'shared_accommodation\' means staff share organization-managed housing; \'not_applicable\' for cases where housing is not part of the package.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icrRatePct rdf:type rdf:Property ;
    rdfs:label 'Icr Rate Pct' ;
    rdfs:comment 'The ICR (Indirect Cost Rate) or F&A (Facilities and Administration) rate applied to this expatriate package for grant cost recovery purposes, as defined in the organization\'s NICRA (Negotiated Indirect Cost Rate Agreement) with the US government or equivalent donor agreement.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxEligibleDependents rdf:type rdf:Property ;
    rdfs:label 'Max Eligible Dependents' ;
    rdfs:comment 'Maximum number of dependent children eligible for the education allowance under this package, as defined by organizational policy and applicable salary scale rules.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this expatriate package record, used in HR correspondence, payroll systems, and audit documentation.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle state of the expatriate package. \'draft\' indicates pending approval; \'active\' indicates currently in effect; \'suspended\' indicates temporarily paused; \'terminated\' indicates ended before natural expiry; \'expired\' indicates reached end date.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Classification of the expatriate package by deployment context. \'standard\' applies to normal international postings; \'hardship\' applies to high-risk or difficult duty stations; \'emergency\' applies to rapid-onset humanitarian response deployments; \'transitional\' applies to staff in between postings.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pensionScheme rdf:type rdf:Property ;
    rdfs:label 'Pension Scheme' ;
    rdfs:comment 'Name or code of the pension or retirement savings scheme applicable to the expatriate under this package (e.g., UN Joint Staff Pension Fund, organizational defined contribution plan). Governs employer and employee contribution rates.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repatriationAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Repatriation Allowance Amount' ;
    rdfs:comment 'One-time monetary allowance provided to the expatriate upon end of assignment to cover costs of returning to their home country, including shipping and travel expenses.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rnrCycleDays rdf:type rdf:Property ;
    rdfs:label 'Rnr Cycle Days' ;
    rdfs:comment 'Number of days in the R&R (Rest and Recuperation) cycle applicable to this package. Defines how frequently the expatriate is entitled to R&R breaks from hardship duty stations. Typically 6, 8, or 12 weeks depending on hardship tier.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salaryScale rdf:type rdf:Property ;
    rdfs:label 'Salary Scale' ;
    rdfs:comment 'The applicable salary scale framework governing base compensation for this expatriate, e.g., UN Common System, organizational scale, ICSC (International Civil Service Commission) scale, or donor-mandated scale. [ENUM-REF-CANDIDATE: un_common_system|organizational_scale|icsc_scale|ngo_network_scale|donor_mandated — promote to reference product]' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxEqualizationApplicable rdf:type rdf:Property ;
    rdfs:label 'Tax Equalization Applicable' ;
    rdfs:comment 'Indicates whether a tax equalization policy applies to this expatriate package, ensuring the staff member pays no more or less tax than they would in their home country. Common for internationally-recruited staff on global mobility assignments.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxEqualizationCountry rdf:type rdf:Property ;
    rdfs:label 'Tax Equalization Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the home country used as the reference jurisdiction for tax equalization calculations. Determines the hypothetical tax liability benchmark.' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayPackageReference rdf:type rdf:Property ;
    rdfs:label 'Workday Package Reference' ;
    rdfs:comment 'Source system identifier for this expatriate package record in Workday HCM, used for data lineage, reconciliation, and integration with the HRIS (Human Resource Information System).' ;
    rdfs:domain ind:ExpatPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobApplicationId rdf:type rdf:Property ;
    rdfs:label 'Job Application Id' ;
    rdfs:comment 'Unique system-generated identifier for each job application record in the Workday HCM recruitment module. Serves as the primary key for the job_application data product.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:candidateId rdf:type rdf:Property ;
    rdfs:label 'Candidate Id' ;
    rdfs:comment 'Reference to the candidate (applicant) master record containing personal profile, contact details, and employment history. Enables tracking of a single individual across multiple applications.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Candidate .

ind:primaryJobStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Job Staff Member Id' ;
    rdfs:comment 'Reference to the HR staff member or recruiter responsible for managing this application through the pipeline. Used for recruiter workload reporting and RACI accountability tracking.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:applicationStage rdf:type rdf:Property ;
    rdfs:label 'Application Stage' ;
    rdfs:comment 'Current stage of the candidate in the recruitment pipeline workflow (e.g., Applied, Screening, Assessment, Interview, Reference Check, Offer, Onboarding, Withdrawn, Rejected). Drives pipeline funnel analytics and recruiter workload dashboards. [ENUM-REF-CANDIDATE: Applied|Screening|Assessment|Interview|Reference Check|Offer|Onboarding|Withdrawn|Rejected — promote to reference product]' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the application was received by the system. Supports SLA measurement, duplicate detection, and audit compliance.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:candidateType rdf:type rdf:Property ;
    rdfs:label 'Candidate Type' ;
    rdfs:comment 'Classifies whether the applicant is an external candidate, an internal staff member applying for a different role, a former employee (rehire), or a contractor being converted to staff. Affects onboarding workflow and background check requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverLetterReference rdf:type rdf:Property ;
    rdfs:label 'Cover Letter Reference' ;
    rdfs:comment 'Storage path or document management system reference pointing to the candidate\'s submitted cover letter. Supports recruiter review and competency-based screening.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Cv Document Reference' ;
    rdfs:comment 'Storage path or document management system reference (e.g., SharePoint URL, S3 URI) pointing to the candidate\'s submitted CV or resume. Enables recruiters to retrieve the document without storing binary content in the lakehouse.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disabilityDisclosure rdf:type rdf:Property ;
    rdfs:label 'Disability Disclosure' ;
    rdfs:comment 'Whether the candidate has voluntarily disclosed a disability for the purpose of reasonable accommodation requests and equal-opportunity monitoring. Collected under GDPR Article 9 explicit consent and UK Equality Act 2010 requirements.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderSelfIdentified rdf:type rdf:Property ;
    rdfs:label 'Gender Self Identified' ;
    rdfs:comment 'Gender as self-reported by the candidate on the application form. Collected for equal-opportunity monitoring, gender-disaggregated workforce reporting, and donor diversity requirements (e.g., USAID Gender Policy, DFID Development Assistance Committee DAC gender markers).' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantFundedPosition rdf:type rdf:Property ;
    rdfs:label 'Grant Funded Position' ;
    rdfs:comment 'Indicates whether the position being applied for is funded by a specific donor grant rather than core/unrestricted organisational funds. Affects allowability review under OMB Uniform Guidance 2 CFR 200 and NICRA cost allocation.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:highestEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Highest Education Level' ;
    rdfs:comment 'Highest academic qualification attained by the candidate as declared on the application. Used for minimum qualification screening and workforce capability analytics. [ENUM-REF-CANDIDATE: secondary|bachelor|postgraduate_diploma|master|doctorate|professional_certification|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hiringDecision rdf:type rdf:Property ;
    rdfs:label 'Hiring Decision' ;
    rdfs:comment 'Final hiring decision made by the selection committee for this application. \'Reserve list\' indicates the candidate was strong but the position was filled; they may be contacted for future vacancies.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewDate rdf:type rdf:Property ;
    rdfs:label 'Interview Date' ;
    rdfs:comment 'Date on which the primary (or most recent) interview was conducted. Used for time-to-interview SLA tracking and scheduling analytics.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interviewPanelNotes rdf:type rdf:Property ;
    rdfs:label 'Interview Panel Notes' ;
    rdfs:comment 'Free-text summary of interview panel observations, competency ratings, and recommendation rationale. Stored for audit, grievance, and equal-opportunity compliance purposes. Access restricted to HR and hiring managers.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewScore rdf:type rdf:Property ;
    rdfs:label 'Interview Score' ;
    rdfs:comment 'Aggregate numeric score (0–100) from the structured interview panel, combining scores across competency dimensions. Supports merit-based selection and equal-opportunity compliance documentation.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nationalityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Nationality Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the candidate\'s nationality. Required for work permit eligibility assessment, expatriate management, and national/international staff classification.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Offer Accepted Date' ;
    rdfs:comment 'Date on which the candidate formally accepted the employment offer. Triggers onboarding workflow initiation in Workday HCM and Microsoft Dynamics 365.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerExtendedDate rdf:type rdf:Property ;
    rdfs:label 'Offer Extended Date' ;
    rdfs:comment 'Date on which a formal employment offer was extended to the selected candidate. Used for time-to-offer KPI measurement and offer acceptance rate analytics.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:positionTitle rdf:type rdf:Property ;
    rdfs:label 'Position Title' ;
    rdfs:comment 'Official job title of the position being applied for as defined in the approved job requisition. Used in offer letters, employment contracts, and HRIS records.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedSalary rdf:type rdf:Property ;
    rdfs:label 'Proposed Salary' ;
    rdfs:comment 'Gross annual or monthly salary amount proposed in the offer letter, in the local or contract currency. Used for budget-versus-actual (BvA) analysis and grant-funded position cost allocation.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safeguardingCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Check Status' ;
    rdfs:comment 'Status of the safeguarding and child protection vetting check. Required for all roles with access to vulnerable populations including children, IDPs, and PoCs under CHS, SPHERE, and donor safeguarding policies.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Salary Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the proposed salary amount (e.g., USD, EUR, GBP, KES). Required for multi-currency payroll and donor financial reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningScore rdf:type rdf:Property ;
    rdfs:label 'Screening Score' ;
    rdfs:comment 'Numeric score (0–100) assigned during the initial CV/application screening phase, reflecting how well the candidate meets the minimum qualifications and desirable criteria defined in the job requisition. Used for shortlisting decisions.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stageOutcome rdf:type rdf:Property ;
    rdfs:label 'Stage Outcome' ;
    rdfs:comment 'Result of the most recently completed pipeline stage for this application. Indicates whether the candidate advanced, was eliminated, withdrew, or is awaiting a decision at the current stage.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writtenAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Written Assessment Score' ;
    rdfs:comment 'Numeric score (0–100) from a written technical or competency-based assessment administered to shortlisted candidates. Common in NGO recruitment for programme, finance, and MEL roles.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of relevant professional experience declared by the candidate on the application form. Used for minimum qualification screening and competency benchmarking.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backgroundCheckLevel rdf:type rdf:Property ;
    rdfs:label 'Background Check Level' ;
    rdfs:comment 'Required level of pre-employment background screening for this job profile. \'child_protection\' and \'enhanced\' checks are mandatory for safeguarding-designated roles and roles with access to vulnerable beneficiaries, per CHS and donor requirements.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyFrameworkCode rdf:type rdf:Property ;
    rdfs:label 'Competency Framework Code' ;
    rdfs:comment 'Reference code identifying the competency framework applied to this job profile (e.g., CHS competency framework, Ngo internal framework, IASC humanitarian competencies). Links to the competency library in Workday HCM for performance management and talent development.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coreCompetencies rdf:type rdf:Property ;
    rdfs:label 'Core Competencies' ;
    rdfs:comment 'Comma-separated list of core behavioral and technical competencies required for this job profile as defined in the Workday HCM competency library (e.g., \'Accountability\', \'Communication\', \'Collaboration\', \'Results Orientation\', \'MEAL Proficiency\'). Used in performance reviews and talent assessments.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyStationType rdf:type rdf:Property ;
    rdfs:label 'Duty Station Type' ;
    rdfs:comment 'Classification of the expected duty station for this job profile. \'roving\' indicates the role covers multiple field locations. Drives hardship allowance eligibility, security protocols, and benefits packages for field personnel.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Standard employment type associated with this job profile, indicating the expected contractual arrangement (e.g., full-time permanent, part-time, fixed-term contract, casual, secondment). Drives benefits eligibility and contract template selection in Workday HCM.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldExperienceRequired rdf:type rdf:Property ;
    rdfs:label 'Field Experience Required' ;
    rdfs:comment 'Indicates whether prior humanitarian field experience (e.g., deployment in conflict zones, disaster response, IDP (Internally Displaced Person) settings) is a mandatory requirement for this job profile. Critical for operational roles in Ngo\'s field programs.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flsaExemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Flsa Exemption Status' ;
    rdfs:comment 'Indicates whether the job profile is classified as exempt or non-exempt under the US Fair Labor Standards Act (FLSA) for overtime eligibility purposes. \'not_applicable\' for roles outside US jurisdiction. Required for US-based payroll compliance.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icrCostCategory rdf:type rdf:Property ;
    rdfs:label 'Icr Cost Category' ;
    rdfs:comment 'Classification of the job profile\'s cost as direct, indirect, or shared for purposes of grant budget allocation and NICRA (Negotiated Indirect Cost Rate Agreement) compliance. Determines how staff costs are charged to grants and reported to donors such as USAID and BHA.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalRole rdf:type rdf:Property ;
    rdfs:label 'Is Critical Role' ;
    rdfs:comment 'Indicates whether this job profile is designated as a critical or key position within Ngo\'s organizational structure. Critical roles are prioritized in succession planning, talent retention programs, and emergency staffing protocols.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafeguardingDesignated rdf:type rdf:Property ;
    rdfs:label 'Is Safeguarding Designated' ;
    rdfs:comment 'Indicates whether this job profile is designated as a safeguarding role requiring enhanced background checks, child protection clearances, and mandatory safeguarding training. Mandatory for roles working directly with beneficiaries, children, or vulnerable populations.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobCategory rdf:type rdf:Property ;
    rdfs:label 'Job Category' ;
    rdfs:comment 'Classification of the job profile by employment category as used in Ngo HR and payroll systems. Distinguishes national staff, international staff (INGO), expatriates, consultants, volunteers, and interns. Drives benefits eligibility, tax treatment, and regulatory compliance reporting.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamilyGroupName rdf:type rdf:Property ;
    rdfs:label 'Job Family Group Name' ;
    rdfs:comment 'The broader job family group that clusters related job families in the Workday HCM hierarchy (e.g., \'Operations\', \'Finance\', \'Technical Specialists\', \'Leadership\'). Enables enterprise-level workforce analytics and organizational design.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamilyName rdf:type rdf:Property ;
    rdfs:label 'Job Family Name' ;
    rdfs:comment 'The job family grouping to which this profile belongs within the Workday HCM job architecture (e.g., \'Program Management\', \'Finance and Accounting\', \'Monitoring Evaluation and Learning (MEL)\', \'Logistics and Supply Chain\', \'Human Resources\'). Supports workforce planning and compensation benchmarking.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobLevel rdf:type rdf:Property ;
    rdfs:label 'Job Level' ;
    rdfs:comment 'Standardized job level designation indicating seniority and scope of responsibility within the Ngo grading structure (e.g., \'Entry\', \'Junior\', \'Mid\', \'Senior\', \'Lead\', \'Manager\', \'Director\', \'Executive\'). Drives pay grade assignment and career pathing. [ENUM-REF-CANDIDATE: entry|junior|mid|senior|lead|manager|director|executive — promote to reference product]' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyResponsibilities rdf:type rdf:Property ;
    rdfs:label 'Key Responsibilities' ;
    rdfs:comment 'Structured narrative of the primary duties and accountabilities for this job profile. Serves as the basis for position descriptions, performance agreements, and RACI (Responsible Accountable Consulted Informed) role mapping across programs.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadershipCompetencies rdf:type rdf:Property ;
    rdfs:label 'Leadership Competencies' ;
    rdfs:comment 'Comma-separated list of leadership-specific competencies required for managerial and senior roles in this job profile (e.g., \'Strategic Thinking\', \'People Development\', \'Change Management\', \'Stakeholder Engagement\'). Populated only for management-level profiles.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementLevel rdf:type rdf:Property ;
    rdfs:label 'Management Level' ;
    rdfs:comment 'Indicates whether the job profile is for an individual contributor or a people manager role, and at what management tier. Used in organizational design, RACI (Responsible Accountable Consulted Informed) role assignments, and leadership development programs.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Min Education Level' ;
    rdfs:comment 'Minimum academic qualification required for this job profile (e.g., Bachelor\'s degree, Master\'s degree). Used as a screening criterion in recruitment and talent acquisition workflows in Workday HCM and Microsoft Dynamics 365. [ENUM-REF-CANDIDATE: none|secondary|diploma|bachelor|master|doctorate|professional_certification — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Min Years Experience' ;
    rdfs:comment 'Minimum number of years of relevant professional experience required for this job profile. Used as a screening criterion in recruitment and for determining eligibility for internal mobility and promotions.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'The compensation pay grade band assigned to this job profile (e.g., \'G5\', \'P3\', \'M2\'). Defines the salary range applicable to positions created from this profile. Confidential as it reveals internal compensation structure. Aligned with Ngo\'s compensation framework and NICRA (Negotiated Indirect Cost Rate Agreement) requirements.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGradeMaxUsd rdf:type rdf:Property ;
    rdfs:label 'Pay Grade Max Usd' ;
    rdfs:comment 'Maximum base salary in US Dollars for the pay grade band associated with this job profile. Used in compensation benchmarking, offer approvals, and grant budget ceiling calculations. Confidential as it reveals internal compensation structure.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payGradeMidpointUsd rdf:type rdf:Property ;
    rdfs:label 'Pay Grade Midpoint Usd' ;
    rdfs:comment 'Midpoint salary in US Dollars for the pay grade band, representing the market reference point for fully competent performance in this job profile. Used in compensation equity analysis and salary benchmarking against sector surveys (e.g., Birches Group, Hay Group).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payGradeMinUsd rdf:type rdf:Property ;
    rdfs:label 'Pay Grade Min Usd' ;
    rdfs:comment 'Minimum base salary in US Dollars for the pay grade band associated with this job profile. Used in budget planning, compensation benchmarking, and grant budget preparation. Confidential as it reveals internal compensation structure.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredCertifications rdf:type rdf:Property ;
    rdfs:label 'Preferred Certifications' ;
    rdfs:comment 'Comma-separated list of desirable but non-mandatory professional certifications for this job profile. Used to differentiate candidates during recruitment and to guide learning and development (L&D) planning in Workday HCM LMS.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable title of the job profile as defined in the Workday HCM job catalog (e.g., \'Field Program Officer\', \'MEAL Coordinator\', \'Finance Manager\'). Used in recruitment postings, organizational charts, and staff communications.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionEligibility rdf:type rdf:Property ;
    rdfs:label 'Succession Eligibility' ;
    rdfs:comment 'Indicates whether this job profile is included in Ngo\'s formal succession planning program in Workday HCM. Profiles marked as succession-eligible are tracked for talent pipeline development and leadership continuity.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelRequirement rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement' ;
    rdfs:comment 'Expected level of travel associated with this job profile. \'field_based\' indicates deployment to humanitarian field operations (e.g., IDP camps, disaster response zones). Used in recruitment communications and duty of care planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayJobProfileReference rdf:type rdf:Property ;
    rdfs:label 'Workday Job Profile Reference' ;
    rdfs:comment 'The native identifier of this job profile record in the Workday HCM source system. Used for system-of-record traceability, data lineage, and integration with Workday payroll, talent, and learning modules.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostingSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Hosting System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Identifies which LMS hosts each course. Essential for user access provisioning, course migration planning, vendor contract management, and integration with HR systems. Replaces denormalized platform_n' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:availableFromDate rdf:type rdf:Property ;
    rdfs:label 'Available From Date' ;
    rdfs:comment 'Date from which the course becomes available for enrollment in the Workday HCM Learning catalog. Used for scheduling new course launches, onboarding cohort planning, and compliance deadline management.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availableUntilDate rdf:type rdf:Property ;
    rdfs:label 'Available Until Date' ;
    rdfs:comment 'Date after which the course is no longer available for new enrollments. Null for courses with no planned end date. Used to manage course retirement and transition to updated versions in the Workday HCM Learning catalog.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateValidityMonths rdf:type rdf:Property ;
    rdfs:label 'Certificate Validity Months' ;
    rdfs:comment 'Number of months for which the course completion certificate or credential remains valid before recertification is required. Null if the certificate does not expire. Used to calculate recertification due dates and compliance status in Workday HCM.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competencyFramework rdf:type rdf:Property ;
    rdfs:label 'Competency Framework' ;
    rdfs:comment 'Name of the competency framework or standard to which this course is aligned (e.g., \'CHS Core Commitments\', \'SPHERE Minimum Standards\', \'IASC Gender Handbook\', \'Ngo Internal Competency Framework\', \'USAID CDCS\'). Enables skills gap analysis and results-based management (RBM) reporting.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerLearner rdf:type rdf:Property ;
    rdfs:label 'Cost Per Learner' ;
    rdfs:comment 'Estimated or actual cost in USD to deliver this course to one learner, including licensing, facilitation, materials, and platform fees. Used for budget planning, Budget versus Actual (BvA) analysis, and indirect cost rate (ICR/NICRA) calculations under OMB Uniform Guidance 2 CFR 200.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the course in the Workday HCM Learning catalog and referenced in staff communications, compliance registers, and donor reporting (e.g., PSEA-001, CHS-FOUND-02). Serves as the BUSINESS_IDENTIFIER for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseOwner rdf:type rdf:Property ;
    rdfs:label 'Course Owner' ;
    rdfs:comment 'Name or identifier of the internal team or role responsible for maintaining and updating this course (e.g., \'Global L&D Team\', \'HR Business Partner - Field Operations\', \'Safeguarding Unit\'). Used for content governance, RACI assignment, and accountability tracking.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseStatus rdf:type rdf:Property ;
    rdfs:label 'Course Status' ;
    rdfs:comment 'Current lifecycle status of the course in the Workday HCM Learning catalog. \'active\' means available for enrollment; \'draft\' means under development; \'archived\' means retired from active use but retained for historical records. Serves as the LIFECYCLE_STATUS for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseType rdf:type rdf:Property ;
    rdfs:label 'Course Type' ;
    rdfs:comment 'High-level classification of the course by its primary purpose within Ngo\'s workforce development framework. \'mandatory_compliance\' covers PSEA, CHS, safeguarding, and security courses required by donors and regulators; \'technical_skills\' covers programmatic and operational competencies; \'field_operations\' covers WASH, GBV response, and humanitarian response protocols. Serves as the primary CLASSIFICATION_OR_TYPE for this MASTER_RESOURCE entity. [ENUM-REF-CANDIDATE: mandatory_compliance|technical_skills|leadership_development|field_operations|onboarding|health_safety|other — promote to reference product]' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseUrl rdf:type rdf:Property ;
    rdfs:label 'Course Url' ;
    rdfs:comment 'Direct URL link to the course in the hosting LMS or external platform. Enables staff to access the course directly from HR portals, intranet pages, and automated assignment notifications.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpeCredits rdf:type rdf:Property ;
    rdfs:label 'Cpe Credits' ;
    rdfs:comment 'Number of Continuing Professional Education (CPE) or Continuing Education Unit (CEU) credits awarded upon successful completion of this course. Used for professional development tracking and external accreditation reporting.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalAccreditation rdf:type rdf:Property ;
    rdfs:label 'External Accreditation' ;
    rdfs:comment 'Name of the external body or standard that accredits or endorses this course (e.g., \'Sphere Association\', \'CHS Alliance\', \'ACNM\', \'PMI\', \'UNHCR\'). Null if the course is not externally accredited. Used for professional development reporting and donor compliance.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundSource rdf:type rdf:Property ;
    rdfs:label 'Fund Source' ;
    rdfs:comment 'Classification of the funding source for this course, aligned to Ngo\'s fund accounting structure. \'restricted_grant\' indicates the course is funded by a specific donor grant with reporting obligations; \'unrestricted\' indicates organizational core funding. Used for fund accounting in SAP S/4HANA and donor compliance reporting.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasAssessment rdf:type rdf:Property ;
    rdfs:label 'Has Assessment' ;
    rdfs:comment 'Indicates whether the course includes a formal assessment, quiz, or competency test that learners must pass to receive credit or certification. Drives pass/fail tracking in Workday HCM and compliance verification for mandatory courses.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuesCertificate rdf:type rdf:Property ;
    rdfs:label 'Issues Certificate' ;
    rdfs:comment 'Indicates whether successful completion of this course results in the issuance of a formal certificate or credential to the learner. Relevant for professional development tracking, donor reporting, and staff file management.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:learningCourseDescription rdf:type rdf:Property ;
    rdfs:label 'Learning Course Description' ;
    rdfs:comment 'Full narrative description of the course content, learning objectives, and intended outcomes as displayed in the Workday HCM Learning catalog. Helps staff and managers understand the course scope before enrollment.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxEnrollment rdf:type rdf:Property ;
    rdfs:label 'Max Enrollment' ;
    rdfs:comment 'Maximum number of learners that can be enrolled in a single offering or session of this course. Applicable primarily to classroom and virtual instructor-led delivery modes. Null for self-paced e-learning with unlimited capacity. Used for session scheduling and waitlist management.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingScore rdf:type rdf:Property ;
    rdfs:label 'Passing Score' ;
    rdfs:comment 'Minimum percentage score (0–100) required for a learner to pass the course assessment and receive completion credit. Applicable only when has_assessment is True. Used for compliance verification and certification issuance in Workday HCM.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisiteCourseCodes rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Course Codes' ;
    rdfs:comment 'Comma-separated list of course codes that must be completed before a learner can enroll in this course (e.g., \'PSEA-001,CHS-FOUND-01\'). Supports learning pathway design and enrollment eligibility enforcement in Workday HCM.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Classification of the course provider by organizational type. Distinguishes internally developed courses from those sourced from UN agencies, peer INGOs, academic institutions, or commercial vendors. Used for procurement compliance under OMB Uniform Guidance 2 CFR 200 and donor reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scormCompliant rdf:type rdf:Property ;
    rdfs:label 'Scorm Compliant' ;
    rdfs:comment 'Indicates whether the e-learning course package is compliant with the Sharable Content Object Reference Model (SCORM) standard, enabling interoperability with Workday HCM and other SCORM-compatible LMS platforms. Relevant for e-learning and blended delivery modes.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Brief summary of the course (maximum 255 characters) used in catalog listings, automated assignment notifications, and mobile LMS displays. Complements the full description for space-constrained interfaces.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectArea rdf:type rdf:Property ;
    rdfs:label 'Subject Area' ;
    rdfs:comment 'Thematic subject area or competency domain the course addresses, aligned to Ngo\'s learning taxonomy (e.g., \'Safeguarding\', \'WASH\', \'GBV Prevention\', \'Financial Stewardship\', \'MEL\', \'Security Management\', \'ICT4D\', \'Leadership\'). Used for catalog browsing, skills gap analysis, and MEL reporting. Secondary CLASSIFICATION_OR_TYPE for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Version Effective Date' ;
    rdfs:comment 'Date from which the current version of the course content is effective and available for enrollment. Used to determine whether staff completions on prior versions remain valid for compliance purposes.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:learningEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Learning Enrollment Id' ;
    rdfs:comment 'Unique system-generated identifier for each learning enrollment record. Serves as the primary key for the learning_enrollment data product in Workday HCM Learning module.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lmsEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Lms Enrollment Id' ;
    rdfs:comment 'External enrollment identifier from the source Learning Management System (LMS) such as Workday Learning or a third-party LMS platform. Used for cross-system reconciliation and data lineage tracing between the lakehouse silver layer and the operational system of record.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Enrollment .

ind:primaryLearningStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Learning Staff Member Id' ;
    rdfs:comment 'Reference to the staff member enrolled in the learning activity. Corresponds to the Workday Worker record for national staff, international staff, or expatriate personnel.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:actualHoursSpent rdf:type rdf:Property ;
    rdfs:label 'Actual Hours Spent' ;
    rdfs:comment 'Actual number of hours the staff member spent on the course, as recorded in the Learning Management System (LMS). May differ from duration_hours for self-paced or blended courses. Used for staff capacity building analytics.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attemptNumber rdf:type rdf:Property ;
    rdfs:label 'Attempt Number' ;
    rdfs:comment 'Sequential number indicating which attempt this enrollment record represents for the staff member on this course. A value of 1 indicates the first attempt; values greater than 1 indicate retakes following a failed or incomplete prior attempt.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionEvidenceUrl rdf:type rdf:Property ;
    rdfs:label 'Completion Evidence Url' ;
    rdfs:comment 'URL or document reference path to the digital evidence of course completion, such as a scanned certificate, attendance register, or e-learning completion screenshot stored in the document management system. Supports audit and compliance verification.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseCategory rdf:type rdf:Property ;
    rdfs:label 'Course Category' ;
    rdfs:comment 'High-level classification of the course content area. Compliance covers mandatory regulatory courses (PSEA, CHS, safeguarding); technical_skills covers programmatic and operational competencies; leadership_development covers management and supervisory training; field_operations covers WASH, GBV response, NFI distribution, and humanitarian field protocols. [ENUM-REF-CANDIDATE: compliance|technical_skills|leadership_development|field_operations|safeguarding|security|health_safety|other — promote to reference product]' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseTitle rdf:type rdf:Property ;
    rdfs:label 'Course Title' ;
    rdfs:comment 'Full descriptive title of the learning course or training activity as defined in the course catalog. Examples: \'Prevention of Sexual Exploitation and Abuse (PSEA) Awareness\', \'Core Humanitarian Standard (CHS) Orientation\', \'Field Security Management\'.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'Name of the organizational department or unit to which the staff member belongs at the time of enrollment. Used for departmental training compliance reporting and capacity building analytics.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobProfile rdf:type rdf:Property ;
    rdfs:label 'Job Profile' ;
    rdfs:comment 'Workday HCM job profile or role title of the staff member at the time of enrollment. Used to assess training coverage by role and to link mandatory training requirements to specific job profiles (e.g., Field Officer, Program Manager, Finance Officer).' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredFrequency rdf:type rdf:Property ;
    rdfs:label 'Required Frequency' ;
    rdfs:comment 'Frequency at which the staff member is required to complete or refresh this course. once: one-time onboarding requirement; annual: yearly renewal (e.g., PSEA, security); biennial: every two years; quarterly: every three months; as_needed: triggered by role change or incident.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numeric score achieved by the staff member on the course assessment or final evaluation, expressed as a percentage (0.00–100.00). Null if no formal scored assessment exists for the course.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:staffType rdf:type rdf:Property ;
    rdfs:label 'Staff Type' ;
    rdfs:comment 'Classification of the enrolled staff member\'s employment category at the time of enrollment. Supports disaggregated reporting on training coverage across national staff, international staff, expatriates, volunteers, consultants, and interns as required by donor and regulatory reporting.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCost rdf:type rdf:Property ;
    rdfs:label 'Training Cost' ;
    rdfs:comment 'Total cost incurred for the staff member\'s enrollment in this training activity, in the organization\'s functional currency. Includes registration fees, materials, and direct delivery costs. Used for Budget versus Actual (BvA) reporting and grant financial management.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveRequestId rdf:type rdf:Property ;
    rdfs:label 'Leave Request Id' ;
    rdfs:comment 'Unique system-generated identifier for each leave request record in the Workday HCM system. Serves as the primary key for the leave_request data product.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLeaveStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Leave Staff Member Id' ;
    rdfs:comment 'Reference to the staff member submitting the leave request. Links to the employee master record in Workday HCM covering national staff, international staff, and expatriate personnel.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:actualDaysTaken rdf:type rdf:Property ;
    rdfs:label 'Actual Days Taken' ;
    rdfs:comment 'Number of working days actually taken by the staff member. Populated upon return from leave and used to update leave balance entitlements. Supports half-day precision.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approverComments rdf:type rdf:Property ;
    rdfs:label 'Approver Comments' ;
    rdfs:comment 'Free-text notes entered by the approving manager or HR officer when approving, rejecting, or modifying the leave request. Supports audit trail and communication.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the leave request was cancelled or withdrawn, either by the employee or by HR. Null if the request was not cancelled.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carryForwardDays rdf:type rdf:Property ;
    rdfs:label 'Carry Forward Days' ;
    rdfs:comment 'Number of unused leave days carried forward from the previous leave year that are being applied to this request. Subject to organizational carry-forward policy limits.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyContactAvailable rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Available' ;
    rdfs:comment 'Indicates whether the staff member has confirmed they can be reached in an emergency during their leave period. Particularly relevant for field staff and humanitarian response contexts.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementDays rdf:type rdf:Property ;
    rdfs:label 'Entitlement Days' ;
    rdfs:comment 'Total number of days the staff member is entitled to for the applicable leave type in the current leave year, as defined by their contract, grade, and duty station policy.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handoverCompleted rdf:type rdf:Property ;
    rdfs:label 'Handover Completed' ;
    rdfs:comment 'Indicates whether the staff member has completed a formal handover of duties and responsibilities before commencing leave. Critical for field operations continuity and program delivery.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRnrEligible rdf:type rdf:Property ;
    rdfs:label 'Is Rnr Eligible' ;
    rdfs:comment 'Indicates whether the staff member is eligible for Rest and Recuperation (R&R) leave based on their duty station hardship classification. True for staff posted to hardship or non-family duty stations per OCHA/UNDSS security phase criteria.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Leave Balance After' ;
    rdfs:comment 'The staff member\'s remaining leave balance (in days) for the applicable leave type after the leave has been taken and confirmed. Updated upon return from leave.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Leave Balance Before' ;
    rdfs:comment 'The staff member\'s available leave balance (in days) for the applicable leave type at the time the request was submitted. Enables entitlement validation and balance tracking.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveDestinationCountry rdf:type rdf:Property ;
    rdfs:label 'Leave Destination Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the staff member will spend their leave. Required for R&R and annual leave for international/expatriate staff for security tracking and travel authorization.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveReason rdf:type rdf:Property ;
    rdfs:label 'Leave Reason' ;
    rdfs:comment 'Free-text description of the reason provided by the staff member for the leave request. May contain sensitive personal information (e.g., medical, family). Classified as confidential.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Classification of the leave being requested. Covers standard humanitarian workforce leave categories: Annual (vacation), Sick, Maternity/Paternity, Rest and Recuperation (R&R) for field staff, Compassionate (bereavement/family emergency), and Time Off In Lieu (TOIL) for overtime compensation.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveYear rdf:type rdf:Property ;
    rdfs:label 'Leave Year' ;
    rdfs:comment 'The calendar or fiscal year to which this leave request applies (e.g., 2024). Used for annual entitlement tracking, carry-forward calculations, and year-end reporting.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalCertificateReceived rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Received' ;
    rdfs:comment 'Indicates whether the required medical certificate has been received and verified by HR. Relevant for sick leave requests where documentation is mandatory per organizational policy.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificateRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Required' ;
    rdfs:comment 'Indicates whether a medical certificate is required for this leave request based on leave type and duration policy (e.g., sick leave exceeding 3 consecutive days). Drives compliance workflow in Workday HCM.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedDays rdf:type rdf:Property ;
    rdfs:label 'Requested Days' ;
    rdfs:comment 'Number of working days requested for the leave period, as submitted by the employee. Supports half-day increments (e.g., 0.5). Excludes weekends and public holidays per the applicable country calendar.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedEndDate rdf:type rdf:Property ;
    rdfs:label 'Requested End Date' ;
    rdfs:comment 'The date the staff member has requested their leave to end (inclusive). Combined with requested_start_date to determine the requested duration.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedStartDate rdf:type rdf:Property ;
    rdfs:label 'Requested Start Date' ;
    rdfs:comment 'The date the staff member has requested their leave to begin. Used for scheduling, coverage planning, and field rotation management.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:securityClearanceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Confirmed' ;
    rdfs:comment 'Indicates whether the staff member\'s travel to the leave destination has been cleared by the security team. Required for international staff and field personnel traveling to or from high-risk areas.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toilHoursAccrued rdf:type rdf:Property ;
    rdfs:label 'Toil Hours Accrued' ;
    rdfs:comment 'Number of overtime hours accrued by the staff member that are being converted to Time Off In Lieu (TOIL). Applicable only for TOIL leave type requests. Supports overtime compensation tracking.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workdayLeaveRequestReference rdf:type rdf:Property ;
    rdfs:label 'Workday Leave Request Reference' ;
    rdfs:comment 'The native leave request identifier from the Workday HCM source system. Enables traceability back to the system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent organizational unit, enabling recursive parent-child hierarchy traversal for headcount, payroll, and program staffing rollups. Null for the root/top-level unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:cityName rdf:type rdf:Property ;
    rdfs:label 'City Name' ;
    rdfs:comment 'Name of the city or locality where the organizational unit\'s primary office is situated. Used for operational logistics, staff deployment planning, and field operations coordination.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingModel rdf:type rdf:Property ;
    rdfs:label 'Funding Model' ;
    rdfs:comment 'Indicates how the organizational unit is financially sustained. \'core\' = funded from unrestricted/core organizational budget; \'grant_funded\' = funded entirely by restricted donor grants; \'mixed\' = combination of core and grant funding; \'self_funded\' = generates own revenue. Critical for fund accounting and BvA reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountActual rdf:type rdf:Property ;
    rdfs:label 'Headcount Actual' ;
    rdfs:comment 'Current number of active staff members assigned to this organizational unit as recorded in Workday HCM. Used for real-time workforce reporting, MEL dashboards, and BvA staffing analysis.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountAuthorized rdf:type rdf:Property ;
    rdfs:label 'Headcount Authorized' ;
    rdfs:comment 'Maximum number of staff positions (both national and international) authorized for this organizational unit as per the approved organizational structure and donor-approved staffing plans. Used for workforce planning and grant compliance.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path string representing the full ancestry chain of the organizational unit from root to current node (e.g., \'/1/5/12/34/\'). Enables fast subtree queries for headcount and payroll rollups without recursive joins.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internationalStaffCount rdf:type rdf:Property ;
    rdfs:label 'International Staff Count' ;
    rdfs:comment 'Number of international (expatriate) staff currently assigned to this organizational unit. Used for expatriate management reporting, visa/work permit tracking, and INGO staffing ratio compliance.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFieldOffice rdf:type rdf:Property ;
    rdfs:label 'Is Field Office' ;
    rdfs:comment 'Indicates whether this organizational unit is classified as a field office operating in a humanitarian or development program context (True) versus a non-field administrative or HQ unit (False). Used to apply field-specific HR policies, allowances, and security protocols.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHq rdf:type rdf:Property ;
    rdfs:label 'Is Hq' ;
    rdfs:comment 'Indicates whether this organizational unit is the global or regional headquarters (True). Used to distinguish HQ administrative units from field and country offices in hierarchical reporting and governance structures.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandateDescription rdf:type rdf:Property ;
    rdfs:label 'Mandate Description' ;
    rdfs:comment 'Narrative description of the organizational unit\'s mandate, scope of work (SoW), and primary responsibilities within the Ngo\'s Theory of Change (ToC). Used for onboarding, stakeholder engagement, and compliance reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalStaffCount rdf:type rdf:Property ;
    rdfs:label 'National Staff Count' ;
    rdfs:comment 'Number of national (locally-hired) staff currently assigned to this organizational unit. Supports localization reporting, donor compliance requirements, and INGO staffing ratio analysis.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:officeEmail rdf:type rdf:Property ;
    rdfs:label 'Office Email' ;
    rdfs:comment 'Primary email address for the organizational unit used for official correspondence, donor communications, and regulatory filings. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Org Unit Status' ;
    rdfs:comment 'Current lifecycle status of the organizational unit. \'active\' = operational; \'inactive\' = temporarily suspended; \'pending\' = awaiting activation; \'dissolved\' = permanently closed; \'merged\' = absorbed into another unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Name of the geographic region or sub-national administrative area where this unit operates (e.g., \'East Africa\', \'West Africa\', \'Middle East and North Africa\', \'South Asia\'). Supports regional rollup reporting for MEL dashboards and donor reports.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registration Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction in which this organizational unit is legally registered. May differ from the operational country for country offices registered under host-country law.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sap Company Code' ;
    rdfs:comment 'SAP S/4HANA company code associated with this organizational unit for General Ledger (GL), Accounts Payable (AP), Accounts Receivable (AR), and fund accounting integration. Enables cross-system financial reconciliation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the organizational unit across systems (Workday HCM, SAP S/4HANA Chart of Accounts, Unit4 ERP). Used as the business identifier in cross-system integrations and financial reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitMissionStatement rdf:type rdf:Property ;
    rdfs:label 'Unit Mission Statement' ;
    rdfs:comment 'Formal mission statement specific to this organizational unit, articulating its contribution to the Ngo\'s overall mission and SDG alignment. Used in annual reports, donor communications, and regulatory filings.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Full human-readable name of the organizational unit (e.g., \'East Africa Regional Office\', \'WASH Program Unit – South Sudan\', \'Finance and Administration Department – HQ\'). Used in all reporting, dashboards, and donor communications.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitShortName rdf:type rdf:Property ;
    rdfs:label 'Unit Short Name' ;
    rdfs:comment 'Abbreviated or shortened display name for the organizational unit used in dashboards, SitRep headers, and space-constrained reporting contexts (e.g., \'EA Regional\', \'WASH-SSD\').' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the organizational unit within the global Ngo structure. Drives hierarchical reporting logic and determines applicable governance rules. [ENUM-REF-CANDIDATE: hq_department|regional_office|country_office|area_office|field_office|program_unit|cost_center — promote to reference product]' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayOrgReference rdf:type rdf:Property ;
    rdfs:label 'Workday Org Reference' ;
    rdfs:comment 'Native organization identifier assigned by Workday HCM to this organizational unit. Used as the source system key for data integration, reconciliation, and lineage tracking between Workday HCM and the Databricks Lakehouse Silver Layer.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Unique system-generated identifier for each payroll run record in Workday HCM. Serves as the primary key for the payroll_run entity.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:payrollSystemPlatformId rdf:type rdf:Property ;
    rdfs:label 'Payroll System Platform Id' ;
    rdfs:comment 'Foreign key linking to technology.system_platform. Business justification: Tracks which payroll system processed each run. Essential for financial audit trails, donor compliance reporting, system reconciliation, and regulatory requirements. NGOs must demonstrate which certif' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SystemPlatform .

ind:bankAccountReference rdf:type rdf:Property ;
    rdfs:label 'Bank Account Reference' ;
    rdfs:comment 'The organizational bank account identifier or reference number from which net pay is disbursed for this payroll run. Not an individual employee account — this is the organization\'s payroll disbursement account reference used for treasury reconciliation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'The date and time when the payroll calculation was executed in Workday HCM. Marks the business event of gross-to-net computation. Distinct from approved_timestamp and created_timestamp, this captures when the financial figures were computed.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'The total number of employees included in this payroll run. Used for headcount reporting, per-capita cost analysis, and validation that all eligible staff were processed. Reconciled against HRIS (Human Resource Information System) active headcount.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalEntityCode rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Code' ;
    rdfs:comment 'The code identifying the legal entity (registered country office or subsidiary) under which this payroll run is processed. Aligns with the organizational structure in SAP S/4HANA and Workday HCM for fund accounting and statutory reporting purposes.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'The cadence at which employees in this payroll group are paid. Determines the number of pay periods per year and affects annualized salary calculations, benefit proration, and grant budget reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'The last calendar date of the pay period covered by this payroll run. Defines the closing boundary of the earnings window. Together with pay_period_start_date, determines the scope of labor costs chargeable to grants and programs.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'The first calendar date of the pay period covered by this payroll run. Defines the beginning of the earnings window for all employees included in the run. Used for time-and-attendance reconciliation and grant cost allocation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollGroup rdf:type rdf:Property ;
    rdfs:label 'Payroll Group' ;
    rdfs:comment 'Classification of the staff population covered by this payroll run. Distinguishes between national staff (locally hired), international staff (globally mobile), expatriates (expat), volunteers with stipends, and consultants. Drives applicable tax regimes, benefit structures, and compliance reporting requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedBy rdf:type rdf:Property ;
    rdfs:label 'Processed By' ;
    rdfs:comment 'The name or employee identifier of the payroll officer who initiated and processed this payroll run in Workday HCM. Supports RACI (Responsible Accountable Consulted Informed) accountability tracking and audit trail requirements.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retroactivePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Retroactive Period Start Date' ;
    rdfs:comment 'The start date of the prior period for which retroactive pay adjustments are being made in this payroll run. Populated only when is_retroactive is True. Used to correctly allocate retroactive costs to the appropriate grant and fiscal period.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Externally-known business identifier for the payroll run, typically formatted as PR-YYYY-MM-NNNN (e.g., PR-2024-03-0012). Used in audit trails, finance reconciliation, and donor/grant reporting to reference a specific payroll cycle.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle state of the payroll run within Workday HCM. Progresses from draft through calculation, approval, and payment. Cancelled status indicates the run was voided before disbursement. Used for workflow control and audit compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Categorizes the nature of the payroll run. Regular runs follow the standard pay schedule; off-cycle runs address missed payments; supplemental runs cover bonuses or allowances; correction runs fix prior errors; final runs process termination pay. Determines processing rules and audit requirements.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Deductions' ;
    rdfs:comment 'The aggregate of all deductions applied across employees in this payroll run, including statutory taxes, social security contributions, health insurance premiums, pension contributions, and voluntary deductions. Reconciled against payroll liabilities in the General Ledger (GL).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEmployerContributions rdf:type rdf:Property ;
    rdfs:label 'Total Employer Contributions' ;
    rdfs:comment 'The aggregate employer-side payroll costs for this run, including employer social security, pension matching, health insurance, and other statutory employer contributions. Represents the full labor cost burden beyond gross pay, critical for grant budget management and F&A (Facilities and Administration) cost allocation.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossPay rdf:type rdf:Property ;
    rdfs:label 'Total Gross Pay' ;
    rdfs:comment 'The aggregate gross earnings for all employees included in this payroll run before any deductions. Includes base salary, allowances, overtime, and other earnings components. Used for BvA (Budget versus Actual) reporting, grant cost allocation, and financial stewardship.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetPay rdf:type rdf:Property ;
    rdfs:label 'Total Net Pay' ;
    rdfs:comment 'The aggregate net amount disbursed to all employees in this payroll run after all deductions. Equals total_gross_pay minus total_deductions. Used for cash disbursement planning, bank transfer reconciliation, and treasury management.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Total Tax Withheld' ;
    rdfs:comment 'The aggregate income tax and statutory levies withheld from employee earnings in this payroll run. Reported to tax authorities and reconciled against payroll tax liability accounts in the CoA (Chart of Accounts). Supports compliance with IRS and local tax authority reporting.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workdayRunReference rdf:type rdf:Property ;
    rdfs:label 'Workday Run Reference' ;
    rdfs:comment 'The native identifier assigned to this payroll run by Workday HCM, the system of record. Enables traceability back to the source system for audit, reconciliation, and support purposes. Distinct from the Silver layer surrogate key payroll_run_id.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payslipId rdf:type rdf:Property ;
    rdfs:label 'Payslip Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual payslip record in the Workday HCM payroll system. Serves as the primary key for the payslip data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalPayslipId rdf:type rdf:Property ;
    rdfs:label 'Original Payslip Id' ;
    rdfs:comment 'Reference to the original payslip record that this corrected or reversed payslip supersedes. Null for standard payslips; populated only when is_correction is True, enabling full audit trail of payroll corrections.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payslip .

ind:employerPensionContribution rdf:type rdf:Property ;
    rdfs:label 'Employer Pension Contribution' ;
    rdfs:comment 'Employer\'s contribution to the employee\'s pension or provident fund for the pay period. Recorded separately from employee deductions for total employment cost reporting and grant cost allocation under OMB Uniform Guidance.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerSocialSecurity rdf:type rdf:Property ;
    rdfs:label 'Employer Social Security' ;
    rdfs:comment 'Employer\'s statutory social security or national insurance contribution associated with this payslip. Not deducted from employee pay but recorded for total employment cost reporting, BvA grant cost allocation, and NICRA indirect cost rate calculations.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expatAllowance rdf:type rdf:Property ;
    rdfs:label 'Expat Allowance' ;
    rdfs:comment 'Allowance specific to internationally-recruited expatriate staff, covering relocation, cost-of-living differentials, and international assignment premiums. Applicable only to staff in the expat payroll group.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldAllowance rdf:type rdf:Property ;
    rdfs:label 'Field Allowance' ;
    rdfs:comment 'Allowance paid to staff working in active field operations, remote areas, or humanitarian response zones. Distinct from hardship allowance; compensates for operational field conditions and mobility requirements.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glJournalReference rdf:type rdf:Property ;
    rdfs:label 'Gl Journal Reference' ;
    rdfs:comment 'Reference number of the General Ledger journal entry posted in SAP S/4HANA or Unit4 ERP for this payslip\'s payroll costs. Enables reconciliation between payroll records and the fund accounting general ledger.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossSalary rdf:type rdf:Property ;
    rdfs:label 'Gross Salary' ;
    rdfs:comment 'Total gross salary amount in local currency before any deductions, representing the employee\'s base contractual pay for the pay period. Forms the basis for all statutory deduction calculations and BvA payroll cost reporting.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardshipAllowance rdf:type rdf:Property ;
    rdfs:label 'Hardship Allowance' ;
    rdfs:comment 'Additional allowance paid to staff deployed in hardship or non-family duty stations as classified by UN/INGO hardship classification frameworks. Compensates for difficult living conditions in humanitarian field operations.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:housingAllowance rdf:type rdf:Property ;
    rdfs:label 'Housing Allowance' ;
    rdfs:comment 'Monetary allowance paid to the employee to cover accommodation costs, commonly provided to international and expat staff in high-cost or insecure duty stations. Taxability varies by country and employment contract type.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incomeTaxDeduction rdf:type rdf:Property ;
    rdfs:label 'Income Tax Deduction' ;
    rdfs:comment 'Statutory income tax withheld from the employee\'s gross pay in accordance with the applicable national tax legislation of the duty station country. Reported to tax authorities and included in statutory payroll filings.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCorrection rdf:type rdf:Property ;
    rdfs:label 'Is Correction' ;
    rdfs:comment 'Indicates whether this payslip is a corrected reissue of a previously reversed payslip. When True, the original_payslip_id field references the superseded payslip for audit trail continuity.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOffCycle rdf:type rdf:Property ;
    rdfs:label 'Is Off Cycle' ;
    rdfs:comment 'Indicates whether this payslip was generated as part of an off-cycle payroll run (e.g., for a new hire mid-period, a termination payment, or a correction) rather than the standard scheduled payroll cycle.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the local currency in which the employee\'s salary components are denominated and calculated. Supports multi-currency payroll operations across 50+ countries.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPayLocal rdf:type rdf:Property ;
    rdfs:label 'Net Pay Local' ;
    rdfs:comment 'Final take-home pay amount in local currency after all statutory and voluntary deductions have been subtracted from gross pay and allowances. Represents the amount the employee is entitled to receive for the pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPayPaymentCurrency rdf:type rdf:Property ;
    rdfs:label 'Net Pay Payment Currency' ;
    rdfs:comment 'Net pay amount converted to the payment currency using the applicable exchange rate. Represents the actual amount disbursed to the employee\'s bank account. May equal net_pay_local when local and payment currencies are the same.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payrollRunSequence rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Sequence' ;
    rdfs:comment 'Sequential run number within the payroll period (e.g., 1 for the primary run, 2 for a supplemental or correction run). Distinguishes regular payroll runs from off-cycle or adjustment runs.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payslipNumber rdf:type rdf:Property ;
    rdfs:label 'Payslip Number' ;
    rdfs:comment 'Externally-visible, human-readable unique reference number for this payslip, typically formatted as PSL-{COUNTRY}-{YEAR}-{MONTH}-{SEQUENCE}. Used in employee communications, statutory filings, and donor audit documentation.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payslipStatus rdf:type rdf:Property ;
    rdfs:label 'Payslip Status' ;
    rdfs:comment 'Current lifecycle state of this individual payslip record. Distinguishes between payslips that have been generated and issued to the employee versus those that have been reversed or superseded by a corrected payslip.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pensionDeduction rdf:type rdf:Property ;
    rdfs:label 'Pension Deduction' ;
    rdfs:comment 'Employee contribution to pension or provident fund deducted from gross pay. Includes both mandatory statutory pension contributions and voluntary supplementary pension scheme contributions where applicable.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSecurityDeduction rdf:type rdf:Property ;
    rdfs:label 'Social Security Deduction' ;
    rdfs:comment 'Statutory social security or national insurance contribution deducted from the employee\'s pay as required by local labour law. Varies by country and employment type; may be zero for certain expat staff under bilateral social security agreements.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAllowances rdf:type rdf:Property ;
    rdfs:label 'Total Allowances' ;
    rdfs:comment 'Sum of all allowance components (housing, hardship, field, expat, transport, and any other applicable allowances) for the pay period in local currency. Used as a subtotal in payslip presentation and BvA reporting.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStatutoryDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Statutory Deductions' ;
    rdfs:comment 'Sum of all mandatory statutory deductions (income tax, social security, pension) for the pay period. Used as a subtotal in payslip presentation and for statutory remittance reconciliation.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportAllowance rdf:type rdf:Property ;
    rdfs:label 'Transport Allowance' ;
    rdfs:comment 'Allowance paid to cover employee commuting or field transportation costs. Commonly provided to national staff in urban and peri-urban duty stations as part of the total compensation package.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voluntaryDeductions rdf:type rdf:Property ;
    rdfs:label 'Voluntary Deductions' ;
    rdfs:comment 'Total of all employee-elected voluntary deductions for the pay period, including staff association fees, health insurance premiums, loan repayments, savings scheme contributions, and other authorised deductions.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique system-generated identifier for the performance review record. Primary key for the performance_review data product in the Workday HCM-sourced workforce domain.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationSessionId rdf:type rdf:Property ;
    rdfs:label 'Calibration Session Id' ;
    rdfs:comment 'Reference to the talent calibration session in which this review\'s rating was discussed and validated against peer employees. Ensures rating consistency and fairness across the organization.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CalibrationSession .

ind:pipId rdf:type rdf:Property ;
    rdfs:label 'Pip Id' ;
    rdfs:comment 'Reference to the associated Performance Improvement Plan (PIP) record if one was initiated as a result of this review. Null if no PIP was required.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceImprovementPlan .

ind:primaryPerformanceStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Staff Member Id' ;
    rdfs:comment 'Reference to the staff member (reviewee) who is the subject of this performance review. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:reviewTemplateId rdf:type rdf:Property ;
    rdfs:label 'Review Template Id' ;
    rdfs:comment 'Reference to the standardized performance review template used for this appraisal cycle, defining the competency framework, rating scales, and objective categories applied.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReviewTemplate .

ind:reviewerStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Staff Member Id' ;
    rdfs:comment 'Reference to the staff member (manager or designated reviewer) who conducted and submitted this performance review. Supports Results-Based Management (RBM) accountability chains.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:accountabilityRating rdf:type rdf:Property ;
    rdfs:label 'Accountability Rating' ;
    rdfs:comment 'Rating assessing the employee\'s demonstrated accountability to affected populations and beneficiaries, a core CHS and HAP requirement for all humanitarian staff. Reflects adherence to feedback mechanisms and complaint handling.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationRating rdf:type rdf:Property ;
    rdfs:label 'Collaboration Rating' ;
    rdfs:comment 'Rating for the collaboration and partnership competency, assessing the employee\'s effectiveness in working across teams, with partner organizations (CSOs, CBOs, INGOs), and with beneficiary communities.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyRatingScore rdf:type rdf:Property ;
    rdfs:label 'Competency Rating Score' ;
    rdfs:comment 'Composite numeric score reflecting the employee\'s average rating across all behavioral competencies assessed in the review (e.g., leadership, collaboration, accountability, humanitarian principles). Supports talent development analytics.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentRecommendations rdf:type rdf:Property ;
    rdfs:label 'Development Recommendations' ;
    rdfs:comment 'Structured recommendations from the reviewer for the employee\'s professional development, including suggested training, mentoring, stretch assignments, or Learning Management System (LMS) courses to address identified gaps.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledged' ;
    rdfs:comment 'Indicates whether the employee has formally acknowledged the performance review in Workday HCM. Required for HR audit compliance and CHS accountability to affected populations standards.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeAcknowledgedDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledged Date' ;
    rdfs:comment 'The date on which the reviewed employee formally acknowledged receipt and review of their performance appraisal in Workday HCM. Required for HAP and CHS accountability compliance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeComments rdf:type rdf:Property ;
    rdfs:label 'Employee Comments' ;
    rdfs:comment 'Free-text comments submitted by the employee at the time of acknowledgment, capturing their response to the review outcome, including any disagreements, additional context, or commitments for the next period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeDisagreementFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Disagreement Flag' ;
    rdfs:comment 'Indicates whether the employee formally disputed or disagreed with the performance review outcome. Triggers the HR grievance and appeals process in accordance with organizational HR policy and CHS accountability standards.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeSelfAssessment rdf:type rdf:Property ;
    rdfs:label 'Employee Self Assessment' ;
    rdfs:comment 'Free-text self-assessment narrative submitted by the employee prior to the review meeting, documenting their own perspective on achievements, challenges, and development needs during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadershipRating rdf:type rdf:Property ;
    rdfs:label 'Leadership Rating' ;
    rdfs:comment 'Rating for the leadership competency dimension, assessing the employee\'s ability to guide teams, make decisions under pressure, and drive program outcomes in humanitarian field contexts.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectiveAchievementScore rdf:type rdf:Property ;
    rdfs:label 'Objective Achievement Score' ;
    rdfs:comment 'Composite percentage score (0–100) reflecting the degree to which the employee achieved their defined performance objectives during the review period. Derived from individual objective ratings in Workday HCM and used in RBM and LogFrame reporting.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numeric score corresponding to the overall performance rating on the configured rating scale (e.g., 1.00–5.00). Enables quantitative talent analytics, benchmarking, and Results-Based Management (RBM) reporting.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipRequired rdf:type rdf:Property ;
    rdfs:label 'Pip Required' ;
    rdfs:comment 'Indicates whether a formal Performance Improvement Plan (PIP) has been recommended or initiated as a result of this review, typically triggered by an unsatisfactory or needs_improvement overall rating.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionRecommendation rdf:type rdf:Property ;
    rdfs:label 'Promotion Recommendation' ;
    rdfs:comment 'Indicates whether the reviewer recommends the employee for promotion or advancement to a higher grade or responsibility level based on this review cycle\'s performance outcomes.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingScaleVersion rdf:type rdf:Property ;
    rdfs:label 'Rating Scale Version' ;
    rdfs:comment 'Version identifier of the performance rating scale applied in this review (e.g., \'v2.1-2024\'). Ensures historical comparability as rating scales evolve over time.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Retention Risk Flag' ;
    rdfs:comment 'Indicates whether the reviewer or HR has flagged this employee as at risk of leaving the organization, enabling proactive talent retention interventions. Supports NGO workforce stability in high-turnover humanitarian contexts.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCycleType rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Type' ;
    rdfs:comment 'Classification of the performance review cycle that this appraisal belongs to. Distinguishes annual appraisals, mid-year check-ins, probationary reviews, end-of-contract assessments, and ad hoc reviews triggered by specific events.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'The deadline by which the performance review must be completed and submitted by the reviewer. Used for HR compliance tracking and manager accountability reporting.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Review Meeting Date' ;
    rdfs:comment 'The date on which the formal performance review discussion meeting took place between the reviewer and the employee. Distinct from the submission date; required for CHS accountability documentation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Review Submitted Date' ;
    rdfs:comment 'The date on which the reviewer formally submitted the completed performance review in Workday HCM. Used to measure timeliness compliance against the review due date.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerNarrative rdf:type rdf:Property ;
    rdfs:label 'Reviewer Narrative' ;
    rdfs:comment 'Free-text qualitative narrative provided by the reviewer summarizing the employee\'s performance, key achievements, areas for improvement, and behavioral observations during the review period. Confidential HR record.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSkillsRating rdf:type rdf:Property ;
    rdfs:label 'Technical Skills Rating' ;
    rdfs:comment 'Rating for the employee\'s technical competency relevant to their functional role (e.g., MEAL methodology, WASH engineering, GBV case management, financial stewardship, ICT4D). Supports targeted learning and development planning.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuesAlignmentRating rdf:type rdf:Property ;
    rdfs:label 'Values Alignment Rating' ;
    rdfs:comment 'Rating assessing the degree to which the employee demonstrates alignment with the NGO\'s core organizational values and humanitarian principles (e.g., humanity, neutrality, impartiality, accountability). Critical for CHS compliance and organizational culture.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportsToPositionId rdf:type rdf:Property ;
    rdfs:label 'Reports To Position Id' ;
    rdfs:comment 'Reference to the parent position in the organizational hierarchy to which this position reports. Enables organizational chart construction, span-of-control analysis, and RACI role assignment across programs.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:availabilityDate rdf:type rdf:Property ;
    rdfs:label 'Availability Date' ;
    rdfs:comment 'Date from which the position is authorized and available for filling, either through recruitment or internal transfer. Marks the effective start of the headcount slot in the organizational plan.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetedAnnualCost rdf:type rdf:Property ;
    rdfs:label 'Budgeted Annual Cost' ;
    rdfs:comment 'Total budgeted annual cost of the position including salary, benefits, and applicable indirect cost rate (ICR/NICRA), in the salary currency. Used in grant budget justifications, Budget versus Actual (BvA) reporting, and workforce cost planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filledDate rdf:type rdf:Property ;
    rdfs:label 'Filled Date' ;
    rdfs:comment 'Date on which the position was most recently filled by an incumbent. Used to calculate time-to-fill metrics and vacancy duration reporting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fteAllocation rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation' ;
    rdfs:comment 'Authorized Full-Time Equivalent (FTE) percentage allocated to this position, expressed as a decimal (e.g., 1.00 = full-time, 0.50 = half-time). Used in workforce planning, grant budget justifications, and headcount reporting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingSourceType rdf:type rdf:Property ;
    rdfs:label 'Funding Source Type' ;
    rdfs:comment 'Classification of the primary funding source for this position. \'Grant\' indicates the position is funded by a specific donor award; \'core\' indicates unrestricted organizational funding; \'split\' indicates funding from multiple sources; \'in-kind\' indicates a contributed position; \'cost-share\' indicates a position partially funded as match on a grant.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountPlanYear rdf:type rdf:Property ;
    rdfs:label 'Headcount Plan Year' ;
    rdfs:comment 'Fiscal or calendar year for which this position is authorized in the organizational headcount plan. Used in annual workforce planning cycles and grant budget period alignment.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:icrApplicable rdf:type rdf:Property ;
    rdfs:label 'Icr Applicable' ;
    rdfs:comment 'Indicates whether the Negotiated Indirect Cost Rate Agreement (NICRA) / Indirect Cost Rate (ICR) applies to this position\'s costs when charged to federal grants. Drives Facilities and Administration (F&A) cost calculations in grant financial management.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFieldPosition rdf:type rdf:Property ;
    rdfs:label 'Is Field Position' ;
    rdfs:comment 'Indicates whether this position is classified as a field operations position (True) versus a headquarters or support office position (False). Drives hardship allowance eligibility, security protocols, and field operations staffing analytics.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSupervisory rdf:type rdf:Property ;
    rdfs:label 'Is Supervisory' ;
    rdfs:comment 'Indicates whether this position carries supervisory or managerial responsibility over other positions (True = supervisory). Used in organizational design, RACI role assignments, and span-of-control analytics.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVacant rdf:type rdf:Property ;
    rdfs:label 'Is Vacant' ;
    rdfs:comment 'Indicates whether the position currently has no active incumbent (True = vacant, False = filled). Drives recruitment requisition creation and vacancy reporting to donors and boards.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobDescriptionUrl rdf:type rdf:Property ;
    rdfs:label 'Job Description Url' ;
    rdfs:comment 'URL or document management system reference to the official job description document for this position. Provides access to the full scope of work, responsibilities, and qualifications for recruitment and performance management purposes.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSalary rdf:type rdf:Property ;
    rdfs:label 'Max Salary' ;
    rdfs:comment 'Maximum base salary authorized for this position\'s pay grade band, in the local or organizational currency. Used in budget ceiling planning and compensation equity analysis.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minSalary rdf:type rdf:Property ;
    rdfs:label 'Min Salary' ;
    rdfs:comment 'Minimum base salary authorized for this position\'s pay grade band, in the local or organizational currency. Used in budget planning, grant budget justifications, and compensation equity analysis.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payGradeBand rdf:type rdf:Property ;
    rdfs:label 'Pay Grade Band' ;
    rdfs:comment 'Compensation grade band assigned to this position as defined in the organization\'s salary scale (e.g., \'G5\', \'P3\', \'NB4\'). Determines the salary range applicable to the position. Classified as confidential business data.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the position within the organization\'s headcount plan and Workday HCM job catalog. Used in grant proposals, budget submissions, and organizational charts.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle state of the position headcount slot. \'Open\' indicates a vacancy available for recruitment; \'filled\' indicates an active incumbent; \'frozen\' indicates a position on hold due to budget constraints; \'eliminated\' indicates the position has been removed from the headcount plan; \'proposed\' indicates pending organizational approval.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Classification of the position by employment arrangement. \'Permanent\' indicates an indefinite contract; \'fixed-term\' indicates a time-bound contract; \'temporary\' indicates a short-term assignment; \'secondment\' indicates a position filled by staff from a partner organization; \'volunteer\' indicates an unpaid position.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raciRole rdf:type rdf:Property ;
    rdfs:label 'Raci Role' ;
    rdfs:comment 'Primary Responsible Accountable Consulted Informed (RACI) role designation for this position within program delivery processes. Supports organizational design and program accountability frameworks.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCompetencies rdf:type rdf:Property ;
    rdfs:label 'Required Competencies' ;
    rdfs:comment 'Comma-separated list of core competencies required for this position as defined in the Workday HCM competency framework (e.g., \'Results Orientation, Teamwork, Communication, WASH Technical Skills\'). Used in performance management and talent acquisition.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredLanguages rdf:type rdf:Property ;
    rdfs:label 'Required Languages' ;
    rdfs:comment 'Comma-separated list of language proficiency requirements for this position (e.g., \'English (fluent), French (working), Swahili (basic)\'). Critical for field operations positions in multilingual humanitarian contexts.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vacancyReason rdf:type rdf:Property ;
    rdfs:label 'Vacancy Reason' ;
    rdfs:comment 'Reason why the position is currently vacant. Used in workforce analytics, turnover reporting, and recruitment planning. [ENUM-REF-CANDIDATE: new_position|resignation|termination|transfer|promotion|retirement|contract_end — promote to reference product]' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayPositionReference rdf:type rdf:Property ;
    rdfs:label 'Workday Position Reference' ;
    rdfs:comment 'Native position identifier from the Workday HCM source system. Used for data lineage, system reconciliation, and integration with Workday HCM APIs.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRecruitmentStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Recruitment Staff Member Id' ;
    rdfs:comment 'Reference to the staff member designated as the hiring manager responsible for defining requirements, participating in interviews, and making the final selection decision. Maps to PARTY_REFERENCE category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:tertiaryRecruitmentRecruiterStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Recruitment Recruiter Staff Member Id' ;
    rdfs:comment 'Reference to the HR staff member assigned as the primary recruiter responsible for managing the end-to-end recruitment process for this requisition in Workday HCM.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:actualFillDate rdf:type rdf:Property ;
    rdfs:label 'Actual Fill Date' ;
    rdfs:comment 'The date on which the requisition was formally closed as filled, i.e., when an offer was accepted by the selected candidate. Used to calculate time-to-fill metrics and assess recruitment efficiency against targets.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetedAnnualSalary rdf:type rdf:Property ;
    rdfs:label 'Budgeted Annual Salary' ;
    rdfs:comment 'The approved annual salary budget for this position in the organizational base currency. Used for budget-versus-actual (BvA) tracking, grant budget compliance, and workforce cost forecasting. Confidential financial data.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:educationLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Education Level Required' ;
    rdfs:comment 'Minimum academic qualification required for the position: \'certificate\', \'diploma\', \'bachelors\', \'masters\', \'phd\', or \'none\'. Used for candidate screening and workforce capability gap analysis.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingConfirmed rdf:type rdf:Property ;
    rdfs:label 'Funding Confirmed' ;
    rdfs:comment 'Indicates whether the funding source for this position has been confirmed and budget availability verified prior to opening the requisition. True = funding confirmed; False = pending funding confirmation. Critical control for grant-funded positions to prevent unauthorized commitments.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderMarker rdf:type rdf:Property ;
    rdfs:label 'Gender Marker' ;
    rdfs:comment 'Indicates any gender preference or affirmative action target for this position as part of Ngo\'s gender equity and diversity commitments: \'open\' = no preference; \'female_preferred\' = women strongly encouraged to apply; \'male_preferred\' = men strongly encouraged to apply (rare, context-specific). Supports gender-disaggregated workforce reporting to donors and IASC gender accountability frameworks.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountType rdf:type rdf:Property ;
    rdfs:label 'Headcount Type' ;
    rdfs:comment 'Indicates whether this requisition is for a backfill of a vacated position, a newly created position, a replacement for a terminated employee, or a surge addition for emergency response. Drives workforce planning analytics and budget impact assessment.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergencySurge rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Surge' ;
    rdfs:comment 'Indicates whether this requisition was triggered by an emergency humanitarian response requiring rapid deployment (surge recruitment). True = emergency surge; False = standard recruitment. When True, expedited approval workflows and compressed time-to-fill targets apply per CHS and SPHERE standards.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobPostingDate rdf:type rdf:Property ;
    rdfs:label 'Job Posting Date' ;
    rdfs:comment 'Date on which the job advertisement was first published on external or internal channels. Used to calculate time-to-post (from requisition opening to posting) and to manage posting expiry dates per platform requirements.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Experience Years' ;
    rdfs:comment 'The minimum number of years of relevant professional experience required for the position as specified in the job description. Used for candidate screening, competency benchmarking, and workforce capability analytics.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfOpenings rdf:type rdf:Property ;
    rdfs:label 'Number Of Openings' ;
    rdfs:comment 'The total number of identical positions to be filled under this single requisition. Values greater than 1 are common for surge recruitment (e.g., hiring 10 community health workers for a WASH response). Drives candidate pipeline sizing and recruiter workload planning.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Calendar date on which the requisition was formally opened and made available for sourcing. Represents the principal business event date for time-to-fill calculations and workforce planning analytics. Maps to BUSINESS_EVENT_TIMESTAMP category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:positionsFilledCount rdf:type rdf:Property ;
    rdfs:label 'Positions Filled Count' ;
    rdfs:comment 'Running count of the number of openings that have been successfully filled under this requisition. Compared against number_of_openings to determine requisition completion. Supports partial-fill tracking for multi-opening surge requisitions.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recruitmentType rdf:type rdf:Property ;
    rdfs:label 'Recruitment Type' ;
    rdfs:comment 'Classification of the recruitment approach: \'internal\' = open only to current staff; \'external\' = open to the public; \'emergency_surge\' = rapid deployment for humanitarian response; \'rehire\' = former employee returning; \'secondment\' = staff loaned from a partner organization. Drives sourcing channel selection and time-to-fill targets.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current workflow lifecycle state of the requisition within Workday HCM. Drives downstream actions: \'draft\' = not yet submitted for approval; \'open\' = actively recruiting; \'on_hold\' = paused pending funding or approvals; \'filled\' = candidate selected and offer accepted; \'cancelled\' = withdrawn before fill; \'closed\' = administratively closed. Maps to LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingChannels rdf:type rdf:Property ;
    rdfs:label 'Sourcing Channels' ;
    rdfs:comment 'Comma-separated list of recruitment sourcing channels activated for this requisition (e.g., \'internal_posting, reliefweb, un_jobs, linkedin, devex, ngo_network\'). Supports sourcing effectiveness analytics and cost-per-hire reporting. [ENUM-REF-CANDIDATE: internal_posting|reliefweb|un_jobs|linkedin|devex|ngo_network|referral|direct_outreach — promote to reference product]' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFillDate rdf:type rdf:Property ;
    rdfs:label 'Target Fill Date' ;
    rdfs:comment 'The deadline by which the requisition must be filled, distinct from the target start date. Drives recruiter workload prioritization and escalation triggers. For emergency surge requisitions, this date is typically within 72 hours of opening.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'The desired date by which the recruited candidate should be onboarded and operational. Used for workforce planning, program staffing gap analysis, and time-to-fill KPI measurement. May be adjusted based on recruitment progress.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeToFillDays rdf:type rdf:Property ;
    rdfs:label 'Time To Fill Days' ;
    rdfs:comment 'Number of calendar days elapsed from the requisition opened_date to the actual_fill_date. Populated once the requisition is filled. Key KPI for recruitment efficiency, benchmarked against organizational targets and humanitarian surge standards (e.g., 72-hour surge fill target).' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deprovisionedUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Deprovisioned User Account Id' ;
    rdfs:comment 'Foreign key linking to technology.user_account. Business justification: Links separation events to deprovisioned user accounts. Security and compliance requirement for audit trails, access control verification, and demonstrating timely account deactivation. Critical for d' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:primarySeparationStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Separation Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who is separating from Ngo. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:assetReturnCompleted rdf:type rdf:Property ;
    rdfs:label 'Asset Return Completed' ;
    rdfs:comment 'Indicates whether the departing staff member has returned all Ngo assets (laptop, phone, ID card, vehicle keys, field equipment) prior to or on the effective separation date.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'The organizational department or cost center code to which the staff member was assigned at the time of separation. Used for departmental attrition reporting and budget impact analysis.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitInterviewConductedBy rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Conducted By' ;
    rdfs:comment 'Name or role of the HR staff member or manager who conducted the exit interview. Supports accountability tracking for the offboarding process.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitInterviewDate rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Date' ;
    rdfs:comment 'The date on which the exit interview was conducted with the departing staff member. Null if exit interview was not completed or not required.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitInterviewStatus rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Status' ;
    rdfs:comment 'Tracks the completion status of the exit interview process for the departing staff member. Exit interview data feeds talent retention analysis and MEL (Monitoring Evaluation and Learning) workforce indicators.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Final Settlement Amount' ;
    rdfs:comment 'The total gross monetary amount paid to the staff member as part of the final settlement, including severance pay, payment in lieu of notice (PILON), accrued leave encashment, and end-of-service gratuity. Expressed in the settlement currency.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isNoticeServedInFull rdf:type rdf:Property ;
    rdfs:label 'Is Notice Served In Full' ;
    rdfs:comment 'Indicates whether the staff member served the full contractually required notice period. False triggers calculation of payment in lieu of notice (PILON) in final settlement.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobGrade rdf:type rdf:Property ;
    rdfs:label 'Job Grade' ;
    rdfs:comment 'The salary grade or band of the staff member at the time of separation. Used for attrition analysis by grade level and benchmarking against sector compensation standards.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knowledgeTransferCompleted rdf:type rdf:Property ;
    rdfs:label 'Knowledge Transfer Completed' ;
    rdfs:comment 'Indicates whether the departing staff member completed the required knowledge transfer and handover activities prior to their last working date. Supports program continuity and field operations risk management.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastWorkingDate rdf:type rdf:Property ;
    rdfs:label 'Last Working Date' ;
    rdfs:comment 'The actual final day the staff member performed work duties at Ngo. May differ from effective_date when garden leave or paid notice is applied.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaveEncashmentDays rdf:type rdf:Property ;
    rdfs:label 'Leave Encashment Days' ;
    rdfs:comment 'The number of accrued but unused annual leave days encashed as part of the final settlement. Feeds into the leave encashment payment calculation and leave liability reporting.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noticePeriodDaysRequired rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days Required' ;
    rdfs:comment 'The contractually required notice period in calendar days as stipulated in the staff member\'s employment contract or Ngo HR policy.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noticePeriodDaysServed rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days Served' ;
    rdfs:comment 'The actual number of calendar days of notice served by the separating staff member or Ngo. Used to determine if notice was served in full or if payment in lieu of notice (PILON) applies.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalHireDate rdf:type rdf:Property ;
    rdfs:label 'Original Hire Date' ;
    rdfs:comment 'The date on which the staff member was first hired by Ngo. Preserved as a historical snapshot on the separation record for service length calculations and end-of-service benefit determination.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryDepartureReason rdf:type rdf:Property ;
    rdfs:label 'Primary Departure Reason' ;
    rdfs:comment 'The staff member\'s self-reported primary reason for leaving Ngo as captured during the exit interview. Confidential narrative used for talent retention analysis and workforce strategy. [ENUM-REF-CANDIDATE: compensation|career_growth|management|workload|security|relocation|family|health|better_opportunity|end_of_funding|other — promote to reference product]' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehireIneligibilityReason rdf:type rdf:Property ;
    rdfs:label 'Rehire Ineligibility Reason' ;
    rdfs:comment 'Confidential narrative reason explaining why a former staff member has been flagged as ineligible for rehire. Populated only when rehire_eligibility is \'ineligible\' or \'eligible_with_conditions\'. Supports safeguarding due diligence.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repatriationDestinationCountry rdf:type rdf:Property ;
    rdfs:label 'Repatriation Destination Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country to which the international staff member is being repatriated upon separation. Used for travel cost estimation and logistics planning.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repatriationEntitlement rdf:type rdf:Property ;
    rdfs:label 'Repatriation Entitlement' ;
    rdfs:comment 'Indicates whether the separating staff member is entitled to repatriation support (travel, shipment of personal effects) under Ngo\'s international staff policy. Applicable primarily to expatriate and international staff categories.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safeguardingClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Clearance Status' ;
    rdfs:comment 'Indicates the safeguarding clearance status of the staff member at the time of separation. Ensures compliance with CHS Core Humanitarian Standard obligations and prevents re-employment of individuals with unresolved safeguarding concerns.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Separation Reason Code' ;
    rdfs:comment 'Granular reason code for the separation as configured in Workday HCM (e.g., VOL-BETTER-OPPORTUNITY, VOL-PERSONAL, INV-MISCONDUCT, INV-PERFORMANCE). Supports detailed attrition root-cause analysis and donor/grant reporting on workforce stability. [ENUM-REF-CANDIDATE: vol_better_opportunity|vol_personal|vol_relocation|inv_misconduct|inv_performance|inv_redundancy|eoc_project_end|eoc_funding_end|retirement_age|death_in_service — promote to reference product]' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationStatus rdf:type rdf:Property ;
    rdfs:label 'Separation Status' ;
    rdfs:comment 'Current workflow state of the separation business process in Workday HCM. Tracks whether the offboarding process has been initiated, is in progress, approved by HR, completed, or cancelled.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationType rdf:type rdf:Property ;
    rdfs:label 'Separation Type' ;
    rdfs:comment 'Classification of the reason for the staff member\'s departure from Ngo. Drives attrition analytics, legal obligations, and final settlement calculations. Values: resignation, end_of_contract, redundancy, termination, retirement, death_in_service.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the currency in which the final settlement amount is denominated. Supports multi-currency financial reporting in SAP S/4HANA.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severancePayAmount rdf:type rdf:Property ;
    rdfs:label 'Severance Pay Amount' ;
    rdfs:comment 'The gross severance pay component of the final settlement, calculated based on years of service and applicable HR policy or statutory requirements. Distinct from PILON and leave encashment components.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systemAccessRevoked rdf:type rdf:Property ;
    rdfs:label 'System Access Revoked' ;
    rdfs:comment 'Indicates whether all IT system access (email, ERP, CRM, HRIS, field data systems) has been revoked for the departing staff member. Critical for information security compliance and data protection obligations.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workdayTerminationReference rdf:type rdf:Property ;
    rdfs:label 'Workday Termination Reference' ;
    rdfs:comment 'The native business process instance identifier assigned by Workday HCM for the termination event, used for system-of-record traceability and reconciliation.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfService rdf:type rdf:Property ;
    rdfs:label 'Years Of Service' ;
    rdfs:comment 'Total length of continuous service with Ngo at the time of separation, expressed in years with decimal precision. Used to calculate end-of-service gratuity, severance entitlements, and long-service recognition.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workforceStaffAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Workforce Staff Assignment Id' ;
    rdfs:comment 'Unique system-generated identifier for each staff assignment record in Workday HCM. Serves as the primary key for the staff_assignment data product.' ;
    rdfs:domain ind:WorkforceStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryWorkforceStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Staff Member Id' ;
    rdfs:comment 'Reference to the staff member record in the workforce master data. Links the assignment to the individual employee or contractor being assigned.' ;
    rdfs:domain ind:WorkforceStaffAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:tertiaryWorkforceApprovedByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Workforce Approved By Staff Member Id' ;
    rdfs:comment 'Reference to the staff member (typically HR manager or program director) who approved this assignment in Workday HCM. Supports authorization audit trails and accountability documentation.' ;
    rdfs:domain ind:WorkforceStaffAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:assignmentCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this staff assignment, used in donor reports, effort certification forms, and cross-system references (e.g., ASN-2024-WASH-001). Sourced from Workday HCM assignment reference number.' ;
    rdfs:domain ind:WorkforceStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle state of the staff assignment record. \'draft\' indicates pending approval; \'active\' indicates currently deployed; \'on_hold\' indicates temporarily suspended; \'completed\' indicates successfully concluded; \'cancelled\' indicates terminated before completion.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classification of the nature of the staff assignment. \'primary\' indicates the main assignment; \'secondary\' indicates a concurrent partial assignment; \'surge_deployment\' indicates emergency response deployment; \'tdy\' (Temporary Duty) indicates short-term field deployment; \'secondment\' indicates inter-agency placement; \'consultant\' indicates contracted technical assistance.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyCountryCode rdf:type rdf:Property ;
    rdfs:label 'Duty Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the staff member is deployed for this assignment (e.g., \'SSD\' for South Sudan, \'HTI\' for Haiti). Used for hardship classification, tax treaty application, and OCHA country-level reporting.' ;
    rdfs:domain ind:WorkforceStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effortCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Effort Certification Required' ;
    rdfs:comment 'Indicates whether this assignment requires periodic effort certification by the staff member or supervisor (True), as mandated for federally-funded grants under OMB Uniform Guidance 2 CFR 200 §200.430. Drives the effort certification workflow in the GMS.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effortPercent rdf:type rdf:Property ;
    rdfs:label 'Effort Percent' ;
    rdfs:comment 'The percentage of the staff member\'s total working time allocated to this specific assignment, expressed as a decimal percentage (e.g., 50.00 for 50%). Must sum to 100% across all active assignments for a staff member. Critical for donor-compliant effort reporting and payroll cost allocation to grants per OMB Uniform Guidance 2 CFR 200 §200.430.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardshipLevel rdf:type rdf:Property ;
    rdfs:label 'Hardship Level' ;
    rdfs:comment 'The UN/ICSC hardship classification level for the duty station of this assignment (A=normal; B=some hardship; C=hardship; D=extreme hardship; E=unaccompanied). Determines hardship allowance entitlements and R&R (Rest and Recuperation) schedules for international and expatriate staff.' ;
    rdfs:domain ind:WorkforceStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCostShared rdf:type rdf:Property ;
    rdfs:label 'Is Cost Shared' ;
    rdfs:comment 'Indicates whether the payroll costs for this assignment are shared across multiple grants or funding sources (True). When True, the effort_percent and grant_code fields define the primary allocation, and supplementary cost-share records exist for the remaining allocation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFieldDeployment rdf:type rdf:Property ;
    rdfs:label 'Is Field Deployment' ;
    rdfs:comment 'Indicates whether this assignment involves deployment to a field or humanitarian response location (True) as opposed to a headquarters or regional office posting (False). Used to trigger field-specific HR policies, security protocols, and allowance calculations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSurgeDeployment rdf:type rdf:Property ;
    rdfs:label 'Is Surge Deployment' ;
    rdfs:comment 'Indicates whether this assignment is classified as a surge deployment in response to an acute humanitarian emergency (True). Surge deployments trigger expedited onboarding, emergency per diem rates, and OCHA SitRep staffing reporting.' ;
    rdfs:domain ind:WorkforceStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastEffortCertifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Effort Certified Date' ;
    rdfs:comment 'The date on which the most recent effort certification was completed and approved for this assignment. Used to track compliance with periodic effort reporting requirements under OMB Uniform Guidance and donor agreements.' ;
    rdfs:domain ind:WorkforceStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safeguardingTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Safeguarding Training Completed' ;
    rdfs:comment 'Indicates whether the staff member has completed mandatory safeguarding and protection training prior to or during this assignment (True). Required by CHS Alliance Core Humanitarian Standard and donor compliance frameworks for all field deployments.' ;
    rdfs:domain ind:WorkforceStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tdyPurpose rdf:type rdf:Property ;
    rdfs:label 'Tdy Purpose' ;
    rdfs:comment 'Description of the business purpose for a Temporary Duty (TDY) assignment, such as \'emergency response support\', \'capacity building mission\', or \'program assessment\'. Required for TDY travel authorization and donor reporting. Applicable only when assignment_type = \'tdy\'.' ;
    rdfs:domain ind:WorkforceStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayAssignmentRef rdf:type rdf:Property ;
    rdfs:label 'Workday Assignment Ref' ;
    rdfs:comment 'The source system reference identifier for this assignment record in Workday HCM. Enables traceability back to the system of record for reconciliation, audit, and data lineage purposes.' ;
    rdfs:domain ind:WorkforceStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffCertificationId rdf:type rdf:Property ;
    rdfs:label 'Staff Certification Id' ;
    rdfs:comment 'Unique system-generated identifier for each staff certification record in the Workday HCM system. Primary key for the staff_certification data product.' ;
    rdfs:domain ind:StaffCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationCode rdf:type rdf:Property ;
    rdfs:label 'Certification Code' ;
    rdfs:comment 'Standardized short code or reference number for the certification type, used for classification and reporting (e.g., \'HEAT\', \'PSEA-101\', \'CHS-CERT\', \'SAFEGUARD-CLR\').' ;
    rdfs:domain ind:StaffCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'The unique certificate or license number assigned by the issuing body. Used for verification and compliance audits. Treated as confidential business data.' ;
    rdfs:domain ind:StaffCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the certification record. Indicates whether the certification is currently active and valid, expired, suspended by the issuing body, revoked, or pending verification of submitted documents.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Document Received Date' ;
    rdfs:comment 'The date on which the physical or digital copy of the certification document was received by the HR department for filing and verification.' ;
    rdfs:domain ind:StaffCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentRef rdf:type rdf:Property ;
    rdfs:label 'Document Ref' ;
    rdfs:comment 'Reference path, URL, or document management system identifier pointing to the scanned copy or digital file of the certification document stored in the organization\'s document repository.' ;
    rdfs:domain ind:StaffCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorRequirementRef rdf:type rdf:Property ;
    rdfs:label 'Donor Requirement Ref' ;
    rdfs:comment 'Reference code or name of the donor agreement, grant, or compliance framework that mandates this certification (e.g., \'USAID-APS-2023-001\', \'BHA-PSEA-MANDATORY\'). Populated only when is_donor_required is True.' ;
    rdfs:domain ind:StaffCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDonorRequired rdf:type rdf:Property ;
    rdfs:label 'Is Donor Required' ;
    rdfs:comment 'Indicates whether this certification is mandated by a specific donor or grant agreement as a condition of staff deployment on funded programs (e.g., USAID BHA mandatory training requirements, DFID safeguarding certifications).' ;
    rdfs:domain ind:StaffCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFieldDeploymentRequired rdf:type rdf:Property ;
    rdfs:label 'Is Field Deployment Required' ;
    rdfs:comment 'Indicates whether this certification is specifically required for field deployment eligibility (e.g., HEAT training, medical fitness certificate, security clearance). Drives automated deployment eligibility checks in field operations.' ;
    rdfs:domain ind:StaffCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPass rdf:type rdf:Property ;
    rdfs:label 'Is Pass' ;
    rdfs:comment 'Indicates whether the staff member passed the certification assessment or examination. True = passed; False = failed or did not meet the required standard.' ;
    rdfs:domain ind:StaffCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRoleRequired rdf:type rdf:Property ;
    rdfs:label 'Is Role Required' ;
    rdfs:comment 'Indicates whether this certification is a mandatory requirement for the staff member\'s current position or role. True = required for role; False = voluntary or supplementary. Used in field deployment eligibility checks and compliance reporting.' ;
    rdfs:domain ind:StaffCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The date by which the staff member must initiate or complete the renewal process to maintain continuous validity of the certification. May precede the expiry date to allow processing lead time.' ;
    rdfs:domain ind:StaffCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current status of the certification renewal process. Tracks whether renewal is not yet due, currently in progress, submitted for review, successfully renewed, lapsed due to non-renewal, or formally waived.' ;
    rdfs:domain ind:StaffCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreOrGrade rdf:type rdf:Property ;
    rdfs:label 'Score Or Grade' ;
    rdfs:comment 'The score, grade, or result achieved by the staff member in the certification examination or assessment (e.g., \'Pass\', \'Distinction\', \'87%\', \'Competent\'). Null if the certification is pass/fail without a graded result.' ;
    rdfs:domain ind:StaffCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingLocationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Training Location Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the training was conducted. Relevant for field-based and in-country training programs.' ;
    rdfs:domain ind:StaffCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayCredentialReference rdf:type rdf:Property ;
    rdfs:label 'Workday Credential Reference' ;
    rdfs:comment 'The native credential/certification record identifier from Workday HCM, used for system-of-record traceability and reconciliation with the source HRIS.' ;
    rdfs:domain ind:StaffCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Staff Member Id' ;
    rdfs:comment 'Reference to the staff_member_id of this staff member\'s direct line manager. Enables organizational hierarchy traversal, RACI reporting, performance management workflows, and approval chain configuration in Workday HCM.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:employeeNumber rdf:type rdf:Property ;
    rdfs:label 'Employee Number' ;
    rdfs:comment 'The human-readable, organization-assigned employee identification number used in payroll, HR correspondence, and access control systems. Distinct from the surrogate staff_member_id.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current lifecycle state of the staff member\'s employment at Ngo. Drives access control, payroll processing, and workforce headcount reporting. \'active\' = currently employed and working; \'on_leave\' = approved absence; \'suspended\' = temporarily not working pending investigation; \'separated\' = employment ended; \'probation\' = within initial probationary period.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitInterviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Completed' ;
    rdfs:comment 'Indicates whether the staff member completed an exit interview prior to or at separation. Used to track organizational learning compliance and ensure knowledge transfer processes are followed per CHS Core Humanitarian Standard accountability requirements.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftePercentage rdf:type rdf:Property ;
    rdfs:label 'Fte Percentage' ;
    rdfs:comment 'The proportion of full-time hours this staff member is contracted to work, expressed as a percentage (e.g., 100.00 for full-time, 50.00 for half-time). Used for headcount reporting, grant effort allocation, and Indirect Cost Rate (ICR/NICRA) calculations.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'The official date on which the staff member commenced employment with Ngo, as recorded in Workday HCM. Used for service length calculations, benefits vesting schedules, probation period tracking, and anniversary-based entitlements.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalFirstName rdf:type rdf:Property ;
    rdfs:label 'Legal First Name' ;
    rdfs:comment 'The staff member\'s legal given name as it appears on official government-issued identification documents. Used for payroll, visa, and compliance documentation.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalLastName rdf:type rdf:Property ;
    rdfs:label 'Legal Last Name' ;
    rdfs:comment 'The staff member\'s legal family/surname as it appears on official government-issued identification documents. Used for payroll, visa, and compliance documentation.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passportExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Passport Expiry Date' ;
    rdfs:comment 'The expiry date of the staff member\'s passport. Used to trigger renewal alerts and ensure compliance with international travel and visa requirements for field deployments.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passportNumber rdf:type rdf:Property ;
    rdfs:label 'Passport Number' ;
    rdfs:comment 'The staff member\'s passport number, required for international travel, visa applications, and expatriate deployment documentation. Stored securely in compliance with data protection regulations.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehireEligible rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligible' ;
    rdfs:comment 'Indicates whether the staff member is eligible for rehire at Ngo following separation. Set to false for staff separated due to gross misconduct, fraud, or serious policy violations. Used during talent acquisition screening.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:separationDate rdf:type rdf:Property ;
    rdfs:label 'Separation Date' ;
    rdfs:comment 'The effective date on which the staff member\'s employment with Ngo ended. Used for final payroll processing, benefits termination, access revocation, and workforce attrition reporting.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:separationReason rdf:type rdf:Property ;
    rdfs:label 'Separation Reason' ;
    rdfs:comment 'A free-text narrative describing the specific reason for the staff member\'s separation from Ngo. Complements the separation_type categorical field with contextual detail for HR records, exit documentation, and workforce analytics.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workEmail rdf:type rdf:Property ;
    rdfs:label 'Work Email' ;
    rdfs:comment 'The official organizational email address assigned to the staff member. Primary digital contact channel for HR communications, system access provisioning, and donor/partner correspondence.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPermitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Work Permit Expiry Date' ;
    rdfs:comment 'The expiry date of the staff member\'s work permit or visa authorization. Used to trigger renewal workflows and ensure continuous legal authorization to work in the duty station country.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Work Permit Number' ;
    rdfs:comment 'The work permit or visa authorization number for staff members who require legal authorization to work in their duty station country. Null for staff working in their country of nationality.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhone rdf:type rdf:Property ;
    rdfs:label 'Work Phone' ;
    rdfs:comment 'The staff member\'s official work telephone number in E.164 international format. Used for operational communications, field coordination, and emergency contact protocols.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayWorkerReference rdf:type rdf:Property ;
    rdfs:label 'Workday Worker Reference' ;
    rdfs:comment 'The unique worker identifier assigned by Workday HCM, used to cross-reference this record with the source system of record for all HR transactions, payroll, and benefits data.' ;
    rdfs:domain ind:StaffMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timesheetId rdf:type rdf:Property ;
    rdfs:label 'Timesheet Id' ;
    rdfs:comment 'Unique identifier for the timesheet record. Primary key.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timesheetStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Timesheet Staff Member Id' ;
    rdfs:comment 'Reference to the staff member who submitted this timesheet. Links to the staff_member product.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:effortCertifiedDate rdf:type rdf:Property ;
    rdfs:label 'Effort Certified Date' ;
    rdfs:comment 'The date when the employee formally certified that the reported effort allocation is accurate. Required for compliance with federal grant regulations.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hoursWorked rdf:type rdf:Property ;
    rdfs:label 'Hours Worked' ;
    rdfs:comment 'Total number of hours worked on the specified work_date. Includes regular hours, overtime, and any other compensable time.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBillable rdf:type rdf:Property ;
    rdfs:label 'Is Billable' ;
    rdfs:comment 'Indicates whether the hours are billable to a donor or grant. True for direct program work, false for indirect or administrative activities.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Number of hours worked beyond the standard working hours, eligible for overtime compensation per labor law and employment contract terms.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularHours rdf:type rdf:Property ;
    rdfs:label 'Regular Hours' ;
    rdfs:comment 'Number of standard working hours within the employee\'s normal schedule. Typically up to 8 hours per day or 40 hours per week for full-time staff.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timesheetNumber rdf:type rdf:Property ;
    rdfs:label 'Timesheet Number' ;
    rdfs:comment 'Human-readable business identifier for the timesheet, typically formatted as TS-YYYY-NNNN or similar convention.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timesheetStatus rdf:type rdf:Property ;
    rdfs:label 'Timesheet Status' ;
    rdfs:comment 'Current lifecycle status of the timesheet in the approval workflow. Determines whether hours are eligible for payroll processing and grant charging.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workDate rdf:type rdf:Property ;
    rdfs:label 'Work Date' ;
    rdfs:comment 'The specific calendar date on which the work hours were performed. Must fall within the period_start_date and period_end_date range.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workLocationType rdf:type rdf:Property ;
    rdfs:label 'Work Location Type' ;
    rdfs:comment 'Classification of where the work was physically performed. Used for remote work tracking, field allowance eligibility, and operational reporting.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayTimesheetReference rdf:type rdf:Property ;
    rdfs:label 'Workday Timesheet Reference' ;
    rdfs:comment 'External identifier from Workday HCM system for this timesheet record. Used for system reconciliation and audit trail.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programPartnershipId rdf:type rdf:Property ;
    rdfs:label 'Program Partnership Id' ;
    rdfs:comment 'Primary key for the partnership association' ;
    rdfs:domain ind:ProgramPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bidId rdf:type rdf:Property ;
    rdfs:label 'Bid Id' ;
    rdfs:comment 'Unique identifier for this bid submission record. Primary key.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardedFlag rdf:type rdf:Property ;
    rdfs:label 'Awarded Flag' ;
    rdfs:comment 'Boolean indicator (True/False) showing whether this bid was awarded the contract. Only one bid per RFQ should have awarded_flag = True.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bidStatus rdf:type rdf:Property ;
    rdfs:label 'Bid Status' ;
    rdfs:comment 'Current lifecycle status of the bid: submitted (received), under_evaluation (being scored), responsive (meets requirements), non_responsive (disqualified), awarded (won contract), not_awarded (lost), withdrawn (vendor withdrew).' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialScore rdf:type rdf:Property ;
    rdfs:label 'Financial Score' ;
    rdfs:comment 'Score assigned during financial evaluation of the bid based on pricing competitiveness and value for money.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rank rdf:type rdf:Property ;
    rdfs:label 'Rank' ;
    rdfs:comment 'Ranking position of this bid among all responsive bids for the RFQ, based on total_score (1 = highest ranked).' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalScore rdf:type rdf:Property ;
    rdfs:label 'Technical Score' ;
    rdfs:comment 'Score assigned during technical evaluation of the bid based on quality, specifications compliance, and vendor capability.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalScore rdf:type rdf:Property ;
    rdfs:label 'Total Score' ;
    rdfs:comment 'Combined weighted score from technical and financial evaluation, used for final bid ranking and award decision.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityDays rdf:type rdf:Property ;
    rdfs:label 'Validity Days' ;
    rdfs:comment 'Number of days from submission date during which the vendor commits to honor the quoted price and terms.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplyDistributionLineId rdf:type rdf:Property ;
    rdfs:label 'Supply Distribution Line Id' ;
    rdfs:comment 'Primary key for supply_distribution_line' ;
    rdfs:domain ind:SupplyDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionLineId rdf:type rdf:Property ;
    rdfs:label 'Distribution Line Id' ;
    rdfs:comment 'Unique identifier for this distribution order line item. Primary key for the association.' ;
    rdfs:domain ind:SupplyDistributionLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldDistributionLine .

ind:conditionOnDispatch rdf:type rdf:Property ;
    rdfs:label 'Condition On Dispatch' ;
    rdfs:comment 'Physical condition assessment of the commodity at the time of dispatch from the warehouse.' ;
    rdfs:domain ind:SupplyDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionOnReceipt rdf:type rdf:Property ;
    rdfs:label 'Condition On Receipt' ;
    rdfs:comment 'Physical condition assessment of the commodity upon receipt at the destination distribution point. Used to identify damage during transport.' ;
    rdfs:domain ind:SupplyDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current status of this distribution line item tracking its progression through the distribution lifecycle.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotalValue rdf:type rdf:Property ;
    rdfs:label 'Line Total Value' ;
    rdfs:comment 'Total monetary value of this line item, calculated as quantity_dispatched × unit_value. Used for distribution order valuation and donor reporting. Identified in detection phase relationship data.' ;
    rdfs:domain ind:SupplyDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDiscrepancy rdf:type rdf:Property ;
    rdfs:label 'Quantity Discrepancy' ;
    rdfs:comment 'Difference between quantity_dispatched and quantity_received (dispatched minus received). Positive values indicate shortages, negative values indicate overages. Triggers investigation and reconciliation. Identified in detection phase relationship data.' ;
    rdfs:domain ind:SupplyDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDispatched rdf:type rdf:Property ;
    rdfs:label 'Quantity Dispatched' ;
    rdfs:comment 'Quantity of this commodity dispatched from the warehouse on this line, measured in the commodity\'s standard unit of measure. Identified in detection phase relationship data.' ;
    rdfs:domain ind:SupplyDistributionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Line Id' ;
    rdfs:comment 'Unique system identifier for this purchase order line item. Primary key.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Total amount for this line (quantity_ordered × unit_price). Contributes to purchase_order.subtotal_amount.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOutstanding rdf:type rdf:Property ;
    rdfs:label 'Quantity Outstanding' ;
    rdfs:comment 'Remaining quantity yet to be received (quantity_ordered - quantity_received). Drives open PO reporting and follow-up with vendors.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Agreed price per unit of measure for this commodity on this purchase order. Vendor-specific and time-specific pricing.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignMediaOutreachId rdf:type rdf:Property ;
    rdfs:label 'Campaign Media Outreach Id' ;
    rdfs:comment 'Unique identifier for this campaign-media contact engagement record. Primary key.' ;
    rdfs:domain ind:CampaignMediaOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'The role or capacity in which the media contact is engaged for this campaign (e.g., primary journalist, backup contact, spokesperson, technical expert for interviews)' ;
    rdfs:domain ind:CampaignMediaOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveragePublicationDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Publication Date' ;
    rdfs:comment 'The date when media coverage resulting from this engagement was published or broadcast' ;
    rdfs:domain ind:CampaignMediaOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageType rdf:type rdf:Property ;
    rdfs:label 'Coverage Type' ;
    rdfs:comment 'The type of media coverage resulting from this engagement (e.g., news article, feature story, interview, broadcast segment, social media post, opinion piece, or none if no coverage resulted)' ;
    rdfs:domain ind:CampaignMediaOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageUrl rdf:type rdf:Property ;
    rdfs:label 'Coverage Url' ;
    rdfs:comment 'URL or link to the published media coverage resulting from this campaign-contact engagement' ;
    rdfs:domain ind:CampaignMediaOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Date' ;
    rdfs:comment 'The date when the media contact was first engaged or contacted for this specific campaign' ;
    rdfs:domain ind:CampaignMediaOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interviewGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Interview Granted Flag' ;
    rdfs:comment 'Indicates whether an interview with NGO spokesperson or subject matter expert was granted to this media contact for this campaign (true if interview occurred)' ;
    rdfs:domain ind:CampaignMediaOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaKitSentDate rdf:type rdf:Property ;
    rdfs:label 'Media Kit Sent Date' ;
    rdfs:comment 'The date when the campaign media kit, press release, or briefing materials were sent to this media contact' ;
    rdfs:domain ind:CampaignMediaOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outreachStatus rdf:type rdf:Property ;
    rdfs:label 'Outreach Status' ;
    rdfs:comment 'Current status of the media outreach activity for this campaign-contact pair (e.g., planned, contacted, responded, coverage secured, declined, no response, closed)' ;
    rdfs:domain ind:CampaignMediaOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealTargetingId rdf:type rdf:Property ;
    rdfs:label 'Appeal Targeting Id' ;
    rdfs:comment 'Unique identifier for this appeal-segment targeting record. Primary key.' ;
    rdfs:domain ind:AppealTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:donorSegmentId rdf:type rdf:Property ;
    rdfs:label 'Donor Segment Id' ;
    rdfs:comment 'Foreign key to the donor_segment product' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:costAllocated rdf:type rdf:Property ;
    rdfs:label 'Cost Allocated' ;
    rdfs:comment 'Portion of the total appeal cost allocated to this segment based on pieces sent or other cost allocation methodology. Enables segment-level ROI calculation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deploymentDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Date' ;
    rdfs:comment 'Date when the appeal was deployed to this specific segment. May differ from overall appeal mailing_date if segments are deployed in waves.' ;
    rdfs:domain ind:AppealTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'Timestamp when performance metrics for this appeal-segment combination were last updated.' ;
    rdfs:domain ind:AppealTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:segmentAskAmount rdf:type rdf:Property ;
    rdfs:label 'Segment Ask Amount' ;
    rdfs:comment 'Suggested gift amount presented to constituents in this segment, which may differ from the general appeal ask_amount based on segment giving capacity (e.g., major donors receive higher asks).' ;
    rdfs:domain ind:AppealTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSegment rdf:type rdf:Property ;
    rdfs:label 'Target Segment' ;
    rdfs:comment 'Description of the constituent segment targeted by this appeal (e.g., lapsed donors 12-24 months, major gift prospects $10K+, monthly sustainers). [Moved from appeal: The target_segment STRING attribute in appeal is a text description that cannot capture the reality of multi-segment targeting. When an appeal targets multiple segments (e.g., \'Major Donors\', \'LYBUNT Q1\', \'Mid-Level Annual\'), this single STRING field would require concatenation or comma-separated values, making it impossible to query segment-specific performance. This attribute should be removed from appeal as the relationship is now properly modeled through the appeal_targeting association.]' ;
    rdfs:domain ind:AppealTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testVariant rdf:type rdf:Property ;
    rdfs:label 'Test Variant' ;
    rdfs:comment 'Identifier for A/B test variant or creative package version used for this segment (e.g., \'Control\', \'Variant_A\', \'High_Ask\'). Enables multivariate testing across segments.' ;
    rdfs:domain ind:AppealTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Supply Agreement Id' ;
    rdfs:comment 'Primary key for supply_agreement' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Unique identifier for this supply agreement record. Primary key.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FrameworkAgreement .

ind:lastSupplyDate rdf:type rdf:Property ;
    rdfs:label 'Last Supply Date' ;
    rdfs:comment 'Most recent date when this vendor successfully delivered this commodity. Tracks relationship history.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Event Registration Id' ;
    rdfs:comment 'Unique identifier for this event registration record. Primary key.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auctionPaddleNumber rdf:type rdf:Property ;
    rdfs:label 'Auction Paddle Number' ;
    rdfs:comment 'The paddle or bidder number assigned to the constituent for auction participation at the event. Links to auction transaction tracking. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dietaryRestrictions rdf:type rdf:Property ;
    rdfs:label 'Dietary Restrictions' ;
    rdfs:comment 'Any dietary restrictions or meal preferences specified by the constituent during registration (vegetarian, vegan, gluten-free, allergies). Used for catering planning. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestCount rdf:type rdf:Property ;
    rdfs:label 'Guest Count' ;
    rdfs:comment 'The number of guests included in this registration (e.g., table sponsorships may include multiple seats). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postEventFollowUpStatus rdf:type rdf:Property ;
    rdfs:label 'Post Event Follow Up Status' ;
    rdfs:comment 'The status of post-event stewardship and cultivation follow-up activities for this constituent (pending, thank_you_sent, survey_sent, completed). Tracks donor engagement workflow completion.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialRequests rdf:type rdf:Property ;
    rdfs:label 'Special Requests' ;
    rdfs:comment 'Any special requests or accommodations requested by the constituent (accessibility needs, seating preferences, VIP treatment). Used for event logistics and donor stewardship.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tableNumber rdf:type rdf:Property ;
    rdfs:label 'Table Number' ;
    rdfs:comment 'The table number or seating assignment for the constituent at the event. Used for seating logistics and VIP placement. Explicitly identified in detection phase relationship data (table_assignment/table_number).' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketPricePaid rdf:type rdf:Property ;
    rdfs:label 'Ticket Price Paid' ;
    rdfs:comment 'The actual amount paid by the constituent for their ticket or registration. May differ from standard ticket price due to discounts, early bird pricing, or sponsorship levels. Corresponds to amount_paid in detection phase data.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ticketType rdf:type rdf:Property ;
    rdfs:label 'Ticket Type' ;
    rdfs:comment 'The specific ticket tier or type purchased by the constituent (e.g., general admission, VIP, early bird). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Service Assignment Id' ;
    rdfs:comment 'Unique identifier for each volunteer-beneficiary service assignment record. Primary key for the association.' ;
    rdfs:domain ind:ServiceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseLoadPriority rdf:type rdf:Property ;
    rdfs:label 'Case Load Priority' ;
    rdfs:comment 'Priority level of this beneficiary within the volunteer\'s caseload. Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:ServiceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDeliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Status' ;
    rdfs:comment 'Current status of the service delivery relationship between this volunteer and beneficiary. Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:ServiceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationId rdf:type rdf:Property ;
    rdfs:label 'Participation Id' ;
    rdfs:comment 'Unique identifier for this participation record. Primary key.' ;
    rdfs:domain ind:Participation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:giftAmount rdf:type rdf:Property ;
    rdfs:label 'Gift Amount' ;
    rdfs:comment 'The monetary amount contributed by the constituent to this campaign in this participation instance. Null if participation type is not gift. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Participation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationDate rdf:type rdf:Property ;
    rdfs:label 'Participation Date' ;
    rdfs:comment 'The date when this participation event occurred. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationType rdf:type rdf:Property ;
    rdfs:label 'Participation Type' ;
    rdfs:comment 'The type of participation or engagement activity. Explicitly identified in detection phase relationship data. Values include solicitation (outreach attempt), gift (monetary contribution), pledge (commitment to give), volunteer (time contribution), advocacy (campaign promotion), event_attendance (campaign event participation), non_response (solicited but did not respond).' ;
    rdfs:domain ind:Participation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pledgeAmount rdf:type rdf:Property ;
    rdfs:label 'Pledge Amount' ;
    rdfs:comment 'The monetary amount pledged by the constituent to this campaign in this participation instance. Null if participation type is not pledge. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Participation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseFlag rdf:type rdf:Property ;
    rdfs:label 'Response Flag' ;
    rdfs:comment 'Indicates whether the constituent responded to the campaign solicitation. True = responded (gift, pledge, volunteer, etc.); False = solicited but no response. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Participation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:solicitationChannel rdf:type rdf:Property ;
    rdfs:label 'Solicitation Channel' ;
    rdfs:comment 'The communication channel through which the constituent was solicited or engaged for this campaign. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Participation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPlanLineId rdf:type rdf:Property ;
    rdfs:label 'Distribution Plan Line Id' ;
    rdfs:comment 'Unique identifier for this distribution plan line item. Primary key.' ;
    rdfs:domain ind:DistributionPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commodityPriority rdf:type rdf:Property ;
    rdfs:label 'Commodity Priority' ;
    rdfs:comment 'Priority level of this commodity within the distribution plan, indicating urgency or importance for distribution execution.' ;
    rdfs:domain ind:DistributionPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityPlanned rdf:type rdf:Property ;
    rdfs:label 'Quantity Planned' ;
    rdfs:comment 'Planned quantity of this commodity to be distributed under this plan, expressed in the commodity\'s unit of measure.' ;
    rdfs:domain ind:DistributionPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCommodityItems rdf:type rdf:Property ;
    rdfs:label 'Total Commodity Items' ;
    rdfs:comment 'Total number of distinct commodity line items included in this distribution plan. [Moved from distribution_plan: This is a derived count that should be calculated from the number of distribution_plan_line records associated with the plan, not stored redundantly in the plan header.]' ;
    rdfs:domain ind:DistributionPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalEstimatedValue rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Value' ;
    rdfs:comment 'Total estimated value of this line item (quantity_planned × estimated_unit_cost), contributing to overall distribution plan budget.' ;
    rdfs:domain ind:DistributionPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdVolunteerAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Household Volunteer Assignment Id' ;
    rdfs:comment 'Primary key for household_volunteer_assignment' ;
    rdfs:domain ind:HouseholdVolunteerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentId rdf:type rdf:Property ;
    rdfs:label 'Assignment Id' ;
    rdfs:comment 'Unique system-generated identifier for the household-volunteer assignment record. Primary key.' ;
    rdfs:domain ind:HouseholdVolunteerAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceAssignment .

ind:lastVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Visit Date' ;
    rdfs:comment 'Calendar date of the most recent visit by this volunteer to this household. Updated after each completed visit for monitoring and follow-up scheduling.' ;
    rdfs:domain ind:HouseholdVolunteerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextVisitDate rdf:type rdf:Property ;
    rdfs:label 'Next Visit Date' ;
    rdfs:comment 'Calendar date of the next scheduled visit by this volunteer to this household. Used for volunteer scheduling and workload planning.' ;
    rdfs:domain ind:HouseholdVolunteerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitFrequency rdf:type rdf:Property ;
    rdfs:label 'Visit Frequency' ;
    rdfs:comment 'Expected frequency of volunteer visits to the household based on program requirements and household needs assessment.' ;
    rdfs:domain ind:HouseholdVolunteerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interventionComplianceId rdf:type rdf:Property ;
    rdfs:label 'Intervention Compliance Id' ;
    rdfs:comment 'Unique identifier for this intervention-specific compliance obligation record. Primary key.' ;
    rdfs:domain ind:InterventionCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commoditySupplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Commodity Supply Agreement Id' ;
    rdfs:comment 'Unique identifier for this commodity supply agreement record' ;
    rdfs:domain ind:CommoditySupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityCertificationVerified rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Verified' ;
    rdfs:comment 'Indicates whether the partner\'s quality certifications for supplying this commodity have been verified and approved (e.g., ISO standards, Sphere compliance, cold chain capability).' ;
    rdfs:domain ind:CommoditySupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitCostAgreement rdf:type rdf:Property ;
    rdfs:label 'Unit Cost Agreement' ;
    rdfs:comment 'Negotiated or agreed unit cost for this commodity from this partner, used for budgeting and sourcing decisions. May differ from standard_unit_cost in the commodity master.' ;
    rdfs:domain ind:CommoditySupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communityInterventionId rdf:type rdf:Property ;
    rdfs:label 'Community Intervention Id' ;
    rdfs:comment 'Unique identifier for this specific community-intervention implementation record' ;
    rdfs:domain ind:CommunityIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicCoverageType rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Type' ;
    rdfs:comment 'Classification of how the intervention covers this community. Explicitly identified in detection phase as relationship data. Full community: all households eligible; Partial - targeted households: specific vulnerability-based targeting; Partial - geographic zone: specific neighborhoods/sectors; Pilot: test implementation.' ;
    rdfs:domain ind:CommunityIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachedHouseholdCount rdf:type rdf:Property ;
    rdfs:label 'Reached Household Count' ;
    rdfs:comment 'Actual number of households reached by this intervention in this specific community. Explicitly identified in detection phase as relationship data. Used for coverage calculation and donor reporting.' ;
    rdfs:domain ind:CommunityIntervention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentMembershipId rdf:type rdf:Property ;
    rdfs:label 'Segment Membership Id' ;
    rdfs:comment 'Unique identifier for this segment membership record. Primary key.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'Method by which the constituent was assigned to this segment (manual, automated RFM scoring, wealth screening import, campaign response, lifecycle trigger, data import). Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentSource rdf:type rdf:Property ;
    rdfs:label 'Assignment Source' ;
    rdfs:comment 'Source system or process that created this membership record (e.g., \'Salesforce NPSP\', \'Raiser\'s Edge NXT\', \'RFM Batch Job\', \'Manual Entry\'). Referenced in Product B description.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Score At Assignment' ;
    rdfs:comment 'RFM score, wealth rating, or other quantitative score that qualified the constituent for this segment at the time of assignment. Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentAssignmentReason rdf:type rdf:Property ;
    rdfs:label 'Segment Assignment Reason' ;
    rdfs:comment 'Business rationale or rule that triggered this segment assignment (e.g., \'Total giving >$10K in FY2024\', \'LYBUNT - gave $5K in 2023, $0 in 2024\', \'Wealth screening capacity $100K+\'). Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorFundingId rdf:type rdf:Property ;
    rdfs:label 'Indicator Funding Id' ;
    rdfs:comment 'Unique identifier for this donor-indicator funding relationship record. Primary key.' ;
    rdfs:domain ind:IndicatorFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:donorTargetValue rdf:type rdf:Property ;
    rdfs:label 'Donor Target Value' ;
    rdfs:comment 'The donor-specific target value for this indicator, which may differ from the indicator\'s overall target. Represents what this specific donor expects to achieve with their funding contribution.' ;
    rdfs:domain ind:IndicatorFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingAmount rdf:type rdf:Property ;
    rdfs:label 'Funding Amount' ;
    rdfs:comment 'The monetary amount allocated by this donor specifically for this indicator. Currency should align with constituent\'s preferred currency or grant currency.' ;
    rdfs:domain ind:IndicatorFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grantReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Reference Number' ;
    rdfs:comment 'The donor\'s grant or award reference number under which this indicator funding is provided. Links to the broader grant agreement.' ;
    rdfs:domain ind:IndicatorFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorFundingStatus rdf:type rdf:Property ;
    rdfs:label 'Indicator Funding Status' ;
    rdfs:comment 'Current status of this donor-indicator funding relationship. Active = currently funded; Pending = approved but not yet active; Completed = funding period ended; Suspended = temporarily paused; Cancelled = funding withdrawn.' ;
    rdfs:domain ind:IndicatorFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedDate rdf:type rdf:Property ;
    rdfs:label 'Modified Date' ;
    rdfs:comment 'Timestamp when this donor-indicator funding relationship was last modified.' ;
    rdfs:domain ind:IndicatorFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventVolunteerAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Event Volunteer Assignment Id' ;
    rdfs:comment 'Unique identifier for the event volunteer assignment record. Primary key.' ;
    rdfs:domain ind:EventVolunteerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkInStatus rdf:type rdf:Property ;
    rdfs:label 'Check In Status' ;
    rdfs:comment 'Current attendance status of the volunteer for this event assignment (not arrived, checked in, checked out, no show). Tracks actual attendance vs. scheduled assignment.' ;
    rdfs:domain ind:EventVolunteerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleAssignment rdf:type rdf:Property ;
    rdfs:label 'Role Assignment' ;
    rdfs:comment 'The specific role or function assigned to the volunteer for this event (e.g., registration desk, setup crew, catering support, cleanup, greeter, auction support). This attribute exists only in the context of the assignment.' ;
    rdfs:domain ind:EventVolunteerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftEndTime rdf:type rdf:Property ;
    rdfs:label 'Shift End Time' ;
    rdfs:comment 'The scheduled end date and time for the volunteer\'s shift at this event. Specific to this volunteer-event assignment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTime rdf:type rdf:Property ;
    rdfs:label 'Shift Start Time' ;
    rdfs:comment 'The scheduled start date and time for the volunteer\'s shift at this event. Specific to this volunteer-event assignment.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partnerComplianceId rdf:type rdf:Property ;
    rdfs:label 'Partner Compliance Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a partner compliance assignment record. Primary key.' ;
    rdfs:domain ind:PartnerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Partner Compliance Status' ;
    rdfs:comment 'Current status of this partner\'s fulfillment of this specific obligation. Tracks lifecycle from assignment through completion. Values: assigned (obligation applies but work not started), in_progress (partner actively working on fulfillment), submitted (partner submitted but pending review), completed (successfully fulfilled), overdue (past due date without completion), waived (obligation waived for this partner), not_applicable (determined not to apply to this partner).' ;
    rdfs:domain ind:PartnerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleFocalPoint rdf:type rdf:Property ;
    rdfs:label 'Responsible Focal Point' ;
    rdfs:comment 'Name or identifier of the specific individual at the partner organization responsible for fulfilling this obligation. May reference a contact from partner_org embedded contact records or be a free-text name. Used for accountability and follow-up communications.' ;
    rdfs:domain ind:PartnerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverStatus rdf:type rdf:Property ;
    rdfs:label 'Waiver Status' ;
    rdfs:comment 'Indicates whether a waiver has been requested or granted for this partner for this obligation. Values: none (no waiver), requested (partner requested waiver, pending decision), approved (waiver granted, obligation does not apply), denied (waiver request rejected, obligation still applies). Used when partners seek exemptions from specific obligations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignParticipationId rdf:type rdf:Property ;
    rdfs:label 'Campaign Participation Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a specific partner organization\'s participation in a specific advocacy campaign.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participationEndDate rdf:type rdf:Property ;
    rdfs:label 'Participation End Date' ;
    rdfs:comment 'The date when the partner organization\'s active participation in this campaign ended or is planned to end. May differ from the campaign end date if the partner\'s involvement is time-limited. Null for ongoing participation. Used for tracking partner engagement duration and post-campaign evaluation.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationStartDate rdf:type rdf:Property ;
    rdfs:label 'Participation Start Date' ;
    rdfs:comment 'The date when the partner organization\'s active participation in this campaign began. May differ from the campaign start date if the partner joined mid-campaign. Used for tracking partner engagement duration and coordination timelines.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerRole rdf:type rdf:Property ;
    rdfs:label 'Partner Role' ;
    rdfs:comment 'The specific role the partner organization plays in this campaign. Distinguishes between lead partners (primary coordinators), supporting partners (secondary contributors), implementing partners (field execution), technical partners (subject matter expertise), financial partners (funding contributors), and media partners (amplification and outreach). This attribute exists only in the context of a specific partner-campaign relationship.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Visibility Level' ;
    rdfs:comment 'The level of public visibility and attribution the partner organization receives for their participation in this campaign. Public means prominently featured in campaign materials; acknowledged means listed as a partner but not prominently featured; confidential means partner involvement is tracked internally but not publicly disclosed; anonymous means partner requested no attribution. Visibility level varies by partner preference and campaign context.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Id' ;
    rdfs:comment 'Unique identifier for this enrollment record. Primary key for the enrollment association.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendanceRate rdf:type rdf:Property ;
    rdfs:label 'Attendance Rate' ;
    rdfs:comment 'Percentage of scheduled component activities or sessions that the registrant attended. Calculated as (sessions_attended / sessions_scheduled) * 100. Used for engagement monitoring, outcome correlation analysis, and donor reporting on program participation quality. Explicitly identified in detection phase.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentForComponent rdf:type rdf:Property ;
    rdfs:label 'Consent For Component' ;
    rdfs:comment 'Indicates whether the registrant (or guardian) provided informed consent specifically for participation in this component. Some components (e.g., health screening, psychosocial support) require additional consent beyond general registration consent.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdAt rdf:type rdf:Property ;
    rdfs:label 'Created At' ;
    rdfs:comment 'System timestamp when this enrollment record was created in the database. Used for audit trail and data lineage.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceDeliveryModality rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Modality' ;
    rdfs:comment 'The method or channel through which this component\'s services are delivered to the registrant. Distinguishes in-person group sessions, mobile outreach, remote/digital delivery, hybrid approaches, cash transfers, vouchers, or direct provision of goods/services. Critical for modality-disaggregated MEL reporting required by donors. Explicitly identified in detection phase.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedAt rdf:type rdf:Property ;
    rdfs:label 'Updated At' ;
    rdfs:comment 'System timestamp when this enrollment record was last modified. Used for audit trail and change tracking.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entitlementId rdf:type rdf:Property ;
    rdfs:label 'Entitlement Id' ;
    rdfs:comment 'Unique surrogate identifier for each beneficiary-commodity entitlement record' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByUserUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User User Account Id' ;
    rdfs:comment 'Identifier of the system user who most recently modified this entitlement record. Used for accountability and audit purposes.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:entitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Entitlement Status' ;
    rdfs:comment 'Current lifecycle status of this entitlement record. Controls whether the beneficiary is currently eligible to receive this commodity in distribution operations.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialDietaryRequirement rdf:type rdf:Property ;
    rdfs:label 'Special Dietary Requirement' ;
    rdfs:comment 'Free-text description of any special dietary requirements, restrictions, or substitutions applicable to this beneficiary-commodity entitlement (e.g., halal, kosher, allergen-free, therapeutic food for MAM/SAM cases). Used for commodity substitution and specialized ration planning.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerabilityBasedAdjustment rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Based Adjustment' ;
    rdfs:comment 'Multiplier or adjustment factor applied to the base entitlement quantity based on the beneficiary\'s vulnerability category, protection status, or special needs (e.g., 1.5x for pregnant/lactating women, 2.0x for severely malnourished children). Applied during ration calculation.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volunteerTrainingCompletionId rdf:type rdf:Property ;
    rdfs:label 'Volunteer Training Completion Id' ;
    rdfs:comment 'Primary key for volunteer_training_completion' ;
    rdfs:domain ind:VolunteerTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Assessment Score Percentage' ;
    rdfs:comment 'Percentage score achieved by the volunteer on the training assessment, if assessment_required_flag is true. Used to determine pass/fail status against training_program.passing_score_percentage.' ;
    rdfs:domain ind:VolunteerTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCompletionCode rdf:type rdf:Property ;
    rdfs:label 'Training Completion Code' ;
    rdfs:comment 'Unique identifier for this training completion record. Primary key.' ;
    rdfs:domain ind:VolunteerTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volunteerPolicyAcknowledgmentId rdf:type rdf:Property ;
    rdfs:label 'Volunteer Policy Acknowledgment Id' ;
    rdfs:comment 'Primary key for volunteer_policy_acknowledgment' ;
    rdfs:domain ind:VolunteerPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acknowledgedByName rdf:type rdf:Property ;
    rdfs:label 'Acknowledged By Name' ;
    rdfs:comment 'Full name of the volunteer at the time of acknowledgment for audit trail purposes.' ;
    rdfs:domain ind:VolunteerPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyAcknowledgmentCode rdf:type rdf:Property ;
    rdfs:label 'Policy Acknowledgment Code' ;
    rdfs:comment 'Unique identifier for this policy acknowledgment record. Primary key.' ;
    rdfs:domain ind:VolunteerPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletionFlag rdf:type rdf:Property ;
    rdfs:label 'Training Completion Flag' ;
    rdfs:comment 'Indicates whether associated training was completed as part of the acknowledgment process.' ;
    rdfs:domain ind:VolunteerPolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentParticipationId rdf:type rdf:Property ;
    rdfs:label 'Assessment Participation Id' ;
    rdfs:comment 'Unique identifier for this assessment participation record. Primary key.' ;
    rdfs:domain ind:AssessmentParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Date and time when this volunteer completed their participation in this assessment. Used for timesheet validation and operational reporting.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:enumeratorRole rdf:type rdf:Property ;
    rdfs:label 'Enumerator Role' ;
    rdfs:comment 'The specific role this volunteer performed in this assessment. Values include lead (team lead), enumerator (data collector), facilitator (for FGDs), translator (language support), supervisor (quality oversight). This attribute exists only in the context of a specific assessment participation—the same volunteer may be lead on one assessment and enumerator on another.' ;
    rdfs:domain ind:AssessmentParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'Current status of this volunteer\'s participation in this assessment. Tracks lifecycle from recruitment through completion. Values: confirmed (volunteer committed), completed (fieldwork done), cancelled (volunteer withdrew), no_show (volunteer did not appear). Supports operational coordination and volunteer reliability tracking.' ;
    rdfs:domain ind:AssessmentParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveysCompletedCount rdf:type rdf:Property ;
    rdfs:label 'Surveys Completed Count' ;
    rdfs:comment 'Number of individual survey submissions, interviews, or FGD sessions this volunteer completed during this assessment. Used for productivity tracking, workload balancing, and incentive calculation. This is assessment-specific—cannot be stored on volunteer (varies by assessment) or assessment (varies by volunteer).' ;
    rdfs:domain ind:AssessmentParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Training Completion Status' ;
    rdfs:comment 'Status indicating whether this volunteer completed the methodology-specific training required for this assessment (e.g., MUAC screening training, PDM interview protocol, KoboToolbox form training). Values: completed (training done), not_required (volunteer already certified), pending (scheduled), incomplete (did not complete). This is assessment-specific because different assessment types require different training.' ;
    rdfs:domain ind:AssessmentParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardSiteAllocationId rdf:type rdf:Property ;
    rdfs:label 'Award Site Allocation Id' ;
    rdfs:comment 'Unique identifier for this award-site allocation record. Primary key.' ;
    rdfs:domain ind:AwardSiteAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiaryTargetAtSite rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Target At Site' ;
    rdfs:comment 'The target number of beneficiaries or persons of concern (PoC) that this award aims to reach at this specific project site. Used for site-level performance monitoring and donor reporting.' ;
    rdfs:domain ind:AwardSiteAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteActivationDate rdf:type rdf:Property ;
    rdfs:label 'Site Activation Date' ;
    rdfs:comment 'The date when this specific award became active at this project site. Governs when site-level expenditures can begin charging to this award.' ;
    rdfs:domain ind:AwardSiteAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteBudgetAllocation rdf:type rdf:Property ;
    rdfs:label 'Site Budget Allocation' ;
    rdfs:comment 'The amount of the award\'s total budget allocated to activities at this specific project site, in the award\'s functional currency. Used for site-level financial tracking and donor reporting.' ;
    rdfs:domain ind:AwardSiteAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteDeactivationDate rdf:type rdf:Property ;
    rdfs:label 'Site Deactivation Date' ;
    rdfs:comment 'The date when this award\'s activities at this project site were officially closed or transitioned. Null for currently active allocations.' ;
    rdfs:domain ind:AwardSiteAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteRoleInAward rdf:type rdf:Property ;
    rdfs:label 'Site Role In Award' ;
    rdfs:comment 'The functional role this project site plays in the award\'s implementation strategy (e.g., primary implementation site, secondary site, beneficiary registration point, distribution center, monitoring site).' ;
    rdfs:domain ind:AwardSiteAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current operational status of this award at this specific site: planned (allocation approved but not yet active), active (currently implementing), suspended (temporarily halted), closed (implementation complete or terminated).' ;
    rdfs:domain ind:AwardSiteAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Asset Allocation Id' ;
    rdfs:comment 'Unique identifier for this grant-asset allocation record. Primary key.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationEndDate rdf:type rdf:Property ;
    rdfs:label 'Allocation End Date' ;
    rdfs:comment 'The date on which this cost allocation relationship ended, typically due to award closeout, asset disposal, or reallocation to another award.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationJustification rdf:type rdf:Property ;
    rdfs:label 'Allocation Justification' ;
    rdfs:comment 'Business justification for allocating this asset to this grant award, used for audit trails and allowable cost documentation.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStartDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Start Date' ;
    rdfs:comment 'The date on which this cost allocation relationship became effective, typically aligned with the award start date or asset procurement date, whichever is later.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationAllocation rdf:type rdf:Property ;
    rdfs:label 'Depreciation Allocation' ;
    rdfs:comment 'The depreciation expense allocated to this grant award for the asset over the award period of performance. Used for indirect cost recovery and financial reporting to donors.' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Donor Approval Required' ;
    rdfs:comment 'Indicates whether this asset allocation requires explicit donor approval based on the award\'s regulatory framework and asset value thresholds (e.g., equipment over $5,000 under 2 CFR 200).' ;
    rdfs:domain ind:AssetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:awardPositionFundingId rdf:type rdf:Property ;
    rdfs:label 'Award Position Funding Id' ;
    rdfs:comment 'Unique identifier for this award-position funding allocation record. Primary key.' ;
    rdfs:domain ind:AwardPositionFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cost allocation amount. Typically matches the award currency or the NGO\'s functional currency depending on cost allocation methodology.' ;
    rdfs:domain ind:AwardPositionFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Amount' ;
    rdfs:comment 'The total budgeted or actual cost amount allocated from this award to fund this position during the funding period. Calculated based on effort percentage, position salary, benefits, and applicable indirect costs. Used for grant budget tracking and financial reporting.' ;
    rdfs:domain ind:AwardPositionFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingStatus rdf:type rdf:Property ;
    rdfs:label 'Funding Status' ;
    rdfs:comment 'Current status of this funding allocation: planned (budgeted but not yet active), active (currently funding the position), suspended (temporarily paused), closed (funding period ended or allocation terminated).' ;
    rdfs:domain ind:AwardPositionFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantStaffAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Grant Staff Assignment Id' ;
    rdfs:comment 'Primary key for grant_staff_assignment' ;
    rdfs:domain ind:GrantStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByStaffStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Approved By Staff Staff Member Id' ;
    rdfs:comment 'Reference to the staff_member_id of the manager or grants officer who approved this assignment. Used for audit trail and compliance verification.' ;
    rdfs:domain ind:GrantStaffAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:staffAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Staff Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each staff assignment record. Primary key for the association.' ;
    rdfs:domain ind:GrantStaffAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforceStaffAssignment .

ind:budgetedFte rdf:type rdf:Property ;
    rdfs:label 'Budgeted Fte' ;
    rdfs:comment 'The full-time equivalent (FTE) amount budgeted for this staff member on this award in the original grant proposal or budget. Used for variance analysis between budgeted and actual effort.' ;
    rdfs:domain ind:GrantStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentIndicatorId rdf:type rdf:Property ;
    rdfs:label 'Component Indicator Id' ;
    rdfs:comment 'Unique identifier for this component-indicator assignment. Primary key.' ;
    rdfs:domain ind:ComponentIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentIndicatorStatus rdf:type rdf:Property ;
    rdfs:label 'Component Indicator Status' ;
    rdfs:comment 'Current status of this component-indicator assignment. Indicates whether this indicator is actively being measured for this component.' ;
    rdfs:domain ind:ComponentIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentSystemUsageId rdf:type rdf:Property ;
    rdfs:label 'Component System Usage Id' ;
    rdfs:comment 'Unique identifier for this component-system usage relationship. Primary key.' ;
    rdfs:domain ind:ComponentSystemUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentSystemRole rdf:type rdf:Property ;
    rdfs:label 'Component System Role' ;
    rdfs:comment 'The functional role this system plays for this specific component (e.g., Data Collection for KoboToolbox in a WASH component, Beneficiary Management for Salesforce in a cash transfer component). Explicitly identified in detection phase.' ;
    rdfs:domain ind:ComponentSystemUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Integration Required Flag' ;
    rdfs:comment 'Indicates whether this component requires data integration or synchronization between this system and other systems in the component\'s technology stack.' ;
    rdfs:domain ind:ComponentSystemUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryContact rdf:type rdf:Property ;
    rdfs:label 'Primary Contact' ;
    rdfs:comment 'Name or identifier of the individual responsible for managing this system usage for this component (e.g., component MEL officer, data focal point).' ;
    rdfs:domain ind:ComponentSystemUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageStatus rdf:type rdf:Property ;
    rdfs:label 'Usage Status' ;
    rdfs:comment 'Current status of this component-system usage relationship (Active, Inactive, Pilot, Sunset, Decommissioned). Tracks the lifecycle of the usage relationship independently from the component or system status.' ;
    rdfs:domain ind:ComponentSystemUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAccessCount rdf:type rdf:Property ;
    rdfs:label 'User Access Count' ;
    rdfs:comment 'Number of users from this component team who have active access to this system platform. Tracks component-specific system access provisioning. Explicitly identified in detection phase.' ;
    rdfs:domain ind:ComponentSystemUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consortiumCommunicationId rdf:type rdf:Property ;
    rdfs:label 'Consortium Communication Id' ;
    rdfs:comment 'Primary key for the consortium_communication association' ;
    rdfs:domain ind:ConsortiumCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewedByStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Staff Member Id' ;
    rdfs:comment 'Reference to the staff member from this consortium who conducted the review and approval. Captures accountability for consortium governance compliance in joint communications.' ;
    rdfs:domain ind:ConsortiumCommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:brandingGuidelines rdf:type rdf:Property ;
    rdfs:label 'Branding Guidelines' ;
    rdfs:comment 'Specific branding and logo usage guidelines for this consortium in the communication plan. Captures consortium logo placement requirements, member organization logo protocols, lead agency branding hierarchy, pooled fund mechanism branding requirements, and any donor-mandated branding restrictions for joint communications.' ;
    rdfs:domain ind:ConsortiumCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consortiumRole rdf:type rdf:Property ;
    rdfs:label 'Consortium Role' ;
    rdfs:comment 'The specific role this consortium plays in the communication plan execution. Lead_communicator indicates the consortium is the primary author/distributor; contributing_partner indicates input/review responsibilities; review_only indicates approval rights without authorship; information_recipient indicates the consortium receives but does not contribute to the communication.' ;
    rdfs:domain ind:ConsortiumCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Review Completed Date' ;
    rdfs:comment 'Date when this consortium completed its review and approval process for the communication plan. Used for tracking consortium governance cycle times and coordination efficiency.' ;
    rdfs:domain ind:ConsortiumCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewDeadline rdf:type rdf:Property ;
    rdfs:label 'Review Deadline' ;
    rdfs:comment 'Deadline by which this consortium must complete its review and approval process for the communication plan. Critical for time-sensitive humanitarian coordination reporting such as OCHA SitReps and cluster updates.' ;
    rdfs:domain ind:ConsortiumCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visibilityRequirements rdf:type rdf:Property ;
    rdfs:label 'Visibility Requirements' ;
    rdfs:comment 'Specific visibility and acknowledgment requirements for this consortium in the communication deliverables. Captures donor visibility clauses, OCHA cluster reporting requirements, IASC working group acknowledgment protocols, and Grand Bargain localization visibility commitments that must be reflected in the communication materials.' ;
    rdfs:domain ind:ConsortiumCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Tool Authorization Id' ;
    rdfs:comment 'Unique identifier for this volunteer tool authorization record. Primary key.' ;
    rdfs:domain ind:ToolAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizingStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Authorizing Staff Member Id' ;
    rdfs:comment 'Identifier of the MEL staff member who authorized this volunteer to use this tool, establishing accountability for authorization decisions.' ;
    rdfs:domain ind:ToolAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'Date when the volunteer was officially authorized to administer this data collection tool independently. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:ToolAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiry Date' ;
    rdfs:comment 'Date when the volunteers authorization to use this tool expires and recertification is required. Critical for compliance and data quality control. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:ToolAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deploymentCount rdf:type rdf:Property ;
    rdfs:label 'Deployment Count' ;
    rdfs:comment 'Number of times this volunteer has been deployed to use this specific tool in field data collection activities, tracking experience level.' ;
    rdfs:domain ind:ToolAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastRefresherTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Refresher Training Date' ;
    rdfs:comment 'Date of the most recent refresher training session completed by the volunteer for this tool, used to track ongoing competency maintenance.' ;
    rdfs:domain ind:ToolAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionParticipationId rdf:type rdf:Property ;
    rdfs:label 'Distribution Participation Id' ;
    rdfs:comment 'Unique identifier for this volunteer participation record. Primary key.' ;
    rdfs:domain ind:DistributionParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiariesServed rdf:type rdf:Property ;
    rdfs:label 'Beneficiaries Served' ;
    rdfs:comment 'Number of beneficiaries directly served or processed by this volunteer during this distribution event (e.g., registrations completed, verifications conducted).' ;
    rdfs:domain ind:DistributionParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftAssignment rdf:type rdf:Property ;
    rdfs:label 'Shift Assignment' ;
    rdfs:comment 'The time shift during which the volunteer was assigned to work at this distribution event.' ;
    rdfs:domain ind:DistributionParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volunteerRole rdf:type rdf:Property ;
    rdfs:label 'Volunteer Role' ;
    rdfs:comment 'The specific functional role the volunteer performed during this distribution event (e.g., registration, verification, commodity handling, crowd management). This is event-specific and varies by distribution needs.' ;
    rdfs:domain ind:DistributionParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundComplianceTrackingId rdf:type rdf:Property ;
    rdfs:label 'Fund Compliance Tracking Id' ;
    rdfs:comment 'Unique identifier for this fund-requirement compliance tracking record. Primary key.' ;
    rdfs:domain ind:FundComplianceTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedStaffMemberId rdf:type rdf:Property ;
    rdfs:label 'Assigned Staff Member Id' ;
    rdfs:comment 'Reference to the staff member assigned responsibility for ensuring this fund\'s compliance with this specific requirement. May differ from the general requirement owner.' ;
    rdfs:domain ind:FundComplianceTracking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffMember .

ind:fundFinanceFundId rdf:type rdf:Property ;
    rdfs:label 'Fund Finance Fund Id' ;
    rdfs:comment 'Foreign key linking to the fund being tracked for compliance' ;
    rdfs:domain ind:FundComplianceTracking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceFund .

ind:requirementApplicabilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Requirement Applicability End Date' ;
    rdfs:comment 'The date on which this donor requirement ceases to apply to this specific fund. May differ from fund effective_end_date if requirement is waived or modified.' ;
    rdfs:domain ind:FundComplianceTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requirementApplicabilityStartDate rdf:type rdf:Property ;
    rdfs:label 'Requirement Applicability Start Date' ;
    rdfs:comment 'The date from which this donor requirement becomes applicable to this specific fund. May differ from the fund effective_start_date if requirement is added mid-grant.' ;
    rdfs:domain ind:FundComplianceTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Decision Date' ;
    rdfs:comment 'Date on which the donor made a decision (granted or denied) on the waiver request for this fund-requirement combination.' ;
    rdfs:domain ind:FundComplianceTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverRequestDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Request Date' ;
    rdfs:comment 'Date on which a waiver was formally requested for this fund-requirement combination.' ;
    rdfs:domain ind:FundComplianceTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:volunteerDeployment2Id rdf:type rdf:Property ;
    rdfs:label 'Volunteer Deployment2 Id' ;
    rdfs:comment 'Primary key for volunteer_deployment2' ;
    rdfs:domain ind:VolunteerDeployment2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:messageThreadId rdf:type rdf:Property ;
    rdfs:label 'Message Thread Id' ;
    rdfs:comment 'Primary key for message_thread' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedToTeamId rdf:type rdf:Property ;
    rdfs:label 'Assigned To Team Id' ;
    rdfs:comment 'Reference to the team or department responsible for handling this message thread.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldTeam .

ind:accountReference rdf:type rdf:Property ;
    rdfs:label 'Account Reference' ;
    rdfs:comment 'Reference to the organizational account associated with this message thread, if applicable.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'The date and time when the message thread was archived. Null if not archived.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complaintCategory rdf:type rdf:Property ;
    rdfs:label 'Complaint Category' ;
    rdfs:comment 'Classification of the complaint type if this thread is marked as a complaint (service quality, staff conduct, discrimination, safety concern, fraud, other).' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProtectionClassification rdf:type rdf:Property ;
    rdfs:label 'Data Protection Classification' ;
    rdfs:comment 'Data classification level assigned to the message thread content based on sensitivity and privacy requirements.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'The geographic region or operational area associated with this message thread, relevant for field operations and beneficiary communications.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'The date and time when the message thread was first created or initiated by the originating party.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isArchived rdf:type rdf:Property ;
    rdfs:label 'Is Archived' ;
    rdfs:comment 'Indicates whether the message thread has been archived and moved out of active communication management.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isComplaint rdf:type rdf:Property ;
    rdfs:label 'Is Complaint' ;
    rdfs:comment 'Indicates whether this message thread represents a formal complaint or grievance requiring special handling per accountability standards.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConfidential rdf:type rdf:Property ;
    rdfs:label 'Is Confidential' ;
    rdfs:comment 'Indicates whether the message thread contains confidential or sensitive information requiring restricted access and special handling.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMessageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Message Timestamp' ;
    rdfs:comment 'The date and time when the most recent message was added to this thread.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageCount rdf:type rdf:Property ;
    rdfs:label 'Message Count' ;
    rdfs:comment 'Total number of individual messages exchanged within this thread.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionEndDate rdf:type rdf:Property ;
    rdfs:label 'Retention End Date' ;
    rdfs:comment 'The date after which this message thread should be archived or deleted according to data retention policies and regulatory requirements.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:satisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Rating' ;
    rdfs:comment 'Numeric satisfaction rating provided by the contact after thread resolution, typically on a scale of 1 to 5, used to measure service quality.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:threadReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Thread Reference Number' ;
    rdfs:comment 'Human-readable business identifier for the message thread, used in external communications and reporting.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threadStatus rdf:type rdf:Property ;
    rdfs:label 'Thread Status' ;
    rdfs:comment 'Current lifecycle status of the message thread indicating its state in the communication workflow.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threadSubject rdf:type rdf:Property ;
    rdfs:label 'Thread Subject' ;
    rdfs:comment 'The subject or title of the message thread, summarizing the topic or purpose of the conversation.' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threadType rdf:type rdf:Property ;
    rdfs:label 'Thread Type' ;
    rdfs:comment 'Classification of the message thread based on its purpose and audience (donor communication, advocacy campaign, beneficiary feedback, complaint, media inquiry, internal communication).' ;
    rdfs:domain ind:MessageThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAgencyId rdf:type rdf:Property ;
    rdfs:label 'Parent Agency Id' ;
    rdfs:comment 'Reference to the parent or umbrella agency if this cognizant agency is a sub-agency or division of a larger governmental body.' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CognizantAgency .

ind:agencyAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Agency Address Line1' ;
    rdfs:comment 'First line of the cognizant agency\'s official mailing address (street address, building number).' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Agency Address Line2' ;
    rdfs:comment 'Second line of the cognizant agency\'s official mailing address (suite, floor, department).' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyCity rdf:type rdf:Property ;
    rdfs:label 'Agency City' ;
    rdfs:comment 'City where the cognizant agency is located.' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyCode rdf:type rdf:Property ;
    rdfs:label 'Agency Code' ;
    rdfs:comment 'Official alphanumeric code assigned to the cognizant agency by the federal government or oversight body. Used as the business identifier in grant documentation and audit reports.' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyCountryCode rdf:type rdf:Property ;
    rdfs:label 'Agency Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the cognizant agency\'s location.' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Full legal name of the cognizant agency responsible for oversight and audit coordination.' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyPostalCode rdf:type rdf:Property ;
    rdfs:label 'Agency Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the cognizant agency\'s address.' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyShortName rdf:type rdf:Property ;
    rdfs:label 'Agency Short Name' ;
    rdfs:comment 'Abbreviated or commonly used short name for the cognizant agency (e.g., USAID, HHS, DOD).' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyStateProvince rdf:type rdf:Property ;
    rdfs:label 'Agency State Province' ;
    rdfs:comment 'State, province, or administrative region where the cognizant agency is located.' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the cognizant agency by governmental or organizational level.' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Required frequency of audits coordinated by the cognizant agency, expressed in months (e.g., 12 for annual, 24 for biennial).' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designationDate rdf:type rdf:Property ;
    rdfs:label 'Designation Date' ;
    rdfs:comment 'Date when the agency was officially designated as the cognizant agency for the organization.' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designationEndDate rdf:type rdf:Property ;
    rdfs:label 'Designation End Date' ;
    rdfs:comment 'Date when the cognizant agency designation ended or is scheduled to end. Null for ongoing designations.' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:federalAwardThresholdUsd rdf:type rdf:Property ;
    rdfs:label 'Federal Award Threshold Usd' ;
    rdfs:comment 'Minimum dollar threshold of federal awards that triggers cognizant agency oversight responsibility, expressed in US dollars.' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indirectCostRateApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Rate Approval Authority' ;
    rdfs:comment 'Indicates whether the cognizant agency has authority to approve indirect cost rate proposals for organizations under its oversight.' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryCognizantAgency rdf:type rdf:Property ;
    rdfs:label 'Is Primary Cognizant Agency' ;
    rdfs:comment 'Indicates whether this is the primary cognizant agency for the organization when multiple agencies have oversight roles.' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionScope rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Scope' ;
    rdfs:comment 'Description of the geographic or programmatic scope of the cognizant agency\'s oversight authority (e.g., nationwide, regional, sector-specific).' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oversightStatus rdf:type rdf:Property ;
    rdfs:label 'Oversight Status' ;
    rdfs:comment 'Current operational status of the cognizant agency\'s oversight authority.' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPortalUrl rdf:type rdf:Property ;
    rdfs:label 'Reporting Portal Url' ;
    rdfs:comment 'URL of the online portal where organizations submit compliance reports and audit documentation to the cognizant agency.' ;
    rdfs:domain ind:CognizantAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersionId rdf:type rdf:Property ;
    rdfs:label 'Budget Version Id' ;
    rdfs:comment 'Reference to the budget version applicable to this fiscal period. Used for Budget vs. Actual (BvA) tracking and variance analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetVersion .

ind:priorYearPeriodId rdf:type rdf:Property ;
    rdfs:label 'Prior Year Period Id' ;
    rdfs:comment 'Reference to the corresponding fiscal period in the prior fiscal year. Enables year-over-year comparative analysis.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:daysInPeriod rdf:type rdf:Property ;
    rdfs:label 'Days In Period' ;
    rdfs:comment 'Total number of calendar days in the fiscal period. Used for prorations, accruals, and time-weighted calculations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed description or notes about the fiscal period, including any special considerations, adjustments, or organizational context.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Date' ;
    rdfs:comment 'The date for which exchange rates are locked for multi-currency translation in this fiscal period. Nullable for single-currency organizations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAdjustmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment Period' ;
    rdfs:comment 'Indicates whether this is a special adjustment period (typically Period 13) used for year-end closing entries and corrections.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isYearEndPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Year End Period' ;
    rdfs:comment 'Indicates whether this is the final period of the fiscal year, requiring special year-end closing procedures and financial statement preparation.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockedDate rdf:type rdf:Property ;
    rdfs:label 'Locked Date' ;
    rdfs:comment 'The date when the fiscal period was permanently locked, preventing any further modifications. Nullable if not yet locked.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodCode rdf:type rdf:Property ;
    rdfs:label 'Period Code' ;
    rdfs:comment 'Short alphanumeric code representing the fiscal period (e.g., FY24-Q1, P01-2024). Used as a business identifier for reporting and reference.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name of the fiscal period (e.g., \'January 2024\', \'Q1 FY2024\', \'Period 1 - FY2024\').' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodNumber rdf:type rdf:Property ;
    rdfs:label 'Period Number' ;
    rdfs:comment 'Sequential number of the period within the fiscal year (e.g., 1 for January, 4 for Q1, 12 for December). Used for ordering and reporting.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Current lifecycle status of the fiscal period. Open allows transactions; closed prevents new entries but allows adjustments; locked is final and immutable; future indicates not yet active.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the fiscal period by duration and frequency (monthly, quarterly, semi-annual, annual, or custom).' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarterNumber rdf:type rdf:Property ;
    rdfs:label 'Quarter Number' ;
    rdfs:comment 'The fiscal quarter number (1-4) to which this period belongs. Nullable for non-quarterly periods.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for financial reporting in this period (e.g., USD, EUR, GBP). Supports multi-currency nonprofit operations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workingDaysInPeriod rdf:type rdf:Property ;
    rdfs:label 'Working Days In Period' ;
    rdfs:comment 'Number of business working days in the fiscal period, excluding weekends and holidays. Used for operational metrics and staffing calculations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessConstraints rdf:type rdf:Property ;
    rdfs:label 'Access Constraints' ;
    rdfs:comment 'Primary type of access constraints affecting humanitarian operations in the country. Used for operational planning and risk mitigation.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeClusters rdf:type rdf:Property ;
    rdfs:label 'Active Clusters' ;
    rdfs:comment 'Comma-separated list of active humanitarian clusters in the country (e.g., WASH, Health, Nutrition, Shelter, Protection). Used for coordination and reporting alignment.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalCity rdf:type rdf:Property ;
    rdfs:label 'Capital City' ;
    rdfs:comment 'Name of the capital city of the country. Often the location of the country office headquarters.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterCoordinationActive rdf:type rdf:Property ;
    rdfs:label 'Cluster Coordination Active' ;
    rdfs:comment 'Indicates whether the OCHA cluster coordination system is active in this country. Affects reporting obligations and inter-agency coordination requirements.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryCodeAlpha2 rdf:type rdf:Property ;
    rdfs:label 'Country Code Alpha2' ;
    rdfs:comment 'Two-letter country code as defined by ISO 3166-1 alpha-2 standard. Used for international identification and data exchange.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCodeAlpha3 rdf:type rdf:Property ;
    rdfs:label 'Country Code Alpha3' ;
    rdfs:comment 'Three-letter country code as defined by ISO 3166-1 alpha-3 standard. Commonly used in humanitarian reporting and OCHA coordination.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCodeNumeric rdf:type rdf:Property ;
    rdfs:label 'Country Code Numeric' ;
    rdfs:comment 'Three-digit numeric country code as defined by ISO 3166-1 numeric standard.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryName rdf:type rdf:Property ;
    rdfs:label 'Country Name' ;
    rdfs:comment 'Official full name of the country as recognized by the United Nations.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfficeEstablished rdf:type rdf:Property ;
    rdfs:label 'Country Office Established' ;
    rdfs:comment 'Indicates whether the organization has an established country office with permanent presence in this country.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsProcedures rdf:type rdf:Property ;
    rdfs:label 'Customs Procedures' ;
    rdfs:comment 'Summary of customs clearance procedures and requirements for importing humanitarian supplies. Critical for supply chain and logistics planning.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fragilityStatus rdf:type rdf:Property ;
    rdfs:label 'Fragility Status' ;
    rdfs:comment 'Classification of the countrys fragility and conflict status. Critical for risk assessment, security planning, and humanitarian response prioritization.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisDataAvailable rdf:type rdf:Property ;
    rdfs:label 'Gis Data Available' ;
    rdfs:comment 'Indicates whether comprehensive GIS data layers (administrative boundaries, roads, facilities) are available for this country to support location-based analysis.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governmentPartnershipStatus rdf:type rdf:Property ;
    rdfs:label 'Government Partnership Status' ;
    rdfs:comment 'Level of partnership and collaboration with the national government. Affects program implementation modalities and coordination mechanisms.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humanitarianResponsePlanActive rdf:type rdf:Property ;
    rdfs:label 'Humanitarian Response Plan Active' ;
    rdfs:comment 'Indicates whether an active Humanitarian Response Plan coordinated by OCHA exists for this country. Used to determine cluster coordination requirements and reporting obligations.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incomeClassification rdf:type rdf:Property ;
    rdfs:label 'Income Classification' ;
    rdfs:comment 'World Bank income classification category for the country. Used for program eligibility, funding allocation, and needs assessment.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:koboDeploymentActive rdf:type rdf:Property ;
    rdfs:label 'Kobo Deployment Active' ;
    rdfs:comment 'Indicates whether KoboToolbox mobile data collection is actively deployed for field assessments and monitoring in this country.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landAreaSqKm rdf:type rdf:Property ;
    rdfs:label 'Land Area Sq Km' ;
    rdfs:comment 'Total land area of the country in square kilometers. Used for logistics planning, geographic information system (GIS) analysis, and distribution coverage calculations.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landlocked rdf:type rdf:Property ;
    rdfs:label 'Landlocked' ;
    rdfs:comment 'Indicates whether the country is landlocked with no direct access to the sea. Critical for supply chain and logistics planning.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leastDevelopedCountry rdf:type rdf:Property ;
    rdfs:label 'Least Developed Country' ;
    rdfs:comment 'Indicates whether the country is classified as a Least Developed Country by the United Nations. Affects funding eligibility and program prioritization.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memorandumOfUnderstandingSigned rdf:type rdf:Property ;
    rdfs:label 'Memorandum Of Understanding Signed' ;
    rdfs:comment 'Indicates whether a formal Memorandum of Understanding has been signed with the national government for humanitarian operations.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ochaPresence rdf:type rdf:Property ;
    rdfs:label 'Ocha Presence' ;
    rdfs:comment 'Indicates whether OCHA has an active presence in the country. Determines cluster coordination mechanisms and humanitarian reporting requirements.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:officeEstablishmentDate rdf:type rdf:Property ;
    rdfs:label 'Office Establishment Date' ;
    rdfs:comment 'Date when the country office was officially established. Null if no country office exists.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:officialLanguages rdf:type rdf:Property ;
    rdfs:label 'Official Languages' ;
    rdfs:comment 'Comma-separated list of official languages spoken in the country. Used for translation requirements, field staff recruitment, and beneficiary communication planning.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:population rdf:type rdf:Property ;
    rdfs:label 'Population' ;
    rdfs:comment 'Total population of the country based on the most recent census or UN estimate. Used for needs assessment and program scale planning.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:populationYear rdf:type rdf:Property ;
    rdfs:label 'Population Year' ;
    rdfs:comment 'Year of the population estimate or census data. Indicates the currency of population data.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDonorCountries rdf:type rdf:Property ;
    rdfs:label 'Primary Donor Countries' ;
    rdfs:comment 'Comma-separated list of primary donor countries or institutions funding operations in this country. Used for donor reporting and relationship management.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Security Risk Level' ;
    rdfs:comment 'Current security risk assessment level for the country. Determines staff travel restrictions, security protocols, and operational modalities.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smallIslandDevelopingState rdf:type rdf:Property ;
    rdfs:label 'Small Island Developing State' ;
    rdfs:comment 'Indicates whether the country is classified as a Small Island Developing State. Relevant for climate adaptation and disaster risk reduction programs.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subRegion rdf:type rdf:Property ;
    rdfs:label 'Sub Region' ;
    rdfs:comment 'Geographic sub-region classification providing more granular regional grouping for operational planning and analysis.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Status' ;
    rdfs:comment 'Tax exemption status granted to the organization by the national government. Affects financial planning and procurement.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visaRequirements rdf:type rdf:Property ;
    rdfs:label 'Visa Requirements' ;
    rdfs:comment 'Description of visa requirements and procedures for international staff deployment to this country. Used for staff travel planning and compliance.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedPopulationCount rdf:type rdf:Property ;
    rdfs:label 'Affected Population Count' ;
    rdfs:comment 'Estimated total number of individuals directly affected by the emergency event.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedRegions rdf:type rdf:Property ;
    rdfs:label 'Affected Regions' ;
    rdfs:comment 'Comma-separated list of administrative regions, provinces, or districts affected by the emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cerfAllocationReceived rdf:type rdf:Property ;
    rdfs:label 'Cerf Allocation Received' ;
    rdfs:comment 'Indicates whether the organization received funding from the UN Central Emergency Response Fund for this emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clusterCoordinationMechanism rdf:type rdf:Property ;
    rdfs:label 'Cluster Coordination Mechanism' ;
    rdfs:comment 'Description of the OCHA cluster coordination structure activated for this emergency (e.g., \'Full cluster activation with 11 sectors\').' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationDate rdf:type rdf:Property ;
    rdfs:label 'Declaration Date' ;
    rdfs:comment 'Date when the emergency was officially declared by the organization or governing authority.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disasterCategory rdf:type rdf:Property ;
    rdfs:label 'Disaster Category' ;
    rdfs:comment 'Specific disaster category providing granular classification of the emergency event type.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displacedPopulationCount rdf:type rdf:Property ;
    rdfs:label 'Displaced Population Count' ;
    rdfs:comment 'Estimated number of individuals displaced or forced to leave their homes due to the emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emergencyCode rdf:type rdf:Property ;
    rdfs:label 'Emergency Code' ;
    rdfs:comment 'Externally-known unique business identifier for the emergency, following organizational coding standards (e.g., SYR-2023-EQKE01).' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyName rdf:type rdf:Property ;
    rdfs:label 'Emergency Name' ;
    rdfs:comment 'Human-readable name or title of the emergency event (e.g., \'Syria Earthquake Response 2023\', \'Bangladesh Flood Relief\').' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyType rdf:type rdf:Property ;
    rdfs:label 'Emergency Type' ;
    rdfs:comment 'Classification of the emergency by its primary cause or nature.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fgdConductedCount rdf:type rdf:Property ;
    rdfs:label 'Fgd Conducted Count' ;
    rdfs:comment 'Number of Focus Group Discussions conducted as part of field assessments for this emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flashAppealIssued rdf:type rdf:Property ;
    rdfs:label 'Flash Appeal Issued' ;
    rdfs:comment 'Indicates whether an OCHA Flash Appeal was issued for this emergency to mobilize rapid funding.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundingReceivedUsd rdf:type rdf:Property ;
    rdfs:label 'Funding Received Usd' ;
    rdfs:comment 'Total funding received in US Dollars for the emergency response as of the last update.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingRequirementUsd rdf:type rdf:Property ;
    rdfs:label 'Funding Requirement Usd' ;
    rdfs:comment 'Total funding requirement in US Dollars for the organizations emergency response operations.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gisMappingCompleted rdf:type rdf:Property ;
    rdfs:label 'Gis Mapping Completed' ;
    rdfs:comment 'Indicates whether GIS-based location mapping and spatial analysis were completed for affected areas.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hrpIssued rdf:type rdf:Property ;
    rdfs:label 'Hrp Issued' ;
    rdfs:comment 'Indicates whether a formal Humanitarian Response Plan was developed and issued for this emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementingPartnersCount rdf:type rdf:Property ;
    rdfs:label 'Implementing Partners Count' ;
    rdfs:comment 'Number of local and international partner organizations collaborating in the emergency response.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kiiConductedCount rdf:type rdf:Property ;
    rdfs:label 'Kii Conducted Count' ;
    rdfs:comment 'Number of Key Informant Interviews conducted as part of field assessments for this emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:koboSurveyDeployed rdf:type rdf:Property ;
    rdfs:label 'Kobo Survey Deployed' ;
    rdfs:comment 'Indicates whether mobile data collection surveys via KoboToolbox were deployed for field assessments in this emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadClusters rdf:type rdf:Property ;
    rdfs:label 'Lead Clusters' ;
    rdfs:comment 'Comma-separated list of humanitarian clusters where the organization holds lead or co-lead responsibility (e.g., \'WASH, Shelter, Protection\').' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileHealthOutreachPlanned rdf:type rdf:Property ;
    rdfs:label 'Mobile Health Outreach Planned' ;
    rdfs:comment 'Indicates whether mobile health clinics or outreach services are planned as part of the health response.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nfiDistributionPlanned rdf:type rdf:Property ;
    rdfs:label 'Nfi Distribution Planned' ;
    rdfs:comment 'Indicates whether distribution of non-food items (shelter materials, hygiene kits, household items) is planned.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onsetDate rdf:type rdf:Property ;
    rdfs:label 'Onset Date' ;
    rdfs:comment 'Date when the emergency event first occurred or began impacting the affected population.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:protectionConcernsIdentified rdf:type rdf:Property ;
    rdfs:label 'Protection Concerns Identified' ;
    rdfs:comment 'Summary of key protection concerns identified during assessments (e.g., \'GBV risk, child protection, housing land property rights\').' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rapidAssessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Rapid Assessment Completed' ;
    rdfs:comment 'Indicates whether a rapid needs assessment was completed within the first 72 hours of the emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseEndDate rdf:type rdf:Property ;
    rdfs:label 'Response End Date' ;
    rdfs:comment 'Date when the emergency response operations were concluded or transitioned to recovery phase.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseModality rdf:type rdf:Property ;
    rdfs:label 'Response Modality' ;
    rdfs:comment 'Description of the primary response delivery mechanisms employed (e.g., \'In-kind distribution, Cash and Voucher Assistance (CVA), Service delivery\').' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseStartDate rdf:type rdf:Property ;
    rdfs:label 'Response Start Date' ;
    rdfs:comment 'Date when the organization initiated its emergency response operations.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sitrepFrequency rdf:type rdf:Property ;
    rdfs:label 'Sitrep Frequency' ;
    rdfs:comment 'Frequency at which situation reports are generated and disseminated for this emergency.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current lifecycle status of the emergency response operation.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetedBeneficiariesCount rdf:type rdf:Property ;
    rdfs:label 'Targeted Beneficiaries Count' ;
    rdfs:comment 'Number of beneficiaries the organization plans to reach through its emergency response interventions.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:washInterventionsPlanned rdf:type rdf:Property ;
    rdfs:label 'Wash Interventions Planned' ;
    rdfs:comment 'Indicates whether WASH sector interventions are included in the emergency response plan.' ;
    rdfs:domain ind:Emergency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundId rdf:type rdf:Property ;
    rdfs:label 'Fund Id' ;
    rdfs:comment 'Reference to the fund from which payments in this run are sourced, critical for restricted fund tracking and compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceFund .

ind:batchReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Reference Number' ;
    rdfs:comment 'External batch reference number provided by the bank or payment processor for reconciliation purposes.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'System-generated error message or failure reason if the payment run encountered processing errors.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'The precise date and time when the payment run was executed and payments were initiated.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failedAmount rdf:type rdf:Property ;
    rdfs:label 'Failed Amount' ;
    rdfs:comment 'The total monetary value of payments that failed during processing in this run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failedPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Failed Payment Count' ;
    rdfs:comment 'The number of payments that failed during processing in this run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which payments in this run are due to be received by payees, used for scheduling and compliance.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:successfulAmount rdf:type rdf:Property ;
    rdfs:label 'Successful Amount' ;
    rdfs:comment 'The total monetary value of payments that were successfully processed in this run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:successfulPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Successful Payment Count' ;
    rdfs:comment 'The number of payments that were successfully processed and completed in this run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Count' ;
    rdfs:comment 'The total number of individual payment transactions included in this payment run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByUserUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Created By User User Account Id' ;
    rdfs:comment 'Identifier of the user who created this bank transaction record in the system.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:modifiedByUserUserAccountId rdf:type rdf:Property ;
    rdfs:label 'Modified By User User Account Id' ;
    rdfs:comment 'Identifier of the user who last modified this bank transaction record.' ;
    rdfs:domain ind:Ngo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UserAccount .

ind:bankStatementDate rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Date' ;
    rdfs:comment 'The date of the bank statement on which this transaction appeared.' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:counterpartyAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Counterparty Account Number' ;
    rdfs:comment 'Bank account number of the counterparty (other party) involved in the transaction.' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyBankName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Bank Name' ;
    rdfs:comment 'Name of the financial institution holding the counterparty\'s account.' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Counterparty Routing Number' ;
    rdfs:comment 'Bank routing number or SWIFT code for the counterparty\'s financial institution.' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memo rdf:type rdf:Property ;
    rdfs:label 'Memo' ;
    rdfs:comment 'Additional notes or memo text associated with the transaction for internal reference or clarification.' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeeName rdf:type rdf:Property ;
    rdfs:label 'Payee Name' ;
    rdfs:comment 'Name of the individual or organization receiving funds in this transaction.' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerName rdf:type rdf:Property ;
    rdfs:label 'Payer Name' ;
    rdfs:comment 'Name of the individual or organization providing funds in this transaction.' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runningBalance rdf:type rdf:Property ;
    rdfs:label 'Running Balance' ;
    rdfs:comment 'The account balance after this transaction has been applied, used for reconciliation and cash position tracking.' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The monetary value of the bank transaction in the account\'s base currency. Positive for credits/deposits, negative for debits/withdrawals.' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The date when the bank transaction occurred or was posted to the account.' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionDescription rdf:type rdf:Property ;
    rdfs:label 'Transaction Description' ;
    rdfs:comment 'Detailed narrative description of the bank transaction purpose, often provided by the bank or entered by the user.' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned by the bank or payment processor for this transaction. Used for reconciliation and audit trails.' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the bank transaction indicating its processing state.' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'The precise date and time when the bank transaction was executed or recorded by the banking system.' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the bank transaction indicating the nature of the movement (deposit, withdrawal, transfer, fee, interest, refund).' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date when funds become available or are debited, used for interest calculation and cash flow management.' ;
    rdfs:domain ind:BankTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentPeriodId rdf:type rdf:Property ;
    rdfs:label 'Parent Period Id' ;
    rdfs:comment 'Reference to a parent reporting period for hierarchical period structures (e.g., monthly periods rolling up to quarterly periods, quarterly to annual). Null for top-level periods.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingPeriod .

ind:baselinePeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Period Flag' ;
    rdfs:comment 'Indicates whether this reporting period represents a baseline measurement period for program indicators (True) or not (False). Baseline periods establish the starting point for impact measurement.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'The calendar year in which the reporting period falls, used for temporal analysis and trend reporting.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dacCriteriaFocus rdf:type rdf:Property ;
    rdfs:label 'Dac Criteria Focus' ;
    rdfs:comment 'The primary DAC evaluation criteria focus for this period (e.g., \'Relevance\', \'Effectiveness\', \'Efficiency\', \'Impact\', \'Sustainability\', \'Coherence\'). Multiple criteria may be listed as comma-separated values.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionDeadline rdf:type rdf:Property ;
    rdfs:label 'Data Collection Deadline' ;
    rdfs:comment 'The deadline date by which all data collection activities for this reporting period must be completed. Used for MEL workflow management.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataQualityAuditFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Audit Flag' ;
    rdfs:comment 'Indicates whether a data quality audit or verification exercise is scheduled for this reporting period (True) or not (False). Ensures data integrity and reliability.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dhis2PeriodCode rdf:type rdf:Property ;
    rdfs:label 'Dhis2 Period Code' ;
    rdfs:comment 'The period identifier used in DHIS2 system for aggregate health data reporting. Enables integration with DHIS2 for health program monitoring.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorReportingCycle rdf:type rdf:Property ;
    rdfs:label 'Donor Reporting Cycle' ;
    rdfs:comment 'The specific donor reporting cycle or phase that this period supports (e.g., \'Year 1 Q2\', \'Mid-term Review\', \'Final Report\'). Used to align with donor contractual obligations.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endlinePeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Endline Period Flag' ;
    rdfs:comment 'Indicates whether this reporting period represents an endline measurement period for program indicators (True) or not (False). Endline periods capture final outcomes and impact.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fgdScheduledFlag rdf:type rdf:Property ;
    rdfs:label 'Fgd Scheduled Flag' ;
    rdfs:comment 'Indicates whether Focus Group Discussions (FGDs) are scheduled to be conducted during this reporting period (True) or not (False). Used for qualitative data collection planning.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kiiScheduledFlag rdf:type rdf:Property ;
    rdfs:label 'Kii Scheduled Flag' ;
    rdfs:comment 'Indicates whether Key Informant Interviews (KIIs) are scheduled to be conducted during this reporting period (True) or not (False). Used for qualitative data collection planning.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:midlinePeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Midline Period Flag' ;
    rdfs:comment 'Indicates whether this reporting period represents a midline measurement period for program indicators (True) or not (False). Midline periods assess progress at the program midpoint.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monthNumber rdf:type rdf:Property ;
    rdfs:label 'Month Number' ;
    rdfs:comment 'The month number (1-12) within the year, applicable for monthly reporting periods. Null for non-monthly periods.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pdmCycleFlag rdf:type rdf:Property ;
    rdfs:label 'Pdm Cycle Flag' ;
    rdfs:comment 'Indicates whether this reporting period includes a Post-Distribution Monitoring (PDM) cycle for assessing the effectiveness and impact of distributed aid (True) or not (False).' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodDescription rdf:type rdf:Property ;
    rdfs:label 'Period Description' ;
    rdfs:comment 'Detailed description of the reporting period, including any special characteristics, contextual information, or notes about data collection activities during this period.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Report Submission Deadline' ;
    rdfs:comment 'The deadline date by which the final report for this period must be submitted to donors or stakeholders. Critical for compliance with donor agreements.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:weekNumber rdf:type rdf:Property ;
    rdfs:label 'Week Number' ;
    rdfs:comment 'The ISO week number (1-53) within the year, applicable for weekly reporting periods. Null for non-weekly periods.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dhis2OrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Dhis2 Org Unit Id' ;
    rdfs:comment 'External identifier for this geographic scope in the DHIS2 health information system, used for health indicator reporting.' ;
    rdfs:domain ind:GeographicScope ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:parentScopeId rdf:type rdf:Property ;
