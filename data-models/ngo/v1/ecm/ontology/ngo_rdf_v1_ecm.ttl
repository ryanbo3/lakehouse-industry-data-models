ind:administrativeLevel rdf:type rdf:Property ;
    rdfs:label 'Administrative Level' ;
    rdfs:comment 'Numeric administrative hierarchy level (0=global, 1=regional, 2=national, 3=subnational, 4=provincial, 5=district, 6=municipal, 7=community).' ;
    rdfs:domain ind:GeographicScope ;
