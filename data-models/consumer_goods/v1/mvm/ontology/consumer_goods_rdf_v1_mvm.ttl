    rdfs:range xsd:dateTime .

ind:analystName rdf:type rdf:Property ;
    rdfs:label 'Analyst Name' ;
    rdfs:comment 'Name of the quality analyst who performed the test.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectedBy rdf:type rdf:Property ;
    rdfs:label 'Collected By' ;
    rdfs:comment 'Name of the person who performed the sample collection.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'Date on which the sample was physically collected.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'Exact timestamp when the sample was collected.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isControl rdf:type rdf:Property ;
    rdfs:label 'Is Control' ;
    rdfs:comment 'Indicates whether the sample is a control specimen used for method verification.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRetest rdf:type rdf:Property ;
    rdfs:label 'Is Retest' ;
    rdfs:comment 'True if the sample is a repeat test due to a prior failure or out-of-spec result.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultUnit rdf:type rdf:Property ;
    rdfs:label 'Result Unit' ;
    rdfs:comment 'Unit of measure for the numeric result.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValue rdf:type rdf:Property ;
    rdfs:label 'Result Value' ;
    rdfs:comment 'Quantitative measurement obtained from the analysis (e.g., concentration).' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleCode rdf:type rdf:Property ;
    rdfs:label 'Sample Code' ;
    rdfs:comment 'External code or barcode assigned to the sample for tracking in the quality system.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleName rdf:type rdf:Property ;
    rdfs:label 'Sample Name' ;
    rdfs:comment 'Human-readable name or description of the sample (e.g., "Batch 12 – Tablet Sample").' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Status' ;
    rdfs:comment 'Current lifecycle state of the sample within the quality process.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Category of the sample indicating its purpose in quality testing.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightG rdf:type rdf:Property ;
    rdfs:label 'Weight G' ;
    rdfs:comment 'Measured weight of the sample in grams.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousPlanningPeriodId rdf:type rdf:Property ;
    rdfs:label 'Previous Planning Period Id' ;
    rdfs:comment 'Self-referencing FK on planning_period (previous_planning_period_id)' ;
    rdfs:domain ind:PlanningPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanningPeriod .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Number of days covered by the planning period.' ;
    rdfs:domain ind:PlanningPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isHistorical rdf:type rdf:Property ;
    rdfs:label 'Is Historical' ;
    rdfs:comment 'Indicates whether the period is historical (true) or future (false).' ;
    rdfs:domain ind:PlanningPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodCode rdf:type rdf:Property ;
    rdfs:label 'Period Code' ;
    rdfs:comment 'External code used in planning systems to reference the period.' ;
    rdfs:domain ind:PlanningPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name of the planning period (e.g., FY2024 Q1).' ;
    rdfs:domain ind:PlanningPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizon rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon' ;
    rdfs:comment 'Planning horizon classification for the period.' ;
    rdfs:domain ind:PlanningPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodDescription rdf:type rdf:Property ;
    rdfs:label 'Planning Period Description' ;
    rdfs:comment 'Free-text description of the planning period purpose.' ;
    rdfs:domain ind:PlanningPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodStatus rdf:type rdf:Property ;
    rdfs:label 'Planning Period Status' ;
    rdfs:comment 'Current lifecycle status of the period.' ;
    rdfs:domain ind:PlanningPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallLotScopeId rdf:type rdf:Property ;
    rdfs:label 'Recall Lot Scope Id' ;
    rdfs:comment 'Primary key for the recall_lot_scope association' ;
    rdfs:domain ind:RecallLotScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedLotBatchRange rdf:type rdf:Property ;
    rdfs:label 'Affected Lot Batch Range' ;
    rdfs:comment 'Specification of the lot numbers, batch codes, or serial number ranges included in the recall. Critical for traceability and targeted recovery. May be expressed as ranges, lists, or patterns. [Moved from recall_event: This STRING field is a denormalized placeholder that stores lot/batch ranges as unstructured text. It cannot support proper lot-level traceability, per-lot quantity tracking, or regulatory reporting. Its functional purpose is entirely replaced by the recall_lot_scope association table, which provides a proper FK-based enumeration of affected lots with per-lot recovery attributes. This field should be deprecated and removed from recall_event once recall_lot_scope is populated.]' ;
    rdfs:domain ind:RecallLotScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotRecallStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Recall Status' ;
    rdfs:comment 'The current recovery status of this specific lot/batch within the recall action. Tracks per-lot progress independently of the overall recall event status. Pending: recovery not yet initiated for this lot; In Progress: recovery activities underway; Recovered: full recovery achieved; Destroyed: product destroyed in lieu of return; Not Located: product cannot be traced.' ;
    rdfs:domain ind:RecallLotScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRecalledPerLot rdf:type rdf:Property ;
    rdfs:label 'Quantity Recalled Per Lot' ;
    rdfs:comment 'The quantity of product from this specific lot/batch that is subject to the recall action. May differ from the lot\'s total quantity_produced if only a portion was distributed or affected. Required for per-lot FDA effectiveness reporting.' ;
    rdfs:domain ind:RecallLotScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRecoveredPerLot rdf:type rdf:Property ;
    rdfs:label 'Quantity Recovered Per Lot' ;
    rdfs:comment 'The actual quantity of product from this specific lot/batch that has been recovered from the market through returns, destruction, or retrieval. Used to calculate per-lot recovery effectiveness rate for regulatory reporting.' ;
    rdfs:domain ind:RecallLotScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Date' ;
    rdfs:comment 'The date on which recovery activities for this specific lot/batch were completed. Null if recovery is not yet complete. Used to calculate time-to-recovery per lot and to support FDA effectiveness check submissions.' ;
    rdfs:domain ind:RecallLotScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:skuLaneAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Sku Lane Assignment Id' ;
    rdfs:comment 'Primary key for the sku_lane_assignment association' ;
    rdfs:domain ind:SkuLaneAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of this SKU-lane assignment. Active assignments are used by planning engines; inactive or suspended assignments are retained for audit and reactivation purposes.' ;
    rdfs:domain ind:SkuLaneAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsSubstanceCompositionId rdf:type rdf:Property ;
    rdfs:label 'Sds Substance Composition Id' ;
    rdfs:comment 'Primary key for the sds_substance_composition association' ;
    rdfs:domain ind:SdsSubstanceComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:concentrationInProduct rdf:type rdf:Property ;
    rdfs:label 'Concentration In Product' ;
    rdfs:comment 'The actual concentration (percentage by weight or volume) of this restricted substance in the specific product formulation covered by the linked SDS. This value is specific to the substance-SDS pairing and cannot reside on either master record alone.' ;
    rdfs:domain ind:SdsSubstanceComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disclosureBasis rdf:type rdf:Property ;
    rdfs:label 'Disclosure Basis' ;
    rdfs:comment 'The specific regulatory framework or requirement that mandates the disclosure of this substance in this SDS (e.g., REACH SVHC listing, Prop 65, OSHA HazCom threshold). A substance may be disclosed in one SDS under REACH and in another under Prop 65.' ;
    rdfs:domain ind:SdsSubstanceComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureLimitOverride rdf:type rdf:Property ;
    rdfs:label 'Exposure Limit Override' ;
    rdfs:comment 'Any product-specific or jurisdiction-specific occupational exposure limit (OEL) that overrides the standard limit for this substance in the context of this specific SDS/formulation. Belongs to the relationship because the override is formulation-context-dependent.' ;
    rdfs:domain ind:SdsSubstanceComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardContributionFlag rdf:type rdf:Property ;
    rdfs:label 'Hazard Contribution Flag' ;
    rdfs:comment 'Indicates whether this restricted substance is the primary contributor to the GHS hazard classification of the product covered by the linked SDS. This determination is specific to each substance-SDS pairing and cannot reside on either master record.' ;
    rdfs:domain ind:SdsSubstanceComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sectionReference rdf:type rdf:Property ;
    rdfs:label 'Section Reference' ;
    rdfs:comment 'The specific GHS SDS section number(s) where this restricted substance is disclosed or referenced (e.g., Section 3 for composition, Section 8 for exposure limits). Belongs to the relationship as the same substance may be referenced in different sections across different SDS documents.' ;
    rdfs:domain ind:SdsSubstanceComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
