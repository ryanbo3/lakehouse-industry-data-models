# RDFS Schema for Business: Consumer Goods

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/consumer_goods#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Consumer Goods ---
ind:ConsumerGoods rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Consumer Goods' ;
    rdfs:comment 'Consumer Goods is a broad manufacturing industry producing and marketing household, health, hygiene, and personal care products distributed through retail stores, e-commerce platforms, and wholesale channels worldwide.' .

# --- Domain Classes ---
ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ConsumerGoods ;
    rdfs:label 'Product' ;
    rdfs:comment 'Single source of truth for all product master data across the CPG/FMCG portfolio. Owns SKU definitions, GTIN/UPC/EAN identifiers, product hierarchies, BOM structures, PLM lifecycle stages, formulation records, packaging specifications, INCI ingredient declarations, and regulatory labeling attributes. Serves as the authoritative product catalog referenced by all other domains.' .

ind:Manufacturing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ConsumerGoods ;
    rdfs:label 'Manufacturing' ;
    rdfs:comment 'Owns production planning, scheduling, and execution across manufacturing facilities. Manages production orders, batch records, work orders, MES integration (Siemens Opcenter), line performance (OEE), yield tracking, MRP runs, GMP compliance events, changeover management, and shop floor data collection aligned with ISO 22716 standards.' .

ind:Consumer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ConsumerGoods ;
    rdfs:label 'Consumer' ;
    rdfs:comment 'SSOT for all end consumers, shoppers, households, and loyalty program members in B2C and DTC channels. Manages consumer profiles, preferences, purchase history, segmentation, NPS scores, CLTV calculations, consent and privacy preferences (GDPR/CCPA), and contact data. Supports CRM, personalization, and consumer engagement programs.' .

ind:Supply rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ConsumerGoods ;
    rdfs:label 'Supply' ;
    rdfs:comment 'Owns end-to-end supply chain planning and orchestration including demand planning, supply planning, inventory optimization, S&OP/IBP processes, DRP execution, safety stock targets, ATP/CTP calculations, supply network design, demand sensing, forecast accuracy tracking, and supply risk management. Integrates with SAP IBP.' .

ind:Sales rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ConsumerGoods ;
    rdfs:label 'Sales' ;
    rdfs:comment 'Owns commercial sales execution, order management, and revenue transactions across all channels (retail, wholesale, DTC, e-commerce). Manages sales orders, pricing agreements, sales force automation (SFA), retail account call records, POG compliance, RSP/MSRP price management, ACV/TDP/SOM metrics, and field sales KPIs. Integrates with Salesforce Consumer Goods Cloud.' .

ind:Quality rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ConsumerGoods ;
    rdfs:label 'Quality' ;
    rdfs:comment 'Owns quality assurance, quality control, and GMP compliance data across the product lifecycle. Manages QC inspection results, non-conformance records, CAPA processes, batch release decisions, stability studies, certificate of analysis, GMP audit findings, supplier quality assessments, product complaints, and regulatory hold events. Integrates with SAP QM and Veeva Vault.' .

ind:Distribution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ConsumerGoods ;
    rdfs:label 'Distribution' ;
    rdfs:comment 'Owns warehouse operations, inventory management, and order fulfillment across distribution centers. Manages inbound/outbound logistics within DCs, put-away/picking/packing processes, cycle counting, FEFO/FIFO inventory rotation, WMS integration (Blue Yonder), OTIF performance, OSA metrics, and DSD execution for direct store delivery channels.' .

ind:Procurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ConsumerGoods ;
    rdfs:label 'Procurement' ;
    rdfs:comment 'Owns sourcing, supplier management, and purchase order execution for raw materials, packaging, and indirect goods. Manages supplier master data, contracts, RFQs, purchase requisitions, PO lifecycle, goods receipt, invoice verification, MOQ terms, SDS documentation, supplier performance scorecards, VMI programs, and sustainable sourcing initiatives (FSC, RSPO).' .

ind:Promotion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ConsumerGoods ;
    rdfs:label 'Promotion' ;
    rdfs:comment 'Owns trade promotion planning, execution, and optimization (TPM/TPO). Manages promotional calendars, trade spend allocation, retailer funding agreements, promotional pricing (Hi-Lo, EDLP), accruals, deductions, post-event analysis, promotional lift measurement, ROI/GMROI analysis, and retailer rebate settlements. Integrates with Salesforce TPM.' .

ind:Marketing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ConsumerGoods ;
    rdfs:label 'Marketing' ;
    rdfs:comment 'Owns brand management, consumer engagement campaigns, digital marketing, and market research. Manages campaign planning, media spend, creative assets, influencer partnerships, social media engagement, marketing attribution, brand health metrics, SOV (Share of Voice), SOM, consumer sentiment analysis, and Nielsen IQ panel insights.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ConsumerGoods ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Owns financial planning, accounting, and reporting including general ledger, accounts payable/receivable, cost accounting, COGS allocation, EBITDA reporting, DSO/DIO tracking, budgeting, revenue recognition, and SOX-compliant financial controls and audit trails. Integrates with SAP S/4HANA FI/CO and Oracle Cloud Financials.' .

ind:Logistics rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ConsumerGoods ;
    rdfs:label 'Logistics' ;
    rdfs:comment 'Owns transportation management, freight optimization, and delivery execution across inbound and outbound networks. Manages carrier contracts, shipment planning, route optimization, freight audit, track-and-trace, 3PL coordination, proof of delivery, cold-chain compliance, and transportation cost tracking. Distinct from distribution (warehouse-focused) — logistics covers inter-facility and last-mile movement.' .

ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ConsumerGoods ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'Owns physical inventory positions across the entire distribution network. Manages stock on hand, in-transit inventory, warehouse locations, FEFO/FIFO rotation rules, DIO metrics, OOS/OSA events, VMI replenishment triggers, lot/batch traceability for recall readiness, safety stock levels, and multi-echelon inventory visibility.' .

ind:Regulatory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ConsumerGoods ;
    rdfs:label 'Regulatory' ;
    rdfs:comment 'Owns product registration, regulatory submissions, labeling compliance, and safety documentation management. Manages regulatory dossiers, SDS/MSDS sheets, ingredient declarations, country-specific registrations (FDA, EPA, EU), CPSC filings, IFRA compliance records, post-market surveillance, and CFR compliance. Ensures multi-jurisdictional regulatory adherence.' .

# --- Data Product Classes (Tables) ---
ind:Shopper rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consumer ;
    rdfs:label 'Shopper' ;
    rdfs:comment 'Golden master record for every end consumer and shopper across B2C and DTC channels. Stores consumer identity (full name, date of birth, gender), contact details (primary email, phone), language and currency preferences, acquisition metadata (channel, date), consumer lifecycle status (active/inactive/opted-out), identity verification status, and source system references. This is the single anchor entity for the consumer domain — all other consumer entities reference this record via shopper_id. Supports CRM, personalization, regulatory compliance (GDPR/CCPA subject identification), and consumer 360-degree view.' .

ind:Household rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consumer ;
    rdfs:label 'Household' ;
    rdfs:comment 'Household unit grouping multiple shoppers who share a residence and purchasing decisions. Captures household demographics (estimated size, income band, life stage), formation date, status, and primary shopper designation. Enables household-level basket analysis, cross-sell targeting (e.g., recommending baby products when life stage changes), and loyalty program household pooling for CPG/FMCG brands.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consumer ;
    rdfs:label 'Address' ;
    rdfs:comment 'Physical and digital address records associated with a consumer/shopper. Stores address type (billing, shipping, home, work), street lines, city, state/province, postal code, country, geocoordinates (latitude/longitude), address validation status, address source, effective date, and expiry date. Supports DTC order fulfillment, personalized marketing, and regulatory compliance for GDPR/CCPA data residency requirements.' .

ind:LoyaltyAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consumer ;
    rdfs:label 'Loyalty Account' ;
    rdfs:comment 'Loyalty program membership account and transaction history for a consumer enrolled in a CPG brand loyalty or rewards program. Captures account master (program name, membership tier, enrollment date, points balance, lifetime points earned/redeemed, tier qualification spend, tier review date, status) and individual points movement events (earn, redeem, adjust, expire — with points amount, triggering event, associated order reference, balance snapshot, processing status, timestamp). Supports CLTV calculation, personalized promotions, consumer retention programs, and points liability reporting required by finance.' .

ind:LoyaltyTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consumer ;
    rdfs:label 'Loyalty Transaction' ;
    rdfs:comment 'Individual points movement event within a loyalty account — earn, redeem, adjust, or expire. Records points amount, triggering event (purchase, referral, review, birthday bonus, promotion), associated order reference, balance snapshot (before/after), processing status, and transaction timestamp. Provides the complete audit trail for loyalty currency reconciliation and supports points liability reporting required by finance.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consumer ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Consumer segmentation classification and membership records used for targeting, personalization, and marketing activation. Stores segment definition (name, code, model version, type — behavioral/demographic/psychographic/RFM/CLTV-based, description, effective date range, owning brand/BU) and individual membership assignments (shopper reference, assignment date, expiry date, assignment method — rule-based/ML/manual, confidence score, segment version). Enables time-variant segment membership tracking, CRM-driven personalization, and trade promotion targeting across CPG brands.' .

ind:SegmentMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consumer ;
    rdfs:label 'Segment Membership' ;
    rdfs:comment 'Association record linking an individual shopper/consumer to one or more consumer segments at a point in time. Captures shopper reference, segment reference, assignment date, expiry date, assignment method (rule-based, ML model, manual), confidence score, and segment version. Enables time-variant segment membership tracking for personalization and campaign targeting.' .

ind:Preference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consumer ;
    rdfs:label 'Preference' ;
    rdfs:comment 'Unified consumer preference profile capturing product, brand, channel, and communication preferences. Stores preference category (product category, brand, flavor, fragrance, pack size, channel, communication channel, contact frequency, preferred time of day, preferred language), preference value, opt-in/opt-out status, preference source (declared via web/app/call-center vs. inferred by ML model), confidence level, effective date, brand-level overrides, and last updated timestamp. Drives personalization engines, recommendation systems, communication orchestration, and targeted consumer engagement programs for CPG brands. This is the SSOT for all consumer preference data — both product/brand preferences and communication/contact preferences.' .

ind:ConsentRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consumer ;
    rdfs:label 'Consent Record' ;
    rdfs:comment 'Formal consent and privacy preference record for a consumer capturing GDPR, CCPA, and other regulatory consent obligations, including full audit history of all consent changes. Stores consent type (marketing email, SMS, push notification, data sharing, profiling, cookies), current consent status (granted, withdrawn, pending), consent version, capture method (web form, app, in-store, call center), capture timestamp, IP address, regulatory jurisdiction, expiry date, and immutable event log of every status change (prior status, new status, change trigger, channel, processing agent/system). This is the SSOT for consumer privacy compliance and provides the complete consent history required for GDPR Article 7 and CCPA compliance audits.' .

ind:DtcOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consumer ;
    rdfs:label 'Dtc Order' ;
    rdfs:comment 'Direct-to-Consumer (DTC) order with line-item detail placed by a shopper through owned e-commerce or brand website channels. Captures order header (order number, date, status, channel, shipping/billing address, payment method, subtotal, discount, shipping cost, tax, total, currency, fulfillment reference) and line items (SKU/GTIN, product name, quantity ordered/shipped, unit price, line discount, line total, promotion code, fulfillment status, return flag). This is the SSOT for DTC channel order transactions and enables SKU-level purchase analysis, replenishment triggers, and product affinity modeling.' .

ind:DtcOrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consumer ;
    rdfs:label 'Dtc Order Line' ;
    rdfs:comment 'Individual line item within a DTC order representing a single SKU purchased. Stores order reference, SKU/GTIN, product name, quantity ordered, quantity shipped, unit price, line discount, line total, promotion code applied, fulfillment status, and return flag. Enables SKU-level purchase analysis, replenishment triggers, and product affinity modeling for CPG DTC channels.' .

ind:DtcReturn rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consumer ;
    rdfs:label 'Dtc Return' ;
    rdfs:comment 'Consumer return or refund request for a DTC order. Captures return request date, return reason code (defective, wrong item, changed mind, damaged in transit), return status (requested, approved, received, refunded, rejected), return method (mail-in, drop-off), refund amount, refund method (original payment, store credit, loyalty points), and associated order and order line references. Supports consumer satisfaction tracking and product quality feedback loops.' .

ind:NpsResponse rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consumer ;
    rdfs:label 'Nps Response' ;
    rdfs:comment 'Net Promoter Score (NPS) survey response captured from a consumer. Stores survey date, survey channel (email, in-app, SMS, post-purchase), NPS score (0-10), promoter/passive/detractor classification, verbatim comment, product or brand surveyed, survey campaign reference, and response status. Enables brand health tracking, consumer sentiment analysis, and closed-loop consumer feedback management for CPG brands.' .

ind:Interaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consumer ;
    rdfs:label 'Interaction' ;
    rdfs:comment 'Record of every consumer touchpoint across service and engagement channels (call center, live chat, email, social media, in-app, retail). Captures interaction type (inquiry, complaint, compliment, product feedback, adverse event report), resolution workflow (status, resolution date, assigned agent/bot), sentiment classification, and referenced product/brand. Serves as the operational backbone for CRM case management, SLA tracking, consumer satisfaction measurement, and escalation workflows.' .

ind:Subscription rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consumer ;
    rdfs:label 'Subscription' ;
    rdfs:comment 'Consumer subscription record for DTC auto-replenishment or subscription box programs. Stores subscription plan name, subscribed SKU(s), subscription frequency (weekly, monthly, bi-monthly), subscription status (active, paused, cancelled), start date, next order date, billing cycle, subscription price, discount rate, payment method reference, and cancellation reason if applicable. Enables subscription revenue forecasting and consumer retention management for CPG DTC channels.' .

ind:Carrier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Carrier' ;
    rdfs:comment 'Master record for all transportation carriers (trucking, rail, ocean, air, parcel) contracted by Consumer Goods. Captures carrier identity, SCAC/IATA codes, carrier type, service modes, geographic coverage, insurance certificates, safety ratings (FMCSA/DOT), EDI capability flags, and contractual status. SSOT for carrier identity referenced by shipments, freight orders, contracts, and invoices across inbound and outbound networks.' .

ind:CarrierContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Carrier Contract' ;
    rdfs:comment 'Freight contract, rate agreement, and granular rate schedule between Consumer Goods and a carrier. Captures contract term dates, lane coverage, mode of transport, negotiated base rates, fuel surcharge tables, accessorial charge schedules, volume commitments, OTIF penalty clauses, contract status, and detailed rate records including rate type (per-mile/per-cwt/per-pallet/flat), origin/destination zones, weight breaks, effective/expiry dates, and currency. Supports freight cost estimation, tender evaluation, freight audit rate lookup, and carrier performance management.' .

ind:Lane rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Lane' ;
    rdfs:comment 'Defined origin-to-destination transportation lane used for freight planning, carrier assignment, and cost benchmarking. Captures origin and destination location codes, transport mode, distance, transit time standard, lane classification (inbound/outbound/inter-facility/last-mile), preferred carrier assignments, volume history, and lane-level cost benchmarks. Foundational reference for route optimization, freight tendering, and network design.' .

ind:LogisticsShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Logistics Shipment' ;
    rdfs:comment 'Core transactional record representing a physical movement of goods from origin to destination. Captures shipment number, BOL (Bill of Lading), PRO number, carrier assignment, mode of transport (TL/LTL/parcel/ocean/air/rail), origin and destination facility, planned and actual ship/delivery dates, total weight and volume, freight terms (prepaid/collect/third-party), shipment status lifecycle, incoterms, cold-chain flag, and consolidation references. Central entity for track-and-trace, OTIF measurement, and freight cost allocation. References carrier, lane, and freight order.' .

ind:ShipmentItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Shipment Item' ;
    rdfs:comment 'Line-item detail of goods included in a shipment. Captures SKU/GTIN, product description, ordered quantity, shipped quantity, unit of measure, gross weight, net weight, volume, hazmat flag, temperature-sensitive flag, lot/batch number, expiry date (FEFO compliance), and packaging type. Enables item-level traceability and cold-chain compliance tracking.' .

ind:Delivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Delivery' ;
    rdfs:comment 'Record of final delivery execution and proof of delivery (POD) at the consignee location. Captures delivery number, shipment reference, consignee account, delivery address, scheduled and actual delivery timestamps, delivered quantity, delivery status (full/partial/failed/refused), recipient name and signature, electronic signature flag, condition of goods at receipt, photo attachment references, discrepancy notes, POD source (DSD handheld, e-POD app, paper scan), driver/vehicle reference, and exception codes. SSOT for last-mile delivery outcomes, OTIF calculation, and dispute resolution evidence.' .

ind:ProofOfDelivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Proof Of Delivery' ;
    rdfs:comment 'Formal POD record capturing evidence of successful goods receipt at the consignee. Captures delivery reference, recipient name and signature, timestamp of receipt, condition of goods at delivery (intact/damaged), photo attachment references, electronic signature flag, discrepancy notes, and POD source (DSD handheld, e-POD app, paper scan). Critical for dispute resolution, freight audit, and DSD compliance.' .

ind:FreightOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Freight Order' ;
    rdfs:comment 'Transportation planning and tendering record issued to a carrier for a specific shipment movement. Captures freight order number, tendering method (spot/contract/load board), carrier assignment, load type (FTL/LTL/parcel), pickup and delivery locations, requested pickup window, freight order status (tendered/accepted/rejected/in-transit/delivered), agreed rate, and equipment type required. Sourced from SAP TM / Blue Yonder TMS.' .

ind:Route rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Route' ;
    rdfs:comment 'Optimized delivery route plan for a vehicle or driver covering multiple sequential stops. Captures route ID, route date, vehicle/trailer assignment, driver reference, total planned distance and duration, planned departure time, route optimization algorithm used, route status (planned/dispatched/in-progress/completed), and ordered stop details including stop sequence, consignee reference, delivery address, planned/actual arrival and departure times, stop type (delivery/pickup/cross-dock), cases/pallets to deliver, stop status, and dwell time. Supports last-mile route optimization, DSD execution, and stop-level performance tracking.' .

ind:FreightInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Freight Invoice' ;
    rdfs:comment 'Carrier-issued freight invoice submitted to Consumer Goods for transportation services rendered. Captures invoice number, carrier reference, invoice date, payment due date, shipment/BOL references, invoiced charges (line-haul, fuel surcharge, accessorials), currency, invoice status (received/under-audit/approved/disputed/paid), and variance amount vs. contracted rate. Central to freight audit and pay (FAP) process.' .

ind:TrackingEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Tracking Event' ;
    rdfs:comment 'Real-time or near-real-time shipment tracking event captured from carrier EDI (214/990), GPS telematics, or IoT sensors. Captures event timestamp, shipment/leg reference, event type (picked-up, in-transit, out-for-delivery, delivered, exception, delay, damage, refused), location (city/state/GPS coordinates), carrier event code, temperature reading (cold-chain), exception root cause code, financial impact estimate, resolution action and timestamp, and data source. Powers track-and-trace visibility, cold-chain compliance monitoring, exception management, and carrier performance measurement.' .

ind:FreightRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Freight Rate' ;
    rdfs:comment 'Granular freight rate record defining the cost per unit of transport for a specific lane, carrier, mode, and shipment characteristic. Captures rate type (per-mile, per-cwt, per-pallet, flat), origin/destination zone or postal code range, weight break, effective and expiry dates, base rate, fuel surcharge rate, accessorial rate schedule reference, and currency. Sourced from carrier contracts and spot market quotes for freight cost estimation.' .

ind:Sku rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Core master record for every Stock Keeping Unit (SKU) in the CPG/FMCG portfolio. Single source of truth for SKU identity including internal code, description, brand assignment, sub-brand, product form, variant, net content, unit of measure, pack size, launch date, discontinuation date, PLM lifecycle stage, portfolio classification, shelf life attributes (total shelf life, FEFO threshold, storage conditions), and key consumer-facing attributes (scent, color, target demographic). Referenced by all other domains as the authoritative product identifier.' .

ind:GtinRegistry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Gtin Registry' ;
    rdfs:comment 'Authoritative registry of all GS1-compliant global trade item numbers (GTIN-8, GTIN-12/UPC, GTIN-13/EAN, GTIN-14) assigned to each SKU and its packaging hierarchy levels (each, inner pack, case, pallet). Stores GTIN value, GS1 company prefix, indicator digit, check digit, packaging level, assignment date, status, and GS1 registration reference. Enables barcode scanning, EDI transactions, and retailer catalog synchronization.' .

ind:Hierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Hierarchy' ;
    rdfs:comment 'Defines the multi-level product classification hierarchy used across the CPG portfolio: Division → Category → Sub-Category → Brand → Sub-Brand → Product Form → SKU. Each node carries hierarchy level code, node name, parent node reference, sort order, active flag, GPC brick code alignment, Nielsen/IRI category code mapping, and applicable regulatory framework. Serves as the single authoritative classification backbone for OLAP drill-down, trade promotion planning, demand forecasting, market share reporting, and regulatory categorization.' .

ind:ProductBom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Bom' ;
    rdfs:comment 'Bill of Materials (BOM) header record defining the complete ingredient and component structure for a finished good or semi-finished SKU. Captures BOM number, BOM type (production, costing, engineering), base quantity, unit of measure, effective date range, PLM status, and the owning plant or production site. Links to BOM line items for individual component details. Sourced from SAP S/4HANA PP/MM modules.' .

ind:BomLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bom Line' ;
    rdfs:comment 'Individual component line within a Bill of Materials, specifying each raw material, packaging component, or sub-assembly required to produce the parent SKU. Attributes include component item number, component description, component type (raw material, packaging, semi-finished), required quantity, unit of measure, scrap percentage, lead time offset, and whether the component is a critical or alternative item. Supports MRP, COGS calculation, and procurement planning.' .

ind:Formulation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Formulation' ;
    rdfs:comment 'Formulation master record capturing the approved chemical or ingredient recipe for a consumer goods product (household, personal care, health, or hygiene). Stores formulation code, version number, formulation name, product category, regulatory approval status, pH range, viscosity, color, fragrance code, preservative system, and the R&D project reference. Tracks the full formulation lifecycle from lab development through commercial approval. Sourced from Veeva Vault PLM.' .

ind:FormulationIngredient rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Formulation Ingredient' ;
    rdfs:comment 'Individual ingredient line within a formulation record, specifying each chemical or biological substance used in the product formula. Attributes include INCI name (International Nomenclature of Cosmetic Ingredients), CAS number, EC number, function/role (e.g., surfactant, preservative, fragrance, colorant), concentration percentage (min/max/nominal), raw material supplier code, SDS reference, EU REACH registration status, FDA status, and whether the ingredient is a restricted or prohibited substance under applicable regulations.' .

ind:PackagingSpec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Packaging Spec' ;
    rdfs:comment 'Packaging specification master defining the complete physical, material, structural, and hierarchy attributes of all packaging levels for each SKU — primary (bottle, tube, sachet, pouch), secondary (carton, sleeve, shrink-wrap), tertiary (case, shipper), display unit, and pallet. Each record represents one packaging level for one SKU and captures: component type, material composition (HDPE, PET, glass, paperboard, aluminum, PCR content %), dimensions (L×W×H), gross/tare weight, color, finish, print method, recyclability code (How2Recycle label), FSC/RSPO certification flag, supplier tooling reference, quantity per hierarchy level (e.g., 12 eaches per case, 48 cases per pallet), Ti-Hi pallet configuration, and GTIN assigned at that level. Supports sustainability reporting (EPR, plastic tax), planogram compliance, DRP/MRP calculations, warehouse slotting, transportation cube optimization, and retailer EDI order processing.' .

ind:LabelSpec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Label Spec' ;
    rdfs:comment 'Regulatory labeling specification for each SKU and market/country combination. Captures label version, language, market/country code, label type (front-of-pack, back-of-pack, inner label), mandatory regulatory statements (FDA, EU, CPSC), ingredient declaration text, net content declaration, warning statements, usage instructions, claim text (e.g., \'dermatologist tested\', \'cruelty-free\'), barcode placement, and label approval status. Supports multi-market regulatory compliance and artwork management.' .

ind:ProductClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Claim' ;
    rdfs:comment 'Master record of all marketing and regulatory claims associated with a SKU, including claim text, claim type (efficacy, environmental, certification, nutritional, safety), substantiation method, supporting study or test reference, claim approval date, expiry date, applicable markets, FTC compliance flag, and claim status (approved, pending, withdrawn). Ensures all consumer-facing claims are substantiated and compliant with FTC advertising guidelines and local market regulations.' .

ind:ProductBrand rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Brand' ;
    rdfs:comment 'Brand master record defining each consumer goods brand in the portfolio. Captures brand code, brand name, brand tier (premium, mass, value), parent brand (for sub-brands), brand owner entity, brand launch year, brand positioning statement, target consumer segment, primary category, brand trademark registration reference, brand status (active, dormant, divested), and the brand equity tracking methodology. Serves as the authoritative brand dimension for marketing, trade promotion, and financial reporting.' .

ind:PackHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Pack Hierarchy' ;
    rdfs:comment 'Defines the packaging hierarchy levels for each SKU — each/unit, inner pack, case/shipper, display unit, and pallet — including the quantity per level, GTIN per level, dimensions, weight, and Ti-Hi (tier × height) pallet configuration. Supports warehouse slotting, DRP replenishment calculations, transportation cube optimization, and retailer EDI order processing.' .

ind:Certification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Certification' ;
    rdfs:comment 'Tracks third-party certifications and compliance attestations held by a SKU or formulation, such as RSPO (sustainable palm oil), FSC (sustainable packaging), Leaping Bunny (cruelty-free), COSMOS Organic, NSF, Halal, Kosher, EPA Safer Choice, and ISO 22716 GMP. Each record captures certification body, certificate number, certification scope, issue date, expiry date, renewal status, and the applicable markets. Supports sustainability reporting, retailer compliance, and consumer-facing claim substantiation.' .

ind:ManufacturingFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Manufacturing Facility' ;
    rdfs:comment 'Master record for each manufacturing facility (plant/site) in the Consumer Goods network. Captures plant code, site name, address, GMP certification status, ISO 22716 compliance tier, production capacity (units/day), facility type (mixing, filling, packaging, co-manufacturing), regulatory registration numbers (FDA establishment ID, EPA site ID), and operational status. SSOT for all plant-level master data referenced by production orders, batch records, and OEE metrics.' .

ind:ProductionLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Line' ;
    rdfs:comment 'Master record for each physical production line within a manufacturing facility. Captures line code, line name, facility reference, line type (filling, blending, packaging, assembly), design speed (units/hour), nominal OEE target, GMP classification, MES asset tag (Siemens Opcenter), changeover time standard (minutes), and current operational status. Enables OEE benchmarking, scheduling capacity allocation, and MES integration at the line level.' .

ind:ManufacturingBom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Manufacturing Bom' ;
    rdfs:comment 'Bill of Materials master record (header + component lines) defining the complete material structure for each finished good or semi-finished SKU. Header captures BOM number, BOM type (production, co-product, phantom), base quantity, unit of measure, validity dates, PLM system reference, and BOM status. Component lines capture item number, material reference (raw material, packaging, semi-finished), component quantity per base quantity, scrap factor percentage, item category (stock, non-stock, phantom), INCI name for cosmetic ingredients, allergen flag, hazardous material flag, and component validity dates. SSOT for MRP explosion, production order material requirements, COGS calculation, and regulatory ingredient disclosure per FDA/EU REACH. This is the single authoritative source for all BOM component data — no separate component entity exists.' .

ind:Routing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Routing' ;
    rdfs:comment 'Production routing master (header + operation steps) defining the complete manufacturing process sequence for a finished or semi-finished SKU. Header captures routing number, routing type (standard, reference, rate), base quantity, plant, validity dates, and total standard lead time. Operation steps capture operation number, work center assignment, standard values (setup time, machine time, labor time), control key (internal processing, external processing, milestone), yield quantity, scrap percentage, GMP critical step flag, and IPC checkpoint flag. SSOT for production scheduling, capacity planning, standard cost calculation, and GMP batch record generation per ISO 22716. This is the single authoritative source for all routing operation data — no separate operation entity exists. Aligned with SAP PP Routing master.' .

ind:ProductionOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Order' ;
    rdfs:comment 'Core transactional record representing a manufacturing production order issued to produce a specific SKU quantity at a facility. Captures order number, order type (PP01 standard, PP03 rework), SKU reference, plant, production line, scheduled start/finish dates, actual start/finish dates, order quantity, confirmed quantity, scrap quantity, order status (created, released, partially confirmed, technically complete, closed), MRP controller, and cost object. SSOT for production execution tracking in SAP S/4HANA PP.' .

ind:BatchRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Batch Record' ;
    rdfs:comment 'Electronic batch manufacturing record (eBMR) capturing the complete GMP-compliant execution history for a production batch. Captures batch number, production order reference, SKU, batch size, manufacturing date, expiry date (FEFO), facility, production line, batch status (in-process, released, rejected, quarantine, recalled), GMP deviation flag, electronic signature records, yield percentage, and Veeva Vault document reference. SSOT for GMP batch traceability per ISO 22716 and FDA 21 CFR Part 211.' .

ind:OeeRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Oee Record' ;
    rdfs:comment 'Overall Equipment Effectiveness (OEE) measurement record captured per production line per shift. Captures OEE record ID, facility, production line, shift date, shift number, planned production time (minutes), downtime (minutes), speed loss (minutes), quality loss (minutes), availability rate, performance rate, quality rate, composite OEE percentage, total units produced, total units rejected, and MES data source (Siemens Opcenter). SSOT for line performance analytics and continuous improvement programs.' .

ind:DowntimeEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Downtime Event' ;
    rdfs:comment 'Individual downtime event record capturing each unplanned or planned stoppage on a production line or work center. Captures event ID, facility, production line, work center, downtime start/end timestamps, duration (minutes), downtime category (mechanical failure, changeover, material shortage, operator absence, planned maintenance, cleaning/sanitation), root cause code, responsible department, production order impacted, and corrective action taken. Feeds OEE loss analysis and maintenance work order creation.' .

ind:YieldRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Yield Record' ;
    rdfs:comment 'Yield tracking record capturing input vs. output quantities at each stage of the manufacturing process for a production order or batch. Captures yield record ID, production order reference, batch number, routing operation, work center, input quantity, output quantity, scrap quantity, rework quantity, theoretical yield percentage, actual yield percentage, yield variance, unit of measure, and yield loss reason code. Enables yield variance analysis, COGS accuracy, and GMP batch record reconciliation.' .

ind:ProductionConfirmation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Confirmation' ;
    rdfs:comment 'Shop floor execution and confirmation record capturing the complete lifecycle of each manufacturing operation within a production order — from assignment and scheduling through actual execution and final confirmation. Captures work order number, parent production order reference, operation number, work center, assigned operator, scheduled start/end, actual start/end, confirmation type (partial, final), confirmed yield quantity, confirmed scrap quantity, actual setup/machine/labor time, operation status (open, in-progress, completed, cancelled), posting date, and MES transaction reference (Siemens Opcenter). SSOT for granular shop floor execution tracking, labor confirmation, production order settlement, and OEE calculation. Subsumes discrete work order assignment data.' .

ind:PlannedOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Planned Order' ;
    rdfs:comment 'Production planning record representing the complete planning pipeline from S&OP/IBP through MRP execution to production order conversion. Encompasses both Master Production Schedule (MPS) entries (planned quantities by SKU/facility/period with schedule versioning) and MRP-generated planned orders (system-proposed production or procurement proposals). Captures planned order ID, order type (MPS, MRP planned, CBP), SKU, plant, MRP run reference, planned quantity, scheduled start/finish dates, planning period (week/month), schedule version, S&OP cycle reference, IBP plan version, firming indicator, schedule status (draft, firmed, released, converted, deleted), exception message code, planner ID, and conversion status. SSOT for MRP exception management, MPS governance, and the complete production planning pipeline from demand signal through to production order creation.' .

ind:StockPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Position' ;
    rdfs:comment 'Core master record of physical inventory on-hand quantities for each SKU at each storage location. Captures unrestricted, quality-hold, blocked, consignment, VMI-managed, and in-transit stock quantities by stock type and special stock indicator. Serves as the authoritative real-time inventory balance (single source of truth for quantity on hand). Supports OOS/OSA monitoring, days-inventory-outstanding calculation, available-to-promise derivation, and multi-echelon inventory visibility across the distribution network.' .

ind:LotBatch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Lot Batch' ;
    rdfs:comment 'Master record for each manufactured or received lot/batch of a SKU, capturing batch number, manufacturing date, expiry date, best-before date, country of origin, GMP status, and quarantine flags. Supports FEFO/FIFO rotation enforcement, lot-level traceability for recall readiness, and regulatory compliance (FDA 21 CFR Part 11, EU REACH, EU Food Information Regulation). Linked to production batch records in manufacturing execution systems and quality inspection lots.' .

ind:InventoryStorageLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Inventory Storage Location' ;
    rdfs:comment 'Master record for physical and logical storage locations within the distribution network including distribution centers, warehouses, retail back-rooms, 3PL facilities, and in-transit staging areas. Captures location code, location type (bulk, pick, reserve, quarantine, returns), temperature zone, capacity (weight, volume, pallet positions), WMS zone mapping, and geo-coordinates. Serves as the single source of truth for the location hierarchy used across warehouse management and inventory systems.' .

ind:StockMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Movement' ;
    rdfs:comment 'Transactional record of every inventory movement event including goods receipts, goods issues, stock transfers, returns, write-offs, and inter-plant transfers. Captures movement type code, quantity, unit of measure, source and destination locations, posting date, reference document (purchase order, production order, delivery note), carrier/shipment reference for inter-node transfers, and posting user. Provides the full audit trail for inventory reconciliation and in-transit tracking.' .

ind:InventoryReplenishmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Inventory Replenishment Order' ;
    rdfs:comment 'Transactional record of inventory replenishment requests and orders generated through VMI auto-replenishment, distribution requirements planning (DRP), or manual triggers. Captures replenishment type, requested quantity, approved quantity, source location, destination location, requested delivery date, priority, and fulfillment status. Closes the loop between demand sensing signals and physical stock movement execution.' .

ind:InventoryCycleCount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Inventory Cycle Count' ;
    rdfs:comment 'Transactional record of physical inventory cycle count events conducted at storage locations. Captures count date, count method (full physical, ABC cycle, perpetual), counted quantity, system quantity, variance quantity, variance percentage, count status (planned, in-progress, confirmed, posted), and approver. Supports inventory accuracy KPIs, shrinkage investigation triggers, and WMS reconciliation. Distinct from stock_movement as it represents a formal audit event, not a stock transaction.' .

ind:OosEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Oos Event' ;
    rdfs:comment 'Transactional record capturing Out-of-Stock (OOS) and On-Shelf Availability (OSA) events at the SKU-location level. Captures OOS start timestamp, OOS end timestamp, OOS duration (hours), root cause category (demand spike, replenishment failure, forecast miss, upstream stockout, logistics delay), estimated lost sales value, and resolution action. Sourced from POS data feeds and demand sensing signals. Critical for OSA improvement programs, retail execution accountability, and service level reporting.' .

ind:RecallEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Recall Event' ;
    rdfs:comment 'Master record for product recall and withdrawal events triggered by safety, quality, or regulatory findings. Captures recall classification (Class I/II/III FDA, voluntary withdrawal), affected SKUs, affected lot/batch ranges, recall scope (geographic, channel, customer), recall initiation date, regulatory notification date (FDA/CPSC), quantity recalled, quantity recovered, recall status, and financial impact estimate. Supports lot_batch traceability queries and regulatory reporting obligations.' .

ind:StockAdjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Adjustment' ;
    rdfs:comment 'Transactional record of manual and system-generated inventory adjustments that correct stock balances outside of normal goods movement flows. Captures adjustment reason (shrinkage, damage, system reconciliation, theft, sampling, promotional giveaway), adjusted quantity, adjusted value, adjustment date, approver, and supporting reference document. Distinct from stock_movement (which covers standard GR/GI flows) — adjustments represent exception corrections to the inventory ledger.' .

ind:TradeAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Trade Account' ;
    rdfs:comment 'SSOT master record for all B2B trade customers including retailers, distributors, wholesalers, and foodservice operators. Captures authoritative account identity: legal entity name, trade channel classification (grocery, mass, club, drug, foodservice, e-commerce), account tier, credit rating, payment terms, currency, tax identifiers, DUNS number, GLN (GS1 Global Location Number), primary language, account status, lifecycle dates, and full status change audit history (previous status, new status, change reason, change timestamp, changed-by user). This is the golden record for all trade partner identity — every other customer domain entity references this product via FK.' .

ind:AccountHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Account Hierarchy' ;
    rdfs:comment 'Defines the parent-child organizational hierarchy of trade accounts, enabling roll-up of ACV, TDP, trade spend, and sales performance from store level to banner, banner to chain, and chain to parent corporation. Captures parent account, child account, hierarchy level (store, banner, chain, parent corporation), effective date range, hierarchy type (commercial, logistics, financial), and consolidation flag. Critical for S&OP and TPM reporting.' .

ind:RetailStore rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Retail Store' ;
    rdfs:comment 'Individual physical retail store or outlet location associated with a trade account banner or chain. Captures store number, store name, banner, format (hypermarket, supermarket, convenience, club, drug, dollar, e-commerce fulfillment center), store size (sq ft), trading area, store open/close dates, store manager, operating hours, and planogram zone assignment. Used for retail execution, OSA tracking, and DSD route management.' .

ind:AccountSegment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Account Segment' ;
    rdfs:comment 'Commercial segmentation, channel classification taxonomy, and go-to-market tier assignment for trade accounts. Owns the complete channel reference hierarchy (primary: retail, foodservice, wholesale, DTC; secondary: grocery, mass, club, drug, convenience, e-commerce, QSR, institutional) as well as the commercial segment assignment (strategic, key account, regional, emerging, tail). Captures channel code, channel name, channel tier, segmentation model version, customer tier, strategic priority flag, assigned sales region, applicable region, active status, and effective date range. Drives trade promotion allocation, field sales call frequency, and standardized channel reporting across all downstream domains.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Order' ;
    rdfs:comment 'Core sales order record capturing all commercial sales transactions across retail, wholesale, DTC, and e-commerce channels. Contains order header details (order number, date, channel type, status, delivery dates, OTIF status, payment terms, currency, totals, SAP SD document number) and line-level detail (SKU/GTIN, quantities ordered/confirmed/shipped, unit pricing, discounts, trade promotion references, line status, COGS, gross margin, delivery schedule). Serves as the primary transactional backbone of the sales domain enabling both order-level and SKU-level revenue and margin analysis.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Commercial billing document issued to retail accounts, distributors, or DTC consumers upon order fulfillment. Contains invoice header (invoice number, date, billing type, payment terms, gross/net values, tax, currency, payment status, DSO tracking, EDI status) and line-level detail (SKU/GTIN, billed quantities, unit prices, trade discounts, net line values, tax codes, revenue recognition categories, COGS allocation). Links to the originating sales order and serves as the accounts receivable source record enabling SKU-level revenue and profitability reporting.' .

ind:PricingAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Pricing Agreement' ;
    rdfs:comment 'Contractual pricing arrangement established with a retail account, distributor, or wholesale customer defining agreed RSP/MSRP, net pricing, volume-based tiered discounts, promotional allowances, and rebate structures. Captures agreement number, effective start/end dates, pricing tier, base list price, contracted net price, volume thresholds, rebate percentage, payment terms, currency, and approval status. Source of truth for customer-specific pricing in SAP SD condition records.' .

ind:Opportunity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Opportunity' ;
    rdfs:comment 'Sales opportunity record managed within Salesforce Consumer Goods Cloud representing potential new business: new retail account acquisition, SKU authorization/listing expansion, new channel entry, or distribution gain with a retailer or distributor. Captures opportunity name, stage (prospecting/qualification/proposal/negotiation/closed-won/closed-lost), estimated incremental annual revenue, probability percentage, expected close date, channel type, product category focus, assigned sales rep, buyer contact, and competitive displacement context. Drives SFA pipeline management, new distribution forecasting, and JBP (Joint Business Planning) alignment.' .

ind:AccountCall rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Account Call' ;
    rdfs:comment 'Field sales representative store visit record captured via Salesforce Consumer Goods Cloud SFA, including planogram compliance audit observations. Records call date/time, store/account visited, sales rep, call type, objectives, activities completed, orders placed, shelf compliance observations, OSA findings, competitor activity, POG compliance scores (facings required vs actual, shelf position, OOS items, display compliance), photo evidence references, corrective actions, and call outcome. Core operational record for retail execution, field sales KPI tracking, and shelf compliance reporting.' .

ind:ReturnOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Return Order' ;
    rdfs:comment 'Sales return authorization and credit memo request capturing product returns from retail accounts, distributors, or DTC consumers. Records return authorization number, return reason code (damaged in transit/expired/shelf-life rejection/overstock/quality defect/wrong item shipped/recall), return date, originating order reference, returned SKU/GTIN, returned quantity, return value, restocking fee if applicable, credit memo status (requested/approved/issued/posted), and disposition instruction (return to stock/destroy/rework/donate). Tracks reverse logistics triggers and financial credit processing for AR settlement.' .

ind:Territory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Geographic and account-based sales territory definition used to assign field sales representatives and key account managers to specific retail accounts, geographic regions, or channel segments. Captures territory code, name, region, district, channel assignment (grocery/drug/mass/club/convenience/e-commerce), territory type (field/key account/national account), channel characteristics (trade class, EDI capability, DSD eligibility), active status, effective dates, and assigned quota. Master reference for SFA routing, field sales KPI attribution, and channel-level segmentation.' .

ind:Rep rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Rep' ;
    rdfs:comment 'Sales representative master record for field sales, key account management, and inside sales personnel operating within the sales domain. Captures employee ID reference, rep name, rep type (field sales/key account manager/national account manager/inside sales/DSD driver), assigned territory, channel specialization, hire date, active status, SFA user ID, and current quota period. Distinct from the workforce domain employee record — this is the sales-domain operational view of the selling resource.' .

ind:Quota rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quota' ;
    rdfs:comment 'Sales quota assignment record defining revenue, volume, and distribution targets for sales representatives, territories, or account teams for a given planning period. Captures quota period (month/quarter/year), quota type (revenue/volume/new distribution/TDP), assigned rep or territory, product category or brand, quota value, stretch target, currency, approval status, and quota source (top-down/bottom-up/negotiated). Enables field sales KPI attainment tracking and S&OP alignment.' .

ind:DistributionPoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Distribution Point' ;
    rdfs:comment 'Total Distribution Points (TDP) record tracking which SKUs are actively distributed and available for sale at specific retail accounts or store locations. Captures store/account reference, SKU/GTIN, distribution status (active/inactive/authorized/delisted), authorization date, delist date, channel, planogram slot reference, ACV-weighted distribution flag, and distribution source (sell-in confirmed/POS verified). Core entity for ACV/TDP metric computation and new product distribution tracking.' .

ind:PriceList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Price List' ;
    rdfs:comment 'Standard price list master defining list prices, RSP/MSRP, and channel-specific base prices for SKUs across different trade classes and geographies. Contains both header-level metadata (price list code, name, currency, effective dates, channel applicability, type, approval status) and SKU-level price entries (unit price, MOQ, price UoM, effective dates, override flags) for each product in the list. Serves as the pricing baseline from which customer-specific pricing agreements and trade discounts are derived in SAP SD condition records.' .

ind:PriceListItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Price List Item' ;
    rdfs:comment 'Individual SKU-level price entry within a price list, capturing the specific list price or MSRP/RSP for a given product in a given channel and currency. Records SKU/GTIN reference, price list reference, unit price, minimum order quantity (MOQ), price unit of measure, effective dates, and override flag. Enables granular SKU-level pricing management and supports SAP SD condition record maintenance.' .

ind:DistributionFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Distribution Facility' ;
    rdfs:comment 'Master record for each physical distribution center (DC) or warehouse facility in the CPG network. Captures DC identity, location, type (ambient, chilled, frozen, DSD hub), capacity metrics, WMS integration identifiers (Blue Yonder site codes), SAP plant/storage location mappings, operating hours, and operational status. SSOT for DC facility master data across the distribution domain.' .

ind:DistributionStorageLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Distribution Storage Location' ;
    rdfs:comment 'Granular storage location master within a distribution center — aisles, bays, levels, bin positions, and pick faces as defined in Blue Yonder WMS. Tracks location type (bulk, pick, reserve, staging, dock), zone classification, temperature zone, weight/volume capacity, and FEFO/FIFO eligibility flags. Enables put-away and picking optimization at the slot level.' .

ind:InboundReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Inbound Receipt' ;
    rdfs:comment 'Transactional record capturing the physical receipt of goods at a DC from suppliers, manufacturing plants, or inter-DC transfers. Records ASN reference, carrier, trailer/container ID, dock door, receipt date/time, received quantity by SKU/lot, temperature check results, and discrepancy flags. Integrates with SAP WM goods receipt and Blue Yonder WMS inbound processing. Drives inventory on-hand updates and FEFO/FIFO lot registration.' .

ind:OutboundOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Outbound Order' ;
    rdfs:comment 'Master outbound fulfillment order record representing a customer or retailer replenishment request to be fulfilled from a DC. Captures order number, order type (retail replenishment, DSD, e-commerce, inter-DC transfer), customer/account reference, requested ship date, required delivery date, priority, OTIF commitment, and order status lifecycle. Sourced from SAP SD and Salesforce Consumer Goods Cloud order management.' .

ind:PickTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Pick Task' ;
    rdfs:comment 'Fulfillment task record covering both picking and packing operations within DC outbound execution. For picking: captures pick list reference, source location, SKU, lot, pick quantity, assigned operator, wave/batch reference, pick accuracy flag, and task timestamps. For packing: captures pack station, carton/pallet ID, packed SKUs and quantities, packaging material, gross weight, dimensions, GS1-128/SSCC label, and packer operator. Supports wave picking, batch picking, zone picking, and cartonization strategies in Blue Yonder WMS. Task_type discriminator distinguishes pick vs pack execution steps.' .

ind:PackTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Pack Task' ;
    rdfs:comment 'Packing task record capturing the consolidation and packaging of picked items into shipping cartons or pallets for outbound dispatch. Records pack station ID, outbound order reference, carton/pallet ID, packed SKUs and quantities, packaging material used, gross weight, dimensions, label applied (GS1-128 / SSCC), pack completion timestamp, and packer operator ID. Drives cartonization and pallet build compliance.' .

ind:DistributionShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Distribution Shipment' ;
    rdfs:comment 'Outbound shipment record representing the physical dispatch of goods from a DC to a customer, retailer, or downstream DC. Captures shipment number, carrier, trailer/container ID, seal number, dock door, scheduled and actual departure datetime, destination, total weight, total cube, pallet count, carton count, and OTIF status. Integrates with Blue Yonder WMS load planning and SAP SD goods issue. SSOT for DC-level outbound shipment execution distinct from the logistics domain\'s carrier-level shipment tracking.' .

ind:InventoryPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Inventory Position' ;
    rdfs:comment 'Current on-hand inventory position at the DC-location-SKU-lot level within distribution center walls. Captures storage location, SKU, lot number, manufacture and expiry dates, quantity on hand, allocated quantity, available-to-pick (ATP) quantity, quarantine quantity, inventory status (available, hold, damaged, expired), and last cycle count date. This is the operational working inventory view for DC execution — distinct from the inventory domain\'s network-wide planning position which aggregates across all nodes.' .

ind:DistributionCycleCount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Distribution Cycle Count' ;
    rdfs:comment 'Cycle count event record capturing scheduled or ad-hoc physical inventory counts at DC locations, including line-level detail for each SKU/lot counted with system vs. actual quantities and variance calculations.' .

ind:OtifEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Otif Event' ;
    rdfs:comment 'OTIF (On Time In Full) performance measurement record for each outbound shipment or DSD delivery against committed service levels. Captures shipment/delivery reference, customer/account, committed vs actual delivery date, on-time flag, committed vs delivered quantity, in-full flag, composite OTIF score, root cause category for failures (DC pick error, inventory shortage, dock delay, carrier issue), and retailer penalty exposure amount. Primary KPI entity for DC operations accountability and retailer scorecard compliance.' .

ind:InspectionPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Plan' ;
    rdfs:comment 'Master data defining QC inspection plans and quality specifications for raw materials, in-process intermediates, packaging, and finished goods. Captures sampling procedures, inspection characteristics with specification limits (USL/LSL/target), acceptable quality levels (AQL), test methods, units of measure, effective date ranges, and GMP-mandated control points. Serves as the single authoritative source for what to test, how to sample, and what limits apply — governing all inspection lot execution and feeding CoA generation. Aligned with SAP QM inspection planning.' .

ind:InspectionLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Lot' ;
    rdfs:comment 'Transactional record of a QC inspection lot triggered by a production batch, goods receipt, or periodic review. Tracks lot origin (batch, purchase order, production order), inspection type, assigned inspection plan, lot quantity, inspection status, and complete disposition lifecycle including formal usage decision (accept/reject/restricted use/rework), decision maker, decision date, decision code, stock posting instruction, regulatory hold flag, and disposition outcome. Core operational entity in SAP QM representing the end-to-end inspection-to-disposition workflow.' .

ind:InspectionResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Granular QC measurement and test result records captured at the characteristic level within an inspection lot. Stores measured values, upper/lower specification limits, pass/fail status, instrument used, inspector ID, and timestamp. Supports SPC (Statistical Process Control) and GMP audit trails per ISO 9001 and GMP requirements.' .

ind:UsageDecision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Usage Decision' ;
    rdfs:comment 'Records the formal QC usage decision made at the conclusion of an inspection lot — accept, reject, restricted use, or rework. Captures decision code, decision maker, decision date, stock posting instruction, and regulatory hold flag. Drives downstream batch release and inventory disposition in SAP QM/MM.' .

ind:Nonconformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Nonconformance' ;
    rdfs:comment 'Unified quality event record for non-conformances, deviations, quality notifications, and improvement requests identified during manufacturing, QC inspection, supplier receipt, or customer complaint escalation. Captures event type (complaint, defect, deviation, improvement request), defect description, defect classification, affected batch/SKU, detection source, severity, priority, containment actions, task assignments, responsible plant, and linkage to CAPA. Serves as the single routing point for all quality events across SAP QM notifications and Veeva Vault workflows. Aligns with ISO 9001:2015 clause 10.2 and GMP deviation reporting requirements.' .

ind:Capa rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Capa' ;
    rdfs:comment 'Corrective and Preventive Action (CAPA) records initiated in response to nonconformances, audit findings, complaints, or stability failures. Tracks root cause analysis method, corrective actions, preventive actions, responsible owner, target completion dates, effectiveness verification, and closure status. Managed in Veeva Vault QMS.' .

ind:BatchRelease rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Batch Release' ;
    rdfs:comment 'Formal batch release decision records authorizing finished goods batches for distribution and sale. Captures batch number, product SKU, release decision (released, rejected, quarantine), QP (Qualified Person) sign-off, release date, certificate of analysis reference, and regulatory hold status. Critical GMP control point per FDA 21 CFR and EU GMP.' .

ind:CertificateOfAnalysis rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Certificate Of Analysis' ;
    rdfs:comment 'Certificate of Analysis (CoA) documents issued per finished goods or raw material batch. Stores test parameters, specification limits, actual results, pass/fail status, issuing lab, authorized signatory, issue date, and customer-facing distribution flag. Supports trade customer requirements and regulatory submissions. Managed in Veeva Vault.' .

ind:ProductComplaint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Product Complaint' ;
    rdfs:comment 'Consumer and trade customer product complaint records capturing post-market quality issues. Stores complaint source (consumer, retailer, regulatory), product SKU, batch number, complaint category (foreign body, contamination, labeling, efficacy), severity, investigation status, regulatory reportability flag, and resolution outcome. Integrates with Salesforce Consumer Goods Cloud and Veeva Vault.' .

ind:Specification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Specification' ;
    rdfs:comment 'Master data defining quality specifications for raw materials, packaging, in-process intermediates, and finished goods. Stores specification type, test characteristic, unit of measure, target value, upper/lower specification limits (USL/LSL), test method reference, and effective date range. Serves as the authoritative specification repository linked to inspection plans and CoA generation.' .

ind:Notification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Notification' ;
    rdfs:comment 'SAP QM quality notification records used to formally document and route quality defects, deviations, and improvement requests within the organization. Captures notification type (complaint, defect, improvement), priority, affected material/batch, responsible plant, task assignments, and closure details. Native SAP QM entity.' .

ind:MarketingBrand rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Marketing Brand' ;
    rdfs:comment 'Master record for each brand in the Consumer Goods portfolio. Captures brand identity, positioning, architecture tier (masterbrand, subbrand, endorsed), target consumer segment, brand equity scores, SOV (Share of Voice) benchmarks, brand health KPI targets, and lifecycle stage. Serves as the SSOT for brand master data referenced across campaign, media, and trade promotion domains.' .

ind:Campaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Campaign' ;
    rdfs:comment 'Master record for each marketing campaign executed by Consumer Goods. Captures campaign name, type (ATL, BTL, digital, shopper, influencer, integrated), objective, target audience, brand association, channel mix, planned vs. actual media spend, campaign start/end dates, creative concept, campaign status, and owning brand/category. Sourced from Salesforce Consumer Goods Cloud and internal campaign management systems.' .

ind:CampaignFlight rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Campaign Flight' ;
    rdfs:comment 'Transactional record of campaign execution at the flight level, capturing performance metrics across ALL channels (digital, TV, OOH, print, social, search, programmatic) at the campaign-channel-market-date grain. Defines scheduled media run dates, channel, market/geography, budget allocation, and flight-level performance targets. Captures planned and actual impressions, clicks, CTR, video views, view-through rate, conversions, CPC, CPA, ROAS, reach, frequency, GRPs (traditional), and platform-specific metrics (Meta, Google, TikTok, programmatic DSP). A single campaign may have multiple flights across different channels or geographies. Sourced from digital ad platform APIs, agency post-buy reports, and media monitoring systems. Serves as the unified granular performance record for omnichannel campaign measurement.' .

ind:MediaPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Media Plan' ;
    rdfs:comment 'Formal media plan document capturing planned media investments across channels (TV, digital, OOH, print, social, search, programmatic) for a brand or campaign. Includes planned impressions, GRPs, reach, frequency, CPM, total planned spend, agency, media owner, market, and planning period. Serves as the authoritative pre-buy record for media investment decisions.' .

ind:MediaSpend rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Media Spend' ;
    rdfs:comment 'Transactional record of actual media spend incurred per channel, campaign, brand, and time period. Captures invoiced spend, committed spend, variance to plan, media owner, agency fees, working vs. non-working spend classification, and cost-per-metric actuals (CPM, CPC, CPV). Sourced from agency billing systems and reconciled against media plan commitments.' .

ind:CreativeAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Creative Asset' ;
    rdfs:comment 'Master record for each creative asset and content item (TV commercial, digital banner, social post, print ad, packaging visual, influencer brief, video, blog post, email template) used in marketing campaigns or published on owned/earned channels. Captures asset name, format, dimensions, file type, brand, campaign association, creative concept, approval status, rights/usage restrictions, expiry date, DAM reference ID, and content publishing metadata (planned publish date, actual publish date, publishing channel, content status, content type, target audience segment, content owner). Serves as the unified creative and content management record supporting brand compliance, creative reuse tracking, DAM integration, and coordinated omnichannel content calendar planning. No separate content calendar product exists — all scheduling and publishing metadata lives here.' .

ind:ConsumerSegment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Consumer Segment' ;
    rdfs:comment 'Reference master for consumer segmentation definitions used in targeting and campaign planning. Captures segment name, segmentation model (behavioral, psychographic, demographic, needs-based), segment size estimate, key characteristics, target channel affinity, brand affinity, and strategic priority tier. Used to align campaign targeting across digital, retail, and DTC channels. Distinct from consumer profile (owned by consumer domain).' .

ind:MarketResearchStudy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Market Research Study' ;
    rdfs:comment 'Master record for each market research study or syndicated data subscription commissioned or conducted by Consumer Goods. Captures study name, research type (quantitative, qualitative, U&A, concept test, pack test, NPS, brand health tracker, consumer panel), research agency/data provider (Nielsen IQ, Kantar, Circana, Ipsos), fieldwork dates, target market, sample size, methodology, status, key findings summary, and periodic panel metrics (household penetration, purchase frequency, basket size, repeat rate, switching behavior, buyer demographics). Serves as the SSOT for all primary and syndicated research investment, output tracking, and consumer panel insight management. Enables research ROI tracking and insight activation across brand strategy.' .

ind:BrandHealthTracker rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Brand Health Tracker' ;
    rdfs:comment 'Consolidated periodic brand performance scorecard capturing all consumer perception, market position, competitive share, media share, and social sentiment metrics for a brand in a specific market and time period. Captures awareness (spontaneous, aided), consideration, preference, purchase intent, NPS, brand equity index, SOV% (Share of Voice by channel — TV, digital, OOH, social), SOM% (value share, volume share by category/channel/geography), total category spend, competitor benchmarks, social sentiment scores (positive/neutral/negative breakdown), mention volume, share of conversation, platform distribution, net sentiment score, and key image attribute scores. Sourced from Nielsen Ad Intel/Kantar media monitoring (SOV), Nielsen IQ Retail Measurement/Circana (SOM), proprietary brand tracking studies (awareness/equity), and social listening platforms (sentiment). Serves as the single authoritative brand scorecard enabling longitudinal brand health monitoring, SOV vs. SOM gap analysis, competitive benchmarking, market share trend tracking, and sentiment trend analysis.' .

ind:Agency rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Agency' ;
    rdfs:comment 'Master record for marketing agency partners engaged by Consumer Goods. Captures agency name, agency type (creative, media, digital, PR, shopper, research, influencer), holding group, scope of services, retainer vs. project basis, primary contact, contract status, performance rating, markets served, assigned brands, and fee structure. Serves as the SSOT for agency partner identity and roster management within the marketing domain. Enables agency performance benchmarking and spend consolidation analysis.' .

ind:MarketingBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Marketing Budget' ;
    rdfs:comment 'Marketing budget allocation record capturing planned and approved marketing investment by brand, category, channel, campaign type, and fiscal period. Captures total budget, working media budget, non-working budget, agency fees, research budget, committed spend, actual spend, variance, and budget owner. Distinct from finance domain general ledger — this is the marketing-owned investment planning record.' .

ind:MarketShareRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Market Share Record' ;
    rdfs:comment 'Periodic market share (SOM) measurement record capturing a brand\'s or SKU\'s value and volume share within a defined category, channel, and geography at a given time period. Captures value share %, volume share %, category total value, brand value, data source (Nielsen IQ Retail Measurement, IRI/Circana), market definition, and period. Enables SOM trend tracking and competitive benchmarking.' .

ind:Registration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Registration' ;
    rdfs:comment 'Master record for product registrations with regulatory authorities across all jurisdictions. Tracks registration number, status, effective/expiry dates, registering authority, product scope, registration type (new, renewal, amendment, cancellation), active ingredients, use classification, submission reference, and renewal due date. Covers FDA, EPA (FIFRA pesticide/antimicrobial), CPSC, EU REACH, and country-specific registrations. SSOT for all regulatory registration identities regardless of authority or jurisdiction.' .

ind:Submission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Submission' ;
    rdfs:comment 'Regulatory submission records filed with any governing body worldwide. Captures submission type (510k, PMA, GRAS, TSCA, cosmetic notification, CPSC Section 15(b) report, SaferProducts.gov, REACH registration), submission date, dossier reference, submission channel, assigned reviewer, status, target decision date, hazard/incident details (for safety filings), population at risk, and linked registration. SSOT for all regulatory filings regardless of authority. Sourced from Veeva Vault regulatory submissions module.' .

ind:Dossier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Dossier' ;
    rdfs:comment 'Regulatory dossier master record representing the compiled technical and scientific documentation package supporting a product registration or submission. Tracks dossier type (CTD, eCTD, IECIC, CPNP), version, compilation date, owning regulatory affairs team, completeness status, linked submission, and document repository reference in Veeva Vault. One dossier may support multiple submissions across jurisdictions.' .

ind:Sds rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Sds' ;
    rdfs:comment 'Safety Data Sheet (SDS/MSDS) master records for raw materials, finished goods, and intermediates as required by OSHA HazCom, EU CLP, and GHS standards. Captures SDS version, revision date, GHS hazard classifications, signal word, precautionary statements, first aid measures, handling/storage requirements, disposal guidance, transport classification (UN number, packing group), and authoring chemist. Managed in Veeva Vault.' .

ind:IngredientList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Ingredient List' ;
    rdfs:comment 'Ingredient declaration records capturing the full ingredient list for a finished product SKU as required for labeling compliance. Tracks INCI names, CAS numbers, concentration ranges, function (preservative, surfactant, fragrance, colorant), declaration order, jurisdiction-specific requirements (FDA 21 CFR, EU Cosmetics Regulation, REACH), allergen flags, and restricted substance flags. Links to product master and formulation records.' .

ind:LabelVersion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Label Version' ;
    rdfs:comment 'Product label version master tracking all approved and historical label artwork versions for each SKU across markets. Captures label version number, market/country, language, label type (primary, secondary, shipper), regulatory approval status, approval date, approving authority, label claims, warning statements, net content declaration, country-of-origin, and Veeva Vault document reference. Supports multi-jurisdictional labeling compliance.' .

ind:ComplianceObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Compliance Obligation' ;
    rdfs:comment 'Master record of regulatory compliance obligations applicable to the business by jurisdiction, product category, and governing body. Tracks obligation type (registration, labeling, reporting, testing, notification, renewal), governing regulation (CFR part, EU directive, REACH article, state law), applicable product categories, compliance deadline, renewal frequency, advance notice period, responsible regulatory affairs owner, estimated compliance cost, and current compliance status. Drives the regulatory compliance calendar and proactive renewal management.' .

ind:ComplianceAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Compliance Assessment' ;
    rdfs:comment 'Transactional records documenting compliance assessments against specific regulatory requirements (CFR, IFRA, EU CLP, REACH, state regulations) for each product, formulation, or facility. Captures regulatory framework, specific requirement reference, compliance assessment date, assessor, compliance finding (compliant, non-compliant, conditional), corrective action required, corrective action due date, closure date, and evidence document reference. Supports multi-framework compliance verification including FDA/EPA audit readiness and IFRA fragrance safety substantiation. SSOT for all regulatory compliance assessments regardless of governing body.' .

ind:ProductRecall rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Product Recall' ;
    rdfs:comment 'Product recall and market withdrawal master records initiated voluntarily or mandated by regulatory authorities. Captures recall class (Class I/II/III per FDA/CPSC), recall reason, affected SKUs, affected lot/batch numbers, recall scope (geographic, channel), initiation date, authority notification date, press release reference, quantity recalled, completion date, effectiveness check results, and consumer remedy type. SSOT for recall event management across all jurisdictions and authorities.' .

ind:Jurisdiction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Reference master for regulatory jurisdictions defining the geographic and legal scope of regulatory requirements. Captures jurisdiction code, jurisdiction name, country/region, applicable regulatory framework (FDA, EU, ASEAN, GCC), market entry requirement type, language requirements for labeling, and notification vs. registration requirement flag. Used to drive multi-jurisdictional compliance workflows across registrations, labels, and submissions.' .

ind:RestrictedSubstance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Restricted Substance' ;
    rdfs:comment 'Master record for all chemicals, ingredients, and materials subject to prohibition, restriction, authorization, or disclosure under any applicable regulation worldwide. Captures substance name, CAS number, EC number, restriction type (banned, concentration limit, disclosure required, authorization required), applicable regulation(s), REACH registration number, tonnage band, SVHC status, authorization status, maximum permitted concentration, effective date, downstream user notification obligations, and affected product categories. SSOT for all regulated substance data including EU REACH, California Prop 65, FDA prohibited ingredients, EPA restricted chemicals, and FIFRA substances.' .

ind:RegulatoryClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Regulatory Claim' ;
    rdfs:comment 'Master record of approved and pending regulatory claims for products including structure/function claims, environmental claims (biodegradable, recyclable), organic/natural certifications, and efficacy claims. Captures claim text, claim type, substantiation method, supporting study references, regulatory authority approval status, approved markets, claim expiry date, and FTC/FDA compliance review outcome. Prevents unapproved claims from appearing on labels or marketing materials.' .

ind:DemandPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Demand Plan' ;
    rdfs:comment 'Core master entity representing the demand plan across all versions, stages, and consensus outcomes within the S&OP/IBP cycle for each SKU/location/channel/planning period combination. Each record represents a specific version-point: captures version name, version type (statistical baseline/field sales overlay/marketing-adjusted/consensus/final approved), planning cycle reference, created-by persona, approval status, effective date range, planning bucket (weekly/monthly), statistical baseline quantity, commercial overlay, marketing event uplift, new product launch volume, consensus quantity, variance to statistical baseline, channel disaggregation, promotional overlays, and lifecycle stage. The consensus version represents the single agreed demand signal passed to supply planning. Enables forecast accuracy benchmarking across versions. Sourced from SAP IBP Demand Planning module.' .

ind:Plan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Plan' ;
    rdfs:comment 'Core master entity representing the constrained and unconstrained supply plan for each SKU/plant/DC combination. Captures planned production quantities, planned replenishment orders, supply source, planning horizon, constraint flags, and IBP supply planning run metadata. Sourced from SAP IBP Supply Planning module.' .

ind:SafetyStock rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Safety Stock' ;
    rdfs:comment 'Transactional record capturing the calculated and approved safety stock quantity for each SKU/location/time-period combination. Stores calculation method (statistical, days-of-supply, manual override), demand variability, lead time variability, service level input, calculated SS units, approved SS units, effective date, and review status. Distinct from inventory_policy (policy target) as this captures the actual calculated output.' .

ind:SupplyReplenishmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supply Replenishment Order' ;
    rdfs:comment 'Transactional record representing a planned or released replenishment order generated by DRP execution for moving inventory between supply network nodes (plant-to-DC, DC-to-DC). Captures order type (planned/firmed/released), source location, destination location, SKU, requested quantity, confirmed quantity, planned ship date, planned receipt date, and DRP run reference. Distinct from purchase orders (owned by procurement) and production orders (owned by manufacturing).' .

ind:NetworkNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Network Node' ;
    rdfs:comment 'Master entity representing each node in the supply network (manufacturing plant, regional DC, forward DC, co-manufacturer, 3PL site). Captures node type, geographic location, capacity class, lead time to downstream nodes, sourcing rules, and active status. Forms the backbone of the supply network design used in IBP supply planning and DRP.' .

ind:NetworkLane rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Network Lane' ;
    rdfs:comment 'Master entity defining the sourcing lane between two supply network nodes (source-destination pair). Captures lane type (production, transfer, external procurement), primary/secondary sourcing priority, standard lead time, transportation lead time, minimum order quantity (MOQ), lot size, and active status. Used by DRP and IBP to determine replenishment routing.' .

ind:AtpRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Atp Record' ;
    rdfs:comment 'Transactional record capturing the Available-to-Promise (ATP) and Capable-to-Promise (CTP) calculation results for each SKU/location/date combination. Stores confirmed ATP quantity, CTP quantity, cumulative ATP, demand pegging reference, supply pegging reference, calculation timestamp, and ATP method (simple, cumulative, multi-level). Consumed by sales order management for order promising.' .

ind:ConsensusDemand rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Consensus Demand' ;
    rdfs:comment 'Transactional record capturing the final consensus demand volume agreed upon during the S&OP demand review for each SKU/location/planning period. Stores statistical forecast input, commercial overlay, marketing event uplift, new product launch volume, consensus quantity, variance to statistical baseline, approver, and S&OP cycle reference. Represents the single agreed demand signal passed to supply planning.' .

ind:SkuPlanningParam rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Sku Planning Param' ;
    rdfs:comment 'Master entity storing SKU-level planning parameters used in demand and supply planning calculations. Captures planning horizon, lot size, minimum order quantity (MOQ), shelf life (days), FEFO/FIFO flag, planning strategy (make-to-stock/make-to-order), ABC/XYZ classification, demand pattern type, seasonality index, and IBP planning group assignment. Distinct from product master (owned by product domain) as this captures supply-planning-specific parameters.' .

ind:TradePromotion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Trade Promotion' ;
    rdfs:comment 'Core master entity for trade promotion programs. Captures the full definition of a trade promotion including name, type (Hi-Lo, EDLP, display, coupon, scan-back, off-invoice), promotional period, owning brand/category, status (planned, active, closed, cancelled), total authorized trade spend budget, promotion objectives, promotion type classification (temporary price reduction, feature ad, display, BOGO, multi-buy, scan-back, coupon, loyalty reward), applicable channels, and integration reference to Salesforce TPM. Serves as the SSOT for all trade promotion definitions and the parent entity for all promotion events, spend allocations, and post-event analyses.' .

ind:Event rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Event' ;
    rdfs:comment 'Represents a discrete promotional execution event tied to a trade promotion program. A single trade promotion may have multiple events across different retailers, geographies, or time windows. Captures event-level details: event type (feature ad, display, temporary price reduction, BOGO, scan-back), event start/end dates, retailer account, ship-to location, participating SKUs, planned vs. actual event status, and event-level trade spend allocation. Integrates with Salesforce TPM event records.' .

ind:EventSku rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Event Sku' ;
    rdfs:comment 'Association entity linking individual SKUs (GTINs/UPCs) to a specific promotion event with full promotional pricing authority. Captures SKU-level promotional details including promoted price, promoted price type (Hi-Lo temporary price reduction, EDLP, multi-buy, BOGO, scan-back, off-invoice, bill-back), price reduction depth (%), regular shelf price (RSP/MSRP), effective date range, planned promotional volume (cases/units), actual promotional volume, baseline volume estimate, incremental lift volume, promotional discount amount per unit, retailer account, channel, and pricing approval status. Serves as the SSOT for SKU-level promotional pricing within trade events — distinct from standard list pricing owned by the product domain. Enables SKU-level trade spend, lift analysis, and promotional price compliance per event.' .

ind:TradeCalendar rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Trade Calendar' ;
    rdfs:comment 'Master entity representing the annual or periodic trade promotional calendar for a brand, category, or retailer account. Captures calendar name, fiscal year, planning cycle, owning brand/category manager, retailer account scope, calendar status (draft, approved, locked), total planned trade spend envelope, and number of planned promotion events. Serves as the planning container for all trade promotion events within a given period and account relationship.' .

ind:TradeSpendAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Trade Spend Allocation' ;
    rdfs:comment 'Transactional record capturing the allocation of trade spend budget to a specific promotion event, retailer account, brand, or SKU group. Tracks allocated amount, spend type (off-invoice discount, scan-back, bill-back, lump sum, co-op advertising, slotting fee, display allowance, free goods), spend category classification, GL account mapping, fiscal period, cost center, approval status, and variance between planned and committed spend. Feeds into COGS and trade spend reporting for S&OP and finance reconciliation.' .

ind:FundingAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Funding Agreement' ;
    rdfs:comment 'Master entity representing a formal retailer funding agreement (RFA) or joint business plan (JBP) between the CPG manufacturer and a retail account. Captures agreement name, retailer account, agreement type (annual lump sum, scan-back, co-op, slotting, performance-based), total committed funding amount, funding period, payment terms, performance conditions, approval status, and signatory details. Serves as the contractual basis for trade spend commitments and deduction settlements.' .

ind:Deduction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Deduction' ;
    rdfs:comment 'Transactional record representing the full lifecycle of a retailer deduction from initial short-payment through final settlement. Captures deduction number, retailer account, invoice reference, deduction amount, deduction type (promotional, pricing, shortage, compliance), deduction date, dispute status (open, approved, disputed, written-off), and complete settlement details: settlement date, settlement method (credit memo, check, offset against future invoice, write-off), settled amount, approved amount, disputed amount, settlement reason code, approver, and linkage to originating promotion event and funding agreement. Serves as the single entity for the entire deduction management workflow — no separate settlement record exists. Central to trade spend reconciliation, dispute resolution, and retailer relationship management.' .

ind:DeductionSettlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Deduction Settlement' ;
    rdfs:comment 'Transactional record capturing the resolution and settlement of a retailer deduction. Tracks settlement date, settlement method (credit memo, check, offset against future invoice, write-off), settled amount, approved amount, disputed amount, settlement reason code, approver, and linkage to the originating deduction and funding agreement. Enables closed-loop deduction management and accurate trade spend reconciliation.' .

ind:PostEventAnalysis rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Post Event Analysis' ;
    rdfs:comment 'Comprehensive analytical record capturing post-event review (PER) results for a completed promotion event at SKU-retailer-period granularity. Stores baseline volume estimates (methodology, confidence interval, data source, pre-promotion trend), actual promoted volume, incremental lift measurements (units, percentage, lift source — POS scan data, Nielsen IQ panel, TradeEdge secondary sales), measurement methodology, data vintage, planned vs. actual trade spend, promotional ROI, GMROI, cost per incremental case, sell-through rate, OOS incidents, retailer compliance score, and analyst notes. Serves as the single analytical SSOT for all promotion performance measurement including baseline estimation, lift calculation, and ROI analysis. Feeds TPO optimization models, learning loops, and future planning decisions.' .

ind:PromotedPrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Promoted Price' ;
    rdfs:comment 'Master entity capturing the promotional price points defined for SKUs within a promotion event or pricing program. Tracks promoted price type (Hi-Lo temporary price reduction, EDLP, multi-buy, BOGO, scan-back price), promoted price amount, regular shelf price (RSP/MSRP), price reduction depth (%), effective date range, retailer account, channel, and approval status. Distinct from standard list pricing — this entity owns the promotional price layer used during trade events.' .

ind:LiftMeasurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Lift Measurement' ;
    rdfs:comment 'Transactional record capturing incremental volume lift measurements for a promotion event at the SKU-retailer-week level. Stores baseline volume (pre-promotion trend), actual promoted volume, incremental lift units, incremental lift percentage, lift source (POS scan data, Nielsen IQ panel, TradeEdge secondary sales), measurement methodology, confidence interval, and data vintage. Feeds TPO optimization models and post-event ROI calculations.' .

ind:RetailerCompliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Retailer Compliance' ;
    rdfs:comment 'Transactional record capturing retailer execution compliance for a promotion event — whether the retailer delivered the agreed promotional mechanics (feature ad, display, price point, shelf placement per POG). Tracks compliance check date, compliance type (ad feature, display, price compliance, OSA), compliance score (%), non-compliance reason, penalty amount applied, auditor/field rep reference, and data source (SFA field audit, third-party compliance service). Feeds deduction dispute resolution and future funding negotiations.' .

ind:BaselineVolume rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Baseline Volume' ;
    rdfs:comment 'Transactional record capturing the statistical baseline volume estimate for a SKU-retailer-period combination, representing expected sales absent any promotional activity. Stores baseline volume (units/cases), baseline revenue, baseline methodology (moving average, regression, Nielsen IQ panel, Bayesian structural time series), data source, baseline period, confidence interval, last refresh date, analyst override flag, and model version. Serves as the reusable baseline denominator consumed by post_event_analysis for incremental lift calculation across all promotion events. Maintained independently of any single promotion event to enable consistent cross-event comparison and baseline trend monitoring.' .

ind:ConsumerOffer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Consumer Offer' ;
    rdfs:comment 'Master entity defining consumer-facing promotional offers (coupons, digital offers, loyalty rewards, instant rebates, free goods with purchase) that are part of a trade promotion or brand marketing program. Captures offer code, offer type, offer description, discount value/percentage, qualifying SKUs, minimum purchase requirement, offer validity period, distribution channel (FSI, digital, in-store, DTC app), maximum redemption limit, and offer status. Distinct from trade funding — this entity owns the consumer-facing offer definition.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Master record for all suppliers, vendors, and contract manufacturers providing raw materials, packaging, and indirect goods. Captures supplier legal entity details, GS1/DUNS identifiers, tax registration, payment terms, MOQ terms, lead times, incoterms, preferred currency, supplier tier classification (strategic/preferred/approved/conditional), VMI eligibility flag, EDI capability, sustainability certifications (FSC, RSPO), and onboarding status. SSOT for supplier identity across the procurement domain.' .

ind:SupplierSite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier Site' ;
    rdfs:comment 'Physical manufacturing, warehouse, or office locations associated with a supplier. Captures site address, site type (manufacturing/warehouse/office/port), GS1 GLN, country of origin, site capacity, certifications held at site level (ISO 9001, ISO 22716, GMP), site-level lead time, and active status. Supports multi-site supplier relationships and origin traceability for regulatory compliance.' .

ind:SupplierContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier Contract' ;
    rdfs:comment 'Procurement contracts and framework agreements negotiated with suppliers for raw materials, packaging, and indirect goods. Captures contract header (number, type, effective/expiry dates, total value, currency, pricing mechanism, rebate terms, penalty clauses, auto-renewal, governing law) and contract line items (material/SKU, agreed unit price, price UoM, target quantity, MOQ, max order quantity, price validity period, escalation formula, line status). Tracks contract lifecycle from draft through active to expired/terminated. Enables granular price and volume commitment tracking at the material level. Owns all line-level detail as embedded attributes.' .

ind:ContractLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Contract Line' ;
    rdfs:comment 'Individual line items within a supplier contract specifying material, packaging component, or service being procured. Captures material/SKU reference, agreed unit price, price unit of measure, target quantity, MOQ, maximum order quantity, price validity period, price escalation formula, and contract line status. Enables granular price and volume commitment tracking at the material level.' .

ind:PurchaseRequisition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Purchase Requisition' ;
    rdfs:comment 'Internal purchase requisition (PR) raised by manufacturing, R&D, marketing, or other departments requesting procurement of raw materials, packaging, or indirect goods. Captures requisition number, requesting cost center, material/service description, required quantity, unit of measure, required delivery date, estimated value, approval workflow status, and source of supply recommendation. Feeds the purchase order creation process and supports budget control and spend governance.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Purchase order issued to a supplier for raw materials, packaging components, or indirect goods/services. Captures PO header (number, type, order date, supplier, delivery plant, payment terms, incoterms, total value, currency, EDI status, lifecycle status) and PO line items (material number, ordered quantity, unit price, delivery dates, batch requirements, GR/IR indicators, line status). Includes supplier order confirmations (confirmed dates, quantities, variances, confirmation method EDI 855/portal/email) and delivery schedule lines (planned/confirmed dates, quantities, transport mode, delivery status). Core transactional entity for procurement execution, three-way match, OTIF tracking, and proactive supply risk management.' .

ind:PoLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Po Line' ;
    rdfs:comment 'Individual line items on a purchase order specifying the material, packaging component, or service being ordered. Captures PO line number, material number, material description, ordered quantity, unit of measure, confirmed delivery date, net price, price unit, storage location, batch management flag, goods receipt indicator, invoice receipt indicator, and line status. Enables granular tracking of delivery and invoice matching at the material level.' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Goods receipt (GR) event recorded when raw materials, packaging, or indirect goods are physically received at a plant or distribution center against a purchase order. Captures GR document number, posting date, receiving plant, storage location, received quantity per line, unit of measure, batch number, FEFO expiry date, quality inspection flag, movement type, and GR status. Triggers inventory update and three-way match process. Supports GR reversal and return-to-vendor scenarios.' .

ind:SupplierInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier Invoice' ;
    rdfs:comment 'Supplier invoice received for goods or services delivered against a purchase order. Captures invoice header (supplier-assigned number, invoice date, posting date, gross amount, tax amount, currency, payment due date, three-way match status, tolerance check result, blocking reason, processing status) and invoice line items (referenced PO line, material/service description, invoiced quantity, unit price, line amount, tax code, line-level match status). Supports granular three-way match (PO vs GR vs invoice) at both header and line level. Feeds accounts payable and COGS allocation. Owns all line-level detail as embedded attributes.' .

ind:SupplierScorecard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier Scorecard' ;
    rdfs:comment 'Periodic supplier performance scorecard evaluating suppliers across key procurement KPIs: OTIF delivery rate, quality rejection rate (defect PPM), invoice accuracy, responsiveness, sustainability compliance, and regulatory adherence. Captures scorecard period, overall weighted score, individual KPI scores, trend vs prior period, scorecard status, and recommended action (maintain/develop/escalate/delist). Supports strategic supplier relationship management, sourcing decisions, and category reviews.' .

ind:SpendCategory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Spend Category' ;
    rdfs:comment 'Hierarchical classification taxonomy for procurement spend categories covering raw materials (oils, surfactants, fragrances, actives, excipients), primary and secondary packaging, MRO, capex, and indirect services. Captures category code, category name, parent category, category level (L1/L2/L3/L4), commodity type, applicable regulatory frameworks (REACH, FDA, RSPO), preferred sourcing strategy, and category owner. Enables spend analytics, category management, and compliance reporting.' .

ind:ApprovedSupplierList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Approved Supplier List' ;
    rdfs:comment 'Approved Supplier List (ASL) entry defining which suppliers are authorized to supply specific materials or spend categories to specific plants. Captures material/category, supplier, plant, approval status (approved/conditional/blocked/delisted), approval date, re-evaluation due date, approval basis (audit/certification/qualification test), and blocking reason. Enforces sourcing compliance and prevents unauthorized supplier usage in PO creation.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Master record for organizational cost centers used in SAP S/4HANA CO module. Defines the financial accountability units within the CPG enterprise — brand units, manufacturing plants, regional sales offices, and shared service centers. Each cost center carries a hierarchy path, responsible manager, controlling area, profit center assignment, currency, and active period. Serves as the foundational dimension for all cost accounting, COGS allocation, and EBITDA reporting.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Master record for profit centers representing autonomous business segments within the consumer goods enterprise — product lines, brands, or geographic business units. Tracks revenue, cost, and profitability at a granular level below the legal entity. Integrates with SAP S/4HANA CO-PCA (Profit Center Accounting) and Oracle Cloud Financials for segment reporting and EBITDA decomposition.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger chart of accounts master for the consumer goods enterprise. Defines every account in the COA including P&L accounts (revenue, COGS, trade spend, marketing, SG&A), balance sheet accounts (inventory, AR, AP, fixed assets), and statistical accounts. Stores account type, financial statement category, tax category, reconciliation account flag, currency, and controlling relevance. Source of truth for all financial postings in SAP S/4HANA FI and Oracle Cloud Financials.' .

ind:Ledger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ledger' ;
    rdfs:comment 'Financial ledger master defining the accounting ledgers maintained in the enterprise — leading ledger (IFRS/GAAP), parallel ledgers for local GAAP, and extension ledgers for management reporting. Each ledger record captures ledger type, accounting principle, currency type, fiscal year variant, and posting period variant. Supports multi-GAAP reporting requirements common in global CPG companies operating across multiple regulatory jurisdictions.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Core general ledger journal entry header capturing every financial posting in the consumer goods enterprise. Records document type (vendor invoice, customer payment, goods issue, payroll posting, accrual, reversal), posting date, fiscal period, company code, ledger, currency, exchange rate, reference document, and SOX-compliant posting user and approval chain. The authoritative transactional record for all financial activity sourced from SAP S/4HANA FI and Oracle Cloud Financials.' .

ind:JournalEntryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry Line' ;
    rdfs:comment 'Individual line items of a general ledger journal entry. Each line captures the GL account, cost center, profit center, WBS element, business area, debit/credit indicator, amount in transaction currency, amount in company code currency, amount in group currency, tax code, and assignment field. Enables granular cost allocation, COGS decomposition, and audit trail tracing at the line level as required by SOX compliance.' .

ind:ArInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ar Invoice' ;
    rdfs:comment 'Accounts receivable master record representing the full trade receivable lifecycle for consumer goods sales to retailers, distributors, and wholesalers. Owns invoice creation, payment terms, cash receipt application, partial payments, deductions/short-payments, clearing, and write-offs. Captures invoice number, billing date, due date, payment terms, gross amount, trade discounts, net amount, tax, currency, payment method, payment date, amount received, clearing reference, DSO aging bucket, dunning level, and deduction reason codes. The single source of truth for all receivable balances, cash application, deduction management, DSO tracking, cash flow forecasting, and revenue recognition under ASC 606/IFRS 15. Integrates with SAP S/4HANA SD billing and FI-AR.' .

ind:ArPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ar Payment' ;
    rdfs:comment 'Accounts receivable payment record capturing cash receipts from trade customers against outstanding AR invoices. Records payment date, payment method (ACH, wire, check, EDI 820), amount received, currency, exchange rate, bank account, clearing document reference, partial payment flag, and deduction/short-payment details. Supports cash application, deduction management, and DSO calculation. Sourced from SAP S/4HANA FI-AR and Oracle Cloud Receivables.' .

ind:ApInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ap Invoice' ;
    rdfs:comment 'Accounts payable master record representing the full trade payable lifecycle for raw materials, packaging, contract manufacturing, and indirect goods/services. Owns invoice receipt, three-way match verification, payment scheduling, payment execution, early payment discount capture, and clearing. Captures vendor invoice number, invoice date, posting date, due date, gross amount, tax, net amount, payment terms, currency, match status, payment method, payment date, payment amount, payment run ID, bank account reference, early discount taken, clearing document, and payment block details. The single source of truth for all payable balances, payment execution, DIO tracking, working capital optimization, and supplier payment management. Integrates with SAP S/4HANA MM-IV, FI-AP, and Oracle Cloud Payables.' .

ind:ApPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ap Payment' ;
    rdfs:comment 'Accounts payable payment record capturing outgoing payments to suppliers for raw materials, packaging, and services. Records payment date, payment method (ACH, wire, check, EDI 820), payment amount, currency, exchange rate, bank account, payment run ID, clearing document, early payment discount taken, and payment block release authorization. Supports cash flow management, supplier relationship management, and working capital optimization. Sourced from SAP S/4HANA FI-AP.' .

ind:CogsAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cogs Allocation' ;
    rdfs:comment 'Product costing and COGS allocation master for CPG manufacturing. Owns both standard cost estimates (planned) and actual cost allocations for finished goods, semi-finished goods, and raw materials. Captures cost component splits (raw material, packaging, direct labor, variable/fixed overhead, machine overhead, freight-in, depreciation), costing version, validity period, costing lot size, release status, plant, allocation date, fiscal period, standard vs actual cost, variance amount, variance category, and allocation method. The single source of truth for inventory valuation, SKU-level and brand-level gross margin analysis, manufacturing variance reporting, COGS decomposition, and make-vs-buy cost comparison. Sourced from SAP S/4HANA CO-PC (Product Costing).' .

ind:StandardCost rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Standard cost master record for finished goods, semi-finished goods, and raw materials used in CPG manufacturing. Stores the cost estimate per SKU/material including cost component split (raw material, packaging, direct labor, machine overhead, fixed overhead, freight-in), costing version, validity period, plant, costing lot size, and release status. The authoritative source for inventory valuation, COGS calculation, and manufacturing variance analysis. Sourced from SAP S/4HANA CO-PC.' .

ind:FinanceBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Finance Budget' ;
    rdfs:comment 'Financial budget record for the consumer goods enterprise covering annual, rolling, and zero-based budgets at both summary and line-item granularity. Captures budget version (original, revised, latest estimate), fiscal year, period, company code, cost center, profit center, GL account, cost element, product line, channel, planned quantity, planned amount in local and group currency, budget category (opex, capex, headcount), approval status, budget owner, and justification notes. Supports S&OP/IBP financial integration, variance-to-budget reporting, EBITDA bridge analysis, ZBB, and activity-based costing methodologies. Managed in SAP S/4HANA CO and Oracle Cloud Financials.' .

ind:FixedAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fixed Asset' ;
    rdfs:comment 'Fixed asset master and lifecycle record for capital assets owned by the consumer goods enterprise — manufacturing equipment, production lines, warehouse automation, vehicles, buildings, and IT infrastructure. Covers the full asset lifecycle: acquisition, capitalization, depreciation, transfer, revaluation, impairment, and disposal. Captures asset class, description, acquisition date/cost, useful life, depreciation method, accumulated depreciation, net book value, plant/location, responsible cost center, and all transaction events (transaction type, posting date, amount, document reference, originating business process). Supports capex tracking, depreciation run reconciliation, asset lifecycle audit trail, and SOX-compliant fixed asset management. Sourced from SAP S/4HANA FI-AA and Oracle Cloud Fixed Assets.' .

ind:IntercompanyTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Intercompany Transaction' ;
    rdfs:comment 'Intercompany financial transaction record capturing cross-entity postings between legal entities within the consumer goods corporate group. Covers intercompany sales of finished goods, cost allocations, management fee charges, royalty payments, intercompany loans, and dividend distributions. Stores sending company code, receiving company code, transaction type, posting date, amount, currency, transfer price, arm\'s-length validation flag, netting status, elimination flag, reconciliation reference, and matching status. Critical for consolidated financial reporting, transfer pricing compliance, intercompany elimination in group close, and regulatory documentation under OECD transfer pricing guidelines.' .

ind:RevenueRecognition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Revenue Recognition' ;
    rdfs:comment 'Revenue recognition event record capturing the timing and amount of revenue recognized under ASC 606 / IFRS 15 for consumer goods sales transactions. Stores performance obligation ID, contract reference, recognition date, recognition method (point-in-time vs over-time), recognized revenue amount, deferred revenue amount, variable consideration estimate (trade promotions, rebates, returns), constraint applied flag, and cumulative catch-up adjustment. Supports compliant revenue reporting and audit trail for complex CPG revenue arrangements.' .

ind:BankAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Bank Account' ;
    rdfs:comment 'Master reference table for bank_account. Referenced by bank_account_id.' .

ind:CompanyCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Master reference table for company_code. Referenced by company_code_id.' .

ind:Warehouse rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Warehouse' ;
    rdfs:comment 'Master reference table for warehouse. Referenced by warehouse_id.' .

ind:Vehicle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Vehicle' ;
    rdfs:comment 'Master reference table for vehicle. Referenced by vehicle_id.' .

ind:Equipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Equipment' ;
    rdfs:comment 'Master reference table for equipment. Referenced by equipment_id.' .

ind:Category rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Category' ;
    rdfs:comment 'Master reference table for category. Referenced by category_id.' .

ind:Material rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Material' ;
    rdfs:comment 'Master reference table for material. Referenced by material_id.' .

ind:Sample rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Sample' ;
    rdfs:comment 'Master reference table for sample. Referenced by sample_id.' .

ind:PlanningPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Planning Period' ;
    rdfs:comment 'Master reference table for planning_period. Referenced by planning_period_id.' .

ind:RecallLotScope rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Recall Lot Scope' ;
    rdfs:comment 'This association product represents the regulatory compliance artifact that enumerates exactly which lot/batch records are covered by each recall event, with per-lot recovery tracking. It captures the scope and recovery status of each recall at the lot level, replacing the denormalized affected_lot_batch_range STRING field on recall_event. Each record links one recall_event to one lot_batch and carries attributes — quantity recalled per lot, quantity recovered per lot, lot-level recall status, and recovery date — that exist only in the context of this specific recall-lot pairing. Required for FDA effectiveness checks and regulatory reporting obligations.. Existence Justification: In consumer goods regulatory operations, a single recall event explicitly covers multiple specific lot/batch numbers (e.g., Recall #2024-001 covers Lot A123, Lot B456, Lot C789), AND a single lot/batch can theoretically be implicated in multiple recall events over its lifecycle (e.g., a contamination recall and a labeling recall affecting overlapping lots). More critically, the business must track per-lot recovery status, quantities recalled per lot, and recovery dates — data that belongs neither to the recall event header nor to the lot master record alone. Regulatory bodies (FDA, CPSC) require manufacturers to report exactly which lot numbers are covered and the recovery status per lot, making this an operationally managed compliance artifact.' .

ind:SkuLaneAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Sku Lane Assignment' ;
    rdfs:comment 'This association product represents the operational assignment (sourcing rule) between a network_lane and a sku_planning_param. It captures which network lanes are valid sourcing options for a given SKU at a given planning node, along with the lane-specific planning parameters (priority, lead time, MOQ) that govern how the planning system uses each lane for that SKU. Each record links one network_lane to one sku_planning_param with attributes that exist only in the context of this SKU-lane sourcing relationship, and is actively managed during supply network design and S&OP reviews.. Existence Justification: In consumer goods supply chain planning, a network lane (source-destination pair) services many SKUs, and a single SKU may have multiple valid sourcing lanes with different priorities, lead times, and order quantities. This SKU-to-lane assignment is a recognized operational concept in planning systems like SAP IBP and is actively managed during supply network design reviews — planners create, update, and deactivate these assignments as sourcing strategies evolve. The relationship carries its own data (sourcing priority, effective dates, MOQ per lane) that belongs neither to the lane alone nor to the SKU planning parameters alone.' .

ind:SdsSubstanceComposition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Sds Substance Composition' ;
    rdfs:comment 'This association product represents the Hazardous Component Listing between a restricted_substance and an sds record. It captures the formal disclosure of a regulated substance within a specific Safety Data Sheet, as required by GHS Section 3 (Composition/Information on Ingredients), OSHA HazCom, and EU CLP. Each record links one restricted substance to one SDS and carries attributes that exist only in the context of that specific substance-SDS pairing: the concentration of the substance in that product formulation, any exposure limit overrides applicable to that combination, the SDS section where the substance is disclosed, and whether the substance is the primary hazard contributor for that SDS.. Existence Justification: In chemical safety management for consumer goods, a single restricted substance (e.g., formaldehyde, a phthalate) appears as a listed hazardous component in MULTIPLE Safety Data Sheets — one SDS per raw material, intermediate, or finished good that contains it. Conversely, a single SDS for a complex mixture (e.g., a fragrance blend or cleaning formulation) will list MULTIPLE restricted substances in its composition section (Section 3 of GHS SDS). Regulatory chemists actively manage this substance-SDS composition mapping as a formal business process — it is the \'Hazardous Component Listing\' or \'SDS Substance Composition\' record, with its own attributes (concentration in product, exposure limit overrides, section reference, hazard contribution flag) that belong to neither the substance master nor the SDS master alone.' .

# --- Attribute Properties ---
ind:shopperId rdf:type rdf:Property ;
    rdfs:label 'Shopper Id' ;
    rdfs:comment 'Unique surrogate identifier for every end consumer and shopper record in the Consumer Goods golden master. This is the anchor primary key for the entire consumer domain — all other consumer entities reference this record. Role: MASTER_PARTY.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shopper .

ind:householdId rdf:type rdf:Property ;
    rdfs:label 'Household Id' ;
    rdfs:comment 'An identifier linking this consumer to a household grouping. Multiple individual shoppers may share the same household_id, enabling household-level purchase analysis, co-habitation segmentation, and family-targeted promotions. Used in Nielsen IQ Consumer Panel household modeling.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'The channel through which the consumer was first acquired or registered. Supports marketing attribution, channel ROI analysis, and consumer journey analytics. Aligns with DTC, POS, and loyalty enrollment touchpoints. [ENUM-REF-CANDIDATE: dtc_web|dtc_mobile|retail_pos|loyalty_enrollment|social_media|event|referral|wholesale — promote to reference product]' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'The date on which the consumer was first acquired or registered in the system (yyyy-MM-dd). Used for cohort analysis, consumer tenure calculations, and lifecycle marketing programs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ageVerified rdf:type rdf:Property ;
    rdfs:label 'Age Verified' ;
    rdfs:comment 'Indicates whether the consumer has passed age verification for access to age-restricted products (e.g., alcohol, tobacco, certain health products). TRUE = age verified; FALSE = not verified. Required for regulatory compliance with FDA and CPSC age-restriction mandates.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:birthDate rdf:type rdf:Property ;
    rdfs:label 'Birth Date' ;
    rdfs:comment 'The consumer\'s date of birth in ISO 8601 format (yyyy-MM-dd). Used for age verification (e.g., age-restricted products), lifecycle segmentation, birthday loyalty rewards, and regulatory compliance.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ccpaSubject rdf:type rdf:Property ;
    rdfs:label 'Ccpa Subject' ;
    rdfs:comment 'Indicates whether this consumer is a California resident subject to CCPA protections. TRUE = CCPA applies; FALSE = not a CCPA subject. Drives opt-out of sale workflows, data deletion requests, and disclosure obligations.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cltvSegment rdf:type rdf:Property ;
    rdfs:label 'Cltv Segment' ;
    rdfs:comment 'The consumer\'s current CLTV (Customer Lifetime Value) segment classification derived from purchase history and predictive modeling. Used for resource allocation in marketing, personalization prioritization, and retention investment decisions. Segment label, not a calculated metric.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'The exact date and time (ISO 8601 with timezone) when the consumer last provided or updated their privacy consent. Provides the auditable consent record required by GDPR Article 7 and CCPA. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'The version identifier of the privacy policy and consent notice that the consumer accepted (e.g., \'v2.3\', \'2024-01\'). Used to track consent currency and trigger re-consent workflows when policy versions are updated.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerType rdf:type rdf:Property ;
    rdfs:label 'Consumer Type' ;
    rdfs:comment 'Categorical classification of the shopper record distinguishing individual consumers, household accounts, small business buyers, enrolled loyalty program members, and guest/anonymous shoppers. Drives CRM segmentation and personalization strategy.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'The consumer\'s country of residence in ISO 3166-1 alpha-3 format (e.g., \'USA\', \'GBR\', \'DEU\'). Determines applicable regulatory framework (GDPR for EU, CCPA for California), tax jurisdiction, and localized product availability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The exact date and time (ISO 8601 with timezone) when this shopper record was first created in the Consumer Goods data platform. Serves as the authoritative audit trail for record creation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the consumer has consented to sharing their personal data with third-party partners (e.g., retail partners, market research firms such as Nielsen IQ). TRUE = consented; FALSE = not consented. Critical for GDPR Article 6 lawful basis and CCPA opt-out compliance.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayName rdf:type rdf:Property ;
    rdfs:label 'Display Name' ;
    rdfs:comment 'The consumer\'s preferred display name or alias used in digital channels, loyalty portals, and personalized marketing communications. May differ from legal name.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Indicates whether the consumer has provided explicit opt-in consent to receive email marketing communications. TRUE = consented; FALSE = not consented or withdrawn. Mandatory suppression flag for GDPR/CCPA compliance in all outbound email campaigns.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'The consumer\'s legal family name (surname) as captured at registration or identity verification. Combined with given_name to form the full legal identity for CRM, personalization, and regulatory compliance.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprSubject rdf:type rdf:Property ;
    rdfs:label 'Gdpr Subject' ;
    rdfs:comment 'Indicates whether this consumer is a GDPR data subject (i.e., located in the EU/EEA and subject to GDPR protections). TRUE = GDPR applies; FALSE = not a GDPR subject. Drives data processing lawful basis checks, right-to-erasure workflows, and data portability requests.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'The consumer\'s self-reported gender identity. Used for consumer segmentation, personalized product recommendations, and inclusive marketing. Collected with explicit consent per GDPR/CCPA.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:givenName rdf:type rdf:Property ;
    rdfs:label 'Given Name' ;
    rdfs:comment 'The consumer\'s legal given name (first name) as captured at registration or identity verification. Used for personalized communications, CRM, and regulatory subject identification under GDPR/CCPA.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Date' ;
    rdfs:comment 'The date on which the consumer\'s identity was most recently verified (yyyy-MM-dd). Used to assess verification recency and trigger re-verification workflows for high-risk transactions or regulatory audits.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identityVerified rdf:type rdf:Property ;
    rdfs:label 'Identity Verified' ;
    rdfs:comment 'Indicates whether the consumer\'s identity has been formally verified through an identity verification process (e.g., email confirmation, document verification, phone OTP). TRUE = verified; FALSE = unverified. Affects eligibility for high-value loyalty redemptions and DTC account features.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'The date of the consumer\'s most recent confirmed purchase transaction across any channel (DTC, retail POS, e-commerce). Used for recency scoring in RFM (Recency, Frequency, Monetary) analysis, churn prediction, and re-engagement campaign triggers.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the consumer record in the lifecycle. \'active\' = engaged consumer; \'inactive\' = no activity within defined period; \'opted_out\' = consumer has withdrawn consent and must not be contacted; \'suspended\' = account temporarily restricted; \'pending_verification\' = identity not yet confirmed. Drives GDPR/CCPA suppression logic.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrollment Date' ;
    rdfs:comment 'The date the consumer formally enrolled in the loyalty program (yyyy-MM-dd). Used to calculate loyalty tenure, anniversary rewards, and cohort-based loyalty analytics.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Balance' ;
    rdfs:comment 'The current redeemable loyalty points balance held by the consumer. This is the raw operational balance as recorded in the loyalty system — not a calculated aggregate. Used for redemption eligibility checks and consumer-facing balance display.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyTier rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier' ;
    rdfs:comment 'The consumer\'s current tier within the loyalty program (e.g., Bronze, Silver, Gold, Platinum). Determines benefit entitlements, promotional eligibility, and personalized offer thresholds. Recalculated periodically based on purchase activity.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'The most recently recorded Net Promoter Score (NPS) for this consumer, on a scale of 0–10. NPS is the industry-standard metric for measuring consumer loyalty and likelihood to recommend. Supports consumer satisfaction analytics and brand health reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'The date on which the most recent NPS survey response was recorded for this consumer. Used to assess recency of satisfaction data and trigger re-survey workflows.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'The consumer\'s residential postal or ZIP code. Used for geographic segmentation, regional marketing campaigns, distribution territory assignment, and retail proximity analysis (OSA, planogram relevance).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'The consumer\'s preferred transaction currency in ISO 4217 three-letter code (e.g., \'USD\', \'EUR\', \'GBP\'). Used for DTC pricing display, loyalty point valuation, and cross-border e-commerce personalization.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'The consumer\'s preferred communication language in IETF BCP 47 format (e.g., \'en-US\', \'fr-FR\', \'es-MX\'). Drives localization of marketing communications, product labels, and digital experience personalization.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredStoreBanner rdf:type rdf:Property ;
    rdfs:label 'Preferred Store Banner' ;
    rdfs:comment 'The consumer\'s self-reported or behaviorally-inferred preferred retail store banner or chain (e.g., \'Walmart\', \'Target\', \'Kroger\'). Used for retail execution targeting, trade promotion personalization, and channel affinity analytics in Salesforce Consumer Goods Cloud.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'The primary email address used for all consumer communications, loyalty program enrollment, DTC order confirmations, and digital marketing. Serves as the principal digital identity key in CRM and Salesforce Consumer Goods Cloud.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'The consumer\'s primary contact phone number in E.164 international format. Used for SMS marketing, two-factor authentication, consumer care, and DTC order notifications.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationOptIn rdf:type rdf:Property ;
    rdfs:label 'Push Notification Opt In' ;
    rdfs:comment 'Indicates whether the consumer has opted in to receive push notifications via the brand\'s mobile application. TRUE = opted in; FALSE = opted out or not set. Drives mobile engagement campaign eligibility.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Registration Source Url' ;
    rdfs:comment 'The URL or digital touchpoint from which the consumer completed their registration (e.g., brand website landing page, DTC checkout, loyalty sign-up page). Supports digital marketing attribution and campaign source tracking.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptIn rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In' ;
    rdfs:comment 'Indicates whether the consumer has provided explicit opt-in consent to receive SMS/text marketing communications. TRUE = consented; FALSE = not consented or withdrawn. Required for TCPA compliance in the US and equivalent regulations globally.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'The originating operational system from which this consumer record was sourced or first created (e.g., Salesforce Consumer Goods Cloud, SAP S/4HANA SD, DTC web platform). Supports data lineage, master data management deduplication, and system-of-record governance. [ENUM-REF-CANDIDATE: salesforce_cgc|sap_s4hana|oracle_erp|dtc_web|dtc_mobile|loyalty_platform|pos_system — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemConsumerRef rdf:type rdf:Property ;
    rdfs:label 'Source System Consumer Ref' ;
    rdfs:comment 'The consumer\'s unique identifier as recorded in the originating source system (e.g., SAP Business Partner ID, Salesforce Contact ID, DTC platform user ID). Enables cross-system reconciliation, MDM golden record matching, and audit traceability back to the system of record.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'The exact date and time (ISO 8601 with timezone) when this shopper record was most recently modified. Used for change data capture (CDC), incremental ETL processing, and audit compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Foreign key linking to consumer.address. Business justification: A household has a physical address (dwelling location) that is the authoritative geographic reference for the household unit. The address table is the SSOT for physical addresses in the consumer domai' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:mergedFromHouseholdId rdf:type rdf:Property ;
    rdfs:label 'Merged From Household Id' ;
    rdfs:comment 'Reference to the source household record that was merged into this household during deduplication or household consolidation. Null if no merge has occurred. Supports data lineage and audit trails.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:brandAffinityFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Affinity Flag' ;
    rdfs:comment 'Indicates whether the household has demonstrated strong brand loyalty to the company\'s portfolio based on repeat purchase patterns and SOV (Share of Voice) analysis. Used for brand marketing investment decisions.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccpaOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Flag' ;
    rdfs:comment 'Indicates whether the household has exercised the right to opt out of the sale of personal information under CCPA (California Consumer Privacy Act). Mandatory compliance field for California-resident households.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:childrenPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Children Present Flag' ;
    rdfs:comment 'Indicates whether children under 18 are present in the household. Key trigger for cross-sell targeting of baby, child health, and family-oriented CPG/FMCG product categories.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cltvBand rdf:type rdf:Property ;
    rdfs:label 'Cltv Band' ;
    rdfs:comment 'Categorical CLTV (Customer Lifetime Value) band assigned to the household based on historical purchase behavior and predictive modeling. Used for investment prioritization in trade promotion and personalization.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to any consent or privacy preference for the household. Critical for GDPR/CCPA audit trails and demonstrating lawful basis for data processing.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Originating system or channel from which the household record was first created or last enriched. Used for data lineage, quality scoring, and source system reconciliation in the lakehouse. [ENUM-REF-CANDIDATE: crm|loyalty_program|ecommerce|panel|pos|dtc|manual — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalEngagementFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Engagement Flag' ;
    rdfs:comment 'Indicates whether the household actively engages with the brand through digital channels (e-commerce, mobile app, social media). Used for DTC (Direct to Consumer) channel strategy and omnichannel personalization.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'Date on which the household was dissolved, merged, or deactivated. Null for active households. Used for lifecycle reporting and GDPR/CCPA data retention compliance.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dwellingType rdf:type rdf:Property ;
    rdfs:label 'Dwelling Type' ;
    rdfs:comment 'Type of residential dwelling occupied by the household. Used for product category targeting (e.g., home care, cleaning products) and basket size normalization in CPG analytics.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedSize rdf:type rdf:Property ;
    rdfs:label 'Estimated Size' ;
    rdfs:comment 'Estimated number of individuals residing in the household. Used for basket size normalization, per-capita consumption analysis, and product volume forecasting in S&OP (Sales and Operations Planning).' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'Date on which the household record was first established in the system, representing when the household unit was recognized as a distinct entity for loyalty and analytics purposes.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the household has provided valid consent for data processing under GDPR (General Data Protection Regulation). Mandatory for EU-resident households before any marketing or analytics processing.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Broad geographic region of the household\'s residence (e.g., Northeast, Southeast, Midwest, West, Southwest). Used for regional demand planning and distribution channel management.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdCode rdf:type rdf:Property ;
    rdfs:label 'Household Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the household, used in CRM, loyalty, and DTC channel communications. Distinct from the surrogate primary key.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdName rdf:type rdf:Property ;
    rdfs:label 'Household Name' ;
    rdfs:comment 'Human-readable label for the household, typically the primary shopper\'s surname or a family name used for display in CRM and loyalty program communications.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdStatus rdf:type rdf:Property ;
    rdfs:label 'Household Status' ;
    rdfs:comment 'Current lifecycle state of the household record. \'merged\' indicates consolidation with another household; \'dissolved\' indicates the household no longer exists as a unit.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdType rdf:type rdf:Property ;
    rdfs:label 'Household Type' ;
    rdfs:comment 'Categorical classification of the household composition used for segmentation and cross-sell targeting in CPG/FMCG analytics. [ENUM-REF-CANDIDATE: single|couple|family|multi_generational|shared_living|other — promote to reference product if values expand]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBand rdf:type rdf:Property ;
    rdfs:label 'Income Band' ;
    rdfs:comment 'Estimated annual household income bracket used for consumer segmentation, RSP (Recommended Selling Price) sensitivity analysis, and premium product targeting. Derived from third-party panel data or self-reported.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the household record. Used for change data capture (CDC) in the Databricks lakehouse Silver layer and data freshness monitoring.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lifeStage rdf:type rdf:Property ;
    rdfs:label 'Life Stage' ;
    rdfs:comment 'Life stage classification of the household used for targeted marketing and NPD (New Product Development) insights (e.g., young_single, young_couple_no_children, family_with_young_children, family_with_teens, empty_nester, retired). Enables cross-sell triggers such as recommending baby products when life stage transitions. [ENUM-REF-CANDIDATE: young_single|young_couple_no_children|family_with_young_children|family_with_teens|empty_nester|retired|other — promote to reference product]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'Strategic consumer market segment assigned to the household for brand marketing and consumer engagement programs (e.g., health_conscious, value_seeker, premium_buyer, eco_friendly). [ENUM-REF-CANDIDATE: health_conscious|value_seeker|premium_buyer|eco_friendly|convenience_driven|brand_loyal — promote to reference product]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Flag' ;
    rdfs:comment 'Indicates whether the household has opted in to receive marketing communications (email, SMS, push notifications) from the brand. Governs eligibility for trade promotion and consumer engagement campaigns.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:panelMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Panel Member Flag' ;
    rdfs:comment 'Indicates whether the household is an active member of a consumer research panel (e.g., Nielsen IQ Consumer Panel). Panel households provide purchase diary data used for market intelligence and SOM (Share of Market) analysis.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:petOwnerFlag rdf:type rdf:Property ;
    rdfs:label 'Pet Owner Flag' ;
    rdfs:comment 'Indicates whether the household owns pets. Used for targeted marketing of pet care product categories and cross-sell recommendations within the CPG/FMCG portfolio.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryChannel rdf:type rdf:Property ;
    rdfs:label 'Primary Channel' ;
    rdfs:comment 'The dominant channel through which the household makes purchases. Used for DTC (Direct to Consumer) strategy, channel mix analysis, and trade promotion targeting.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRetailerBanner rdf:type rdf:Property ;
    rdfs:label 'Primary Retailer Banner' ;
    rdfs:comment 'The retail banner or chain where the household conducts the majority of its grocery or consumer goods shopping (e.g., Walmart, Target, Kroger). Used for OSA (On Shelf Availability) and POG (Planogram) analytics.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelBuyerFlag rdf:type rdf:Property ;
    rdfs:label 'Private Label Buyer Flag' ;
    rdfs:comment 'Indicates whether the household regularly purchases private label or store-brand products in addition to or instead of branded CPG products. Used for competitive analysis and brand switching risk assessment.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchaseFrequencyBand rdf:type rdf:Property ;
    rdfs:label 'Purchase Frequency Band' ;
    rdfs:comment 'Categorical band representing how frequently the household makes purchases across CPG/FMCG categories. Derived from POS (Point of Sale) transaction history and used for demand sensing and replenishment planning.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenureType rdf:type rdf:Property ;
    rdfs:label 'Tenure Type' ;
    rdfs:comment 'Indicates whether the household owns or rents their residence. Used for home improvement and home care product category targeting and consumer segmentation.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressSource rdf:type rdf:Property ;
    rdfs:label 'Address Source' ;
    rdfs:comment 'The originating channel or system through which this address was captured. Supports data lineage, source quality scoring, and GDPR/CCPA consent audit trails. [ENUM-REF-CANDIDATE: crm|dtc_checkout|loyalty_enrollment|call_center|mobile_app|web_portal|third_party|manual_entry — promote to reference product]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active addresses are eligible for order fulfillment and marketing. Inactive addresses are retained for historical reporting. Deleted status supports GDPR right-to-erasure soft-delete workflows.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the address by its business purpose. Billing addresses are used for invoicing and financial compliance; shipping addresses drive DTC order fulfillment and last-mile logistics; home and work addresses support personalized marketing and consumer segmentation.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierRoute rdf:type rdf:Property ;
    rdfs:label 'Carrier Route' ;
    rdfs:comment 'USPS carrier route code assigned to this address (e.g., C001, R001, B001, H001). Used for direct mail presort discounts, delivery sequence optimization, and postal cost modeling in consumer marketing programs.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:censusTract rdf:type rdf:Property ;
    rdfs:label 'Census Tract' ;
    rdfs:comment 'U.S. Census Bureau census tract code for the address location. Enables demographic overlay analysis, market penetration reporting by socioeconomic segment, and trade area planning for consumer goods distribution.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality of the consumer\'s address. Used for geographic segmentation, regional marketing campaigns, distribution zone assignment, and regulatory data residency tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentCaptured rdf:type rdf:Property ;
    rdfs:label 'Consent Captured' ;
    rdfs:comment 'Indicates whether explicit consumer consent was obtained for storing and processing this address record under applicable privacy regulations (GDPR/CCPA). True indicates consent is on file; False requires consent collection before marketing use.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date on which the consumer provided consent for storage and processing of this address record. Required for GDPR Article 7 compliance documentation and CCPA opt-in audit trails.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataResidencyRegion rdf:type rdf:Property ;
    rdfs:label 'Data Residency Region' ;
    rdfs:comment 'Geographic data residency classification for this address record, indicating the regulatory jurisdiction governing data storage and processing. Drives GDPR (EU), CCPA (US/CA), and other regional privacy law compliance for data localization requirements.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverabilityScore rdf:type rdf:Property ;
    rdfs:label 'Deliverability Score' ;
    rdfs:comment 'Numeric score (0.00–100.00) representing the likelihood that a physical shipment or direct mail piece will be successfully delivered to this address. Derived from address validation provider output. Supports carrier selection and DTC fulfillment risk management.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmaCode rdf:type rdf:Property ;
    rdfs:label 'Dma Code' ;
    rdfs:comment 'Nielsen Designated Market Area (DMA) code for the address location. Used for media planning, Share of Voice (SOV) analysis, and regional brand marketing investment allocation in consumer goods trade promotion programs.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotMail rdf:type rdf:Property ;
    rdfs:label 'Do Not Mail' ;
    rdfs:comment 'Indicates whether the consumer has opted out of physical direct mail marketing to this address. When True, this address must be suppressed from direct mail campaign execution lists. Supports GDPR right-to-object and CCPA opt-out compliance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dpvConfirmation rdf:type rdf:Property ;
    rdfs:label 'Dpv Confirmation' ;
    rdfs:comment 'USPS Delivery Point Validation confirmation code indicating the deliverability of the address. Y=Confirmed deliverable, S=Confirmed deliverable (secondary info missing), D=Confirmed deliverable (secondary info present but unneeded), N=Not confirmed. Critical for DTC fulfillment and direct mail campaigns.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date from which this address record is considered valid and active for business use. Supports bi-temporal data modeling, address history tracking, and GDPR right-to-erasure compliance by enabling point-in-time address reconstruction.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date after which this address record is no longer valid for business use. Null indicates an open-ended active address. Used for address lifecycle management, historical reporting, and GDPR data minimization compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'Classification of the address format to guide formatting, validation, and carrier routing logic. PO Box addresses may not be eligible for certain DTC carriers; military addresses (APO/FPO/DPO) require specific handling; rural route addresses may have extended delivery windows.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodingAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocoding Accuracy' ;
    rdfs:comment 'Precision level of the geocoded latitude/longitude coordinates for this address. Rooftop indicates exact parcel-level geocoding; range_interpolated indicates interpolation between street numbers; geometric_center indicates centroid of a polygon. Impacts reliability of proximity-based analytics.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultBilling rdf:type rdf:Property ;
    rdfs:label 'Is Default Billing' ;
    rdfs:comment 'Indicates whether this address is the consumer\'s default billing address for payment processing and invoice generation. Used in DTC checkout flows and financial compliance reporting.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultShipping rdf:type rdf:Property ;
    rdfs:label 'Is Default Shipping' ;
    rdfs:comment 'Indicates whether this address is the consumer\'s default shipping destination for DTC orders. Distinct from is_primary as a consumer may have a primary home address but a different default shipping address (e.g., workplace).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this is the consumer\'s primary address record for the given address type. When True, this address is used as the default for order fulfillment, marketing communications, and regulatory correspondence.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the consumer\'s address in decimal degrees (WGS84 datum). Enables geocoded proximity analysis, delivery zone optimization, and location-based personalized marketing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including house/building number and street name. Core component of the consumer\'s physical location used for DTC order fulfillment, direct mail marketing, and GDPR/CCPA data residency compliance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for apartment, suite, unit, floor, or building designations. Supplements address_line_1 to ensure complete and accurate delivery routing for DTC shipments.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line 3' ;
    rdfs:comment 'Tertiary address line for additional location details such as neighborhood, district, or care-of designations. Used in international address formats where three address lines are required.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the consumer\'s address in decimal degrees (WGS84 datum). Used alongside latitude for geocoded proximity analysis, store locator features, and last-mile delivery optimization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plus4Code rdf:type rdf:Property ;
    rdfs:label 'Plus4 Code' ;
    rdfs:comment 'The four-digit USPS ZIP+4 extension code that narrows delivery to a specific block face or building. Enables postal presort discounts for direct mail campaigns and improves delivery precision for DTC shipments within the United States.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialIndicator rdf:type rdf:Property ;
    rdfs:label 'Residential Indicator' ;
    rdfs:comment 'Classification of the address as residential or commercial. Impacts carrier surcharge calculations (UPS/FedEx residential delivery fees), marketing segmentation, and DTC fulfillment cost modeling.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Code' ;
    rdfs:comment 'Internal sales territory or region code assigned to this address based on geographic boundaries. Used for Sales Force Automation (SFA) territory assignment, trade promotion planning, and regional sales performance reporting.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'The native record identifier from the originating operational system of record (e.g., Salesforce Consumer Goods Cloud Contact Address ID, SAP S/4HANA Business Partner Address GUID). Enables cross-system reconciliation and data lineage tracing in the Silver Layer.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemName rdf:type rdf:Property ;
    rdfs:label 'Source System Name' ;
    rdfs:comment 'Name of the operational system of record from which this address record originated. Supports data lineage, master data management (MDM) conflict resolution, and Silver Layer data quality governance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardizedAddress rdf:type rdf:Property ;
    rdfs:label 'Standardized Address' ;
    rdfs:comment 'The full address formatted as a single standardized string per USPS/UPU postal standards after address validation and normalization (e.g., \'123 MAIN ST APT 4B, CHICAGO IL 60601-1234\'). Used as the canonical address for carrier label generation and deduplication.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region of the consumer\'s address using ISO 3166-2 subdivision codes (e.g., US-CA, CA-ON). Supports tax jurisdiction determination, regional compliance, and territory-based sales reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA time zone identifier for the address location (e.g., America/New_York, Europe/London). Used for scheduling personalized marketing communications at optimal local times and for regulatory compliance with time-sensitive consumer notifications.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationProvider rdf:type rdf:Property ;
    rdfs:label 'Validation Provider' ;
    rdfs:comment 'Name of the third-party address validation service used to verify this address (e.g., USPS CASS, SmartyStreets, Loqate, Google Maps API). Supports audit trails for data quality governance and vendor performance tracking.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current validation state of the address record as determined by address verification services (e.g., USPS CASS, SmartyStreets, Loqate). Validated addresses reduce failed DTC deliveries and return-to-sender costs. Failed addresses require consumer outreach before order fulfillment.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when the address was last validated by the address verification service. Used to determine if re-validation is needed based on data freshness policies and to support data quality SLA reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyAccountId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Account Id' ;
    rdfs:comment 'Unique surrogate identifier for the loyalty program account record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyAccount .

ind:productBrandId rdf:type rdf:Property ;
    rdfs:label 'Product Brand Id' ;
    rdfs:comment 'Foreign key linking to product.product_brand. Business justification: In CPG, loyalty programs are frequently brand-specific (e.g., Pampers Club, Oral-B Genius program). loyalty_account has no product domain link. This FK enables brand-level loyalty KPI reporting (enrol' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductBrand .

ind:referralAccountId rdf:type rdf:Property ;
    rdfs:label 'Referral Account Id' ;
    rdfs:comment 'Loyalty account ID of the existing member who referred this consumer to the program. Used for referral reward attribution, viral growth tracking, and network-effect analysis in consumer retention programs.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyAccount .

ind:retailStoreId rdf:type rdf:Property ;
    rdfs:label 'Retail Store Id' ;
    rdfs:comment 'Reference to the consumer\'s preferred or most frequently visited retail store location. Used for store-level loyalty analytics, On Shelf Availability (OSA) correlation, and localized promotion targeting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailStore .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally visible, human-readable membership number assigned to the consumer at enrollment. Printed on loyalty cards, referenced in consumer communications, and used for in-store identification. Serves as the BUSINESS_IDENTIFIER for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle state of the loyalty account. \'active\' = fully operational; \'suspended\' = temporarily restricted (e.g., fraud review); \'closed\' = permanently deactivated; \'pending\' = enrollment not yet confirmed; \'frozen\' = points locked pending investigation. Serves as the LIFECYCLE_STATUS for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the loyalty account indicating whether it belongs to an individual consumer, a household unit, a small business buyer, or a coalition partner program. Drives eligibility rules and benefit structures.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'Consumer\'s preferred channel for receiving loyalty program communications (e.g., points balance updates, tier change notifications, promotional offers). Drives outbound communication channel selection in CRM and marketing automation.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDataSharing rdf:type rdf:Property ;
    rdfs:label 'Consent Data Sharing' ;
    rdfs:comment 'Indicates whether the consumer has consented to sharing their loyalty data with third-party partners (e.g., retail partners, coalition program members). Required for GDPR and CCPA compliance. True = consented; False = not consented.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentMarketing rdf:type rdf:Property ;
    rdfs:label 'Consent Marketing' ;
    rdfs:comment 'Indicates whether the consumer has provided explicit opt-in consent to receive marketing communications related to the loyalty program. Required for GDPR Article 6 lawful basis and CCPA compliance. True = consented; False = not consented.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the consumer enrolled in the loyalty program (e.g., web, mobile app, in-store, call center, partner, Direct-to-Consumer (DTC) platform). Used for channel attribution and acquisition cost analysis.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Calendar date on which the consumer formally enrolled in the loyalty program. Used to calculate membership tenure, anniversary rewards, and cohort-based retention analytics. Serves as EFFECTIVE_FROM for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentSourceCode rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source Code' ;
    rdfs:comment 'Campaign or promotion source code associated with the consumer\'s enrollment event (e.g., a Trade Promotion Management (TPM) campaign code, QR code identifier, or referral code). Used for acquisition attribution and Trade Promotion Optimization (TPO) ROI analysis.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Indicates whether this loyalty account has been flagged for suspected fraudulent activity (e.g., points manipulation, account takeover, synthetic identity). True = flagged for review; False = no fraud concern. Triggers account suspension workflow.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudReviewDate rdf:type rdf:Property ;
    rdfs:label 'Fraud Review Date' ;
    rdfs:comment 'Date on which the most recent fraud review was conducted or scheduled for this account. Nullable if no fraud review has occurred. Used by the fraud operations team to track investigation timelines.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code (optionally with ISO 3166-1 country subtag) representing the consumer\'s preferred language for loyalty program communications (e.g., \'en\', \'fr\', \'es-MX\'). Supports multilingual global loyalty programs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent qualifying activity (purchase, redemption, or engagement event) on this loyalty account. Used to determine account dormancy, trigger re-engagement campaigns, and apply activity-based points expiry policies.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastEarnDate rdf:type rdf:Property ;
    rdfs:label 'Last Earn Date' ;
    rdfs:comment 'Date of the most recent points earn event on this account. Used to assess earn recency for RFM (Recency, Frequency, Monetary) segmentation and to trigger earn-reminder communications.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRedemptionDate rdf:type rdf:Property ;
    rdfs:label 'Last Redemption Date' ;
    rdfs:comment 'Date of the most recent points redemption event on this account. Used to assess redemption engagement, identify high-value redeemers, and support personalized redemption offer targeting.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimePointsEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Earned' ;
    rdfs:comment 'Cumulative total of all points ever earned on this account since enrollment, including base earn, bonus earn, and promotional earn events. Never decremented by redemptions or expirations. Used for Customer Lifetime Value (CLTV) calculation and tier qualification history.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsExpired rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Expired' ;
    rdfs:comment 'Cumulative total of all points that have expired on this account due to inactivity or program rules. Used for points liability release reporting in finance and consumer re-engagement analysis.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Redeemed' ;
    rdfs:comment 'Cumulative total of all points ever redeemed on this account since enrollment. Used for redemption rate analysis, points liability reconciliation, and CLTV modeling.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:membershipTier rdf:type rdf:Property ;
    rdfs:label 'Membership Tier' ;
    rdfs:comment 'Current loyalty tier of the account reflecting the consumer\'s engagement and spend level (e.g., Standard, Silver, Gold, Platinum, Elite). Determines benefit multipliers, exclusive offers, and service levels. Reviewed periodically against tier_qualification_spend.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Date' ;
    rdfs:comment 'Date on which the consumer formally opted out of the loyalty program or withdrew consent for data processing. Nullable if the consumer has not opted out. Required for GDPR right-to-erasure and CCPA opt-out compliance tracking.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pointsBalance rdf:type rdf:Property ;
    rdfs:label 'Points Balance' ;
    rdfs:comment 'Current redeemable points balance on the loyalty account as of the last transaction processing. Represents the net of all earned, redeemed, adjusted, and expired points. Used for consumer-facing balance display and finance points liability reporting.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Points Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the monetary currency in which tier_qualification_spend and redemption values are denominated (e.g., USD, EUR, GBP). Supports multi-currency global loyalty programs.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsExpiryPolicy rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Policy' ;
    rdfs:comment 'Policy governing when unredeemed points on this account expire. Options include rolling 12-month inactivity, annual calendar expiry, never-expire, program-end expiry, or activity-based reset. Drives points liability forecasting and consumer communication triggers.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredRedemptionType rdf:type rdf:Property ;
    rdfs:label 'Preferred Redemption Type' ;
    rdfs:comment 'Consumer\'s stated or inferred preferred method of redeeming loyalty points. Used for personalized redemption offer targeting and program design optimization. [ENUM-REF-CANDIDATE: discount|free_product|gift_card|charity|cashback|experience|travel|merchandise — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousTier rdf:type rdf:Property ;
    rdfs:label 'Previous Tier' ;
    rdfs:comment 'The membership tier held by the consumer immediately before the most recent tier change. Used for tier transition analysis, win-back campaigns, and understanding tier migration patterns.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Tier Effective Date' ;
    rdfs:comment 'Date on which the current membership tier became effective. Used to calculate tier tenure, assess tier stability, and trigger tier-anniversary benefits.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualificationSpend rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Spend' ;
    rdfs:comment 'Cumulative qualifying purchase spend (in program currency) accumulated within the current tier review period. Compared against tier thresholds to determine tier upgrade, maintenance, or downgrade at the next tier review date.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierReviewDate rdf:type rdf:Property ;
    rdfs:label 'Tier Review Date' ;
    rdfs:comment 'Scheduled date on which the consumer\'s membership tier will be evaluated against tier_qualification_spend thresholds for potential upgrade, maintenance, or downgrade. Drives proactive consumer engagement campaigns before review.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Transaction Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for each loyalty points movement event. Serves as the primary key for the loyalty_transaction data product and enables precise audit trail reconciliation of all points currency activity.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Loyalty points liability is a financial obligation recorded per legal entity (company code) for IFRS/GAAP balance sheet disclosure. Consumer goods multinationals must attribute points liability to the' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:consumerOfferId rdf:type rdf:Property ;
    rdfs:label 'Consumer Offer Id' ;
    rdfs:comment 'Foreign key linking to promotion.consumer_offer. Business justification: Offer-triggered loyalty earn/redemption: consumer offers frequently include bonus loyalty point mechanics (e.g., \'2x points with this offer\'). Linking loyalty_transaction to consumer_offer enables off' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsumerOffer .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Loyalty program costs (points liability accruals, bonus awards) are allocated to cost centers for marketing spend reporting and brand controller budgets. loyalty_transaction already has gl_account_id ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:eventId rdf:type rdf:Property ;
    rdfs:label 'Event Id' ;
    rdfs:comment 'Reference to the Trade Promotion Management (TPM) promotion or loyalty campaign that triggered a bonus points award. Null when the transaction is not promotion-driven.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Event .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Required for accounting loyalty point expense; loyalty_transaction must post expense to a GL account for financial statements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Reference to the originating sales order or DTC purchase that triggered an earn or redemption event. Null for non-purchase-triggered transactions such as birthday bonuses, referral awards, or manual adjustments.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Loyalty transactions are attributed to profit centers for brand/channel P&L reporting. Consumer goods companies track loyalty program ROI and points liability by profit center for brand contribution m' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:reversalReferenceLoyaltyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Loyalty Transaction Id' ;
    rdfs:comment 'For reversal-type transactions, the loyalty_transaction_id of the original transaction being reversed. Enables bidirectional audit trail linking between original and reversal entries for points reconciliation.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyTransaction .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Reference to the specific SKU (Stock Keeping Unit) purchased or redeemed in this transaction. Populated for purchase-triggered earn events and product-reward redemptions. Enables product-level loyalty attribution and NPD performance analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:adjustmentNotes rdf:type rdf:Property ;
    rdfs:label 'Adjustment Notes' ;
    rdfs:comment 'Free-text narrative entered by a customer service agent or system process explaining the rationale for a manual points adjustment or reversal. Supports audit review and consumer dispute resolution.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Standardized code identifying the business reason for manual point adjustments or reversals (e.g., GOODWILL, DATA_CORRECTION, FRAUD_REVERSAL, SYSTEM_ERROR, PROMOTION_CORRECTION). Populated only for adjust and reversal transaction types. [ENUM-REF-CANDIDATE: GOODWILL|DATA_CORRECTION|FRAUD_REVERSAL|SYSTEM_ERROR|PROMOTION_CORRECTION|COMPLAINT_RESOLUTION — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusMultiplier rdf:type rdf:Property ;
    rdfs:label 'Bonus Multiplier' ;
    rdfs:comment 'The multiplier applied to the base earn rate for bonus transactions (e.g., 2.0 for double points, 1.5 for 50% bonus). Null for non-bonus transactions. Used to decompose total points awarded into base and bonus components for TPM ROI analysis.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The consumer engagement channel through which the triggering event occurred: ecommerce (third-party online), mobile_app (brand app), retail_store (physical POS), dtc_website (Direct-to-Consumer website), call_centre (agent-assisted), or kiosk (in-store self-service). Supports omnichannel loyalty analytics and channel attribution reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVerified rdf:type rdf:Property ;
    rdfs:label 'Consent Verified' ;
    rdfs:comment 'Indicates whether the consumer\'s active consent for loyalty program participation and data processing was verified at the time of this transaction. Supports GDPR Article 7 and CCPA consent audit requirements.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the monetary_value field (e.g., USD, EUR, GBP). Supports multi-currency loyalty programs operating across international markets.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionFlag rdf:type rdf:Property ;
    rdfs:label 'Data Retention Flag' ;
    rdfs:comment 'Indicates whether this transaction record is subject to a data retention hold, preventing deletion or anonymization beyond the standard retention period. Set to True for records under legal hold, active fraud investigation, or regulatory audit. Supports GDPR right-to-erasure compliance.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earnRate rdf:type rdf:Property ;
    rdfs:label 'Earn Rate' ;
    rdfs:comment 'The points-per-currency-unit rate applied to calculate the points_amount for earn transactions (e.g., 1.5 points per USD spent). Captures the rate in effect at the time of the transaction for historical accuracy and program performance analysis.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Review Status' ;
    rdfs:comment 'The outcome of the fraud review process for transactions flagged by the fraud detection system: not_reviewed (default), under_review (investigation in progress), cleared (confirmed legitimate), or confirmed_fraud (fraudulent transaction confirmed and reversed).' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBonusTransaction rdf:type rdf:Property ;
    rdfs:label 'Is Bonus Transaction' ;
    rdfs:comment 'Indicates whether this earn transaction includes a bonus points multiplier applied on top of the base earn rate (e.g., double-points promotion, birthday bonus, new member bonus). Enables separation of base earn from promotional bonus in program cost analysis.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monetaryValue rdf:type rdf:Property ;
    rdfs:label 'Monetary Value' ;
    rdfs:comment 'The monetary equivalent value of the points moved in this transaction, expressed in the program\'s base currency. Used for points liability valuation on the balance sheet and for calculating the cost of loyalty rewards in COGS reporting.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsAmount rdf:type rdf:Property ;
    rdfs:label 'Points Amount' ;
    rdfs:comment 'The absolute number of loyalty points moved in this transaction. Always stored as a positive value regardless of direction; the transaction_type field determines whether points are added or subtracted from the account balance. Supports fractional points for precision in tiered earn-rate calculations.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Points Balance After' ;
    rdfs:comment 'Snapshot of the loyalty account\'s total available points balance immediately after this transaction was applied. Together with points_balance_before, provides the complete before/after audit trail for each points movement event.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Points Balance Before' ;
    rdfs:comment 'Snapshot of the loyalty account\'s total available points balance immediately before this transaction was applied. Critical for audit trail completeness and points liability reconciliation required by finance.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsDirection rdf:type rdf:Property ;
    rdfs:label 'Points Direction' ;
    rdfs:comment 'Indicates whether the points_amount increases (credit) or decreases (debit) the loyalty account balance. Enables double-entry-style reconciliation of the points ledger for finance liability reporting.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Date' ;
    rdfs:comment 'The date on which the points awarded in this earn transaction are scheduled to expire per the loyalty program\'s currency expiration policy. Null for non-earn transactions. Drives the points liability aging schedule reported to finance.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pointsLiabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Points Liability Flag' ;
    rdfs:comment 'Indicates whether this transaction contributes to the outstanding points liability on the company\'s balance sheet (True for unspent earned points, False for redeemed or expired points). Supports finance\'s points liability reserve calculation under GAAP/IFRS.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Timestamp' ;
    rdfs:comment 'The date and time at which the loyalty transaction was processed and posted to the account balance by the loyalty engine. May differ from transaction_timestamp due to batch processing windows or pending verification holds.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:programYear rdf:type rdf:Property ;
    rdfs:label 'Program Year' ;
    rdfs:comment 'The fiscal or calendar year of the loyalty program in which this transaction occurred. Used for annual points balance resets, year-over-year program performance reporting, and points expiration policy enforcement.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Amount' ;
    rdfs:comment 'The net purchase amount (after discounts, excluding taxes) on the triggering order that qualified for points earning. Used to verify earn rate calculations and supports COGS and loyalty cost-per-transaction reporting.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionValue rdf:type rdf:Property ;
    rdfs:label 'Redemption Value' ;
    rdfs:comment 'The monetary discount or reward value applied to the consumer\'s order when points are redeemed. Populated only for redeem-type transactions. Used to calculate the effective discount rate and redemption liability release in financial reporting.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceTransactionRef rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Ref' ;
    rdfs:comment 'The native transaction identifier from the originating source system (e.g., Salesforce record ID, SAP document number, POS receipt number). Enables cross-system reconciliation and traceability back to the system of record.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Human-readable, externally referenceable business identifier for the loyalty transaction, formatted as LT-{YYYY}-{sequence}. Used in consumer-facing communications, call-centre lookups, and points dispute resolution.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current workflow state of the loyalty transaction reflecting its processing lifecycle: pending (awaiting confirmation), processed (successfully posted to account), reversed (cancelled after posting), failed (processing error), or cancelled (voided before posting).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which the loyalty points movement event occurred in the real world — i.e., when the triggering business event (purchase, referral, etc.) was confirmed and points were posted. This is the principal business event timestamp, distinct from system audit timestamps.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Categorical discriminator identifying the nature of the points movement: earn (points awarded), redeem (points consumed), adjust (manual correction), expire (points lapsed per program rules), transfer (inter-account movement), or reversal (cancellation of a prior transaction). [ENUM-REF-CANDIDATE: earn|redeem|adjust|expire|transfer|reversal — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEvent rdf:type rdf:Property ;
    rdfs:label 'Trigger Event' ;
    rdfs:comment 'The specific business event that initiated this points movement, such as purchase, referral, product_review, birthday_bonus, promotion_bonus, account_registration, social_share, or survey_completion. Drives attribution analysis and program ROI reporting. [ENUM-REF-CANDIDATE: purchase|referral|product_review|birthday_bonus|promotion_bonus|account_registration|social_share|survey_completion — promote to reference product]' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Unique surrogate identifier for each consumer segment definition record in the Consumer Goods lakehouse silver layer. Serves as the primary key for all segment definition and membership records.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to product.category. Business justification: CPG segments are defined around product category taxonomy (e.g., \'Premium Skincare Buyers\'). Segment targeting, category-level audience sizing, and trade promotion eligibility reports all require link' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:marketingBrandId rdf:type rdf:Property ;
    rdfs:label 'Marketing Brand Id' ;
    rdfs:comment 'Foreign key linking to marketing.brand. Business justification: Report: Segment Ownership Report requires linking each consumer segment to its owning brand for brand-level performance analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingBrand .

ind:parentSegmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Segment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent segment when this segment is a sub-segment or child in a hierarchical segmentation structure (e.g., \'High-Value Loyalists\' as a child of \'Loyalty Program Members\'). Null for top-level segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:activationChannel rdf:type rdf:Property ;
    rdfs:label 'Activation Channel' ;
    rdfs:comment 'The primary marketing activation channel for which this segment is designed (e.g., email campaigns, SMS, push notifications, paid media audiences, in-store promotions). Drives channel-specific audience export configurations in Salesforce Consumer Goods Cloud and CRM platforms.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageRangeMax rdf:type rdf:Property ;
    rdfs:label 'Age Range Max' ;
    rdfs:comment 'For demographic segments, the maximum consumer age (in years) defining the upper bound for segment inclusion. Used alongside age_range_min to define age-banded demographic segments (e.g., Millennials: 28–43).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeMin rdf:type rdf:Property ;
    rdfs:label 'Age Range Min' ;
    rdfs:comment 'For demographic segments, the minimum consumer age (in years) required for segment inclusion. Used in age-gated product targeting (e.g., health supplements, alcohol-adjacent personal care) and regulatory compliance with COPPA for under-13 restrictions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'Method by which consumers are assigned to this segment. \'rule_based\' uses deterministic business rules (e.g., purchase frequency thresholds); \'ml_model\' uses a trained machine learning classifier; \'manual\' indicates analyst-driven assignment; \'hybrid\' combines rule-based and ML approaches.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelScope rdf:type rdf:Property ;
    rdfs:label 'Channel Scope' ;
    rdfs:comment 'The distribution or engagement channel(s) for which this segment is applicable. \'dtc\' (Direct to Consumer) segments target consumers via owned digital channels; \'retail\' targets in-store shoppers; \'ecommerce\' targets online platform shoppers; \'omnichannel\' applies across all channels.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvMaxValue rdf:type rdf:Property ;
    rdfs:label 'Cltv Max Value' ;
    rdfs:comment 'For CLTV (Customer Lifetime Value)-based segments, the maximum predicted CLTV value defining the upper bound of this segment tier. Used to create banded CLTV segments (e.g., mid-value tier: CLTV between $500 and $2000). Null if no upper bound applies.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cltvMinValue rdf:type rdf:Property ;
    rdfs:label 'Cltv Min Value' ;
    rdfs:comment 'For CLTV (Customer Lifetime Value)-based segments, the minimum predicted CLTV score or monetary value required for a consumer to qualify for segment membership. Enables tiered loyalty and high-value consumer targeting strategies. Null for non-CLTV segment types.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentBasis rdf:type rdf:Property ;
    rdfs:label 'Consent Basis' ;
    rdfs:comment 'The legal basis under GDPR Article 6 or CCPA for processing consumer data within this segment. \'consent\' requires explicit opt-in; \'legitimate_interest\' applies where the business has a justified interest; \'contract\' applies for contractual necessity; \'not_required\' for non-personal aggregate segments.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRequired rdf:type rdf:Property ;
    rdfs:label 'Consent Required' ;
    rdfs:comment 'Indicates whether explicit consumer consent is required before a consumer can be assigned to or activated within this segment. True for segments used in direct marketing, personalization, or profiling activities subject to GDPR Article 6 or CCPA opt-in requirements.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date on which this segment definition expires and is no longer eligible for active targeting. Null indicates an open-ended segment with no planned expiry. Used for time-variant segment membership tracking and historical analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date from which this segment definition becomes valid and eligible for use in CRM targeting, personalization, and trade promotion activation. Supports time-variant segment tracking and bi-temporal data modeling in the silver layer.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code(s) or region identifiers defining the geographic boundary of this segment (e.g., \'USA\', \'GBR\', \'DEU\'). Supports multi-country CPG brand activation and ensures GDPR/CCPA-compliant targeting within applicable jurisdictions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSuppressionSegment rdf:type rdf:Property ;
    rdfs:label 'Is Suppression Segment' ;
    rdfs:comment 'Indicates whether this segment is a suppression list used to exclude consumers from campaigns (e.g., opted-out consumers, recent purchasers, regulatory exclusions). True means consumers in this segment are excluded from targeted marketing activations.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'The date and time when the segment membership was last recalculated and updated. Used to assess data freshness for CRM targeting and to trigger refresh workflows when the segment is stale relative to its defined refresh frequency.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyTierScope rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Scope' ;
    rdfs:comment 'The loyalty program tier(s) targeted by this segment. Enables differentiated engagement strategies for loyalty program members (e.g., exclusive offers for Platinum tier, win-back campaigns for Bronze tier). \'all\' indicates the segment applies across all loyalty tiers.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Min Confidence Score' ;
    rdfs:comment 'The minimum ML model confidence score (0.0000 to 1.0000) required for a consumer to be assigned to this segment when using ML-based assignment. Consumers with scores below this threshold are excluded. Null for rule-based or manual segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlModelCode rdf:type rdf:Property ;
    rdfs:label 'Ml Model Code' ;
    rdfs:comment 'Identifier of the machine learning model used to generate or score this segment, when assignment_method is \'ml_model\' or \'hybrid\'. Enables traceability to the model registry for audit, retraining, and explainability purposes. Null for rule_based or manual segments.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version identifier of the segmentation model or rule set that produced this segment definition (e.g., \'v1.0\', \'v2.3\'). Enables traceability of segment membership changes across model iterations and supports A/B testing of segmentation approaches.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScoreMax rdf:type rdf:Property ;
    rdfs:label 'Nps Score Max' ;
    rdfs:comment 'For NPS (Net Promoter Score)-based segments, the maximum NPS score (0–10 scale) defining the upper bound for segment inclusion. Used in conjunction with nps_score_min to define NPS-banded segments (e.g., detractors: 0–6).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsScoreMin rdf:type rdf:Property ;
    rdfs:label 'Nps Score Min' ;
    rdfs:comment 'For NPS (Net Promoter Score)-based segments, the minimum NPS score (0–10 scale) required for segment inclusion. Enables targeting of promoters (9–10), passives (7–8), or detractors (0–6) for tailored consumer engagement programs.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:owningBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owning Business Unit' ;
    rdfs:comment 'The business unit (BU) within Consumer Goods responsible for this segment\'s definition, governance, and activation (e.g., \'Personal Care\', \'Home Care\', \'Health & Wellness\'). Used for segment ownership reporting and cross-BU deduplication governance.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationEligible rdf:type rdf:Property ;
    rdfs:label 'Personalization Eligible' ;
    rdfs:comment 'Indicates whether consumers in this segment are eligible for personalized content, product recommendations, or pricing in DTC (Direct to Consumer) and e-commerce channels. Requires valid consent_basis when consent_required is True.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Numeric priority rank used to resolve conflicts when a consumer qualifies for multiple overlapping segments. Lower values indicate higher priority. Used by CRM and personalization engines to determine which segment\'s rules take precedence for offer assignment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'How frequently the segment membership is recalculated and updated. Determines the cadence at which consumer assignments are re-evaluated against the segment\'s rules or ML model. Impacts CRM campaign freshness and personalization accuracy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfmFrequencyMin rdf:type rdf:Property ;
    rdfs:label 'Rfm Frequency Min' ;
    rdfs:comment 'For RFM (Recency, Frequency, Monetary)-based segments, the minimum number of purchase transactions required within the recency window for a consumer to qualify for the frequency criterion. Null for non-RFM segment types.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfmMonetaryMin rdf:type rdf:Property ;
    rdfs:label 'Rfm Monetary Min' ;
    rdfs:comment 'For RFM (Recency, Frequency, Monetary)-based segments, the minimum cumulative spend amount (in the segment\'s currency) required within the recency window for a consumer to qualify for the monetary criterion. Null for non-RFM segment types.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfmRecencyDays rdf:type rdf:Property ;
    rdfs:label 'Rfm Recency Days' ;
    rdfs:comment 'For RFM (Recency, Frequency, Monetary)-based segments, the number of days used to define the recency window (e.g., last 90 days). Consumers with a purchase within this window qualify for the recency criterion. Null for non-RFM segment types.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the segment, used in CRM campaign targeting, trade promotion management (TPM) systems, and Salesforce Consumer Goods Cloud audience configurations. Unique per segment version.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the segment\'s defining characteristics, inclusion criteria, and intended business use (e.g., targeting strategy, personalization approach, or trade promotion eligibility). Authored by the owning brand or business unit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable business name of the consumer segment (e.g., \'High-Value Loyalists\', \'Lapsed Shoppers\', \'Health-Conscious Millennials\'). Used in marketing activation, CRM dashboards, and trade promotion targeting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle state of the segment definition. \'active\' segments are available for CRM targeting and trade promotion activation; \'draft\' segments are under construction; \'archived\' segments are retained for historical analysis but no longer used in campaigns.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segmentation methodology applied to define this segment. Behavioral segments are based on purchase patterns; demographic on age/gender/income; psychographic on lifestyle/values; RFM (Recency, Frequency, Monetary) on transactional scoring; CLTV (Customer Lifetime Value)-based on predicted long-term value; geographic on location.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Source Segment Code' ;
    rdfs:comment 'The native identifier of this segment in the originating operational system (e.g., Salesforce Consumer Goods Cloud segment ID, Nielsen IQ panel group code). Enables cross-system reconciliation and data lineage tracing back to the system of record.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceSize rdf:type rdf:Property ;
    rdfs:label 'Target Audience Size' ;
    rdfs:comment 'The estimated or actual count of unique consumers assigned to this segment at the time of last refresh. Used for campaign planning, media budget allocation, and share of voice (SOV) estimation. Not a real-time count — reflects the last segment refresh cycle.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradePromotionEligible rdf:type rdf:Property ;
    rdfs:label 'Trade Promotion Eligible' ;
    rdfs:comment 'Indicates whether this consumer segment is eligible for trade promotion targeting within the Trade Promotion Management (TPM) system. True enables the segment to be used in TPM/TPO campaign audience configurations in Salesforce Consumer Goods Cloud.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Integer version number of this segment definition record, incremented each time the segment\'s criteria, model, or metadata is materially updated. Supports bi-temporal tracking and enables comparison of segment membership across definition versions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentMembershipId rdf:type rdf:Property ;
    rdfs:label 'Segment Membership Id' ;
    rdfs:comment 'Unique surrogate identifier for each segment membership association record in the consumer domain. Primary key for the segment_membership data product.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Reference to the marketing campaign or trade promotion for which this segment membership was created or activated. Links segment membership to specific campaign execution context.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'The unique identifier of the consent record that authorizes the use of this consumer\'s data for segment assignment and targeting. Provides an auditable link to the consent management system for GDPR and CCPA compliance.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentRecord .

ind:activationCount rdf:type rdf:Property ;
    rdfs:label 'Activation Count' ;
    rdfs:comment 'The number of times this segment membership has been activated or used in campaign targeting or personalization executions. Supports frequency capping and engagement fatigue management.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'The calendar date on which the consumer was assigned or enrolled into this segment. Marks the start of the membership period for time-variant tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:brandAffinityCode rdf:type rdf:Property ;
    rdfs:label 'Brand Affinity Code' ;
    rdfs:comment 'Code identifying the specific brand or brand portfolio for which this segment membership is relevant. Enables brand-level personalization and targeted engagement within a multi-brand consumer goods portfolio.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvTier rdf:type rdf:Property ;
    rdfs:label 'Cltv Tier' ;
    rdfs:comment 'The Customer Lifetime Value (CLTV) tier of the consumer at the time of segment assignment. Captures the consumer\'s value classification to support premium targeting and differentiated engagement strategies.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'A numeric probability or confidence value (0.0000 to 1.0000) indicating the certainty of the segment assignment, particularly relevant for ML model and propensity-score assignment methods. Higher values indicate stronger segment fit.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'The consent status of the consumer for use of their data in this segment assignment and associated targeting activities. Granted indicates valid consent; withdrawn indicates consent has been revoked and the membership should not be used for targeting. Mandatory for GDPR and CCPA compliance.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProcessingBasis rdf:type rdf:Property ;
    rdfs:label 'Data Processing Basis' ;
    rdfs:comment 'The legal basis under which the consumer\'s personal data is processed for this segment assignment. Required for GDPR Article 6 compliance documentation. Consent indicates explicit opt-in; legitimate_interest indicates business interest basis; contract indicates processing necessary for contract performance.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective From Timestamp' ;
    rdfs:comment 'The precise date and time from which this segment membership record is considered effective. Supports bi-temporal data modeling and time-variant segment tracking at sub-day precision for real-time personalization.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveUntilTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Until Timestamp' ;
    rdfs:comment 'The precise date and time until which this segment membership record is considered effective. Null indicates the record is currently active with no defined end. Supports bi-temporal data modeling and SCD Type 2 history tracking.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:evaluationFrequency rdf:type rdf:Property ;
    rdfs:label 'Evaluation Frequency' ;
    rdfs:comment 'The cadence at which this segment membership is re-evaluated and potentially updated. Real-time indicates event-driven evaluation; daily/weekly/monthly/quarterly indicate batch evaluation schedules.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isControlGroup rdf:type rdf:Property ;
    rdfs:label 'Is Control Group' ;
    rdfs:comment 'Flag indicating whether the consumer is assigned to a holdout or control group within this segment for A/B testing or campaign measurement purposes. True indicates the consumer is in the control group and should not receive targeted communications.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimarySegment rdf:type rdf:Property ;
    rdfs:label 'Is Primary Segment' ;
    rdfs:comment 'Flag indicating whether this segment is the primary or dominant segment for the consumer when multiple segment memberships exist simultaneously. True indicates this is the primary segment used for default personalization.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivationDate rdf:type rdf:Property ;
    rdfs:label 'Last Activation Date' ;
    rdfs:comment 'The most recent date on which this segment membership was used to activate a campaign, promotion, or personalization event. Supports recency analysis and frequency capping in campaign management.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastEvaluatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Evaluated Timestamp' ;
    rdfs:comment 'The date and time when the segment membership was last re-evaluated by the segmentation engine or rule processor. Indicates freshness of the assignment and supports refresh scheduling.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the segment membership record. Active indicates the consumer is currently a member of the segment; expired indicates the membership period has lapsed; suspended indicates temporary hold.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScoreAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Nps Score At Assignment' ;
    rdfs:comment 'The Net Promoter Score (NPS) of the consumer at the time of segment assignment. Captured as a point-in-time snapshot to contextualize the segmentation decision and support consumer satisfaction analytics.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Indicates whether the consumer has exercised their right to opt out of data-driven segmentation and targeted marketing under CCPA or GDPR. True means the consumer has opted out and this membership must not be used for targeting.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text description of the business justification for a manual segment assignment or override. Populated when assignment_method is manual. Required for audit compliance and governance review.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Product Category Code' ;
    rdfs:comment 'The product category code for which this segment membership is specifically applicable. Enables category-level targeting (e.g., personal care, household, health) within broader consumer segmentation strategies.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'The scheduled date for periodic review or re-evaluation of this segment membership. Supports governance processes ensuring segment assignments remain accurate and consent remains valid.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ruleSetCode rdf:type rdf:Property ;
    rdfs:label 'Rule Set Code' ;
    rdfs:comment 'Identifier of the business rule set applied when assignment_method is rule_based. Enables traceability of which rule definition produced the membership assignment.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentPriority rdf:type rdf:Property ;
    rdfs:label 'Segment Priority' ;
    rdfs:comment 'Numeric priority rank for this segment membership when a consumer belongs to multiple overlapping segments. Lower values indicate higher priority. Used to resolve conflicts in personalization and campaign targeting logic.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentVersion rdf:type rdf:Property ;
    rdfs:label 'Segment Version' ;
    rdfs:comment 'The version identifier of the segment definition that was active at the time of assignment. Enables tracking of membership against evolving segment criteria and supports reproducibility of historical targeting decisions.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordRef rdf:type rdf:Property ;
    rdfs:label 'Source Record Ref' ;
    rdfs:comment 'The native identifier of this segment membership record in the originating source system. Enables cross-system reconciliation and traceability back to the system of record.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression Flag' ;
    rdfs:comment 'Indicates whether this consumer should be suppressed from communications or activations associated with this segment, despite being a member. True means the consumer is suppressed. Used for do-not-contact lists, regulatory holds, or competitive exclusions.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'The reason code explaining why the consumer is suppressed from segment activations. Populated only when suppression_flag is True. Supports compliance audit trails for GDPR and CCPA suppression requests.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceId rdf:type rdf:Property ;
    rdfs:label 'Preference Id' ;
    rdfs:comment 'Unique surrogate identifier for each consumer preference record in the Consumer Goods lakehouse silver layer. Primary key for the preference data product.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Override Flag' ;
    rdfs:comment 'Indicates whether this preference record has been overridden at the brand level, superseding the consumer\'s global preference. When True, the brand_id field identifies which brand applied the override. Enables brand-specific preference management within a multi-brand CPG portfolio.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brandOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Brand Override Reason' ;
    rdfs:comment 'The business reason for the brand-level preference override when brand_override_flag is True. Used for audit trails and compliance reporting, particularly for regulatory restrictions (e.g., FDA, CPSC product safety communications).' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Data Subject Request Flag' ;
    rdfs:comment 'Indicates whether this preference record is subject to an active Data Subject Request (DSR) under GDPR or CCPA (e.g., right to erasure, right to access, right to portability). When True, downstream systems must apply appropriate data handling restrictions.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flavorFragrancePreference rdf:type rdf:Property ;
    rdfs:label 'Flavor Fragrance Preference' ;
    rdfs:comment 'The consumer\'s preferred flavor (for food/beverage/oral care) or fragrance (for personal care/household products). Drives variant-level recommendations and new product development (NPD) consumer insights. Aligns with INCI nomenclature for fragrance ingredients.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferenceBasis rdf:type rdf:Property ;
    rdfs:label 'Inference Basis' ;
    rdfs:comment 'The data signal or behavioral evidence used to infer this preference when preference_source is ML-inferred. Provides transparency into the inference methodology for model explainability and GDPR Article 22 automated decision-making compliance.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferenceModelVersion rdf:type rdf:Property ;
    rdfs:label 'Inference Model Version' ;
    rdfs:comment 'The version identifier of the ML model used to infer this preference when preference_source is \'inferred_ml\' or \'inferred_purchase_history\'. Enables model governance, A/B testing of recommendation algorithms, and reproducibility of inferred preferences for audit purposes.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGlobalPreference rdf:type rdf:Property ;
    rdfs:label 'Is Global Preference' ;
    rdfs:comment 'Indicates whether this preference applies globally across all brands in the CPG portfolio (True) or is specific to a single brand identified by brand_id (False). Global preferences serve as the default when no brand-specific preference exists.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for additional context or qualifications about this preference record, such as special instructions captured during a call-center interaction or notes from a consumer survey. Used by CRM agents and consumer engagement teams.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSegment rdf:type rdf:Property ;
    rdfs:label 'Nps Segment' ;
    rdfs:comment 'The consumer\'s NPS (Net Promoter Score) segment classification at the time this preference was captured. Used to contextualize preference data — promoters may have stronger brand preferences while detractors may have channel avoidance preferences. Supports consumer engagement strategy.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInStatus rdf:type rdf:Property ;
    rdfs:label 'Opt In Status' ;
    rdfs:comment 'Indicates whether the consumer has opted in (True) or opted out (False) for this specific preference category. Critical for GDPR/CCPA compliance — a False value means the consumer must NOT be targeted via this preference dimension.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packSizePreference rdf:type rdf:Property ;
    rdfs:label 'Pack Size Preference' ;
    rdfs:comment 'The consumer\'s preferred pack size or format (e.g., \'travel_size\', \'standard\', \'family_size\', \'bulk\', \'subscription_bundle\'). Used to tailor product recommendations and promotional offers to the consumer\'s typical purchase behavior.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceCategory rdf:type rdf:Property ;
    rdfs:label 'Preference Category' ;
    rdfs:comment 'High-level classification of the preference type. Defines what dimension of consumer behavior or communication this preference record governs. [ENUM-REF-CANDIDATE: product_category|brand|flavor_fragrance|pack_size|channel|communication_channel|contact_frequency|preferred_time_of_day|preferred_language — promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceRank rdf:type rdf:Property ;
    rdfs:label 'Preference Rank' ;
    rdfs:comment 'Ordinal ranking of this preference value relative to other values within the same category for the same consumer. Rank 1 indicates the most preferred option. Enables ranked preference lists for recommendation engines (e.g., first, second, third flavor choice).' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferenceSource rdf:type rdf:Property ;
    rdfs:label 'Preference Source' ;
    rdfs:comment 'Origin of the preference record indicating whether it was explicitly declared by the consumer through a digital or physical touchpoint, or inferred by an ML model or behavioral analysis. Declared preferences carry higher trust weight in personalization engines. [ENUM-REF-CANDIDATE: declared_web|declared_app|declared_call_center|declared_in_store|inferred_ml|inferred_purchase_history|inferred_survey — promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle state of the preference record. \'active\' means the preference is valid and in use by personalization engines; \'suppressed\' means the preference is overridden by a brand-level or regulatory rule; \'expired\' means the preference has passed its effective end date.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceValue rdf:type rdf:Property ;
    rdfs:label 'Preference Value' ;
    rdfs:comment 'The specific declared or inferred preference value within the category and subcategory. Examples: \'mint\' for flavor, \'English\' for language, \'morning\' for time of day, \'weekly\' for contact frequency, \'email\' for communication channel. Free-form string to accommodate diverse CPG preference dimensions.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Channel' ;
    rdfs:comment 'The consumer\'s preferred channel for receiving brand communications, promotions, and personalized content. Drives communication orchestration in Salesforce Consumer Goods Cloud and DTC engagement programs. \'none\' indicates the consumer has opted out of all outbound communications. [ENUM-REF-CANDIDATE: email|sms|push_notification|direct_mail|in_app|whatsapp|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactFrequency rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Frequency' ;
    rdfs:comment 'The consumer\'s declared preference for how often they wish to receive brand communications. Used by communication orchestration engines to enforce contact frequency caps and prevent consumer fatigue in CPG engagement programs. [ENUM-REF-CANDIDATE: daily|weekly|bi_weekly|monthly|quarterly|as_needed|never — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredTimeOfDay rdf:type rdf:Property ;
    rdfs:label 'Preferred Time Of Day' ;
    rdfs:comment 'The consumer\'s preferred time window for receiving communications and push notifications. Used by send-time optimization algorithms in CPG personalization engines to maximize open rates and engagement.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredTimezone rdf:type rdf:Property ;
    rdfs:label 'Preferred Timezone' ;
    rdfs:comment 'The IANA timezone identifier for the consumer\'s preferred timezone (e.g., \'America/New_York\', \'Europe/London\'). Used in conjunction with preferred_time_of_day to schedule communications at the correct local time for global CPG consumer bases.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryPreference rdf:type rdf:Property ;
    rdfs:label 'Product Category Preference' ;
    rdfs:comment 'The specific CPG product category this consumer prefers (e.g., \'oral_care\', \'hair_care\', \'skin_care\', \'household_cleaning\', \'personal_hygiene\'). Drives product recommendation engines and category-level targeted promotions. Populated when preference_category = \'product_category\'.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailChannelPreference rdf:type rdf:Property ;
    rdfs:label 'Retail Channel Preference' ;
    rdfs:comment 'The consumer\'s preferred retail channel for purchasing CPG products. Used for channel-specific targeting, trade promotion alignment, and omnichannel engagement strategies. Supports DSD (Direct Store Delivery) and DTC channel optimization. [ENUM-REF-CANDIDATE: ecommerce|grocery|mass_retail|pharmacy|dtc|club_store|convenience|specialty — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuPreference rdf:type rdf:Property ;
    rdfs:label 'Sku Preference' ;
    rdfs:comment 'The specific SKU (Stock Keeping Unit) code that the consumer has declared or demonstrated a preference for. Enables SKU-level personalization and targeted replenishment reminders in DTC and e-commerce channels. Aligns with SAP S/4HANA MM material master.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPreferenceRef rdf:type rdf:Property ;
    rdfs:label 'Source System Preference Ref' ;
    rdfs:comment 'The native identifier of this preference record in the originating source system (e.g., Salesforce Consumer Goods Cloud preference record ID). Enables cross-system reconciliation and EDI-based data exchange between CPG operational systems.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Granular sub-classification within the preference category. For example, within \'product_category\' the subcategory may be \'hair_care\' or \'oral_care\'; within \'communication_channel\' it may be \'email\' or \'push_notification\'. Enables multi-level preference taxonomy for CPG personalization engines.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Id' ;
    rdfs:comment 'Foreign key linking to regulatory.compliance_obligation. Business justification: Consent records are captured to satisfy specific regulatory compliance obligations (GDPR Art.6, CCPA §1798.100). Regulatory affairs teams must trace which compliance obligation mandates each consent t' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceObligation .

ind:jurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to regulatory.jurisdiction. Business justification: Data privacy compliance mandates mapping each consent record to its governing jurisdiction for regulatory reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:captureMethod rdf:type rdf:Property ;
    rdfs:label 'Capture Method' ;
    rdfs:comment 'Channel or mechanism through which the consumer\'s consent was captured. Identifies whether consent was obtained via a web form, mobile app, in-store interaction, call center agent, paper form, or email link. Required for GDPR proof-of-consent obligations.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Capture Timestamp' ;
    rdfs:comment 'Exact date and time (with timezone offset) when the consumer\'s consent action was recorded in the system. This is the principal business event timestamp for the consent record and is immutable once set. Required for GDPR Article 7 audit trail.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeTrigger rdf:type rdf:Property ;
    rdfs:label 'Change Trigger' ;
    rdfs:comment 'The business reason or event that triggered the most recent change to the consent status. Distinguishes consumer-initiated changes from system-driven expirations, administrative overrides, legal requests (e.g., right to erasure), or re-consent campaigns.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Consent Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 country subtag) of the language in which the consent notice was presented to the consumer (e.g., \'en\', \'fr\', \'de\', \'es-MX\'). Required to confirm consent was given in an intelligible form per GDPR Article 7.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentProofReference rdf:type rdf:Property ;
    rdfs:label 'Consent Proof Reference' ;
    rdfs:comment 'Reference identifier or URL pointing to the stored proof-of-consent artifact (e.g., screenshot, signed form scan, call recording reference, Veeva Vault document ID). Supports GDPR Article 7(1) obligation to demonstrate that consent was given.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Defines the breadth of the consent grant — whether it applies globally across all Consumer Goods brands and products, is restricted to a specific brand, product category, or a single campaign. Enables granular consent management across the product portfolio.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTextSnapshot rdf:type rdf:Property ;
    rdfs:label 'Consent Text Snapshot' ;
    rdfs:comment 'Verbatim text or reference hash of the consent notice, privacy policy excerpt, or opt-in language presented to the consumer at the time of consent capture. Immutable record of what the consumer agreed to, required for GDPR Article 7 proof-of-consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Category of consent being captured, defining the specific processing activity for which the consumer has provided or withheld consent. Covers marketing email, SMS, push notification, data sharing, profiling, and cookies as required by GDPR and CCPA.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cookieConsentCategories rdf:type rdf:Property ;
    rdfs:label 'Cookie Consent Categories' ;
    rdfs:comment 'Comma-separated list of cookie categories for which the consumer has granted consent (e.g., \'functional,analytics,marketing\'). Captures granular cookie preferences as required by the ePrivacy Directive and GDPR for digital channels. [ENUM-REF-CANDIDATE: necessary|functional|analytics|marketing|social_media|personalization|advertising — promote to reference product]' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Type of device used by the consumer when providing consent in digital channels. Supports forensic audit trails and UX analysis of consent capture flows.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Flag' ;
    rdfs:comment 'Indicates whether the consumer completed a double opt-in confirmation process (e.g., clicked a confirmation link in a verification email) in addition to the initial consent action. Double opt-in provides stronger proof of consent for marketing communications under GDPR.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Timestamp' ;
    rdfs:comment 'Exact date and time when the consumer completed the double opt-in confirmation step. Null if double opt-in was not required or not yet completed. Provides the definitive timestamp for consent activation in double opt-in workflows.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which this consent record is considered active and binding. Typically aligns with the capture date but may differ for backdated or scheduled consent activations. Supports MASTER_AGREEMENT role effective-period tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address of the device from which the consumer submitted their consent. Captured for digital consent channels (web form, mobile app, email link) as evidence of consent origin. May be considered PII under GDPR in some EU jurisdictions.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentRecord rdf:type rdf:Property ;
    rdfs:label 'Is Current Record' ;
    rdfs:comment 'Indicates whether this row represents the current active consent record for the consumer-consent_type combination. Supports Slowly Changing Dimension (SCD Type 2) pattern in the Silver Layer, where historical consent versions are retained for audit purposes and this flag identifies the latest version.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The lawful basis under GDPR Article 6 or equivalent regulation for processing the consumer\'s personal data. Consent is one of six legal bases; this field distinguishes consent-based processing from other lawful bases to support compliance reporting.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorAgeThreshold rdf:type rdf:Property ;
    rdfs:label 'Minor Age Threshold' ;
    rdfs:comment 'Age threshold (in years) used to determine whether parental consent was required for this consent record, based on the applicable jurisdiction\'s rules (e.g., 16 for GDPR default, 13 for COPPA, 13-16 for EU member state variations). Null if consumer is not a minor.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentalConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Flag' ;
    rdfs:comment 'Indicates whether parental or guardian consent was obtained for a minor consumer. Required under GDPR Article 8 for children under 16 (or lower age threshold set by member state) and COPPA for US consumers under 13.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Consent Status' ;
    rdfs:comment 'The consent status immediately before the most recent status change. Enables point-in-time audit reconstruction and supports the immutable event log requirement for GDPR Article 7 compliance audits without requiring a separate history table join.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingAgent rdf:type rdf:Property ;
    rdfs:label 'Processing Agent' ;
    rdfs:comment 'Identifier of the system, application, or human agent (call center representative ID or system name) that processed and recorded the consent event. Supports accountability requirements under GDPR Article 5(2) and provides an audit trail of who or what captured the consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profilingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Profiling Consent Flag' ;
    rdfs:comment 'Indicates whether the consumer has consented to automated profiling and decision-making activities, including personalization algorithms, NPS scoring, CLTV modeling, and segmentation. Required under GDPR Article 22 for automated decision-making with significant effects.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reConsentDeadline rdf:type rdf:Property ;
    rdfs:label 'Re Consent Deadline' ;
    rdfs:comment 'Date by which the consumer must re-confirm their consent before the current consent record is automatically withdrawn or expired. Null if re-consent is not required. Used to drive automated consent renewal campaigns.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Re Consent Required Flag' ;
    rdfs:comment 'Indicates whether this consent record requires re-confirmation from the consumer due to a material change in the privacy policy, consent notice, or processing purpose. Triggers re-consent outreach workflows in the CRM system.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Sequential version number of this consent record for the consumer-consent_type combination. Increments with each status change or update, enabling full audit history reconstruction. Version 1 is the initial consent capture; subsequent versions reflect changes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'The applicable privacy regulation or jurisdiction framework under which this consent record was created and must be managed. Determines the legal basis, retention rules, and consumer rights applicable to this record (e.g., GDPR for EU consumers, CCPA for California residents).' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'Number of days this consent record must be retained for compliance purposes after the consent is withdrawn or expires. Determined by applicable regulatory requirements (e.g., GDPR Article 5(1)(e) storage limitation, CCPA). Drives automated data lifecycle management.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thirdPartySharingFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Flag' ;
    rdfs:comment 'Indicates whether the consumer has explicitly consented to their personal data being shared with third-party partners (e.g., retail partners, data brokers, analytics providers). Distinct from general data sharing consent; specifically governs external data transfers.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withdrawalMethod rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Method' ;
    rdfs:comment 'Channel or mechanism through which the consumer withdrew their consent. Null if consent has not been withdrawn. Required to demonstrate that withdrawal was as easy as giving consent per GDPR Article 7(3).' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Timestamp' ;
    rdfs:comment 'Exact date and time when the consumer withdrew their consent. Null if consent has not been withdrawn. GDPR Article 7(3) requires that withdrawal be as easy as giving consent; this timestamp documents the withdrawal event for audit purposes.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dtcOrderId rdf:type rdf:Property ;
    rdfs:label 'Dtc Order Id' ;
    rdfs:comment 'Unique surrogate identifier for each Direct-to-Consumer (DTC) order record in the Silver layer lakehouse. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DtcOrder .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_invoice. Business justification: DTC orders generate AR invoices for revenue recognition, DSO reporting, and dispute management. Consumer goods O2C process requires tracing each DTC order to its AR invoice for collections and ASC 606' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:deliveryId rdf:type rdf:Property ;
    rdfs:label 'Delivery Id' ;
    rdfs:comment 'Foreign key linking to logistics.delivery. Business justification: DTC order fulfillment tracking requires direct access to the delivery record for consumer-facing OTIF reporting, last-mile status, and delivery exception management. DTC operations teams monitor deliv' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Delivery .

ind:distributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Distribution Facility Id' ;
    rdfs:comment 'Foreign key linking to distribution.distribution_facility. Business justification: Order fulfillment report requires order-level DC assignment for shipping cost, OTIF metrics, and inventory allocation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:distributionShipmentId rdf:type rdf:Property ;
    rdfs:label 'Distribution Shipment Id' ;
    rdfs:comment 'Foreign key linking to distribution.distribution_shipment. Business justification: A DTC order is physically fulfilled via a DC distribution shipment. Linking them enables end-to-end order-to-shipment traceability, OTIF compliance reporting at the consumer order level, and consumer ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionShipment .

ind:outboundOrderId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Id' ;
    rdfs:comment 'Foreign key linking to distribution.outbound_order. Business justification: A DTC consumer order triggers a DC outbound order for fulfillment. Order-to-delivery traceability, OTIF measurement, and consumer service escalations all require linking the consumer-facing order to t' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundOrder .

ind:priceListId rdf:type rdf:Property ;
    rdfs:label 'Price List Id' ;
    rdfs:comment 'Foreign key linking to sales.price_list. Business justification: DTC channel orders must reference the applicable price list for pricing governance, margin analysis, and promotional compliance auditing. Consumer goods companies maintain DTC-specific price lists; li' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:shippingAddressId rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Id' ;
    rdfs:comment 'Foreign key linking to consumer.address. Business justification: DTC orders have a shipping address captured as denormalized fields (ship_to_address_line1, ship_to_city, ship_to_country_code, ship_to_name, ship_to_postal_code, ship_to_state_province). The address t' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:subscriptionId rdf:type rdf:Property ;
    rdfs:label 'Subscription Id' ;
    rdfs:comment 'Reference to the consumer subscription plan that generated this DTC order, when subscription_order_flag is True. Links to the subscription master for recurring order management, churn analysis, and subscription revenue reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscription .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The date the shipment was confirmed as delivered to the consumer. Compared against promised_delivery_date to calculate OTIF performance and identify late delivery patterns for carrier SLA management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingAddressSameFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Address Same Flag' ;
    rdfs:comment 'Indicates whether the billing address is identical to the shipping address for this order. When False, a separate billing address record is maintained. Used for payment processing and fraud risk scoring.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'Code identifying the shipping carrier assigned to deliver this DTC order (e.g., UPS, FedEx, USPS, DHL). Used for carrier performance analysis, SLA tracking, and logistics cost allocation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'The specific owned DTC channel through which the order was placed (e.g., brand website, mobile app, social commerce). Enables channel-level performance analysis, attribution modeling, and Share of Voice (SOV) reporting across DTC touchpoints.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total monetary discount applied at the order header level, including promotional codes, loyalty redemptions, and trade promotion discounts. Used for Trade Promotion Management (TPM) ROI analysis and net revenue reporting. Part of TRANSACTION_HEADER MONETARY_TRIPLET adjustment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentRef rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Ref' ;
    rdfs:comment 'External reference number linking this DTC order to the fulfillment system (e.g., Blue Yonder WMS warehouse order, 3PL fulfillment reference, or SAP WM transfer order). Enables end-to-end order-to-delivery traceability and OTIF measurement.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current fulfillment state of the DTC order at the header level, indicating whether all line items have been picked, packed, and shipped. Used for OTIF (On Time In Full) KPI reporting and supply chain performance dashboards.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Order Flag' ;
    rdfs:comment 'Indicates whether this DTC order was placed as a gift, triggering gift wrapping, suppression of price information on packing slips, and gift message inclusion. Used for seasonal demand analysis and consumer gifting behavior modeling.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ip Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code derived from the consumer\'s IP address at the time of order placement. Used for fraud detection, geo-restriction compliance, and cross-border commerce analytics. Classified as potentially PII under GDPR.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsEarned rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Earned' ;
    rdfs:comment 'Number of loyalty program points earned by the consumer for this DTC order, based on the order total and applicable loyalty tier multipliers. Feeds into CLTV calculations and loyalty program engagement analytics.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyPointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Redeemed' ;
    rdfs:comment 'Number of loyalty program points redeemed by the consumer as a discount on this DTC order. Used for loyalty liability accounting, redemption rate analysis, and consumer engagement reporting.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The exact date and time (UTC) when the consumer submitted the order through the DTC e-commerce or brand website channel. This is the principal business event timestamp used for demand planning, daily sales reporting, and S&OP inputs. Satisfies TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the DTC order, tracking progression from placement through fulfillment or cancellation. Used for order management dashboards, OTIF reporting, and consumer communication triggers. Satisfies TRANSACTION_HEADER LIFECYCLE_STATUS category. [ENUM-REF-CANDIDATE: pending|confirmed|processing|shipped|delivered|cancelled|returned — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Order Total Amount' ;
    rdfs:comment 'The final net amount charged to the consumer, calculated as subtotal minus discounts plus shipping plus tax. This is the authoritative revenue figure for DTC channel financial reporting and EBITDA contribution analysis. Satisfies TRANSACTION_HEADER MONETARY_TRIPLET net total.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The payment instrument type used by the consumer to complete this DTC order (e.g., credit card, PayPal, digital wallet). Used for payment analytics, fraud detection, and consumer payment preference reporting. Note: No raw card data is stored; only the instrument type.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of the payment transaction associated with this DTC order, tracking authorization through capture or refund. Critical for revenue recognition, accounts receivable (DSO), and consumer dispute resolution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTransactionRef rdf:type rdf:Property ;
    rdfs:label 'Payment Transaction Ref' ;
    rdfs:comment 'External payment gateway transaction reference or authorization code for this order. Used for payment reconciliation, chargeback management, and financial audit trails. Does not contain sensitive card data (PCI DSS compliant tokenized reference only).' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'The delivery date committed to the consumer at the time of order placement, based on Available to Promise (ATP) or Capable to Promise (CTP) logic. Used for SLA compliance measurement and consumer expectation management.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnFlag rdf:type rdf:Property ;
    rdfs:label 'Return Flag' ;
    rdfs:comment 'Indicates whether any item in this DTC order has been returned or a return has been initiated. Used for return rate analysis, product quality monitoring, and consumer satisfaction (NPS) correlation studies.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for the order return (e.g., defective product, wrong item, consumer changed mind). Populated when return_flag is True. Used for quality defect analysis, product improvement, and COGS impact reporting. [ENUM-REF-CANDIDATE: defective|wrong_item|not_as_described|changed_mind|damaged_in_transit|late_delivery|other — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedDate rdf:type rdf:Property ;
    rdfs:label 'Shipped Date' ;
    rdfs:comment 'The date the order was physically dispatched from the fulfillment center or warehouse. Used for lead time analysis, carrier handoff tracking, and revenue recognition timing under ASC 606.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Amount' ;
    rdfs:comment 'Shipping and handling charges billed to the consumer for this DTC order. Used for logistics cost analysis, free-shipping threshold reporting, and net revenue calculations.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemOrderRef rdf:type rdf:Property ;
    rdfs:label 'Source System Order Ref' ;
    rdfs:comment 'The native order identifier from the originating e-commerce platform or ERP system (e.g., Salesforce Commerce Cloud order ID, SAP SD sales order number). Used for cross-system reconciliation, EDI integration, and data lineage tracing back to the system of record.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Subscription Order Flag' ;
    rdfs:comment 'Indicates whether this DTC order was generated as part of a recurring subscription (subscribe-and-save) program. Used to distinguish subscription revenue from one-time purchase revenue for CLTV modeling and replenishment trigger analysis.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'The gross merchandise value of all line items before discounts, shipping charges, and taxes are applied. Used as the base for promotional discount calculations, COGS analysis, and gross margin reporting. Part of TRANSACTION_HEADER MONETARY_TRIPLET.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total sales tax or VAT charged on this DTC order, calculated based on the shipping destination jurisdiction. Required for financial reporting, tax compliance, and SOX audit trails. Part of TRANSACTION_HEADER MONETARY_TRIPLET adjustment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-assigned tracking number for the shipment associated with this DTC order. Provided to the consumer for last-mile visibility and used internally for delivery confirmation and OTIF measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtcOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Dtc Order Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual line item within a DTC order. Primary key for this entity. Role: TRANSACTION_LINE.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchRecordId rdf:type rdf:Property ;
    rdfs:label 'Batch Record Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.batch_record. Business justification: Forward traceability — identifying which consumers received which manufacturing batch — is a core regulatory requirement (FDA 21 CFR, EU GPR) for targeted recall notifications. Consumer Goods quality ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:batchReleaseId rdf:type rdf:Property ;
    rdfs:label 'Batch Release Id' ;
    rdfs:comment 'Foreign key linking to quality.batch_release. Business justification: Consumer goods companies shipping regulated health/personal care products must verify each order line\'s lot had a valid QA batch release before shipment. This link enables recall traceability (identif' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRelease .

ind:dtcReturnId rdf:type rdf:Property ;
    rdfs:label 'Dtc Return Id' ;
    rdfs:comment 'Reference to the consumer return record associated with this order line when a return has been initiated. Enables end-to-end return lifecycle tracking and refund reconciliation.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DtcReturn .

ind:logisticsShipmentId rdf:type rdf:Property ;
    rdfs:label 'Logistics Shipment Id' ;
    rdfs:comment 'Reference to the outbound shipment record associated with this order line. Enables traceability from order line to physical shipment for OTIF tracking and logistics cost allocation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LogisticsShipment .

ind:lotBatchId rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Id' ;
    rdfs:comment 'Foreign key linking to inventory.lot_batch. Business justification: DTC order lines must be traceable to specific lot/batch for product traceability, recall response, and shelf-life compliance reporting. Consumer goods regulatory requirements (e.g., FDA, EU traceabili' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotBatch .

ind:pickTaskId rdf:type rdf:Property ;
    rdfs:label 'Pick Task Id' ;
    rdfs:comment 'Foreign key linking to distribution.pick_task. Business justification: Each DTC order line drives a specific warehouse pick task. Linking them enables pick accuracy reporting per order line, exception management (short picks, substitutions), and fulfillment SLA tracking ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PickTask .

ind:productRecallId rdf:type rdf:Property ;
    rdfs:label 'Product Recall Id' ;
    rdfs:comment 'Foreign key linking to regulatory.product_recall. Business justification: Recall effectiveness analysis needs to associate each order line with the recall that affected the SKU.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductRecall .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_movement. Business justification: Shipment tracking process ties each order line to the inventory movement record that shipped the product.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockMovement .

ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_position. Business justification: Fulfillment allocation report requires linking each order line to the specific stock position that supplied the SKU.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:supplyAtpRecordId rdf:type rdf:Property ;
    rdfs:label 'Supply Atp Record Id' ;
    rdfs:comment 'Foreign key linking to supply.atp_record. Business justification: REQUIRED: Order line allocation references the ATP record used for inventory commitment; this link supports order-to-inventory reconciliation and fulfillment reporting.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AtpRecord .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'Date on which the order line was physically dispatched from the fulfillment warehouse. Used to calculate On Time In Full (OTIF) performance and carrier SLA adherence.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Code identifying the brand under which the product on this order line is marketed. Supports brand-level revenue reporting, Share of Market (SOM) analysis, and brand portfolio performance tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfGoodsSold rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold' ;
    rdfs:comment 'Standard cost of goods for the units on this order line at time of sale. Used for gross margin calculation, DTC channel profitability analysis, and EBITDA reporting. Classified confidential as it reveals internal cost structure.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Flag' ;
    rdfs:comment 'Indicates whether this order line was designated as a gift by the consumer. True when the consumer selected gift options (e.g., gift wrapping, gift message). Supports gifting program analytics and packaging operations.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment 'GS1-standard Global Trade Item Number for the product on this line. Enables cross-retailer product identification, barcode scanning, and regulatory traceability. Conforms to GS1 GTIN-8, GTIN-12 (UPC), GTIN-13 (EAN), or GTIN-14 formats.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether the product on this order line is classified as a hazardous material requiring special handling, packaging, or shipping restrictions. True for products subject to DOT, IATA, or EPA hazmat regulations. Critical for carrier compliance and Safety Data Sheet (SDS) requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturned rdf:type rdf:Property ;
    rdfs:label 'Is Returned' ;
    rdfs:comment 'Indicates whether this order line has been subject to a consumer return. True when a return has been initiated or completed. Enables return rate analysis by SKU, category, and consumer segment for product quality and consumer experience programs.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Line Discount Amount' ;
    rdfs:comment 'Total monetary discount applied to this order line, including promotional discounts, coupon redemptions, and loyalty rewards. Used for Trade Promotion Management (TPM) analysis and margin reporting.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Line Discount Pct' ;
    rdfs:comment 'Discount rate applied to this order line expressed as a percentage of the gross unit price. Enables promotional effectiveness analysis and margin impact assessment without requiring price recalculation.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNetAmount rdf:type rdf:Property ;
    rdfs:label 'Line Net Amount' ;
    rdfs:comment 'Net monetary value of this order line after all discounts have been applied but before tax. Core revenue recognition field for DTC channel P&L reporting and COGS analysis. Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT monetary component.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential position of this line item within the parent DTC order. Used for ordering, display, and reconciliation of multi-line orders. Satisfies TRANSACTION_LINE LINE_SEQUENCE category.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineSubtotal rdf:type rdf:Property ;
    rdfs:label 'Line Subtotal' ;
    rdfs:comment 'Gross line value before tax, calculated as unit_price multiplied by quantity_ordered. Represents the pre-discount, pre-tax revenue contribution of this line item.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Final total amount for this order line inclusive of all discounts and taxes. Represents the actual amount charged to the consumer for this line item. Used for revenue reporting and consumer billing reconciliation.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Commercial name of the product SKU as displayed to the consumer at time of purchase. Captured at order time to preserve historical accuracy independent of future product name changes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedShipDate rdf:type rdf:Property ;
    rdfs:label 'Promised Ship Date' ;
    rdfs:comment 'Date on which the order line was committed to ship to the consumer at time of order placement. Basis for Available to Promise (ATP) and Service Level Agreement (SLA) compliance measurement.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityCancelled rdf:type rdf:Property ;
    rdfs:label 'Quantity Cancelled' ;
    rdfs:comment 'Number of units cancelled on this order line, either by the consumer or due to inventory unavailability. Supports cancellation rate analysis and demand signal correction.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'Number of units of the SKU ordered by the consumer on this line. Basis for demand planning, inventory reservation, and fulfillment processing. Satisfies TRANSACTION_LINE LINE_QUANTITY category.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityShipped rdf:type rdf:Property ;
    rdfs:label 'Quantity Shipped' ;
    rdfs:comment 'Actual number of units of the SKU dispatched to the consumer for this line. May differ from quantity_ordered due to partial fulfillment, Out of Stock (OOS) situations, or split shipments. Key metric for On Time In Full (OTIF) measurement.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether this order line is subject to a regulatory hold preventing fulfillment (e.g., FDA product recall, CPSC safety alert, EU REACH restriction). True when a hold is active. Supports compliance-driven order management and consumer safety programs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subscriptionFlag rdf:type rdf:Property ;
    rdfs:label 'Subscription Flag' ;
    rdfs:comment 'Indicates whether this order line was generated as part of a recurring subscription program (e.g., Subscribe & Save). True for subscription-triggered lines. Enables subscription revenue tracking and replenishment program analysis.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit of measure in which the SKU quantity is expressed on this order line (e.g., EA=Each, CS=Case, PK=Pack). Aligns with GS1 and SAP UOM standards for consistent quantity interpretation. [ENUM-REF-CANDIDATE: EA|CS|PK|BX|KG|LB|OZ|L|ML — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Gross selling price per unit of the SKU at the time of order placement, before any discounts or promotions. Represents the consumer-facing price (RSP/MSRP or DTC-specific price). Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT category.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'FK to logistics.carrier' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:inboundReceiptId rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Id' ;
    rdfs:comment 'Foreign key linking to distribution.inbound_receipt. Business justification: When a consumer return arrives at a DC, an inbound receipt formally records its acceptance into inventory. Linking dtc_return to inbound_receipt enables reverse logistics traceability, quality inspect' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundReceipt .

ind:nonconformanceId rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Id' ;
    rdfs:comment 'Foreign key linking to quality.nonconformance. Business justification: DTC returns with quality_defect_code or safety_incident_flag trigger nonconformance records in the quality system. Consumer goods QA teams require this traceability to aggregate consumer-reported defe' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Nonconformance .

ind:productComplaintId rdf:type rdf:Property ;
    rdfs:label 'Product Complaint Id' ;
    rdfs:comment 'Foreign key linking to quality.product_complaint. Business justification: DTC returns with safety_incident_flag or quality_defect_code must be traceable to a formal product complaint record for regulatory adverse event reporting and recall management. Consumer goods regulat' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductComplaint .

ind:recallEventId rdf:type rdf:Property ;
    rdfs:label 'Recall Event Id' ;
    rdfs:comment 'Foreign key linking to inventory.recall_event. Business justification: Returns triggered by product recalls must link to the inventory recall_event record for recall effectiveness measurement (quantity recovered vs. distributed) and regulatory closure reporting. dtc_retu' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecallEvent .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the return request was approved by the consumer service team or automated system. Used for SLA tracking and return processing time analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Customer service case or ticket number associated with this return request in the CRM system. Enables cross-referencing between the return record and the consumer service interaction history in Salesforce Consumer Goods Cloud.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Consumer Satisfaction Score' ;
    rdfs:comment 'Post-return consumer satisfaction rating collected via survey (typically 1–5 or 1–10 scale). Used as an input to Net Promoter Score (NPS) calculations and consumer experience improvement programs. Collected via Salesforce Consumer Goods Cloud post-return survey.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Final disposition decision for the returned product after quality inspection. Drives inventory management, COGS impact, and regulatory compliance for product destruction. Valid values: restock (return to sellable inventory), refurbish (rework required), destroy (product destroyed per policy), return_to_vendor (sent back to supplier), quarantine (held pending investigation).' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Review Flag' ;
    rdfs:comment 'Indicates whether this return has been flagged for manual fraud review based on fraud_risk_score or other risk signals. Supports loss prevention workflows and return abuse management.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudRiskScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Score' ;
    rdfs:comment 'Numeric risk score (0.00–100.00) assigned by the fraud detection system to assess the likelihood of return fraud. Drives manual review routing and automated rejection thresholds. Supports loss prevention analytics.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyPointsRefunded rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Refunded' ;
    rdfs:comment 'Number of loyalty program points credited back to the consumer\'s account as part of the refund. Populated when refund_method is \'loyalty_points\' or when loyalty points were originally redeemed on the order. Supports loyalty program financial reconciliation.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Net Refund Amount' ;
    rdfs:comment 'Net monetary amount actually refunded to the consumer after deducting any restocking fees or adjustments from the gross refund amount. Used for financial settlement and consumer account reconciliation.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productConditionCode rdf:type rdf:Property ;
    rdfs:label 'Product Condition Code' ;
    rdfs:comment 'Assessed condition of the returned product upon receipt at the warehouse. Determines disposition (restock, refurbish, destroy) and impacts inventory valuation. Assessed by warehouse quality inspection team per GMP guidelines.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDefectCode rdf:type rdf:Property ;
    rdfs:label 'Quality Defect Code' ;
    rdfs:comment 'Standardized quality defect classification code assigned when the return reason indicates a product quality issue (defective, damaged). Feeds into the Quality Management (QM) system for defect trending, root cause analysis, and regulatory reporting. Sourced from SAP QM or Siemens Opcenter MES quality module.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date on which the returned product was physically received at the warehouse or returns processing center. Triggers refund processing and inventory restock workflows. Sourced from Blue Yonder WMS goods receipt.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Gross monetary amount to be refunded or already refunded to the consumer, in the transaction currency. Represents the base refund before any deductions such as restocking fees. Used for financial reconciliation and COGS impact reporting.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Refund Issued Date' ;
    rdfs:comment 'Date on which the refund was issued to the consumer. Used for financial reconciliation, Days Sales Outstanding (DSO) adjustment, and consumer satisfaction SLA measurement.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'Method by which the refund is issued to the consumer. Drives financial processing workflows and consumer communication. Valid values: original_payment (refund to original payment instrument), store_credit (credit to consumer account), loyalty_points (converted to loyalty program points), bank_transfer (direct bank transfer), gift_card (issued as gift card value).' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Required' ;
    rdfs:comment 'Indicates whether this return requires submission of a regulatory report to a governing body (FDA, CPSC, EPA). Driven by safety_incident_flag, product category, and jurisdiction. Supports compliance workflow automation and audit readiness.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date on which the return request was rejected. Populated only when return_status is \'rejected\'. Used for consumer communication SLA tracking and dispute resolution analytics.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Reason code explaining why the return request was rejected. Populated only when return_status is \'rejected\'. Supports consumer dispute resolution and return policy analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Calendar date on which the consumer submitted the return request. Used for SLA measurement, return window eligibility validation, and trend reporting.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) when the consumer submitted the return request. Used for SLA measurement at sub-day granularity and audit trail purposes.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restockingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Amount' ;
    rdfs:comment 'Fee deducted from the refund amount to cover reverse logistics and restocking costs, where applicable per return policy. Used for net refund calculation and cost recovery reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnChannel rdf:type rdf:Property ;
    rdfs:label 'Return Channel' ;
    rdfs:comment 'Digital or service channel through which the consumer initiated the return request. Distinct from return method (physical logistics). Used for channel analytics and consumer experience optimization.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnLabelTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Return Label Tracking Number' ;
    rdfs:comment 'Carrier tracking number assigned to the prepaid return shipping label issued to the consumer. Enables reverse logistics tracking and proof-of-return verification. Sourced from Blue Yonder WMS or carrier integration.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnMethod rdf:type rdf:Property ;
    rdfs:label 'Return Method' ;
    rdfs:comment 'Physical method by which the consumer returns the product. Determines logistics handling, prepaid label issuance, and reverse logistics cost allocation. Valid values: mail_in (consumer ships via postal/courier), drop_off (consumer drops at designated location), carrier_pickup (carrier collects from consumer address), in_store (returned at retail partner location).' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnNumber rdf:type rdf:Property ;
    rdfs:label 'Return Number' ;
    rdfs:comment 'Externally-visible, human-readable Return Merchandise Authorization (RMA) number assigned to this return request. Used in consumer communications, shipping labels, and customer service interactions. Sourced from Salesforce Consumer Goods Cloud or SAP SD returns order.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnPolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Return Policy Version' ;
    rdfs:comment 'Version identifier of the return policy that was in effect at the time the return was requested. Ensures consistent policy application and supports audit trails for policy change impact analysis.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnQuantity rdf:type rdf:Property ;
    rdfs:label 'Return Quantity' ;
    rdfs:comment 'Number of units of the product being returned in this return request. Used for inventory restock planning, refund calculation, and return rate KPI computation.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Free-text narrative provided by the consumer describing the specific reason for the return. Supplements the standardized return reason code with qualitative detail for quality analysis and consumer service resolution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnStatus rdf:type rdf:Property ;
    rdfs:label 'Return Status' ;
    rdfs:comment 'Current lifecycle state of the return request. Tracks the return workflow from initial consumer request through final resolution. Valid values: requested (consumer submitted), approved (return authorized), received (item received at warehouse), refunded (refund issued), rejected (return denied), cancelled (consumer cancelled). [ENUM-REF-CANDIDATE: requested|approved|received|refunded|rejected|cancelled — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnWindowEligible rdf:type rdf:Property ;
    rdfs:label 'Return Window Eligible' ;
    rdfs:comment 'Indicates whether the return request was submitted within the brand\'s published return policy window (e.g., 30 days from delivery). Drives automated approval/rejection workflows and consumer communication.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Indicates whether the return involves a consumer safety incident (e.g., injury, adverse reaction, product hazard). When true, triggers mandatory regulatory reporting workflows to FDA, CPSC, or EPA as applicable. Critical for product safety compliance and recall management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsResponseId rdf:type rdf:Property ;
    rdfs:label 'Nps Response Id' ;
    rdfs:comment 'Unique surrogate identifier for each NPS survey response record in the Consumer Goods consumer feedback system. Primary key for the nps_response data product.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'Name of the CPG brand being evaluated in this NPS survey response. Stored denormalized for direct use in brand health reporting and consumer sentiment dashboards without requiring a join to the brand master.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedLoopActionDate rdf:type rdf:Property ;
    rdfs:label 'Closed Loop Action Date' ;
    rdfs:comment 'Date on which the closed-loop follow-up action was completed or resolved for this NPS response. Used to measure response time SLA compliance for consumer feedback management programs.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedLoopStatus rdf:type rdf:Property ;
    rdfs:label 'Closed Loop Status' ;
    rdfs:comment 'Status of the closed-loop consumer feedback management action triggered by this NPS response. Tracks whether a follow-up action has been initiated, is in progress, resolved, or escalated — particularly critical for Detractor responses to recover consumer relationships.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Flag' ;
    rdfs:comment 'Indicates whether the consumer provided valid consent for their NPS survey response data to be collected, stored, and used for brand analytics and personalization purposes. Mandatory for GDPR and CCPA compliance in consumer data processing.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumerSegment rdf:type rdf:Property ;
    rdfs:label 'Consumer Segment' ;
    rdfs:comment 'Marketing segmentation label assigned to the consumer at the time of survey dispatch (e.g., Loyalist, Occasional Buyer, Lapsed, New Consumer). Enables NPS analysis by consumer segment for targeted closed-loop follow-up and personalization programs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this NPS response was ingested into the Databricks Silver Layer (e.g., Salesforce Consumer Goods Cloud, SAP S/4HANA, TradeEdge, Nielsen IQ, Custom Survey Platform, Third-Party Panel). Supports data lineage and audit traceability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseChannel rdf:type rdf:Property ;
    rdfs:label 'Purchase Channel' ;
    rdfs:comment 'The retail or distribution channel through which the consumer purchased the product prior to receiving this NPS survey (e.g., E-Commerce, Retail Store, DTC, Wholesale, DSD, Pharmacy). Enables channel-level NPS benchmarking for distribution and channel management strategy.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatBuyerFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Buyer Flag' ;
    rdfs:comment 'Indicates whether the consumer had made more than one purchase of the brand or product prior to submitting this NPS response. Enables differentiation of NPS scores between first-time and repeat buyers for consumer retention and NPD analytics.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:respondentCategory rdf:type rdf:Property ;
    rdfs:label 'Respondent Category' ;
    rdfs:comment 'Classification of the consumer based on their NPS score: Promoter (score 9-10), Passive (score 7-8), or Detractor (score 0-6). Derived classification stored for direct use in brand health dashboards, consumer segmentation, and closed-loop follow-up prioritization.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Response Reference Number' ;
    rdfs:comment 'Externally visible alphanumeric reference number assigned to this NPS survey response, used for closed-loop follow-up, consumer service case creation, and cross-system traceability (e.g., CRM ticket linkage).' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current lifecycle status of the NPS survey response record: Submitted (complete response received), Partial (survey started but not completed), Abandoned (survey opened but no score entered), Invalid (failed validation rules), Closed (response processed and closed-loop action completed).' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the consumer submitted the NPS survey response. Enables intraday analysis, response latency measurement, and audit trail for closed-loop feedback management.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sentimentLabel rdf:type rdf:Property ;
    rdfs:label 'Sentiment Label' ;
    rdfs:comment 'Categorical sentiment classification derived from NLP analysis of the verbatim comment (Positive, Neutral, Negative, Mixed). Complements the numeric sentiment score for business-friendly reporting and consumer feedback dashboards.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'Numeric sentiment polarity score derived from NLP analysis of the verbatim comment, ranging from -1.0 (most negative) to +1.0 (most positive). Stored as a business attribute to enable sentiment trend analysis and AI/ML consumer intelligence without re-processing raw text.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceResponseRef rdf:type rdf:Property ;
    rdfs:label 'Source Response Ref' ;
    rdfs:comment 'The native identifier of this NPS response record in the originating operational system of record (e.g., Salesforce Survey Response ID, SAP interaction record ID). Enables cross-system traceability and deduplication during Silver Layer ingestion.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyChannel rdf:type rdf:Property ;
    rdfs:label 'Survey Channel' ;
    rdfs:comment 'The communication channel through which the NPS survey was delivered to the consumer (e.g., Email, In-App, SMS, Post-Purchase, Web, IVR). Enables channel-level response rate analysis and omnichannel consumer engagement optimization. [ENUM-REF-CANDIDATE: Email|In-App|SMS|Post-Purchase|Web|IVR — promote to reference product]' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyDate rdf:type rdf:Property ;
    rdfs:label 'Survey Date' ;
    rdfs:comment 'Calendar date on which the consumer submitted the NPS survey response. Used as the primary business event date for brand health trend analysis, period-over-period NPS reporting, and S&OP consumer sentiment inputs.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Survey Trigger Event' ;
    rdfs:comment 'The business event that triggered the dispatch of this NPS survey to the consumer (e.g., Post-Purchase, Post-Delivery, Post-Support interaction, Periodic relationship survey, Event-Based, Onboarding). Enables analysis of NPS scores by consumer journey touchpoint.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyVersion rdf:type rdf:Property ;
    rdfs:label 'Survey Version' ;
    rdfs:comment 'Version identifier of the NPS survey questionnaire used to capture this response. Ensures comparability of NPS scores across survey redesigns and supports longitudinal brand health trend analysis.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topicTags rdf:type rdf:Property ;
    rdfs:label 'Topic Tags' ;
    rdfs:comment 'Comma-separated list of business topic labels extracted from the verbatim comment via NLP text classification (e.g., \'packaging,scent,value-for-money,availability\'). Enables topic-level consumer feedback analysis for product development, quality, and marketing teams.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatimComment rdf:type rdf:Property ;
    rdfs:label 'Verbatim Comment' ;
    rdfs:comment 'Free-text open-ended comment provided by the consumer explaining their NPS score. Contains qualitative consumer sentiment, product feedback, and brand perception insights used for text analytics, sentiment analysis, and AI/ML-driven consumer intelligence programs.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each consumer interaction record in the silver layer lakehouse. Primary key for this data product.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountCallId rdf:type rdf:Property ;
    rdfs:label 'Account Call Id' ;
    rdfs:comment 'Foreign key linking to sales.account_call. Business justification: Customer service interactions often trigger sales account calls; linking allows tracking follow-up actions and performance metrics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountCall .

ind:parentInteractionId rdf:type rdf:Property ;
    rdfs:label 'Parent Interaction Id' ;
    rdfs:comment 'Self-referencing identifier linking this interaction to a parent case when it is a follow-up, escalation, or sub-case of a prior interaction. Enables interaction hierarchy and repeat-contact chain analysis.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:proofOfDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Id' ;
    rdfs:comment 'Foreign key linking to logistics.proof_of_delivery. Business justification: Delivery dispute resolution in consumer goods DTC requires linking consumer interactions directly to the POD record. Contact center agents reference POD signature, photo attachments, discrepancy flags' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProofOfDelivery .

ind:submissionId rdf:type rdf:Property ;
    rdfs:label 'Submission Id' ;
    rdfs:comment 'Foreign key linking to regulatory.submission. Business justification: interaction.regulatory_report_number is a denormalized reference to a regulatory submission filed as a result of a consumer adverse event or complaint interaction. A direct FK to submission enables en' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:tradeAccountId rdf:type rdf:Property ;
    rdfs:label 'Trade Account Id' ;
    rdfs:comment 'Foreign key linking to customer.trade_account. Business justification: Support interactions tied to a specific trade account enable account-level SLA tracking and issue resolution reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAccount .

ind:adverseEventFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Flag' ;
    rdfs:comment 'Indicates whether this interaction has been classified as an adverse event report (e.g., allergic reaction, injury, illness linked to product use). Triggers mandatory regulatory reporting workflows under FDA, CPSC, and EU REACH regulations.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumerConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Consumer Consent Flag' ;
    rdfs:comment 'Indicates whether the consumer provided explicit consent for their interaction data to be used for quality improvement, marketing analytics, or regulatory reporting purposes at the time of the interaction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactReasonCode rdf:type rdf:Property ;
    rdfs:label 'Contact Reason Code' ;
    rdfs:comment 'Standardized code categorizing the specific reason for consumer contact (e.g., product defect, packaging issue, allergic reaction, pricing query, loyalty redemption). Enables granular root cause analysis and product quality reporting. [ENUM-REF-CANDIDATE: promote to reference product with full taxonomy]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Expiry Date' ;
    rdfs:comment 'The date after which this interaction record must be purged or anonymized in compliance with GDPR right-to-erasure and CCPA data retention policies. Calculated based on interaction type and applicable jurisdiction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total duration of the consumer interaction in seconds, applicable primarily to real-time channels (call center, live chat). Used for agent efficiency KPIs, average handle time (AHT) reporting, and capacity planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether this interaction was escalated to a higher-tier support team, supervisor, or regulatory body during its lifecycle. Drives escalation workflow reporting and quality management reviews.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Categorical reason why the interaction was escalated. Null if escalation_flag is False. Supports root cause analysis and process improvement initiatives. [ENUM-REF-CANDIDATE: sla_breach|consumer_request|regulatory_requirement|repeat_contact|safety_concern|management_review — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionDescription rdf:type rdf:Property ;
    rdfs:label 'Interaction Description' ;
    rdfs:comment 'Full narrative text of the consumer interaction as captured by the agent or automated system. Contains the consumer\'s verbatim concern, inquiry, or feedback. Classified confidential due to potential inclusion of personal context.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle state of the interaction within the CRM case management workflow. Drives SLA monitoring, escalation triggers, and operational dashboards.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The precise date and time when the consumer interaction was initiated or first recorded. This is the principal real-world event time used for SLA calculation, trend analysis, and regulatory reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the nature of the consumer touchpoint. Drives routing, SLA assignment, and regulatory reporting workflows. \'adverse_event_report\' triggers mandatory escalation per FDA/CPSC requirements.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBotHandled rdf:type rdf:Property ;
    rdfs:label 'Is Bot Handled' ;
    rdfs:comment 'Indicates whether this interaction was fully or partially handled by an automated bot or virtual assistant without human agent involvement. Used to measure automation rate and bot containment KPIs.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Audit timestamp of the most recent update to this interaction record. Used for incremental data pipeline processing and change tracking in the silver layer.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to the interaction, determining routing urgency and SLA tier. Critical priority is automatically assigned to adverse event reports and regulatory complaints per CPSC and FDA guidelines.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'Date on which the consumer purchased the product referenced in this interaction, as reported by the consumer or verified via POS/loyalty data. Used for warranty validation, product age assessment, and adverse event timeline analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repeatContactFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Contact Flag' ;
    rdfs:comment 'Indicates whether this interaction is a follow-up or repeat contact from the same consumer regarding the same issue within a defined lookback window. Key metric for first-contact resolution (FCR) KPI measurement.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Agent-authored narrative documenting the resolution actions taken, root cause identified, and outcome communicated to the consumer. Supports quality audits and repeat-contact analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the consumer interaction was formally resolved or closed. Used to calculate actual resolution time against SLA targets and for consumer satisfaction measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'Categorical classification of the resolution action taken to close this interaction. Drives cost-of-service analytics, consumer satisfaction correlation, and resolution effectiveness reporting. [ENUM-REF-CANDIDATE: refund|replacement|coupon|apology|information_provided|no_action_required|regulatory_referral — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the interaction exceeded its defined SLA target resolution time. True if resolution_timestamp minus interaction_timestamp exceeds sla_target_hours. Drives escalation and quality reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'The contracted or policy-defined maximum number of hours within which this interaction must be resolved, based on interaction type and channel. Used for SLA compliance reporting and KPI dashboards.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief, structured subject line or title summarizing the consumer interaction. Used for case categorization, search, and reporting in CRM systems.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upcCode rdf:type rdf:Property ;
    rdfs:label 'Upc Code' ;
    rdfs:comment 'The Universal Product Code (UPC) or GTIN of the product as reported or scanned by the consumer. Enables precise product identification when the consumer provides packaging information, supporting recall and quality investigations.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionCampaignId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Subscription acquisition attribution: DTC subscription programs in consumer goods track which marketing campaign drove each subscription sign-up for campaign ROI, LTV-by-campaign, and acquisition cost' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:deliveryAddressId rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Id' ;
    rdfs:comment 'Reference to the consumer\'s preferred delivery address for subscription fulfillment. Links to the address master for DSD (Direct Store Delivery) routing and last-mile logistics planning via Blue Yonder WMS.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:revenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Id' ;
    rdfs:comment 'Foreign key linking to finance.revenue_recognition. Business justification: Subscription contracts require deferred revenue recognition schedules under ASC 606/IFRS 15. Consumer goods subscription programs (auto-replenishment) must link to revenue recognition records for defe' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognition .

ind:skuPlanningParamId rdf:type rdf:Property ;
    rdfs:label 'Sku Planning Param Id' ;
    rdfs:comment 'Foreign key linking to supply.sku_planning_param. Business justification: Subscription fulfillment is governed by SKU-level planning parameters (minimum order quantity, shelf life, order multiples, reorder point). Consumer goods subscription operations must validate each re' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuPlanningParam .

ind:supplierContractId rdf:type rdf:Property ;
    rdfs:label 'Supplier Contract Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_contract. Business justification: Ensures Subscription sourcing audit linking each consumer subscription to the supplier contract governing the product supply.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierContract .

ind:acquisitionSource rdf:type rdf:Property ;
    rdfs:label 'Acquisition Source' ;
    rdfs:comment 'Marketing source or campaign that drove the consumer to subscribe (e.g., email campaign code, paid search, influencer referral, loyalty program). Used for marketing ROI (Return on Investment) attribution and SOV (Share of Voice) analysis.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether the subscription is configured to automatically renew at the end of each billing cycle (True) or requires explicit consumer action to continue (False). Governs recurring revenue recognition and consumer notification obligations.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCycleDay rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Day' ;
    rdfs:comment 'Day of the month (1–31) on which the subscription billing charge is processed. Governs the recurring payment schedule and aligns with the consumer\'s preferred billing date. Used in accounts receivable and DSO (Days Sales Outstanding) reporting.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Calendar date on which the consumer formally cancelled the subscription. Distinct from end_date (which may be a future scheduled end). Used in churn cohort analysis and subscription tenure reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Consumer-stated or system-derived reason for cancelling the subscription. Populated when subscription_status transitions to \'cancelled\'. Critical input for churn analysis, NPS (Net Promoter Score) correlation, and consumer retention strategy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'Percentage discount applied to the subscription price per billing cycle, expressed as a decimal (e.g., 0.1500 = 15%). Reflects subscriber loyalty pricing, promotional offers, or TPM (Trade Promotion Management) funded discounts.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Calendar date on which the subscription is scheduled to end or was terminated. Null for open-ended subscriptions. Represents EFFECTIVE_UNTIL for this agreement. Populated on cancellation or plan expiry.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:failedPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Failed Payment Count' ;
    rdfs:comment 'Cumulative number of failed payment attempts on this subscription since inception. Used to trigger dunning workflows, payment retry logic, and subscription suspension rules. Key indicator for revenue leakage management.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Cadence at which the subscription order is automatically triggered and fulfilled. Drives the replenishment schedule and next order date calculation. Key input for demand planning and S&OP forecasting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'Calendar date of the most recently fulfilled subscription order. Used to validate subscription activity, detect stalled subscriptions, and support FEFO (First Expired First Out) inventory allocation for replenishment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Actual amount charged to the consumer per billing cycle after applying the discount rate. Equals subscription_price × (1 - discount_rate). Used in revenue recognition, COGS (Cost of Goods Sold) analysis, and financial reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextOrderDate rdf:type rdf:Property ;
    rdfs:label 'Next Order Date' ;
    rdfs:comment 'Scheduled calendar date for the next automatic order generation under this subscription. Used by fulfillment systems for ATP (Available to Promise) checks and demand sensing. Updated after each successful order cycle.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pauseEndDate rdf:type rdf:Property ;
    rdfs:label 'Pause End Date' ;
    rdfs:comment 'Calendar date on which the subscription pause is scheduled to end and auto-replenishment is set to resume. Null if the pause is indefinite. Used in demand forecasting to anticipate reactivation volumes.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pauseReason rdf:type rdf:Property ;
    rdfs:label 'Pause Reason' ;
    rdfs:comment 'Consumer-stated reason for pausing the subscription. Populated when subscription_status transitions to \'paused\'. Used in consumer retention analysis and proactive re-engagement campaign targeting.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pauseStartDate rdf:type rdf:Property ;
    rdfs:label 'Pause Start Date' ;
    rdfs:comment 'Calendar date on which the consumer-initiated subscription pause became effective. Used to calculate pause duration and adjust next_order_date upon resumption. Supports consumer retention lifecycle tracking.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'Category of payment instrument used for recurring subscription billing (e.g., credit_card, digital_wallet). Stored as a type reference only — no raw card or account data is stored here per PCI DSS compliance. Supports payment failure analysis and retry logic.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTokenReference rdf:type rdf:Property ;
    rdfs:label 'Payment Token Reference' ;
    rdfs:comment 'Tokenized reference identifier for the consumer\'s stored payment method, issued by the payment processor vault. Never contains raw card or bank account data. Used to initiate recurring charges without storing PCI-sensitive data. Compliant with PCI DSS tokenization requirements.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:price rdf:type rdf:Property ;
    rdfs:label 'Price' ;
    rdfs:comment 'Gross price charged to the consumer per billing cycle before any discounts are applied. Expressed in the subscription\'s billing currency. Used in subscription revenue forecasting and CLTV (Customer Lifetime Value) calculations.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Number of units of the subscribed SKU to be fulfilled per order cycle. Drives replenishment volume, inventory reservation, and demand planning inputs for S&OP (Sales and Operations Planning).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Calendar date on which the subscription became effective and the first order cycle was initiated. Represents EFFECTIVE_FROM for this agreement. Used in cohort analysis and subscription tenure calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Subscription Number' ;
    rdfs:comment 'Externally visible, human-readable subscription reference number communicated to the consumer in confirmation emails, invoices, and customer service interactions. Serves as the BUSINESS_IDENTIFIER for this agreement.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle state of the subscription. \'active\' = fulfilling orders; \'paused\' = consumer-initiated hold; \'cancelled\' = permanently terminated; \'pending\' = awaiting first payment confirmation; \'expired\' = plan term ended without renewal. Drives LIFECYCLE_STATUS for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionType rdf:type rdf:Property ;
    rdfs:label 'Subscription Type' ;
    rdfs:comment 'Classification of the subscription program type. \'auto_replenishment\' covers single-SKU DTC replenishment; \'subscription_box\' covers curated multi-product boxes; \'bundle\' covers fixed product bundles; \'trial\' covers introductory trial subscriptions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrdersFulfilled rdf:type rdf:Property ;
    rdfs:label 'Total Orders Fulfilled' ;
    rdfs:comment 'Cumulative count of successfully fulfilled subscription orders since the subscription start date. Non-derived operational counter maintained by the fulfillment system. Used in subscription tenure analysis and OTIF (On Time In Full) performance tracking.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trialEndDate rdf:type rdf:Property ;
    rdfs:label 'Trial End Date' ;
    rdfs:comment 'Calendar date on which the trial period ends and standard subscription billing commences. Null for non-trial subscriptions. Used to trigger trial-to-paid conversion communications and revenue recognition timing.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialFlag rdf:type rdf:Property ;
    rdfs:label 'Trial Flag' ;
    rdfs:comment 'Indicates whether this subscription was initiated as a trial or introductory offer (True) or as a standard paid subscription (False). Used to segment trial-to-paid conversion analytics and NPD (New Product Development) launch performance.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Reference to the corresponding vendor/supplier master record in the ERP system (SAP S/4HANA or Oracle Cloud ERP) for this carrier. Links the carrier master to the procurement and accounts payable vendor record for freight invoice processing and payment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:apiTrackingCapable rdf:type rdf:Property ;
    rdfs:label 'Api Tracking Capable' ;
    rdfs:comment 'Indicates whether the carrier provides a real-time shipment tracking API for track-and-trace integration. Enables automated shipment status updates in the TMS without manual EDI 214 processing. Used in carrier technology capability assessment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current lifecycle status of the carrier in the Consumer Goods approved carrier program. Active carriers are eligible for shipment tendering. Suspended carriers are temporarily blocked pending compliance review. Blacklisted carriers are permanently disqualified. Drives carrier selection eligibility in TMS routing.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Primary transportation mode classification of the carrier. Drives rate card selection, shipment planning rules, and EDI transaction sets. TL (Truckload), LTL (Less-Than-Truckload), parcel, rail, ocean, air, intermodal, and courier are the standard classifications in consumer goods logistics. [ENUM-REF-CANDIDATE: truckload|less_than_truckload|parcel|rail|ocean|air|intermodal|courier — promote to reference product]' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainCapable rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Capable' ;
    rdfs:comment 'Indicates whether the carrier has certified temperature-controlled transportation capability (refrigerated or frozen) for cold-chain compliant shipments of health, hygiene, and personal care products requiring temperature management. Critical for product safety and regulatory compliance.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Expiry date of the current master transportation services agreement. Triggers contract renewal workflows and rate renegotiation processes. Shipment tendering to the carrier may be restricted after this date if no renewal is in place.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date of the current master transportation services agreement between Consumer Goods and the carrier. Defines the period during which contracted rates and service commitments are valid.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryOfRegistration rdf:type rdf:Property ;
    rdfs:label 'Country Of Registration' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the carrier is legally registered and incorporated. Used for cross-border compliance checks, customs documentation, and carrier eligibility for specific trade lanes.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Number' ;
    rdfs:comment 'Unique identifier assigned by the U.S. Federal Motor Carrier Safety Administration (FMCSA) to commercial motor carriers operating in interstate commerce. Required for regulatory compliance verification and safety rating lookup. Mandatory for US-based trucking carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet Data Universal Numbering System (DUNS) number uniquely identifying the carrier\'s business entity globally. Used for supplier risk assessment, credit verification, and EDI trading partner identification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapable rdf:type rdf:Property ;
    rdfs:label 'Edi Capable' ;
    rdfs:comment 'Indicates whether the carrier supports Electronic Data Interchange (EDI) for automated exchange of shipment tenders (204), load tenders (990), shipment status (214), and freight invoices (210). EDI-capable carriers are preferred for high-volume automated tendering in the TMS.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediCode rdf:type rdf:Property ;
    rdfs:label 'Edi Code' ;
    rdfs:comment 'Carrier\'s EDI interchange identifier used in the ISA segment of X12 EDI transactions. Combined with the EDI qualifier, this uniquely identifies the carrier as an EDI trading partner. Required for automated tender and status message routing.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediQualifier rdf:type rdf:Property ;
    rdfs:label 'Edi Qualifier' ;
    rdfs:comment 'Two-digit qualifier code identifying the type of EDI sender/receiver identifier used in ISA segment of X12 EDI transactions (e.g., 02 = DUNS, 08 = UCC/EAN, ZZ = Mutually Defined). Required for EDI trading partner setup and message routing.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmcsaRatingDate rdf:type rdf:Property ;
    rdfs:label 'Fmcsa Rating Date' ;
    rdfs:comment 'Date on which the current FMCSA safety rating was issued or last updated. Used to assess rating currency and trigger re-evaluation workflows when ratings are older than the compliance review threshold.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fmcsaSafetyRating rdf:type rdf:Property ;
    rdfs:label 'Fmcsa Safety Rating' ;
    rdfs:comment 'Official safety fitness rating assigned by the FMCSA to motor carriers based on compliance reviews and safety audits. Satisfactory rating is required for carrier approval in Consumer Goods\' carrier program. Conditional or Unsatisfactory ratings trigger carrier review or suspension. Mandatory compliance field for US trucking carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Description of the carrier\'s operational geographic coverage scope, including regions, countries, or trade lanes served. Used in TMS routing logic to filter eligible carriers by origin-destination pair. Examples: \'Continental US\', \'US-Canada cross-border\', \'Trans-Pacific\', \'EU domestic\'.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Hazmat Cert Expiry Date' ;
    rdfs:comment 'Expiry date of the carrier\'s hazardous materials transportation certification. Triggers compliance alerts and blocks HAZMAT shipment tendering to the carrier if certification has lapsed.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Indicates whether the carrier holds valid certification to transport hazardous materials (HAZMAT) as defined by DOT 49 CFR. Required for shipments of aerosols, flammable products, and chemical-based consumer goods. Validated against DOT HAZMAT registration database.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Full street address of the carrier\'s principal place of business or corporate headquarters. Used for legal correspondence, contract execution, and regulatory filings. Includes street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCode rdf:type rdf:Property ;
    rdfs:label 'Iata Code' ;
    rdfs:comment '2-3 character alphanumeric code assigned by IATA to identify air freight carriers. Used for air waybill generation, air freight booking, and international air cargo tracking. Applicable only to air freight carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCargoAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Cargo Amount' ;
    rdfs:comment 'Maximum coverage amount (in USD) of the carrier\'s cargo insurance policy covering loss or damage to goods in transit. Consumer Goods mandates minimum cargo insurance thresholds based on shipment value profiles. Critical for high-value CPG product shipments.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number of the carrier\'s current certificate of insurance (COI) on file with Consumer Goods. Used for insurance verification, claims processing, and audit trail of carrier compliance documentation.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'Date on which the carrier\'s insurance certificate expires. Triggers automated renewal reminder workflows and carrier status suspension if insurance lapses. Critical compliance field for carrier program management.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Liability Amount' ;
    rdfs:comment 'Maximum coverage amount (in USD) of the carrier\'s general liability insurance policy. Consumer Goods requires minimum liability coverage thresholds as a condition of carrier approval. Validated during carrier onboarding and annual renewal.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'Date of the most recent compliance review conducted for this carrier, covering safety ratings, insurance certificates, HAZMAT certifications, and contractual obligations. Used to schedule periodic re-evaluations and flag overdue reviews.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full legal registered business name of the transportation carrier as filed with regulatory authorities (FMCSA, state business registry). Used in contracts, freight invoices, and regulatory filings. Must match the name on the carrier\'s operating authority.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Max Payload Kg' ;
    rdfs:comment 'Maximum weight capacity in kilograms that the carrier\'s standard equipment can transport per shipment. Used in load planning, shipment consolidation, and carrier eligibility checks to prevent overweight violations.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mcNumber rdf:type rdf:Property ;
    rdfs:label 'Mc Number' ;
    rdfs:comment 'Operating authority number issued by the FMCSA to for-hire motor carriers transporting regulated commodities in interstate commerce. Distinct from DOT number — MC number grants operating authority while DOT number is for safety registration. Used in carrier compliance validation.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date on which the carrier was formally approved and onboarded into Consumer Goods\' carrier program, completing all compliance checks, insurance verification, and EDI/API setup. Marks the start of the carrier\'s operational eligibility.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Contractual payment terms agreed with the carrier for freight invoice settlement. Drives accounts payable scheduling and cash flow planning. Standard terms in consumer goods logistics range from Net 15 to Net 60 days.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCarrier rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier' ;
    rdfs:comment 'Indicates whether the carrier has been designated as a preferred carrier in Consumer Goods\' carrier program, typically based on negotiated rates, service performance, and strategic partnership status. Preferred carriers receive priority in TMS automated tendering sequences.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Business email address of the primary carrier contact for operational communications, tender notifications, and account management. Used in EDI onboarding and carrier portal access provisioning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the carrier organization responsible for account management, contract negotiations, and escalation handling. Used in carrier relationship management and communication workflows.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary business telephone number for the carrier contact, used for operational coordination, shipment tracking inquiries, and exception management. Formatted per E.164 international standard.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Unique 2-4 character alpha code assigned by the National Motor Freight Traffic Association (NMFTA) to identify transportation carriers in North America. Used in EDI transactions (204, 214, 990) and freight billing. Mandatory for motor carriers operating in the US.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaCountries rdf:type rdf:Property ;
    rdfs:label 'Service Area Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing the countries in which the carrier provides transportation services. Used for international shipment routing, customs compliance validation, and carrier eligibility filtering in cross-border logistics.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceMode rdf:type rdf:Property ;
    rdfs:label 'Service Mode' ;
    rdfs:comment 'Service level classification offered by the carrier indicating transit speed and handling commitment. Drives SLA assignment, freight cost tier selection, and shipment routing logic in the TMS. Used in OTIF (On Time In Full) performance measurement.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Federal tax identification number (EIN/TIN) or VAT registration number of the carrier, used for tax compliance, 1099 reporting, and cross-border customs documentation. Required for freight invoice processing and IRS reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max C' ;
    rdfs:comment 'Maximum temperature (in degrees Celsius) that the carrier\'s cold-chain equipment can maintain during transit. Combined with the minimum temperature range, defines the carrier\'s certified temperature corridor for cold-chain shipments.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min C' ;
    rdfs:comment 'Minimum temperature (in degrees Celsius) that the carrier\'s cold-chain equipment can maintain during transit. Used to validate carrier eligibility for temperature-sensitive product shipments and cold-chain compliance verification.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingUrlTemplate rdf:type rdf:Property ;
    rdfs:label 'Tracking Url Template' ;
    rdfs:comment 'URL template for the carrier\'s web-based shipment tracking portal, with a placeholder (e.g., {tracking_number}) for dynamic substitution. Used to generate direct tracking links in shipment notifications, customer portals, and internal TMS dashboards.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Doing-business-as (DBA) or trade name used by the carrier in commercial operations, which may differ from the legal registered name. Used in operational communications, carrier portals, and reporting where the trade name is more recognizable.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierContractId rdf:type rdf:Property ;
    rdfs:label 'Carrier Contract Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for the carrier contract record in the logistics data platform. Primary key for the carrier_contract entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierContract .

ind:accessorialScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Accessorial Schedule Code' ;
    rdfs:comment 'Reference code identifying the accessorial charge schedule applicable to this contract. Accessorial charges include liftgate, residential delivery, inside delivery, detention, layover, hazmat handling, and temperature-controlled surcharges. Links to the accessorial rate table for freight audit and cost estimation.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the authorized approver who signed off on this carrier contract. Required for SOX financial controls compliance and procurement governance. Supports audit trail for contract authorization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether this carrier contract automatically renews at expiry unless terminated with advance notice. When true, the renewal_notice_days field defines the required notice period. Supports contract lifecycle management and procurement planning.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'The primary negotiated freight rate under this contract before surcharges and accessorial charges are applied. The unit of measure for this rate is defined by the rate_type field (e.g., per mile, per CWT, per pallet, flat). Used as the foundation for freight cost estimation and freight audit rate lookup.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Frequency at which the carrier submits freight invoices under this contract. Per-shipment billing generates an invoice for each delivery; weekly/bi-weekly/monthly billing consolidates charges into periodic invoices. Impacts freight audit workflow and accounts payable processing.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainRequired rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required' ;
    rdfs:comment 'Indicates whether this contract covers temperature-controlled (cold chain) shipments requiring refrigerated or frozen transport. When true, cold chain compliance monitoring, temperature logging, and FEFO inventory management protocols apply. Relevant for health, hygiene, and perishable consumer goods.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known, human-readable contract reference number assigned by the procurement or logistics team. Used in EDI communications, freight audit, and carrier correspondence. Aligns with SAP S/4HANA MM contract document number.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the carrier contract. Draft indicates contract is being authored; pending_approval is awaiting sign-off; active means the contract is in force; suspended means temporarily halted; expired means the term has lapsed; terminated means the contract was ended before expiry.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the freight contract by commercial arrangement type. Spot contracts cover single-shipment rates; committed contracts lock volume at negotiated rates; preferred carrier agreements define priority tender; dedicated contracts reserve capacity; intermodal covers multi-mode arrangements; 3PL master covers third-party logistics umbrella agreements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the destination country covered by this contract. Used for cross-border freight classification, customs compliance, and international rate applicability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRegion rdf:type rdf:Property ;
    rdfs:label 'Destination Region' ;
    rdfs:comment 'Geographic destination zone or region covered by this contract for lane-level rate applicability. May represent a state, ZIP zone, city cluster, or carrier-defined zone code. Used in freight cost estimation and tender evaluation.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detentionFreeTimeHours rdf:type rdf:Property ;
    rdfs:label 'Detention Free Time Hours' ;
    rdfs:comment 'Number of hours the carrier\'s equipment (trailer/container) may remain at a Consumer Goods facility for loading or unloading without incurring detention charges. Exceeding this threshold triggers accessorial detention fees per the contract rate schedule.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelSurchargeBasis rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Basis' ;
    rdfs:comment 'Defines how the fuel surcharge is calculated and applied: as a percentage of the base freight rate, a flat amount per mile, a flat amount per shipment, or dynamically linked to the DOE diesel fuel price index. Determines the fuel surcharge computation method in freight audit.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Rate' ;
    rdfs:comment 'Contracted fuel surcharge rate expressed as a percentage of the base rate or as a fixed amount per unit, applied on top of the base freight rate to account for fuel cost variability. Linked to a fuel index table or DOE diesel price index. Critical for freight cost estimation and audit.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'Maximum cargo insurance coverage amount provided by the carrier under this contract, expressed in the contract currency. Defines the financial liability limit for cargo loss or damage claims. Used in risk management and claims processing.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityLimitPerKg rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Per Kg' ;
    rdfs:comment 'Contractual carrier liability limit per kilogram of cargo for loss or damage claims, expressed in the contract currency. Used in freight claims management to calculate maximum recoverable amounts for damaged or lost shipments.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Kg' ;
    rdfs:comment 'Maximum shipment weight in kilograms at which this contract rate applies. Defines the upper bound of the weight break tier. Null indicates no upper limit (applies to all weights above the minimum). Used in freight cost estimation and audit.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minWeightKg rdf:type rdf:Property ;
    rdfs:label 'Min Weight Kg' ;
    rdfs:comment 'Minimum shipment weight in kilograms at which this contract rate applies. Defines the lower bound of the weight break tier for rate applicability. Used in freight cost estimation and audit to validate correct rate application.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the origin country covered by this contract. Used for cross-border freight classification, customs compliance, and international rate applicability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originRegion rdf:type rdf:Property ;
    rdfs:label 'Origin Region' ;
    rdfs:comment 'Geographic origin zone or region covered by this contract for lane-level rate applicability. May represent a state, ZIP zone, city cluster, or carrier-defined zone code. Used in freight cost estimation and tender evaluation.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Otif Penalty Rate' ;
    rdfs:comment 'Contractual penalty rate applied to the carrier for OTIF (On Time In Full) failures, expressed as a percentage of the invoice value or a fixed amount per incident. OTIF is a key KPI in consumer goods supply chain performance management. Supports carrier performance management and deduction processing.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Otif Threshold Pct' ;
    rdfs:comment 'Minimum OTIF performance percentage the carrier must achieve to avoid penalty charges under this contract. Expressed as a percentage (e.g., 98.5 means 98.5% OTIF compliance required). Below this threshold, the otif_penalty_rate is triggered.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Pickup Lead Time Hours' ;
    rdfs:comment 'Contracted lead time in hours from tender acceptance to carrier pickup at the origin facility. Used in shipment planning, load scheduling, and Blue Yonder WMS labor planning for dock door assignment.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Defines the unit basis on which the base_rate is charged. Per-mile rates apply to distance-based pricing; per-CWT (hundredweight) applies to weight-based LTL pricing; per-pallet applies to unit-load pricing; flat rate is a fixed charge per shipment regardless of weight or distance; per-kg and per-lb are weight-based variants used in air and parcel freight. [ENUM-REF-CANDIDATE: per_mile|per_cwt|per_pallet|per_shipment|flat|per_kg|per_lb — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days advance notice required to terminate or renegotiate this contract before auto-renewal. Applicable only when auto_renewal is true. Used in contract lifecycle management to trigger procurement review workflows.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Contracted service level defining the speed and handling tier for shipments under this agreement. Drives SLA commitments, OTIF measurement thresholds, and rate applicability. Examples: standard ground, expedited, overnight, two-day, deferred, white-glove.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum temperature in degrees Celsius that must be maintained throughout transit for cold chain shipments under this contract. Applicable only when cold_chain_required is true. Exceedance triggers non-conformance reporting and potential product rejection.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum temperature in degrees Celsius that must be maintained throughout transit for cold chain shipments under this contract. Applicable only when cold_chain_required is true. Used for cold chain compliance monitoring and carrier performance audits.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackTraceMethod rdf:type rdf:Property ;
    rdfs:label 'Track Trace Method' ;
    rdfs:comment 'Method by which shipment tracking and status updates are provided by the carrier under this contract. EDI 214 is the standard electronic shipment status transaction; API enables real-time integration; portal requires manual check-in; email is manual notification. Drives track-and-trace capability in logistics operations.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Time Days' ;
    rdfs:comment 'Contracted standard transit time in calendar days from pickup to delivery for shipments under this contract and lane. Used as the SLA baseline for OTIF measurement, delivery promise, and ATP/CTP calculations in demand planning.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Primary mode of transportation covered by this contract. TL (Truckload), LTL (Less-than-Truckload), intermodal, rail, ocean freight, air freight, parcel/small package, or drayage (port/terminal moves). Drives rate table applicability and freight audit logic. [ENUM-REF-CANDIDATE: truckload|ltl|intermodal|rail|ocean|air|parcel|drayage — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentUnits rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Units' ;
    rdfs:comment 'Contracted minimum volume commitment by Consumer Goods to the carrier over the contract term, expressed in the unit defined by volume_commitment_uom (e.g., shipments, pallets, CWT, revenue miles). Failure to meet this commitment may trigger shortfall penalties or rate renegotiation.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCommitmentUom rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Uom' ;
    rdfs:comment 'Unit of measure for the volume_commitment_units field. Defines whether the volume commitment is expressed in number of shipments, pallets, hundredweight (CWT), revenue miles, kilograms, or truckloads.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneId rdf:type rdf:Property ;
    rdfs:label 'Lane Id' ;
    rdfs:comment 'Unique system-generated identifier for the transportation lane record. Primary key for the lane entity in the logistics domain.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:destinationLocationSupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Supply Network Node Id' ;
    rdfs:comment 'Reference to the destination facility, distribution center, retail store, or customer location where freight is delivered on this lane. Links to the location master in the logistics domain.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:laneBackupCarrierId rdf:type rdf:Property ;
    rdfs:label 'Lane Backup Carrier Id' ;
    rdfs:comment 'Reference to the secondary/backup carrier for this lane, used when the preferred carrier declines the tender or is unavailable. Represents the second position in the routing guide.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:lanePreferredCarrierId rdf:type rdf:Property ;
    rdfs:label 'Lane Preferred Carrier Id' ;
    rdfs:comment 'Reference to the primary/preferred carrier assigned to this lane for freight tendering. Represents the first-tender carrier in the routing guide hierarchy. Links to the carrier master in the logistics domain.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:laneSupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Lane Supply Network Node Id' ;
    rdfs:comment 'Reference to the origin facility, distribution center, plant, or supplier location from which freight departs on this lane. Links to the location master in the logistics domain.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:annualVolumeLoads rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Loads' ;
    rdfs:comment 'Historical or planned annual shipment volume on this lane expressed in number of loads (truckloads, containers, or equivalent units). Used for carrier contract negotiations, network design, and freight spend forecasting.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualVolumeWeightKg rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Weight Kg' ;
    rdfs:comment 'Historical or planned annual freight weight moved on this lane in kilograms. Used for carrier contract negotiations, modal optimization, and carbon emissions intensity calculations per ISO 14001.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkRateFlat rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Flat' ;
    rdfs:comment 'Lane-level flat cost benchmark (all-in rate per load/shipment) in the operating currency. Used for truckload lanes where per-km pricing is not applicable. Supports freight audit and carrier contract negotiation.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkRatePerKm rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Per Km' ;
    rdfs:comment 'Lane-level cost benchmark expressed as rate per kilometer in the operating currency. Used for freight audit, carrier performance benchmarking, and transportation cost variance analysis. Confidential as it reflects negotiated contract intelligence.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonEmissionFactor rdf:type rdf:Property ;
    rdfs:label 'Carbon Emission Factor' ;
    rdfs:comment 'Lane-level carbon emission intensity factor expressed as kilograms of CO2 equivalent per kilometer, based on transport mode and equipment type. Used for Scope 3 emissions reporting, sustainability KPIs, and ESG disclosures per ISO 14001 and EPA Greenhouse Gas Reporting Program.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Directional and functional classification of the lane within the supply chain network. Inbound covers supplier-to-plant/DC movements; outbound covers DC-to-customer/retailer; inter-facility covers plant-to-DC or DC-to-DC; last-mile covers final delivery to end consumer or store; reverse covers returns flow.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorder rdf:type rdf:Property ;
    rdfs:label 'Cross Border' ;
    rdfs:comment 'Indicates whether this lane crosses an international border, requiring customs documentation, import/export compliance, and potentially additional transit time for border clearance. Drives customs broker assignment and trade compliance workflows.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsTradeZone rdf:type rdf:Property ;
    rdfs:label 'Customs Trade Zone' ;
    rdfs:comment 'Trade zone or customs agreement applicable to this cross-border lane (e.g., USMCA, EU Single Market, ASEAN). Determines duty rates, documentation requirements, and customs clearance procedures. Populated only for cross-border lanes.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCity rdf:type rdf:Property ;
    rdfs:label 'Destination City' ;
    rdfs:comment 'City name of the lane destination point. Used for geographic lane analysis, carrier rate zone determination, and network design reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Business-facing code for the destination location (e.g., customer DC code, store code, or GS1 Global Location Number). Used in EDI transactions, carrier communications, and freight audit matching.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStateProvince rdf:type rdf:Property ;
    rdfs:label 'Destination State Province' ;
    rdfs:comment 'ISO 3166-2 state or province code for the lane destination. Used in carrier rate zone mapping and freight cost benchmarking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Measured or calculated road/route distance between origin and destination in kilometers. Used for transit time estimation, fuel surcharge calculation, carrier rate benchmarking, and carbon emissions reporting per ISO 14001 and EPA guidelines.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsdEligible rdf:type rdf:Property ;
    rdfs:label 'Dsd Eligible' ;
    rdfs:comment 'Indicates whether this lane supports Direct Store Delivery (DSD), where product is delivered directly from the manufacturer or distributor to the retail store, bypassing the retailer\'s distribution center. Relevant for high-velocity CPG categories.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Type of transportation equipment required for this lane. Refrigerated (reefer) equipment is critical for cold-chain compliance in temperature-sensitive consumer goods. Drives carrier qualification and cost benchmarking. [ENUM-REF-CANDIDATE: dry_van|refrigerated|flatbed|tanker|container_20ft|container_40ft|container_45ft|parcel|bulk — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatRequired rdf:type rdf:Property ;
    rdfs:label 'Hazmat Required' ;
    rdfs:comment 'Indicates whether this lane requires carriers certified for hazardous materials (HAZMAT) transport. Applicable for lanes carrying chemical, aerosol, or regulated consumer goods. Triggers carrier qualification checks and regulatory documentation requirements per DOT/EPA/OSHA.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneCode rdf:type rdf:Property ;
    rdfs:label 'Lane Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the transportation lane, used in carrier contracts, freight tenders, and TMS systems. Typically formatted as ORIGIN-DEST-MODE (e.g., CHI-NYC-TL). Aligns with SAP TM lane master data.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneName rdf:type rdf:Property ;
    rdfs:label 'Lane Name' ;
    rdfs:comment 'Human-readable descriptive name for the transportation lane, typically combining origin and destination location names and transport mode (e.g., \'Chicago DC to New York RDC - Truckload\'). Used in reporting and carrier communication.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneStatus rdf:type rdf:Property ;
    rdfs:label 'Lane Status' ;
    rdfs:comment 'Current lifecycle status of the transportation lane. Active lanes are available for freight tendering and route optimization. Inactive or suspended lanes are excluded from planning runs.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this lane record was last updated. Used for change tracking, data freshness monitoring, and incremental ETL processing in the Databricks Silver Layer.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:networkRegion rdf:type rdf:Property ;
    rdfs:label 'Network Region' ;
    rdfs:comment 'Geographic or operational network region to which this lane belongs (e.g., Northeast, Southeast, Midwest, West Coast, EMEA, APAC). Used for network design segmentation, regional freight cost analysis, and carrier portfolio management.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCity rdf:type rdf:Property ;
    rdfs:label 'Origin City' ;
    rdfs:comment 'City name of the lane origin point. Used for geographic lane analysis, carrier rate zone determination, and network design reporting.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Location Code' ;
    rdfs:comment 'Business-facing code for the origin location (e.g., plant code, DC code, or GS1 Global Location Number). Used in EDI transactions, carrier communications, and freight audit matching.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originStateProvince rdf:type rdf:Property ;
    rdfs:label 'Origin State Province' ;
    rdfs:comment 'ISO 3166-2 state or province code for the lane origin. Used in carrier rate zone mapping, regulatory compliance (e.g., CARB emissions zones), and freight cost benchmarking.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otif Target Pct' ;
    rdfs:comment 'Target OTIF (On Time In Full) performance percentage for this lane, representing the contractual or operational delivery reliability goal. Used as the KPI baseline for carrier performance scorecards and SLA compliance reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingGuideRank rdf:type rdf:Property ;
    rdfs:label 'Routing Guide Rank' ;
    rdfs:comment 'Numeric rank of the preferred carrier in the lane routing guide sequence. Rank 1 is the primary carrier; higher ranks are fallback options. Used in automated freight tendering workflows to determine tender sequence.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardTransitDays rdf:type rdf:Property ;
    rdfs:label 'Standard Transit Days' ;
    rdfs:comment 'Contractually agreed or operationally standard number of calendar days for freight to travel from origin to destination on this lane. Used as the baseline for OTIF (On Time In Full) measurement, delivery promise, and ATP/CTP calculations in SAP IBP.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationFacilityDistributionCenterDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Distribution Center Distribution Facility Id' ;
    rdfs:comment 'Reference to the facility (distribution center, retail store, customer location, or 3PL node) to which the shipment is consigned.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:freightRateId rdf:type rdf:Property ;
    rdfs:label 'Freight Rate Id' ;
    rdfs:comment 'Foreign key linking to logistics.freight_rate. Business justification: A logistics shipment is executed at a specific freight rate from the rate schedule. Linking logistics_shipment to freight_rate enables direct rate-to-actuals reconciliation — comparing the contracted ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightRate .

ind:manufacturingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Facility Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: Traceability: link each shipment to its originating manufacturing facility for cost allocation and regulatory reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingFacility .

ind:originTradeAccountId rdf:type rdf:Property ;
    rdfs:label 'Origin Trade Account Id' ;
    rdfs:comment 'Foreign key linking to customer.trade_account. Business justification: Shipment origin account is needed for cost attribution, SLA reporting, and regulatory shipment origin documentation.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAccount .

ind:primaryLogisticsDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Logistics Distribution Facility Id' ;
    rdfs:comment 'Reference to the facility (plant, distribution center, warehouse, or supplier location) from which the shipment departs.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:registrationId rdf:type rdf:Property ;
    rdfs:label 'Registration Id' ;
    rdfs:comment 'Foreign key linking to regulatory.registration. Business justification: Required for shipment compliance verification: each shipment must reference the product\'s regulatory registration to confirm valid registration at shipping time.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registration .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Foreign key linking to sales.order. Business justification: Shipment tracking must reference the originating sales order for fulfillment status and revenue reconciliation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Precise date and time the shipment was delivered and signed for at the destination, as captured by the carrier\'s POD (Proof of Delivery) system or electronic signature device. Enables time-window compliance measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bolNumber rdf:type rdf:Property ;
    rdfs:label 'Bol Number' ;
    rdfs:comment 'Bill of Lading number issued by the carrier as the legal contract of carriage and receipt of goods. Required for freight audit, customs clearance, and proof of delivery. Key document in SAP S/4HANA SD and Blue Yonder WMS.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'ISO 6346 standardized container identification number for ocean freight shipments (e.g., MSCU1234567). Used for port tracking, customs clearance, and demurrage/detention management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates the direction of the shipment relative to the enterprise network: inbound (from supplier), outbound (to customer/retailer), interplant (between internal facilities), or return (reverse logistics).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Standardized code identifying the reason for a shipment exception or delay (e.g., weather delay, carrier capacity, customs hold, address correction, damaged goods). Used for root cause analysis and carrier performance management. [ENUM-REF-CANDIDATE: weather_delay|carrier_capacity|customs_hold|address_correction|damaged_goods|mechanical_failure|other — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCostAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Amount' ;
    rdfs:comment 'Total contracted or invoiced freight cost for this shipment in the transaction currency. Used for freight cost allocation to COGS (Cost of Goods Sold), carrier spend analytics, and freight audit reconciliation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the freight cost amount (e.g., USD, EUR, GBP). Required for multi-currency freight spend reporting and financial consolidation.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Freight payment terms indicating who bears the freight cost: prepaid (shipper pays), collect (consignee pays), or third_party (a designated third party pays). Drives freight invoice routing and cost allocation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Amount' ;
    rdfs:comment 'Carrier-applied fuel surcharge amount for this shipment, separate from the base freight rate. Used for freight audit, cost variance analysis, and carrier contract compliance.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms) code defining the transfer of risk, cost responsibility, and delivery obligations between shipper and consignee. Governs freight cost allocation and insurance requirements. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — promote to reference product]' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifInFull rdf:type rdf:Property ;
    rdfs:label 'Otif In Full' ;
    rdfs:comment 'Indicates whether the shipment was delivered with the complete ordered quantity, contributing to the OTIF (On Time In Full) KPI. Supports retailer compliance scorecarding and deduction management.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifOnTime rdf:type rdf:Property ;
    rdfs:label 'Otif On Time' ;
    rdfs:comment 'Indicates whether the shipment was delivered on or before the planned delivery date, contributing to the OTIF (On Time In Full) KPI. Derived from planned vs. actual delivery date comparison and stored for reporting efficiency.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'The date on which the shipment is expected to arrive at the destination facility, based on contracted transit time and lane performance.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedShipDate rdf:type rdf:Property ;
    rdfs:label 'Planned Ship Date' ;
    rdfs:comment 'The date on which the shipment is scheduled to depart from the origin facility, as determined by the transportation plan or S&OP (Sales and Operations Planning) process.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:podReceived rdf:type rdf:Property ;
    rdfs:label 'Pod Received' ;
    rdfs:comment 'Indicates whether a signed Proof of Delivery (POD) document has been received and validated for this shipment. Required for freight invoice payment release and dispute resolution.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:podTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pod Timestamp' ;
    rdfs:comment 'Date and time the Proof of Delivery (POD) was electronically captured or received, as recorded by the carrier\'s mobile device or ePOD system. Used for freight audit and dispute resolution timelines.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Carrier-assigned Progressive (PRO) number used to track LTL (Less-Than-Truckload) shipments through the carrier\'s network. Essential for freight audit and claims management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ship Timestamp' ;
    rdfs:comment 'Precise date and time the shipment departed the origin facility, as recorded by the WMS or gate system. Used for transit time calculation and carrier SLA compliance.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally-known business identifier for the shipment, typically generated by the TMS or ERP (e.g., SAP outbound delivery number or transportation order number). Used for track-and-trace and carrier communication.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment. Drives OTIF (On Time In Full) measurement, exception management, and track-and-trace visibility. [ENUM-REF-CANDIDATE: planned|tendered|confirmed|in_transit|out_for_delivery|delivered|cancelled|exception — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threePlReference rdf:type rdf:Property ;
    rdfs:label 'Three Pl Reference' ;
    rdfs:comment 'Reference number assigned by the 3PL (Third-Party Logistics) provider for this shipment in their WMS or TMS. Enables cross-system reconciliation and 3PL billing validation.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCases rdf:type rdf:Property ;
    rdfs:label 'Total Cases' ;
    rdfs:comment 'Total number of cases (cartons) included in the shipment. Used for pick/pack verification, receiving reconciliation, and OTIF (On Time In Full) quantity compliance.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPallets rdf:type rdf:Property ;
    rdfs:label 'Total Pallets' ;
    rdfs:comment 'Total number of pallets included in the shipment. Used for dock scheduling, trailer loading planning, and carrier billing for LTL shipments.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'Total cubic volume of the shipment in cubic meters. Used for dimensional weight calculation, trailer utilization, and freight cost optimization.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms, including packaging and pallets. Used for freight rate calculation, carrier billing, and compliance with road weight limits.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentItemId rdf:type rdf:Property ;
    rdfs:label 'Shipment Item Id' ;
    rdfs:comment 'Unique surrogate identifier for each shipment line item record in the logistics data platform. Primary key for the shipment_item entity.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventSkuId rdf:type rdf:Property ;
    rdfs:label 'Event Sku Id' ;
    rdfs:comment 'Foreign key linking to promotion.promotion_event_sku. Business justification: Needed for Promotional SKU shipment reconciliation to calculate allocated vs actual promotional volume per shipment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EventSku .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_lot. Business justification: Required for lot traceability report linking inspected lots to shipped items, enabling recall and compliance verification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:labelVersionId rdf:type rdf:Property ;
    rdfs:label 'Label Version Id' ;
    rdfs:comment 'Foreign key linking to regulatory.label_version. Business justification: Consumer Goods regulatory compliance requires that shipped products carry the jurisdiction-approved label version for the destination market. This link enables label compliance audits, recall traceabi' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabelVersion .

ind:packHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Pack Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to product.pack_hierarchy. Business justification: SSCC labeling, pallet configuration validation, and carrier compliance in consumer goods require knowing the exact pack level (each/case/pallet) being shipped. Pack hierarchy defines TI/HI, GTIN, and ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackHierarchy .

ind:packagingSpecId rdf:type rdf:Property ;
    rdfs:label 'Packaging Spec Id' ;
    rdfs:comment 'Foreign key linking to product.product_packaging_spec. Business justification: Freight audit, carrier compliance, and OTIF reporting require knowing which packaging spec (dimensions, weight, hazmat, cold-chain flags) was used for each shipment line. Consumer goods logistics team' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackagingSpec .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Foreign key linking to procurement.po_line. Business justification: shipment_item.purchase_order_number is a denormalized text reference to the originating PO line. Replacing with a proper FK to po_line enables OTIF measurement at PO line level, goods receipt reconcil' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:sdsId rdf:type rdf:Property ;
    rdfs:label 'Sds Id' ;
    rdfs:comment 'Foreign key linking to regulatory.sds. Business justification: ADR/IATA/IMDG regulations mandate that Safety Data Sheets accompany hazardous shipment items in transit. Consumer Goods compliance teams must verify the correct SDS version is associated with each haz' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sds .

ind:supplyReplenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Supply Replenishment Order Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_replenishment_order. Business justification: Shipment items represent line-level shipped quantities that must be reconciled against replenishment order lines for goods receipt confirmation and over/under-shipment resolution — a standard consumer' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplyReplenishmentOrder .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'Quantity confirmed as received by the consignee at the delivery destination, captured from proof of delivery (POD) or EDI 214 acknowledgment. Used for invoice reconciliation and OTIF final measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating where the product was manufactured or substantially transformed. Required for customs declarations, import duty determination, and trade compliance reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Document Number' ;
    rdfs:comment 'ERP delivery document number (e.g., SAP outbound delivery number) associated with this shipment line. Serves as the primary cross-reference between the logistics execution system and the financial/order management system.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of this shipment line item in kilograms, including product, inner packaging, and outer packaging. Used for freight cost calculation, carrier capacity planning, and customs declarations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:harmonizedTariffCode rdf:type rdf:Property ;
    rdfs:label 'Harmonized Tariff Code' ;
    rdfs:comment 'Harmonized System (HS) tariff classification code for the product, used for customs clearance, import duty calculation, and international trade compliance. Typically 6-10 digits per WCO HS nomenclature.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isControlledSubstance rdf:type rdf:Property ;
    rdfs:label 'Is Controlled Substance' ;
    rdfs:comment 'Indicates whether this item contains a controlled substance subject to DEA scheduling, FDA drug regulations, or equivalent international narcotics controls. Triggers enhanced chain-of-custody documentation requirements.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDsd rdf:type rdf:Property ;
    rdfs:label 'Is Dsd' ;
    rdfs:comment 'Indicates whether this item is fulfilled via Direct Store Delivery (DSD) channel, bypassing the retailer\'s distribution center and delivering directly to the store. Impacts route planning, SFA integration, and trade promotion settlement.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'Indicates whether this shipment item is classified as a hazardous material requiring special handling, labeling, and transport documentation per DOT, IATA, or IMDG regulations. Triggers mandatory SDS (Safety Data Sheet) attachment.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemperatureSensitive rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Sensitive' ;
    rdfs:comment 'Indicates whether this item requires temperature-controlled handling and transport (cold chain). When true, temperature range requirements and cold-chain compliance monitoring are enforced throughout the shipment lifecycle.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Human-readable description of the product being shipped, including product name, variant, and pack size. Used on shipping documents, proof of delivery, and freight audit records.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current lifecycle status of this shipment line item. Tracks progression from warehouse picking through delivery confirmation. [ENUM-REF-CANDIDATE: planned|picked|loaded|in_transit|delivered|short_shipped|cancelled — promote to reference product]' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineValue rdf:type rdf:Property ;
    rdfs:label 'Line Value' ;
    rdfs:comment 'Total declared value of this shipment line item (shipped_quantity × unit_cost), used for customs valuation, cargo insurance, and financial reporting. Expressed in the shipment currency.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'Maximum allowable temperature in degrees Celsius for storage and transport of this item. Applicable when is_temperature_sensitive is true. Exceedances trigger quality holds and non-conformance reporting.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum allowable temperature in degrees Celsius for storage and transport of this item. Applicable when is_temperature_sensitive is true. Used to configure cold-chain monitoring alerts and carrier SLA requirements.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netWeightKg rdf:type rdf:Property ;
    rdfs:label 'Net Weight Kg' ;
    rdfs:comment 'Net weight of the product content only in kilograms, excluding all packaging materials. Required for regulatory labeling compliance, customs documentation, and COGS (Cost of Goods Sold) reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity of this item originally ordered by the customer or requested in the purchase order. Used for OTIF (On Time In Full) calculation and order fulfillment rate reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Type of packaging unit in which the item is shipped. Determines handling requirements, stacking rules, and warehouse slotting. Aligns with GS1 packaging hierarchy levels.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'Indicates whether this shipment line item has been placed on a quality hold due to a failed QC inspection, temperature exceedance, or regulatory non-conformance. Items on hold must not be delivered until released by QA.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Number' ;
    rdfs:comment 'Product registration or regulatory approval number required for cross-border shipments of regulated consumer goods (e.g., FDA registration, EPA registration, EU REACH authorization). Stored for customs and import compliance documentation.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrderLine rdf:type rdf:Property ;
    rdfs:label 'Sales Order Line' ;
    rdfs:comment 'Line item number within the originating sales order corresponding to this shipment item. Used for precise order-to-shipment reconciliation and partial fulfillment tracking.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Number' ;
    rdfs:comment 'Reference to the originating sales order number from the ERP system (SAP SD) that triggered this shipment line. Enables order-to-delivery traceability and OTIF measurement at the order line level.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Unique serial number assigned to an individual product unit, applicable for serialized items requiring unit-level traceability (e.g., high-value consumer electronics, regulated health products). Null for non-serialized bulk items.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'Actual quantity of this item loaded and dispatched in the shipment. May differ from ordered quantity due to partial fulfillment, OOS (Out of Stock) conditions, or substitution. Core metric for OTIF compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sscc rdf:type rdf:Property ;
    rdfs:label 'Sscc' ;
    rdfs:comment 'GS1 Serial Shipping Container Code (SSCC) — an 18-digit identifier assigned to the logistic unit (pallet, case) containing this item. Enables pallet-level traceability and EDI 856 ASN compliance with retail trading partners.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Specific storage location or bin within the warehouse from which this item was picked, as recorded in the WMS. Used for warehouse slotting optimization and pick path efficiency analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Standard cost per unit of measure for this item at time of shipment, used for COGS (Cost of Goods Sold) calculation, inventory valuation, and freight cost allocation. Sourced from SAP S/4HANA CO standard cost.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeM3 rdf:type rdf:Property ;
    rdfs:label 'Volume M3' ;
    rdfs:comment 'Cubic volume of this shipment line item in cubic metres, used for truck load planning, container utilization optimization, and freight rate calculation based on dimensional weight.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to sales.invoice. Business justification: Accounts receivable teams match delivery confirmations to invoices for payment release, dispute resolution, and DSO tracking. OTIF delivery status directly affects invoice dispute flags. Consumer good' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'Reference to the planned delivery route assigned to this delivery. Enables route optimization analysis and OTIF (On Time In Full) performance measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:vehicleId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Id' ;
    rdfs:comment 'Reference to the vehicle or transport unit used for this delivery. Supports fleet management, cold-chain compliance, and route analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:warehouseId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Id' ;
    rdfs:comment 'Foreign key linking to inventory.warehouse. Business justification: Deliveries in consumer goods dispatch from a specific warehouse. Warehouse-level delivery performance reporting (OTIF by dispatch warehouse), dock scheduling, and inventory reservation at dispatch all' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:actualTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Actual Temperature C' ;
    rdfs:comment 'Actual temperature in degrees Celsius recorded during delivery, captured by IoT sensor or driver log. Used to verify cold-chain compliance and support FDA/EU GDP regulatory reporting for temperature-sensitive goods.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Tracking Number' ;
    rdfs:comment 'External tracking number assigned by the carrier for track-and-trace visibility. Enables real-time shipment monitoring and customer-facing delivery status updates.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeName rdf:type rdf:Property ;
    rdfs:label 'Consignee Name' ;
    rdfs:comment 'Legal or trading name of the receiving party (store, warehouse, or customer) at the delivery destination. Used for POD (Proof of Delivery) documentation and dispute resolution.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'Actual quantity of goods physically delivered and accepted at the consignee location. Core metric for OTIF (On Time In Full) in-full measurement, fill rate KPI, and invoice reconciliation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Externally-known business identifier for the delivery, typically sourced from SAP S/4HANA SD outbound delivery document (e.g., 80XXXXXXXX). Used in EDI communications, carrier coordination, and customer-facing tracking.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the delivery execution. \'full\' = all ordered quantities delivered; \'partial\' = some quantities delivered; \'failed\' = delivery attempt unsuccessful; \'refused\' = consignee rejected delivery; \'pending\' = delivery not yet attempted. Core field for OTIF (On Time In Full) calculation.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of the delivery method. DSD (Direct Store Delivery) = manufacturer delivers directly to retail shelf; warehouse = delivery to distribution center; cross_dock = transit without storage; drop_ship = vendor ships directly to consignee; returns = reverse logistics delivery. [ENUM-REF-CANDIDATE: DSD|warehouse|cross_dock|drop_ship|returns — promote to reference product]' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Flag' ;
    rdfs:comment 'Indicates whether the POD (Proof of Delivery) signature was captured electronically (True) via e-POD app or DSD handheld, or obtained on paper (False). Determines evidentiary strength for dispute resolution.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text notes describing delivery discrepancies, exceptions, or special circumstances recorded by the driver or dispatcher. Supplements the structured exception code for dispute resolution and root cause analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstAttemptTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Attempt Timestamp' ;
    rdfs:comment 'Date and time of the first delivery attempt at the consignee location. Relevant when the delivery required multiple attempts (e.g., failed first attempt followed by successful re-delivery). Supports carrier performance analytics.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:goodsConditionCode rdf:type rdf:Property ;
    rdfs:label 'Goods Condition Code' ;
    rdfs:comment 'Condition of goods as assessed at point of delivery receipt. \'good\' = acceptable; \'damaged\' = physical damage observed; \'partial_damage\' = some units damaged; \'temperature_breach\' = cold-chain violation detected; \'contaminated\' = product integrity compromised. Triggers quality investigation and regulatory reporting. [ENUM-REF-CANDIDATE: good|damaged|partial_damage|temperature_breach|contaminated — promote to reference product]' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inFullFlag rdf:type rdf:Property ;
    rdfs:label 'In Full Flag' ;
    rdfs:comment 'Indicates whether the full ordered quantity was delivered (True). Component of the OTIF (On Time In Full) KPI, enabling separate on-time vs. in-full root cause analysis and fill rate reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onTimeFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Flag' ;
    rdfs:comment 'Indicates whether the delivery was completed on or before the scheduled delivery date/time (True). Component of the OTIF (On Time In Full) KPI, enabling separate on-time vs. in-full root cause analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Flag' ;
    rdfs:comment 'Indicates whether this delivery met the OTIF (On Time In Full) KPI criteria — True if delivered on or before the scheduled date AND at 100% of ordered quantity. Core retail compliance metric for major retailers (e.g., Walmart OTIF penalty program).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoAttachmentReference rdf:type rdf:Property ;
    rdfs:label 'Photo Attachment Reference' ;
    rdfs:comment 'Storage reference or URL to photo evidence captured at delivery (e.g., goods condition, placement, damaged packaging). Supports POD (Proof of Delivery) documentation and insurance claims.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSource rdf:type rdf:Property ;
    rdfs:label 'Pod Source' ;
    rdfs:comment 'System or method used to capture the POD (Proof of Delivery). DSD_handheld = Direct Store Delivery device; epod_app = electronic POD mobile application; paper_scan = digitized paper document; EDI = Electronic Data Interchange confirmation; manual = manually entered. Determines data quality and evidentiary weight.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom' ;
    rdfs:comment 'Unit of measure for ordered and delivered quantities (e.g., EA=each, CS=case, PAL=pallet, KG=kilogram). Aligns with GS1 unit of measure codes and SAP base unit of measure configuration. [ENUM-REF-CANDIDATE: EA|CS|PAL|KG|LB|L|GAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Full name of the individual who physically received and signed for the delivery at the consignee location. Core POD (Proof of Delivery) field for dispute resolution and legal evidence.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refusedQuantity rdf:type rdf:Property ;
    rdfs:label 'Refused Quantity' ;
    rdfs:comment 'Quantity of goods refused or rejected by the consignee at point of delivery. Triggers reverse logistics, credit memo processing, and quality investigation workflows.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'The planned calendar date on which the delivery was scheduled to arrive at the consignee location. Used as the baseline for OTIF (On Time In Full) on-time measurement and SLA compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Timestamp' ;
    rdfs:comment 'The precise planned date and time window start for delivery at the consignee location. Supports time-window compliance measurement and carrier SLA (Service Level Agreement) tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signatureReference rdf:type rdf:Property ;
    rdfs:label 'Signature Reference' ;
    rdfs:comment 'Storage reference or URL pointing to the captured electronic or scanned signature image for this delivery. Used as legal evidence in POD (Proof of Delivery) dispute resolution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'The bill of lading number issued by the carrier for this shipment. Serves as the primary legal transport document reference and is used in freight audit, customs compliance, and dispute resolution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierScanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Carrier Scan Timestamp' ;
    rdfs:comment 'Timestamp of the carrier\'s own barcode or RFID scan event at the point of delivery, as transmitted via EDI or carrier portal. May differ from receipt_timestamp if there is a lag between physical delivery and system capture.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coldChainCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Compliant Flag' ;
    rdfs:comment 'Indicates whether the delivery maintained required cold-chain temperature conditions throughout transit (True = compliant). Critical for temperature-sensitive consumer goods (e.g., dairy, frozen, pharmaceutical). Supports FDA and ISO 22716 compliance.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Reference Number' ;
    rdfs:comment 'The consignee\'s own purchase order or reference number for this delivery. Enables cross-referencing between the supplier\'s POD and the customer\'s receiving records for EDI reconciliation and dispute resolution.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocationGln rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Gln' ;
    rdfs:comment 'GS1 Global Location Number (GLN) of the delivery destination. Provides a globally unique, standardized identifier for the consignee location, enabling interoperability with trading partners and EDI systems.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocationName rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Name' ;
    rdfs:comment 'Name of the physical delivery location (e.g., store name, distribution center name, warehouse name). Provides human-readable identification of the delivery destination for reporting and operations.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Delivery Temperature C' ;
    rdfs:comment 'Recorded temperature in degrees Celsius at the point of delivery for temperature-sensitive goods. Used to verify cold-chain compliance and support FDA regulatory reporting for perishable or pharmaceutical consumer goods.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicates whether a discrepancy was identified at the time of delivery (True = discrepancy exists). Triggers downstream dispute resolution, freight audit, and claims workflows.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text description of any discrepancy observed at delivery, such as quantity shortages, damaged packaging, wrong items, or temperature excursions. Used in dispute resolution and freight audit processes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Categorical classification of the type of discrepancy identified at delivery. Enables structured reporting and root cause analysis across the logistics network. [ENUM-REF-CANDIDATE: quantity_shortage|overage|damaged_goods|wrong_item|temperature_breach|missing_documentation — promote to reference product]' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'The date on which a delivery dispute was formally resolved. Used to measure dispute resolution cycle time and SLA compliance for freight audit and carrier management.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current status of any freight or delivery dispute associated with this POD. Tracks the lifecycle of dispute resolution from identification through closure. Supports freight audit and carrier claims management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdRouteStopSequence rdf:type rdf:Property ;
    rdfs:label 'Dsd Route Stop Sequence' ;
    rdfs:comment 'The sequential stop number of this delivery within the DSD route. Used for route optimization analysis, driver performance measurement, and DSD compliance reporting in Salesforce Consumer Goods Cloud.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freightBillNumber rdf:type rdf:Property ;
    rdfs:label 'Freight Bill Number' ;
    rdfs:comment 'The carrier-issued freight bill or bill of lading (BOL) number associated with this delivery. Used to match POD records to freight invoices during freight audit and payment processes.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geofenceValidatedFlag rdf:type rdf:Property ;
    rdfs:label 'Geofence Validated Flag' ;
    rdfs:comment 'Indicates whether the GPS coordinates captured at delivery were within the expected geofence boundary of the consignee location (True = within geofence). Used to detect fraudulent or erroneous POD captures in DSD operations.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'GPS latitude coordinate captured at the time of delivery confirmation. Used for geofencing validation, proof of delivery location verification, and DSD compliance auditing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'GPS longitude coordinate captured at the time of delivery confirmation. Used alongside latitude for geofencing validation, delivery location verification, and DSD compliance auditing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsCondition rdf:type rdf:Property ;
    rdfs:label 'Goods Condition' ;
    rdfs:comment 'Condition of the goods as assessed at the point of delivery by the recipient. Drives claims processing, carrier liability assessment, and quality incident reporting. [ENUM-REF-CANDIDATE: intact|damaged|partial_damage|refused|short_delivered — promote to reference product if additional conditions are required]' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoAttachmentCount rdf:type rdf:Property ;
    rdfs:label 'Photo Attachment Count' ;
    rdfs:comment 'Number of photo attachments captured and associated with this POD record. Indicates the volume of photographic evidence available for dispute resolution and claims processing.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:photoAttachmentUrls rdf:type rdf:Property ;
    rdfs:label 'Photo Attachment Urls' ;
    rdfs:comment 'Comma-separated list of URL or file path references to photo images captured at delivery (e.g., photos of damaged goods, delivery location, pallet condition). Stored in secure document repository and referenced for dispute resolution.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podConfirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Pod Confirmation Method' ;
    rdfs:comment 'The method used to confirm delivery receipt (e.g., signature, PIN code, photo-only, verbal confirmation, unattended drop). Supports compliance with carrier SLA requirements and DSD operational standards.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podNumber rdf:type rdf:Property ;
    rdfs:label 'Pod Number' ;
    rdfs:comment 'Externally-known business reference number for this POD document. Used in freight audit, dispute resolution, and EDI acknowledgement exchanges with carriers and customers.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'The exact date and time at which the consignee acknowledged receipt of the goods. This is the principal business event timestamp for the POD and is the authoritative time used for OTIF measurement and freight audit.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recipientTitle rdf:type rdf:Property ;
    rdfs:label 'Recipient Title' ;
    rdfs:comment 'Job title or role of the individual who received the goods (e.g., Receiving Manager, Store Associate, Warehouse Clerk). Provides context for authorization level of the signatory.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureImageUrl rdf:type rdf:Property ;
    rdfs:label 'Signature Image Url' ;
    rdfs:comment 'URL or file path reference to the stored digital image of the recipient\'s signature. Used as legal evidence in freight disputes and customer claims. Stored in secure document repository.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Code' ;
    rdfs:comment 'Identifier of the vehicle or transport unit used for the delivery (e.g., truck registration number, fleet asset ID). Used for route optimization analysis, cold-chain compliance, and carrier audit.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightOrderId rdf:type rdf:Property ;
    rdfs:label 'Freight Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the freight order record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightOrder .

ind:originWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Origin Warehouse Id' ;
    rdfs:comment 'Foreign key linking to inventory.warehouse. Business justification: Freight orders in consumer goods are raised to move inventory out of a specific warehouse. The origin warehouse drives dock scheduling, inventory reservation, and freight cost allocation to warehouse ' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.plan. Business justification: Freight orders are created to execute supply plans. Linking freight_order to the originating supply plan enables freight cost tracking against supply plans, S&OP execution monitoring, and freight audi' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:primaryFreightNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Freight Network Node Id' ;
    rdfs:comment 'Reference to the delivery/destination location (retailer DC, customer warehouse, store, or end-consumer address) to which the freight order is directed.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: In Consumer Goods inbound logistics, freight orders are created to move purchased materials from supplier to plant/DC against a specific PO. This link enables inbound freight cost allocation to PO, su' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:accessorialChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charges Amount' ;
    rdfs:comment 'Total accessorial charges (e.g., liftgate, detention, residential delivery, inside delivery, hazmat handling) applied to this freight order beyond the base rate and fuel surcharge.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Pickup Timestamp' ;
    rdfs:comment 'The actual date and time the carrier picked up the freight at the origin location. Compared against the pickup window to determine on-time pickup performance for OTIF reporting.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:agreedFreightRate rdf:type rdf:Property ;
    rdfs:label 'Agreed Freight Rate' ;
    rdfs:comment 'The negotiated or spot-quoted rate agreed with the carrier for executing this freight order, expressed in the transaction currency. Used for freight cost accrual, freight audit, and carrier rate benchmarking.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Invoice Number' ;
    rdfs:comment 'Invoice number issued by the carrier for this freight order. Used for freight audit and payment matching in accounts payable. Populated upon receipt of carrier invoice.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End' ;
    rdfs:comment 'End of the agreed delivery time window at the destination location. Defines the latest acceptable delivery time per retailer or customer SLA.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start' ;
    rdfs:comment 'Start of the agreed delivery time window at the destination location. Defines the earliest acceptable delivery time per retailer or customer SLA.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Freight Audit Status' ;
    rdfs:comment 'Status of the freight invoice audit process for this freight order. Tracks whether the carrier invoice has been received, validated against the agreed rate, approved for payment, or disputed due to discrepancies.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Freight Order Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the freight order as issued by the Transportation Management System (TMS). Used in carrier communications, EDI transactions, and proof-of-delivery documents.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isColdChain rdf:type rdf:Property ;
    rdfs:label 'Is Cold Chain' ;
    rdfs:comment 'Indicates whether this freight order requires temperature-controlled cold-chain transportation (e.g., refrigerated or frozen consumer goods). Triggers reefer equipment assignment and temperature monitoring requirements.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadType rdf:type rdf:Property ;
    rdfs:label 'Load Type' ;
    rdfs:comment 'Classification of the shipment load mode. FTL (Full Truckload) indicates the carrier\'s entire trailer is dedicated to this shipment; LTL (Less-than-Truckload) indicates shared trailer space; parcel indicates small-package carrier service; intermodal indicates multi-modal container movement; rail indicates rail freight.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Number of pallets included in this freight order. Used for dock scheduling, trailer space planning, and carrier rate calculation for pallet-based pricing agreements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickupWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Pickup Window End' ;
    rdfs:comment 'End of the agreed pickup time window at the origin location. Defines the latest time the carrier may arrive for loading without incurring a late pickup penalty.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickupWindowStart rdf:type rdf:Property ;
    rdfs:label 'Pickup Window Start' ;
    rdfs:comment 'Start of the agreed pickup time window at the origin location. Defines the earliest time the carrier may arrive for loading. Used for dock scheduling and carrier compliance measurement.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date on which the shipper requests delivery at the destination location. Core input for OTIF (On Time In Full) performance measurement and retailer compliance scoring.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Requested Pickup Date' ;
    rdfs:comment 'The date on which the shipper requests the carrier to pick up the freight at the origin location. Used for OTIF (On Time In Full) measurement and carrier performance tracking.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Reference Number' ;
    rdfs:comment 'External reference number used by the carrier or 3PL to identify this shipment in their system. Enables cross-system track-and-trace and carrier invoice reconciliation via EDI (Electronic Data Interchange).' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderingMethod rdf:type rdf:Property ;
    rdfs:label 'Tendering Method' ;
    rdfs:comment 'Method used to tender the freight order to a carrier. Contract indicates a pre-negotiated rate agreement; spot indicates a one-time market rate; load_board indicates posting to a freight exchange; dedicated indicates a committed fleet arrangement; auction indicates a competitive bidding process.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmsSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Tms Source System' ;
    rdfs:comment 'Identifies the source Transportation Management System (TMS) from which this freight order record was ingested into the lakehouse. Supports data lineage, reconciliation, and multi-system integration auditing.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFreightCost rdf:type rdf:Property ;
    rdfs:label 'Total Freight Cost' ;
    rdfs:comment 'Total cost of this freight order including base rate, fuel surcharge, and all accessorial charges. Used for COGS (Cost of Goods Sold) allocation, freight budget vs. actuals reporting, and carrier invoice audit.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: DSD routes are planned and executed within sales territories in consumer goods. Territory-based route efficiency reporting, sales rep coverage alignment, and call frequency compliance all require link' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:actualDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Time' ;
    rdfs:comment 'Actual timestamp at which the vehicle departed the depot. Compared against planned_departure_time to measure on-time departure performance and identify dispatch delays.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Actual Distance Km' ;
    rdfs:comment 'Actual driving distance recorded for the route in kilometers, typically captured via telematics or GPS. Compared against planned distance for route efficiency analysis.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDurationMin rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Min' ;
    rdfs:comment 'Actual total route duration in minutes from depot departure to return. Used to measure route execution efficiency and identify deviations from plan.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualReturnTime rdf:type rdf:Property ;
    rdfs:label 'Actual Return Time' ;
    rdfs:comment 'Actual timestamp at which the vehicle returned to the depot. Used to calculate total route duration, driver overtime, and vehicle utilization.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:co2EmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Co2 Emissions Kg' ;
    rdfs:comment 'Estimated carbon dioxide emissions in kilograms for this route, calculated from fuel consumption and vehicle type. Supports sustainability reporting, ESG disclosures, and ISO 14001 environmental management.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Total planned or actual freight cost for this route in the operating currency. Used for transportation cost tracking, carrier invoice reconciliation, and freight audit processes.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelConsumptionLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Liters' ;
    rdfs:comment 'Estimated or actual fuel consumed in liters for this route. Used for fleet cost management, carbon emissions calculation, and sustainability reporting under ISO 14001.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Indicates whether this route carries hazardous materials (e.g., aerosols, flammable cleaning products) requiring special handling, placarding, and regulatory compliance under DOT and EPA regulations.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optimizationAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Optimization Algorithm' ;
    rdfs:comment 'Name or identifier of the route optimization algorithm or engine used to generate this route plan (e.g., \'VRP-TW\', \'Clarke-Wright\', \'Blue Yonder Optimizer v4.2\'). Supports algorithm performance benchmarking and audit.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Optimization Run Timestamp' ;
    rdfs:comment 'Timestamp when the route optimization algorithm was executed to generate this route plan. Used to track plan freshness and identify routes built on stale demand data.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:otifCompliant rdf:type rdf:Property ;
    rdfs:label 'Otif Compliant' ;
    rdfs:comment 'Indicates whether this route achieved full OTIF (On Time In Full) compliance — all stops were serviced within the agreed time windows and all ordered quantities were delivered. Key KPI for retailer scorecards.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Time' ;
    rdfs:comment 'Scheduled timestamp at which the vehicle is planned to depart the depot for this route. Used for driver scheduling, dock door allocation, and on-time departure KPI tracking.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Planned Distance Km' ;
    rdfs:comment 'Total planned driving distance for the route in kilometers, as calculated by the route optimization algorithm. Used for fuel cost estimation, carbon footprint calculation, and driver pay.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDurationMin rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Min' ;
    rdfs:comment 'Total planned route duration in minutes, including drive time and estimated stop dwell times. Used for driver scheduling and OTIF planning.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedReturnTime rdf:type rdf:Property ;
    rdfs:label 'Planned Return Time' ;
    rdfs:comment 'Scheduled timestamp at which the vehicle is expected to return to the depot after completing all stops. Used for driver hours-of-service compliance and dock planning.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proofOfDeliveryRequired rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Required' ;
    rdfs:comment 'Indicates whether electronic or physical proof of delivery (POD) must be captured at each stop on this route. Drives mobile app workflows for drivers and supports dispute resolution.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeDate rdf:type rdf:Property ;
    rdfs:label 'Route Date' ;
    rdfs:comment 'The calendar date on which this route is planned to be executed. Used for daily route scheduling, driver dispatch, and OTIF performance tracking.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Human-readable descriptive name for the route, typically reflecting the geographic territory or customer cluster served (e.g., \'Northeast Metro DSD Run\').' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeNumber rdf:type rdf:Property ;
    rdfs:label 'Route Number' ;
    rdfs:comment 'Externally-known business identifier for the route, used in operational communications, driver manifests, and carrier EDI exchanges. May align with SAP Transportation Management route codes.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current lifecycle state of the route. Tracks progression from planning through dispatch, active execution, and completion or cancellation. Supports real-time track-and-trace and operational dashboards.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the route by operational purpose. DSD (Direct Store Delivery) routes serve retail outlets directly; mixed routes combine deliveries and pickups; cross-dock routes transfer goods between facilities. [ENUM-REF-CANDIDATE: delivery|pickup|mixed|cross_dock|dsd|milk_run — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Service Time Window End' ;
    rdfs:comment 'Latest allowable timestamp for the route to complete servicing stops. Breaching this window results in OTIF failures and potential retailer chargebacks.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Service Time Window Start' ;
    rdfs:comment 'Earliest allowable timestamp for the route to begin servicing stops, as defined by customer or retailer receiving window constraints. Used as an input constraint in the route optimization algorithm.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalCasesDelivered rdf:type rdf:Property ;
    rdfs:label 'Total Cases Delivered' ;
    rdfs:comment 'Actual number of cases delivered across all stops on this route. Compared against total_cases_planned to compute fill rate and identify short-shipments.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCasesPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Cases Planned' ;
    rdfs:comment 'Total number of cases (selling units) planned for delivery across all stops on this route. Used for vehicle load planning and OTIF measurement.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPalletsPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Pallets Planned' ;
    rdfs:comment 'Total number of pallets planned for loading on this route. Used for vehicle capacity utilization and dock door planning.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStopsCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Stops Completed' ;
    rdfs:comment 'Actual number of stops successfully completed during route execution. Compared against total_stops_planned to measure route completion rate and identify failed deliveries.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStopsPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Stops Planned' ;
    rdfs:comment 'Total number of delivery or pickup stops planned for this route. Used for workload balancing, route complexity scoring, and driver capacity planning.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleCapacityUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Vehicle Capacity Utilization Pct' ;
    rdfs:comment 'Percentage of the vehicle\'s rated payload capacity utilized by the planned load on this route. Key metric for fleet efficiency and freight cost optimization.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Freight Invoice Id' ;
    rdfs:comment 'Unique surrogate identifier for the freight invoice record in the Consumer Goods lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ap_invoice. Business justification: Freight audit and payment processing in consumer goods requires matching carrier freight invoices to AP invoices for 3-way match, payment release, and accrual reconciliation. Finance teams directly re' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:salesInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Sales Invoice Id' ;
    rdfs:comment 'Foreign key linking to sales.invoice. Business justification: Freight cost allocation to sales invoices is required for landed cost calculation, gross margin reporting, and trade spend reconciliation. Consumer goods finance teams match carrier freight invoices t' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:accessorialAmount rdf:type rdf:Property ;
    rdfs:label 'Accessorial Amount' ;
    rdfs:comment 'Total amount of accessorial charges on the invoice, including but not limited to liftgate, residential delivery, inside delivery, detention, redelivery, and hazmat fees. Audited against contracted accessorial schedules.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Amount approved for payment to the carrier after freight audit review and any adjustments. May differ from invoiced total if disputes or corrections were applied. This is the amount that flows to accounts payable for payment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Completed Timestamp' ;
    rdfs:comment 'Date and time the freight audit review was completed for this invoice. Marks the transition from \'under_audit\' to \'approved\' or \'disputed\' status in the freight audit and pay (FAP) workflow.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contractedAmount rdf:type rdf:Property ;
    rdfs:label 'Contracted Amount' ;
    rdfs:comment 'Expected freight charge calculated from the applicable carrier contract rate for this lane, mode, and service level. Used as the benchmark in freight audit to identify billing variances.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Notes' ;
    rdfs:comment 'Free-text notes describing the reason for disputing the freight invoice, including specific discrepancies identified during freight audit. Supports carrier communication and dispute resolution.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for disputing the freight invoice (e.g., rate discrepancy, duplicate invoice, service failure, unauthorized accessorial). Populated when invoice_status is \'disputed\'. [ENUM-REF-CANDIDATE: rate_discrepancy|duplicate_invoice|service_failure|unauthorized_accessorial|weight_discrepancy|missing_bol — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Code' ;
    rdfs:comment 'EDI (Electronic Data Interchange) transaction set identifier for invoices received electronically via EDI 210 (Motor Carrier Freight Invoice) or equivalent. Enables traceability of electronic invoice transmission.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightClass rdf:type rdf:Property ;
    rdfs:label 'Freight Class' ;
    rdfs:comment 'National Motor Freight Classification (NMFC) freight class assigned to the shipment (e.g., 50, 70, 100, 150). Determines LTL (Less-Than-Truckload) base rates and is a key audit point for freight invoice validation.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date the carrier issued the freight invoice. Used to calculate payment due date, aging, and Days Sales Outstanding (DSO) metrics in freight payables.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Carrier-assigned invoice number as printed on the freight invoice document. Externally known identifier used for carrier communication, dispute resolution, and payment remittance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceSource rdf:type rdf:Property ;
    rdfs:label 'Invoice Source' ;
    rdfs:comment 'Channel through which the freight invoice was received by Consumer Goods. Used to track EDI adoption rates and identify manual processing inefficiencies.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current workflow status of the freight invoice within the freight audit and pay (FAP) process. Drives processing actions and reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the freight invoice by document type. Distinguishes standard carrier invoices from credit memos, debit memos, rebills, and adjustments for accurate financial processing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicedTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Total Amount' ;
    rdfs:comment 'Total gross amount invoiced by the carrier, inclusive of line-haul, fuel surcharge, accessorials, and taxes. This is the amount the carrier is requesting for payment before audit adjustments.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineHaulAmount rdf:type rdf:Property ;
    rdfs:label 'Line Haul Amount' ;
    rdfs:comment 'Base transportation charge for moving freight from origin to destination, excluding surcharges and accessorials. Core component of the freight invoice monetary triplet.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidDate rdf:type rdf:Property ;
    rdfs:label 'Paid Date' ;
    rdfs:comment 'Date the payment was issued to the carrier for this freight invoice. Used to calculate Days Sales Outstanding (DSO), confirm on-time payment, and support carrier relationship management.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which payment must be made to the carrier per the contracted payment terms. Critical for cash flow management and avoiding late payment penalties.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Internal payment document or check/ACH reference number assigned when the invoice was paid. Used to reconcile freight invoices against bank statements and carrier remittance advice.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Code representing the payment terms agreed with the carrier (e.g., Net30, Net45, 2/10Net30). Determines the payment due date and any early payment discount eligibility.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Consumer Goods internal purchase order number associated with the freight services procured. Used for three-way match in accounts payable and freight audit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time the freight invoice was received by Consumer Goods from the carrier, either via EDI (Electronic Data Interchange), email, or carrier portal. Marks the start of the freight audit and pay (FAP) cycle.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceDate rdf:type rdf:Property ;
    rdfs:label 'Service Date' ;
    rdfs:comment 'Date the transportation service was rendered (pickup or delivery date). Used to match the invoice to the correct accounting period and validate service delivery.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Shipment Weight Kg' ;
    rdfs:comment 'Actual or billed shipment weight in kilograms as stated on the freight invoice. Used to validate weight-based freight charges against contracted rates and detect weight discrepancies.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Monetary difference between the invoiced total amount and the contracted rate amount (invoiced_total_amount minus contracted_amount). Positive value indicates overbilling by carrier; negative indicates underbilling. Central metric in the freight audit and pay (FAP) process.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingEventId rdf:type rdf:Property ;
    rdfs:label 'Tracking Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each shipment tracking event record in the silver layer lakehouse. Primary key for the tracking_event data product.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierEventCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Event Code' ;
    rdfs:comment 'The carrier\'s native status or event code as transmitted via EDI 214/990 or carrier API (e.g., \'X1\', \'D1\', \'AF\', \'OFD\'). Preserves the source system code for carrier-specific reporting and reconciliation against carrier invoices and SLA commitments.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierSlaMet rdf:type rdf:Property ;
    rdfs:label 'Carrier Sla Met' ;
    rdfs:comment 'Indicates whether the carrier met the contracted Service Level Agreement (SLA) milestone at this event (e.g., on-time pickup, on-time delivery). Derived from comparison of event_timestamp against planned_event_timestamp and carrier contract terms. Feeds carrier performance scorecards and SLA penalty/incentive calculations.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Status' ;
    rdfs:comment 'The customs clearance status of the shipment at the time of this tracking event, applicable to cross-border shipments. Indicates whether the shipment has cleared customs, is held for inspection, pending documentation, released after hold, or seized. Critical for international supply chain visibility and compliance.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Minutes' ;
    rdfs:comment 'The number of minutes the shipment or vehicle dwelled at the event location (e.g., carrier terminal, cross-dock, customer dock) before the next movement event. Supports carrier performance analysis, dock scheduling optimization, and detention charge identification.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ediInterchangeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Edi Interchange Control Number' ;
    rdfs:comment 'The unique interchange control number from the EDI envelope (ISA segment) of the source EDI transmission that generated this tracking event. Enables end-to-end EDI message traceability and duplicate detection.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionSet rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Set' ;
    rdfs:comment 'The ANSI X12 EDI transaction set number associated with the source message that generated this tracking event (e.g., 214 = Transportation Carrier Shipment Status, 990 = Response to a Load Tender). Supports EDI audit trail and carrier integration troubleshooting.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCode rdf:type rdf:Property ;
    rdfs:label 'Equipment Code' ;
    rdfs:comment 'The identifier of the transportation equipment (trailer number, container number, railcar number, vessel IMO number) associated with this tracking event. Enables equipment-level tracking, utilization analysis, and cross-referencing with carrier equipment records.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCity rdf:type rdf:Property ;
    rdfs:label 'Event City' ;
    rdfs:comment 'The city where the tracking event occurred, as reported by the carrier or GPS system. Used for geographic visualization of shipment progress and lane-level exception analysis.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCountryCode rdf:type rdf:Property ;
    rdfs:label 'Event Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the country where the tracking event occurred (e.g., \'USA\', \'CAN\', \'MEX\'). Required for cross-border shipment tracking and customs compliance reporting.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStateProvince rdf:type rdf:Property ;
    rdfs:label 'Event State Province' ;
    rdfs:comment 'The state or province where the tracking event occurred, using standard postal abbreviations (e.g., \'CA\', \'TX\', \'ON\'). Supports regional performance reporting and regulatory compliance tracking.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Lifecycle status of this tracking event record indicating whether it is the current authoritative event (active), has been superseded by a correction, cancelled, or identified as a duplicate. Supports data quality management in the silver layer.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The precise date and time (in ISO 8601 format with timezone offset) at which the tracking event occurred in the real world, as reported by the carrier, GPS telematics system, or IoT sensor. This is the principal business event time, distinct from record ingestion timestamps.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Standardized classification of the shipment tracking event representing the current milestone or status change in the shipment lifecycle. Drives track-and-trace visibility and exception management workflows. [ENUM-REF-CANDIDATE: picked_up|in_transit|out_for_delivery|delivered|exception|delay|damage|refused — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Free-text narrative description of the exception condition, providing additional context beyond the root cause code. May include carrier notes, driver comments, or system-generated messages explaining the nature of the delay, damage, or refusal.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Boolean indicator that this tracking event represents or triggered a shipment exception condition (e.g., delay, damage, refused delivery, missed pickup, temperature breach). Drives exception management workflows and carrier performance scorecards.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionRootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Exception Root Cause Code' ;
    rdfs:comment 'Standardized root cause code categorizing the reason for a shipment exception (e.g., \'WEATHER\', \'CARRIER_DELAY\', \'CUSTOMS_HOLD\', \'MECHANICAL_FAILURE\', \'INCORRECT_ADDRESS\', \'REFUSED_BY_CONSIGNEE\', \'DAMAGED_IN_TRANSIT\'). Used for exception trend analysis and carrier performance management. [ENUM-REF-CANDIDATE: WEATHER|CARRIER_DELAY|CUSTOMS_HOLD|MECHANICAL_FAILURE|INCORRECT_ADDRESS|REFUSED_BY_CONSIGNEE|DAMAGED_IN_TRANSIT — promote to reference product]' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'The code identifying the carrier terminal, cross-dock, distribution center, port, or customer facility where the tracking event occurred (e.g., carrier hub code, GLN). Supports facility-level dwell time and throughput analysis.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated monetary value of the financial impact associated with this tracking event exception (e.g., cost of delay, damage claim value, re-delivery cost, expedite surcharge). Used for freight cost variance analysis and carrier chargeback management. Expressed in the currency defined by financial_impact_currency.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the financial impact amount (e.g., \'USD\', \'EUR\', \'GBP\'). Required for multi-currency operations across global consumer goods distribution networks.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geofenceZone rdf:type rdf:Property ;
    rdfs:label 'Geofence Zone' ;
    rdfs:comment 'The named geofence zone or virtual boundary that triggered this tracking event (e.g., \'CUSTOMER_DC_INBOUND\', \'CARRIER_TERMINAL_CHICAGO\', \'PORT_OF_LA_GATE\'). Populated for GPS telematics events generated by geofence entry/exit triggers. Supports automated milestone detection without manual carrier check-ins.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityPct rdf:type rdf:Property ;
    rdfs:label 'Humidity Pct' ;
    rdfs:comment 'Relative humidity percentage reading captured at the time of the tracking event by an IoT sensor. Relevant for moisture-sensitive consumer goods (e.g., hygiene products, paper-based packaging). Null for shipments without humidity monitoring.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Event Timestamp' ;
    rdfs:comment 'The originally scheduled or planned date and time for this event milestone (e.g., planned pickup time, planned delivery window). Compared against event_timestamp to calculate schedule adherence and On-Time In-Full (OTIF) performance at the event level.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:podMethod rdf:type rdf:Property ;
    rdfs:label 'Pod Method' ;
    rdfs:comment 'The method by which Proof of Delivery (POD) was captured for a delivered event (electronic signature, paper signature, photo confirmation, or no-signature-required). Supports POD compliance tracking and carrier contract enforcement.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSignatureName rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Name' ;
    rdfs:comment 'The name of the individual who signed for the delivery at the consignee location, as captured on the Proof of Delivery (POD) document. Populated only for \'delivered\' event types. Supports dispute resolution and delivery confirmation.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionActionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Code' ;
    rdfs:comment 'Standardized code identifying the corrective action taken to resolve the exception associated with this tracking event (e.g., \'REROUTED\', \'REDELIVERY_SCHEDULED\', \'CLAIM_FILED\', \'PRODUCT_QUARANTINED\', \'CARRIER_NOTIFIED\', \'EXPEDITED\'). Supports exception resolution tracking and SLA compliance measurement. [ENUM-REF-CANDIDATE: REROUTED|REDELIVERY_SCHEDULED|CLAIM_FILED|PRODUCT_QUARANTINED|CARRIER_NOTIFIED|EXPEDITED — promote to reference product]' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentLegNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Leg Number' ;
    rdfs:comment 'Sequential leg number within a multi-leg shipment (e.g., leg 1 = origin DC to cross-dock, leg 2 = cross-dock to destination). Enables granular tracking of multi-modal or relay shipments across the inbound and outbound network.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speedKmh rdf:type rdf:Property ;
    rdfs:label 'Speed Kmh' ;
    rdfs:comment 'The speed of the transport vehicle in kilometers per hour at the time of the GPS telematics event. Used for route compliance monitoring, driver safety analytics, and detection of unauthorized stops or route deviations. Null for non-GPS-sourced events.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureBreach rdf:type rdf:Property ;
    rdfs:label 'Temperature Breach' ;
    rdfs:comment 'Indicates whether the temperature reading at this event exceeded the shipment\'s defined cold-chain temperature range (temperature_min_c to temperature_max_c as defined on the parent shipment). True signals a cold-chain compliance violation requiring exception management and potential product quarantine.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'Ambient or product temperature reading in degrees Celsius captured at the time of the tracking event by an IoT sensor or cold-chain monitoring device. Critical for cold-chain compliance monitoring of temperature-sensitive consumer goods (e.g., personal care, food, pharmaceutical products). Null for non-cold-chain shipments.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationPostalCodeFrom rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code From' ;
    rdfs:comment 'Starting postal code of the destination zone range for this freight rate. Used for zone-based rate determination when the rate applies to a range of destination postal codes.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCodeTo rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code To' ;
    rdfs:comment 'Ending postal code of the destination zone range for this freight rate. Together with destination_postal_code_from, defines the geographic destination band to which this rate applies.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationZoneCode rdf:type rdf:Property ;
    rdfs:label 'Destination Zone Code' ;
    rdfs:comment 'Carrier-defined zone code for the destination geography. Used in conjunction with origin_zone_code for zone-pair rate determination in carrier tariff structures.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatApplicable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Applicable' ;
    rdfs:comment 'Indicates whether this freight rate applies to hazardous materials (hazmat) shipments. Consumer goods with hazmat classification (e.g., aerosols, flammable products) require specialized rates and carrier certifications per DOT and EPA regulations.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxCharge rdf:type rdf:Property ;
    rdfs:label 'Max Charge' ;
    rdfs:comment 'Maximum charge amount that applies as a cap for this rate, regardless of shipment weight or distance. Null indicates no cap. Used in negotiated contract rates to protect shippers from excessive charges on large shipments.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minCharge rdf:type rdf:Property ;
    rdfs:label 'Min Charge' ;
    rdfs:comment 'Minimum charge amount that applies regardless of shipment weight or distance. Ensures the carrier recovers a floor cost for any shipment under this rate. Used in freight cost estimation to enforce rate floor.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originPostalCodeFrom rdf:type rdf:Property ;
    rdfs:label 'Origin Postal Code From' ;
    rdfs:comment 'Starting postal code of the origin zone range for this freight rate. Used for zone-based rate determination when the rate applies to a range of origin postal codes rather than a single location.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPostalCodeTo rdf:type rdf:Property ;
    rdfs:label 'Origin Postal Code To' ;
    rdfs:comment 'Ending postal code of the origin zone range for this freight rate. Together with origin_postal_code_from, defines the geographic origin band to which this rate applies.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originZoneCode rdf:type rdf:Property ;
    rdfs:label 'Origin Zone Code' ;
    rdfs:comment 'Carrier-defined zone code for the origin geography. Zone codes are used in carrier tariff structures to group postal codes into pricing zones for simplified rate lookup.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateBasisUom rdf:type rdf:Property ;
    rdfs:label 'Rate Basis Uom' ;
    rdfs:comment 'Unit of measure that defines the denominator for the base_rate. Specifies what one unit of the rate_type represents (e.g., KG for per-kilogram rates, CWT for hundredweight, PALLET for per-pallet rates). Essential for correct freight cost computation. [ENUM-REF-CANDIDATE: KG|CWT|PALLET|MILE|KM|UNIT|SHIPMENT|CONTAINER — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Number' ;
    rdfs:comment 'Externally-known business identifier for this freight rate record, used in carrier communications, freight audit, and cost estimation workflows. Typically sourced from the carrier tariff or contract schedule.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'Origin of the freight rate — whether derived from a negotiated carrier contract, spot market quote, published tariff, or benchmark rate. Used to distinguish contracted rates from market rates in freight cost analysis.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the freight rate record. Indicates whether the rate is currently applicable for freight cost estimation and shipment planning.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotQuoteReference rdf:type rdf:Property ;
    rdfs:label 'Spot Quote Reference' ;
    rdfs:comment 'Reference number for the spot market quote when rate_source is \'spot_market\' or \'spot_quote\'. Enables traceability back to the original carrier quote for audit and freight cost reconciliation purposes.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffName rdf:type rdf:Property ;
    rdfs:label 'Tariff Name' ;
    rdfs:comment 'Name or identifier of the carrier\'s published tariff schedule from which this rate is derived. Used when rate_source is \'tariff\' to reference the specific tariff document governing the rate.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitDays rdf:type rdf:Property ;
    rdfs:label 'Transit Days' ;
    rdfs:comment 'Standard number of business days for transit from origin to destination under this rate and service level. Used in delivery date estimation, OTIF (On Time In Full) planning, and S&OP (Sales and Operations Planning).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightBreakMaxKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Max Kg' ;
    rdfs:comment 'Maximum shipment weight in kilograms for this rate to apply. Defines the upper bound of the weight break tier. Null indicates no upper limit (applies to all weights above the minimum).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakMinKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Min Kg' ;
    rdfs:comment 'Minimum shipment weight in kilograms for this rate to apply. Defines the lower bound of the weight break tier. Used in LTL and CWT-based rate structures to determine applicable rate.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultSupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Default Supply Network Node Id' ;
    rdfs:comment 'Foreign key linking to supply.network_node. Business justification: Required for assigning each SKU to its primary distribution node used in supply planning, ATP calculations, and network optimization.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:hierarchyId rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to product.product_hierarchy. Business justification: sku should be linked to its product hierarchy for classification; no existing column, so new FK added.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:primarySupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Primary Supplier Assignment for each SKU is required for sourcing strategy, cost analysis, and regulatory compliance reports.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:primarySupplierSiteId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Site Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_site. Business justification: Designating a primary supplier site per SKU supports logistics planning, VMI inventory control, and OTIF performance tracking.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierSite .

ind:color rdf:type rdf:Property ;
    rdfs:label 'Color' ;
    rdfs:comment 'Consumer-facing color descriptor for the SKU (e.g., \'Blue\', \'Clear\', \'White\'). Applicable to products where color is a differentiating attribute (e.g., hair color, cosmetics, cleaning products). Used in planogram execution and consumer-facing content.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date on which the SKU was or is planned to be permanently discontinued from the portfolio. Triggers end-of-life processes in supply chain, manufacturing, and trade. Null if the SKU is still active.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ean rdf:type rdf:Property ;
    rdfs:label 'Ean' ;
    rdfs:comment '13-digit European Article Number (EAN-13) used in international retail markets outside North America for barcode scanning and product identification. Registered with GS1.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Fefo Threshold Pct' ;
    rdfs:comment 'Minimum remaining shelf life percentage (of total shelf life) required at the time of shipment to a customer or retailer. Below this threshold, the product is considered non-shippable. Used in Blue Yonder WMS and SAP IBP inventory optimization.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inciDeclaration rdf:type rdf:Property ;
    rdfs:label 'Inci Declaration' ;
    rdfs:comment 'Full INCI (International Nomenclature of Cosmetic Ingredients) ingredient list as declared on product packaging, listed in descending order of concentration. Mandatory for cosmetic and personal care products under FDA and EU regulations. Stored in Veeva Vault.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous' ;
    rdfs:comment 'Indicates whether the SKU is classified as a hazardous material requiring special handling, storage, or transportation documentation (e.g., Safety Data Sheet / SDS). Triggers compliance workflows in logistics and warehouse management.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecyclablePackaging rdf:type rdf:Property ;
    rdfs:label 'Is Recyclable Packaging' ;
    rdfs:comment 'Indicates whether the primary packaging of the SKU is designed to be recyclable. Used in sustainability reporting, ESG disclosures, and consumer-facing labeling claims per FTC Green Guides.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatedProduct rdf:type rdf:Property ;
    rdfs:label 'Is Regulated Product' ;
    rdfs:comment 'Indicates whether the SKU is subject to regulatory approval or registration requirements (e.g., FDA OTC drug, EPA-registered disinfectant, CPSC-regulated product). Triggers regulatory submission workflows in Veeva Vault.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSustainable rdf:type rdf:Property ;
    rdfs:label 'Is Sustainable' ;
    rdfs:comment 'Indicates whether the SKU meets the company\'s sustainability criteria, such as FSC-certified packaging, RSPO-certified palm oil, or ISO 14001-aligned manufacturing. Used in sustainability reporting and ESG disclosures.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'Date on which the SKU was first commercially available for sale in any market. Used in new product development (NPD) tracking, demand planning baseline establishment, and trade promotion planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage of the SKU in the Product Lifecycle Management (PLM) framework (e.g., concept, development, launch, growth, mature, decline, discontinued). Governs which business processes are active for the SKU. Managed in Veeva Vault PLM. [ENUM-REF-CANDIDATE: concept|development|launch|growth|mature|decline|discontinued — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrp rdf:type rdf:Property ;
    rdfs:label 'Msrp' ;
    rdfs:comment 'Manufacturer Suggested Retail Price (MSRP) in the base currency. Represents the recommended consumer selling price (RSP) set by the manufacturer. Used in trade promotion planning (TPM), pricing strategy, and retailer negotiations. Confidential commercial data.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netContent rdf:type rdf:Property ;
    rdfs:label 'Net Content' ;
    rdfs:comment 'Numeric net content quantity of the product as declared on packaging (e.g., 500, 1.5, 200). Must be paired with net_content_uom. Regulated by FDA and FTC for accurate labeling. Used in COGS calculation and logistics weight/volume planning.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netContentUom rdf:type rdf:Property ;
    rdfs:label 'Net Content Uom' ;
    rdfs:comment 'Unit of measure for the net content quantity (e.g., ml, L, g, kg, oz, fl oz, ct). Aligned with GS1 UN/CEFACT unit codes. Required for regulatory labeling compliance and logistics planning. [ENUM-REF-CANDIDATE: ml|L|g|kg|oz|fl oz|ct|units — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packSize rdf:type rdf:Property ;
    rdfs:label 'Pack Size' ;
    rdfs:comment 'Number of individual consumer units contained within a single sellable pack (e.g., 1 for single unit, 2 for twin pack, 6 for multipack). Used in trade promotion planning (TPM), pricing, and distribution requirements planning (DRP).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packagingMaterialType rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Type' ;
    rdfs:comment 'Material type of the primary consumer packaging (e.g., plastic, glass, aluminum, paper, cardboard). Used in sustainability reporting, EU REACH compliance, and packaging specification management in Veeva Vault. [ENUM-REF-CANDIDATE: plastic|glass|aluminum|paper|cardboard|composite|biodegradable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioClassification rdf:type rdf:Property ;
    rdfs:label 'Portfolio Classification' ;
    rdfs:comment 'Strategic classification of the SKU within the brand portfolio (e.g., core, strategic, tail, innovation, seasonal, limited_edition). Used in S&OP (Sales and Operations Planning) prioritization, resource allocation, and SKU rationalization decisions.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productForm rdf:type rdf:Property ;
    rdfs:label 'Product Form' ;
    rdfs:comment 'Physical or chemical form of the product (e.g., liquid, powder, gel, cream, spray). Critical for manufacturing process routing in Siemens Opcenter MES, packaging specification, and regulatory classification. [ENUM-REF-CANDIDATE: liquid|powder|gel|cream|foam|spray|bar|tablet|capsule|wipe|stick|sheet — promote to reference product]' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Category' ;
    rdfs:comment 'Regulatory classification of the SKU determining the applicable regulatory framework and labeling requirements (e.g., cosmetic, OTC drug, household chemical, food). Drives compliance workflows in Veeva Vault and regulatory reporting. [ENUM-REF-CANDIDATE: cosmetic|otc_drug|household_chemical|food|dietary_supplement|medical_device|general_merchandise — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scent rdf:type rdf:Property ;
    rdfs:label 'Scent' ;
    rdfs:comment 'Consumer-facing scent or fragrance descriptor for the SKU (e.g., \'Fresh\', \'Lavender\', \'Unscented\'). Relevant for personal care and household products. Used in consumer engagement, marketing, and IFRA fragrance compliance tracking.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Abbreviated product description (typically 40–80 characters) used in ERP transactions, warehouse management systems, and EDI communications where full product names are truncated. Maps to SAP MM short text field.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'Internal alphanumeric code assigned to the SKU within the ERP system (SAP S/4HANA Material Number). Serves as the primary business identifier used in procurement, manufacturing, and sales transactions. Maps to SAP MM material number.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuStatus rdf:type rdf:Property ;
    rdfs:label 'Sku Status' ;
    rdfs:comment 'Current operational status of the SKU in the ERP system (SAP S/4HANA material status). Controls whether the SKU can be procured, manufactured, sold, or shipped. \'blocked\' prevents all transactions; \'pending_launch\' indicates pre-commercialization.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Standard cost per consumer unit used for Cost of Goods Sold (COGS) calculation, financial reporting, and profitability analysis. Set annually during standard cost roll in SAP S/4HANA CO. Confidential financial data.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Required storage conditions for the SKU throughout the supply chain (e.g., ambient, refrigerated, frozen, controlled_temperature). Drives warehouse slotting in Blue Yonder WMS, transportation lane requirements, and regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subBrand rdf:type rdf:Property ;
    rdfs:label 'Sub Brand' ;
    rdfs:comment 'Sub-brand or product line within the parent brand (e.g., \'Dove Men+Care\', \'Tide PODS\'). Enables granular brand portfolio analysis and targeted trade promotion management (TPM).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDemographic rdf:type rdf:Property ;
    rdfs:label 'Target Demographic' ;
    rdfs:comment 'Primary consumer demographic segment this SKU is designed and marketed for (e.g., adult, baby, male, female, professional). Drives consumer segmentation, marketing investment allocation, and shelf placement strategy. [ENUM-REF-CANDIDATE: adult|baby|child|teen|senior|unisex|male|female|professional|family — promote to reference product]' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Total Shelf Life Days' ;
    rdfs:comment 'Total shelf life of the SKU in days from the date of manufacture to the expiry date as declared on packaging. Used in FEFO (First Expired First Out) inventory management, Blue Yonder WMS configuration, and regulatory compliance.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upc rdf:type rdf:Property ;
    rdfs:label 'Upc' ;
    rdfs:comment '12-digit Universal Product Code (UPC-A) used primarily in North American retail for point-of-sale scanning and inventory management. Subset of GTIN. Registered with GS1 US.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variant rdf:type rdf:Property ;
    rdfs:label 'Variant' ;
    rdfs:comment 'Specific variant descriptor distinguishing this SKU from others within the same product line (e.g., \'Original\', \'Sensitive Skin\', \'Extra Strength\', \'2-in-1\'). Used in PLM lifecycle management and consumer segmentation.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeMl rdf:type rdf:Property ;
    rdfs:label 'Volume Ml' ;
    rdfs:comment 'Volume of the consumer unit in millilitres, used for liquid and semi-liquid products. Supports logistics cube utilization calculations, warehouse slotting, and transportation planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gtinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Gtin Registry Id' ;
    rdfs:comment 'Unique surrogate primary key for each GTIN registry record in the Databricks Silver layer. Assigned by the platform upon ingestion from SAP S/4HANA MM or GS1 registration source.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'The date on which the GTIN was activated and made available for commercial use, EDI transactions, and retailer catalog publication. May differ from assignment_date when a GTIN is pre-assigned during NPD but activated at product launch.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:barcodeSymbology rdf:type rdf:Property ;
    rdfs:label 'Barcode Symbology' ;
    rdfs:comment 'The barcode symbology used to encode this GTIN on the physical product or packaging (e.g., UPC-A for consumer units, ITF-14 for cases, GS1-128 for logistic labels). Determines scanner compatibility at POS, warehouse, and DSD delivery points. [ENUM-REF-CANDIDATE: UPC-A|EAN-13|EAN-8|ITF-14|GS1-128|GS1_DataBar|QR_Code — promote to reference product]' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandOwnerGln rdf:type rdf:Property ;
    rdfs:label 'Brand Owner Gln' ;
    rdfs:comment 'The 13-digit GS1 Global Location Number (GLN) identifying the legal entity that owns the brand and is responsible for the GTIN assignment. Required for GS1 Data Source (1WorldSync/Salsify) product data syndication and retailer onboarding.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casesPerPallet rdf:type rdf:Property ;
    rdfs:label 'Cases Per Pallet' ;
    rdfs:comment 'The standard number of cases stacked on one pallet (logistic unit). Used for transportation planning, warehouse slotting in Blue Yonder WMS, and pallet-level GTIN-14 assignment. Drives DRP and S&OP capacity calculations in SAP IBP.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkDigit rdf:type rdf:Property ;
    rdfs:label 'Check Digit' ;
    rdfs:comment 'The single trailing check digit of the GTIN, calculated using the GS1 modulo-10 algorithm. Used to validate GTIN integrity during barcode scanning, EDI processing, and retailer catalog ingestion. Stored explicitly to support validation workflows.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPoolPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Data Pool Publication Date' ;
    rdfs:comment 'The date on which the product data for this GTIN was first published to the GS1 data pool (GDSN). Used to track compliance with retailer new item setup timelines and GS1 sunrise date requirements.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataPoolPublished rdf:type rdf:Property ;
    rdfs:label 'Data Pool Published' ;
    rdfs:comment 'Indicates whether the full product data record for this GTIN has been published to a GS1-certified data pool (e.g., 1WorldSync, Salsify) for retailer catalog synchronization. True = published and available to subscribers; False = not yet published.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eanValue rdf:type rdf:Property ;
    rdfs:label 'Ean Value' ;
    rdfs:comment 'The 13-digit EAN-13 barcode value used for international retail scanning and cross-border trade. Populated when gtin_format is GTIN-13. Required for EU, APAC, and LATAM retailer catalog submissions and EDI transactions.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediEligible rdf:type rdf:Property ;
    rdfs:label 'Edi Eligible' ;
    rdfs:comment 'Indicates whether this GTIN is set up and approved for EDI transactions (850 Purchase Order, 856 ASN, 832 Price/Sales Catalog) with trading partners. False when the GTIN is pending retailer item setup or has failed EDI validation. Managed in SAP S/4HANA SD and Oracle Cloud EDI.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpcBrickCode rdf:type rdf:Property ;
    rdfs:label 'Gpc Brick Code' ;
    rdfs:comment 'The 8-digit GS1 Global Product Classification (GPC) Brick Code that categorizes the product into a standardized product segment, family, class, and brick. Required for GS1 data pool submissions and used by retailers for category management and planogram (POG) optimization.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1CompanyPrefix rdf:type rdf:Property ;
    rdfs:label 'Gs1 Company Prefix' ;
    rdfs:comment 'The GS1-assigned company prefix (6–12 digits) that identifies the brand owner within the GTIN structure. Issued by GS1 US or a GS1 Member Organization. Determines the number of GTINs available to the company and is embedded in every GTIN assigned by the company.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1MemberOrg rdf:type rdf:Property ;
    rdfs:label 'Gs1 Member Org' ;
    rdfs:comment 'The name of the GS1 Member Organization (e.g., GS1 US, GS1 UK, GS1 Germany) through which the company prefix was licensed. Relevant for multi-national CPG companies that hold prefixes from multiple GS1 member organizations across different markets.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1RegistrationReference rdf:type rdf:Property ;
    rdfs:label 'Gs1 Registration Reference' ;
    rdfs:comment 'The reference number or confirmation identifier issued by GS1 (or a GS1 Member Organization) upon formal registration of this GTIN in the GS1 registry. Used for audit, dispute resolution, and regulatory submissions requiring proof of GS1 registration.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1RegistryPublished rdf:type rdf:Property ;
    rdfs:label 'Gs1 Registry Published' ;
    rdfs:comment 'Indicates whether this GTIN has been published to the GS1 Registry Platform (formerly GEPIR) and is visible to trading partners and retailers for catalog synchronization. True = published; False = not yet published or withheld.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gtinFormat rdf:type rdf:Property ;
    rdfs:label 'Gtin Format' ;
    rdfs:comment 'Identifies the GTIN format variant: GTIN-8 (EAN-8 short barcode), GTIN-12 (UPC-A, North American standard), GTIN-13 (EAN-13, international standard), or GTIN-14 (ITF-14, used for cases and pallets). Determines barcode symbology and EDI transaction set usage.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtinValue rdf:type rdf:Property ;
    rdfs:label 'Gtin Value' ;
    rdfs:comment 'The full numeric GTIN string including the check digit. Supports GTIN-8, GTIN-12 (UPC-A), GTIN-13 (EAN-13), and GTIN-14 (shipping container/case) formats as defined by GS1 General Specifications. Used in barcode scanning, EDI transactions, and retailer catalog synchronization.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indicatorDigit rdf:type rdf:Property ;
    rdfs:label 'Indicator Digit' ;
    rdfs:comment 'Single leading digit (0–9) used in GTIN-14 to indicate the packaging level of a trade item. A value of 0 indicates a consumer unit; values 1–8 indicate inner packs or cases; value 9 is reserved for variable-measure trade items. Applicable only when gtin_format is GTIN-14.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innerPacksPerCase rdf:type rdf:Property ;
    rdfs:label 'Inner Packs Per Case' ;
    rdfs:comment 'The number of inner packs (display shippers or multi-packs) contained within one case. Populated only when an intermediate inner-pack packaging level exists in the hierarchy. Used in SAP S/4HANA MM BOM and GS1 packaging hierarchy declarations.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isConsumerUnit rdf:type rdf:Property ;
    rdfs:label 'Is Consumer Unit' ;
    rdfs:comment 'Indicates whether this GTIN represents the consumer-facing sellable unit (each/each pack) as opposed to an inner pack, case, or pallet. True = consumer unit eligible for POS scanning; False = logistic/trade unit. Drives OSA monitoring and POS data matching in Nielsen IQ and TradeEdge.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrderable rdf:type rdf:Property ;
    rdfs:label 'Is Orderable' ;
    rdfs:comment 'Indicates whether this GTIN is currently eligible to be ordered by retail customers via EDI or Salesforce Consumer Goods Cloud order management. False when the GTIN is retired, pending, or restricted to specific channels.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isScannable rdf:type rdf:Property ;
    rdfs:label 'Is Scannable' ;
    rdfs:comment 'Indicates whether a valid, scannable barcode (UPC/EAN/ITF-14) has been verified and approved for this GTIN. False when the barcode artwork is pending verification or has failed GS1 barcode quality verification. Used in retail execution and DSD workflows in Salesforce Consumer Goods Cloud.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVariableMeasure rdf:type rdf:Property ;
    rdfs:label 'Is Variable Measure' ;
    rdfs:comment 'Indicates whether this GTIN represents a variable-measure trade item (e.g., catch-weight products sold by weight). True = variable measure; False = fixed measure. Variable-measure GTINs use indicator digit 9 in GTIN-14 and require special POS and EDI handling per GS1 specifications.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Item Reference Number' ;
    rdfs:comment 'The item reference portion of the GTIN, assigned by the brand owner to uniquely identify the product within the company prefix. Together with the company prefix and check digit, it forms the complete GTIN. Sourced from SAP S/4HANA MM material master EAN/UPC segment.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netContentValue rdf:type rdf:Property ;
    rdfs:label 'Net Content Value' ;
    rdfs:comment 'The numeric net content quantity of the consumer unit (e.g., 400 for a 400ml shampoo bottle). Combined with net_content_uom to express the full net content declaration required on product labels per FDA and FTC labeling regulations.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingLevel rdf:type rdf:Property ;
    rdfs:label 'Packaging Level' ;
    rdfs:comment 'Identifies the packaging hierarchy level to which this GTIN is assigned: each (consumer unit), inner pack (multi-pack or display shipper), case (master carton), or pallet (logistic unit). Drives EDI order management, warehouse scanning, and DRP/MRP planning in SAP S/4HANA and Blue Yonder WMS.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmLifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Plm Lifecycle Stage' ;
    rdfs:comment 'The current PLM lifecycle stage of the product associated with this GTIN: concept, development, commercialization, active (in market), end_of_life (phase-out initiated), or discontinued. Sourced from the PLM system and used to govern GTIN activation, EDI eligibility, and retailer catalog status.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'The internal product category classification (e.g., Hair Care, Skin Care, Oral Care, Home Care) to which the SKU belongs. Aligns with the company\'s PLM product hierarchy and Nielsen IQ category definitions for market share reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Short consumer-facing product description associated with this GTIN, as published to retailer catalogs and GS1 data pools. Typically includes brand name, product name, variant, and net content (e.g., \'Brand X Moisturizing Shampoo 400ml\'). Sourced from SAP S/4HANA MM material description.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the GTIN registration: active (in use and published to trading partners), pending (assigned but not yet published), inactive (temporarily suspended), retired (permanently discontinued), or cancelled (assigned in error and voided). Governs EDI eligibility and retailer catalog synchronization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'The date on which the GTIN was retired or discontinued from active commercial use. Per GS1 GTIN Management Standard, a retired GTIN must not be reassigned for a minimum of 48 months. Null when the GTIN is still active.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemKey rdf:type rdf:Property ;
    rdfs:label 'Source System Key' ;
    rdfs:comment 'The natural key or internal identifier of this GTIN record in the originating source system (e.g., SAP material number + EAN category combination). Used for delta-load reconciliation, deduplication, and lineage tracing in the Databricks Silver layer ingestion pipeline.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarketCountry rdf:type rdf:Property ;
    rdfs:label 'Target Market Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary market for which this GTIN is intended. A single SKU may have different GTINs for different target markets due to regulatory labeling, language, or formulation differences. Used in GS1 data pool syndication and Veeva Vault regulatory submissions.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsPerCase rdf:type rdf:Property ;
    rdfs:label 'Units Per Case' ;
    rdfs:comment 'The number of consumer units (eaches) contained within one case (master carton). Used in SAP S/4HANA MM for BOM/packaging hierarchy, DRP/MRP planning, and EDI order quantity validation. Also referenced in Blue Yonder WMS for receiving and putaway.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upcValue rdf:type rdf:Property ;
    rdfs:label 'Upc Value' ;
    rdfs:comment 'The 12-digit UPC-A barcode value assigned to the consumer unit (each). Derived from the GTIN-12 and used primarily for North American retail POS scanning and retailer item setup. Populated only when gtin_format is GTIN-12.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Parent Hierarchy Id' ;
    rdfs:comment 'Reference to the immediate parent node in the product hierarchy tree. NULL for root-level nodes (e.g., Division). Enables recursive traversal of the Division → Category → Sub-Category → Brand → Sub-Brand → Product Form → SKU hierarchy.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which this hierarchy node was formally approved by the data steward or product management team. Supports PLM lifecycle governance and audit trail for regulatory submissions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Code of the Category-level ancestor node for this hierarchy node. Denormalized to support category management, trade promotion planning (TPM), and demand forecasting without recursive hierarchy joins.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Distribution channels through which products in this hierarchy node are sold (e.g., \'Retail\', \'E-Commerce\', \'DTC\', \'Wholesale\', \'DSD\'). Supports channel management, trade promotion planning, and distribution requirements planning (DRP). [ENUM-REF-CANDIDATE: Retail|E-Commerce|DTC|Wholesale|DSD|Club|Drug — promote to reference product]' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscRegulated rdf:type rdf:Property ;
    rdfs:label 'Cpsc Regulated' ;
    rdfs:comment 'Indicates whether products in this hierarchy node are subject to CPSC (Consumer Product Safety Commission) regulations. True = product safety testing, labeling, and reporting requirements under CPSA apply.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'Code of the top-level Division node to which this hierarchy node belongs (e.g., \'HPC\' for Home & Personal Care, \'FOOD\' for Food & Beverage). Denormalized for fast filtering in OLAP queries and S&OP (Sales and Operations Planning) reporting without full hierarchy traversal.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date after which this hierarchy node is no longer active. NULL indicates an open-ended validity. Used for hierarchy versioning, portfolio rationalization, and ensuring discontinued nodes are excluded from forward-looking demand plans.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External partner or retailer-specific category code mapped to this hierarchy node (e.g., Walmart category code, Amazon browse node ID). Supports EDI (Electronic Data Interchange) transactions, retailer data synchronization, and VMI (Vendor Managed Inventory) programs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpStandard rdf:type rdf:Property ;
    rdfs:label 'Gmp Standard' ;
    rdfs:comment 'Applicable GMP (Good Manufacturing Practice) standard for manufacturing products in this hierarchy node. Drives quality management requirements in Siemens Opcenter MES and Veeva Vault QMS. ISO 22716 applies to cosmetics; 21 CFR 111 to dietary supplements; 21 CFR 210/211 to pharmaceuticals.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpcBrickName rdf:type rdf:Property ;
    rdfs:label 'Gpc Brick Name' ;
    rdfs:comment 'Descriptive name of the GS1 GPC brick code associated with this hierarchy node (e.g., \'Shampoo/Conditioner - Non-Medicated\'). Supports regulatory submissions, retailer onboarding, and GS1 data pool synchronization.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of this node within the product classification hierarchy. Level 1 = Division, Level 2 = Category, Level 3 = Sub-Category, Level 4 = Brand, Level 5 = Sub-Brand, Level 6 = Product Form, Level 7 = SKU (Stock Keeping Unit). Used for OLAP drill-down and aggregation logic.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ibpPlanningLevel rdf:type rdf:Property ;
    rdfs:label 'Ibp Planning Level' ;
    rdfs:comment 'Indicates whether this hierarchy node is a designated planning level in SAP IBP (Integrated Business Planning) for demand forecasting and S&OP (Sales and Operations Planning). True = this node is an active planning aggregation point.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inciApplicable rdf:type rdf:Property ;
    rdfs:label 'Inci Applicable' ;
    rdfs:comment 'Indicates whether products in this hierarchy node require INCI (International Nomenclature of Cosmetic Ingredients) ingredient declaration on labeling. True = cosmetic/personal care products subject to EU Cosmetics Regulation and FDA cosmetic labeling requirements.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iriCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Iri Category Code' ;
    rdfs:comment 'IRI (now Circana) proprietary category code mapped to this hierarchy node. Supports market share reporting, TDP (Total Distribution Points) analysis, and SOM (Share of Market) calculations using IRI syndicated data.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLeafNode rdf:type rdf:Property ;
    rdfs:label 'Is Leaf Node' ;
    rdfs:comment 'Indicates whether this node is a terminal leaf in the hierarchy (True = no children exist, typically the SKU level). Used to filter for assignable product nodes in demand forecasting, inventory management, and trade promotion planning.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:levelName rdf:type rdf:Property ;
    rdfs:label 'Level Name' ;
    rdfs:comment 'Business label for the hierarchy depth of this node. Enumerated values correspond to the CPG/FMCG standard classification spine: Division, Category, Sub-Category, Brand, Sub-Brand, Product Form, SKU (Stock Keeping Unit). Drives display logic in reporting tools and S&OP dashboards. [ENUM-REF-CANDIDATE: Division|Category|Sub-Category|Brand|Sub-Brand|Product Form|SKU — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketShareReportable rdf:type rdf:Property ;
    rdfs:label 'Market Share Reportable' ;
    rdfs:comment 'Indicates whether this hierarchy node is included in external market share reporting via Nielsen IQ or IRI/Circana syndicated data. True = node is mapped to a syndicated data category for SOM (Share of Market) and ACV (All Commodity Volume) reporting.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nielsenCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Category Code' ;
    rdfs:comment 'Nielsen IQ proprietary category code mapped to this hierarchy node. Enables direct linkage between internal product classification and Nielsen IQ retail measurement data for market share reporting, ACV (All Commodity Volume) analysis, and competitive benchmarking.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this hierarchy node within its level. Used as the business key in SAP S/4HANA MM product group structures and referenced in EDI transactions and trade promotion planning systems.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeDescription rdf:type rdf:Property ;
    rdfs:label 'Node Description' ;
    rdfs:comment 'Extended business description of the hierarchy node providing additional context about the product grouping, its scope, and intended use in classification. Supports regulatory categorization and PLM documentation.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable business name of this hierarchy node (e.g., \'Personal Care\', \'Shampoo\', \'Head & Shoulders\', \'Classic Clean\'). Used in OLAP drill-down reports, trade promotion planning, and market share dashboards.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current lifecycle status of this hierarchy node. \'active\' nodes are available for use in planning, trade promotion, and reporting. \'discontinued\' nodes are retained for historical analysis. \'pending\' nodes are awaiting approval in the PLM (Product Lifecycle Management) workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:path rdf:type rdf:Property ;
    rdfs:label 'Path' ;
    rdfs:comment 'Materialized full path string from root to this node using a delimiter (e.g., \'Consumer Goods / Personal Care / Hair Care / Shampoo / Head & Shoulders / Classic Clean\'). Enables fast string-based filtering and display in BI tools without recursive joins.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRegulated rdf:type rdf:Property ;
    rdfs:label 'Reach Regulated' ;
    rdfs:comment 'Indicates whether products in this hierarchy node are subject to EU REACH Regulation (Registration, Evaluation, Authorisation and Restriction of Chemicals). True = chemical substance registration and SDS (Safety Data Sheet) requirements apply.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Identifies the primary regulatory framework governing products classified under this hierarchy node (e.g., \'FDA OTC Drug\', \'FDA Cosmetic\', \'EPA Pesticide\', \'CPSC Consumer Product\', \'EU Cosmetics Regulation\'). Drives compliance workflows in Veeva Vault and regulatory labeling requirements. [ENUM-REF-CANDIDATE: FDA OTC Drug|FDA Cosmetic|EPA Pesticide|CPSC Consumer Product|EU Cosmetics Regulation|REACH|ISO 22716|IFRA — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric sequence controlling the display order of sibling nodes within the same parent. Used to enforce business-defined ordering in planograms (POG), category management reports, and trade promotion planning interfaces.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemNodeCode rdf:type rdf:Property ;
    rdfs:label 'Source System Node Code' ;
    rdfs:comment 'Native identifier of this hierarchy node in the originating operational system (e.g., SAP product hierarchy node ID, Veeva Vault record ID). Enables reverse traceability from the Silver Layer back to the system of record for reconciliation and audit.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Flag' ;
    rdfs:comment 'Indicates whether products in this hierarchy node carry a sustainability certification (e.g., FSC, RSPO, ISO 14001). Supports ESG reporting, sustainable sourcing procurement decisions, and consumer-facing sustainability claims.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Tax Category Code' ;
    rdfs:comment 'Tax classification code assigned to this hierarchy node for VAT/GST determination in SAP S/4HANA FI/CO. Drives correct tax treatment in sales orders, invoicing, and financial reporting across jurisdictions.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Monotonically incrementing version counter for this hierarchy node record. Incremented each time the node definition is materially changed (e.g., reclassification, rename, regulatory framework update). Supports SCD Type 2 history management and audit compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productBomId rdf:type rdf:Property ;
    rdfs:label 'Product Bom Id' ;
    rdfs:comment 'Unique surrogate identifier for the Bill of Materials (BOM) header record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductBom .

ind:formulationId rdf:type rdf:Property ;
    rdfs:label 'Formulation Id' ;
    rdfs:comment 'Foreign key linking to product.product_formulation. Business justification: product_bom currently has a formulation_code (STRING) that is a string reference to the product_formulation record. This is a classic denormalized string reference that should be a proper FK. Adding p' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Formulation .

ind:specificationId rdf:type rdf:Property ;
    rdfs:label 'Specification Id' ;
    rdfs:comment 'Foreign key linking to quality.specification. Business justification: GMP change control and BOM validation processes require linking each BOM to its governing quality specification. QA teams use this link during BOM approval reviews to verify component acceptance crite' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:alternativeBom rdf:type rdf:Property ;
    rdfs:label 'Alternative Bom' ;
    rdfs:comment 'Alternative BOM identifier (SAP STLAL) allowing multiple BOM variants for the same material and plant combination. Used to manage seasonal formulations, regional variants, or cost-optimized alternatives within the same SKU.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Quantity' ;
    rdfs:comment 'The reference quantity of the finished or semi-finished material for which the BOM component quantities are specified. All component quantities in BOM line items are expressed relative to this base quantity. Typically 1 or 100 in CPG manufacturing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseUom rdf:type rdf:Property ;
    rdfs:label 'Base Uom' ;
    rdfs:comment 'Unit of measure for the BOM base quantity (e.g., KG, L, EA, G). Defines the unit in which the finished good is expressed for component ratio calculations. Aligns with SAP base unit of measure (MARA-MEINS) and GS1 unit codes.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomCategory rdf:type rdf:Property ;
    rdfs:label 'Bom Category' ;
    rdfs:comment 'SAP BOM category indicating the object type the BOM is assigned to. \'material\' is the standard category for product BOMs in CPG/FMCG. \'equipment\' and \'functional_location\' apply to plant maintenance BOMs. Aligns with SAP STKO-STLTY.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomDescription rdf:type rdf:Property ;
    rdfs:label 'Bom Description' ;
    rdfs:comment 'Human-readable description of the BOM, typically including the product name, formulation variant, and intended use. Used in PLM, engineering change orders, and regulatory documentation.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLevel rdf:type rdf:Property ;
    rdfs:label 'Bom Level' ;
    rdfs:comment 'Indicates the level of the BOM in a multi-level product structure. Level 0 is the finished good, level 1 represents direct components, level 2 represents sub-components, etc. Used for multi-level BOM explosion in MRP and costing roll-ups.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Number' ;
    rdfs:comment 'Externally-known BOM document number as assigned in SAP S/4HANA PP/MM (e.g., SAP BOM header number). This is the business-facing identifier used in PLM, procurement, and manufacturing communications.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomType rdf:type rdf:Property ;
    rdfs:label 'Bom Type' ;
    rdfs:comment 'Classifies the purpose of the BOM. \'production\' is used for manufacturing execution (MRP/MES), \'costing\' for COGS and standard cost roll-up, \'engineering\' for R&D and NPD design, \'sales\' for variant configuration, \'configurable\' for multi-variant BOMs. Aligns with SAP BOM usage (STLAL).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'Engineering Change Number (ECN) or Engineering Change Order (ECO) reference that authorized the creation or modification of this BOM version. Provides traceability from BOM changes back to the formal change management process in PLM.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCount rdf:type rdf:Property ;
    rdfs:label 'Component Count' ;
    rdfs:comment 'Total number of active component line items in this BOM. Provides a quick indicator of BOM complexity and is used in BOM completeness validation checks during PLM review and quality audits.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costingRelevance rdf:type rdf:Property ;
    rdfs:label 'Costing Relevance' ;
    rdfs:comment 'Indicates whether this BOM is relevant for product costing (COGS calculation and standard cost roll-up). \'relevant\' means the BOM is included in cost estimates, \'not_relevant\' excludes it, \'conditional\' applies under specific costing scenarios. Critical for financial reporting and EBITDA analysis.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'Indicates whether this BOM has been flagged for deletion in SAP. A deletion flag marks the BOM as logically deleted without physically removing the record, preserving audit history. Aligns with SAP STKO-LOEKZ.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpCompliant rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant' ;
    rdfs:comment 'Indicates whether this BOM has been validated as compliant with Good Manufacturing Practice (GMP) standards. Required for health, hygiene, and personal care products. Compliance is verified during quality review before BOM activation.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConfigurable rdf:type rdf:Property ;
    rdfs:label 'Is Configurable' ;
    rdfs:comment 'Indicates whether this BOM supports variant configuration, allowing different component selections based on product characteristics (e.g., fragrance variant, pack size). Used for configurable products in CPG where a single BOM covers multiple SKU variants.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhantom rdf:type rdf:Property ;
    rdfs:label 'Is Phantom' ;
    rdfs:comment 'Indicates whether this BOM represents a phantom assembly — a logical grouping of components that does not physically exist as a stocked item but is used to simplify BOM structures. Phantom assemblies are exploded through in MRP without generating production orders.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastChangedBy rdf:type rdf:Property ;
    rdfs:label 'Last Changed By' ;
    rdfs:comment 'User ID or name of the person who last modified this BOM record. Part of the change audit trail required for GMP, engineering change management, and SOX compliance.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this BOM record in the source system. Used for incremental data loading, change detection, and audit trail maintenance.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotSizeFrom rdf:type rdf:Property ;
    rdfs:label 'Lot Size From' ;
    rdfs:comment 'Minimum lot size for which this BOM is valid. BOMs can be lot-size dependent in process manufacturing, where component quantities vary based on batch size. Used in conjunction with lot_size_to to define the valid production quantity range.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeTo rdf:type rdf:Property ;
    rdfs:label 'Lot Size To' ;
    rdfs:comment 'Maximum lot size for which this BOM is valid. Defines the upper bound of the production quantity range for lot-size-dependent BOMs. Null indicates no upper limit.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeUom rdf:type rdf:Property ;
    rdfs:label 'Lot Size Uom' ;
    rdfs:comment 'Unit of measure for the lot size range (lot_size_from and lot_size_to). Typically matches the base UOM of the finished good (e.g., KG, L, EA).' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'SAP material number (MATNR) of the finished good or semi-finished product for which this BOM is defined. This is the externally-known product code used across SAP modules (MM, PP, SD, CO) and in EDI transactions with trading partners.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpRelevance rdf:type rdf:Property ;
    rdfs:label 'Mrp Relevance' ;
    rdfs:comment 'Indicates whether this BOM is used in Material Requirements Planning (MRP) runs for procurement and production scheduling. When true, MRP will explode this BOM to generate dependent requirements for components and raw materials.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'Four-character SAP plant code identifying the manufacturing facility or production site where this BOM is applicable. Used in MRP, production orders, and supply chain planning (SAP IBP).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmStatus rdf:type rdf:Property ;
    rdfs:label 'Plm Status' ;
    rdfs:comment 'Current lifecycle state of the BOM as managed in the PLM process. \'draft\' indicates initial creation, \'in_review\' is under engineering/regulatory review, \'approved\' is signed off but not yet released to production, \'active\' is in use for manufacturing, \'obsolete\' is retired, \'superseded\' has been replaced by a newer BOM version.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVersion rdf:type rdf:Property ;
    rdfs:label 'Production Version' ;
    rdfs:comment 'SAP production version identifier (MKAL-VERID) that links this BOM to a specific routing/recipe and production line. A material may have multiple production versions representing different manufacturing processes or lines at the same plant.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachCompliant rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant' ;
    rdfs:comment 'Indicates whether all chemical substances in this BOM are compliant with EU REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) regulation. Mandatory for products sold in the European Union.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Status of regulatory approval for this BOM/formulation. Indicates whether the ingredient composition has been reviewed and approved by relevant regulatory bodies (FDA, EU REACH, CPSC). Required before a BOM can be released to active production status.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rspoCertified rdf:type rdf:Property ;
    rdfs:label 'Rspo Certified' ;
    rdfs:comment 'Indicates whether palm oil or palm-derived ingredients in this BOM are sourced from RSPO-certified sustainable sources. Relevant for personal care and household products containing palm oil derivatives. Supports sustainability reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemBomCode rdf:type rdf:Property ;
    rdfs:label 'Source System Bom Code' ;
    rdfs:comment 'The native primary key or document number of this BOM record in the originating source system (e.g., SAP internal BOM header key combining MATNR+WERKS+STLAL+STLAN). Enables traceability back to the system of record.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User ID or name of the person who created this BOM record in SAP S/4HANA or the PLM system. Part of the mandatory audit trail for GMP and SOX compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLineId rdf:type rdf:Property ;
    rdfs:label 'Bom Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual component line within a Bill of Materials. Primary key for this entity. Role: TRANSACTION_LINE.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BomLine .

ind:approvedSupplierListId rdf:type rdf:Property ;
    rdfs:label 'Approved Supplier List Id' ;
    rdfs:comment 'Foreign key linking to procurement.approved_supplier_list. Business justification: Each BOM line component must reference an approved supplier list entry to enforce qualified sourcing during production. GMP compliance in consumer goods manufacturing requires that every BOM component' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovedSupplierList .

ind:materialId rdf:type rdf:Property ;
    rdfs:label 'Material Id' ;
    rdfs:comment 'Foreign key linking to product.material. Business justification: Each BOM line specifies a component (raw material, packaging component, etc.). The material table is the authoritative master for all materials in the domain. bom_line.component_item_number is a strin' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:restrictedSubstanceId rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Id' ;
    rdfs:comment 'Foreign key linking to regulatory.restricted_substance. Business justification: BOM components must be screened against restricted substance lists (REACH SVHC, RoHS, California Prop 65) during product development and supplier qualification. This FK enables automated restricted su' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RestrictedSubstance .

ind:alternativeItemGroup rdf:type rdf:Property ;
    rdfs:label 'Alternative Item Group' ;
    rdfs:comment 'Groups multiple BOM lines that are interchangeable alternatives for the same component requirement. All lines sharing the same group code can substitute for one another, enabling flexible sourcing and production planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativePriority rdf:type rdf:Property ;
    rdfs:label 'Alternative Priority' ;
    rdfs:comment 'Numeric priority rank within an alternative item group, determining the preferred order of substitution when multiple alternatives exist. Lower numbers indicate higher preference (e.g., 1 = first choice).' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomItemCategory rdf:type rdf:Property ;
    rdfs:label 'Bom Item Category' ;
    rdfs:comment 'SAP BOM item category code that controls how the component is procured and managed. Determines whether the item is stocked, non-stocked, variable-size, or a document/text item. [ENUM-REF-CANDIDATE: stock|non_stock|variable_size|document|text|class — promote to reference product]' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Bulk Material Flag' ;
    rdfs:comment 'Indicates whether this component is a bulk material that is not individually picked or issued but is consumed from a bulk supply point on the shop floor. Bulk materials are typically excluded from individual goods issue postings.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coProductFlag rdf:type rdf:Property ;
    rdfs:label 'Co Product Flag' ;
    rdfs:comment 'Indicates whether this BOM line represents a co-product or by-product that is produced alongside the primary output. Co-products have positive quantities and receive a portion of the production cost allocation.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:componentCostUsd rdf:type rdf:Property ;
    rdfs:label 'Component Cost Usd' ;
    rdfs:comment 'The standard cost per unit of measure for this component in USD, used for COGS (Cost of Goods Sold) calculation and product costing. Sourced from the material master standard price or moving average price.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Human-readable description of the component material, such as \'HDPE Bottle 500ml Natural\' or \'Fragrance Blend XY-204\'. Used in procurement, quality, and manufacturing documentation.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Classification of the component indicating its role in the manufacturing process. Drives MRP planning logic and COGS categorization. [ENUM-REF-CANDIDATE: raw_material|packaging|semi_finished|finished_good|co_product|by_product — promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedQuantityFlag rdf:type rdf:Property ;
    rdfs:label 'Fixed Quantity Flag' ;
    rdfs:comment 'Indicates whether the component quantity is fixed regardless of the parent order quantity (True) or scales proportionally with the production order size (False). Fixed quantities are common for setup materials, catalysts, or tooling items.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether this component is classified as a hazardous material under applicable regulations (e.g., OSHA HazCom, EU CLP, DOT). Triggers special handling, storage, and transportation requirements and SDS documentation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inciName rdf:type rdf:Property ;
    rdfs:label 'Inci Name' ;
    rdfs:comment 'The standardized INCI (International Nomenclature of Cosmetic Ingredients) name for this component when used in personal care or cosmetic formulations. Required for regulatory ingredient labeling compliance on finished product packaging.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAlternativeItem rdf:type rdf:Property ;
    rdfs:label 'Is Alternative Item' ;
    rdfs:comment 'Indicates whether this BOM line represents an alternative or substitute component that can be used in place of the primary component. Alternative items are used when the primary component is unavailable, supporting supply continuity.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCriticalComponent rdf:type rdf:Property ;
    rdfs:label 'Is Critical Component' ;
    rdfs:comment 'Indicates whether this component is designated as critical to the production of the parent SKU. Critical components trigger priority procurement actions and are subject to enhanced supply chain monitoring and safety stock policies.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueMethod rdf:type rdf:Property ;
    rdfs:label 'Issue Method' ;
    rdfs:comment 'The method by which this component is issued from inventory to the production order. Backflush automatically posts consumption upon order confirmation; manual requires explicit goods issue; pick list generates a picking document; kanban uses replenishment signals.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Offset Days' ;
    rdfs:comment 'The number of days before or after the parent order start date that this component must be available. Positive values indicate the component is needed before production start; negative values indicate it is needed after. Used in MRP scheduling.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle status of this BOM line item. Controls whether the component is included in active MRP runs and procurement planning. Inactive or obsolete lines are retained for historical traceability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'The minimum quantity of this component that must be ordered from the supplier in a single purchase order. Used in procurement planning to ensure order quantities meet supplier MOQ (Minimum Order Quantity) requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Number' ;
    rdfs:comment 'Reference to the specific production routing operation or work center step at which this component is consumed. Enables precise material staging and backflushing in the MES and MRP systems.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phantomItemFlag rdf:type rdf:Property ;
    rdfs:label 'Phantom Item Flag' ;
    rdfs:comment 'Indicates whether this BOM line represents a phantom assembly — a logical grouping of components that is not physically stocked or produced as a discrete item but is exploded through in MRP planning.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Number' ;
    rdfs:comment 'The EU REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) registration number for this chemical component. Required for substances manufactured or imported into the EU above threshold quantities.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recursiveBomFlag rdf:type rdf:Property ;
    rdfs:label 'Recursive Bom Flag' ;
    rdfs:comment 'Indicates whether this component itself has a subordinate BOM (i.e., it is a sub-assembly or semi-finished good with its own BOM structure). Used to identify multi-level BOM explosion requirements in MRP planning.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredQuantity rdf:type rdf:Property ;
    rdfs:label 'Required Quantity' ;
    rdfs:comment 'The quantity of the component required to produce one unit of the parent SKU at the base quantity defined in the BOM header. Satisfies TRANSACTION_LINE LINE_QUANTITY category. Supports MRP and COGS calculation.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Percentage' ;
    rdfs:comment 'The expected percentage of this component that will be lost or wasted during the manufacturing process. Used to inflate the planned component quantity in MRP runs and COGS calculations. Expressed as a percentage (e.g., 2.5 = 2.5%).' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdsDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Document Number' ;
    rdfs:comment 'The document number or reference identifier for the Safety Data Sheet (SDS) associated with this hazardous component. Links to the SDS stored in Veeva Vault or the document management system for regulatory compliance.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Usage Probability Pct' ;
    rdfs:comment 'The probability (expressed as a percentage, 0–100) that this alternative component will actually be used in production. Used by MRP to calculate weighted component requirements across alternative item groups.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this BOM line is effective and should be included in production and MRP planning. Supports date-effective BOM management for product reformulations and packaging changes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date after which this BOM line is no longer effective and should be excluded from production and MRP planning. Null indicates the line is open-ended with no planned expiry.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeIngredientName rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient Name' ;
    rdfs:comment 'Name of the primary active ingredient in the formulation (e.g., \'Salicylic Acid\', \'Zinc Pyrithione\', \'Fluoride\'). Required for OTC drug product regulatory filings with FDA and for consumer-facing efficacy claims.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeIngredientPct rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient Pct' ;
    rdfs:comment 'Concentration of the primary active ingredient expressed as a weight percentage (w/w%) of the total formulation. Proprietary trade secret data. Governs regulatory classification (OTC drug vs. cosmetic), label claims, and dosage compliance.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allergenDeclaration rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration' ;
    rdfs:comment 'Free-text or structured declaration of regulated allergens present in the formulation above threshold concentrations (e.g., EU 26 listed fragrance allergens, FDA major food allergens for food-contact products). Required for consumer safety labeling.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Bom Reference Code' ;
    rdfs:comment 'Reference code linking this formulation to the corresponding Bill of Materials (BOM) in SAP S/4HANA PP/MM. Enables traceability between the approved formulation recipe and the manufacturing BOM used for production planning and Material Requirements Planning (MRP).' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorDescription rdf:type rdf:Property ;
    rdfs:label 'Color Description' ;
    rdfs:comment 'Standardized color description of the finished formulation as specified in the quality standard (e.g., \'White to off-white\', \'Clear colorless\', \'Pale yellow\'). Used in visual QC inspection and consumer safety documentation.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationCode rdf:type rdf:Property ;
    rdfs:label 'Formulation Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the formulation within the Product Lifecycle Management (PLM) system. Sourced from Veeva Vault PLM and used as the cross-system business key across SAP S/4HANA QM and Siemens Opcenter MES.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationName rdf:type rdf:Property ;
    rdfs:label 'Formulation Name' ;
    rdfs:comment 'Human-readable descriptive name of the formulation as registered in the PLM system (e.g., \'Moisturizing Body Lotion Base v2 - Fragrance Free\'). Used in regulatory submissions, quality documents, and R&D reporting.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationType rdf:type rdf:Property ;
    rdfs:label 'Formulation Type' ;
    rdfs:comment 'Physical form classification of the formulation describing its physicochemical structure. Drives manufacturing process selection, packaging requirements, and stability testing protocols. [ENUM-REF-CANDIDATE: emulsion|solution|suspension|gel|powder|foam|aerosol|solid — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fragranceCode rdf:type rdf:Property ;
    rdfs:label 'Fragrance Code' ;
    rdfs:comment 'Proprietary or supplier-assigned code identifying the fragrance ingredient blend used in this formulation. Required for IFRA compliance assessment, allergen declaration, and INCI ingredient listing on product labels.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Flag' ;
    rdfs:comment 'Indicates whether the formulation has been developed and validated in compliance with Good Manufacturing Practice (GMP) standards. Required for commercial manufacturing authorization and regulatory audit readiness.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intendedUse rdf:type rdf:Property ;
    rdfs:label 'Intended Use' ;
    rdfs:comment 'Declared intended use or application of the formulation (e.g., \'Rinse-off body wash for daily use\', \'Leave-on facial moisturizer\', \'Hard surface disinfectant cleaner\'). Determines regulatory classification pathway and labeling requirements.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCrueltyFree rdf:type rdf:Property ;
    rdfs:label 'Is Cruelty Free' ;
    rdfs:comment 'Indicates whether the formulation and its constituent ingredients have not been tested on animals. Supports cruelty-free certification claims and compliance with EU animal testing ban under Cosmetics Regulation 1223/2009.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFragranceFree rdf:type rdf:Property ;
    rdfs:label 'Is Fragrance Free' ;
    rdfs:comment 'Indicates whether the formulation contains no added fragrance ingredients. Drives consumer-facing label claims, regulatory declarations, and product positioning for sensitive-skin or hypoallergenic product lines.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVegan rdf:type rdf:Property ;
    rdfs:label 'Is Vegan' ;
    rdfs:comment 'Indicates whether the formulation contains no animal-derived ingredients or by-products. Supports consumer-facing vegan label claims and retailer listing requirements for vegan-certified product ranges.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labNotebookReference rdf:type rdf:Property ;
    rdfs:label 'Lab Notebook Reference' ;
    rdfs:comment 'Reference identifier for the electronic laboratory notebook (ELN) entry or physical lab notebook record documenting the original formulation development experiments. Provides scientific traceability for regulatory submissions and IP protection.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obsolescenceDate rdf:type rdf:Property ;
    rdfs:label 'Obsolescence Date' ;
    rdfs:comment 'Date on which this formulation version was or is scheduled to be retired and replaced by a newer version. Null for currently active formulations. Used in manufacturing planning to manage version transitions.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phMax rdf:type rdf:Property ;
    rdfs:label 'Ph Max' ;
    rdfs:comment 'Maximum acceptable pH value of the formulation as defined in the approved specification. Together with ph_min, defines the pH range tolerance band for quality control (QC) release testing and in-process checks.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phMin rdf:type rdf:Property ;
    rdfs:label 'Ph Min' ;
    rdfs:comment 'Minimum acceptable pH value of the formulation as defined in the approved specification. Used in quality control (QC) testing and stability assessments. pH range is a critical quality attribute (CQA) for consumer safety and product efficacy.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preservativeSystem rdf:type rdf:Property ;
    rdfs:label 'Preservative System' ;
    rdfs:comment 'Description or code identifying the preservative system used in the formulation (e.g., \'Phenoxyethanol/Ethylhexylglycerin\', \'Benzalkonium Chloride\', \'Paraben-free system\'). Critical for regulatory compliance, challenge testing, and consumer safety claims.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rdProjectCode rdf:type rdf:Property ;
    rdfs:label 'Rd Project Code' ;
    rdfs:comment 'Reference code linking this formulation to the originating Research and Development (R&D) / New Product Development (NPD) project in the PLM system. Enables traceability from commercial formulation back to the innovation pipeline.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Regulatory product classification determining the applicable compliance framework and submission pathway. Drives FDA, EPA, or CPSC filing requirements and labeling obligations.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Stability Period Months' ;
    rdfs:comment 'Approved shelf-life stability period of the formulation expressed in months, as determined by accelerated and real-time stability studies. Drives product expiry date calculation, FEFO inventory management, and label \'best before\' declarations.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Specified storage conditions required to maintain formulation integrity and stability (e.g., \'Store below 25°C, away from direct sunlight\', \'Refrigerate at 2-8°C\'). Used in warehouse management (WMS), logistics planning, and label compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSolidContentPct rdf:type rdf:Property ;
    rdfs:label 'Total Solid Content Pct' ;
    rdfs:comment 'Total solid content of the formulation expressed as weight percentage (w/w%). Key physical property used in manufacturing process design, packaging compatibility assessment, and stability testing protocols.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viscosityMaxCps rdf:type rdf:Property ;
    rdfs:label 'Viscosity Max Cps' ;
    rdfs:comment 'Maximum acceptable viscosity of the formulation measured in centipoise (cPs) at the specified test temperature. Together with viscosity_min_cps, defines the viscosity tolerance band for quality control (QC) release and in-process testing.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viscosityMinCps rdf:type rdf:Property ;
    rdfs:label 'Viscosity Min Cps' ;
    rdfs:comment 'Minimum acceptable viscosity of the formulation measured in centipoise (cPs) at the specified test temperature. Critical quality attribute (CQA) governing product texture, pourability, and consumer experience. Used in QC release testing.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formulationIngredientId rdf:type rdf:Property ;
    rdfs:label 'Formulation Ingredient Id' ;
    rdfs:comment 'Unique surrogate identifier for each ingredient line within a formulation record. Primary key for the formulation_ingredient entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when this ingredient line was formally approved for use in the formulation. Provides GMP-compliant audit trail for regulatory inspections and quality management system records.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'Unique numerical identifier assigned by the Chemical Abstracts Service (CAS) to every chemical substance. Required for EU REACH registration, SDS documentation, and regulatory submissions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationMaxPct rdf:type rdf:Property ;
    rdfs:label 'Concentration Max Pct' ;
    rdfs:comment 'Maximum allowable concentration of the ingredient (% w/w) within the approved formulation range. Critical for safety compliance with regulatory concentration limits (e.g., EU Annex III restricted substances). Classified as confidential due to proprietary formulation IP.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationMinPct rdf:type rdf:Property ;
    rdfs:label 'Concentration Min Pct' ;
    rdfs:comment 'Minimum allowable concentration of the ingredient (% w/w) within the approved formulation range. Used for in-process quality control and batch release decisions. Classified as confidential due to proprietary formulation IP.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationNominalPct rdf:type rdf:Property ;
    rdfs:label 'Concentration Nominal Pct' ;
    rdfs:comment 'Target or nominal concentration of the ingredient expressed as a weight/weight percentage (% w/w) in the finished formulation. Represents the standard manufacturing target. Classified as confidential due to proprietary formulation IP.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationUom rdf:type rdf:Property ;
    rdfs:label 'Concentration Uom' ;
    rdfs:comment 'Unit of measure used to express ingredient concentration values (nominal, min, max). Standard is % w/w (weight by weight) for most cosmetic and personal care formulations; ppm or ppb may apply for trace ingredients or contaminants.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecNumber rdf:type rdf:Property ;
    rdfs:label 'Ec Number' ;
    rdfs:comment 'Seven-digit EC number (EINECS, ELINCS, or NLP list) assigned to chemical substances regulated under EU REACH. Mandatory for REACH registration dossiers and EU market compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaStatus rdf:type rdf:Property ;
    rdfs:label 'Fda Status' ;
    rdfs:comment 'Regulatory status of the ingredient under U.S. FDA regulations. Indicates whether the ingredient is approved, Generally Recognized as Safe (GRAS), permitted with restrictions, or prohibited for use in the applicable product category (cosmetics, OTC drug, food contact).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsHazardClassification rdf:type rdf:Property ;
    rdfs:label 'Ghs Hazard Classification' ;
    rdfs:comment 'GHS hazard classification codes for this ingredient (e.g., Flam. Liq. 3, Skin Irrit. 2, Aquatic Chronic 1). Drives SDS authoring, workplace safety controls, transport classification, and environmental risk assessment.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeSpecification rdf:type rdf:Property ;
    rdfs:label 'Grade Specification' ;
    rdfs:comment 'Quality grade or purity specification required for this ingredient (e.g., USP, NF, Ph.Eur., cosmetic grade, food grade, technical grade). Defines the minimum quality standard for procurement and incoming quality control.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:halalStatus rdf:type rdf:Property ;
    rdfs:label 'Halal Status' ;
    rdfs:comment 'Halal certification status of this ingredient, indicating compliance with Islamic dietary and product standards. Required for halal-certified product lines sold in Muslim-majority markets and for halal labeling claims.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Ifra Compliance Status' ;
    rdfs:comment 'Compliance status of this ingredient against the current IFRA Standards for fragrance materials. Applicable to fragrance ingredients and fragrance-containing raw materials. Non-compliant ingredients require reformulation or removal.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientFunction rdf:type rdf:Property ;
    rdfs:label 'Ingredient Function' ;
    rdfs:comment 'Functional role or purpose of the ingredient within the product formula (e.g., surfactant, preservative, fragrance, colorant, emollient, emulsifier, pH adjuster, solvent, active). Drives regulatory classification and labeling requirements. [ENUM-REF-CANDIDATE: surfactant|preservative|fragrance|colorant|emollient|emulsifier|pH adjuster|solvent|active|thickener|chelating agent|antioxidant — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientName rdf:type rdf:Property ;
    rdfs:label 'Ingredient Name' ;
    rdfs:comment 'Common or trade name of the ingredient as used internally within the organization, which may differ from the INCI name. Used for internal formulation documentation and procurement communication.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientStatus rdf:type rdf:Property ;
    rdfs:label 'Ingredient Status' ;
    rdfs:comment 'Current lifecycle status of this ingredient line within the formulation. Drives PLM workflow gates, regulatory review processes, and manufacturing authorization. Active ingredients are cleared for production use.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActiveIngredient rdf:type rdf:Property ;
    rdfs:label 'Is Active Ingredient' ;
    rdfs:comment 'Indicates whether this ingredient is classified as an active ingredient (e.g., OTC drug active, sunscreen active, anti-dandruff active) requiring specific regulatory declaration and concentration compliance under FDA OTC monograph or equivalent regulations.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFragranceAllergen rdf:type rdf:Property ;
    rdfs:label 'Is Fragrance Allergen' ;
    rdfs:comment 'Indicates whether this ingredient is a declared fragrance allergen requiring mandatory labeling disclosure under EU Cosmetics Regulation 1223/2009 (Annex III) when present above threshold concentrations (0.001% in rinse-off, 0.01% in leave-on products).' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNaturalOrigin rdf:type rdf:Property ;
    rdfs:label 'Is Natural Origin' ;
    rdfs:comment 'Indicates whether this ingredient is of natural origin as defined by ISO 16128 (Guidelines on definitions and criteria for natural and organic cosmetic ingredients). Supports natural/organic product claims and consumer transparency labeling.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPalmDerived rdf:type rdf:Property ;
    rdfs:label 'Is Palm Derived' ;
    rdfs:comment 'Indicates whether this ingredient is derived from palm oil or palm kernel oil. Triggers RSPO (Roundtable on Sustainable Palm Oil) sourcing compliance requirements and sustainability reporting obligations.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProhibitedSubstance rdf:type rdf:Property ;
    rdfs:label 'Is Prohibited Substance' ;
    rdfs:comment 'Indicates whether this ingredient is classified as a prohibited substance under applicable regulations (e.g., EU Cosmetics Regulation Annex II, FDA prohibited ingredients list). Prohibited substances must not appear in finished products.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRestrictedSubstance rdf:type rdf:Property ;
    rdfs:label 'Is Restricted Substance' ;
    rdfs:comment 'Indicates whether this ingredient is classified as a restricted substance under applicable regulations (e.g., EU Cosmetics Regulation Annex III, IFRA restricted list, EPA restricted chemicals). Restricted substances may be used within defined concentration limits.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:naturalOriginIndex rdf:type rdf:Property ;
    rdfs:label 'Natural Origin Index' ;
    rdfs:comment 'Quantitative natural origin index (0.0000 to 1.0000) calculated per ISO 16128-2 methodology, representing the proportion of the ingredient derived from natural sources. Used to compute product-level natural origin index for claims substantiation.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalForm rdf:type rdf:Property ;
    rdfs:label 'Physical Form' ;
    rdfs:comment 'Physical state or form of the ingredient as received from the supplier (e.g., liquid, solid, powder, paste, gel). Relevant for handling, storage, and manufacturing process design. [ENUM-REF-CANDIDATE: liquid|solid|powder|paste|gel|emulsion|suspension|gas — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Status' ;
    rdfs:comment 'Registration status of this ingredient under EU REACH Regulation (EC) No 1907/2006. Indicates whether the substance has been registered with ECHA, is pre-registered, exempt from registration, or registration is pending. Mandatory for EU market access.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLimitReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Limit Reference' ;
    rdfs:comment 'Citation of the specific regulatory provision or standard that establishes the maximum concentration limit for this ingredient (e.g., \'EU Cosmetics Reg. 1223/2009 Annex III Entry 98\', \'FDA 21 CFR 352.10\'). Provides audit traceability for compliance decisions.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMaxConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Regulatory Max Concentration Pct' ;
    rdfs:comment 'Maximum concentration limit (% w/w) for this ingredient as mandated by applicable regulations (e.g., EU Cosmetics Regulation Annex III, FDA OTC monograph limits, IFRA usage limits). Formulation concentration_max_pct must not exceed this value.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Reference Number' ;
    rdfs:comment 'Document reference number for the Safety Data Sheet (SDS) associated with this ingredient, as maintained in the document management system (Veeva Vault). Required under OSHA Hazard Communication Standard (HCS) 29 CFR 1910.1200 and EU REACH.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsVersion rdf:type rdf:Property ;
    rdfs:label 'Sds Version' ;
    rdfs:comment 'Version identifier of the Safety Data Sheet currently associated with this ingredient. Ensures traceability to the correct SDS revision used during formulation approval and manufacturing.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:svhcFlag rdf:type rdf:Property ;
    rdfs:label 'Svhc Flag' ;
    rdfs:comment 'Indicates whether this ingredient is listed as a Substance of Very High Concern (SVHC) on the ECHA Candidate List under EU REACH Article 59. SVHC presence above 0.1% w/w in articles triggers communication and notification obligations.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veganStatus rdf:type rdf:Property ;
    rdfs:label 'Vegan Status' ;
    rdfs:comment 'Vegan classification of this ingredient, indicating whether it is free from animal-derived components. Supports vegan product claims, certification (e.g., The Vegan Society), and consumer labeling requirements.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPlanId rdf:type rdf:Property ;
    rdfs:label 'Inspection Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_plan. Business justification: Packaging components require dedicated incoming inspection plans (AQL sampling for bottles, caps, tubes). QA teams maintain inspection plans specifically for each packaging component type, linked to t' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionPlan .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Quality and regulatory approval status of this packaging specification. Only approved specifications may be used in production orders. Supports GMP compliance and change control workflows.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artworkRef rdf:type rdf:Property ;
    rdfs:label 'Artwork Ref' ;
    rdfs:comment 'Reference code linking to the approved artwork file for this packaging specification in the digital asset management or PLM system. Ensures the correct print-ready artwork version is used in production.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finish rdf:type rdf:Property ;
    rdfs:label 'Finish' ;
    rdfs:comment 'Surface finish specification of the packaging component. Impacts print quality, consumer perception, and manufacturing process selection. [ENUM-REF-CANDIDATE: gloss|matte|satin|soft_touch|metallic|frosted|clear — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightG rdf:type rdf:Property ;
    rdfs:label 'Gross Weight G' ;
    rdfs:comment 'Total weight of the packaging component including product contents in grams. Used for freight cost calculations, transportation planning, and customs documentation.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heightMm rdf:type rdf:Property ;
    rdfs:label 'Height Mm' ;
    rdfs:comment 'External height dimension of the packaging component in millimeters. Used for planogram compliance, warehouse slotting, Ti-Hi pallet configuration, and transportation cube optimization.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hi rdf:type rdf:Property ;
    rdfs:label 'Hi' ;
    rdfs:comment 'Number of tiers (layers) stacked on a pallet — the \'Hi\' component of the Ti-Hi pallet configuration. Combined with Ti to determine total units per pallet for DRP/MRP and transportation planning.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFscCertified rdf:type rdf:Property ;
    rdfs:label 'Is Fsc Certified' ;
    rdfs:comment 'Indicates whether the packaging material is sourced from FSC-certified forests or recycled sources. Required for sustainability claims, retailer compliance programs, and ESG reporting.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRspoCertified rdf:type rdf:Property ;
    rdfs:label 'Is Rspo Certified' ;
    rdfs:comment 'Indicates whether palm oil-derived materials in the packaging component are RSPO-certified. Relevant for packaging components containing palm-based inks, coatings, or adhesives. Supports ESG and sustainability reporting.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Supplier lead time in calendar days from purchase order placement to delivery of this packaging component. Critical input for MRP/DRP scheduling and supply chain risk management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lengthMm rdf:type rdf:Property ;
    rdfs:label 'Length Mm' ;
    rdfs:comment 'External length dimension of the packaging component in millimeters. Used for planogram compliance, warehouse slotting, transportation cube optimization, and retailer shelf-space calculations.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialComposition rdf:type rdf:Property ;
    rdfs:label 'Material Composition' ;
    rdfs:comment 'Primary material(s) used in the packaging component (e.g., HDPE, PET, glass, paperboard, aluminum, polypropylene, PCR blend). Supports sustainability reporting, EPR compliance, and plastic tax calculations. [ENUM-REF-CANDIDATE: HDPE|PET|glass|paperboard|aluminum|polypropylene|PCR_blend|cardboard|bioplastic — promote to reference product]' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moq rdf:type rdf:Property ;
    rdfs:label 'Moq' ;
    rdfs:comment 'Minimum number of units the supplier requires per purchase order for this packaging component. Used in procurement planning, MRP calculations, and cost negotiations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcrContentPct rdf:type rdf:Property ;
    rdfs:label 'Pcr Content Pct' ;
    rdfs:comment 'Percentage of post-consumer recycled material in the packaging component by weight (0.00–100.00). Critical for sustainability reporting, EPR obligations, and plastic tax compliance across EU and US jurisdictions.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:printMethod rdf:type rdf:Property ;
    rdfs:label 'Print Method' ;
    rdfs:comment 'Printing technology used to apply graphics and text to the packaging component. Determines supplier capability requirements, cost structure, and minimum order quantities. [ENUM-REF-CANDIDATE: flexography|offset_lithography|digital|gravure|screen_printing|hot_stamping|label — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qtyPerParent rdf:type rdf:Property ;
    rdfs:label 'Qty Per Parent' ;
    rdfs:comment 'Number of units of this packaging level contained within the next higher packaging level (e.g., 12 eaches per case, 48 cases per pallet). Core input for DRP/MRP quantity calculations and order processing.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recyclabilityCode rdf:type rdf:Property ;
    rdfs:label 'Recyclability Code' ;
    rdfs:comment 'How2Recycle label code assigned to this packaging component indicating recyclability instructions for consumers (e.g., \'Widely Recycled\', \'Check Locally\', \'Not Yet Recycled\'). Required for EPR compliance and sustainability reporting.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this packaging specification has passed all applicable regulatory compliance checks (FDA, EU REACH, CPSC, etc.) for the target markets. False triggers a compliance review workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specCode rdf:type rdf:Property ;
    rdfs:label 'Spec Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this packaging specification within the PLM or ERP system. Used for cross-system reference and EDI communication.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specName rdf:type rdf:Property ;
    rdfs:label 'Spec Name' ;
    rdfs:comment 'Human-readable name describing this packaging specification (e.g., \'500ml HDPE Bottle Primary Pack — SKU XYZ\'). Used in PLM, procurement, and supplier communications.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierToolingRef rdf:type rdf:Property ;
    rdfs:label 'Supplier Tooling Ref' ;
    rdfs:comment 'Supplier-assigned tooling or mold reference number for this packaging component. Used to track proprietary tooling ownership, maintenance schedules, and supplier change management in procurement.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tareWeightG rdf:type rdf:Property ;
    rdfs:label 'Tare Weight G' ;
    rdfs:comment 'Weight of the empty packaging component without product contents in grams. Used for net weight labeling compliance, material cost calculations, and sustainability reporting on packaging material mass.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ti rdf:type rdf:Property ;
    rdfs:label 'Ti' ;
    rdfs:comment 'Number of cases or units per tier (layer) on a pallet — the \'Ti\' component of the Ti-Hi pallet configuration. Used for warehouse slotting, transportation cube optimization, and retailer receiving compliance.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:widthMm rdf:type rdf:Property ;
    rdfs:label 'Width Mm' ;
    rdfs:comment 'External width dimension of the packaging component in millimeters. Used for planogram compliance, warehouse slotting, and transportation cube optimization.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labelSpecId rdf:type rdf:Property ;
    rdfs:label 'Label Spec Id' ;
    rdfs:comment 'Unique surrogate identifier for each label specification record. Primary key for the label_spec data product in the product domain.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:artworkFileReference rdf:type rdf:Property ;
    rdfs:label 'Artwork File Reference' ;
    rdfs:comment 'Document management system reference or file path to the approved artwork file for this label specification (e.g., Veeva Vault document ID or DAM asset reference). Links label spec to the physical artwork asset.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodePlacement rdf:type rdf:Property ;
    rdfs:label 'Barcode Placement' ;
    rdfs:comment 'Specification of the physical placement zone for the barcode on the label or packaging (e.g., \'bottom-right back panel\', \'base of container\'). Ensures retail scanner readability and planogram compliance.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeType rdf:type rdf:Property ;
    rdfs:label 'Barcode Type' ;
    rdfs:comment 'Type of barcode symbology specified for placement on the label (e.g., UPC-A, EAN-13, ITF-14, GS1-128, QR Code, DataMatrix). Governs scanner compatibility at retail POS and logistics. [ENUM-REF-CANDIDATE: UPC-A|EAN-13|EAN-8|ITF-14|GS1-128|QR_Code|DataMatrix — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationMarks rdf:type rdf:Property ;
    rdfs:label 'Certification Marks' ;
    rdfs:comment 'Third-party certification marks and logos authorized for display on this label (e.g., \'USDA Organic\', \'NSF Certified\', \'Leaping Bunny\', \'RSPO\', \'FSC\', \'CE Mark\'). Subject to certification body licensing requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimText rdf:type rdf:Property ;
    rdfs:label 'Claim Text' ;
    rdfs:comment 'Marketing and regulatory claims printed on the label (e.g., \'Dermatologist Tested\', \'Cruelty-Free\', \'Hypoallergenic\', \'Organic\', \'Clinically Proven\'). Subject to FTC advertising substantiation requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorProfile rdf:type rdf:Property ;
    rdfs:label 'Color Profile' ;
    rdfs:comment 'Color management profile and ink specification for the label (e.g., \'CMYK + 2 Pantone\', \'Pantone 485C + Black\'). Ensures brand color consistency across print runs and suppliers.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalWatermarkEnabled rdf:type rdf:Property ;
    rdfs:label 'Digital Watermark Enabled' ;
    rdfs:comment 'Indicates whether a digital watermark (e.g., GS1 Digital Link, Digimarc) is embedded in the label artwork to support connected packaging, consumer engagement, and supply chain traceability.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributorName rdf:type rdf:Property ;
    rdfs:label 'Distributor Name' ;
    rdfs:comment 'Legal name of the distributor or importer as printed on the label, where different from the manufacturer. Required in markets where the responsible party is the local distributor.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientDeclarationText rdf:type rdf:Property ;
    rdfs:label 'Ingredient Declaration Text' ;
    rdfs:comment 'Full ingredient declaration text as it appears on the label, including INCI (International Nomenclature of Cosmetic Ingredients) names for cosmetics or common/scientific names for food and household products. Mandatory for regulatory compliance.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryLabel rdf:type rdf:Property ;
    rdfs:label 'Is Primary Label' ;
    rdfs:comment 'Indicates whether this label specification is the primary (master) label for the SKU-market-language combination, as opposed to a supplementary or promotional label variant.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Label Approval Date' ;
    rdfs:comment 'Date on which the label specification received final regulatory and quality approval, authorizing use in production. Key milestone in the PLM artwork approval workflow.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labelDimensions rdf:type rdf:Property ;
    rdfs:label 'Label Dimensions' ;
    rdfs:comment 'Physical dimensions of the label (width x height in mm, e.g., \'120x80mm\'). Required for print production specifications and packaging line setup.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelType rdf:type rdf:Property ;
    rdfs:label 'Label Type' ;
    rdfs:comment 'Categorizes the physical placement and function of the label on the product packaging (e.g., front_of_pack, back_of_pack, inner_label, neck_label, hang_tag, insert). Drives artwork management and regulatory review workflows.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelVersion rdf:type rdf:Property ;
    rdfs:label 'Label Version' ;
    rdfs:comment 'Version number of the label specification (e.g., 1.0, 2.1, 3.0). Used to track label revisions and manage artwork lifecycle in PLM and Veeva Vault.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotCodeFormat rdf:type rdf:Property ;
    rdfs:label 'Lot Code Format' ;
    rdfs:comment 'Format specification for the lot/batch code printed on the label (e.g., \'YYYYMMDD-XXXX\', \'Julian date + shift code\'). Enables product traceability and recall management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryRegulatoryStatements rdf:type rdf:Property ;
    rdfs:label 'Mandatory Regulatory Statements' ;
    rdfs:comment 'Concatenated text of all mandatory regulatory statements required by the applicable regulatory framework (e.g., FDA required statements, EU mandatory disclosures, CPSC safety notices). Stored as structured text for label artwork population.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerAddress rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Address' ;
    rdfs:comment 'Full address of the manufacturer or responsible party as printed on the label. Mandatory for consumer contact and regulatory traceability in most jurisdictions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Legal name of the manufacturer or responsible party as printed on the label. Required by FDA, EU, and most national regulatory frameworks for product traceability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketCountryCode rdf:type rdf:Property ;
    rdfs:label 'Market Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code identifying the market or country for which this label specification is valid (e.g., USA, GBR, DEU, FRA). Supports multi-market regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netContentDeclaration rdf:type rdf:Property ;
    rdfs:label 'Net Content Declaration' ;
    rdfs:comment 'Net content statement as printed on the label, including quantity and unit of measure (e.g., \'500 mL\', \'16 fl oz (473 mL)\', \'250 g\'). Mandatory per weights and measures regulations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nutritionFactsRequired rdf:type rdf:Property ;
    rdfs:label 'Nutrition Facts Required' ;
    rdfs:comment 'Indicates whether a Nutrition Facts panel or equivalent nutritional information table is required on this label per applicable regulatory framework. Applies to food, beverage, and dietary supplement categories.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plmChangeOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Plm Change Order Number' ;
    rdfs:comment 'Change order or engineering change notice (ECN) number from the PLM system that authorized this label specification version. Provides traceability to the formal change management process.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printProcess rdf:type rdf:Property ;
    rdfs:label 'Print Process' ;
    rdfs:comment 'Printing technology specified for producing this label (e.g., flexographic, digital, offset, gravure, screen). Determines supplier qualification and color reproduction requirements.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclingSymbolCode rdf:type rdf:Property ;
    rdfs:label 'Recycling Symbol Code' ;
    rdfs:comment 'Recycling and environmental symbol codes required on the label (e.g., Mobius loop resin identification code, Green Dot, Tidyman, FSC logo). Supports sustainability compliance and consumer communication.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeStatement rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Statement' ;
    rdfs:comment 'Shelf life or best-before/expiry date format statement as printed on the label (e.g., \'Best Before: see base\', \'Use By: MM/YYYY\', \'PAO 12M\'). Supports FEFO inventory management and consumer safety.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substrateMaterial rdf:type rdf:Property ;
    rdfs:label 'Substrate Material' ;
    rdfs:comment 'Material specification for the label substrate (e.g., \'White BOPP\', \'Kraft Paper\', \'Clear PET\', \'Foil\'). Drives procurement of label stock and sustainability reporting.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageInstructions rdf:type rdf:Property ;
    rdfs:label 'Usage Instructions' ;
    rdfs:comment 'Directions for use as printed on the label (e.g., application method, dosage, frequency, preparation instructions). Required for regulated product categories and consumer safety.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Document Reference' ;
    rdfs:comment 'Document identifier in Veeva Vault for the controlled label specification document. Provides direct traceability to the system of record for regulatory submissions and quality documents.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningStatements rdf:type rdf:Property ;
    rdfs:label 'Warning Statements' ;
    rdfs:comment 'All warning and precautionary statements required on the label (e.g., \'Keep out of reach of children\', \'Flammable\', allergen warnings, GHS hazard statements). Mandatory for consumer safety compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productClaimId rdf:type rdf:Property ;
    rdfs:label 'Product Claim Id' ;
    rdfs:comment 'Unique surrogate identifier for each product claim record in the master claim registry. Primary key for the product_claim data product.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Foreign key linking to product.certification. Business justification: product_claim has certification_number, certification_body, and certification_expiry_date — these are denormalized attributes from the certification master. When a claim is certification-backed (e.g.,' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certification .

ind:applicableMarkets rdf:type rdf:Property ;
    rdfs:label 'Applicable Markets' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes identifying the markets where this claim is authorized for use. Claim validity is jurisdiction-specific due to varying regulatory requirements (e.g., FDA in USA, EU REACH in Europe). Example: \'USA,GBR,DEU,FRA\'.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimCode rdf:type rdf:Property ;
    rdfs:label 'Claim Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the claim, used in regulatory submissions, PLM systems, and cross-functional references. Sourced from Veeva Vault claim registration.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimScope rdf:type rdf:Property ;
    rdfs:label 'Claim Scope' ;
    rdfs:comment 'Defines the level at which the claim applies: Product (specific SKU), Brand (entire brand portfolio), Range (product line/sub-brand), or Ingredient (specific INCI ingredient within the formulation).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle status of the claim within the approval and compliance workflow. Approved: substantiated and cleared for use; Pending: awaiting substantiation review; Withdrawn: voluntarily removed; Expired: past validity date; Under Review: triggered by regulatory inquiry or market change.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Categorical classification of the claim by its business and regulatory nature. Efficacy: performance-based claims; Environmental: green/sustainability claims; Certification: third-party certified claims; Nutritional: nutrient content or health claims; Safety: dermatological or toxicological safety claims.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimValue rdf:type rdf:Property ;
    rdfs:label 'Claim Value' ;
    rdfs:comment 'The specific numeric value or percentage cited in a quantitative claim (e.g., \'99.9\', \'30\', \'100\'). Stored as STRING to accommodate ranges and non-numeric qualifiers. Null for qualitative claims.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalClaimStandard rdf:type rdf:Property ;
    rdfs:label 'Environmental Claim Standard' ;
    rdfs:comment 'The specific environmental standard or framework under which an environmental claim is made (e.g., ISO 14021 for self-declared environmental claims, ISO 14024 for Type I eco-labels, EPA Safer Choice). Applicable only for environmental claim types.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaReviewed rdf:type rdf:Property ;
    rdfs:label 'Fda Reviewed' ;
    rdfs:comment 'Indicates whether the claim has been reviewed for compliance with FDA labeling regulations (21 CFR Part 101 for food/nutrition claims or 21 CFR Part 701 for cosmetics). Applicable for health, nutritional, and drug-related claims.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftcCompliant rdf:type rdf:Property ;
    rdfs:label 'Ftc Compliant' ;
    rdfs:comment 'Indicates whether the claim has been reviewed and confirmed compliant with FTC advertising guidelines, including the requirement for competent and reliable scientific evidence. True = FTC compliant; False = non-compliant or not yet reviewed.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inciIngredientRef rdf:type rdf:Property ;
    rdfs:label 'Inci Ingredient Ref' ;
    rdfs:comment 'The INCI (International Nomenclature of Cosmetic Ingredients) name of the specific ingredient referenced in an ingredient-scoped claim. Applicable when claim_scope is \'ingredient\'. Ensures regulatory alignment with EU Cosmetics Regulation and FDA cosmetic labeling.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewed rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewed' ;
    rdfs:comment 'Indicates whether the claim has been reviewed and cleared by the internal legal counsel for advertising law compliance, IP considerations, and litigation risk. True = legal sign-off obtained.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewer rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer' ;
    rdfs:comment 'Name or employee identifier of the legal counsel who reviewed and approved the claim. Provides audit trail for legal sign-off accountability.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingApproved rdf:type rdf:Property ;
    rdfs:label 'Marketing Approved' ;
    rdfs:comment 'Indicates whether the marketing team has approved the claim copy for consumer-facing deployment. Part of the multi-functional claim approval workflow (R&D, Legal, Regulatory, Marketing).' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'The scheduled date for the next periodic review of the claim\'s substantiation and compliance status. Calculated from approval_date plus review_frequency_days. Triggers compliance workflow in Veeva Vault.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plmStage rdf:type rdf:Property ;
    rdfs:label 'Plm Stage' ;
    rdfs:comment 'The PLM lifecycle stage of the associated SKU at the time this claim is active. Ensures claims are only deployed during appropriate product lifecycle phases and supports NPD (New Product Development) claim planning.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantitativeClaim rdf:type rdf:Property ;
    rdfs:label 'Quantitative Claim' ;
    rdfs:comment 'Indicates whether the claim contains a specific quantitative assertion (e.g., \'99.9% effective\', \'reduces wrinkles by 30%\'). Quantitative claims require a higher standard of substantiation evidence under FTC guidelines.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'The primary regulatory authority governing this claim in its applicable market(s) (e.g., FDA, EPA, CPSC, EU REACH, IFRA). Drives the compliance review process and substantiation requirements. [ENUM-REF-CANDIDATE: FDA|EPA|CPSC|EU_REACH|IFRA|FTC|OSHA|ISO|RSPO|FSC — promote to reference product]' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Days' ;
    rdfs:comment 'The mandated periodic review interval in days for re-substantiating or reconfirming the claim\'s validity. Drives automated compliance alerts and claim lifecycle management workflows.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scientificReviewer rdf:type rdf:Property ;
    rdfs:label 'Scientific Reviewer' ;
    rdfs:comment 'Name or employee identifier of the R&D scientist or regulatory affairs specialist who validated the substantiation evidence for the claim.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemClaimCode rdf:type rdf:Property ;
    rdfs:label 'Source System Claim Code' ;
    rdfs:comment 'The native identifier of this claim record in the originating operational system (e.g., Veeva Vault document ID, SAP object ID). Enables traceability and reconciliation between the lakehouse silver layer and the system of record.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantiationMethod rdf:type rdf:Property ;
    rdfs:label 'Substantiation Method' ;
    rdfs:comment 'The scientific or evidentiary method used to substantiate the claim per FTC competent and reliable scientific evidence standard. Determines the rigor and defensibility of the claim in regulatory or legal proceedings.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Secondary classification providing finer granularity within the claim type (e.g., \'anti-bacterial\', \'biodegradable\', \'cruelty-free\', \'hypoallergenic\', \'organic\', \'fair-trade\'). [ENUM-REF-CANDIDATE: anti-bacterial|biodegradable|cruelty-free|hypoallergenic|organic|fair-trade|recyclable|vegan|gluten-free|non-gmo — promote to reference product]' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueUnit rdf:type rdf:Property ;
    rdfs:label 'Value Unit' ;
    rdfs:comment 'Unit of measure for the quantitative claim value (e.g., \'%\', \'mg\', \'CFU\', \'hours\'). Required when claim_value is populated to provide full context for the quantitative assertion.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'The date on which the claim was formally withdrawn from consumer-facing use. Populated only when claim_status is \'withdrawn\'. Critical for regulatory audit trail and litigation defense.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Free-text explanation for why a claim was withdrawn or rejected. Populated when claim_status is \'withdrawn\' or \'under_review\'. Captures regulatory challenge, substantiation failure, reformulation, or voluntary removal rationale.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCategoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Category Id' ;
    rdfs:comment 'Foreign key linking to product.category. Business justification: product_brand has a primary_category (STRING) field that is a string reference to the product category. The category table is the authoritative master for product categories. Adding primary_category_i' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:architectureType rdf:type rdf:Property ;
    rdfs:label 'Architecture Type' ;
    rdfs:comment 'Classification of the brand\'s role within the overall brand architecture strategy. Master brands are umbrella identities; sub-brands extend a master brand; endorsed brands carry a parent endorsement; standalone brands operate independently; house_of_brands indicates a portfolio brand with no visible corporate parent.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Status' ;
    rdfs:comment 'Current lifecycle status of the brand within the Consumer Goods portfolio. Active brands are fully marketed and distributed; dormant brands are temporarily inactive; divested brands have been sold or licensed out; discontinued brands are permanently retired; pipeline brands are in NPD/R&D pre-launch phase.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandTier rdf:type rdf:Property ;
    rdfs:label 'Brand Tier' ;
    rdfs:comment 'Market positioning tier of the brand within the CPG/FMCG portfolio, indicating price-value positioning relative to competition. Drives RSP/MSRP strategy, trade promotion investment levels, and retail channel prioritization. [ENUM-REF-CANDIDATE: premium|mass|value|super_premium|private_label — promote to reference product if tiers expand]' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Primary channel through which the brand\'s products are distributed to consumers. Retail covers brick-and-mortar stores; DTC (Direct to Consumer) covers brand-owned channels; DSD (Direct Store Delivery) covers direct distribution; omnichannel covers integrated multi-channel distribution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divestitureDate rdf:type rdf:Property ;
    rdfs:label 'Divestiture Date' ;
    rdfs:comment 'Date on which the brand was officially divested, sold, or licensed to a third party. Populated only when brand_status is \'divested\'. Required for SOX financial reporting and portfolio restructuring audit trails.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eanPrefix rdf:type rdf:Property ;
    rdfs:label 'Ean Prefix' ;
    rdfs:comment 'GS1 company prefix assigned to the brand owner, forming the first digits of all EAN/GTIN barcodes for products under this brand. Enables GS1-compliant product identification and EDI transactions across the global supply chain.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityMethodology rdf:type rdf:Property ;
    rdfs:label 'Equity Methodology' ;
    rdfs:comment 'Methodology or framework used to measure and track brand equity over time. Determines which external measurement partner (Nielsen IQ, Kantar BrandZ, Ipsos) or internal scorecard approach is applied for brand health KPI reporting. [ENUM-REF-CANDIDATE: nielsen_brand_health|kantar_brandz|ipsos_brand_value|internal_scorecard|bav|none — promote to reference product if methodologies expand]' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificationRef rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Ref' ;
    rdfs:comment 'Reference number or identifier for the GMP certification applicable to the brand\'s manufacturing operations. Required for FDA-regulated brands (21 CFR Parts 110/111/210/211) and cosmetics brands under ISO 22716. Stored in Veeva Vault Quality Documents.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLicensedBrand rdf:type rdf:Property ;
    rdfs:label 'Is Licensed Brand' ;
    rdfs:comment 'Indicates whether the brand is operated under a licensing agreement from a third-party brand owner rather than being wholly owned by the Consumer Goods entity. Licensed brands have different royalty accounting treatment in Oracle Cloud ERP Financials and different regulatory responsibility structures.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchYear rdf:type rdf:Property ;
    rdfs:label 'Launch Year' ;
    rdfs:comment 'Calendar year in which the brand was first commercially launched in any market. Used for brand age analytics, heritage positioning, and portfolio vintage analysis in brand equity tracking.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Date on which the brand licensing agreement expires, applicable only when is_licensed_brand is True. Critical for contract renewal planning, financial risk management, and SOX disclosure requirements. Null for wholly-owned brands.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:msrpCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Msrp Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the MSRP/RSP defined at the brand level. Provides the currency context for brand-level pricing strategy and trade promotion ROI calculations.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Nps Tracking Enabled' ;
    rdfs:comment 'Indicates whether active NPS (Net Promoter Score) consumer sentiment tracking is configured for this brand. When True, the brand is enrolled in periodic consumer surveys and NPS measurement programs linked to the consumer domain\'s nps_response product.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerDivision rdf:type rdf:Property ;
    rdfs:label 'Owner Division' ;
    rdfs:comment 'Internal business division or strategic business unit (SBU) within the Consumer Goods organization that owns and manages the brand. Used for financial reporting, EBITDA attribution, and S&OP planning alignment in SAP S/4HANA CO module.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEntity rdf:type rdf:Property ;
    rdfs:label 'Owner Entity' ;
    rdfs:comment 'Legal entity name of the company or subsidiary that owns the brand trademark and bears regulatory responsibility for the brand. Critical for SOX financial reporting, regulatory submissions to FDA/EPA/CPSC, and inter-company transfer pricing.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBrandCode rdf:type rdf:Property ;
    rdfs:label 'Parent Brand Code' ;
    rdfs:comment 'Brand code of the parent or umbrella brand for sub-brands and brand extensions. Enables hierarchical brand architecture modeling (e.g., a skincare sub-brand under a master personal care brand). Null for top-level master brands with no parent.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positioningStatement rdf:type rdf:Property ;
    rdfs:label 'Positioning Statement' ;
    rdfs:comment 'Internal strategic statement articulating the brand\'s unique value proposition, target audience, competitive frame of reference, and key differentiators. Confidential business strategy document used by marketing and trade promotion teams for campaign alignment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Primary Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary market or country of origin for the brand. Used for regulatory compliance (FDA, EU REACH), customs documentation, and market-level financial reporting.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or shortened version of the brand name used in space-constrained contexts such as POS displays, planograms (POG), shelf labels, and reporting dashboards where the full brand name may not fit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHandle rdf:type rdf:Property ;
    rdfs:label 'Social Media Handle' ;
    rdfs:comment 'Primary social media handle or username for the brand (e.g., @BrandName on Instagram/Twitter/TikTok). Used for SOV (Share of Voice) measurement, digital marketing analytics, and consumer engagement tracking in Nielsen IQ and Salesforce.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemBrandCode rdf:type rdf:Property ;
    rdfs:label 'Source System Brand Code' ;
    rdfs:comment 'Native brand identifier as stored in the originating operational system (e.g., SAP S/4HANA brand master ID, Salesforce Consumer Goods Cloud brand record ID). Enables reverse lookup and reconciliation between the lakehouse Silver Layer and source systems.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertification rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification' ;
    rdfs:comment 'Primary sustainability or environmental certification held by the brand, indicating compliance with responsible sourcing and environmental management standards. FSC covers sustainable forestry; RSPO covers sustainable palm oil; ISO 14001 covers environmental management systems.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetConsumerSegment rdf:type rdf:Property ;
    rdfs:label 'Target Consumer Segment' ;
    rdfs:comment 'Primary consumer demographic or psychographic segment the brand is designed to serve (e.g., Millennial Families, Gen Z Beauty Enthusiasts, Health-Conscious Adults 35-55). Drives brand positioning, media SOV allocation, and NPS/CLTV measurement segmentation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkRegistrationRef rdf:type rdf:Property ;
    rdfs:label 'Trademark Registration Ref' ;
    rdfs:comment 'Official trademark registration number or reference identifier issued by the relevant intellectual property authority (e.g., USPTO, EUIPO, WIPO). Used for legal protection verification, brand licensing agreements, and regulatory labeling compliance.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official consumer-facing website URL for the brand. Used for DTC channel management, digital marketing attribution, and e-commerce integration. Referenced in Salesforce Consumer Goods Cloud for omnichannel campaign tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Quantity' ;
    rdfs:comment 'The total number of consumer units (eaches) contained in this packaging level. For a case containing 6 inner packs of 12 eaches, this would be 72.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayReadyFlag rdf:type rdf:Property ;
    rdfs:label 'Display Ready Flag' ;
    rdfs:comment 'Indicates whether this packaging level is designed as a retail-ready display unit that can be placed directly on the sales floor without unpacking.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'The height dimension of the packaging at this level, measured in centimeters.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hiCount rdf:type rdf:Property ;
    rdfs:label 'Hi Count' ;
    rdfs:comment 'The number of layers stacked on a pallet (Hi in Ti-Hi configuration). Used for pallet configuration and warehouse planning.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'The length dimension of the packaging at this level, measured in centimeters.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStackHeight rdf:type rdf:Property ;
    rdfs:label 'Max Stack Height' ;
    rdfs:comment 'The maximum number of units of this packaging level that can be safely stacked vertically.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderableFlag rdf:type rdf:Property ;
    rdfs:label 'Orderable Flag' ;
    rdfs:comment 'Indicates whether this packaging level can be ordered by customers or retailers through EDI or other ordering systems.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packHierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Pack Hierarchy Status' ;
    rdfs:comment 'The current lifecycle status of this pack hierarchy configuration: active (in use), inactive (temporarily suspended), pending (awaiting approval), or discontinued (permanently retired).' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingMaterial rdf:type rdf:Property ;
    rdfs:label 'Packaging Material' ;
    rdfs:comment 'The primary material used for packaging at this level: corrugated cardboard, plastic, wood, metal, composite, or shrink wrap.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletType rdf:type rdf:Property ;
    rdfs:label 'Pallet Type' ;
    rdfs:comment 'The type of pallet used for this packaging level: standard (48x40 inches), euro (1200x800 mm), block, custom, half, or quarter pallet.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityPerLevel rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Level' ;
    rdfs:comment 'The number of units from the next lower hierarchy level contained in this level (e.g., 12 eaches per inner pack, 6 inner packs per case).' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recyclableFlag rdf:type rdf:Property ;
    rdfs:label 'Recyclable Flag' ;
    rdfs:comment 'Indicates whether the packaging material at this level is recyclable according to local recycling standards.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recycledContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Recycled Content Percentage' ;
    rdfs:comment 'The percentage of recycled material content in the packaging at this level, supporting sustainability reporting.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippableFlag rdf:type rdf:Property ;
    rdfs:label 'Shippable Flag' ;
    rdfs:comment 'Indicates whether this packaging level is suitable for direct shipment to customers or distribution centers.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stackableFlag rdf:type rdf:Property ;
    rdfs:label 'Stackable Flag' ;
    rdfs:comment 'Indicates whether this packaging level can be safely stacked on top of similar units during storage and transportation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tareWeightKg rdf:type rdf:Property ;
    rdfs:label 'Tare Weight Kg' ;
    rdfs:comment 'The weight of the packaging materials only at this level, excluding product content, measured in kilograms.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tiCount rdf:type rdf:Property ;
    rdfs:label 'Ti Count' ;
    rdfs:comment 'The number of cases or units per layer on a pallet (Ti in Ti-Hi configuration). Used for pallet configuration and warehouse planning.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeCubicCm rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Cm' ;
    rdfs:comment 'The cubic volume of the packaging at this level, measured in cubic centimeters. Used for warehouse slotting and transportation cube optimization.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'The width dimension of the packaging at this level, measured in centimeters.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableChannels rdf:type rdf:Property ;
    rdfs:label 'Applicable Channels' ;
    rdfs:comment 'Comma-separated list of sales channels where this certification applies and can be claimed. Examples: retail, e-commerce, DTC (Direct to Consumer), food service, professional, wholesale.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'The date of the most recent audit or inspection conducted by the certification body to verify ongoing compliance.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditResult rdf:type rdf:Property ;
    rdfs:label 'Audit Result' ;
    rdfs:comment 'The outcome of the most recent audit. Passed indicates full compliance. Passed with conditions indicates minor non-conformances that must be addressed. Failed indicates major non-conformances.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:body rdf:type rdf:Property ;
    rdfs:label 'Body' ;
    rdfs:comment 'The name of the third-party organization or authority that issued the certification. Examples: RSPO Secretariat, Forest Stewardship Council, Cruelty Free International, Ecocert, NSF International, Islamic Food and Nutrition Council of America, Orthodox Union.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Reference' ;
    rdfs:comment 'Reference path or identifier to the official certificate document in the document management system (e.g., Veeva Vault). Used for regulatory submissions and retailer compliance requests.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'The unique certificate or license number assigned by the certification body. Used for verification and audit trail purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'Detailed description of what the certification covers. May specify ingredients, packaging materials, manufacturing processes, supply chain stages, or product categories included in the certification scope.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the certification. Active indicates the certification is valid and in force. Expired means the certification has passed its expiry date. Suspended indicates temporary hold. Revoked means the certification has been withdrawn. Pending and under_review indicate application or renewal in progress.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'The type or name of the third-party certification or compliance attestation. Examples include RSPO (Roundtable on Sustainable Palm Oil), FSC (Forest Stewardship Council), Leaping Bunny (cruelty-free), COSMOS Organic, NSF, Halal, Kosher, EPA Safer Choice, ISO 22716 GMP (Good Manufacturing Practice). [ENUM-REF-CANDIDATE: RSPO|FSC|Leaping Bunny|COSMOS Organic|NSF|Halal|Kosher|EPA Safer Choice|ISO 22716|Fair Trade|Rainforest Alliance|USDA Organic|Ecocert|Vegan Society|B Corp|Carbon Neutral|Cradle to Cradle|EWG Verified|Non-GMO Project|PETA Cruelty-Free|Other — promote to reference product]' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Consumer Facing Flag' ;
    rdfs:comment 'Indicates whether this certification is actively promoted to consumers on packaging, advertising, and digital channels. True means the certification is part of the brand\'s consumer value proposition.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'The total cost paid to obtain and maintain this certification, including application fees, audit fees, and annual licensing fees. Used for sustainability ROI analysis.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the certification cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which the certification was originally issued by the certification body.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:logoFileReference rdf:type rdf:Property ;
    rdfs:label 'Logo File Reference' ;
    rdfs:comment 'Reference path or identifier to the approved certification logo file in the digital asset management system. Used by packaging and marketing teams.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoUsageApproved rdf:type rdf:Property ;
    rdfs:label 'Logo Usage Approved' ;
    rdfs:comment 'Indicates whether the company is authorized to display the certification body\'s logo or seal on product packaging and marketing materials.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'The scheduled date for the next audit or surveillance visit by the certification body.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date by which the certification must be renewed to maintain continuous compliance. May differ from expiry date to allow for renewal processing time.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retailerRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Retailer Requirement Flag' ;
    rdfs:comment 'Indicates whether this certification is required by one or more key retail customers as a condition of distribution. True means at least one retailer mandates this certification.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardVersion rdf:type rdf:Property ;
    rdfs:label 'Standard Version' ;
    rdfs:comment 'The version or edition of the certification standard under which the product was certified. Important for tracking compliance with evolving standards.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityPillar rdf:type rdf:Property ;
    rdfs:label 'Sustainability Pillar' ;
    rdfs:comment 'The primary sustainability or ESG (Environmental Social Governance) pillar that this certification supports. Used for sustainability reporting and ESG disclosure alignment.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationUrl rdf:type rdf:Property ;
    rdfs:label 'Verification Url' ;
    rdfs:comment 'Public URL where consumers, retailers, or auditors can verify the authenticity of this certification using the certificate number. Supports transparency and claim substantiation.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Supply Network Node Id' ;
    rdfs:comment 'Foreign key linking to supply.network_node. Business justification: Required for Supply Network Planning report to map each plant to its network node, enabling ATP, capacity, and logistics calculations; domain experts expect this mapping.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line for the manufacturing facility location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for suite, building, or additional location details. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date when the facility was officially commissioned and began production operations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email contact for the manufacturing facility operations team. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyConsumptionKwhPerYear rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Year' ;
    rdfs:comment 'Annual energy consumption of the facility measured in kilowatt-hours, used for sustainability reporting and cost management.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaSiteNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Site Number' ;
    rdfs:comment 'EPA facility identifier for environmental compliance tracking and reporting under EPA regulations.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpPlantCode rdf:type rdf:Property ;
    rdfs:label 'Erp Plant Code' ;
    rdfs:comment 'Plant identifier in the SAP S/4HANA ERP system used for integration with MM, PP, SD, and WM modules.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Official business name of the manufacturing facility or plant site.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the manufacturing facility based on primary production function: mixing (formulation), filling (liquid/semi-solid), packaging (secondary), co-manufacturing (third-party), integrated (end-to-end), or contract (toll manufacturing).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaEstablishmentNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Establishment Number' ;
    rdfs:comment 'FDA-issued establishment identifier for facilities manufacturing FDA-regulated products (cosmetics, OTC drugs, food). Required for US market distribution.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Date' ;
    rdfs:comment 'Date when the facility received its current GMP certification.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpCertified rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified' ;
    rdfs:comment 'Indicates whether the facility holds current Good Manufacturing Practice certification required for consumer goods production.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Gmp Expiration Date' ;
    rdfs:comment 'Date when the current GMP certification expires and requires renewal.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the facility holds ISO 14001 Environmental Management System certification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso22716ComplianceTier rdf:type rdf:Property ;
    rdfs:label 'Iso 22716 Compliance Tier' ;
    rdfs:comment 'Internal classification of the facility\'s compliance level with ISO 22716 cosmetics GMP standards: tier_1 (full compliance), tier_2 (partial compliance), tier_3 (basic compliance), non_compliant.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the facility holds ISO 9001 Quality Management System certification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent quality or compliance audit conducted at the facility.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mesSystemIntegrated rdf:type rdf:Property ;
    rdfs:label 'Mes System Integrated' ;
    rdfs:comment 'Indicates whether the facility is integrated with Siemens Opcenter MES for real-time production tracking and shop floor data collection.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfProductionLines rdf:type rdf:Property ;
    rdfs:label 'Number Of Production Lines' ;
    rdfs:comment 'Total count of active production lines within the facility available for manufacturing operations.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the manufacturing facility in its lifecycle.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaEstablishmentNumber rdf:type rdf:Property ;
    rdfs:label 'Osha Establishment Number' ;
    rdfs:comment 'OSHA establishment identifier for workplace safety reporting and compliance tracking.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership structure of the facility: owned (company-owned), leased (long-term lease), contract (third-party operated), joint_venture (shared ownership).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the manufacturing facility. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProductCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Product Category' ;
    rdfs:comment 'Main product category or line manufactured at this facility (e.g., skincare, haircare, household cleaning, personal care).' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCapacityUnitsPerDay rdf:type rdf:Property ;
    rdfs:label 'Production Capacity Units Per Day' ;
    rdfs:comment 'Maximum daily production capacity of the facility measured in finished goods units per day under normal operating conditions.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Standard operating shift pattern for the facility: single (8 hours), two_shift (16 hours), three_shift (24 hours), continuous (24/7), flexible (variable).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:squareFootage rdf:type rdf:Property ;
    rdfs:label 'Square Footage' ;
    rdfs:comment 'Total floor area of the manufacturing facility in square feet, including production, warehouse, and administrative spaces.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityRating rdf:type rdf:Property ;
    rdfs:label 'Sustainability Rating' ;
    rdfs:comment 'Internal sustainability performance rating for the facility based on environmental impact, energy efficiency, waste reduction, and sustainable sourcing practices.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the facility location (e.g., America/New_York, Europe/Berlin) used for production scheduling and shift planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterConsumptionCubicMetersPerYear rdf:type rdf:Property ;
    rdfs:label 'Water Consumption Cubic Meters Per Year' ;
    rdfs:comment 'Annual water consumption of the facility measured in cubic meters, tracked for environmental compliance and sustainability reporting.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workforceHeadcount rdf:type rdf:Property ;
    rdfs:label 'Workforce Headcount' ;
    rdfs:comment 'Total number of employees (full-time equivalent) assigned to the manufacturing facility.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionLineId rdf:type rdf:Property ;
    rdfs:label 'Production Line Id' ;
    rdfs:comment 'Unique identifier for the production line. Primary key for the production line master record.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionLine .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: Production lines are capitalized fixed assets. Linking to fixed_asset enables depreciation scheduling, net book value reporting, and capex project tracking for line investments — standard asset manage' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:allergenHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Handling Flag' ;
    rdfs:comment 'Indicates whether this production line handles products containing allergens. Critical for cross-contamination prevention and regulatory compliance.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenTypes rdf:type rdf:Property ;
    rdfs:label 'Allergen Types' ;
    rdfs:comment 'Comma-separated list of allergen types handled on this line (e.g., nuts, dairy, gluten). Used for allergen management and cleaning validation protocols.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Physical asset tag number assigned to the production line for asset management and tracking purposes. Links to the fixed asset register in the ERP system.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of automation on the production line. Indicates the level of human intervention required and impacts labor planning and quality consistency.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverTimeStandardMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Standard Minutes' ;
    rdfs:comment 'Standard time in minutes required to change over the production line from one product or batch to another. Used for production scheduling and OEE loss calculation.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleaningValidationProtocol rdf:type rdf:Property ;
    rdfs:label 'Cleaning Validation Protocol' ;
    rdfs:comment 'Reference to the cleaning validation protocol document applicable to this production line. Ensures GMP compliance and prevents cross-contamination.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewSizeStandard rdf:type rdf:Property ;
    rdfs:label 'Crew Size Standard' ;
    rdfs:comment 'Standard number of operators required to run the production line at full capacity. Used for labor planning and cost allocation.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designSpeedUnitsPerHour rdf:type rdf:Property ;
    rdfs:label 'Design Speed Units Per Hour' ;
    rdfs:comment 'Theoretical maximum production capacity of the line measured in units per hour under ideal conditions. Used for capacity planning and scheduling.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyConsumptionKwhPerUnit rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Unit' ;
    rdfs:comment 'Average energy consumption per unit produced on this line, measured in kilowatt-hours. Key metric for sustainability reporting and cost analysis.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalControlRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Control Required' ;
    rdfs:comment 'Indicates whether the production line requires controlled environmental conditions such as temperature, humidity, or air quality. Critical for GMP compliance and product quality.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpClassification rdf:type rdf:Property ;
    rdfs:label 'Gmp Classification' ;
    rdfs:comment 'GMP classification level of the production line indicating the quality and cleanliness standards required for products manufactured on this line. Critical for regulatory compliance and product safety.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityRangePercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Range Percent' ;
    rdfs:comment 'Acceptable relative humidity range for the production line as a percentage. Format: min-max (e.g., 40-60). Used for environmental monitoring and compliance.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installedPowerKw rdf:type rdf:Property ;
    rdfs:label 'Installed Power Kw' ;
    rdfs:comment 'Total installed electrical power capacity of the production line in kilowatts. Used for energy consumption tracking and sustainability reporting.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMajorOverhaulDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Overhaul Date' ;
    rdfs:comment 'Date of the most recent major overhaul or refurbishment of the production line. Used for maintenance planning and asset condition assessment.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Business identifier code for the production line. Unique within the facility and used for operational reference in MES systems and production scheduling.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineLengthMeters rdf:type rdf:Property ;
    rdfs:label 'Line Length Meters' ;
    rdfs:comment 'Physical length of the production line in meters. Used for facility layout planning and material flow analysis.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'Human-readable name of the production line. Used for display in dashboards, reports, and operator interfaces.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the production line based on its primary manufacturing function. Determines the type of operations and products that can be processed on this line.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeBetweenFailuresHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures Hours' ;
    rdfs:comment 'Average time in hours between equipment failures on this production line. Key reliability metric used for maintenance optimization and capacity planning.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTimeToRepairHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair Hours' ;
    rdfs:comment 'Average time in hours required to repair and restore the production line to operational status after a failure. Used for downtime analysis and maintenance resource planning.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesAssetTag rdf:type rdf:Property ;
    rdfs:label 'Mes Asset Tag' ;
    rdfs:comment 'Unique asset identifier for this production line in the Siemens Opcenter MES system. Used for real-time data collection, production tracking, and integration with shop floor systems.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User identifier of the person who last modified this production line record. Used for audit trail and accountability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next planned preventive maintenance activity for this production line. Used for maintenance scheduling and production planning coordination.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nominalOeeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Nominal Oee Target Percent' ;
    rdfs:comment 'Target OEE percentage for this production line. OEE is calculated as Availability × Performance × Quality and represents the benchmark for line performance evaluation.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plcSystemType rdf:type rdf:Property ;
    rdfs:label 'Plc System Type' ;
    rdfs:comment 'Type and model of the PLC system controlling the production line. Used for technical support, integration planning, and system upgrade management.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Frequency' ;
    rdfs:comment 'Standard frequency for quality control inspections on this production line. Defines the QC sampling plan and compliance with GMP requirements.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Source system from which this production line record originated (e.g., SAP S/4HANA PP, Siemens Opcenter MES). Used for data lineage and integration troubleshooting.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Scada Integration Enabled' ;
    rdfs:comment 'Indicates whether the production line is integrated with the SCADA system for real-time monitoring and control. Enables remote visibility and data collection.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scrapRateTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Scrap Rate Target Percent' ;
    rdfs:comment 'Target scrap rate percentage for this production line. Used for quality performance benchmarking and waste reduction initiatives.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Celsius' ;
    rdfs:comment 'Acceptable operating temperature range for the production line in Celsius. Format: min-max (e.g., 18-25). Used for environmental monitoring and compliance.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingBomId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Bom Id' ;
    rdfs:comment 'Unique identifier for the bill of materials record. Primary key for the manufacturing BOM entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingBom .

ind:contractLineId rdf:type rdf:Property ;
    rdfs:label 'Contract Line Id' ;
    rdfs:comment 'Foreign key linking to procurement.contract_line. Business justification: BOM components are sourced under specific contract lines that define unit price, quality specification, and lead time. In consumer goods, sourcing teams map BOM components to contract lines for standa' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractLine .

ind:primaryManufacturingSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Manufacturing Sku Id' ;
    rdfs:comment 'Reference to the finished good or semi-finished SKU that this BOM defines. Links to the product master for which this material structure applies.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:allergenFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Flag' ;
    rdfs:comment 'Indicates whether this component contains or may contain allergens as defined by FDA and EU REACH regulations. True if allergen present. Used for product labeling, consumer safety warnings, and regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternativeItemPriority rdf:type rdf:Property ;
    rdfs:label 'Alternative Item Priority' ;
    rdfs:comment 'The selection priority for this component within its alternative item group. Lower numbers indicate higher priority. Used by MRP to determine preferred material selection when multiple alternatives are available.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Indicates whether this component is automatically consumed (backflushed) when the finished good is confirmed in the MES system, rather than requiring explicit material issue transactions. True if backflushed. Common for high-volume, low-value components.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the base quantity (e.g., EA for each, KG for kilogram, L for liter, BOX for box). Must align with the SKU primary UOM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM. Active BOMs are used for production planning and MRP runs. Inactive or obsolete BOMs are retained for historical reference and regulatory traceability.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentEffectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Component Effective End Date' ;
    rdfs:comment 'The date after which this specific component is no longer valid within the BOM structure. Nullable for open-ended components. Used for material phase-out and supplier transition management.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:componentEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Component Effective Start Date' ;
    rdfs:comment 'The date from which this specific component becomes valid within the BOM structure. Supports phased material transitions, supplier changes, and cost optimization initiatives.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:componentItemCategory rdf:type rdf:Property ;
    rdfs:label 'Component Item Category' ;
    rdfs:comment 'Classification of the component type. Stock items are inventory-managed materials, non-stock are direct procurement items, phantom are intermediate assemblies not physically stocked, text items are instructions, and variable size items have flexible dimensions.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentQuantity rdf:type rdf:Property ;
    rdfs:label 'Component Quantity' ;
    rdfs:comment 'The quantity of this component required to produce the base quantity of the finished good. Used for MRP explosion, production order material requirements, and COGS calculation.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Component Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the component quantity (e.g., KG for raw materials, EA for packaging units, L for liquids). Must align with the component material master UOM.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Percentage' ;
    rdfs:comment 'The percentage of total product cost attributed to this component. Used for COGS calculation, profitability analysis, and cost optimization initiatives. Sum of all component cost allocations should equal 100% for the BOM.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Component Flag' ;
    rdfs:comment 'Indicates whether this component is critical for product quality, safety, or regulatory compliance. True if critical. Triggers enhanced quality control, supplier qualification requirements, and inventory safety stock policies.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeRequirement rdf:type rdf:Property ;
    rdfs:label 'Lot Size Requirement' ;
    rdfs:comment 'Defines the lot sizing rule for this component in production orders. Exact requires precise quantity, minimum allows overages, multiple requires quantities in specific increments, none has no restriction. Impacts material planning and waste management.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumLotSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Lot Size' ;
    rdfs:comment 'The minimum quantity that must be procured or produced for this component. Driven by supplier MOQ, production batch constraints, or economic order quantity calculations. Nullable if no minimum applies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plmSystemReference rdf:type rdf:Property ;
    rdfs:label 'Plm System Reference' ;
    rdfs:comment 'External reference identifier linking this BOM to the source PLM system record. Enables traceability to engineering change orders, formulation documents, and R&D specifications.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text field capturing regulatory compliance requirements, restrictions, or special handling instructions for this component. Includes FDA registration numbers, EU REACH compliance status, GMP requirements, and safety data sheet references.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapFactorPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percentage' ;
    rdfs:comment 'The expected waste or loss percentage for this component during production. Used to adjust gross material requirements in MRP runs. Typical values range from 0% to 10% depending on material type and process complexity.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Unique identifier for the production routing master record. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:changeoverTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Minutes' ;
    rdfs:comment 'Time required to transition production lines from the previous product to this routing. Critical for production scheduling and minimizing downtime.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedScrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Scrap Percentage' ;
    rdfs:comment 'Overall expected scrap percentage for the routing, representing anticipated waste or defects. Used for material planning and cost estimation.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Yield Percentage' ;
    rdfs:comment 'Overall expected yield percentage for the routing, representing the ratio of good output to total input. Used for production planning and variance analysis.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Critical Flag' ;
    rdfs:comment 'Indicates whether this routing includes GMP-critical operations requiring enhanced documentation, validation, and compliance controls per ISO 22716 and FDA regulations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipcCheckpointCount rdf:type rdf:Property ;
    rdfs:label 'Ipc Checkpoint Count' ;
    rdfs:comment 'Number of in-process control checkpoints defined in this routing. IPC checkpoints are quality inspection points during production per ISO 22716 and GMP requirements.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotSizeRestriction rdf:type rdf:Property ;
    rdfs:label 'Lot Size Restriction' ;
    rdfs:comment 'Constraint on production lot sizes for this routing. Fixed requires exact base quantity; minimum/maximum define bounds; multiple requires lot sizes to be multiples of base quantity; none allows any lot size.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLotSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Lot Size' ;
    rdfs:comment 'Maximum production lot size allowed for this routing. Nullable if no maximum constraint exists.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationSequence rdf:type rdf:Property ;
    rdfs:label 'Operation Sequence' ;
    rdfs:comment 'JSON array or delimited string capturing the complete sequence of operation steps. Each operation includes: operation_number, work_center_code, operation_description, control_key (internal_processing|external_processing|milestone), setup_time_minutes, machine_time_minutes, labor_time_minutes, yield_quantity, scrap_percentage, gmp_critical_step_flag, ipc_checkpoint_flag. This is the single authoritative source for all routing operation data — no separate operation entity exists.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionSchedulerCode rdf:type rdf:Property ;
    rdfs:label 'Production Scheduler Code' ;
    rdfs:comment 'Code identifying the production scheduling strategy or algorithm used for this routing (e.g., forward scheduling, backward scheduling, finite capacity).' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingDescription rdf:type rdf:Property ;
    rdfs:label 'Routing Description' ;
    rdfs:comment 'Detailed textual description of the routing, including its purpose, scope, and any special instructions for production planners and shop floor operators.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Business identifier for the routing. Externally-known unique code used in production planning and scheduling systems.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Status' ;
    rdfs:comment 'Current lifecycle status of the routing. Active routings are available for production scheduling; draft routings are under development; inactive routings are temporarily disabled; obsolete routings are retired; under_review routings are pending approval.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingType rdf:type rdf:Property ;
    rdfs:label 'Routing Type' ;
    rdfs:comment 'Classification of the routing defining its usage pattern. Standard routings are default production paths; reference routings are templates; rate routings define production rates; alternative routings provide backup paths; special routings are for one-time or custom production runs.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Amount' ;
    rdfs:comment 'Standard production cost per base quantity for this routing, including labor, machine, and overhead costs. Used for cost accounting and variance analysis.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLaborTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Labor Time Minutes' ;
    rdfs:comment 'Cumulative labor time across all operations in the routing, used for workforce planning and standard cost calculation.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMachineTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Machine Time Minutes' ;
    rdfs:comment 'Cumulative machine processing time across all operations in the routing, used for capacity planning and Overall Equipment Effectiveness (OEE) calculations.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Setup Time Minutes' ;
    rdfs:comment 'Cumulative setup time across all operations in the routing, used for capacity planning and scheduling.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Standard Lead Time Hours' ;
    rdfs:comment 'Total cumulative lead time in hours required to complete all operations in this routing, including setup, processing, and queue times. Used for Material Requirements Planning (MRP) and capacity planning.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Order Id' ;
    rdfs:comment 'Unique identifier for the production order. Primary key for the production order entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:standardCostId rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Id' ;
    rdfs:comment 'Foreign key linking to finance.standard_cost. Business justification: Production orders are costed against standard costs for manufacturing variance analysis (actual vs. standard). This is a core cost accounting process in consumer goods — planned_cost on the order is d' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StandardCost .

ind:tradePromotionId rdf:type rdf:Property ;
    rdfs:label 'Trade Promotion Id' ;
    rdfs:comment 'Foreign key linking to promotion.trade_promotion. Business justification: Promotional Production Fulfillment Tracking: production orders are released to manufacture promotional volumes committed in trade promotions. Consumer goods planners and finance teams track promotiona' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradePromotion .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual cost incurred for the production order. Includes material, labor, and overhead costs. Used for variance analysis.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'Actual date and time when production execution completed. Used for OEE calculation and performance analysis.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when production execution began on the shop floor. Captured from MES system.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Unique batch or lot number assigned to the production run. Critical for traceability and recall management per GMP requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costObject rdf:type rdf:Property ;
    rdfs:label 'Cost Object' ;
    rdfs:comment 'Cost object (production order number or process order) used for collecting actual costs. Links to CO-PC product costing.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Minutes' ;
    rdfs:comment 'Total unplanned downtime in minutes during production execution. Impacts OEE availability component.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpController rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller' ;
    rdfs:comment 'Three-character code identifying the MRP controller responsible for planning this material. Links to planner master data.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeePercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Percentage' ;
    rdfs:comment 'Overall Equipment Effectiveness percentage for this production run. Calculated as Availability × Performance × Quality. Industry standard KPI.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business identifier for the production order. Externally-known unique order number assigned by SAP S/4HANA PP system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Quantity' ;
    rdfs:comment 'Planned quantity to be produced in base unit of measure. Target output for the production order.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of production order. PP01=Standard Production, PP03=Rework, PP05=Co-Product, PP10=Process Order, PP20=Batch Order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCost rdf:type rdf:Property ;
    rdfs:label 'Planned Cost' ;
    rdfs:comment 'Standard or planned cost for producing the order quantity. Calculated from BOM and routing costs.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionSupervisor rdf:type rdf:Property ;
    rdfs:label 'Production Supervisor' ;
    rdfs:comment 'Name of the production supervisor responsible for overseeing execution of this order on the shop floor.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Indicates whether quality inspection is mandatory before goods receipt. Drives QM integration and inspection lot creation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releasedBy rdf:type rdf:Property ;
    rdfs:label 'Released By' ;
    rdfs:comment 'User ID of the person who released the production order for execution. Audit trail for production authorization.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'Date and time when the production order was released for shop floor execution. Triggers material availability check and capacity reservation.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledFinishDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Date' ;
    rdfs:comment 'Planned date when production is scheduled to complete. Used for capacity planning and delivery commitments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date when production is scheduled to begin. Set during production planning and MRP run.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Quantity of material scrapped or rejected during production. Used for yield analysis and cost accounting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementRule rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule' ;
    rdfs:comment 'Rule for settling production order costs. FUL=Full settlement, PAR=Partial settlement, PER=Periodic settlement.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Actual yield percentage calculated as (confirmed_quantity / order_quantity) * 100. Key performance metric for production efficiency.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Actual cost per unit incurred for this batch. Includes material, labor, and overhead variances.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeActual rdf:type rdf:Property ;
    rdfs:label 'Batch Size Actual' ;
    rdfs:comment 'Actual production quantity achieved for this batch. Used for yield calculation and inventory reconciliation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizePlanned rdf:type rdf:Property ;
    rdfs:label 'Batch Size Planned' ;
    rdfs:comment 'Planned production quantity for this batch as specified in the production order. Measured in base unit of measure.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the batch. Controls inventory availability and distribution eligibility per GMP workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomVersion rdf:type rdf:Property ;
    rdfs:label 'Bom Version' ;
    rdfs:comment 'Version of the bill of materials used for this batch. Ensures traceability of raw material specifications.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Minutes' ;
    rdfs:comment 'Time in minutes required for line changeover before this batch. Key metric for SMED and lean manufacturing initiatives.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:electronicSignatureCount rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Count' ;
    rdfs:comment 'Number of electronic signatures captured during batch record lifecycle. Required for FDA 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Gmp Deviation Count' ;
    rdfs:comment 'Number of GMP deviations recorded for this batch. Used for quality trend analysis and CAPA tracking.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Deviation Flag' ;
    rdfs:comment 'Indicates whether any GMP deviations were recorded during batch production. Triggers quality review workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotGenealogyCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Lot Genealogy Complete Flag' ;
    rdfs:comment 'Indicates whether complete raw material lot traceability has been captured for this batch. Required for recall readiness.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'Calendar date of batch production. Printed on product packaging for consumer information and regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing End Timestamp' ;
    rdfs:comment 'Date and time when batch production was completed and final packaging finished. Used for cycle time analysis.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufacturingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Start Timestamp' ;
    rdfs:comment 'Date and time when batch production was initiated on the shop floor. Captured from MES system.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Release Flag' ;
    rdfs:comment 'Indicates whether the batch has been released by Quality Assurance for distribution. Required before inventory availability.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Quality Release Timestamp' ;
    rdfs:comment 'Date and time when Quality Assurance approved the batch for release. Marks transition from quarantine to available inventory.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this batch is subject to a product recall. Triggers supply chain hold and customer notification.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Recall Initiated Date' ;
    rdfs:comment 'Date when recall was initiated for this batch. Used for regulatory reporting and recall effectiveness tracking.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordLockedFlag rdf:type rdf:Property ;
    rdfs:label 'Record Locked Flag' ;
    rdfs:comment 'Indicates whether this batch record is locked from further edits. Required for GMP record integrity after quality release.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reworkQuantity rdf:type rdf:Property ;
    rdfs:label 'Rework Quantity' ;
    rdfs:comment 'Quantity of product requiring rework during batch production. Indicator of process capability and quality issues.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingVersion rdf:type rdf:Property ;
    rdfs:label 'Routing Version' ;
    rdfs:comment 'Version of the production routing used for this batch. Documents the manufacturing process steps executed.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Number of days between manufacturing date and expiry date. Derived from product stability testing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:veevaVaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Reference' ;
    rdfs:comment 'Reference to the master batch record document stored in Veeva Vault. Links to regulatory document management system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeRecordId rdf:type rdf:Property ;
    rdfs:label 'Oee Record Id' ;
    rdfs:comment 'Unique identifier for the OEE measurement record. Primary key for the OEE record entity.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Actual Cycle Time Seconds' ;
    rdfs:comment 'Average actual time in seconds to produce one unit during the shift, calculated as Actual Operating Time / Total Units Produced.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualOperatingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Operating Time Minutes' ;
    rdfs:comment 'Actual time the production line was operating during the shift in minutes, after subtracting unplanned downtime.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availabilityRate rdf:type rdf:Property ;
    rdfs:label 'Availability Rate' ;
    rdfs:comment 'Percentage of planned production time that the line was actually operating, calculated as (Planned Production Time - Downtime) / Planned Production Time. Component of OEE calculation.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeoverCount rdf:type rdf:Property ;
    rdfs:label 'Changeover Count' ;
    rdfs:comment 'Number of product or format changeovers performed during the shift. Impacts availability and performance metrics.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text comments or notes regarding the OEE measurement, including explanations for anomalies or performance issues.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Method by which OEE data was captured (automated from sensors, manual entry, or semi-automated).' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodUnitsProduced rdf:type rdf:Property ;
    rdfs:label 'Good Units Produced' ;
    rdfs:comment 'Count of units that passed quality inspection and met specifications, calculated as Total Units Produced - Total Units Rejected.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:idealCycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Ideal Cycle Time Seconds' ;
    rdfs:comment 'Theoretical minimum time in seconds to produce one unit at maximum design speed under optimal conditions.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesDataSource rdf:type rdf:Property ;
    rdfs:label 'Mes Data Source' ;
    rdfs:comment 'Source system identifier for the OEE data, typically Siemens Opcenter MES or equivalent system.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:microStopCount rdf:type rdf:Property ;
    rdfs:label 'Micro Stop Count' ;
    rdfs:comment 'Number of brief stoppages (typically under 5 minutes) that impact performance but may not be classified as downtime.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oeeStatus rdf:type rdf:Property ;
    rdfs:label 'Oee Status' ;
    rdfs:comment 'Current lifecycle status of the OEE record indicating validation and approval state.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorCount rdf:type rdf:Property ;
    rdfs:label 'Operator Count' ;
    rdfs:comment 'Number of operators assigned to the production line during the shift.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceRate rdf:type rdf:Property ;
    rdfs:label 'Performance Rate' ;
    rdfs:comment 'Percentage of ideal production speed achieved, calculated as (Ideal Cycle Time × Total Units Produced) / Actual Operating Time. Component of OEE calculation.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedProductionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Production Time Minutes' ;
    rdfs:comment 'Total scheduled production time for the shift in minutes, excluding planned downtime such as breaks and scheduled maintenance.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityLossMinutes rdf:type rdf:Property ;
    rdfs:label 'Quality Loss Minutes' ;
    rdfs:comment 'Time equivalent of production lost due to quality defects and rework in minutes.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityRate rdf:type rdf:Property ;
    rdfs:label 'Quality Rate' ;
    rdfs:comment 'Percentage of good units produced without defects, calculated as (Total Units Produced - Total Units Rejected) / Total Units Produced. Component of OEE calculation.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Date and time when the OEE record was first created in the system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Date and time when the OEE record was last modified.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reworkUnits rdf:type rdf:Property ;
    rdfs:label 'Rework Units' ;
    rdfs:comment 'Count of units that required rework or reprocessing to meet quality standards during the shift.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scrapWeightKg rdf:type rdf:Property ;
    rdfs:label 'Scrap Weight Kg' ;
    rdfs:comment 'Total weight of scrap material generated during the shift in kilograms.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDate rdf:type rdf:Property ;
    rdfs:label 'Shift Date' ;
    rdfs:comment 'Calendar date on which the production shift occurred. Principal business event timestamp for OEE measurement.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftName rdf:type rdf:Property ;
    rdfs:label 'Shift Name' ;
    rdfs:comment 'Descriptive name of the production shift (e.g., day, evening, night).' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftNumber rdf:type rdf:Property ;
    rdfs:label 'Shift Number' ;
    rdfs:comment 'Sequential shift identifier within the shift date (e.g., 1 for first shift, 2 for second shift, 3 for third shift).' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speedLossMinutes rdf:type rdf:Property ;
    rdfs:label 'Speed Loss Minutes' ;
    rdfs:comment 'Time lost due to production running below ideal cycle time in minutes, representing performance inefficiency.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnitsProduced rdf:type rdf:Property ;
    rdfs:label 'Total Units Produced' ;
    rdfs:comment 'Total count of units produced during the shift, including both good units and rejected units.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitsRejected rdf:type rdf:Property ;
    rdfs:label 'Total Units Rejected' ;
    rdfs:comment 'Total count of units rejected due to quality defects during the shift.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unplannedStopCount rdf:type rdf:Property ;
    rdfs:label 'Unplanned Stop Count' ;
    rdfs:comment 'Number of unplanned production stoppages during the shift.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downtimeEventId rdf:type rdf:Property ;
    rdfs:label 'Downtime Event Id' ;
    rdfs:comment 'Unique identifier for the downtime event record. Primary key for the downtime event entity.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.equipment. Business justification: downtime_event records individual stoppages on a production line and captures equipment_failure_mode (STRING) as a description. Adding equipment_id as a FK to the equipment master enables direct linka' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:batchHoldRequired rdf:type rdf:Property ;
    rdfs:label 'Batch Hold Required' ;
    rdfs:comment 'Indicates whether production batches affected by this downtime event require quality hold pending investigation.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of the corrective action taken to resolve the downtime event and restore production.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeCategory rdf:type rdf:Property ;
    rdfs:label 'Downtime Category' ;
    rdfs:comment 'High-level classification of the downtime event type. [ENUM-REF-CANDIDATE: mechanical_failure|electrical_failure|changeover|material_shortage|operator_absence|planned_maintenance|cleaning_sanitation|quality_hold|tooling_issue|system_failure|unplanned_maintenance — promote to reference product]' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime End Timestamp' ;
    rdfs:comment 'Timestamp when the downtime event ended and production resumed. Null if downtime is ongoing.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime Start Timestamp' ;
    rdfs:comment 'Timestamp when the downtime event began. Captured from MES system or manual entry.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeType rdf:type rdf:Property ;
    rdfs:label 'Downtime Type' ;
    rdfs:comment 'Indicates whether the downtime was planned (scheduled maintenance, changeover) or unplanned (breakdown, shortage).' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total duration of the downtime event measured in minutes. Calculated as the difference between end and start timestamps.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentFailureMode rdf:type rdf:Property ;
    rdfs:label 'Equipment Failure Mode' ;
    rdfs:comment 'Specific failure mode of the equipment that caused the downtime, used for reliability analysis and FMEA.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Level of management escalation required or triggered by this downtime event based on duration and impact.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether automated notifications were sent to relevant stakeholders about this downtime event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oeeImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Oee Impact Flag' ;
    rdfs:comment 'Indicates whether this downtime event is included in OEE availability loss calculations.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Required' ;
    rdfs:comment 'Indicates whether preventive action is required to avoid recurrence of this downtime event.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionLossUnits rdf:type rdf:Property ;
    rdfs:label 'Production Loss Units' ;
    rdfs:comment 'Estimated number of production units lost due to this downtime event, based on standard production rate.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Timestamp when the downtime event was first reported or logged in the system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current status of the downtime event resolution process.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Department responsible for addressing or preventing this type of downtime event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code identifying the root cause of the downtime event. Aligned with facility-specific root cause taxonomy.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed textual description of the root cause analysis findings for this downtime event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Severity classification of the downtime event based on impact to production schedule and safety.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldRecordId rdf:type rdf:Property ;
    rdfs:label 'Yield Record Id' ;
    rdfs:comment 'Unique identifier for the yield tracking record. Primary key for the yield record entity.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Percentage' ;
    rdfs:comment 'Actual yield percentage achieved calculated as (output_quantity / input_quantity) * 100. Key Performance Indicator (KPI) for manufacturing efficiency.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Record Status' ;
    rdfs:comment 'Current lifecycle status of the batch record documentation. Tracks progression through Good Manufacturing Practice (GMP) review and approval workflow.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Cost center responsible for this manufacturing operation. Used for Cost of Goods Sold (COGS) allocation and variance accounting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Document Number' ;
    rdfs:comment 'Document number in the Enterprise Resource Planning (ERP) system (SAP S/4HANA) that records the goods movement associated with this yield. Links to material document for inventory reconciliation.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputQuantity rdf:type rdf:Property ;
    rdfs:label 'Input Quantity' ;
    rdfs:comment 'Total quantity of raw materials or semi-finished goods consumed as input for this operation. Used to calculate theoretical yield and material consumption variance.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'Date and time when the yield measurement was captured at the work center. Critical for Manufacturing Execution System (MES) integration and real-time production monitoring.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mesTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Mes Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier from the Manufacturing Execution System (MES) that originated this yield record. Enables traceability to Siemens Opcenter MES source data.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation End Timestamp' ;
    rdfs:comment 'Date and time when the manufacturing operation completed. Used to calculate cycle time and Overall Equipment Effectiveness (OEE).' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation Start Timestamp' ;
    rdfs:comment 'Date and time when the manufacturing operation began. Used to calculate cycle time and Overall Equipment Effectiveness (OEE).' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outputQuantity rdf:type rdf:Property ;
    rdfs:label 'Output Quantity' ;
    rdfs:comment 'Total quantity of finished or semi-finished goods produced as output from this operation. Represents the good production yield before scrap and rework.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Lot Number' ;
    rdfs:comment 'Quality Control (QC) inspection lot number associated with this yield record. Links yield data to quality inspection results for Good Manufacturing Practice (GMP) compliance.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingOperationNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Operation Number' ;
    rdfs:comment 'Specific operation sequence number within the production routing where yield is measured. Identifies the manufacturing step in the Bill of Materials (BOM) routing.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Production shift identifier during which the yield measurement was captured. Used for shift-level performance analysis and labor productivity tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoreticalYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Theoretical Yield Percentage' ;
    rdfs:comment 'Expected yield percentage based on Bill of Materials (BOM) specifications and standard operating procedures. Baseline for variance analysis.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldLossReasonCode rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Reason Code' ;
    rdfs:comment 'Standardized code identifying the root cause of yield variance. Used for Pareto analysis and continuous improvement initiatives. Examples: EQUIP_FAIL, MAT_DEFECT, PROC_ERROR, QUAL_REJECT.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldLossReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Reason Description' ;
    rdfs:comment 'Detailed description of the yield loss root cause. Provides context for quality investigations and corrective action planning.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldVarianceCostImpact rdf:type rdf:Property ;
    rdfs:label 'Yield Variance Cost Impact' ;
    rdfs:comment 'Financial impact of yield variance calculated as (theoretical_yield - actual_yield) * standard_cost_per_unit. Feeds into Cost of Goods Sold (COGS) variance reporting.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Variance Percentage' ;
    rdfs:comment 'Variance between actual and theoretical yield expressed as percentage. Calculated as (actual_yield_percentage - theoretical_yield_percentage). Negative values indicate yield loss.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Production Confirmation Id' ;
    rdfs:comment 'Unique identifier for the production confirmation record. Primary key for shop floor execution tracking.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Production confirmations trigger automatic journal entries in ERP (goods issue, activity confirmation, goods receipt postings). Linking confirmation to journal_entry provides the audit trail from shop' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'SAP CO activity type code representing the type of work performed (e.g., machine hours, labor hours, setup hours) for cost allocation purposes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual date and time when the operation was completed and confirmed by the operator. Used for OEE calculation and production order settlement.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Time Minutes' ;
    rdfs:comment 'Actual operator labor time spent on this operation including manual work, monitoring, and quality checks. Measured in minutes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMachineTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Machine Time Minutes' ;
    rdfs:comment 'Actual time the machine or equipment was actively running during this operation. Excludes setup and downtime. Measured in minutes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Setup Time Minutes' ;
    rdfs:comment 'Actual time spent on machine setup, changeover, and preparation activities before production began. Measured in minutes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual date and time when the operator began executing this operation on the shop floor. Captured from MES or manual confirmation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationNotes rdf:type rdf:Property ;
    rdfs:label 'Confirmation Notes' ;
    rdfs:comment 'Free-text notes or comments entered by the operator or supervisor regarding this operation execution, including any issues or observations.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'System timestamp when this confirmation record was created and submitted to the ERP or MES system.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationType rdf:type rdf:Property ;
    rdfs:label 'Confirmation Type' ;
    rdfs:comment 'Classification of the confirmation event indicating whether this is a partial progress update, final completion, milestone checkpoint, rework confirmation, or cancellation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedScrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Scrap Quantity' ;
    rdfs:comment 'Actual quantity of defective or waste material generated during this operation. Used for yield variance analysis and quality tracking.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedYieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Yield Quantity' ;
    rdfs:comment 'Actual quantity of good output produced and confirmed for this operation. Measured in the base unit of measure for the material.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeAvailabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Availability Percent' ;
    rdfs:comment 'Calculated availability component of OEE for this operation, representing the percentage of scheduled time that equipment was available for production.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeePerformancePercent rdf:type rdf:Property ;
    rdfs:label 'Oee Performance Percent' ;
    rdfs:comment 'Calculated performance component of OEE for this operation, representing actual production speed versus ideal speed.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeQualityPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Quality Percent' ;
    rdfs:comment 'Calculated quality component of OEE for this operation, representing the percentage of good output versus total output produced.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationStatus rdf:type rdf:Property ;
    rdfs:label 'Operation Status' ;
    rdfs:comment 'Current lifecycle status of the manufacturing operation indicating its execution state in the production workflow.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Financial posting date when this confirmation was recorded in the ERP system for inventory and cost accounting purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether this operation output requires quality inspection before release to inventory or next operation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this confirmation has been reversed or cancelled due to error correction or process adjustment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Standardized code explaining why this confirmation was reversed, if applicable. Used for process improvement and error tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Flag' ;
    rdfs:comment 'Indicates whether this confirmation represents a rework operation to correct defects from a previous production run.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'Planned completion date and time for this operation as determined by production scheduling or MES system.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'Planned start date and time for this operation as determined by production scheduling or MES system.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Standardized code explaining any significant variance between planned and actual quantities or times. Used for root cause analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Business identifier for the work order assigned to this manufacturing operation. Externally visible reference used across shop floor systems.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedOrderId rdf:type rdf:Property ;
    rdfs:label 'Planned Order Id' ;
    rdfs:comment 'Unique system-generated identifier for the planned order record. Primary key for the planned order entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlannedOrder .

ind:convertedProductionOrderId rdf:type rdf:Property ;
    rdfs:label 'Converted Production Order Id' ;
    rdfs:comment 'Reference to the production order that was created from this planned order upon conversion. Null if not yet converted.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:demandPlanId rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.demand_plan. Business justification: MRP/IBP planned orders are pegged to demand plan versions for demand-supply traceability. Consumer goods planners use this pegging to assess forecast accuracy impact on production scheduling and to pe' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandPlan .

ind:demandSourceSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Demand Source Sales Order Id' ;
    rdfs:comment 'Foreign key linking to sales.order. Business justification: MRP demand pegging: in consumer goods make-to-order and ATP scenarios, planned orders are generated directly from sales orders. This FK enables S&OP demand traceability reports linking planned product' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:planningPeriodId rdf:type rdf:Property ;
    rdfs:label 'Planning Period Id' ;
    rdfs:comment 'Foreign key linking to supply.planning_period. Business justification: Planned orders belong to a structured planning period/bucket in IBP/APO. Linking to planning_period enables period-level production plan aggregation, S&OP cycle reporting, and planning horizon managem' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanningPeriod .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_requisition. Business justification: In MRP/IBP processes, planned orders for externally procured materials convert directly into purchase requisitions. This link enables end-to-end demand-to-procurement traceability, MRP exception manag' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseRequisition .

ind:safetyStockId rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Id' ;
    rdfs:comment 'Foreign key linking to supply.safety_stock. Business justification: Safety stock replenishment signals trigger planned orders in MRP. Linking planned_order to the safety_stock policy that triggered it enables safety stock policy effectiveness analysis and supports inv' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyStock .

ind:availabilityDate rdf:type rdf:Property ;
    rdfs:label 'Availability Date' ;
    rdfs:comment 'The date when the produced or procured material from this planned order is expected to be available for consumption or shipment.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'The date when this planned order was converted to a production order. Null if not yet converted.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Indicates whether this planned order has been converted to a production order: NOT_CONVERTED (still in planning), PARTIALLY_CONVERTED (split conversion), FULLY_CONVERTED (completely converted).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User ID or system identifier of the person or automated process that created this planned order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSourceType rdf:type rdf:Property ;
    rdfs:label 'Demand Source Type' ;
    rdfs:comment 'Classification of the demand signal that triggered this planned order: FORECAST (demand planning), CUSTOMER_ORDER (firm sales order), STOCK_TRANSFER (inter-plant), SAFETY_STOCK (replenishment), PROMOTION (trade promotion demand).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessageCode rdf:type rdf:Property ;
    rdfs:label 'Exception Message Code' ;
    rdfs:comment 'Code representing MRP exception conditions (e.g., EX01 = reschedule in, EX02 = reschedule out, EX03 = cancel, EX10 = expedite). Empty if no exception.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessageText rdf:type rdf:Property ;
    rdfs:label 'Exception Message Text' ;
    rdfs:comment 'Human-readable description of the MRP exception condition requiring planner attention.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmingDate rdf:type rdf:Property ;
    rdfs:label 'Firming Date' ;
    rdfs:comment 'The date when this planned order was firmed by a planner. Null if not yet firmed.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firmingIndicator rdf:type rdf:Property ;
    rdfs:label 'Firming Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this planned order is firmed (locked from automatic MRP changes). True = firmed, False = subject to MRP rescheduling.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ibpPlanVersion rdf:type rdf:Property ;
    rdfs:label 'Ibp Plan Version' ;
    rdfs:comment 'Version identifier from SAP IBP system that generated the demand signal driving this planned order. Format: IBP-YYYYMM.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User ID or system identifier of the person or automated process that last modified this planned order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeKey rdf:type rdf:Property ;
    rdfs:label 'Lot Size Key' ;
    rdfs:comment 'Code indicating the lot-sizing procedure used: EX (exact lot size), HB (lot-for-lot), FX (fixed lot size), PD (periodic lot size), WM (weekly lot size).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpRunCode rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Code' ;
    rdfs:comment 'Reference to the specific MRP run that generated or last modified this planned order. Links to MRP execution history.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'The quantity of the SKU planned to be produced or procured in this order, expressed in the base unit of measure.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningPeriod rdf:type rdf:Property ;
    rdfs:label 'Planning Period' ;
    rdfs:comment 'The planning time bucket this order belongs to, expressed as YYYY-Wnn (week), YYYY-Mnn (month), or YYYY-Qn (quarter). Used for MPS and S&OP alignment.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningStrategyGroup rdf:type rdf:Property ;
    rdfs:label 'Planning Strategy Group' ;
    rdfs:comment 'Two-digit code defining the planning strategy (e.g., 10 = make-to-stock, 20 = make-to-order, 40 = planning with final assembly, 50 = planning without final assembly).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Priority level assigned to this planned order for scheduling and resource allocation: LOW, NORMAL, HIGH, URGENT.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Indicates whether this planned order is for in-house production (IN_HOUSE), external procurement (EXTERNAL), or can be either (BOTH).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'The inventory level that triggers generation of a planned order for replenishment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'The safety stock level maintained for this SKU at this plant, influencing planned order generation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version identifier for the MPS schedule that generated or governs this planned order. Enables tracking of schedule changes over time.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopCycleReference rdf:type rdf:Property ;
    rdfs:label 'Sop Cycle Reference' ;
    rdfs:comment 'Reference to the S&OP planning cycle that this planned order aligns with. Format: SOP-YYYY-Mnn or SOP-YYYY-Qn.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Inventory Storage Location Id' ;
    rdfs:comment 'Reference to the physical storage location (warehouse, distribution center, store, or specific bin) where the inventory is held.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryStorageLocation .

ind:procurementGoodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Procurement Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to procurement.goods_receipt. Business justification: REQUIRED: Traceability of on-hand stock to the goods receipt that created it for audit and regulatory compliance.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:availableToPromiseQuantity rdf:type rdf:Property ;
    rdfs:label 'Available To Promise Quantity' ;
    rdfs:comment 'Quantity available for new customer orders after accounting for existing commitments and reservations. Calculated as unrestricted quantity minus reserved quantity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockedQuantity rdf:type rdf:Property ;
    rdfs:label 'Blocked Quantity' ;
    rdfs:comment 'Quantity of stock that is blocked from use due to quality issues, regulatory holds, or other restrictions.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysInventoryOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Inventory Outstanding' ;
    rdfs:comment 'Number of days the current inventory level would last based on average daily demand. Key metric for working capital efficiency and cash flow management.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date after which the product should not be sold or used. Essential for FEFO inventory rotation and regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'Date when the inventory was physically received at this storage location. Used for FIFO rotation and aging analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'Quantity of stock currently in transit between locations (plant-to-warehouse, warehouse-to-store, etc.) and not yet received at destination.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastGoodsMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Movement Date' ;
    rdfs:comment 'Date of the most recent inventory transaction (receipt, issue, transfer) for this stock position. Used to identify slow-moving or obsolete inventory.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Inventory Date' ;
    rdfs:comment 'Date when the last physical count or cycle count was performed for this stock position. Used for inventory accuracy monitoring.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Quantity' ;
    rdfs:comment 'Maximum inventory level allowed at this location to prevent overstocking and optimize working capital.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obsoleteFlag rdf:type rdf:Property ;
    rdfs:label 'Obsolete Flag' ;
    rdfs:comment 'Indicates whether the inventory is obsolete (discontinued product, expired, or no longer saleable) and should be written off or disposed.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oosRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Oos Risk Flag' ;
    rdfs:comment 'Indicates whether the current stock level is below safety stock and at risk of stockout. Used for proactive replenishment alerts.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionQuantity rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Quantity' ;
    rdfs:comment 'Quantity of stock currently undergoing quality control inspection and not yet released for use.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current physical inventory quantity available at the storage location. This is the authoritative single source of truth for inventory balance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Indicates whether the stock is under quarantine pending quality inspection, regulatory review, or investigation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Hold Flag' ;
    rdfs:comment 'Indicates whether the stock is on hold due to a product recall or safety alert. Prevents further distribution or sale.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity of stock reserved for specific sales orders, production orders, or other commitments and not available for general allocation.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeRemainingDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Remaining Days' ;
    rdfs:comment 'Number of days remaining until expiration. Used for FEFO prioritization and markdown planning.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slowMovingFlag rdf:type rdf:Property ;
    rdfs:label 'Slow Moving Flag' ;
    rdfs:comment 'Indicates whether the inventory has had no or minimal movement over a defined period (typically 90+ days), signaling potential obsolescence risk.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'Indicates whether the stock is held under special conditions or ownership arrangements. Standard stock is company-owned and unrestricted; consignment is supplier-owned; project stock is allocated to specific projects; sales order stock is reserved for specific customer orders; subcontracting stock is at vendor location; pipeline stock is in-transit; returnable packaging is reusable containers. [ENUM-REF-CANDIDATE: standard|consignment|project|sales_order|subcontracting|pipeline|returnable_packaging — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockRotationRule rdf:type rdf:Property ;
    rdfs:label 'Stock Rotation Rule' ;
    rdfs:comment 'Inventory rotation policy applied at this location. FIFO=First In First Out; FEFO=First Expired First Out (for perishables); LIFO=Last In First Out; Manual=operator-controlled picking.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'Current lifecycle status of the stock position. Active=available for operations; Inactive=temporarily unavailable; Pending Disposal=marked for write-off; Transferred=moved to another location; Consumed=used in production or sold.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'Classification of inventory by availability status. Unrestricted stock is available for sale or use; quality inspection stock is pending QC approval; blocked stock cannot be used; returns stock is customer returns awaiting disposition; restricted use stock has limited applications; consignment stock is owned by supplier; VMI-managed stock is vendor-managed inventory. [ENUM-REF-CANDIDATE: unrestricted|quality_inspection|blocked|returns|restricted_use|consignment|vmi_managed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Total financial value of the stock position, calculated as quantity on hand multiplied by unit cost. Used for balance sheet reporting and working capital analysis.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrestrictedQuantity rdf:type rdf:Property ;
    rdfs:label 'Unrestricted Quantity' ;
    rdfs:comment 'Quantity of stock that is freely available for sale, production, or distribution without any restrictions.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'Method used to value the inventory for financial reporting. Standard uses predetermined costs; moving average recalculates after each receipt; FIFO assumes first-in-first-out; LIFO assumes last-in-first-out; weighted average uses average cost across all receipts.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiReplenishmentFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Replenishment Flag' ;
    rdfs:comment 'Indicates whether this stock position is managed under a VMI agreement where the vendor is responsible for replenishment decisions.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dossierId rdf:type rdf:Property ;
    rdfs:label 'Dossier Id' ;
    rdfs:comment 'Foreign key linking to regulatory.dossier. Business justification: Batch traceability links each lot/batch to its regulatory dossier for post-market surveillance and recall investigations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dossier .

ind:bestBeforeDate rdf:type rdf:Property ;
    rdfs:label 'Best Before Date' ;
    rdfs:comment 'The date until which the product retains optimal quality. Distinct from expiry_date; product may still be safe but quality may degrade after this date.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateOfAnalysisNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Number' ;
    rdfs:comment 'The unique identifier for the Certificate of Analysis document that records the quality test results for this lot or batch.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting regulatory compliance status, exceptions, or special handling requirements for this lot or batch.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Status' ;
    rdfs:comment 'Indicates whether this lot or batch was produced in compliance with Good Manufacturing Practice standards. Critical for regulatory compliance and quality assurance.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Flag' ;
    rdfs:comment 'Boolean flag indicating whether this lot or batch is on hold and cannot be used or shipped. True if on hold, False otherwise.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'The business reason why this lot or batch is on hold, if applicable. Examples: pending quality review, regulatory investigation, customer complaint.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'The date on which quality control inspection was performed on this lot or batch.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Alternative or supplementary lot identifier used in some manufacturing contexts. May be the same as batch_number or represent a sub-batch.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Production Order Number' ;
    rdfs:comment 'The production order or work order number under which this lot or batch was manufactured. Links to Manufacturing Execution System (MES) records.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityGrade rdf:type rdf:Property ;
    rdfs:label 'Quality Grade' ;
    rdfs:comment 'The quality grade or classification assigned to this lot or batch based on quality control inspection results. May affect pricing, distribution channel, or disposal decisions. [ENUM-REF-CANDIDATE: A|B|C|premium|standard|substandard|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityProduced rdf:type rdf:Property ;
    rdfs:label 'Quantity Produced' ;
    rdfs:comment 'The total quantity of product manufactured in this lot or batch, measured in the base unit of measure.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineStatus rdf:type rdf:Property ;
    rdfs:label 'Quarantine Status' ;
    rdfs:comment 'Current quarantine or release status of the lot or batch. Quarantined lots cannot be used or shipped until quality inspection is complete and status is changed to released.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The date on which this lot or batch was received into inventory, applicable for purchased or transferred goods.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Remaining Shelf Life Days' ;
    rdfs:comment 'The number of days remaining until expiry_date as of the current date. Used for inventory rotation and markdown decisions.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'The date by which the lot or batch must be retested to confirm continued quality and compliance. Common in pharmaceutical and chemical manufacturing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageConditionRequirement rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Requirement' ;
    rdfs:comment 'The required storage conditions for this lot or batch to maintain product quality and safety. Examples: ambient, refrigerated, frozen, controlled room temperature.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierLotNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Number' ;
    rdfs:comment 'The lot or batch number assigned by the supplier for received raw materials or finished goods. Used for traceability back to the supplier in case of quality issues or recalls.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityCode rdf:type rdf:Property ;
    rdfs:label 'Traceability Code' ;
    rdfs:comment 'A unique code used for end-to-end supply chain traceability of this lot or batch. May be a GS1 Global Trade Item Number (GTIN) with batch extension or similar standard.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkNodeId rdf:type rdf:Property ;
    rdfs:label 'Network Node Id' ;
    rdfs:comment 'Foreign key linking to supply.network_node. Business justification: WAREHOUSE MANAGEMENT: each storage location is physically part of a supply network node; required for location-level inventory reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC analysis classification for the location based on inventory velocity and value. A for high-velocity/high-value, B for medium, C for low-velocity/low-value items. Used for slotting optimization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisle rdf:type rdf:Property ;
    rdfs:label 'Aisle' ;
    rdfs:comment 'Aisle designation within the warehouse layout for physical navigation and location addressing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bay rdf:type rdf:Property ;
    rdfs:label 'Bay' ;
    rdfs:comment 'Bay or section identifier within an aisle, representing a vertical or horizontal subdivision of storage space.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bin rdf:type rdf:Property ;
    rdfs:label 'Bin' ;
    rdfs:comment 'Bin or slot identifier representing the smallest addressable storage unit within a level, used for item-level location precision.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedDate rdf:type rdf:Property ;
    rdfs:label 'Blocked Date' ;
    rdfs:comment 'Date when the location was blocked or made unavailable for inventory placement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockedReason rdf:type rdf:Property ;
    rdfs:label 'Blocked Reason' ;
    rdfs:comment 'Explanation for why the location is blocked or unavailable, used for operational troubleshooting and compliance documentation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Capacity Pallet Positions' ;
    rdfs:comment 'Number of standard pallet positions that can be stored in this location, used for pallet-based inventory planning.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Capacity Volume M3' ;
    rdfs:comment 'Maximum volumetric capacity of the storage location in cubic meters, used for space utilization optimization.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Capacity Weight Kg' ;
    rdfs:comment 'Maximum weight capacity of the storage location in kilograms, used for load planning and safety compliance.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossDockFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Flag' ;
    rdfs:comment 'Indicates whether this location is designated for cross-docking operations where goods move directly from receiving to shipping without long-term storage.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the storage location is certified and equipped for storing hazardous materials per regulatory requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryStorageLocationLevel rdf:type rdf:Property ;
    rdfs:label 'Inventory Storage Location Level' ;
    rdfs:comment 'Vertical level or shelf position within a bay, used for precise location addressing in multi-tier racking systems.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInventoryCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Inventory Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or cycle count performed at this location, used for inventory accuracy tracking.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'Timestamp of the most recent inventory movement (putaway, pick, transfer) at this location, used for activity analysis and slotting optimization.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Business identifier for the storage location used across warehouse management and inventory systems. Unique alphanumeric code assigned to each physical or logical storage position.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name or description of the storage location for operational reference and reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational status of the storage location. Active for normal operations, blocked for temporary holds, maintenance for repairs, quarantine for quality issues, inactive for unused space, decommissioned for permanently retired locations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the storage location based on its operational purpose within the warehouse. Bulk storage for palletized goods, pick locations for order fulfillment, reserve for overflow, quarantine for quality hold, returns for reverse logistics, and staging for in-transit goods.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mixedSkuAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Mixed Sku Allowed Flag' ;
    rdfs:comment 'Indicates whether the location permits storage of multiple SKUs simultaneously or requires single-SKU dedication for inventory accuracy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickingPriority rdf:type rdf:Property ;
    rdfs:label 'Picking Priority' ;
    rdfs:comment 'Numeric priority ranking for order picking optimization. Lower numbers indicate higher priority for fast-moving SKUs and efficient pick path planning.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replenishmentTriggerThreshold rdf:type rdf:Property ;
    rdfs:label 'Replenishment Trigger Threshold' ;
    rdfs:comment 'Percentage threshold that triggers automatic replenishment from reserve to pick locations. Used in Vendor Managed Inventory (VMI) and automated replenishment processes.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rotationRule rdf:type rdf:Property ;
    rdfs:label 'Rotation Rule' ;
    rdfs:comment 'Inventory rotation policy applied to this location. FEFO (First Expired First Out) for perishables, FIFO (First In First Out) for standard goods, LIFO (Last In First Out) for specific scenarios, or MANUAL for operator-controlled picking.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Security classification of the storage location based on access controls and monitoring requirements. High-value for premium products, controlled substance for regulated materials, restricted for limited access areas.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Temperature control classification for the storage location. Ambient for room temperature, refrigerated for 2-8°C, frozen for below 0°C, and controlled for specific temperature ranges required by product specifications.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'WMS zone identifier used for warehouse layout management, picking optimization, and labor allocation. Zones group locations by operational characteristics or product categories.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignFlightId rdf:type rdf:Property ;
    rdfs:label 'Campaign Flight Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign_flight. Business justification: Logistics teams track stock movements tied to specific campaign flights to measure promotional material delivery and OTIF performance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CampaignFlight .

ind:destinationLocationInventoryStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Inventory Storage Location Id' ;
    rdfs:comment 'Warehouse, plant, or storage location to which inventory is being moved. Null for goods issues to external destinations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryStorageLocation .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to procurement.goods_receipt. Business justification: GR-triggered stock movements (movement type 101) must be traceable to the originating goods receipt for three-way match validation, inventory audit trails, and GR reversal reconciliation. Existing pur' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:inventoryReplenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Inventory Replenishment Order Id' ;
    rdfs:comment 'Foreign key linking to inventory.inventory_replenishment_order. Business justification: A replenishment order generates one or more stock movements (goods receipts, transfer postings). Linking stock_movement to inventory_replenishment_order enables end-to-end replenishment traceability: ' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryReplenishmentOrder .

ind:primaryStockInventoryStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Inventory Storage Location Id' ;
    rdfs:comment 'Warehouse, plant, or storage location from which inventory is being moved. Null for goods receipts from external sources.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryStorageLocation .

ind:reversedMovementStockMovementId rdf:type rdf:Property ;
    rdfs:label 'Reversed Movement Stock Movement Id' ;
    rdfs:comment 'Reference to the original stock movement record that this transaction reverses or cancels.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockMovement .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'Date on the source document (purchase order, production order, delivery note) that triggered this movement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Document Number' ;
    rdfs:comment 'SAP material document number generated for this goods movement. Unique identifier in the source ERP system.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Material Document Year' ;
    rdfs:comment 'Fiscal year of the material document for SAP document key uniqueness.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementCategory rdf:type rdf:Property ;
    rdfs:label 'Movement Category' ;
    rdfs:comment 'High-level classification of the movement event for reporting and analytics purposes.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementNotes rdf:type rdf:Property ;
    rdfs:label 'Movement Notes' ;
    rdfs:comment 'Free-text notes or comments providing additional context about the stock movement event.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Timestamp' ;
    rdfs:comment 'Precise date and time when the physical inventory movement occurred or was recorded in the system.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementTypeCode rdf:type rdf:Property ;
    rdfs:label 'Movement Type Code' ;
    rdfs:comment 'SAP movement type code identifying the nature of the inventory transaction (e.g., 101=Goods Receipt from PO, 261=Goods Issue to Production, 311=Stock Transfer, 551=Scrapping, 601=Goods Receipt from Delivery).' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Code explaining the business reason for the movement (e.g., quality issue, damage, expiration, customer return, production scrap).' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentLine rdf:type rdf:Property ;
    rdfs:label 'Reference Document Line' ;
    rdfs:comment 'Line item number within the reference document that corresponds to this stock movement.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'Document number of the source transaction (PO number, production order number, delivery note number) that triggered this movement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of source document that initiated this stock movement for audit trail and reconciliation. [ENUM-REF-CANDIDATE: purchase_order|production_order|sales_order|delivery_note|transfer_order|return_order|adjustment_document — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this movement is a reversal or cancellation of a previous stock movement transaction.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryInventoryStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Storage Location Id' ;
    rdfs:comment 'Identifier of the warehouse, distribution center, or manufacturing facility from which inventory will be shipped to fulfill this replenishment order.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryStorageLocation .

ind:approvedQuantity rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity' ;
    rdfs:comment 'Quantity of the SKU approved for fulfillment after review and Available to Promise (ATP) validation. May differ from requested quantity due to supply constraints.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the freight cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosPreventionFlag rdf:type rdf:Property ;
    rdfs:label 'Oos Prevention Flag' ;
    rdfs:comment 'Indicates whether this replenishment order was created to prevent an anticipated Out of Stock (OOS) event based on demand forecasting.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Approval Timestamp' ;
    rdfs:comment 'Date and time when the replenishment order was approved for fulfillment by the supply chain planner or automated approval workflow.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderCancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the replenishment order was cancelled, if applicable. Null for active orders.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderCreationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Creation Timestamp' ;
    rdfs:comment 'Date and time when the replenishment order was first created in the system, either automatically by planning algorithms or manually by a planner.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text field for planners to capture special instructions, handling requirements, or contextual information about the replenishment order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual quantity received and confirmed at the destination location. May differ from shipped quantity due to damage or discrepancies.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Number' ;
    rdfs:comment 'Business-facing unique identifier for the replenishment order, used for tracking and communication across systems and stakeholders.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentType rdf:type rdf:Property ;
    rdfs:label 'Replenishment Type' ;
    rdfs:comment 'Classification of the replenishment order generation method: Vendor Managed Inventory (VMI) auto-replenishment, Distribution Requirements Planning (DRP) planned order, manual trigger by planner, safety stock replenishment, emergency order, or seasonal build.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'Quantity of the SKU requested for replenishment, as calculated by the demand planning system or entered by the planner.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Trigger Flag' ;
    rdfs:comment 'Indicates whether this replenishment order was triggered by inventory falling below the safety stock threshold at the destination location.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledShipDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Ship Date' ;
    rdfs:comment 'Planned date for shipment departure from the source location, calculated based on lead time and requested delivery date.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking number for the shipment associated with this replenishment order. Used for in-transit visibility.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryCycleCountId rdf:type rdf:Property ;
    rdfs:label 'Inventory Cycle Count Id' ;
    rdfs:comment 'Unique identifier for the inventory cycle count event. Primary key for the cycle count record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryCycleCount .

ind:originalCountInventoryCycleCountId rdf:type rdf:Property ;
    rdfs:label 'Original Count Inventory Cycle Count Id' ;
    rdfs:comment 'If this is a recount, references the inventory_cycle_count_id of the original count that triggered the recount requirement. Null for initial counts.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryCycleCount .

ind:stockAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Stock Adjustment Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_adjustment. Business justification: A cycle count variance triggers a stock adjustment to correct the inventory balance. The existing adjustment_document_number STRING column is a denormalized reference to the resulting adjustment; repl' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockAdjustment .

ind:adjustmentPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted Flag' ;
    rdfs:comment 'Indicates whether the variance has been posted as an inventory adjustment in the ERP (Enterprise Resource Planning) system. True = adjustment posted, False = pending posting.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the cycle count was approved by the authorized supervisor. Part of the audit trail for inventory adjustments.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:comment 'The calendar date on which the physical cycle count was performed.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'The methodology used for the cycle count. Full physical = complete inventory audit, ABC cycle = frequency-based counting by value classification, perpetual = continuous counting, spot check = random verification, blind count = counter does not see system quantity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the cycle count event. Planned = scheduled but not started, in_progress = counting underway, confirmed = count verified, posted = variance adjusted in system, cancelled = count voided, recount_required = variance exceeds threshold.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Timestamp' ;
    rdfs:comment 'Precise date and time when the cycle count was executed. Used for audit trail and WMS (Warehouse Management System) reconciliation.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countZone rdf:type rdf:Property ;
    rdfs:label 'Count Zone' ;
    rdfs:comment 'The warehouse zone or area designation where the count took place (e.g., receiving, picking, reserve, quarantine). Used for zone-based cycle count scheduling.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'The actual physical quantity counted by the warehouse associate during the cycle count event. Measured in the SKU\'s unit of measure.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryValueAtCount rdf:type rdf:Property ;
    rdfs:label 'Inventory Value At Count' ;
    rdfs:comment 'The total monetary value of the counted inventory based on the counted quantity and the unit cost at the time of count. Used for financial reconciliation and shrinkage cost calculation.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recountFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Flag' ;
    rdfs:comment 'Indicates whether this cycle count is a recount of a previous count that exceeded variance thresholds. True = recount, False = initial count.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemQuantity rdf:type rdf:Property ;
    rdfs:label 'System Quantity' ;
    rdfs:comment 'The quantity recorded in the WMS (Warehouse Management System) or ERP (Enterprise Resource Planning) system at the time of the count. Used to calculate variance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether the counted inventory is stored in a temperature-controlled environment. True = cold chain storage, False = ambient. Relevant for perishable consumer goods.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceNotes rdf:type rdf:Property ;
    rdfs:label 'Variance Notes' ;
    rdfs:comment 'Free-text explanation or additional context provided by the counter or approver regarding the variance. Used for investigation and documentation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The variance expressed as a percentage of the system quantity. Calculated as (variance_quantity / system_quantity) * 100. Used to trigger investigation thresholds.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'The difference between counted quantity and system quantity (counted minus system). Positive values indicate overage, negative values indicate shortage.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceValue rdf:type rdf:Property ;
    rdfs:label 'Variance Value' ;
    rdfs:comment 'The monetary value of the variance (variance_quantity * unit_cost). Represents the financial impact of the inventory discrepancy. Used for shrinkage reporting and P&L (Profit and Loss) impact analysis.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oosEventId rdf:type rdf:Property ;
    rdfs:label 'Oos Event Id' ;
    rdfs:comment 'Unique identifier for the out-of-stock event record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OosEvent .

ind:previousOosEventId rdf:type rdf:Property ;
    rdfs:label 'Previous Oos Event Id' ;
    rdfs:comment 'Reference to the previous OOS event ID for the same SKU-location if this is a recurrence, enabling trend analysis.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OosEvent .

ind:actualDemandUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Demand Units' ;
    rdfs:comment 'Actual observed demand in units during the OOS event period, used to identify demand spikes or forecast misses.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Distribution channel type where the OOS event occurred: retail, wholesale, e-commerce, DSD (Direct Store Delivery), or DTC (Direct to Consumer).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Description of the corrective action plan implemented to prevent recurrence of similar OOS events in the future.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Flag' ;
    rdfs:comment 'Boolean flag indicating whether the OOS event resulted in direct customer impact such as lost sales, customer complaints, or service level breaches.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demandForecastUnits rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Units' ;
    rdfs:comment 'Forecasted demand in units for the period during which the OOS event occurred, used to compare actual vs. planned demand.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'System or channel that detected and reported the out-of-stock event, such as POS system, WMS, demand sensing platform, manual report, retail execution app, or EDI feed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLostSalesValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Lost Sales Value' ;
    rdfs:comment 'Estimated monetary value of sales lost due to the out-of-stock condition, calculated based on historical demand patterns and average selling price.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLostUnits rdf:type rdf:Property ;
    rdfs:label 'Estimated Lost Units' ;
    rdfs:comment 'Estimated quantity of units that could not be sold due to the out-of-stock condition.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAccuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Percent' ;
    rdfs:comment 'Forecast accuracy percentage for the SKU-location during the period of the OOS event, calculated as (1 - |actual - forecast| / actual) * 100.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactSeverity rdf:type rdf:Property ;
    rdfs:label 'Impact Severity' ;
    rdfs:comment 'Severity classification of the OOS event impact based on lost sales value, SKU importance, and customer impact. Categories: critical, high, medium, low.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryOnHandAtOos rdf:type rdf:Property ;
    rdfs:label 'Inventory On Hand At Oos' ;
    rdfs:comment 'System-recorded inventory quantity on hand at the time the OOS event was detected, used to identify phantom inventory situations.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReplenishmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Replenishment Date' ;
    rdfs:comment 'Date of the most recent replenishment delivery prior to the OOS event, used to analyze replenishment frequency adequacy.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledReplenishmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Replenishment Date' ;
    rdfs:comment 'Date of the next scheduled replenishment delivery at the time of the OOS event, used to assess replenishment planning gaps.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oosDurationHours rdf:type rdf:Property ;
    rdfs:label 'Oos Duration Hours' ;
    rdfs:comment 'Total duration of the out-of-stock event measured in hours, calculated as the difference between end and start timestamps.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oosEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Oos End Timestamp' ;
    rdfs:comment 'Timestamp when the out-of-stock condition was resolved and inventory became available again.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:oosStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Oos Start Timestamp' ;
    rdfs:comment 'Timestamp when the out-of-stock condition was first detected. Sourced from POS data feeds or demand sensing signals.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:oosType rdf:type rdf:Property ;
    rdfs:label 'Oos Type' ;
    rdfs:comment 'Classification of the OOS event type: warehouse stockout (no inventory in facility), shelf stockout (inventory in back room but not on shelf), phantom inventory (system shows stock but physical count is zero), or system mismatch.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osaActualPercent rdf:type rdf:Property ;
    rdfs:label 'Osa Actual Percent' ;
    rdfs:comment 'Actual on-shelf availability percentage achieved during the period including the OOS event, calculated from POS and inventory data.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:osaTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Osa Target Percent' ;
    rdfs:comment 'Target on-shelf availability percentage for the SKU-location at the time of the OOS event, used to measure performance against goals.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Boolean flag indicating whether this OOS event is a recurrence of a previous OOS event for the same SKU-location combination within a defined time window.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Configured reorder point threshold for the SKU at this location, used to evaluate whether replenishment triggers were properly set.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Action taken to resolve the out-of-stock event, such as emergency replenishment, transfer from alternate location, expedited shipment, customer backorder, substitution offered, or no action taken.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Primary root cause classification for the OOS event. Categories include demand spike, replenishment failure, forecast miss, upstream stockout, logistics delay, or system error.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaId rdf:type rdf:Property ;
    rdfs:label 'Capa Id' ;
    rdfs:comment 'Foreign key linking to quality.capa. Business justification: Every consumer goods recall requires a CAPA to address root cause and prevent recurrence. Linking recall_event to capa_id enables recall CAPA management, regulatory submission tracking, and effectiven' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capa .

ind:affectedGtinList rdf:type rdf:Property ;
    rdfs:label 'Affected Gtin List' ;
    rdfs:comment 'Comma-separated list of GTIN/UPC/EAN codes for recalled products. Enables point-of-sale blocking and supply chain traceability across trading partners using GS1 standards.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductDescription rdf:type rdf:Property ;
    rdfs:label 'Affected Product Description' ;
    rdfs:comment 'Comprehensive description of the product(s) subject to recall, including brand names, product names, sizes, formulations, and any distinguishing characteristics. Used for consumer identification.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSkuList rdf:type rdf:Property ;
    rdfs:label 'Affected Sku List' ;
    rdfs:comment 'Comma-separated or structured list of SKU codes for all products included in the recall scope. Links to product master for detailed SKU attributes and enables inventory queries.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date when the regulatory authority officially closed the recall after reviewing effectiveness checks and final reports. Nullable until regulatory closure is granted.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date when all recall activities were completed, including product recovery, customer notification, and corrective actions. Nullable until recall is finished.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consumerContactMethod rdf:type rdf:Property ;
    rdfs:label 'Consumer Contact Method' ;
    rdfs:comment 'Primary method(s) used to notify consumers about the recall. Press Release: public media announcement. Direct Mail: letters to registered consumers. Email: electronic notification. Phone: direct phone contact. Social Media: notification via social platforms. Retail Signage: point-of-sale notices. Multiple Methods: combination approach. [ENUM-REF-CANDIDATE: Press Release|Direct Mail|Email|Phone|Social Media|Retail Signage|Multiple Methods — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Description of corrective and preventive actions (CAPA) implemented to address the root cause and prevent recurrence. Includes process changes, equipment modifications, supplier changes, and quality system improvements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depthOfRecall rdf:type rdf:Property ;
    rdfs:label 'Depth Of Recall' ;
    rdfs:comment 'Level in the distribution chain to which the recall extends. Consumer Level: recall reaches end consumers. Retail Level: recall stops at retail stores. Wholesale Level: recall stops at wholesalers/distributors. Distribution Center: recall stops at company distribution centers before reaching trade.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFinancialImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact' ;
    rdfs:comment 'Estimated total financial impact of the recall including product cost, logistics, customer credits, disposal, regulatory fines, and brand impact. Expressed in reporting currency. Used for financial reserves and management reporting.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationDateRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Expiration Date Range End' ;
    rdfs:comment 'Latest expiration or best-by date printed on recalled products. Defines the full date range for consumer identification.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationDateRangeStart rdf:type rdf:Property ;
    rdfs:label 'Expiration Date Range Start' ;
    rdfs:comment 'Earliest expiration or best-by date printed on recalled products. Helps consumers and retailers identify affected units on shelf.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:healthHazardEvaluation rdf:type rdf:Property ;
    rdfs:label 'Health Hazard Evaluation' ;
    rdfs:comment 'FDA or internal assessment of the health risk posed by the recalled product. Describes potential adverse health consequences and likelihood of occurrence. Used to determine recall classification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiationDate rdf:type rdf:Property ;
    rdfs:label 'Initiation Date' ;
    rdfs:comment 'Date when the recall was officially initiated by the company. This is the business event date when the decision to recall was made and communicated internally.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingDateRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date Range End' ;
    rdfs:comment 'Latest manufacturing date of products included in the recall scope. Defines the cutoff for affected production runs.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingDateRangeStart rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date Range Start' ;
    rdfs:comment 'Earliest manufacturing date of products included in the recall scope. Used to identify affected inventory based on production timeline.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date when the regulatory authority (FDA, CPSC, EPA, or other governing body) was formally notified of the recall event. Required for compliance reporting.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicAnnouncementDate rdf:type rdf:Property ;
    rdfs:label 'Public Announcement Date' ;
    rdfs:comment 'Date when the recall was publicly announced through press release, FDA website posting, or other public communication channels.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityDistributed rdf:type rdf:Property ;
    rdfs:label 'Quantity Distributed' ;
    rdfs:comment 'Total quantity of affected product that was distributed into the market prior to recall initiation. Expressed in base unit of measure (units, cases, kilograms). Represents the maximum potential recall scope.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRecalled rdf:type rdf:Property ;
    rdfs:label 'Quantity Recalled' ;
    rdfs:comment 'Total quantity of product subject to the recall action. May differ from quantity distributed if recall scope is narrowed to specific lots, channels, or geographies.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRecovered rdf:type rdf:Property ;
    rdfs:label 'Quantity Recovered' ;
    rdfs:comment 'Actual quantity of recalled product recovered from the market through returns, destructions, and corrections. Updated throughout recall lifecycle. Used to calculate recall effectiveness percentage.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for all quantity fields in this recall record. Ensures consistent interpretation of distributed, recalled, and recovered quantities.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the specific defect, contamination, safety issue, or regulatory violation that triggered the recall. Includes root cause findings and quality investigation summary.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallClassification rdf:type rdf:Property ;
    rdfs:label 'Recall Classification' ;
    rdfs:comment 'FDA or regulatory classification of the recall severity. Class I: dangerous or defective products that could cause serious health problems or death. Class II: products that might cause temporary health problem or pose slight threat of serious nature. Class III: products unlikely to cause adverse health reaction but violate FDA labeling or manufacturing regulations. Voluntary Withdrawal: firm removes product from market not required by FDA. Market Withdrawal: minor violation not subject to legal action. Stock Recovery: correction of product still in distribution chain.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallEffectivenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Recall Effectiveness Percentage' ;
    rdfs:comment 'Calculated percentage of recalled product successfully recovered from the market. Formula: (quantity_recovered / quantity_recalled) * 100. FDA expects effectiveness checks at 2, 4, and 8 weeks. High effectiveness (>95%) supports recall closure.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Number' ;
    rdfs:comment 'External recall identification number assigned by the company or regulatory authority for tracking and communication purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallScopeChannel rdf:type rdf:Property ;
    rdfs:label 'Recall Scope Channel' ;
    rdfs:comment 'Distribution channel(s) affected by the recall. Retail: products sold through retail stores. Wholesale: products in wholesale/distributor inventory. DTC: direct-to-consumer shipments. Food Service: products sold to restaurants/institutions. Healthcare: products distributed to healthcare facilities. All Channels: recall spans all distribution paths.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallScopeCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Recall Scope Customer Segment' ;
    rdfs:comment 'Specific customer segments, account types, or customer groups affected by the recall. Used for targeted notification and recovery when recall does not affect all customers.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallStatus rdf:type rdf:Property ;
    rdfs:label 'Recall Status' ;
    rdfs:comment 'Current lifecycle status of the recall event. Initiated: recall has been declared and communication started. In Progress: active recovery and customer notification underway. Ongoing: recall activities continuing. Completed: all recall activities finished, awaiting final regulatory closure. Terminated: recall ended by firm decision. Closed: regulatory authority has reviewed and closed the recall.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallStrategy rdf:type rdf:Property ;
    rdfs:label 'Recall Strategy' ;
    rdfs:comment 'Documented strategy for executing the recall including communication plan, recovery method, depth of recall (consumer level, retail level, wholesale level), and timeline. Required by FDA 21 CFR 7.42.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallType rdf:type rdf:Property ;
    rdfs:label 'Recall Type' ;
    rdfs:comment 'Primary reason category for the recall event. Safety: product poses health or safety risk. Quality: product fails quality specifications. Regulatory: non-compliance with regulations. Labeling: incorrect or missing label information. Contamination: presence of foreign material or microbial contamination. Allergen: undeclared allergen present.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Primary regulatory authority overseeing this recall. FDA: U.S. Food and Drug Administration. CPSC: Consumer Product Safety Commission. EPA: Environmental Protection Agency. EU REACH: European chemicals regulation. Health Canada: Canadian health authority. ANVISA: Brazilian health authority. TGA: Australian Therapeutic Goods Administration. MHRA: UK Medicines and Healthcare products Regulatory Agency. [ENUM-REF-CANDIDATE: FDA|CPSC|EPA|EU REACH|Health Canada|ANVISA|TGA|MHRA|Other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Case Number' ;
    rdfs:comment 'Official case or reference number assigned by the regulatory authority for tracking this recall in their system. Used for all regulatory correspondence and reporting.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysisSummary rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Summary' ;
    rdfs:comment 'Summary of the root cause investigation findings including failure mode, contributing factors, and systemic issues identified. Supports CAPA and regulatory reporting.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Compliance Assessment Id' ;
    rdfs:comment 'Foreign key linking to regulatory.compliance_assessment. Business justification: GMP-mandated stock adjustments (destruction of non-compliant batches, quarantine write-offs) are directly triggered by compliance assessment findings. Quality and regulatory teams require this FK to t' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceAssessment .

ind:reversedAdjustmentStockAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Reversed Adjustment Stock Adjustment Id' ;
    rdfs:comment 'Reference to the original adjustment transaction that this record reverses, establishing the correction chain for audit purposes.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockAdjustment .

ind:adjustedQuantity rdf:type rdf:Property ;
    rdfs:label 'Adjusted Quantity' ;
    rdfs:comment 'Net quantity change applied to inventory (positive for additions, negative for reductions), measured in the base unit of measure.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedValue rdf:type rdf:Property ;
    rdfs:label 'Adjusted Value' ;
    rdfs:comment 'Total financial value of the inventory adjustment calculated as adjusted quantity multiplied by unit cost, impacting Cost of Goods Sold (COGS) and inventory valuation.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Adjustment Date' ;
    rdfs:comment 'Business date when the inventory adjustment was physically identified or when the correction event occurred, distinct from system posting date.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Business-facing unique adjustment document number used for tracking and reference in operational systems and audit trails.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Description' ;
    rdfs:comment 'Detailed textual explanation of why the inventory adjustment was necessary, providing business context beyond the reason code.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle status of the adjustment transaction indicating its approval and posting state in the inventory ledger.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'Precise date and time when the adjustment transaction was created or recorded in the system.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the adjustment transaction indicating the nature of the inventory correction (physical count variance, shrinkage, damage, expiry, system reconciliation, theft).' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP movement type code classifying the inventory transaction for goods movement and financial posting (e.g., 701 for goods issue, 702 for goods receipt).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalCountQuantity rdf:type rdf:Property ;
    rdfs:label 'Physical Count Quantity' ;
    rdfs:comment 'Actual physical quantity counted during inventory verification, used to calculate the adjustment variance for cycle counts and physical inventories.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systemQuantityAfter rdf:type rdf:Property ;
    rdfs:label 'System Quantity After' ;
    rdfs:comment 'Resulting inventory quantity in the system after the adjustment has been posted, representing the corrected stock balance.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systemQuantityBefore rdf:type rdf:Property ;
    rdfs:label 'System Quantity Before' ;
    rdfs:comment 'Inventory quantity recorded in the system before the adjustment was applied, used for variance analysis and audit trails.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Consumer Segment Id' ;
    rdfs:comment 'Foreign key linking to marketing.consumer_segment. Business justification: Consumer goods companies map trade accounts to consumer segments for JBP (Joint Business Planning) and shopper marketing investment allocation. A key account manager expects to know which consumer seg' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsumerSegment .

ind:accountCloseDate rdf:type rdf:Property ;
    rdfs:label 'Account Close Date' ;
    rdfs:comment 'The date when this trade account was permanently closed or terminated, if applicable.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountOpenDate rdf:type rdf:Property ;
    rdfs:label 'Account Open Date' ;
    rdfs:comment 'The date when this trade account was first established and approved for business transactions.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Strategic tier classification based on account size, coverage, and business importance: Tier 1 (national key accounts), Tier 2 (regional chains), Tier 3 (local/metro accounts), Tier 4 (independent operators).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acvTotal rdf:type rdf:Property ;
    rdfs:label 'Acv Total' ;
    rdfs:comment 'The total All Commodity Volume representing the annual dollar sales volume across all product categories for this retail account, used for market coverage analysis.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'The maximum outstanding accounts receivable balance allowed for this trade account before credit hold is applied.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'The credit risk rating assigned to this trade account by internal credit management or external credit bureau (e.g., AAA, AA, A, BBB, BB, B, CCC, D).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'The trade name or DBA name under which the account operates in the market, if different from legal entity name.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Delivery Flag' ;
    rdfs:comment 'Indicates whether this trade account receives direct store delivery (DSD) shipments bypassing the retailers distribution center.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capable Flag' ;
    rdfs:comment 'Indicates whether this trade account has EDI connectivity enabled for electronic exchange of purchase orders, invoices, and advance ship notices.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gln rdf:type rdf:Property ;
    rdfs:label 'Gln' ;
    rdfs:comment 'The 13-digit GS1 Global Location Number uniquely identifying the legal entity and physical location of the trade partner.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'The first line of the street address for the trade account headquarters or primary business location.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line2' ;
    rdfs:comment 'The second line of the street address (suite, floor, building) for the trade account headquarters.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'The city name of the trade account headquarters location.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'The 3-letter ISO 3166-1 alpha-3 country code for the trade account headquarters location (e.g., USA, CAN, MEX, GBR, DEU).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'The postal code or ZIP code of the trade account headquarters location.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'The state, province, or administrative region of the trade account headquarters location.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'The official registered legal name of the trade partner organization as it appears on legal documents and contracts.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifSlaTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Otif Sla Target Percent' ;
    rdfs:comment 'The contractual OTIF service level agreement target percentage for order fulfillment performance (e.g., 95.00 represents 95% of orders delivered on time and in full).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The account status immediately prior to the most recent status change, maintained for audit trail and lifecycle analysis.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Primary Language Code' ;
    rdfs:comment 'The 2-letter ISO 639-1 language code for the preferred communication language with this trade account (e.g., en, es, fr, de).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeReason rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason' ;
    rdfs:comment 'The business reason or justification for the most recent account status change (e.g., payment default, business closure, credit improvement, contract renewal).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Status Change Timestamp' ;
    rdfs:comment 'The date and time when the most recent account status change occurred.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:statusChangedByUser rdf:type rdf:Property ;
    rdfs:label 'Status Changed By User' ;
    rdfs:comment 'The user ID or name of the person who executed the most recent account status change, for audit and accountability purposes.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Flag' ;
    rdfs:comment 'Indicates whether this trade account holds a valid tax exemption certificate for sales tax or VAT purposes.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tdpCount rdf:type rdf:Property ;
    rdfs:label 'Tdp Count' ;
    rdfs:comment 'The total number of distribution points (store locations or outlets) operated by this trade account where products can be sold.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradeChannel rdf:type rdf:Property ;
    rdfs:label 'Trade Channel' ;
    rdfs:comment 'The primary retail or distribution channel through which this trade account operates: grocery (supermarkets), mass (mass merchandisers), club (warehouse clubs), drug (pharmacy chains), convenience stores, foodservice (restaurants/institutions), or e-commerce (online retailers). [ENUM-REF-CANDIDATE: grocery|mass|club|drug|convenience|foodservice|e-commerce — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Enabled Flag' ;
    rdfs:comment 'Indicates whether this trade account participates in a VMI program where the supplier manages inventory replenishment based on POS or warehouse data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique identifier for the account hierarchy relationship record. Primary key.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAccountTradeAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Trade Account Id' ;
    rdfs:comment 'Identifier of the child account in the hierarchy. References the lower-level organizational entity (e.g., store, banner, chain).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAccount .

ind:primaryTradeAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Trade Account Id' ;
    rdfs:comment 'Identifier of the parent account in the hierarchy. References the higher-level organizational entity (e.g., banner, chain, parent corporation).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAccount .

ind:acvRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Acv Rollup Flag' ;
    rdfs:comment 'Indicates whether All Commodity Volume (ACV) metrics should be rolled up from child to parent account. True means include in ACV aggregation; false means exclude. Critical for market coverage and distribution analysis.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Flag' ;
    rdfs:comment 'Indicates whether financial and operational metrics from the child account should be consolidated into the parent account for reporting purposes. True means consolidate; false means report separately. Critical for All Commodity Volume (ACV), Total Distribution Points (TDP), trade spend, and sales performance roll-ups.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyDepth rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Depth' ;
    rdfs:comment 'Numeric depth of the child account within the hierarchy tree, with 1 representing the top level (parent corporation) and increasing numbers representing deeper levels (chain, banner, store). Used for recursive queries and hierarchy traversal.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path representing the full lineage from root to child account, typically formatted as slash-separated account identifiers (e.g., /1/23/456/7890). Enables efficient ancestor and descendant queries for Sales and Operations Planning (S&OP) and Trade Promotion Management (TPM) reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Type of organizational hierarchy relationship. Commercial hierarchies support sales and trade promotion roll-ups; logistics hierarchies support distribution and delivery planning; financial hierarchies support invoicing and payment consolidation; reporting hierarchies support management reporting structures; legal hierarchies represent corporate ownership; operational hierarchies support day-to-day execution.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of ownership or control the parent account has over the child account. Used for proportional consolidation in financial and operational reporting. Range 0.00 to 100.00.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryHierarchyFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Hierarchy Flag' ;
    rdfs:comment 'Indicates whether this is the primary hierarchical relationship for the child account when multiple hierarchy types exist. True means this is the default hierarchy for reporting and analytics; false means this is a secondary or alternate hierarchy.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipCode rdf:type rdf:Property ;
    rdfs:label 'Relationship Code' ;
    rdfs:comment 'Business code or identifier representing the nature of the parent-child relationship. May include codes for wholly-owned subsidiary, franchise, joint venture, affiliate, or other relationship types specific to the consumer goods trade channel.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipName rdf:type rdf:Property ;
    rdfs:label 'Relationship Name' ;
    rdfs:comment 'Human-readable name or description of the hierarchical relationship. Provides business context for the parent-child linkage (e.g., Regional Banner Group, Corporate Ownership, Distribution Network).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current status of the hierarchical relationship. Active indicates the relationship is currently in effect; inactive indicates the relationship has ended; pending indicates the relationship is awaiting activation; suspended indicates the relationship is temporarily paused; terminated indicates the relationship has been permanently ended.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollupWeight rdf:type rdf:Property ;
    rdfs:label 'Rollup Weight' ;
    rdfs:comment 'Weighting factor applied when rolling up metrics from child to parent account. Used for proportional allocation of All Commodity Volume (ACV), Total Distribution Points (TDP), trade spend, and sales performance when a child account participates in multiple hierarchies or has split ownership.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Sales Rollup Flag' ;
    rdfs:comment 'Indicates whether sales performance metrics should be rolled up from child to parent account. True means include in sales aggregation; false means exclude. Essential for Sales and Operations Planning (S&OP) and Integrated Business Planning (IBP).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tdpRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Tdp Rollup Flag' ;
    rdfs:comment 'Indicates whether Total Distribution Points (TDP) metrics should be rolled up from child to parent account. True means include in TDP aggregation; false means exclude. Essential for numeric distribution and weighted distribution reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeSpendRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Trade Spend Rollup Flag' ;
    rdfs:comment 'Indicates whether trade promotion spending should be rolled up from child to parent account. True means include in trade spend aggregation; false means exclude. Critical for Trade Promotion Management (TPM) and Trade Promotion Optimization (TPO) reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierSiteId rdf:type rdf:Property ;
    rdfs:label 'Supplier Site Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_site. Business justification: Store-level VMI or direct replenishment ties a retail store to the exact supplier site that ships inventory, needed for logistics and OTIF tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierSite .

ind:acvWeight rdf:type rdf:Property ;
    rdfs:label 'Acv Weight' ;
    rdfs:comment 'All Commodity Volume (ACV) weighting factor representing this stores share of total market volume, used for distribution and market share calculations.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bannerName rdf:type rdf:Property ;
    rdfs:label 'Banner Name' ;
    rdfs:comment 'The retail banner or brand under which this store operates (e.g., Walmart Supercenter, Target, Kroger).' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Date when the store permanently closed or is scheduled to close. Null if store is active.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dsdRouteCode rdf:type rdf:Property ;
    rdfs:label 'Dsd Route Code' ;
    rdfs:comment 'Route code or identifier for Direct Store Delivery (DSD) logistics and delivery scheduling.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Visit Date' ;
    rdfs:comment 'Date of the most recent retail execution visit or sales call to this store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledVisitDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Visit Date' ;
    rdfs:comment 'Date of the next planned retail execution visit or sales call to this store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Date when the store first opened for business operations.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for the store (e.g., Mon-Fri 8am-10pm, Sat-Sun 9am-9pm) used for retail execution visit planning.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osaTargetPct rdf:type rdf:Property ;
    rdfs:label 'Osa Target Pct' ;
    rdfs:comment 'Target On Shelf Availability (OSA) percentage for this store indicating expected in-stock performance for key Stock Keeping Units (SKUs).' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifSlaTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otif Sla Target Pct' ;
    rdfs:comment 'Target On Time In Full (OTIF) service level percentage agreed with this store for delivery performance measurement.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planogramZone rdf:type rdf:Property ;
    rdfs:label 'Planogram Zone' ;
    rdfs:comment 'Planogram zone or cluster assignment indicating which shelf layout and assortment plan applies to this store.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posSystemType rdf:type rdf:Property ;
    rdfs:label 'Pos System Type' ;
    rdfs:comment 'Type or vendor of the Point of Sale (POS) system used at this store for transaction processing and sales data capture.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeFormat rdf:type rdf:Property ;
    rdfs:label 'Store Format' ;
    rdfs:comment 'The retail format classification of the store indicating size, assortment, and operational model. [ENUM-REF-CANDIDATE: hypermarket|supermarket|convenience|club|drug|dollar|specialty|e-commerce_fulfillment_center — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeName rdf:type rdf:Property ;
    rdfs:label 'Store Name' ;
    rdfs:comment 'The official name or designation of the retail store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeNumber rdf:type rdf:Property ;
    rdfs:label 'Store Number' ;
    rdfs:comment 'The retailer-assigned unique store number or code used for operational identification and Direct Store Delivery (DSD) routing.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storePhone rdf:type rdf:Property ;
    rdfs:label 'Store Phone' ;
    rdfs:comment 'Primary contact phone number for the retail store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeSizeSqFt rdf:type rdf:Property ;
    rdfs:label 'Store Size Sq Ft' ;
    rdfs:comment 'Total retail selling space of the store measured in square feet, used for All Commodity Volume (ACV) and Total Distribution Points (TDP) calculations.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storeStatus rdf:type rdf:Property ;
    rdfs:label 'Store Status' ;
    rdfs:comment 'Current operational status of the retail store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeTier rdf:type rdf:Property ;
    rdfs:label 'Store Tier' ;
    rdfs:comment 'Strategic tier classification (e.g., Tier 1, Tier 2) indicating store importance based on volume, profitability, or strategic value for prioritized retail execution.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdpWeight rdf:type rdf:Property ;
    rdfs:label 'Tdp Weight' ;
    rdfs:comment 'Total Distribution Points (TDP) weighting factor representing this stores contribution to numeric distribution metrics.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingArea rdf:type rdf:Property ;
    rdfs:label 'Trading Area' ;
    rdfs:comment 'Geographic trading area or market designation (e.g., metro area, region) used for sales territory and distribution planning.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSegmentId rdf:type rdf:Property ;
    rdfs:label 'Account Segment Id' ;
    rdfs:comment 'Unique identifier for the account segment record. Primary key.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this account segment assignment is currently active and in use for commercial operations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acvTier rdf:type rdf:Property ;
    rdfs:label 'Acv Tier' ;
    rdfs:comment 'Tier classification based on All Commodity Volume, representing the total retail sales volume of the account across all product categories.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegion rdf:type rdf:Property ;
    rdfs:label 'Applicable Region' ;
    rdfs:comment 'Geographic region where this segmentation applies (e.g., North America, EMEA, APAC, LATAM).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelTier rdf:type rdf:Property ;
    rdfs:label 'Channel Tier' ;
    rdfs:comment 'Hierarchical tier assignment within the channel, indicating relative importance or volume contribution (tier_1 = highest, tier_4 = lowest).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitTier rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Tier' ;
    rdfs:comment 'Credit limit tier classification for accounts in this segment, determining maximum outstanding receivables allowed.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerTier rdf:type rdf:Property ;
    rdfs:label 'Customer Tier' ;
    rdfs:comment 'Customer value tier assignment based on revenue, volume, or strategic importance (platinum = highest value, standard = baseline).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Eligible Flag' ;
    rdfs:comment 'Indicates whether the account is eligible for Direct Store Delivery, bypassing distribution centers for direct product delivery to retail locations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediTradingPartnerFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Trading Partner Flag' ;
    rdfs:comment 'Indicates whether the account is configured as an EDI trading partner for automated order and invoice exchange.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldSalesCallFrequency rdf:type rdf:Property ;
    rdfs:label 'Field Sales Call Frequency' ;
    rdfs:comment 'Recommended frequency of field sales representative visits based on account segment and strategic priority.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when this account segment assignment was last reviewed and validated by commercial leadership.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'Pricing strategy applicable to this account segment (EDLP = Everyday Low Price, Hi-Lo = High-Low promotional pricing).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryChannelCode rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Code' ;
    rdfs:comment 'Code representing the primary channel classification (e.g., RETAIL, FOODSERVICE, WHOLESALE, DTC).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryChannelName rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Name' ;
    rdfs:comment 'Full name of the primary channel (e.g., Retail, Foodservice, Wholesale, Direct to Consumer).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentAssignmentReason rdf:type rdf:Property ;
    rdfs:label 'Segment Assignment Reason' ;
    rdfs:comment 'Business rationale or trigger for this segment assignment (e.g., annual review, volume threshold met, strategic partnership established).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentationModelVersion rdf:type rdf:Property ;
    rdfs:label 'Segmentation Model Version' ;
    rdfs:comment 'Version identifier of the segmentation model or algorithm used to assign this segment (e.g., 2024.Q1, V3.2).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriorityFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Flag' ;
    rdfs:comment 'Indicates whether this account is designated as a strategic priority for executive engagement and resource allocation.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tdpTier rdf:type rdf:Property ;
    rdfs:label 'Tdp Tier' ;
    rdfs:comment 'Tier classification based on Total Distribution Points, representing the weighted distribution reach of the account.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradePromotionEligibility rdf:type rdf:Property ;
    rdfs:label 'Trade Promotion Eligibility' ;
    rdfs:comment 'Eligibility status for trade promotion programs and funding allocation based on segment classification.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Eligible Flag' ;
    rdfs:comment 'Indicates whether the account is eligible for Vendor Managed Inventory programs where the supplier manages inventory replenishment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Id' ;
    rdfs:comment 'Foreign key linking to sales.pricing_agreement. Business justification: Orders are governed by a pricing agreement; linking captures contract context.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingAgreement .

ind:salesRepId rdf:type rdf:Property ;
    rdfs:label 'Sales Rep Id' ;
    rdfs:comment 'Reference to the sales representative or account manager who created or owns this order. Used for commission calculation and SFA reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:cogsAmount rdf:type rdf:Property ;
    rdfs:label 'Cogs Amount' ;
    rdfs:comment 'Total cost of goods sold for all items on this order. Used for gross margin calculation and profitability analysis.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by supply chain and logistics based on ATP/CTP availability. Committed date for OTIF tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'The product division or business unit for this order. Used for divisional P&L reporting and product line segmentation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Freight and shipping charges applied to the order. May be customer-paid or supplier-absorbed depending on terms.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Amount' ;
    rdfs:comment 'Gross profit on the order calculated as total revenue less COGS. Key profitability metric for order-level margin analysis.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'Three-letter Incoterm code defining the transfer of risk and cost responsibility between buyer and seller. Examples: FOB, CIF, DDP.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSource rdf:type rdf:Property ;
    rdfs:label 'Order Source' ;
    rdfs:comment 'The system or channel through which the order was originally captured. Used for channel attribution and system integration tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifStatus rdf:type rdf:Property ;
    rdfs:label 'Otif Status' ;
    rdfs:comment 'Indicates whether the order was delivered on time and in full per customer commitment. Key supply chain KPI for customer service measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOffice rdf:type rdf:Property ;
    rdfs:label 'Sales Office' ;
    rdfs:comment 'The sales office or branch that originated this order. Used for territory management and sales force performance tracking.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganization rdf:type rdf:Property ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'The sales organization responsible for this order. Defines the selling entity and organizational hierarchy for reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Document Number' ;
    rdfs:comment 'The native SAP SD sales order document number. Used for system-to-system integration and ERP traceability.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'The transportation mode selected for order delivery. Impacts delivery time, cost, and carrier selection.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for customer-specific delivery instructions, packaging requirements, or handling notes for warehouse and logistics teams.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Final total amount for the order including subtotal, taxes, freight, less discounts. The invoiced amount for revenue recognition.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the period covered by this invoice. Used for period-based billing and revenue allocation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this invoice. Relevant for subscription, service, or recurring billing scenarios.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingType rdf:type rdf:Property ;
    rdfs:label 'Billing Type' ;
    rdfs:comment 'Classification of the invoice document type: standard invoice for goods/services, credit memo for returns/adjustments, debit memo for additional charges, proforma for advance notice, intercompany for internal transfers, or consignment for stock-based billing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Timestamp when the invoice was cancelled or voided. Null for active invoices. Used for cancelled invoice reporting and audit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costOfGoodsSoldAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold Amount' ;
    rdfs:comment 'Total standard cost of all products billed on this invoice. Used for gross margin calculation and profitability analysis at invoice level.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysSalesOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Sales Outstanding' ;
    rdfs:comment 'Number of days between invoice date and payment date (or current date if unpaid). Key metric for working capital management and customer payment behavior analysis.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Boolean indicator that the customer has raised a dispute or deduction claim against this invoice. Triggers collections hold and dispute resolution workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'Code representing the distribution channel through which the sale was made (e.g., retail, wholesale, DTC, e-commerce). Enables channel-specific revenue analysis.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The date by which payment is expected per the agreed payment terms. Used for DSO tracking and collections management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ediDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Edi Document Number' ;
    rdfs:comment 'Unique EDI transaction control number assigned when invoice is transmitted via EDI 810. Used for EDI audit trail and error resolution.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Status' ;
    rdfs:comment 'Status of EDI 810 invoice transmission to customer\'s system. Tracks electronic invoice delivery for large retail and distributor accounts.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Amount' ;
    rdfs:comment 'Total freight, shipping, and logistics charges added to the invoice. May be separately itemized for customer transparency.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total invoice value before any deductions, including all line items, charges, and fees but before trade discounts and taxes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'Three-letter Incoterm code defining the division of costs and risks between buyer and seller (e.g., FOB, CIF, DDP). Critical for international trade invoicing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Final invoice total after all discounts, charges, and taxes. This is the amount due from the customer and recorded in accounts receivable.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'Remaining unpaid balance on the invoice. Calculated as net_amount minus paid_amount. Used for aging analysis and collections prioritization.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Cumulative amount received against this invoice across all payment transactions. Used to calculate outstanding balance.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External payment reference number provided by the customer or payment processor for reconciliation. Links invoice to bank statement or remittance advice.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Category' ;
    rdfs:comment 'Classification determining how revenue from this invoice is recognized per accounting standards (ASC 606 / IFRS 15). Drives financial reporting and revenue allocation logic.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Code' ;
    rdfs:comment 'Code identifying the sales organization unit responsible for this invoice. Used for revenue attribution and sales performance reporting.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Trade Discount Amount' ;
    rdfs:comment 'Total trade promotion discounts, volume rebates, and negotiated price reductions applied at invoice level. Reduces gross amount to arrive at net taxable amount.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name or title of the pricing agreement for business reference and reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the pricing agreement, used in contracts and SAP SD condition records.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the pricing agreement structure: standard pricing, volume-based tiered discounts, promotional allowances, rebate structures, long-term contract, or spot pricing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the pricing agreement automatically renews upon expiration unless terminated by either party.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseListPrice rdf:type rdf:Property ;
    rdfs:label 'Base List Price' ;
    rdfs:comment 'Standard manufacturer list price before any discounts, allowances, or negotiated reductions are applied.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the legal contract document or master agreement associated with this pricing agreement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedNetPrice rdf:type rdf:Property ;
    rdfs:label 'Contracted Net Price' ;
    rdfs:comment 'Agreed net price per unit after applying all negotiated discounts and allowances as defined in the pricing agreement.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount off the base list price granted to the customer under this pricing agreement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'Minimum monetary value required per order to qualify for the contracted pricing terms.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User identifier or name of the person who last modified the pricing agreement record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpPrice rdf:type rdf:Property ;
    rdfs:label 'Msrp Price' ;
    rdfs:comment 'Manufacturer suggested retail price for consumer-facing pricing, used for price positioning and margin calculation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Price Protection Flag' ;
    rdfs:comment 'Indicates whether the customer is protected from price increases during the agreement period.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the pricing agreement indicating its operational state and enforceability.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'Tiered pricing level assigned to the customer based on volume commitments, strategic importance, or negotiated terms.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productScope rdf:type rdf:Property ;
    rdfs:label 'Product Scope' ;
    rdfs:comment 'Defines the breadth of product coverage: all products, specific product category, individual SKUs, or brand-level pricing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalAllowance rdf:type rdf:Property ;
    rdfs:label 'Promotional Allowance' ;
    rdfs:comment 'Additional allowance or discount provided to support trade promotions, in-store displays, or marketing activities.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount' ;
    rdfs:comment 'Fixed monetary rebate amount granted per unit or per transaction under the pricing agreement terms.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebatePercentage rdf:type rdf:Property ;
    rdfs:label 'Rebate Percentage' ;
    rdfs:comment 'Percentage rebate granted to the customer upon achieving volume thresholds or other performance criteria defined in the agreement.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rspPrice rdf:type rdf:Property ;
    rdfs:label 'Rsp Price' ;
    rdfs:comment 'Manufacturer recommended selling price to be used by the retailer or distributor at point of sale.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThresholdQuantity rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Quantity' ;
    rdfs:comment 'Minimum order or cumulative purchase quantity required to qualify for the contracted pricing tier or volume-based discount.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThresholdUom rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Uom' ;
    rdfs:comment 'Unit of measure for the volume threshold quantity (e.g., EA for each, CS for case, PAL for pallet).' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Unique identifier for the sales opportunity record. Primary key.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Rep Id' ;
    rdfs:comment 'Reference to the sales representative (field sales, key account manager, or territory manager) responsible for managing this opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Timestamp when this opportunity was marked as closed-won or closed-lost. Null if opportunity is still open. Used for sales cycle duration analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:competitiveDisplacementContext rdf:type rdf:Property ;
    rdfs:label 'Competitive Displacement Context' ;
    rdfs:comment 'Description of competitive dynamics: which competitor\'s product(s) this opportunity aims to displace, or whether this is a net-new distribution gain without displacement. Used for competitive intelligence and win/loss analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAcvGain rdf:type rdf:Property ;
    rdfs:label 'Estimated Acv Gain' ;
    rdfs:comment 'Projected gain in ACV (All Commodity Volume) if this opportunity closes successfully. ACV measures the total retail sales volume of stores carrying the product.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedAnnualRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Revenue' ;
    rdfs:comment 'Projected incremental annual revenue from this opportunity if closed-won, in the base currency. Used for pipeline value calculation and sales forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedSkuCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Sku Count' ;
    rdfs:comment 'Number of SKUs (Stock Keeping Units) expected to be authorized or listed if this opportunity closes successfully. Used for distribution point forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedTdpGain rdf:type rdf:Property ;
    rdfs:label 'Estimated Tdp Gain' ;
    rdfs:comment 'Projected gain in TDP (Total Distribution Points) if this opportunity closes successfully. TDP measures the number of stores carrying the product weighted by store importance.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Anticipated date when the opportunity will reach closed-won or closed-lost stage. Used for sales pipeline forecasting and quota planning.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'Fiscal quarter in which the opportunity is expected to close, formatted as \'Q1 2024\', \'Q2 2024\', etc. Used for quarterly sales forecasting and quota tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year in which the opportunity is expected to close (e.g., 2024, 2025). Used for annual sales planning and year-over-year pipeline comparison.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastCategory rdf:type rdf:Property ;
    rdfs:label 'Forecast Category' ;
    rdfs:comment 'Sales forecast category for pipeline management: pipeline (early stage, low confidence), best_case (possible upside), commit (high confidence, included in quota forecast), or closed (deal finalized).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Soft-delete flag indicating whether this opportunity record has been logically deleted. True if deleted, False if active. Used for audit trail and data retention compliance.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jbpAlignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Jbp Alignment Flag' ;
    rdfs:comment 'Indicates whether this opportunity is aligned with a formal JBP (Joint Business Planning) agreement with the retailer or distributor. True if aligned, False otherwise.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Origin of the opportunity: inbound inquiry from retailer, field sales prospecting, trade show contact, referral, marketing campaign, or expansion within existing account.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Primary reason for opportunity closure as closed-lost: price (not competitive), product fit (product did not meet needs), competitive loss (lost to competitor), timing (wrong time for buyer), budget constraints, no decision made, or other. Null if not closed-lost. [ENUM-REF-CANDIDATE: price|product_fit|competitive_loss|timing|budget_constraints|no_decision|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStepDescription rdf:type rdf:Property ;
    rdfs:label 'Next Step Description' ;
    rdfs:comment 'Description of the next action or milestone required to advance this opportunity (e.g., \'Schedule buyer meeting\', \'Submit pricing proposal\', \'Finalize contract terms\').' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Business-friendly name describing the opportunity (e.g., \'Q2 2024 SKU Authorization - Retailer X\', \'New DTC Channel Launch - Product Line Y\').' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityType rdf:type rdf:Property ;
    rdfs:label 'Opportunity Type' ;
    rdfs:comment 'Classification of the opportunity by business objective: new retail account acquisition, SKU (Stock Keeping Unit) authorization/listing expansion, new channel entry (e.g., e-commerce, DSD), distribution gain with retailer/distributor, shelf space expansion, or promotional program. [ENUM-REF-CANDIDATE: new_account_acquisition|sku_authorization|sku_listing_expansion|channel_entry|distribution_gain|shelf_space_expansion|promotional_program — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Probability Percentage' ;
    rdfs:comment 'Estimated probability of closing this opportunity successfully, expressed as a percentage (0.00 to 100.00). Used for weighted pipeline forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage in the sales opportunity lifecycle: prospecting (initial contact), qualification (fit assessment), needs analysis (requirements gathering), proposal (offer submitted), negotiation (terms discussion), closed-won (deal secured), or closed-lost (deal not secured). [ENUM-REF-CANDIDATE: prospecting|qualification|needs_analysis|proposal|negotiation|closed_won|closed_lost — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winReason rdf:type rdf:Property ;
    rdfs:label 'Win Reason' ;
    rdfs:comment 'Primary reason for opportunity closure as closed-won: price advantage, product quality, brand strength, relationship with buyer, innovation/differentiation, service level, or other. Null if not closed-won. [ENUM-REF-CANDIDATE: price|product_quality|brand_strength|relationship|innovation|service_level|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssetId rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Id' ;
    rdfs:comment 'Foreign key linking to marketing.creative_asset. Business justification: Field sales reps in consumer goods deploy specific POS materials, shelf talkers, and display assets during store calls. Linking account_call to creative_asset enables compliance tracking of in-store m' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeAsset .

ind:activitiesCompleted rdf:type rdf:Property ;
    rdfs:label 'Activities Completed' ;
    rdfs:comment 'Summary of activities performed during the store visit, such as shelf audits, order placement, merchandising, training, or promotional setup. Free-text field capturing execution details.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callDate rdf:type rdf:Property ;
    rdfs:label 'Call Date' ;
    rdfs:comment 'The calendar date on which the store visit occurred. Used for daily sales activity tracking and field sales Key Performance Indicator (KPI) reporting.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:callDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Call Duration Minutes' ;
    rdfs:comment 'Total time spent at the store location in minutes. Key metric for field sales productivity analysis and route optimization.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call End Timestamp' ;
    rdfs:comment 'Precise date and time when the sales representative completed the store visit. Used to calculate call duration and productivity metrics.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callNotes rdf:type rdf:Property ;
    rdfs:label 'Call Notes' ;
    rdfs:comment 'Additional free-text notes and observations captured by the sales representative during the store visit. Provides qualitative context for the call record.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callNumber rdf:type rdf:Property ;
    rdfs:label 'Call Number' ;
    rdfs:comment 'Business identifier for the account call, typically generated by the Sales Force Automation (SFA) system. Used for external reference and tracking.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callObjective rdf:type rdf:Property ;
    rdfs:label 'Call Objective' ;
    rdfs:comment 'Primary business objective or goal for the store visit. Free-text description of what the sales representative intended to accomplish during the call.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callOutcome rdf:type rdf:Property ;
    rdfs:label 'Call Outcome' ;
    rdfs:comment 'Overall outcome assessment of the store visit. Indicates whether call objectives were achieved and execution was successful.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call Start Timestamp' ;
    rdfs:comment 'Precise date and time when the sales representative began the store visit. Captured via mobile Sales Force Automation (SFA) application for time-in-store analytics.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callStatus rdf:type rdf:Property ;
    rdfs:label 'Call Status' ;
    rdfs:comment 'Current lifecycle status of the account call. Tracks progression from scheduled visit through completion or cancellation.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callType rdf:type rdf:Property ;
    rdfs:label 'Call Type' ;
    rdfs:comment 'Classification of the account call purpose. Distinguishes between routine visits, promotional activities, merchandising support, compliance audits, New Product Development (NPD) launches, and issue resolution.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorActivityObserved rdf:type rdf:Property ;
    rdfs:label 'Competitor Activity Observed' ;
    rdfs:comment 'Free-text notes on competitor promotional activities, new product launches, pricing changes, or merchandising observed during the store visit. Competitive intelligence capture.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Competitor Pricing Flag' ;
    rdfs:comment 'Indicates whether competitor pricing information was collected during the store visit. Used to trigger pricing analysis and response.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionsCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Completed Flag' ;
    rdfs:comment 'Indicates whether identified corrective actions were completed during the same store visit. Tracks immediate issue resolution effectiveness.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Description of corrective actions identified during the visit, such as restocking Out of Stock (OOS) items, fixing Planogram (POG) violations, or addressing pricing discrepancies.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Display Compliance Flag' ;
    rdfs:comment 'Indicates whether promotional displays and secondary placements are set up according to trade promotion agreements and merchandising standards.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayType rdf:type rdf:Property ;
    rdfs:label 'Display Type' ;
    rdfs:comment 'Type of promotional display observed or set up during the store visit. Captures secondary placement strategy execution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facingsActual rdf:type rdf:Property ;
    rdfs:label 'Facings Actual' ;
    rdfs:comment 'Actual number of product facings observed during the store visit. Used to calculate facing compliance and identify shelf space gaps.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facingsRequired rdf:type rdf:Property ;
    rdfs:label 'Facings Required' ;
    rdfs:comment 'Total number of product facings specified in the Planogram (POG) for this store. Represents the target shelf presence.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobileDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Mobile Device Code' ;
    rdfs:comment 'Identifier of the mobile device used to capture the account call record. Used for Sales Force Automation (SFA) system audit and device management.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCallDate rdf:type rdf:Property ;
    rdfs:label 'Next Call Date' ;
    rdfs:comment 'Scheduled date for the next store visit. Used for call frequency planning and route optimization.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oosItemsCount rdf:type rdf:Property ;
    rdfs:label 'Oos Items Count' ;
    rdfs:comment 'Number of Stock Keeping Units (SKUs) found to be Out of Stock (OOS) during the store visit. Key metric for On Shelf Availability (OSA) tracking.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oosItemsList rdf:type rdf:Property ;
    rdfs:label 'Oos Items List' ;
    rdfs:comment 'Comma-separated list of Stock Keeping Unit (SKU) codes or product names that were Out of Stock (OOS) during the visit. Used for replenishment prioritization.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoEvidenceCount rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Count' ;
    rdfs:comment 'Number of photos captured during the store visit via mobile Sales Force Automation (SFA) application. Used for visual compliance verification and audit trails.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:photoStorageReference rdf:type rdf:Property ;
    rdfs:label 'Photo Storage Reference' ;
    rdfs:comment 'Reference identifier or Uniform Resource Locator (URL) to the location where call photos are stored. Links to external document management or cloud storage system.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pogComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Pog Compliance Score' ;
    rdfs:comment 'Overall compliance score for Planogram (POG) execution at the store, typically expressed as a percentage. Measures how well the actual shelf layout matches the planned POG.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Originally planned date for the store visit. Used to track adherence to call plans and route schedules.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shelfPositionCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Shelf Position Compliant Flag' ;
    rdfs:comment 'Indicates whether products are placed in the correct shelf position as specified in the Planogram (POG). Critical for optimal product visibility and sales.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Captured Flag' ;
    rdfs:comment 'Indicates whether a digital signature was captured from the store contact to confirm the visit and any agreements made. Used for audit and compliance purposes.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storeContactName rdf:type rdf:Property ;
    rdfs:label 'Store Contact Name' ;
    rdfs:comment 'Name of the store manager or key contact person met during the visit. Used for relationship tracking and follow-up coordination.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncStatus rdf:type rdf:Property ;
    rdfs:label 'Sync Status' ;
    rdfs:comment 'Synchronization status of the call record between the mobile Sales Force Automation (SFA) application and the central system. Tracks data integration completeness.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnOrderId rdf:type rdf:Property ;
    rdfs:label 'Return Order Id' ;
    rdfs:comment 'Unique identifier for the return order record. Primary key.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatingSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Originating Sales Order Id' ;
    rdfs:comment 'Reference to the original sales order that this return is associated with.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:receivingDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Receiving Distribution Facility Id' ;
    rdfs:comment 'Foreign key linking to distribution.distribution_facility. Business justification: Reverse logistics routing: return orders must specify the receiving DC for physical goods return. warehouse_location_code is a plain-text denormalization. Role-prefix \'receiving_\' distinguishes this f' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Additional adjustments applied to the return value (e.g., damage deductions, handling fees, promotional credits).' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the logistics carrier used for reverse shipment of the returned goods.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Issued Date' ;
    rdfs:comment 'Date when the credit memo was officially issued to the customer.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Unique credit memo document number issued for this return in the financial system.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoPostedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Posted Date' ;
    rdfs:comment 'Date when the credit memo was posted to the general ledger for financial settlement.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Status' ;
    rdfs:comment 'Current status of the credit memo in the accounts receivable settlement process. [ENUM-REF-CANDIDATE: not_requested|requested|approved|issued|posted|rejected|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerResponsibleFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Responsible Flag' ;
    rdfs:comment 'Indicates whether the customer is financially responsible for the return (True) or the business absorbs the cost (False).' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionInstruction rdf:type rdf:Property ;
    rdfs:label 'Disposition Instruction' ;
    rdfs:comment 'Instruction for handling the returned goods based on inspection results and business rules. [ENUM-REF-CANDIDATE: return_to_stock|destroy|rework|donate|quarantine|return_to_vendor|scrap — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Goods Received Date' ;
    rdfs:comment 'Date when the returned goods were physically received at the return processing facility or warehouse.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed Date' ;
    rdfs:comment 'Date when quality inspection of the returned goods was completed.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Name of the quality inspector who performed the inspection of returned goods.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Original Unit Price' ;
    rdfs:comment 'Original unit price at which the product was sold in the originating sales order.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Result' ;
    rdfs:comment 'Result of the quality inspection performed on the returned goods.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Date' ;
    rdfs:comment 'Date when the return was officially authorized by the business for processing.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Number' ;
    rdfs:comment 'Externally-known unique authorization number issued for this return request. Format: RMA-XXXXXXXX.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnOrderType rdf:type rdf:Property ;
    rdfs:label 'Return Order Type' ;
    rdfs:comment 'Classification of the return based on the originating channel: retail account, distributor, direct-to-consumer, or wholesale.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnRequestDate rdf:type rdf:Property ;
    rdfs:label 'Return Request Date' ;
    rdfs:comment 'Date when the return request was initiated by the customer or account.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnShippingCost rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Cost' ;
    rdfs:comment 'Cost incurred for shipping the returned goods back to the warehouse.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnValueGross rdf:type rdf:Property ;
    rdfs:label 'Return Value Gross' ;
    rdfs:comment 'Gross monetary value of the returned goods before any deductions (returned quantity × original unit price).' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnValueNet rdf:type rdf:Property ;
    rdfs:label 'Return Value Net' ;
    rdfs:comment 'Net monetary value to be credited to the customer after restocking fees and adjustments (gross - restocking fee - adjustments).' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Quantity of units being returned.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity Uom' ;
    rdfs:comment 'Unit of measure for the returned quantity (EA=Each, CS=Case, PL=Pallet, KG=Kilogram, LB=Pound, L=Liter, GAL=Gallon). [ENUM-REF-CANDIDATE: EA|CS|PL|KG|LB|L|GAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCount rdf:type rdf:Property ;
    rdfs:label 'Account Count' ;
    rdfs:comment 'Total number of retail trade accounts assigned to this territory. Used for workload balancing and territory design.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acvCoverage rdf:type rdf:Property ;
    rdfs:label 'Acv Coverage' ;
    rdfs:comment 'Estimated All Commodity Volume (ACV) represented by the retail accounts in this territory, expressed in currency. ACV measures the total sales volume of all products sold through the retail outlets in the territory, used for market potential assessment.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Quota Amount' ;
    rdfs:comment 'Annual sales quota or revenue target assigned to this territory, expressed in the company\'s reporting currency. Used for sales performance management and incentive compensation.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Call Frequency Days' ;
    rdfs:comment 'Standard call frequency in days for sales representative visits to accounts in this territory (e.g., 7 for weekly, 14 for bi-weekly, 30 for monthly). Used for SFA route planning.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelAssignment rdf:type rdf:Property ;
    rdfs:label 'Channel Assignment' ;
    rdfs:comment 'Primary retail channel or trade class that this territory covers. Aligns with consumer goods distribution channels including grocery, drug, mass merchandiser, club, convenience, e-commerce, and Direct-to-Consumer (DTC). [ENUM-REF-CANDIDATE: grocery|drug|mass|club|convenience|e_commerce|foodservice|wholesale|dtc|multi_channel — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:district rdf:type rdf:Property ;
    rdfs:label 'District' ;
    rdfs:comment 'Mid-level geographic or organizational district within a region. Represents a grouping of territories managed by a district sales manager.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capability Flag' ;
    rdfs:comment 'Indicates whether the majority of accounts in this territory support Electronic Data Interchange (EDI) for automated order processing, invoicing, and inventory management.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pogComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pog Compliance Required Flag' ;
    rdfs:comment 'Indicates whether field sales representatives in this territory are required to monitor and enforce Planogram (POG) compliance for product placement and shelf merchandising.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalCodeList rdf:type rdf:Property ;
    rdfs:label 'Postal Code List' ;
    rdfs:comment 'Comma-separated or structured list of postal codes included in this territory. Used for precise geographic assignment and routing optimization.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Strategic priority classification of the territory based on revenue potential, account importance, or growth opportunity. Tier 1 or Strategic territories receive higher resource allocation and management attention.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quota Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the quota amount (e.g., \'USD\', \'CAD\', \'EUR\').' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Higher-level geographic or organizational region to which this territory belongs (e.g., \'Northeast\', \'West Coast\', \'EMEA\'). Used for regional sales rollup and management hierarchy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceList rdf:type rdf:Property ;
    rdfs:label 'State Province List' ;
    rdfs:comment 'Comma-separated list of states or provinces covered by this territory (e.g., \'NY,NJ,CT\' or \'CA,NV,AZ\'). Used for state-level sales reporting and compliance.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCount rdf:type rdf:Property ;
    rdfs:label 'Store Count' ;
    rdfs:comment 'Total number of retail store locations (points of distribution) within this territory. Key metric for coverage planning and Sales Force Automation (SFA) routing.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tdpCoverage rdf:type rdf:Property ;
    rdfs:label 'Tdp Coverage' ;
    rdfs:comment 'Total Distribution Points (TDP) covered by this territory, representing the number of stores where the company\'s products are authorized for distribution. Critical metric for distribution reach and On-Shelf Availability (OSA).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Business identifier code for the territory used in sales force automation and reporting systems. Typically alphanumeric and unique across the organization.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable name of the sales territory, typically reflecting geographic region or account grouping (e.g., \'Northeast Metro\', \'California Key Accounts\').' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the territory. Active territories are operational and assigned to sales representatives; inactive territories are no longer in use; pending territories are being set up.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of the territory based on sales coverage model. Field territories cover geographic regions with multiple accounts; key account territories focus on strategic retail partners; national account territories manage enterprise-wide relationships.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeClass rdf:type rdf:Property ;
    rdfs:label 'Trade Class' ;
    rdfs:comment 'Detailed trade classification or sub-channel segmentation within the primary channel (e.g., \'Supermarket\', \'Drug Chain\', \'Dollar Store\', \'Online Pure Play\'). Used for granular channel analytics.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repId rdf:type rdf:Property ;
    rdfs:label 'Rep Id' ;
    rdfs:comment 'Primary key for rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerRepId rdf:type rdf:Property ;
    rdfs:label 'Manager Rep Id' ;
    rdfs:comment 'Reference to the sales representative record of this rep\'s direct manager. Supports hierarchical reporting and approval workflows in the sales organization.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:badgeNumber rdf:type rdf:Property ;
    rdfs:label 'Badge Number' ;
    rdfs:comment 'Physical security badge or identification number issued to the sales representative. Used for facility access and field audit verification.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelSpecialization rdf:type rdf:Property ;
    rdfs:label 'Channel Specialization' ;
    rdfs:comment 'Primary sales channel focus for this representative. Retail covers traditional grocery and drug stores; wholesale covers distributors; DTC (Direct to Consumer) covers company-owned stores and online; e-commerce covers digital marketplaces; foodservice covers restaurants and institutions; convenience covers c-stores and gas stations; mass merchandise covers big-box retailers. [ENUM-REF-CANDIDATE: retail|wholesale|dtc|ecommerce|foodservice|convenience|mass_merchandise — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionPlanCode rdf:type rdf:Property ;
    rdfs:label 'Commission Plan Code' ;
    rdfs:comment 'Identifier for the commission or incentive compensation plan assigned to this sales representative. Links to the compensation management system for payout calculation.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Current Quota Amount' ;
    rdfs:comment 'Current sales quota target amount for the active quota period. Measured in the sales organization\'s reporting currency. Used for performance tracking and commission calculation.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'First name of the sales representative. Used for personalization in SFA applications and customer-facing communications.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Full display name of the sales representative (typically first name + last name). Used in reports, dashboards, and customer-facing materials.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the sales representative was hired into the sales organization. Used for tenure calculations, commission eligibility, and performance benchmarking.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Certification Date' ;
    rdfs:comment 'Date the sales representative last completed required certifications or training. Used to track recertification schedules and compliance status.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Last name of the sales representative. Used for personalization in SFA applications and customer-facing communications.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the most recent formal performance review for this sales representative. Used to track review cycles and ensure timely evaluations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile phone number of the sales representative. Used for SFA mobile app authentication, emergency contact, and field communication.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Most recent performance evaluation rating for the sales representative. Exceeds indicates above-quota performance; meets indicates on-target; below indicates under-performing; new_hire indicates insufficient tenure for rating.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriod rdf:type rdf:Property ;
    rdfs:label 'Quota Period' ;
    rdfs:comment 'Frequency at which sales quotas are assigned and measured for this representative. Monthly quotas are typical for field sales; quarterly for key accounts; annual for national accounts.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repNumber rdf:type rdf:Property ;
    rdfs:label 'Rep Number' ;
    rdfs:comment 'Business identifier for the sales representative, typically assigned by the sales organization. Used in Salesforce Consumer Goods Cloud and SAP S/4HANA SD module for sales force automation and order capture.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repStatus rdf:type rdf:Property ;
    rdfs:label 'Rep Status' ;
    rdfs:comment 'Current lifecycle status of the sales representative. Active reps are assigned territories and quotas; inactive reps are temporarily not selling; on_leave indicates approved absence; suspended indicates disciplinary hold; terminated indicates employment ended.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repType rdf:type rdf:Property ;
    rdfs:label 'Rep Type' ;
    rdfs:comment 'Classification of the sales representative role. Field sales covers territory-based retail execution; key account manager handles strategic retail accounts; national account manager manages top-tier national chains; inside sales supports telesales and e-commerce; DSD (Direct Store Delivery) driver combines delivery and merchandising; regional manager oversees field teams.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesGroup rdf:type rdf:Property ;
    rdfs:label 'Sales Group' ;
    rdfs:comment 'SAP S/4HANA SD sales group code. Represents the functional team or product line focus within the sales organization (e.g., health and beauty, household care, personal care).' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sfaUserCode rdf:type rdf:Property ;
    rdfs:label 'Sfa User Code' ;
    rdfs:comment 'User identifier in the Sales Force Automation system (Salesforce Consumer Goods Cloud). Used to link mobile app activity, retail execution records, and call reports to this sales representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date the sales representative left the organization or was terminated. Null for active employees. Used for historical sales attribution and territory transition analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vehicleAssigned rdf:type rdf:Property ;
    rdfs:label 'Vehicle Assigned' ;
    rdfs:comment 'Indicates whether a company vehicle has been assigned to this sales representative. True for DSD drivers and field sales reps with company cars; false for inside sales and office-based roles.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotaId rdf:type rdf:Property ;
    rdfs:label 'Quota Id' ;
    rdfs:comment 'Unique identifier for the sales quota assignment record.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financeBudgetId rdf:type rdf:Property ;
    rdfs:label 'Finance Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_budget. Business justification: Sales quotas are derived from and aligned to financial budgets in consumer goods IBP/S&OP planning cycles. Linking quota to finance_budget enables variance analysis between commercial targets and fina' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceBudget .

ind:acceleratorRate rdf:type rdf:Property ;
    rdfs:label 'Accelerator Rate' ;
    rdfs:comment 'Enhanced commission rate applied when stretch target is exceeded.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Methodology used to allocate quota across territories or reps (e.g., historical performance, market potential, equal distribution).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Commission percentage rate applied when quota is achieved.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Customer segment or account classification to which this quota applies (e.g., national accounts, regional chains, independent retailers).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'Fiscal month within the year (1-12) for which the quota is assigned.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Threshold' ;
    rdfs:comment 'Minimum performance threshold required for quota credit or commission eligibility.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'End date of the quota period.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'Start date of the quota period.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Time period granularity for the quota (monthly, quarterly, semi-annual, or annual).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaName rdf:type rdf:Property ;
    rdfs:label 'Quota Name' ;
    rdfs:comment 'Descriptive name for the quota assignment.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaNumber rdf:type rdf:Property ;
    rdfs:label 'Quota Number' ;
    rdfs:comment 'Business identifier or reference number for the quota assignment.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaSource rdf:type rdf:Property ;
    rdfs:label 'Quota Source' ;
    rdfs:comment 'Method by which the quota was determined. Top-down = allocated from corporate targets, Bottom-up = aggregated from field input, Negotiated = agreed between management and rep, Algorithmic = calculated by predictive model.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaStatus rdf:type rdf:Property ;
    rdfs:label 'Quota Status' ;
    rdfs:comment 'Current lifecycle status of the quota assignment. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaType rdf:type rdf:Property ;
    rdfs:label 'Quota Type' ;
    rdfs:comment 'Type of quota being assigned. Revenue = monetary sales target, Volume = unit/case target, New Distribution = new store/outlet target, TDP (Total Distribution Points) = weighted distribution target, ACV (All Commodity Volume) = market coverage target, Unit Sales = individual unit target, Gross Margin = profitability target. [ENUM-REF-CANDIDATE: revenue|volume|new_distribution|tdp|acv|unit_sales|gross_margin — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaValue rdf:type rdf:Property ;
    rdfs:label 'Quota Value' ;
    rdfs:comment 'Target value for the quota. Interpretation depends on quota_type: monetary amount for revenue quotas, unit count for volume quotas, store count for distribution quotas.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stretchTarget rdf:type rdf:Property ;
    rdfs:label 'Stretch Target' ;
    rdfs:comment 'Aspirational or stretch goal beyond the base quota value, used for incentive compensation.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uom rdf:type rdf:Property ;
    rdfs:label 'Uom' ;
    rdfs:comment 'Unit of measure for the quota value (e.g., USD, cases, units, stores, points).' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPointId rdf:type rdf:Property ;
    rdfs:label 'Distribution Point Id' ;
    rdfs:comment 'Unique identifier for the distribution point record. Primary key.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Actual Retail Price' ;
    rdfs:comment 'Current actual retail selling price observed at this distribution point, may differ from RSP/MSRP.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acvPercentage rdf:type rdf:Property ;
    rdfs:label 'Acv Percentage' ;
    rdfs:comment 'The ACV percentage contribution of this retail location to the total category volume, used for weighted distribution metrics.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acvWeightedFlag rdf:type rdf:Property ;
    rdfs:label 'Acv Weighted Flag' ;
    rdfs:comment 'Indicates whether this distribution point is included in ACV-weighted distribution calculations (True/False). ACV-weighted stores represent a significant portion of category sales volume.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'Date when the SKU was authorized for distribution at this retail location or account.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delistDate rdf:type rdf:Property ;
    rdfs:label 'Delist Date' ;
    rdfs:comment 'Date when the SKU was delisted or removed from distribution at this location. Null if still active.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current lifecycle status of the SKU at this distribution point. Active indicates the product is currently distributed and available for sale; authorized indicates approval but not yet active; delisted indicates removal from distribution; inactive indicates temporary suspension.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Verification Date' ;
    rdfs:comment 'Date when the distribution status was last verified or confirmed through the distribution source.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dsdFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Flag' ;
    rdfs:comment 'Indicates whether this distribution point is serviced via Direct Store Delivery (True) or warehouse distribution (False).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Enabled Flag' ;
    rdfs:comment 'Indicates whether this distribution point supports EDI transactions for order and inventory management (True/False).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facingCount rdf:type rdf:Property ;
    rdfs:label 'Facing Count' ;
    rdfs:comment 'Number of product facings (front-facing units) allocated to this SKU on the retail shelf at this location.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'Geographic market or region code for this distribution point, used for regional distribution analysis.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPosSaleDate rdf:type rdf:Property ;
    rdfs:label 'Last Pos Sale Date' ;
    rdfs:comment 'Most recent date when a POS transaction was recorded for this SKU at this location, used to verify active distribution.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:launchWave rdf:type rdf:Property ;
    rdfs:label 'Launch Wave' ;
    rdfs:comment 'Launch wave or phase identifier for new product rollouts, indicating the sequence of distribution expansion.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newProductFlag rdf:type rdf:Property ;
    rdfs:label 'New Product Flag' ;
    rdfs:comment 'Indicates whether this distribution point represents a new product introduction (True/False). Used for NPD distribution tracking.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:osaStatus rdf:type rdf:Property ;
    rdfs:label 'Osa Status' ;
    rdfs:comment 'Current on-shelf availability status of the SKU at this location, indicating whether the product is physically available for purchase.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramSlotReference rdf:type rdf:Property ;
    rdfs:label 'Planogram Slot Reference' ;
    rdfs:comment 'Reference to the planogram slot or shelf position where this SKU is merchandised at the store.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pogComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Pog Compliance Flag' ;
    rdfs:comment 'Indicates whether the SKU placement at this location is compliant with the authorized planogram (True/False).' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfPosition rdf:type rdf:Property ;
    rdfs:label 'Shelf Position' ;
    rdfs:comment 'Vertical and horizontal shelf position classification for the SKU at this location (eye level, top shelf, middle shelf, bottom shelf, end cap, promotional display).' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdpCountFlag rdf:type rdf:Property ;
    rdfs:label 'Tdp Count Flag' ;
    rdfs:comment 'Indicates whether this distribution point is counted in TDP metrics (True/False). Used to calculate numeric distribution reach.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vmiFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Flag' ;
    rdfs:comment 'Indicates whether this distribution point operates under a Vendor Managed Inventory agreement (True/False).' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByPriceListId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Price List Id' ;
    rdfs:comment 'Reference to the newer price list that replaces this one when status is superseded. Enables price list succession tracking and historical pricing analysis.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:freightInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Freight Inclusion Flag' ;
    rdfs:comment 'Indicates whether freight costs are included in the prices in this list. True when prices are freight-inclusive (delivered pricing), false when prices are ex-works or FOB.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqUom rdf:type rdf:Property ;
    rdfs:label 'Moq Uom' ;
    rdfs:comment 'Unit of measure for the minimum order quantity threshold. May differ from price UoM to support different ordering and pricing units.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpFlag rdf:type rdf:Property ;
    rdfs:label 'Msrp Flag' ;
    rdfs:comment 'Indicates whether this price list contains manufacturer suggested retail prices (MSRP). True when prices represent official MSRP for consumer-facing pricing and promotional compliance.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceBasis rdf:type rdf:Property ;
    rdfs:label 'Price Basis' ;
    rdfs:comment 'Pricing methodology or basis used to establish prices in this list. List price indicates standard published pricing, cost plus indicates markup over cost, market based indicates alignment with market rates, competitive indicates positioning relative to competitors, value based indicates pricing tied to customer value perception.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListCode rdf:type rdf:Property ;
    rdfs:label 'Price List Code' ;
    rdfs:comment 'Unique business identifier code for the price list used in SAP SD pricing procedures and condition records. Externally-known identifier used in pricing agreements and sales documents.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListDescription rdf:type rdf:Property ;
    rdfs:label 'Price List Description' ;
    rdfs:comment 'Detailed description of the price list purpose, scope, and applicability including target customer segments and product categories covered.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListName rdf:type rdf:Property ;
    rdfs:label 'Price List Name' ;
    rdfs:comment 'Descriptive business name of the price list for identification and reporting purposes.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListStatus rdf:type rdf:Property ;
    rdfs:label 'Price List Status' ;
    rdfs:comment 'Current lifecycle status of the price list. Draft indicates under development, pending approval indicates awaiting authorization, active indicates currently in use, inactive indicates temporarily disabled, expired indicates past validity period, superseded indicates replaced by newer version.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListType rdf:type rdf:Property ;
    rdfs:label 'Price List Type' ;
    rdfs:comment 'Classification of the price list by its business purpose and application context. Standard lists provide baseline pricing, promotional lists support time-limited campaigns, contract lists support negotiated agreements, channel-specific lists apply to distribution channels, seasonal lists support seasonal pricing strategies, and clearance lists support inventory liquidation.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceProtectionDays rdf:type rdf:Property ;
    rdfs:label 'Price Protection Days' ;
    rdfs:comment 'Number of days of price protection coverage offered under this price list. Defines the lookback period for retroactive price adjustments when price protection is enabled.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceRoundingRule rdf:type rdf:Property ;
    rdfs:label 'Price Rounding Rule' ;
    rdfs:comment 'Rounding rule applied to calculated prices from this list. Supports psychological pricing strategies and currency denomination constraints.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUom rdf:type rdf:Property ;
    rdfs:label 'Price Uom' ;
    rdfs:comment 'Standard unit of measure in which prices are expressed in this list (e.g., EA for each, CS for case, PAL for pallet). Aligns with SAP MM material master UoM configuration.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingConditionType rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition Type' ;
    rdfs:comment 'SAP SD condition type code that defines how prices from this list are applied in pricing procedures (e.g., PR00 for base price, K004 for material price). Links price list to SAP pricing schema configuration.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rspFlag rdf:type rdf:Property ;
    rdfs:label 'Rsp Flag' ;
    rdfs:comment 'Indicates whether this price list contains recommended selling prices (RSP) for retail partners. True when prices represent manufacturer-suggested retail pricing guidance.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Classification' ;
    rdfs:comment 'Tax category or classification code applicable to prices in this list. Determines tax treatment for products priced under this list in compliance with jurisdictional tax regulations.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListItemId rdf:type rdf:Property ;
    rdfs:label 'Price List Item Id' ;
    rdfs:comment 'Unique identifier for the price list item record. Primary key for this entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceListItem .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'The SAP SD condition type code that defines the pricing logic for this item (e.g., PR00 for base price, K004 for customer discount). Maps to SAP pricing procedure.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPrice rdf:type rdf:Property ;
    rdfs:label 'Cost Price' ;
    rdfs:comment 'The standard cost or COGS for this SKU in the specified currency. Used for margin analysis and profitability calculations. Business-confidential data.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemSequence rdf:type rdf:Property ;
    rdfs:label 'Item Sequence' ;
    rdfs:comment 'Sequential line number of this item within the parent price list. Used for ordering and display purposes.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'The base list price for this SKU in the specified currency and unit of measure. Represents the standard selling price before any discounts or promotions.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginPercentage rdf:type rdf:Property ;
    rdfs:label 'Margin Percentage' ;
    rdfs:comment 'The target gross margin percentage for this price list item, calculated as (list_price - cost_price) / list_price * 100. Business-confidential data.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this price list item represents a manual override of standard pricing logic. True if this is an exception price.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceListItemStatus rdf:type rdf:Property ;
    rdfs:label 'Price List Item Status' ;
    rdfs:comment 'Current lifecycle status of this price list item. Controls whether the item can be used in pricing calculations.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Pricing Unit Quantity' ;
    rdfs:comment 'The quantity of base units represented by one pricing unit. For example, if price is per case and a case contains 12 units, this value is 12.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this price is part of a promotional campaign. True if this is a temporary promotional price rather than standard list price.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapConditionRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Condition Record Number' ;
    rdfs:comment 'The unique SAP SD condition record number for this price list item. Enables traceability back to the source ERP system.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleBasis rdf:type rdf:Property ;
    rdfs:label 'Scale Basis' ;
    rdfs:comment 'The basis for volume-based pricing scales (e.g., quantity, order value, weight, volume). Defines how tiered pricing thresholds are measured.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleQuantityFrom rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity From' ;
    rdfs:comment 'The lower bound of the quantity range for which this price applies in a tiered pricing structure. Used for volume discount calculations.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleQuantityTo rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity To' ;
    rdfs:comment 'The upper bound of the quantity range for which this price applies in a tiered pricing structure. Null indicates no upper limit for the highest tier.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the distribution center ceased operations. Null for active facilities. Used for historical analysis and network optimization studies.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary contact email address for the distribution center. Organizational contact data classified as confidential business information.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary contact phone number for the distribution center. Organizational contact data classified as confidential business information.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDockEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Enabled Flag' ;
    rdfs:comment 'Indicates whether the facility supports cross-docking operations where inbound goods are directly transferred to outbound shipments with minimal storage time.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleCountFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency Days' ;
    rdfs:comment 'Standard frequency in days for cycle counting inventory at this facility. Used for inventory accuracy management and audit compliance.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dcCode rdf:type rdf:Property ;
    rdfs:label 'Dc Code' ;
    rdfs:comment 'Business identifier code for the distribution center used across operational systems. Externally-known unique code for the facility.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dcName rdf:type rdf:Property ;
    rdfs:label 'Dc Name' ;
    rdfs:comment 'Official business name of the distribution center or warehouse facility.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorsInbound rdf:type rdf:Property ;
    rdfs:label 'Dock Doors Inbound' ;
    rdfs:comment 'Number of dock doors designated for inbound receiving operations. Impacts receiving throughput capacity and scheduling.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dockDoorsOutbound rdf:type rdf:Property ;
    rdfs:label 'Dock Doors Outbound' ;
    rdfs:comment 'Number of dock doors designated for outbound shipping operations. Impacts shipping throughput capacity and carrier scheduling.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsdHubFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Hub Flag' ;
    rdfs:comment 'Indicates whether this facility serves as a DSD hub for direct-to-retail delivery operations. DSD hubs bypass traditional distribution channels for faster store replenishment.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fscCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Fsc Certified Flag' ;
    rdfs:comment 'Indicates whether the facility is certified under FSC chain of custody standards for sustainable sourcing. Required for handling FSC-certified paper and wood-based products.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified Flag' ;
    rdfs:comment 'Indicates whether the facility is certified under Good Manufacturing Practice standards. Required for handling cosmetics, personal care, and certain consumer goods products.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryRotationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Rotation Method' ;
    rdfs:comment 'Primary inventory rotation method used at this facility. FIFO (First In First Out) for standard goods, FEFO (First Expired First Out) for perishables and date-sensitive products, LIFO (Last In First Out) for specific use cases.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Expiration date of the facility lease agreement. Null for owned facilities. Used for lease renewal planning and facility strategy.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the distribution center commenced operations. Used for facility age analysis and depreciation calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for weekdays in format HH:MM-HH:MM. Used for scheduling inbound deliveries, outbound shipments, and workforce planning.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard operating hours for weekends in format HH:MM-HH:MM. Used for scheduling weekend operations and carrier coordination.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osaTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Osa Target Percentage' ;
    rdfs:comment 'Target OSA performance percentage for stores served by this distribution center. OSA measures product availability at retail shelf level.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Otif Target Percentage' ;
    rdfs:comment 'Target OTIF performance percentage for this distribution center. OTIF measures the percentage of orders delivered on time and in full, a key supply chain KPI.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapPlantCode rdf:type rdf:Property ;
    rdfs:label 'Sap Plant Code' ;
    rdfs:comment 'SAP S/4HANA plant code representing this distribution center in the ERP system. Maps to the SAP MM and WM modules for material management and warehouse management.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Sap Storage Location' ;
    rdfs:comment 'SAP S/4HANA storage location code within the plant. Represents the primary storage location identifier for inventory transactions in SAP WM module.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftsPerDay rdf:type rdf:Property ;
    rdfs:label 'Shifts Per Day' ;
    rdfs:comment 'Number of operational shifts per day at the facility. Used for labor planning, throughput capacity modeling, and operational cost analysis.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageCapacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Pallet Positions' ;
    rdfs:comment 'Maximum number of pallet positions available for storage. Key metric for inventory capacity planning and space utilization analysis.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Sqft' ;
    rdfs:comment 'Total warehouse floor space capacity in square feet. Includes all storage, staging, and operational areas within the facility.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsSiteCode rdf:type rdf:Property ;
    rdfs:label 'Wms Site Code' ;
    rdfs:comment 'Unique site identifier in the Blue Yonder WMS system. Used for integration and synchronization between the lakehouse and the operational WMS platform.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Distribution Storage Location Id' ;
    rdfs:comment 'Primary key for storage_location' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:binPosition rdf:type rdf:Property ;
    rdfs:label 'Bin Position' ;
    rdfs:comment 'Specific bin or slot position within the level for granular inventory placement and retrieval.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency' ;
    rdfs:comment 'Scheduled frequency for cycle counting inventory at this location to maintain inventory accuracy and compliance.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStorageLocationLevel rdf:type rdf:Property ;
    rdfs:label 'Distribution Storage Location Level' ;
    rdfs:comment 'Vertical level or shelf position within the bay for height-based slotting and equipment compatibility.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Required' ;
    rdfs:comment 'Type of material handling equipment required to access this storage location for put-away and picking operations.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fefo Eligible Flag' ;
    rdfs:comment 'Indicates whether the location supports FEFO inventory rotation logic for expiry-sensitive products (pharmaceuticals, food, cosmetics).' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fifoEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fifo Eligible Flag' ;
    rdfs:comment 'Indicates whether the location supports FIFO inventory rotation logic for age-based stock management.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date when the most recent cycle count was performed at this storage location.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mixedLotAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Mixed Lot Allowed Flag' ;
    rdfs:comment 'Indicates whether the location permits storage of multiple lot or batch numbers for the same SKU or requires lot segregation.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickFaceFlag rdf:type rdf:Property ;
    rdfs:label 'Pick Face Flag' ;
    rdfs:comment 'Indicates whether this location is designated as an active pick face for order fulfillment operations.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickingStrategy rdf:type rdf:Property ;
    rdfs:label 'Picking Strategy' ;
    rdfs:comment 'Order fulfillment picking method supported by this location: batch picking, wave picking, zone picking, discrete (single-order), or cluster picking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayStrategy rdf:type rdf:Property ;
    rdfs:label 'Putaway Strategy' ;
    rdfs:comment 'Algorithm used to assign incoming inventory to this location: directed (system-assigned), random, fixed (dedicated SKU), or dynamic (velocity-based).' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentPriority rdf:type rdf:Property ;
    rdfs:label 'Replenishment Priority' ;
    rdfs:comment 'Priority ranking for automated replenishment from reserve to pick locations, with lower numbers indicating higher priority.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Volume Capacity M3' ;
    rdfs:comment 'Maximum volume capacity of the storage location in cubic meters for space utilization and slotting algorithms.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Kg' ;
    rdfs:comment 'Maximum weight capacity of the storage location in kilograms for safe load management and slotting optimization.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Distribution Facility Id' ;
    rdfs:comment 'Identifier of the specific warehouse or storage facility within the distribution center where goods were received.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
    rdfs:comment 'Quantity of goods accepted into inventory after quality inspection, excluding rejected or damaged items.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Timestamp' ;
    rdfs:comment 'Precise date and time when the physical goods arrived and were checked in at the receiving dock, representing the principal business event for this transaction.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Reference to the Advanced Shipping Notice document sent by the supplier prior to shipment arrival, enabling pre-receipt planning and dock scheduling.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseCount rdf:type rdf:Property ;
    rdfs:label 'Case Count' ;
    rdfs:comment 'Number of cases or cartons received in this inbound shipment.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discrepancyReason rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason' ;
    rdfs:comment 'Classification of the type of discrepancy identified during receiving, used for root cause analysis and supplier performance management.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorNumber rdf:type rdf:Property ;
    rdfs:label 'Dock Door Number' ;
    rdfs:comment 'Physical dock door location where the inbound shipment was unloaded, used for labor planning and dock utilization tracking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity' ;
    rdfs:comment 'Total quantity of goods expected to be received based on the ASN or purchase order, used for discrepancy detection.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Compliant Flag' ;
    rdfs:comment 'Indicator of whether this receipt met both on-time delivery and complete quantity requirements, key supplier performance metric.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:putawayCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Putaway Completion Timestamp' ;
    rdfs:comment 'Date and time when all received goods were moved from the receiving dock to their designated storage locations, completing the inbound process.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Current status of the quality inspection process for this receipt, tracking progression through quality control workflow.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Completion Timestamp' ;
    rdfs:comment 'Date and time when all receiving activities (unloading, inspection, put-away) were completed and the receipt was closed in the WMS.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Externally-known business identifier for the inbound receipt, used for tracking and reference across systems and with suppliers.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the inbound receipt transaction, tracking progression from scheduling through completion or exception handling.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptType rdf:type rdf:Property ;
    rdfs:label 'Receipt Type' ;
    rdfs:comment 'Classification of the inbound receipt based on the source and nature of the goods being received.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'Quantity of goods rejected during receiving due to quality issues, damage, or non-conformance to specifications.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Receipt Date' ;
    rdfs:comment 'Planned date for the inbound shipment to arrive at the distribution center, based on ASN or supplier commitment.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicator of whether the security seal was found intact upon arrival, critical for quality control and loss prevention.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal identifier applied to the trailer or container, verified upon receipt to ensure shipment integrity and prevent tampering.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Check Required Flag' ;
    rdfs:comment 'Indicator of whether temperature verification was required for this receipt due to cold chain or temperature-sensitive product requirements.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Compliant Flag' ;
    rdfs:comment 'Indicator of whether the recorded temperature was within acceptable range per product specifications and cold chain requirements.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureReadingCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading Celsius' ;
    rdfs:comment 'Actual temperature reading in Celsius recorded during receipt inspection for temperature-sensitive products, critical for cold chain compliance.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'Unique identifier of the trailer or truck that delivered the shipment, used for tracking and carrier performance analysis.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryOutboundDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Outbound Distribution Facility Id' ;
    rdfs:comment 'Identifier of the distribution center fulfilling the outbound order. Determines inventory source and warehouse operations responsible for order execution.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:backorderFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Flag' ;
    rdfs:comment 'Indicates whether any line items on the order are backordered due to insufficient inventory. True when ordered quantity exceeds available stock.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fillRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Percentage' ;
    rdfs:comment 'Percentage of ordered quantity that was fulfilled from available inventory. Calculated as (shipped quantity / ordered quantity) * 100. Key metric for inventory availability and customer service.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Commitment Flag' ;
    rdfs:comment 'Indicates whether this order is subject to formal OTIF performance measurement and customer scorecard reporting. True for orders with contractual delivery commitments.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packingSlipNumber rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Number' ;
    rdfs:comment 'Document number for the packing slip accompanying the shipment. Used for customer receiving and invoice reconciliation.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Pick Ticket Number' ;
    rdfs:comment 'Warehouse document number used to direct picking operations for this order. Generated by WMS when order is released to the warehouse floor.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Timestamp' ;
    rdfs:comment 'Date and time when delivery was confirmed by the recipient. Captured from carrier POD or customer signature. Used for OTIF measurement and freight audit.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'Date when the customer or system requests the order to be shipped from the distribution center. Used for warehouse planning and scheduling.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the order must be delivered to the customer destination. Critical for OTIF (On Time In Full) performance measurement and SLA compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text instructions for warehouse and logistics teams regarding special handling requirements. May include temperature control, fragile handling, hazmat procedures, or customer-specific delivery instructions.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Order Quantity' ;
    rdfs:comment 'Total quantity of units across all line items in the outbound order. Used for warehouse capacity planning and OTIF fill rate calculation.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total monetary value of the outbound order before taxes and freight charges. Used for order prioritization, credit limit checks, and revenue forecasting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Order Volume M3' ;
    rdfs:comment 'Total volume of the outbound order in cubic meters. Used for warehouse space planning, truck cube utilization, and pallet configuration.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Order Weight Kg' ;
    rdfs:comment 'Total weight of the outbound order in kilograms. Used for freight cost calculation, carrier capacity planning, and vehicle loading optimization.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waveCode rdf:type rdf:Property ;
    rdfs:label 'Wave Code' ;
    rdfs:comment 'Identifier of the warehouse wave that includes this order. Wave picking groups orders for efficient batch picking and resource optimization.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Distribution Storage Location Id' ;
    rdfs:comment 'Reference to the target location where picked items are staged or packed (e.g., pack station, staging lane, loading dock).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:primaryPickDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Pick Distribution Storage Location Id' ;
    rdfs:comment 'Reference to the warehouse storage location (bin, shelf, pallet position) from which inventory is picked.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:cartonCode rdf:type rdf:Property ;
    rdfs:label 'Carton Code' ;
    rdfs:comment 'Unique identifier for the carton or shipping container into which items are packed. May be a license plate number (LPN) or SSCC (Serial Shipping Container Code).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1128Label rdf:type rdf:Property ;
    rdfs:label 'Gs1 128 Label' ;
    rdfs:comment 'The GS1-128 barcode label data applied to the carton or pallet, encoding SSCC, GTIN, lot, expiry, and other supply chain attributes.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether this pick task is subject to OTIF (On Time In Full) performance measurement (true = OTIF tracked, false = not tracked).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packStationCode rdf:type rdf:Property ;
    rdfs:label 'Pack Station Code' ;
    rdfs:comment 'Reference to the packing station where the packing operation is performed. Applicable when task_type includes packing.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Code' ;
    rdfs:comment 'Code identifying the type of packaging material used (e.g., corrugated box, poly bag, shrink wrap). Used for cartonization and sustainability tracking.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletCode rdf:type rdf:Property ;
    rdfs:label 'Pallet Code' ;
    rdfs:comment 'Unique identifier for the pallet onto which cartons or items are loaded. Typically an SSCC or internal LPN.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickAccuracyFlag rdf:type rdf:Property ;
    rdfs:label 'Pick Accuracy Flag' ;
    rdfs:comment 'Boolean indicator of whether the pick was accurate (true = picked quantity matches requested quantity and correct SKU/lot; false = discrepancy detected).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickListNumber rdf:type rdf:Property ;
    rdfs:label 'Pick List Number' ;
    rdfs:comment 'Human-readable pick list reference number assigned by the WMS for operator identification and tracking.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickQuantity rdf:type rdf:Property ;
    rdfs:label 'Pick Quantity' ;
    rdfs:comment 'The quantity of SKU units to be picked for this task, measured in the SKU\'s base unit of measure.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickedQuantity rdf:type rdf:Property ;
    rdfs:label 'Picked Quantity' ;
    rdfs:comment 'The actual quantity of SKU units picked by the operator. May differ from pick_quantity due to short picks or overages.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taskAssignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Assigned Timestamp' ;
    rdfs:comment 'Timestamp when the pick task was assigned to an operator by the WMS. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Completed Timestamp' ;
    rdfs:comment 'Timestamp when the pick task was completed and confirmed by the operator or WMS. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Task Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from task start to completion. Used for labor productivity analysis and standard time calculation.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Started Timestamp' ;
    rdfs:comment 'Timestamp when the operator began executing the pick task (scanned start or confirmed task initiation). Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the pick task: pending (awaiting assignment), assigned (allocated to operator), in_progress (actively being executed), completed (finished successfully), cancelled (voided), on_hold (temporarily suspended).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Discriminator indicating the type of fulfillment task: pick (picking only), pack (packing only), pick_and_pack (combined operation), or replenishment_pick (internal stock movement).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTaskId rdf:type rdf:Property ;
    rdfs:label 'Pack Task Id' ;
    rdfs:comment 'Unique identifier for the packing task record. Primary key.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cartonizationRuleCode rdf:type rdf:Property ;
    rdfs:label 'Cartonization Rule Code' ;
    rdfs:comment 'Reference to the cartonization algorithm or business rule used to determine optimal packing configuration.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Code' ;
    rdfs:comment 'Code identifying the destination distribution center, retail store, or customer facility for the packed shipment.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelPrintedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Label Printed Timestamp' ;
    rdfs:comment 'Timestamp when the shipping label was printed for the packed container.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:otifTargetShipDate rdf:type rdf:Property ;
    rdfs:label 'Otif Target Ship Date' ;
    rdfs:comment 'Target ship date for OTIF performance measurement and customer service level compliance.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Completion Timestamp' ;
    rdfs:comment 'Timestamp when the packing task was completed and sealed for dispatch.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Pack Duration Minutes' ;
    rdfs:comment 'Total time in minutes taken to complete the packing task, used for labor productivity analysis.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Start Timestamp' ;
    rdfs:comment 'Timestamp when the packing task was initiated by the operator.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packStatus rdf:type rdf:Property ;
    rdfs:label 'Pack Status' ;
    rdfs:comment 'Current lifecycle status of the packing task.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packType rdf:type rdf:Property ;
    rdfs:label 'Pack Type' ;
    rdfs:comment 'Type of packing configuration used for the task.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Check Status' ;
    rdfs:comment 'Status of quality verification performed on the packed container before dispatch.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSkuCount rdf:type rdf:Property ;
    rdfs:label 'Total Sku Count' ;
    rdfs:comment 'Total number of distinct SKUs packed into the container.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Unit Quantity' ;
    rdfs:comment 'Total quantity of units packed across all SKUs in the container.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Meters' ;
    rdfs:comment 'Total volumetric capacity of the packed container in cubic meters, used for transportation planning.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Source Distribution Facility Id' ;
    rdfs:comment 'FK to distribution.distribution_facility' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time when the shipment departed the DC. Critical for OTIF calculation and carrier performance tracking.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Level' ;
    rdfs:comment 'Service tier selected for this shipment defining speed and handling requirements.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartonCount rdf:type rdf:Property ;
    rdfs:label 'Carton Count' ;
    rdfs:comment 'Total number of cartons or cases included in the shipment. Used for piece-level tracking and receiving verification.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Destination Address Line1' ;
    rdfs:comment 'Primary street address line of the shipment destination. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Code' ;
    rdfs:comment 'Business identifier of the destination location (store number, DC code, customer account number) where goods are being delivered.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationName rdf:type rdf:Property ;
    rdfs:label 'Destination Name' ;
    rdfs:comment 'Human-readable name of the destination location for display and confirmation purposes.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the shipment destination. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationType rdf:type rdf:Property ;
    rdfs:label 'Destination Type' ;
    rdfs:comment 'Classification of the shipment destination entity type for routing and handling purposes.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Timestamp' ;
    rdfs:comment 'Current estimated delivery date and time based on real-time tracking and carrier updates. Updated dynamically during transit.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the freight charge amount.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Document Number' ;
    rdfs:comment 'SAP SD goods issue document number linking the physical shipment to the ERP inventory transaction. Critical for inventory accuracy.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemCount rdf:type rdf:Property ;
    rdfs:label 'Line Item Count' ;
    rdfs:comment 'Total number of distinct SKU line items included in the shipment. Used for picking complexity and receiving planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadNumber rdf:type rdf:Property ;
    rdfs:label 'Load Number' ;
    rdfs:comment 'Identifier of the load plan that consolidated multiple orders or shipments into this trailer. Used for load optimization tracking.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Timestamp' ;
    rdfs:comment 'Planned date and time for the shipment to depart from the DC dock. Precision timestamp for appointment scheduling and carrier coordination.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classification of the shipment based on delivery method and business purpose. DSD indicates Direct Store Delivery channel.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:comment 'Total quantity of individual sellable units (eaches) included in the shipment across all SKUs.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cubic Meters' ;
    rdfs:comment 'Total cube or volume of the shipment in cubic meters. Critical for trailer utilization and dimensional weight calculations.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waveNumber rdf:type rdf:Property ;
    rdfs:label 'Wave Number' ;
    rdfs:comment 'Identifier of the warehouse picking wave that generated the orders included in this shipment. Links shipment to WMS wave planning.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryPositionId rdf:type rdf:Property ;
    rdfs:label 'Inventory Position Id' ;
    rdfs:comment 'Primary key for inventory_position' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryPosition .

ind:actualWeight rdf:type rdf:Property ;
    rdfs:label 'Actual Weight' ;
    rdfs:comment 'The actual measured weight of the inventory for catch weight items. Used for billing and compliance when item weight varies.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:catchWeightFlag rdf:type rdf:Property ;
    rdfs:label 'Catch Weight Flag' ;
    rdfs:comment 'Indicates whether the SKU is a catch weight item requiring actual weight capture at transaction time (true) or standard weight (false).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'The unit cost of the inventory lot. Used for inventory valuation and cost of goods sold calculations. Business confidential financial data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOnHand rdf:type rdf:Property ;
    rdfs:label 'Days On Hand' ;
    rdfs:comment 'The number of days the inventory has been on hand since receipt. Calculated as current date minus receipt date. Used for aging analysis.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysToExpiry rdf:type rdf:Property ;
    rdfs:label 'Days To Expiry' ;
    rdfs:comment 'The number of days remaining until the inventory lot expires. Calculated as expiry date minus current date. Critical for FEFO rotation and markdown decisions.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryCondition rdf:type rdf:Property ;
    rdfs:label 'Inventory Condition' ;
    rdfs:comment 'The physical condition classification of the inventory. Used for disposition decisions and channel restrictions.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'The current operational status of the inventory position. Determines availability for picking and order fulfillment.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'The date when inventory was last moved into or out of this storage location. Used for slow-moving inventory identification.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementType rdf:type rdf:Property ;
    rdfs:label 'Last Movement Type' ;
    rdfs:comment 'The type of the last inventory movement transaction that affected this position (receipt, putaway, pick, replenishment, transfer, adjustment, return). [ENUM-REF-CANDIDATE: receipt|putaway|pick|replenishment|transfer|adjustment|return — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensePlateNumber rdf:type rdf:Property ;
    rdfs:label 'License Plate Number' ;
    rdfs:comment 'The warehouse management system license plate number assigned to the handling unit. Used for tracking and automated material handling.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'The date on which the product lot was manufactured. Used for shelf-life calculations and FEFO rotation.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Indicates the ownership model of the inventory (owned by company, consignment from supplier, customer-owned for returns, vendor-managed inventory).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayDate rdf:type rdf:Property ;
    rdfs:label 'Putaway Date' ;
    rdfs:comment 'The date when the inventory was put away into this storage location after receiving. Used for aging analysis and FEFO compliance.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityAllocated rdf:type rdf:Property ;
    rdfs:label 'Quantity Allocated' ;
    rdfs:comment 'The quantity of on-hand inventory that has been allocated to outbound orders or reservations but not yet picked. Reduces available-to-pick quantity.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'The quantity available for new order allocation and picking. Calculated as quantity_on_hand minus quantity_allocated minus quantity_quarantine minus quantity_hold.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDamaged rdf:type rdf:Property ;
    rdfs:label 'Quantity Damaged' ;
    rdfs:comment 'The quantity of inventory identified as damaged and not suitable for sale or distribution. Typically awaiting disposal or return to supplier.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityHold rdf:type rdf:Property ;
    rdfs:label 'Quantity Hold' ;
    rdfs:comment 'The quantity of inventory placed on hold due to quality issues, customer complaints, or pending investigation. Not available for picking.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityQuarantine rdf:type rdf:Property ;
    rdfs:label 'Quantity Quarantine' ;
    rdfs:comment 'The quantity of inventory placed in quarantine status pending quality inspection or regulatory clearance. Not available for picking.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'The quantity of inventory reserved for specific customers, channels, or promotional programs. Subset of allocated quantity with additional business constraints.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentFlag rdf:type rdf:Property ;
    rdfs:label 'Replenishment Flag' ;
    rdfs:comment 'Indicates whether this inventory position requires replenishment from reserve to pick face (true) or not (false). Triggers automated replenishment tasks.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The timestamp when this inventory position snapshot was captured. Used for point-in-time inventory reporting and trend analysis.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:storageZone rdf:type rdf:Property ;
    rdfs:label 'Storage Zone' ;
    rdfs:comment 'The logical zone within the distribution center where the inventory is stored (e.g., ambient, refrigerated, frozen, hazmat, high-velocity, reserve).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalInventoryValue rdf:type rdf:Property ;
    rdfs:label 'Total Inventory Value' ;
    rdfs:comment 'The total financial value of the inventory position calculated as quantity_on_hand multiplied by cost_per_unit. Used for balance sheet reporting. Business confidential financial data.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Weight Unit Of Measure' ;
    rdfs:comment 'The unit of measure for actual weight (Pound, Kilogram, Ounce, Gram). Applicable for catch weight items.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionCycleCountId rdf:type rdf:Property ;
    rdfs:label 'Distribution Cycle Count Id' ;
    rdfs:comment 'Unique identifier for the cycle count event record. Primary key for the distribution cycle count entity.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Approved Flag' ;
    rdfs:comment 'Indicates whether the inventory adjustment has been approved by a supervisor or manager.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Required Flag' ;
    rdfs:comment 'Indicates whether an inventory adjustment is required based on the variance exceeding tolerance thresholds.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count End Timestamp' ;
    rdfs:comment 'The date and time when the physical counting activity was completed.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countNumber rdf:type rdf:Property ;
    rdfs:label 'Count Number' ;
    rdfs:comment 'Business identifier for the cycle count event, typically generated by the WMS. Format: CC-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countReasonCode rdf:type rdf:Property ;
    rdfs:label 'Count Reason Code' ;
    rdfs:comment 'The business reason triggering this cycle count: routine (scheduled ABC cycle), discrepancy (prior variance), audit (compliance), quality (QC hold), recall (product recall), transfer (location move).' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'The date and time when the physical counting activity began.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the cycle count event: scheduled (routine ABC cycle), ad-hoc (unplanned), exception (triggered by discrepancy), blind (counter does not see system quantity), or targeted (specific SKU/lot focus).' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValueVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Inventory Value Variance Amount' ;
    rdfs:comment 'The financial impact of the variance, calculated as variance_quantity multiplied by the standard cost of the SKU. Expressed in the DC\'s functional currency.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recountNumber rdf:type rdf:Property ;
    rdfs:label 'Recount Number' ;
    rdfs:comment 'Sequential number indicating which recount iteration this represents (1 for first recount, 2 for second, etc.). Null if no recount performed.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recountRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Required Flag' ;
    rdfs:comment 'Indicates whether a recount is required due to significant variance or quality control procedures.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toleranceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold Percentage' ;
    rdfs:comment 'The acceptable variance percentage threshold. Variances within this percentage may not require adjustment.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceThresholdQuantity rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold Quantity' ;
    rdfs:comment 'The acceptable variance quantity threshold defined for this SKU/location combination. Variances within this threshold may not require adjustment.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Wms Transaction Code' ;
    rdfs:comment 'The unique transaction identifier generated by the WMS for this cycle count event, used for audit trail and system reconciliation.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifEventId rdf:type rdf:Property ;
    rdfs:label 'Otif Event Id' ;
    rdfs:comment 'Unique identifier for the OTIF performance measurement event. Primary key for the OTIF event record.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Date' ;
    rdfs:comment 'The delivery date committed to the customer per the Service Level Agreement (SLA) or purchase order terms. Baseline for on-time performance measurement.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:committedDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Timestamp' ;
    rdfs:comment 'The precise delivery date and time committed to the customer, including time window for time-sensitive deliveries. Used for precise OTIF measurement when time windows apply.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:committedQuantity rdf:type rdf:Property ;
    rdfs:label 'Committed Quantity' ;
    rdfs:comment 'The total quantity committed to the customer per the sales order or purchase order. Baseline for in-full performance measurement. Measured in order unit of measure.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'The logistics channel used for delivery execution. Values include Direct Store Delivery (DSD), Less Than Truckload (LTL) carrier, Full Truckload (FTL) carrier, parcel, customer pickup, or third-party logistics (3PL).' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Variance Days' ;
    rdfs:comment 'The number of days variance between committed and actual delivery date. Negative values indicate early delivery, positive values indicate late delivery, zero indicates on-time.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Explanation of why the OTIF measurement is disputed. Captures customer or internal objections to the performance assessment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCategory rdf:type rdf:Property ;
    rdfs:label 'Failure Category' ;
    rdfs:comment 'The primary root cause category for OTIF failures. Used for operational improvement analysis and accountability assignment. Values include DC pick error, inventory shortage, dock delay, carrier issue, customer refused, weather delay, system error, quality hold, damaged product, address issue, or no failure for successful deliveries. [ENUM-REF-CANDIDATE: dc_pick_error|inventory_shortage|dock_delay|carrier_issue|customer_refused|weather_delay|system_error|quality_hold|damaged_product|address_issue|no_failure — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Detail' ;
    rdfs:comment 'Detailed explanation of the root cause for OTIF failure. Free-text field capturing specific circumstances, corrective actions, and accountability notes.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inFullTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'In Full Tolerance Percent' ;
    rdfs:comment 'The acceptable variance percentage per customer SLA or business policy. Deliveries within this tolerance are considered in-full compliant.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The date when the OTIF performance was measured and recorded. Used for reporting period assignment and trend analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:otifScore rdf:type rdf:Property ;
    rdfs:label 'Otif Score' ;
    rdfs:comment 'Composite OTIF performance indicator. True only when both on_time_flag and in_full_flag are True. Primary KPI for DC operations accountability and retailer scorecard compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the retailer penalty amount. Standard currency codes such as USD, EUR, GBP.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Captured Flag' ;
    rdfs:comment 'Indicates whether an electronic or physical signature was captured at delivery. True indicates signature obtained, False indicates delivery without signature capture.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'The difference between delivered quantity and committed quantity. Negative values indicate short shipment, positive values indicate over shipment.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariancePercent rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance Percent' ;
    rdfs:comment 'The percentage variance between delivered and committed quantity, calculated as (delivered - committed) / committed * 100. Used to assess severity of in-full failures.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'The organizational function or external party accountable for the OTIF failure. Used for performance accountability and continuous improvement initiatives.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Retailer Penalty Amount' ;
    rdfs:comment 'The financial penalty or chargeback amount assessed by the retailer for OTIF non-compliance per the customer contract or retailer compliance program. Zero for compliant deliveries.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'The service level tier committed to the customer. Defines the delivery speed and OTIF performance expectations per the customer agreement.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether inspection results under this plan require formal approval by a quality manager or authorized person before batch release. Typically true for GMP-critical inspections.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aqlLevel rdf:type rdf:Property ;
    rdfs:label 'Aql Level' ;
    rdfs:comment 'Acceptable Quality Level expressed as a percentage. Maximum percent defective that is considered acceptable for the inspection plan. Used in acceptance sampling decisions.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateOfAnalysisRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Required Flag' ;
    rdfs:comment 'Indicates whether a formal Certificate of Analysis document must be generated upon successful completion of inspections under this plan. Typically required for finished goods and customer-facing materials.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Change Control Number' ;
    rdfs:comment 'Reference to the change control request or document that authorized the creation or last modification of this inspection plan. Required for GMP compliance and audit trail.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicCount rdf:type rdf:Property ;
    rdfs:label 'Characteristic Count' ;
    rdfs:comment 'Number of quality characteristics (test parameters) defined in this inspection plan. Each characteristic has its own specification limits.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Lead Time Days' ;
    rdfs:comment 'Expected number of calendar days required to complete all inspections and testing defined in this plan. Used for production scheduling and inventory planning.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'Primary method used to perform the inspection: manual measurement, automated testing, laboratory analysis, visual examination, destructive testing, or non-destructive testing.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionSeverity rdf:type rdf:Property ;
    rdfs:label 'Inspection Severity' ;
    rdfs:comment 'Severity level of inspection based on supplier quality history and risk assessment. Tightened inspection applies stricter acceptance criteria.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStage rdf:type rdf:Property ;
    rdfs:label 'Inspection Stage' ;
    rdfs:comment 'Production or supply chain stage at which this inspection is triggered. Aligns with GMP critical control points.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Type of quality inspection this plan governs: incoming (supplier materials), in-process (production intermediates), final (finished goods), stability (shelf-life studies), release (batch release), or periodic (routine surveillance).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Classification of the material subject to inspection. Determines applicable GMP requirements and inspection rigor.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Business identifier for the inspection plan, used across quality management systems and documentation. Externally visible code for referencing the plan in quality specifications and batch records.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the inspection plan including scope, objectives, and special instructions for quality control personnel.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable name of the inspection plan describing its purpose and scope.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the inspection plan. Only active plans are used for inspection lot creation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Reference to the regulatory requirement, standard, or guideline that mandates this inspection (e.g., FDA 21 CFR Part 211, EU GMP Annex 1, ISO 22716). Critical for compliance audits.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleInspectorRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Inspector Role' ;
    rdfs:comment 'Job role or qualification level required for personnel authorized to perform inspections under this plan (e.g., QC Technician, QC Analyst, QC Manager). Ensures competency requirements are met.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision number of this inspection plan. Incremented each time the plan is updated. Part of change control and audit trail.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of sample units to be drawn per inspection lot. Determined by statistical sampling plan and AQL requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleUnit rdf:type rdf:Property ;
    rdfs:label 'Sample Unit' ;
    rdfs:comment 'Unit of measure for the sample (e.g., pieces, kg, liters, containers). Defines what constitutes one sample unit.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Sampling Procedure Code' ;
    rdfs:comment 'Code identifying the sampling procedure to be followed: sample size, sampling frequency, sampling method (random, systematic, stratified). References approved sampling SOP.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skipLotAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Skip Lot Allowed Flag' ;
    rdfs:comment 'Indicates whether skip-lot inspection (reduced frequency based on consistent quality history) is permitted for this plan. Not allowed for GMP-critical inspections.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationVersion rdf:type rdf:Property ;
    rdfs:label 'Specification Version' ;
    rdfs:comment 'Version number of the quality specification document that this inspection plan implements. Ensures traceability to approved specifications.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testEquipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Test Equipment Required' ;
    rdfs:comment 'List or description of test equipment, instruments, or laboratory apparatus required to execute this inspection plan. Ensures resource availability.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaIssueDate rdf:type rdf:Property ;
    rdfs:label 'Coa Issue Date' ;
    rdfs:comment 'Date when the Certificate of Analysis was formally issued for this inspection lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date when the formal usage decision was made and recorded in the quality management system.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Precise date and time when the usage decision was recorded. Used for audit trail and compliance reporting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of defects or non-conformances identified during inspection. Used for quality metrics and trend analysis.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionOutcome rdf:type rdf:Property ;
    rdfs:label 'Disposition Outcome' ;
    rdfs:comment 'Final outcome status of the lot after disposition decision and stock posting. Confirms the actual inventory movement executed.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionEndDate rdf:type rdf:Property ;
    rdfs:label 'Inspection End Date' ;
    rdfs:comment 'Date when all inspection and testing activities were completed for this lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionLocation rdf:type rdf:Property ;
    rdfs:label 'Inspection Location' ;
    rdfs:comment 'Physical location or quality lab where the inspection was performed. May be different from the plant code for centralized testing facilities.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'Business identifier for the inspection lot. Externally visible alphanumeric code used in SAP QM and quality documentation for traceability and audit purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-text field for inspector comments, observations, or special conditions noted during the inspection process.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPriority rdf:type rdf:Property ;
    rdfs:label 'Inspection Priority' ;
    rdfs:comment 'Priority level assigned to the inspection lot. Determines the sequence and urgency of inspection execution in the quality lab.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Date' ;
    rdfs:comment 'Date when the physical inspection and testing activities began for this lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle status of the inspection lot. Tracks progression from creation through inspection execution to final disposition decision.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotOriginNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Origin Number' ;
    rdfs:comment 'Document number of the originating transaction (production order number, purchase order number, delivery number, etc.) that triggered this inspection lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotOriginType rdf:type rdf:Property ;
    rdfs:label 'Lot Origin Type' ;
    rdfs:comment 'Source document type that triggered the creation of this inspection lot. Links the quality inspection to the originating business transaction.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotQuantity rdf:type rdf:Property ;
    rdfs:label 'Lot Quantity' ;
    rdfs:comment 'Total quantity of material in the inspection lot. Represents the population from which samples are drawn for inspection.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Lot Quantity Uom' ;
    rdfs:comment 'Unit of measure for the lot quantity (each, kilogram, liter, meter, etc.). Aligns with material master UOM. [ENUM-REF-CANDIDATE: EA|KG|L|M|M2|M3|BOX|CASE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldReason rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Reason' ;
    rdfs:comment 'Detailed explanation of why the lot is under regulatory hold. Documents the specific compliance or quality concern requiring additional review.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleQuantity rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity' ;
    rdfs:comment 'Quantity of material drawn as a sample for inspection testing. Determined by the inspection plan sampling procedure.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity Uom' ;
    rdfs:comment 'Unit of measure for the sample quantity drawn for testing. [ENUM-REF-CANDIDATE: EA|KG|L|M|M2|M3|BOX|CASE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockPostingInstruction rdf:type rdf:Property ;
    rdfs:label 'Stock Posting Instruction' ;
    rdfs:comment 'Instruction for inventory movement based on the usage decision. Determines the target stock type for material posting in warehouse management.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Warehouse storage location code where the inspected material is held during quality inspection.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecision rdf:type rdf:Property ;
    rdfs:label 'Usage Decision' ;
    rdfs:comment 'Final disposition decision for the inspected lot. Determines whether material can be released for use, must be reworked, or should be rejected.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecisionCode rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Code' ;
    rdfs:comment 'Standardized code representing the usage decision. Used for automated stock posting and reporting in SAP QM.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResultId rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Id' ;
    rdfs:comment 'Unique identifier for the inspection result record. Primary key for granular QC (Quality Control) measurement and test result records captured at the characteristic level within an inspection lot.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleId rdf:type rdf:Property ;
    rdfs:label 'Sample Id' ;
    rdfs:comment 'Unique identifier of the physical sample from which this measurement was taken. Enables traceability back to the specific sample unit within the inspection lot.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sample .

ind:coaInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Inclusion Flag' ;
    rdfs:comment 'Flag indicating whether this result should be included in the Certificate of Analysis (COA) document for the batch. True indicates inclusion; false indicates internal-only result.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlChartRuleViolated rdf:type rdf:Property ;
    rdfs:label 'Control Chart Rule Violated' ;
    rdfs:comment 'Description of the specific SPC control chart rule that was violated (e.g., point beyond control limit, 7 consecutive points above centerline, 2 of 3 points beyond 2-sigma). Populated when control_chart_violation_flag is true.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlChartViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Control Chart Violation Flag' ;
    rdfs:comment 'Flag indicating whether this measurement violates SPC (Statistical Process Control) control chart rules (e.g., out of control limits, run rules, trend rules). True indicates a violation requiring investigation.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Standardized code classifying the type of defect or non-conformance observed when result_status is fail. Used for defect trending and root cause analysis.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectSeverity rdf:type rdf:Property ;
    rdfs:label 'Defect Severity' ;
    rdfs:comment 'Classification of the severity of the non-conformance. Critical defects pose safety or regulatory risk; major defects affect functionality; minor defects are cosmetic or non-functional.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationCode rdf:type rdf:Property ;
    rdfs:label 'Deviation Code' ;
    rdfs:comment 'Reference to an approved deviation or waiver document that authorizes acceptance of a non-conforming result. Populated when result_status is waived.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalConditionHumidity rdf:type rdf:Property ;
    rdfs:label 'Environmental Condition Humidity' ;
    rdfs:comment 'Relative humidity (percentage) at the time of measurement. Critical for tests sensitive to moisture levels.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalConditionTemperature rdf:type rdf:Property ;
    rdfs:label 'Environmental Condition Temperature' ;
    rdfs:comment 'Ambient temperature (in degrees Celsius) at the time of measurement. Critical for tests sensitive to environmental conditions.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionCharacteristicCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Code' ;
    rdfs:comment 'Unique code identifying the specific quality characteristic being measured (e.g., pH level, viscosity, weight, color, microbial count). Corresponds to the master inspection characteristic definition.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCharacteristicName rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Name' ;
    rdfs:comment 'Human-readable name of the quality characteristic being tested (e.g., Product pH, Net Weight, Microbial Load, Color Consistency).' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMethodCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Method Code' ;
    rdfs:comment 'Code identifying the standardized test method or procedure used to perform this measurement (e.g., ASTM method, USP method, internal SOP number).' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when this specific characteristic measurement was performed. Critical for time-sensitive tests and GMP audit trails.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:instrumentCode rdf:type rdf:Property ;
    rdfs:label 'Instrument Code' ;
    rdfs:comment 'Unique identifier of the measurement instrument or equipment used to capture this result (e.g., balance ID, pH meter ID, spectrophotometer ID). Required for GMP (Good Manufacturing Practice) audit trails and instrument calibration traceability.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryCode rdf:type rdf:Property ;
    rdfs:label 'Laboratory Code' ;
    rdfs:comment 'Identifier of the laboratory or testing facility where this measurement was performed. May be an internal QC lab or an external contract lab.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Specification Limit' ;
    rdfs:comment 'The minimum acceptable value for this characteristic as defined in the product specification or quality standard. Values below this threshold indicate non-conformance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The actual quantitative measurement or test result value recorded during inspection. For qualitative characteristics, this may be encoded numerically or stored as a code.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementUncertainty rdf:type rdf:Property ;
    rdfs:label 'Measurement Uncertainty' ;
    rdfs:comment 'Quantified estimate of the uncertainty or error margin associated with the measured value. Required for ISO 17025 compliance and advanced SPC (Statistical Process Control) analysis.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Flag indicating whether this result must be reported to regulatory authorities (e.g., FDA, EPA) due to non-conformance or safety concerns. True indicates reportable event.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text comments or observations recorded by the inspector regarding this measurement. May include notes on sample condition, procedural deviations, or contextual information.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Pass/fail status of this individual characteristic measurement. Pass indicates the measured value is within specification limits; fail indicates non-conformance; conditional indicates acceptance with restrictions; pending indicates awaiting review; waived indicates non-conformance accepted by authorized deviation.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestIndicator rdf:type rdf:Property ;
    rdfs:label 'Retest Indicator' ;
    rdfs:comment 'Flag indicating whether this result is a retest of a previously failed or inconclusive measurement. True indicates this is a retest; false indicates initial test.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestReasonCode rdf:type rdf:Property ;
    rdfs:label 'Retest Reason Code' ;
    rdfs:comment 'Code indicating the reason for retesting this characteristic. Applicable only when retest_indicator is true.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Sequence Number' ;
    rdfs:comment 'Sequential number of this sample within the inspection lot (e.g., 1, 2, 3). Used to track sampling order and support statistical sampling plans.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The ideal or nominal value for this characteristic. Used for process capability analysis and SPC (Statistical Process Control) charting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Test Batch Number' ;
    rdfs:comment 'Batch or run number of the test reagents or consumables used during this measurement. Required for traceability in regulated environments.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Specification Limit' ;
    rdfs:comment 'The maximum acceptable value for this characteristic as defined in the product specification or quality standard. Values above this threshold indicate non-conformance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageDecisionId rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Id' ;
    rdfs:comment 'Unique identifier for the quality control usage decision record. Primary key.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UsageDecision .

ind:capaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Required Flag' ;
    rdfs:comment 'Indicates whether this usage decision triggers a CAPA process due to significant non-conformance. True=CAPA required, False=No CAPA needed. Links to continuous improvement.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionCode rdf:type rdf:Property ;
    rdfs:label 'Decision Code' ;
    rdfs:comment 'The formal quality control usage decision code. A=Accept (Unrestricted Use), R=Reject, Q=Quality Hold, S=Restricted Use (Sample/Scrap), X=Rework Required. Drives downstream inventory disposition.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionMakerName rdf:type rdf:Property ;
    rdfs:label 'Decision Maker Name' ;
    rdfs:comment 'Full name of the quality control inspector or authorized personnel who made the usage decision. Captured for audit and traceability purposes.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionText rdf:type rdf:Property ;
    rdfs:label 'Decision Text' ;
    rdfs:comment 'Detailed textual description or rationale for the usage decision. Captures the quality assessor\'s reasoning and any special conditions or instructions.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Detailed description of the defect, non-conformance, or quality issue identified during inspection. Supports CAPA and continuous improvement processes.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'The date when the material disposition action was completed (e.g., stock posted to unrestricted, blocked, or scrapped). Null if disposition is still pending.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current status of the material disposition action following the usage decision. pending=Decision made but stock not yet moved, completed=Stock posting completed, cancelled=Decision reversed or voided.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAccepted rdf:type rdf:Property ;
    rdfs:label 'Quantity Accepted' ;
    rdfs:comment 'The quantity of material accepted for unrestricted use based on the usage decision. Measured in the material\'s base unit of measure.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRejected rdf:type rdf:Property ;
    rdfs:label 'Quantity Rejected' ;
    rdfs:comment 'The quantity of material rejected and not suitable for use. Measured in the material\'s base unit of measure. May trigger disposal or return to supplier.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRework rdf:type rdf:Property ;
    rdfs:label 'Quantity Rework' ;
    rdfs:comment 'The quantity of material designated for rework or reprocessing to meet quality standards. Measured in the material\'s base unit of measure.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplingProcedure rdf:type rdf:Property ;
    rdfs:label 'Sampling Procedure' ;
    rdfs:comment 'The sampling method or procedure used during the inspection (e.g., random sampling, statistical sampling, 100% inspection). Ensures inspection validity.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity' ;
    rdfs:comment 'Quantity of product units or material affected by the nonconformance. Used for containment scope and financial impact assessment.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity Uom' ;
    rdfs:comment 'Unit of measure for the affected quantity: EA (each/units), KG (kilograms), L (liters), M (meters), BOX (boxes), PALLET (pallets).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentAction rdf:type rdf:Property ;
    rdfs:label 'Containment Action' ;
    rdfs:comment 'Immediate containment actions taken to prevent further occurrence or distribution of nonconforming product. Describes short-term corrective measures implemented before root cause analysis.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Containment Timestamp' ;
    rdfs:comment 'Date and time when containment actions were completed and verified effective. Critical for regulatory reporting and OTIF compliance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectClassification rdf:type rdf:Property ;
    rdfs:label 'Defect Classification' ;
    rdfs:comment 'Technical classification of the defect type: appearance (cosmetic defect), functionality (performance issue), safety (consumer safety risk), labeling (incorrect or missing label information), packaging (packaging integrity issue), contamination (foreign material or microbial contamination), specification_failure (out-of-specification test result), or process_deviation (manufacturing process non-conformance). [ENUM-REF-CANDIDATE: appearance|functionality|safety|labeling|packaging|contamination|specification_failure|process_deviation — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'Date and time when the nonconformance was first detected or observed. Represents the real-world event time of quality issue identification.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispositionApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Disposition Approved By' ;
    rdfs:comment 'User identifier of the quality authority who approved the disposition decision. Links to workforce/employee master data for audit trail and GMP compliance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Approved Timestamp' ;
    rdfs:comment 'Date and time when the disposition decision was formally approved by quality authority. Critical for GMP audit trail and batch release decisions.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final disposition decision for the nonconforming product or material: use_as_is (approved for use despite nonconformance), rework (reprocess to meet specifications), scrap (destroy), return_to_supplier (send back to vendor), downgrade (sell as lower grade), or quarantine (hold pending further investigation).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformanceStatus rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Status' ;
    rdfs:comment 'Current lifecycle status of the nonconformance record: open (newly created), in_investigation (root cause analysis underway), containment_active (immediate containment actions in progress), capa_assigned (corrective and preventive action assigned), closed (resolved and verified), or cancelled (invalidated).' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'External business identifier for the quality notification or nonconformance event. Corresponds to SAP QM notification number or Veeva Vault quality event identifier.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when the nonconformance was reported to regulatory authorities, if applicable. Null if not reportable or not yet reported.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePlantCode rdf:type rdf:Property ;
    rdfs:label 'Responsible Plant Code' ;
    rdfs:comment 'Manufacturing plant or facility code where the nonconformance originated or is being managed. Links to distribution_facility for organizational accountability.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Detailed findings from root cause investigation, including methodology used (5-Why, Fishbone, Fault Tree Analysis) and identified root causes. Supports CAPA development.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity classification of the quality event based on impact to product safety, efficacy, and regulatory compliance. Critical: immediate risk to consumer safety or regulatory violation; Major: significant quality impact requiring containment; Minor: low impact quality issue.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify effectiveness of corrective actions and confirm the nonconformance has been resolved (e.g., re-inspection, re-testing, process validation, trend analysis).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'The actual date when all CAPA actions were completed and verified, prior to formal closure.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaDescription rdf:type rdf:Property ;
    rdfs:label 'Capa Description' ;
    rdfs:comment 'Detailed description of the nonconformance, audit finding, complaint, or stability failure that triggered the CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Business-facing unique identifier for the CAPA record, typically formatted as CAPA-NNNNNN. Used for external communication and audit trails.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current lifecycle status of the CAPA record, tracking progression from initiation through closure. [ENUM-REF-CANDIDATE: open|investigation|action_plan|implementation|verification|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Classification of the CAPA as corrective (addressing existing nonconformance), preventive (preventing potential nonconformance), or combined (both corrective and preventive actions).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureComments rdf:type rdf:Property ;
    rdfs:label 'Closure Comments' ;
    rdfs:comment 'Final comments or notes recorded at the time of CAPA closure, summarizing outcomes and lessons learned.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective action(s) taken to address the existing nonconformance and eliminate its cause.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Amount' ;
    rdfs:comment 'Estimated or actual financial cost impact of the CAPA issue, including costs of investigation, rework, scrap, recall, or other remediation activities.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cost impact amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Method' ;
    rdfs:comment 'The method or approach used to verify that the corrective and preventive actions were effective in resolving the issue and preventing recurrence (e.g., follow-up audit, process monitoring, trend analysis).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerificationResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Result' ;
    rdfs:comment 'The outcome of the effectiveness verification, indicating whether the CAPA actions successfully resolved the issue and prevented recurrence.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'The date when the CAPA record was formally initiated and opened in the quality management system.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preventiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Description' ;
    rdfs:comment 'Detailed description of the preventive action(s) implemented to prevent recurrence of the issue or occurrence of similar issues.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processArea rdf:type rdf:Property ;
    rdfs:label 'Process Area' ;
    rdfs:comment 'The specific process, department, or functional area where the issue occurred (e.g., Manufacturing, Packaging, Quality Control, Supply Chain).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Method' ;
    rdfs:comment 'The methodology used to identify the root cause of the issue, such as 5 Whys, Fishbone Diagram, Fault Tree Analysis, Pareto Analysis, or Failure Mode and Effects Analysis (FMEA).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'The origin or trigger event that initiated the CAPA, such as nonconformance, audit finding, customer complaint, supplier quality issue, stability study failure, or regulatory inspection finding.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'The planned or target date by which all CAPA actions should be completed and verified.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Brief descriptive title summarizing the CAPA issue or focus area.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date when the effectiveness verification was completed.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateOfAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Id' ;
    rdfs:comment 'Foreign key linking to quality.certificate_of_analysis. Business justification: Link batch_release to the Certificate of Analysis that documents the released batch, removing redundant reference number.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificateOfAnalysis .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference to the complete audit trail log for all actions and approvals related to this batch release. Required for 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Batch Size Quantity' ;
    rdfs:comment 'Total quantity of finished goods produced in this batch. Used for yield calculation and inventory planning.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeUom rdf:type rdf:Property ;
    rdfs:label 'Batch Size Uom' ;
    rdfs:comment 'Unit of measure for the batch size quantity (e.g., kilograms, liters, units). Aligns with GS1 standards for trade item measurement. [ENUM-REF-CANDIDATE: kg|lbs|liters|gallons|units|cases|pallets — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationCount rdf:type rdf:Property ;
    rdfs:label 'Deviation Count' ;
    rdfs:comment 'Number of manufacturing or quality deviations recorded during the production and testing of this batch. Used for quality trend analysis.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Hold Initiated Date' ;
    rdfs:comment 'Date when the regulatory or business hold was placed on the batch. Nullable if no hold exists.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingSiteCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Code' ;
    rdfs:comment 'Code identifying the manufacturing facility or plant where the batch was produced. Used for site-level quality tracking and regulatory reporting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDate rdf:type rdf:Property ;
    rdfs:label 'Production Date' ;
    rdfs:comment 'Date when the batch manufacturing was completed. Critical for shelf-life calculation and FEFO inventory management.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Inspection Status' ;
    rdfs:comment 'Overall status of QC inspection and testing for this batch. Summarizes results from multiple QC test records.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qpSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qp Signature Timestamp' ;
    rdfs:comment 'Timestamp when the Qualified Person electronically signed the batch release decision. Part of 21 CFR Part 11 electronic signature compliance.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualifiedPersonName rdf:type rdf:Property ;
    rdfs:label 'Qualified Person Name' ;
    rdfs:comment 'Full name of the Qualified Person who signed off on the batch release. Required for regulatory audit trail.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Status' ;
    rdfs:comment 'Indicates if the batch is under any regulatory or business hold that prevents distribution. Holds may be imposed by FDA, EPA, internal quality, customer complaint, or recall investigation.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the batch was officially released for distribution and sale. Marks the point at which product becomes available to promise (ATP).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseDecision rdf:type rdf:Property ;
    rdfs:label 'Release Decision' ;
    rdfs:comment 'Final disposition decision for the batch: released for distribution, rejected for destruction, quarantine for further testing, conditional release with restrictions, pending review, or on hold pending investigation. Critical GMP control point.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNotes rdf:type rdf:Property ;
    rdfs:label 'Release Notes' ;
    rdfs:comment 'Free-text notes and comments from the Qualified Person regarding the release decision. May include justification for conditional release or special handling instructions.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Precise timestamp when the batch release decision was recorded in the system. Used for audit trail and regulatory compliance.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Released Quantity' ;
    rdfs:comment 'Quantity of the batch that was approved for release and distribution. May be less than batch size if partial rejection occurred.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stabilityStudyReference rdf:type rdf:Property ;
    rdfs:label 'Stability Study Reference' ;
    rdfs:comment 'Reference number linking to the stability study protocol and results that support the assigned shelf life and expiry date for this batch.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'Full name of the quality assurance professional authorized to approve and sign this certificate. Must have appropriate delegation of authority.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Title' ;
    rdfs:comment 'Job title or role of the authorized signatory (e.g., QA Manager, Quality Director, Laboratory Supervisor).' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSize rdf:type rdf:Property ;
    rdfs:label 'Batch Size' ;
    rdfs:comment 'Total quantity produced in the manufacturing batch. Used to assess sample representativeness and for statistical quality control.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Classification of the certificate based on the material type being certified. Determines applicable test parameters and regulatory requirements.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Facing Flag' ;
    rdfs:comment 'Indicates whether this certificate is intended for external distribution to trade customers or is for internal use only. True if customer-facing.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path to the digitally signed PDF or scanned image of the certificate stored in Veeva Vault or document management system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant Flag' ;
    rdfs:comment 'Indicates whether the batch and testing process were conducted under GMP conditions. True if GMP-compliant.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingSiteName rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Name' ;
    rdfs:comment 'Full name and location of the manufacturing site. Supports multi-site operations and regulatory site registration requirements.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'The product or material code (SKU, item number, or raw material identifier) for which this certificate was issued. Links to master product or material data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Full textual description of the material or product covered by this certificate. Includes product name, variant, and key characteristics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallResultStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Result Status' ;
    rdfs:comment 'Aggregate pass/fail status for all test parameters on this certificate. Determines batch release decision and customer distribution eligibility.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityTested rdf:type rdf:Property ;
    rdfs:label 'Quantity Tested' ;
    rdfs:comment 'The quantity of material sampled and tested for this certificate. Expressed in the material\'s base unit of measure.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityTestedUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Tested Uom' ;
    rdfs:comment 'Unit of measure for the quantity tested (e.g., kilograms, liters, units). Aligns with material master UOM.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Indicates whether this certificate is required for regulatory submissions or compliance filings with FDA, EPA, or other governing bodies. True if required for submission.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'The date on which quality control testing was performed for this certificate. May differ from manufacturing date for retained samples.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testMethodReference rdf:type rdf:Property ;
    rdfs:label 'Test Method Reference' ;
    rdfs:comment 'Reference to the analytical test methods used (e.g., USP, ASTM, internal method codes). May be a comma-separated list for multiple methods.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantAddress rdf:type rdf:Property ;
    rdfs:label 'Complainant Address' ;
    rdfs:comment 'Mailing address of the complainant for correspondence and product sample return.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantCountryCode rdf:type rdf:Property ;
    rdfs:label 'Complainant Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the complainant location.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantEmail rdf:type rdf:Property ;
    rdfs:label 'Complainant Email' ;
    rdfs:comment 'Email address of the complainant for follow-up communication.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantName rdf:type rdf:Property ;
    rdfs:label 'Complainant Name' ;
    rdfs:comment 'Full name of the individual or organization filing the complaint.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantPhone rdf:type rdf:Property ;
    rdfs:label 'Complainant Phone' ;
    rdfs:comment 'Contact phone number of the complainant.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintCategory rdf:type rdf:Property ;
    rdfs:label 'Complaint Category' ;
    rdfs:comment 'Primary classification of the complaint type based on the nature of the quality issue reported.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Detailed narrative description of the complaint as reported by the complainant, including symptoms, observations, and circumstances.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Number' ;
    rdfs:comment 'Externally-visible unique complaint reference number used for tracking and communication with consumers and regulatory bodies.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Complaint Received Timestamp' ;
    rdfs:comment 'Date and time when the complaint was first received by the organization.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complaintSource rdf:type rdf:Property ;
    rdfs:label 'Complaint Source' ;
    rdfs:comment 'Origin channel through which the complaint was received.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Status' ;
    rdfs:comment 'Current lifecycle state of the complaint investigation and resolution process.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintSubcategory rdf:type rdf:Property ;
    rdfs:label 'Complaint Subcategory' ;
    rdfs:comment 'Detailed sub-classification providing additional granularity to the complaint category.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Date when the consumer or customer experienced the quality issue or adverse event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completion Date' ;
    rdfs:comment 'Date when the investigation was concluded and findings documented.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date when the formal investigation of the complaint was initiated.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current state of the internal quality investigation process.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labAnalysisResult rdf:type rdf:Property ;
    rdfs:label 'Lab Analysis Result' ;
    rdfs:comment 'Summary of laboratory test results conducted on the returned product sample.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Description of preventive actions implemented to prevent recurrence of similar issues.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date when the complaint was resolved and closed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome or action taken to resolve the complaint with the complainant.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause of the quality issue based on investigation findings.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Sample Received Date' ;
    rdfs:comment 'Date when the returned product sample was received by the quality assurance team.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleReturnedFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Returned Flag' ;
    rdfs:comment 'Indicates whether the complainant returned a physical product sample for laboratory analysis.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationMaterialSkuId rdf:type rdf:Property ;
    rdfs:label 'Specification Material Sku Id' ;
    rdfs:comment 'Reference to the material or product this specification applies to. Links to the master material record in SAP MM.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:specificationSkuId rdf:type rdf:Property ;
    rdfs:label 'Specification Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Quality specifications are defined per SKU to ensure manufacturing compliance and product release criteria.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:supersededBySpecificationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Specification Id' ;
    rdfs:comment 'Reference to the newer specification that replaces this one when status is superseded. Maintains specification version lineage.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:criticalQualityAttributeFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Quality Attribute Flag' ;
    rdfs:comment 'Indicates whether this characteristic is a Critical Quality Attribute that directly impacts product safety, efficacy, or regulatory compliance. CQAs require enhanced controls and documentation.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Requirement Flag' ;
    rdfs:comment 'Indicates whether this specification is driven by specific customer contractual requirements rather than internal or regulatory standards.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'How often this specification must be reviewed and revalidated, expressed in months. Ensures specifications remain current and appropriate.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplingPlan rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan' ;
    rdfs:comment 'Description of the sampling methodology and sample size requirements for this test (e.g., AQL 2.5, n=10, ANSI/ASQ Z1.4). Ensures statistical validity of test results.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationCategory rdf:type rdf:Property ;
    rdfs:label 'Specification Category' ;
    rdfs:comment 'High-level classification of the type of quality attribute being specified. Groups related test characteristics for reporting and analysis.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationNumber rdf:type rdf:Property ;
    rdfs:label 'Specification Number' ;
    rdfs:comment 'Business identifier for the quality specification, used for external reference and documentation. Unique across the organization.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationStatus rdf:type rdf:Property ;
    rdfs:label 'Specification Status' ;
    rdfs:comment 'Current lifecycle status of the specification. Only active specifications are used for quality control and Certificate of Analysis (CoA) generation.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationType rdf:type rdf:Property ;
    rdfs:label 'Specification Type' ;
    rdfs:comment 'Classification of the specification based on the material or product stage it applies to. Determines the applicable quality control procedures.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityIndicatingFlag rdf:type rdf:Property ;
    rdfs:label 'Stability Indicating Flag' ;
    rdfs:comment 'Indicates whether this test characteristic is used in stability studies to monitor product degradation over time. Critical for shelf-life determination.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testCharacteristic rdf:type rdf:Property ;
    rdfs:label 'Test Characteristic' ;
    rdfs:comment 'The specific quality attribute or property being measured or tested (e.g., pH, viscosity, color, weight, purity, microbial count). Defines what is being inspected.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFrequency rdf:type rdf:Property ;
    rdfs:label 'Test Frequency' ;
    rdfs:comment 'How often this test characteristic must be measured during production or quality control. Drives inspection plan scheduling. [ENUM-REF-CANDIDATE: per_batch|per_lot|hourly|daily|weekly|monthly|on_demand — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationId rdf:type rdf:Property ;
    rdfs:label 'Notification Id' ;
    rdfs:comment 'Unique identifier for the quality notification record. Primary key.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedToName rdf:type rdf:Property ;
    rdfs:label 'Assigned To Name' ;
    rdfs:comment 'Full name of the person assigned to handle this quality notification.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date when the quality notification was initially created in the system.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defectClass rdf:type rdf:Property ;
    rdfs:label 'Defect Class' ;
    rdfs:comment 'Severity classification of the defect based on its impact on product safety, functionality, and regulatory compliance.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDescription rdf:type rdf:Property ;
    rdfs:label 'Notification Description' ;
    rdfs:comment 'Detailed textual description of the quality issue, defect, or improvement opportunity documented in this notification.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Current lifecycle status of the quality notification indicating its position in the resolution workflow.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'Classification of the quality notification indicating the nature of the issue: customer complaint, internal defect, improvement request, process deviation, audit finding, or supplier quality issue.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBrandMarketingBrandId rdf:type rdf:Property ;
    rdfs:label 'Parent Brand Marketing Brand Id' ;
    rdfs:comment 'Reference to the parent brand in the brand hierarchy. Null for masterbrand level. Used to establish brand family relationships and roll-up reporting.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingBrand .

ind:annualMarketingBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Marketing Budget' ;
    rdfs:comment 'Total allocated marketing investment for the brand for the fiscal year, including media spend, trade promotion, consumer promotion, and agency fees.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenueTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target' ;
    rdfs:comment 'Planned annual revenue goal for the brand in the base currency. Used for budget planning, performance tracking, and brand portfolio prioritization.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:architectureTier rdf:type rdf:Property ;
    rdfs:label 'Architecture Tier' ;
    rdfs:comment 'Classification of the brand within the corporate brand architecture hierarchy. Masterbrand represents the corporate umbrella, subbrand is a distinct offering under the masterbrand, endorsed carries both corporate and product brand, ingredient brand is a component brand, private label is retailer-owned, and house brand is a proprietary store brand.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awarenessPercent rdf:type rdf:Property ;
    rdfs:label 'Awareness Percent' ;
    rdfs:comment 'Percentage of target consumers who recognize or recall the brand when prompted or unprompted. Measured through consumer surveys and market research panels.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandCategory rdf:type rdf:Property ;
    rdfs:label 'Brand Category' ;
    rdfs:comment 'Primary product category or market segment in which the brand competes. Examples include personal care, household cleaning, health and wellness, beauty, food and beverage.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandDescription rdf:type rdf:Property ;
    rdfs:label 'Brand Description' ;
    rdfs:comment 'Detailed narrative describing the brand\'s purpose, value proposition, and positioning in the market. Used for internal reference and marketing brief development.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:considerationPercent rdf:type rdf:Property ;
    rdfs:label 'Consideration Percent' ;
    rdfs:comment 'Percentage of target consumers who would consider purchasing the brand when making a category purchase decision. Key indicator of brand relevance and competitive positioning.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityScore rdf:type rdf:Property ;
    rdfs:label 'Equity Score' ;
    rdfs:comment 'Composite metric measuring the overall strength and value of the brand based on consumer awareness, perceived quality, brand associations, and loyalty. Typically scaled 0-100 with higher scores indicating stronger brand equity.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicMarketScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Market Scope' ;
    rdfs:comment 'Geographic reach of the brand\'s distribution and marketing activities. Global indicates worldwide presence, regional covers multiple countries in a region, national is single-country, and local is sub-national markets.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelinesUrl rdf:type rdf:Property ;
    rdfs:label 'Guidelines Url' ;
    rdfs:comment 'URL or file path to the comprehensive brand guidelines document containing logo usage, color specifications, typography, tone of voice, and visual identity standards.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrivateLabel rdf:type rdf:Property ;
    rdfs:label 'Is Private Label' ;
    rdfs:comment 'Boolean flag indicating whether the brand is a private label or store brand owned by a retail customer rather than the manufacturer. True indicates private label, false indicates manufacturer-owned brand.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logoAssetUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Asset Url' ;
    rdfs:comment 'URL or file path to the official brand logo asset in the digital asset management system. Used for marketing materials, packaging design, and digital campaigns.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Legal entity or business unit that owns the intellectual property rights to the brand. May differ from the manufacturing or distribution entity.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferencePercent rdf:type rdf:Property ;
    rdfs:label 'Preference Percent' ;
    rdfs:comment 'Percentage of target consumers who prefer this brand over competitive alternatives. Indicates brand loyalty and pricing power potential.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryColorHex rdf:type rdf:Property ;
    rdfs:label 'Primary Color Hex' ;
    rdfs:comment 'Hexadecimal color code for the primary brand color used in packaging, marketing materials, and digital assets. Ensures consistent brand identity across touchpoints.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDistributionChannel rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Channel' ;
    rdfs:comment 'Main channel through which the brand reaches consumers. Examples include mass retail, specialty retail, e-commerce, DTC (Direct to Consumer), professional/salon, or foodservice.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:somPercent rdf:type rdf:Property ;
    rdfs:label 'Som Percent' ;
    rdfs:comment 'Brand\'s percentage of total category sales volume or value. Primary metric for competitive market position and growth tracking.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovPercent rdf:type rdf:Property ;
    rdfs:label 'Sov Percent' ;
    rdfs:comment 'Brand\'s share of total advertising and promotional activity within the category, measured across paid media, earned media, and owned channels. Key indicator of marketing investment relative to competitors.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSomPercent rdf:type rdf:Property ;
    rdfs:label 'Target Som Percent' ;
    rdfs:comment 'Strategic target for the brand\'s market share. Used for annual planning, performance evaluation, and resource allocation decisions.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSovPercent rdf:type rdf:Property ;
    rdfs:label 'Target Sov Percent' ;
    rdfs:comment 'Strategic target for the brand\'s share of voice in the category. Used for media planning and budget allocation decisions. Typically set to exceed current SOM (Share of Market) to drive growth.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trademarkExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Trademark Expiration Date' ;
    rdfs:comment 'Date when the current trademark registration expires and requires renewal. Critical for maintaining legal protection of brand assets.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trademarkJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Trademark Jurisdiction' ;
    rdfs:comment 'Geographic territories or countries where the brand trademark is registered and legally protected. May include multiple jurisdictions separated by semicolons.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkRegistrationDate rdf:type rdf:Property ;
    rdfs:label 'Trademark Registration Date' ;
    rdfs:comment 'Date when the trademark was officially registered with the relevant trademark authority. Used for renewal tracking and IP portfolio management.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trademarkRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Trademark Registration Number' ;
    rdfs:comment 'Official registration number assigned by the trademark authority for the brand name, logo, or other protected brand elements. Used for legal protection and IP (Intellectual Property) management.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'Estimated financial value of the brand as an intangible asset. Calculated using income, market, or cost approaches for financial reporting and M&A (Mergers and Acquisitions) purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agencyId rdf:type rdf:Property ;
    rdfs:label 'Agency Id' ;
    rdfs:comment 'FK to marketing.agency' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agency .

ind:primarySkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Campaign planning and ROI attribution need a primary SKU reference to allocate budget and measure lift per product.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:regulatoryClaimId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Claim Id' ;
    rdfs:comment 'Foreign key linking to regulatory.regulatory_claim. Business justification: Consumer goods campaigns must reference the approved regulatory claim authorizing product claims made in advertising (e.g., \'clinically proven\', \'99% germ-free\'). Pre-launch regulatory clearance requi' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryClaim .

ind:targetSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Segment Id' ;
    rdfs:comment 'Reference to the predefined consumer segment this campaign is designed to reach. Links to consumer segmentation master data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'The actual date the campaign concluded. May differ from planned end date due to extensions, early termination, or performance-based adjustments.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualMediaSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Media Spend Amount' ;
    rdfs:comment 'The actual total media spend incurred for this campaign, in the company\'s reporting currency. Includes all paid media costs across channels.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualProductionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Production Cost Amount' ;
    rdfs:comment 'The actual cost incurred for creative production, including all content creation, design, video production, and asset development expenses.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'The actual date the campaign went live and began execution. May differ from planned start date due to operational adjustments.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Short alphanumeric code used to identify and track the campaign across systems, media buys, and analytics platforms.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Detailed narrative description of the campaign\'s purpose, strategy, key messages, and expected outcomes.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'The official name or title of the marketing campaign as used in internal planning and external communications.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle state of the campaign: draft (initial planning), planned (scheduled), approved (ready for execution), active (currently running), paused (temporarily suspended), completed (finished), or cancelled (terminated before completion). [ENUM-REF-CANDIDATE: draft|planned|approved|active|paused|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign by execution approach: ATL (Above The Line - mass media), BTL (Below The Line - targeted), digital (online channels), shopper (in-store/retail), influencer (social media partnerships), or integrated (multi-channel).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelMix rdf:type rdf:Property ;
    rdfs:label 'Channel Mix' ;
    rdfs:comment 'Comma-separated list or description of marketing channels used in the campaign (e.g., TV, digital display, social media, print, radio, OOH, in-store).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCodes rdf:type rdf:Property ;
    rdfs:label 'Country Codes' ;
    rdfs:comment 'Comma-separated list of three-letter ISO 3166-1 alpha-3 country codes where the campaign is executed (e.g., USA,CAN,MEX).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeConcept rdf:type rdf:Property ;
    rdfs:label 'Creative Concept' ;
    rdfs:comment 'High-level description of the creative theme, messaging strategy, and visual identity used in the campaign.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographyScope rdf:type rdf:Property ;
    rdfs:label 'Geography Scope' ;
    rdfs:comment 'Geographic reach of the campaign: global (worldwide), regional (multi-country region), national (single country), or local (city/metro area).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Boolean flag indicating whether the campaign is currently active (True) or inactive (False). Active campaigns are either running or scheduled to run.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Primary business goal of the campaign: awareness (brand visibility), consideration (product evaluation), conversion (purchase), loyalty (retention), launch (new product introduction), or relaunch (product refresh).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'The originally scheduled date for campaign conclusion as defined during planning phase.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedMediaSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Media Spend Amount' ;
    rdfs:comment 'The budgeted total media spend allocated to this campaign during the planning phase, in the company\'s reporting currency.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedProductionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Production Cost Amount' ;
    rdfs:comment 'The budgeted cost for creative production, including content creation, design, video production, and asset development.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'The originally scheduled date for campaign launch as defined during planning phase.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Textual description of the intended consumer segment for this campaign, including demographic, psychographic, and behavioral characteristics.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaPlanId rdf:type rdf:Property ;
    rdfs:label 'Media Plan Id' ;
    rdfs:comment 'Foreign key linking to marketing.media_plan. Business justification: campaign_flight is the transactional execution record of a campaign at the flight level. media_plan is the formal planning document that defines planned impressions, spend, channels, and targeting. Li' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaPlan .

ind:actualImpressions rdf:type rdf:Property ;
    rdfs:label 'Actual Impressions' ;
    rdfs:comment 'Actual number of impressions delivered during the flight. Core metric for reach and frequency analysis.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionModel rdf:type rdf:Property ;
    rdfs:label 'Attribution Model' ;
    rdfs:comment 'Attribution methodology used to assign conversion credit to this flight. Critical for multi-touch attribution analysis.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Total budget allocated to this flight. Represents the planned media spend for this specific flight execution.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetSpentAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Spent Amount' ;
    rdfs:comment 'Actual amount spent on this flight. Used for budget variance analysis and Return on Ad Spend (ROAS) calculation.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clicks rdf:type rdf:Property ;
    rdfs:label 'Clicks' ;
    rdfs:comment 'Total number of clicks generated by the flight. Primary engagement metric for digital and search campaigns.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionRate rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate' ;
    rdfs:comment 'Conversion rate expressed as a decimal (conversions divided by clicks or impressions). Measures campaign effectiveness in driving desired actions.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversions rdf:type rdf:Property ;
    rdfs:label 'Conversions' ;
    rdfs:comment 'Total number of conversions attributed to this flight. Conversion definition varies by campaign objective (purchase, sign-up, download, etc.).' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpa rdf:type rdf:Property ;
    rdfs:label 'Cpa' ;
    rdfs:comment 'Average cost per conversion for this flight. Critical metric for performance marketing and Return on Investment (ROI) analysis.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpc rdf:type rdf:Property ;
    rdfs:label 'Cpc' ;
    rdfs:comment 'Average cost per click for this flight. Key efficiency metric for paid search and digital campaigns.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctr rdf:type rdf:Property ;
    rdfs:label 'Ctr' ;
    rdfs:comment 'Click-through rate expressed as a decimal (clicks divided by impressions). Key performance indicator for digital campaign effectiveness.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flightName rdf:type rdf:Property ;
    rdfs:label 'Flight Name' ;
    rdfs:comment 'Descriptive name of the campaign flight for business user identification and reporting.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightNumber rdf:type rdf:Property ;
    rdfs:label 'Flight Number' ;
    rdfs:comment 'Business identifier for the flight within the campaign. Used for external reporting and agency coordination.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightStatus rdf:type rdf:Property ;
    rdfs:label 'Flight Status' ;
    rdfs:comment 'Current lifecycle status of the campaign flight.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grp rdf:type rdf:Property ;
    rdfs:label 'Grp' ;
    rdfs:comment 'Gross Rating Points for traditional media (TV, radio, OOH). Measures total audience delivery as a percentage of target population multiplied by frequency.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketGeography rdf:type rdf:Property ;
    rdfs:label 'Market Geography' ;
    rdfs:comment 'Geographic market or region where the flight is executed. Supports market-level performance tracking and regional campaign optimization.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementType rdf:type rdf:Property ;
    rdfs:label 'Placement Type' ;
    rdfs:comment 'Specific placement or ad format type within the channel (e.g., banner, video, native, sponsored post, display, search text ad). Enables placement-level optimization.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platform rdf:type rdf:Property ;
    rdfs:label 'Platform' ;
    rdfs:comment 'Specific advertising platform or network (e.g., Meta, Google Ads, TikTok, programmatic DSP, linear TV network). Enables platform-specific performance analysis.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reach rdf:type rdf:Property ;
    rdfs:label 'Reach' ;
    rdfs:comment 'Estimated number of unique individuals exposed to the campaign flight. Used for audience coverage analysis.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roas rdf:type rdf:Property ;
    rdfs:label 'Roas' ;
    rdfs:comment 'Return on Ad Spend expressed as a ratio (revenue generated divided by ad spend). Primary metric for campaign profitability assessment.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned end date for the flight media run. Defines the flight duration for budget allocation and performance measurement.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetImpressions rdf:type rdf:Property ;
    rdfs:label 'Target Impressions' ;
    rdfs:comment 'Planned number of impressions for this flight. Used for media planning and performance target setting.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:videoCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Video Completion Rate' ;
    rdfs:comment 'Percentage of video views that were completed (watched to end). Measures creative engagement quality.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoViews rdf:type rdf:Property ;
    rdfs:label 'Video Views' ;
    rdfs:comment 'Total number of video views for video creative flights. Applicable to digital video, social, and TV campaigns.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAllocationPercent rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Percent' ;
    rdfs:comment 'Percentage of total campaign or brand budget allocated to this media plan line.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creativeFormat rdf:type rdf:Property ;
    rdfs:label 'Creative Format' ;
    rdfs:comment 'Format of the creative asset planned for this media (e.g., 30-second spot, banner ad, full-page print, billboard).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypart rdf:type rdf:Property ;
    rdfs:label 'Daypart' ;
    rdfs:comment 'Time segment of day for broadcast media (e.g., Prime Time, Early Morning, Late Night, Daytime).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightEndDate rdf:type rdf:Property ;
    rdfs:label 'Flight End Date' ;
    rdfs:comment 'End date of the media flight or execution period for this plan.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flightStartDate rdf:type rdf:Property ;
    rdfs:label 'Flight Start Date' ;
    rdfs:comment 'Start date of the media flight or execution period for this plan.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kpiTarget rdf:type rdf:Property ;
    rdfs:label 'Kpi Target' ;
    rdfs:comment 'Target Key Performance Indicator metric and value for measuring media plan success (e.g., Reach 70%, CTR 2.5%, ROAS 3.0).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:market rdf:type rdf:Property ;
    rdfs:label 'Market' ;
    rdfs:comment 'Geographic market or Designated Market Area (DMA) targeted by this media plan (e.g., USA, New York DMA, UK).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaChannel rdf:type rdf:Property ;
    rdfs:label 'Media Channel' ;
    rdfs:comment 'Primary media channel category for this plan line (TV, digital, out-of-home, print, social, search, programmatic, radio, cinema, podcast). [ENUM-REF-CANDIDATE: tv|digital|ooh|print|social|search|programmatic|radio|cinema|podcast — promote to reference product]' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaOwner rdf:type rdf:Property ;
    rdfs:label 'Media Owner' ;
    rdfs:comment 'Name of the media owner or publisher (e.g., NBC, Google, Meta, Clear Channel).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaSubchannel rdf:type rdf:Property ;
    rdfs:label 'Media Subchannel' ;
    rdfs:comment 'Detailed subchannel or platform within the primary media channel (e.g., Facebook, Google Display, National TV, Local Radio).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the media plan by planning horizon and purpose.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version number of this media plan document to track revisions and iterations.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedCpm rdf:type rdf:Property ;
    rdfs:label 'Planned Cpm' ;
    rdfs:comment 'Planned cost per thousand impressions for this media investment.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCpp rdf:type rdf:Property ;
    rdfs:label 'Planned Cpp' ;
    rdfs:comment 'Planned cost per rating point for broadcast media investments.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedFrequency rdf:type rdf:Property ;
    rdfs:label 'Planned Frequency' ;
    rdfs:comment 'Planned average number of times the target audience will be exposed to the media message.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGrp rdf:type rdf:Property ;
    rdfs:label 'Planned Grp' ;
    rdfs:comment 'Planned Gross Rating Points representing the total reach multiplied by frequency for the target audience.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedImpressions rdf:type rdf:Property ;
    rdfs:label 'Planned Impressions' ;
    rdfs:comment 'Total number of planned impressions (ad exposures) for this media plan.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedReachPercent rdf:type rdf:Property ;
    rdfs:label 'Planned Reach Percent' ;
    rdfs:comment 'Planned percentage of the target audience reached at least once during the planning period.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Spend Amount' ;
    rdfs:comment 'Total planned media spend amount for this media plan in the base currency.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the period covered by this media plan.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this media plan.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mediaSpendId rdf:type rdf:Property ;
    rdfs:label 'Media Spend Id' ;
    rdfs:comment 'Unique identifier for the media spend transaction record. Primary key for the media spend data product.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agencyFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Agency Fee Amount' ;
    rdfs:comment 'The agency service fee or commission charged for managing the media buy.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyType rdf:type rdf:Property ;
    rdfs:label 'Buy Type' ;
    rdfs:comment 'The method by which the media inventory was purchased (e.g., Programmatic, Direct, Auction, Guaranteed).' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clicksDelivered rdf:type rdf:Property ;
    rdfs:label 'Clicks Delivered' ;
    rdfs:comment 'The total number of clicks generated by the media placement for this spend transaction.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpcActual rdf:type rdf:Property ;
    rdfs:label 'Cpc Actual' ;
    rdfs:comment 'The actual cost per click (CPC) achieved for this media spend, calculated as working spend divided by clicks delivered.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpmActual rdf:type rdf:Property ;
    rdfs:label 'Cpm Actual' ;
    rdfs:comment 'The actual cost per thousand impressions (CPM) achieved for this media spend, calculated as (working spend / impressions) * 1000.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpvActual rdf:type rdf:Property ;
    rdfs:label 'Cpv Actual' ;
    rdfs:comment 'The actual cost per video view (CPV) achieved for this media spend, calculated as working spend divided by video views delivered.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Impressions Delivered' ;
    rdfs:comment 'The total number of ad impressions delivered for this spend transaction.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoicedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Spend Amount' ;
    rdfs:comment 'The total amount invoiced by the media owner or agency for this media spend transaction.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketName rdf:type rdf:Property ;
    rdfs:label 'Market Name' ;
    rdfs:comment 'The name of the specific market or Designated Market Area (DMA) where the media was placed (e.g., New York, Los Angeles, London).' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaOwnerName rdf:type rdf:Property ;
    rdfs:label 'Media Owner Name' ;
    rdfs:comment 'The name of the media owner or publisher that provided the advertising inventory (e.g., Google, Meta, NBC Universal).' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonWorkingSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Non Working Spend Amount' ;
    rdfs:comment 'The portion of invoiced spend allocated to agency fees, production costs, and other non-media expenses (non-working media).' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date on which the invoice for this media spend was paid.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Production Cost Amount' ;
    rdfs:comment 'The cost of creative production, ad serving, and other production-related expenses included in this spend transaction.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciled Timestamp' ;
    rdfs:comment 'The timestamp when this media spend record was reconciled against the media plan and delivery metrics.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'The current reconciliation status of this spend transaction against the media plan and delivery metrics.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendDate rdf:type rdf:Property ;
    rdfs:label 'Spend Date' ;
    rdfs:comment 'The date on which the media spend was incurred or invoiced.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spendPeriod rdf:type rdf:Property ;
    rdfs:label 'Spend Period' ;
    rdfs:comment 'The fiscal or calendar period (e.g., 2024-Q1, 2024-03) to which this spend is allocated for reporting purposes.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceToPlanAmount rdf:type rdf:Property ;
    rdfs:label 'Variance To Plan Amount' ;
    rdfs:comment 'The difference between invoiced spend and planned spend (invoiced minus planned), indicating over- or under-spend.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoViewsDelivered rdf:type rdf:Property ;
    rdfs:label 'Video Views Delivered' ;
    rdfs:comment 'The total number of video views or completions delivered for video media placements.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workingSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Working Spend Amount' ;
    rdfs:comment 'The portion of invoiced spend that directly purchased media inventory (working media), excluding agency fees and production costs.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentAssetCreativeAssetId rdf:type rdf:Property ;
    rdfs:label 'Parent Asset Creative Asset Id' ;
    rdfs:comment 'Identifier of the parent creative asset if this asset is a derivative, localized version, or variant of another asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeAsset .

ind:actualPublishDate rdf:type rdf:Property ;
    rdfs:label 'Actual Publish Date' ;
    rdfs:comment 'Actual date when the creative asset was published or went live.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetCode rdf:type rdf:Property ;
    rdfs:label 'Asset Code' ;
    rdfs:comment 'Unique business identifier or code assigned to the creative asset for tracking and reference purposes.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable name or title of the creative asset (e.g., \'Spring Campaign Hero Banner\', \'Product Launch Video 30s\').' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Classification of the creative asset by media type (video, image, audio, document, HTML, social post, email template). [ENUM-REF-CANDIDATE: video|image|audio|document|html|social_post|email_template — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Status' ;
    rdfs:comment 'Status of regulatory and legal compliance review for the creative asset (not required, pending, approved, rejected).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentCategory rdf:type rdf:Property ;
    rdfs:label 'Content Category' ;
    rdfs:comment 'Business category or use case of the creative asset (TV commercial, digital banner, social media, print ad, packaging visual, influencer brief, blog post, email content, landing page, infographic). [ENUM-REF-CANDIDATE: tv_commercial|digital_banner|social_media|print_ad|packaging_visual|influencer_brief|blog_post|email_content|landing_page|infographic — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentFormat rdf:type rdf:Property ;
    rdfs:label 'Content Format' ;
    rdfs:comment 'Specific file format or content format of the asset (e.g., MP4, JPEG, PNG, PDF, GIF, HTML5).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentStatus rdf:type rdf:Property ;
    rdfs:label 'Content Status' ;
    rdfs:comment 'Current publishing lifecycle status of the creative asset (planned, scheduled, published, archived, withdrawn).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssetDescription rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Description' ;
    rdfs:comment 'Detailed textual description of the creative asset content, purpose, and key messaging.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Dam Reference Code' ;
    rdfs:comment 'Unique identifier or reference code in the Digital Asset Management system where the asset is stored.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the creative asset file in bytes.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:heightPixels rdf:type rdf:Property ;
    rdfs:label 'Height Pixels' ;
    rdfs:comment 'Height dimension of the creative asset in pixels (applicable to images, videos, and display ads).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isMasterVersion rdf:type rdf:Property ;
    rdfs:label 'Is Master Version' ;
    rdfs:comment 'Flag indicating whether this is the master or primary version of the creative asset (True) or a derivative/variant (False).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords or tags associated with the creative asset for search and discovery purposes.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedPublishDate rdf:type rdf:Property ;
    rdfs:label 'Planned Publish Date' ;
    rdfs:comment 'Planned or scheduled date for the creative asset to be published or go live.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publishingChannel rdf:type rdf:Property ;
    rdfs:label 'Publishing Channel' ;
    rdfs:comment 'Primary channel or platform where the creative asset is published or distributed (e.g., \'Facebook\', \'Instagram\', \'YouTube\', \'Website\', \'Email\', \'TV\').' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Rights Expiry Date' ;
    rdfs:comment 'Date when the usage rights or licensing for the creative asset expire.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageLocationUrl rdf:type rdf:Property ;
    rdfs:label 'Storage Location Url' ;
    rdfs:comment 'Full URL or file path where the creative asset is stored in the DAM or content repository.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'URL of the thumbnail or preview image for the creative asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRights rdf:type rdf:Property ;
    rdfs:label 'Usage Rights' ;
    rdfs:comment 'Description of usage rights, licensing terms, or restrictions governing how the creative asset may be used (e.g., \'Global rights\', \'North America only\', \'Digital channels only\').' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthPixels rdf:type rdf:Property ;
    rdfs:label 'Width Pixels' ;
    rdfs:comment 'Width dimension of the creative asset in pixels (applicable to images, videos, and display ads).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeLower rdf:type rdf:Property ;
    rdfs:label 'Age Range Lower' ;
    rdfs:comment 'Lower bound of the age range for consumers in this segment (in years). Null if age is not a defining characteristic.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeUpper rdf:type rdf:Property ;
    rdfs:label 'Age Range Upper' ;
    rdfs:comment 'Upper bound of the age range for consumers in this segment (in years). Null if age is not a defining characteristic.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageBasketSizeUsd rdf:type rdf:Property ;
    rdfs:label 'Average Basket Size Usd' ;
    rdfs:comment 'Average transaction or basket size in USD for consumers in this segment, used for campaign ROI modeling.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandAffinity rdf:type rdf:Property ;
    rdfs:label 'Brand Affinity' ;
    rdfs:comment 'Brands or brand categories that this segment shows strong preference or loyalty toward. Used for brand-specific campaign targeting.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Cltv Estimate Usd' ;
    rdfs:comment 'Estimated Customer Lifetime Value in USD for consumers in this segment, used for prioritization and investment decisions.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentPreference rdf:type rdf:Property ;
    rdfs:label 'Content Preference' ;
    rdfs:comment 'Types of marketing content that resonate with this segment (e.g., educational, promotional, user-generated, influencer, video).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalEngagementLevel rdf:type rdf:Property ;
    rdfs:label 'Digital Engagement Level' ;
    rdfs:comment 'Level of digital channel engagement and activity for consumers in this segment (social media, email, mobile app, e-commerce).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBracket rdf:type rdf:Property ;
    rdfs:label 'Income Bracket' ;
    rdfs:comment 'Income level classification for consumers in this segment, used for targeting and media planning.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innovationAdoptionProfile rdf:type rdf:Property ;
    rdfs:label 'Innovation Adoption Profile' ;
    rdfs:comment 'Consumer adoption curve classification for new product launches and innovations (based on Rogers Diffusion of Innovations theory).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyCharacteristics rdf:type rdf:Property ;
    rdfs:label 'Key Characteristics' ;
    rdfs:comment 'Defining behavioral, demographic, or psychographic characteristics that distinguish this segment from others.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Date' ;
    rdfs:comment 'Date when the segment definition, size estimate, or characteristics were last updated or recalculated.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:messagingTonePreference rdf:type rdf:Property ;
    rdfs:label 'Messaging Tone Preference' ;
    rdfs:comment 'Preferred messaging tone and style for communications to this segment (e.g., aspirational, practical, humorous, authoritative).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScoreAverage rdf:type rdf:Property ;
    rdfs:label 'Nps Score Average' ;
    rdfs:comment 'Average Net Promoter Score for consumers in this segment, indicating brand loyalty and advocacy potential.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Price Sensitivity Level' ;
    rdfs:comment 'Degree of price sensitivity and responsiveness to promotions and discounts for consumers in this segment.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionResponsiveness rdf:type rdf:Property ;
    rdfs:label 'Promotion Responsiveness' ;
    rdfs:comment 'Level of responsiveness to trade promotions, coupons, and special offers for consumers in this segment.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseFrequencyProfile rdf:type rdf:Property ;
    rdfs:label 'Purchase Frequency Profile' ;
    rdfs:comment 'Typical purchase frequency behavior of consumers in this segment for relevant product categories.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCodes rdf:type rdf:Property ;
    rdfs:label 'Region Codes' ;
    rdfs:comment 'Comma-separated list of regional codes or identifiers where this segment is applicable (e.g., state, province, metro area codes).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentSizeEstimate rdf:type rdf:Property ;
    rdfs:label 'Segment Size Estimate' ;
    rdfs:comment 'Estimated number of consumers or households that belong to this segment based on the most recent segmentation analysis.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentSizePercentage rdf:type rdf:Property ;
    rdfs:label 'Segment Size Percentage' ;
    rdfs:comment 'Percentage of the total addressable consumer base that this segment represents.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentationMethodology rdf:type rdf:Property ;
    rdfs:label 'Segmentation Methodology' ;
    rdfs:comment 'Detailed methodology, algorithm, or analytical approach used to create this segment (e.g., RFM analysis, cluster analysis, decision tree).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentationModelType rdf:type rdf:Property ;
    rdfs:label 'Segmentation Model Type' ;
    rdfs:comment 'The methodology or model used to define this consumer segment (behavioral, psychographic, demographic, geographic, needs-based, or hybrid).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaPlatformPreference rdf:type rdf:Property ;
    rdfs:label 'Social Media Platform Preference' ;
    rdfs:comment 'Preferred social media platforms for consumers in this segment (e.g., Facebook, Instagram, TikTok, Twitter). Comma-separated list.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Tier' ;
    rdfs:comment 'Strategic importance ranking of this segment for marketing investment and campaign focus (tier 1 being highest priority).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityConsciousnessLevel rdf:type rdf:Property ;
    rdfs:label 'Sustainability Consciousness Level' ;
    rdfs:comment 'Level of environmental and sustainability awareness and preference for eco-friendly products within this segment.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetChannelAffinity rdf:type rdf:Property ;
    rdfs:label 'Target Channel Affinity' ;
    rdfs:comment 'Preferred marketing and sales channels for reaching this segment (e.g., digital, retail, DTC, social media, email). Comma-separated list of channel preferences.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketResearchStudyId rdf:type rdf:Property ;
    rdfs:label 'Market Research Study Id' ;
    rdfs:comment 'Unique identifier for the market research study or syndicated data subscription. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketResearchStudy .

ind:analysisCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Completion Date' ;
    rdfs:comment 'The date when the research analysis and reporting were finalized and delivered.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:averageBasketSize rdf:type rdf:Property ;
    rdfs:label 'Average Basket Size' ;
    rdfs:comment 'The average number of units or volume purchased per transaction by panel households during the measurement period.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandAwarenessPct rdf:type rdf:Property ;
    rdfs:label 'Brand Awareness Pct' ;
    rdfs:comment 'The percentage of respondents who demonstrated awareness of the brand, either aided or unaided, as measured in the brand health tracker.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandConsiderationPct rdf:type rdf:Property ;
    rdfs:label 'Brand Consideration Pct' ;
    rdfs:comment 'The percentage of respondents who would consider purchasing the brand, as measured in the brand health tracker.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandPreferencePct rdf:type rdf:Property ;
    rdfs:label 'Brand Preference Pct' ;
    rdfs:comment 'The percentage of respondents who prefer the brand over competitors, as measured in the brand health tracker.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'The business unit or division that commissioned and is responsible for the market research study (e.g., Skincare, Haircare, Home Care).' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerDemographics rdf:type rdf:Property ;
    rdfs:label 'Buyer Demographics' ;
    rdfs:comment 'Summary of the demographic profile of buyers identified in the consumer panel, including age, gender, income, household composition, and other relevant characteristics.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProviderName rdf:type rdf:Property ;
    rdfs:label 'Data Provider Name' ;
    rdfs:comment 'The name of the syndicated data provider for ongoing panel subscriptions or continuous measurement services.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldworkEndDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork End Date' ;
    rdfs:comment 'The date when data collection or fieldwork for the research study was completed.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkStartDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Start Date' ;
    rdfs:comment 'The date when data collection or fieldwork for the research study began.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:householdPenetrationPct rdf:type rdf:Property ;
    rdfs:label 'Household Penetration Pct' ;
    rdfs:comment 'The percentage of households in the target market that have purchased the brand or category during the measurement period, as reported by consumer panel data.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Findings Summary' ;
    rdfs:comment 'Executive summary of the key insights, findings, and actionable recommendations from the market research study.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'Detailed description of the research methodology employed, including sampling approach, data collection method (online survey, in-person interview, focus group, panel tracking), and analytical techniques.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseFrequency rdf:type rdf:Property ;
    rdfs:label 'Purchase Frequency' ;
    rdfs:comment 'The average number of purchase occasions per buying household during the measurement period, as reported by consumer panel data.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repeatRatePct rdf:type rdf:Property ;
    rdfs:label 'Repeat Rate Pct' ;
    rdfs:comment 'The percentage of buyers who made repeat purchases of the brand or product during the measurement period, indicating loyalty and retention.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:researchObjective rdf:type rdf:Property ;
    rdfs:label 'Research Objective' ;
    rdfs:comment 'The primary business objective or research question that the study was designed to address (e.g., measure brand health, test new product concept, understand usage barriers, track competitive dynamics).' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchType rdf:type rdf:Property ;
    rdfs:label 'Research Type' ;
    rdfs:comment 'The type or methodology of the market research study. Includes quantitative surveys, qualitative focus groups, usage and attitude (U&A) studies, concept testing, packaging tests, Net Promoter Score (NPS) surveys, brand health trackers, and consumer panel subscriptions. [ENUM-REF-CANDIDATE: quantitative|qualitative|usage_and_attitude|concept_test|pack_test|nps|brand_health_tracker|consumer_panel — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCode rdf:type rdf:Property ;
    rdfs:label 'Study Code' ;
    rdfs:comment 'The unique business identifier or project code assigned to the market research study for tracking and reference purposes.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Study Investment Amount' ;
    rdfs:comment 'The total financial investment or cost incurred for commissioning and conducting the market research study, including agency fees, fieldwork costs, and data licensing.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyName rdf:type rdf:Property ;
    rdfs:label 'Study Name' ;
    rdfs:comment 'The official name or title of the market research study or syndicated data subscription.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStatus rdf:type rdf:Property ;
    rdfs:label 'Study Status' ;
    rdfs:comment 'The current lifecycle status of the market research study. Tracks progression from planning through fieldwork, analysis, and completion.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionEndDate rdf:type rdf:Property ;
    rdfs:label 'Subscription End Date' ;
    rdfs:comment 'The end date or renewal date of the syndicated data subscription or continuous panel tracking service.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionStartDate rdf:type rdf:Property ;
    rdfs:label 'Subscription Start Date' ;
    rdfs:comment 'The start date of the syndicated data subscription or continuous panel tracking service.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:switchingBehaviorIndex rdf:type rdf:Property ;
    rdfs:label 'Switching Behavior Index' ;
    rdfs:comment 'A metric indicating the rate at which consumers switch between brands within the category, as measured by consumer panel data.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'The geographic market or region where the research study is being conducted (e.g., North America, Western Europe, APAC).' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandHealthTrackerId rdf:type rdf:Property ;
    rdfs:label 'Brand Health Tracker Id' ;
    rdfs:comment 'Unique identifier for the brand health tracking record.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCompetitorBrandMarketingBrandId rdf:type rdf:Property ;
    rdfs:label 'Primary Competitor Brand Marketing Brand Id' ;
    rdfs:comment 'Reference to the primary competing brand used for benchmarking.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingBrand .

ind:aidedAwarenessPct rdf:type rdf:Property ;
    rdfs:label 'Aided Awareness Pct' ;
    rdfs:comment 'Percentage of consumers who recognize the brand when prompted with a list of brands in the category.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandEquityIndex rdf:type rdf:Property ;
    rdfs:label 'Brand Equity Index' ;
    rdfs:comment 'Composite index score measuring overall brand strength combining awareness, consideration, preference, and loyalty metrics.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Brand Spend Amount' ;
    rdfs:comment 'Total advertising spend for this brand during the measurement period.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorSomValuePct rdf:type rdf:Property ;
    rdfs:label 'Competitor Som Value Pct' ;
    rdfs:comment 'Primary competitor share of market by value for benchmarking purposes.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorSovTotalPct rdf:type rdf:Property ;
    rdfs:label 'Competitor Sov Total Pct' ;
    rdfs:comment 'Primary competitor total share of voice for benchmarking purposes.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:considerationPct rdf:type rdf:Property ;
    rdfs:label 'Consideration Pct' ;
    rdfs:comment 'Percentage of consumers who would consider purchasing the brand.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:innovationPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Innovation Perception Score' ;
    rdfs:comment 'Consumer perception score for brand innovation attribute on a scale of 1-10.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSentimentScore rdf:type rdf:Property ;
    rdfs:label 'Net Sentiment Score' ;
    rdfs:comment 'Net sentiment score calculated as positive percentage minus negative percentage, ranging from -100 to +100.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferencePct rdf:type rdf:Property ;
    rdfs:label 'Preference Pct' ;
    rdfs:comment 'Percentage of consumers who prefer this brand over competitors in the category.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseIntentPct rdf:type rdf:Property ;
    rdfs:label 'Purchase Intent Pct' ;
    rdfs:comment 'Percentage of consumers who intend to purchase the brand in the next purchase cycle.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Quality Perception Score' ;
    rdfs:comment 'Consumer perception score for product quality attribute on a scale of 1-10.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shareOfConversationPct rdf:type rdf:Property ;
    rdfs:label 'Share Of Conversation Pct' ;
    rdfs:comment 'Brand share of total social media conversation volume within the category.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialMentionVolume rdf:type rdf:Property ;
    rdfs:label 'Social Mention Volume' ;
    rdfs:comment 'Total number of social media mentions for the brand during the tracking period.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialSentimentNegativePct rdf:type rdf:Property ;
    rdfs:label 'Social Sentiment Negative Pct' ;
    rdfs:comment 'Percentage of social media mentions with negative sentiment during the tracking period.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
