ind:governanceScore rdf:type rdf:Property ;
    rdfs:label 'Governance Score' ;
    rdfs:comment 'Score for the governance pillar of the ESG assessment.' ;
    rdfs:domain ind:SupplierEsgEval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallScoreCategory rdf:type rdf:Property ;
    rdfs:label 'Overall Score Category' ;
    rdfs:comment 'Categorical rating derived from the overall ESG score.' ;
