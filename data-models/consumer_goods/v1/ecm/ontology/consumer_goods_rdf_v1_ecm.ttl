    rdfs:range xsd:decimal .

ind:segmentationMethodology rdf:type rdf:Property ;
    rdfs:label 'Segmentation Methodology' ;
    rdfs:comment 'Detailed methodology, algorithm, or analytical approach used to create this segment (e.g., RFM analysis, cluster analysis, decision tree).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentationModelType rdf:type rdf:Property ;
    rdfs:label 'Segmentation Model Type' ;
    rdfs:comment 'The methodology or model used to define this consumer segment (behavioral, psychographic, demographic, geographic, needs-based, or hybrid).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaPlatformPreference rdf:type rdf:Property ;
    rdfs:label 'Social Media Platform Preference' ;
    rdfs:comment 'Preferred social media platforms for consumers in this segment (e.g., Facebook, Instagram, TikTok, Twitter). Comma-separated list.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Tier' ;
    rdfs:comment 'Strategic importance ranking of this segment for marketing investment and campaign focus (tier 1 being highest priority).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityConsciousnessLevel rdf:type rdf:Property ;
    rdfs:label 'Sustainability Consciousness Level' ;
    rdfs:comment 'Level of environmental and sustainability awareness and preference for eco-friendly products within this segment.' ;
    rdfs:domain ind:ConsumerSegment ;
