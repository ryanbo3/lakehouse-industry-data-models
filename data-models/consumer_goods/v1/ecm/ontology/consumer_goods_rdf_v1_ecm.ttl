    rdfs:range xsd:string .

ind:regionCodes rdf:type rdf:Property ;
    rdfs:label 'Region Codes' ;
    rdfs:comment 'Comma-separated list of regional codes or identifiers where this segment is applicable (e.g., state, province, metro area codes).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentSizeEstimate rdf:type rdf:Property ;
    rdfs:label 'Segment Size Estimate' ;
    rdfs:comment 'Estimated number of consumers or households that belong to this segment based on the most recent segmentation analysis.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
