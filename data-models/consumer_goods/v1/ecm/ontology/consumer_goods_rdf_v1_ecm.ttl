    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingRegion rdf:type rdf:Property ;
    rdfs:label 'Sourcing Region' ;
    rdfs:comment 'Three-letter ISO country code of the region where the commodity originates.' ;
    rdfs:domain ind:DeforestationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityLevel rdf:type rdf:Property ;
    rdfs:label 'Traceability Level' ;
    rdfs:comment 'Depth of traceability achieved for the commodity (e.g., farm-level, mill-level).' ;
