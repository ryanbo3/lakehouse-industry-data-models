    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentageOfTarget rdf:type rdf:Property ;
    rdfs:label 'Percentage Of Target' ;
    rdfs:comment 'Actual value expressed as a percentage of the target value.' ;
