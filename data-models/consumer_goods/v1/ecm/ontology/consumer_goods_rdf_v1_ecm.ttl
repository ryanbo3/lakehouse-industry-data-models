ind:beneficiaryGroup rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Group' ;
    rdfs:comment 'Target group of beneficiaries for the program. [ENUM-REF-CANDIDATE: children|women|youth|elderly|farmers|employees|communities|students — promote to reference product]' ;
