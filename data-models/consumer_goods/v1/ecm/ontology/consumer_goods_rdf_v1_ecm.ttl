    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerHouseholdSize rdf:type rdf:Property ;
    rdfs:label 'Buyer Household Size' ;
    rdfs:comment 'Number of people in the buying household.' ;
