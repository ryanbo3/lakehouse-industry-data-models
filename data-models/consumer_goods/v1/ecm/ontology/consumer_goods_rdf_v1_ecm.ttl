    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaSubchannel rdf:type rdf:Property ;
    rdfs:label 'Media Subchannel' ;
    rdfs:comment 'Detailed subchannel or platform within the primary media channel (e.g., Facebook, Google Display, National TV, Local Radio).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Unique business identifier or code for the media plan used for external reference and tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Business-friendly name or title of the media plan document.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the media plan indicating its approval and execution state.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the media plan by planning horizon and purpose.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version number of this media plan document to track revisions and iterations.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedCpm rdf:type rdf:Property ;
    rdfs:label 'Planned Cpm' ;
    rdfs:comment 'Planned cost per thousand impressions for this media investment.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCpp rdf:type rdf:Property ;
    rdfs:label 'Planned Cpp' ;
    rdfs:comment 'Planned cost per rating point for broadcast media investments.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedFrequency rdf:type rdf:Property ;
    rdfs:label 'Planned Frequency' ;
    rdfs:comment 'Planned average number of times the target audience will be exposed to the media message.' ;
