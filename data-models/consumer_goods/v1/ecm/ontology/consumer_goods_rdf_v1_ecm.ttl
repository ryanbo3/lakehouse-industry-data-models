    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationValidUntil rdf:type rdf:Property ;
    rdfs:label 'Certification Valid Until' ;
    rdfs:comment 'Expiration date of the supplier\'s sustainability certification.' ;
