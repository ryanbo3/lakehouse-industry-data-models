ind:waterSavingsCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Water Savings Cubic Meters' ;
    rdfs:comment 'Volume of water saved (in cubic meters) attributable to the initiative.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitmentProgressId rdf:type rdf:Property ;
    rdfs:label 'Commitment Progress Id' ;
    rdfs:comment 'Primary key for commitment_progress' ;
