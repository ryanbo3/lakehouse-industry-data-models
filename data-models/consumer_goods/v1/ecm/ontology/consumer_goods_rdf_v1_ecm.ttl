ind:productLcaStatus rdf:type rdf:Property ;
    rdfs:label 'Product Lca Status' ;
    rdfs:comment 'Lifecycle status of the LCA record within the data product.' ;
    rdfs:domain ind:ProductLca ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDate rdf:type rdf:Property ;
    rdfs:label 'Study Date' ;
    rdfs:comment 'Date when the LCA study was completed or officially recorded.' ;
