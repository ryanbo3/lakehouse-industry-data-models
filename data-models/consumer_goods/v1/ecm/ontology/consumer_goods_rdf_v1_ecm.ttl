    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:systemBoundaryDescription rdf:type rdf:Property ;
    rdfs:label 'System Boundary Description' ;
    rdfs:comment 'Narrative description of the life-cycle stages included in the assessment.' ;
    rdfs:domain ind:ProductLca ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterFootprintLiters rdf:type rdf:Property ;
    rdfs:label 'Water Footprint Liters' ;
    rdfs:comment 'Total freshwater consumption per functional unit expressed in litres.' ;
