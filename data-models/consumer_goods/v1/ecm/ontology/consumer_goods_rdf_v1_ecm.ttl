    rdfs:comment 'Other sustainability certifications applicable to the packaging (e.g., RSPO, ISO 14001).' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonFootprintKgCo2e rdf:type rdf:Property ;
    rdfs:label 'Carbon Footprint Kg Co2e' ;
    rdfs:comment 'Estimated greenhouse-gas emissions associated with the packaging, expressed in kilograms CO₂-equivalent.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compostable rdf:type rdf:Property ;
    rdfs:label 'Compostable' ;
    rdfs:comment 'True if the packaging holds a recognized compostability certification.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designVersion rdf:type rdf:Property ;
    rdfs:label 'Design Version' ;
    rdfs:comment 'Version identifier for the packaging design (e.g., "v2.1").' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endOfLifeDisposalMethod rdf:type rdf:Property ;
    rdfs:label 'End Of Life Disposal Method' ;
    rdfs:comment 'Designated disposal route for the packaging after consumer use.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyUsageKwh rdf:type rdf:Property ;
    rdfs:label 'Energy Usage Kwh' ;
    rdfs:comment 'Electrical energy consumed to manufacture the packaging component.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:euPackagingWasteComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Eu Packaging Waste Compliance Status' ;
    rdfs:comment 'Compliance status with the EU Packaging and Packaging Waste Regulation.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lightweightingReductionPercent rdf:type rdf:Property ;
