    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationActionRequired rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Required' ;
    rdfs:comment 'Indicates whether corrective remediation actions are required based on the assessment outcome.' ;
    rdfs:domain ind:DeforestationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAssessmentDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Document Url' ;
    rdfs:comment 'Link to the detailed assessment report or supporting documentation.' ;
    rdfs:domain ind:DeforestationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentMethodologyVersion rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Methodology Version' ;
    rdfs:comment 'Version of the risk assessment methodology used.' ;
    rdfs:domain ind:DeforestationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreUnit rdf:type rdf:Property ;
    rdfs:label 'Risk Score Unit' ;
    rdfs:comment 'Unit of measurement for the risk score, typically \'percentage\'.' ;
